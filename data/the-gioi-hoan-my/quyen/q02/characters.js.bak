/* characters q02 (67 mục) — cân xếp hạng toàn cảnh Thạch Hạo */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["the-gioi-hoan-my"]=window.__LIBQ["the-gioi-hoan-my"]||{};window.__LIBQ["the-gioi-hoan-my"]["q02"]=window.__LIBQ["the-gioi-hoan-my"]["q02"]||{};window.__LIBQ["the-gioi-hoan-my"]["q02"]["characters"]={"updatedAt":"2026-07-04","count":67,"chars":[{"id":"thach-hao","name":"Thạch Hạo","aliases":["Nhóc tỳ","Hạo Thiên","Tiểu sư đệ","Nhóc siêu quậy","Tên nhóc siêu quậy ở Hư Thần giới","Nhân thần cộng phẫn","Tiểu tử","Tiểu ca ca","Bóng Lông","Tiểu mập mạp","Ca ca của Thanh Phong","thằng nhóc quỷ","Thằng bé hung tàn","Tiểu ma vương","Tiểu sư đệ Bổ Thiên các"],"gioiTinh":"nam","canhGioiCaoNhat":"Đệ lục Động Thiên (@c0105)","trangThai":"song","tabs":{"diem":[{"text":"Trời sinh Chí Tôn cốt (Nguyên thủy bảo cốt cực hiếm), ba tuổi rưỡi đã có thể lực áp đảo, nâng bổng đỉnh đồng ngàn cân","chuong":"@c0056"},{"text":"Bị Lục tẩu và Thạch Nghị moi mất Chí Tôn cốt, thoi thóp bên bờ sinh tử rồi ngộ đạo tái sinh nhờ Nguyên Thủy Chân Giải","chuong":"@c0063"},{"text":"Sáu tuổi chỉ bằng sức cơ bắp nâng cự thạch ba mươi ngàn cân bước vào đỉnh cao Bàn Huyết, sau khổ tu một tay nâng nổi mười vạn tám ngàn cân","chuong":"@c0066"},{"text":"Đột phá Động Thiên cảnh, mở liền ba Động Thiên khi lột xác — điều chưa từng có","chuong":"@c0082"},{"text":"Đánh bại và thu phục Sư Tử chín đầu, đoạt Ấu Thần từ vòng vây các thế lực tại Thần Quật","chuong":"@c0125"},{"text":"Hạ Vũ Tử Mạch bằng tia chớp vàng và cối xay bạc, đối đầu bốn cường giả Vũ tộc","chuong":"@c0129"}],"kinhLich":[{"text":"Chìm đáy sông tu hành suốt đêm, luyện hóa dược tính Hắc Sát Liên thành hỏa diễm đen rèn gân cốt, mở ra khẩu thứ sáu Động Thiên khi mới 9 tuổi rưỡi, thực lực tăng vọt.; Trở lại chiến trường tan hoang sau thú triều để đoạt thêm Bổ Thiên thạch, Nhóc tỳ ẩn thân quan sát; chính là đứa nhỏ mà Tiêu Thiên từng đánh lén một chưởng và kiêng kỵ. Khi Tiêu Thiên đứng thứ nhất trong hơn chín vạn người vẫn bất an, Nhóc tỳ từ cây gỗ khô sau lưng nứt ra, dùng Bạ…","anchor":"Đến lúc này, nó mở ra khẩu thứ sáu Động Thiên, thực lực lại lần nữa tăng lên một đoạn","bridge":true,"khoang":"@c0101"},{"text":"Nhóc tỳ dùng Bạch cốt đại bổng đánh lén Tiêu Thiên ngất, báo thù việc từng bị đánh lén lúc bị Cổ Ngạc đuổi giết; lục soát lấy 25 khối Bổ Thiên thạch cùng 2 bình bảo đan (bổ tinh huyết + trị trọng thương); về sau vì Bổ Thiên thạch đã mất hiệu lực sau bạo động khu thứ tám nên đánh lén Tiêu Thiên lần 2 rồi ném trả bao Bổ Thiên thạch, dặn cả vốn lẫn lời phải hoàn lại; cuối cùng nhặt lại một Đế tử bị bỏ sót rồi cô đơn đi về khu thứ tám.","anchor":"Ngươi cũng dám đánh lén ta nữa àh... Thôi coi như huề nhau vậy.","bridge":true,"khoang":"@c0102"},{"text":"Khắc hàng chữ chứng minh từng tới rồi đánh xuyên tấm chắn phù văn khu thứ tám, chiếm tổ hung cầm trên cổ thụ để ngủ; sáng ra moi tin từ hai huynh muội, biết Bổ Thiên Các bày thiên la địa võng phong tỏa chiến trường thứ hai để bắt mình và cho người ngoài xem lễ; tặng huynh muội Long Tán và Hổ Dược lột từ thiếu niên áo bạc; đắc ý lẫn vào ba nghìn người vượt ải để vào chiến trường thứ hai.; Khắc lên tảng đá cứng hàng chữ tự lập danh hiệu rồi đánh x…","anchor":"Nhóc tỳ đánh xuyên tấm chắn phù văn của khu thứ tám","bridge":true,"khoang":"@c0103"},{"chuong":"@c0103","importance":"normal","tieuDe":"Khắc chữ lưu danh, chiếm tổ chim, trà trộn vượt ải","text":"Không cam lòng rời đi, nhóc tỳ khắc lên tảng đá cứng dòng chữ về thần vũ và búa để lưu danh, đánh xuyên tấm chắn phù văn khu thứ tám rồi trèo cổ thụ đuổi hung cầm chiếm tổ chim ngủ; sáng hôm sau gặp hai huynh muội, dò tin biết Bổ Thiên Các phong tỏa chiến trường thứ hai để bắt mình, cười ha ha; tặng hai huynh muội Long Tán và Hổ Dược lột từ Tiêu Thiên rồi trà trộn tổ đội mấy trăm người vượt ải vào chiến trường thứ hai","anchor":"khắc lên đó một hàng chữ: Thần vũ ngút trời, quang minh chính đại"},{"chuong":"@c0105","importance":"normal","tieuDe":"Ăn sống Hắc Sát Liên đột phá đệ lục Động Thiên","text":"Trộm và nhai ngấu nghiến Hắc Sát Liên của Bổ Thiên các như củ cà rốt (chỉ hấp thu ~3 thành, ăn cả gốc khiến bảo dược không sống lại) để đột phá đệ lục Động Thiên; giấu 18 bộ bảo cốt (bị tìm ra 6), đổi hình dạng trà trộn trong ba ngàn đệ tử để lẩn trốn.; Trộm rồi nhai ngấu nghiến cả gốc Hắc Sát Liên như củ cà rốt để đột phá đệ lục Động Thiên, chỉ hấp thu khoảng ba thành dược liệu khiến bảo dược không thể sống lại; sau đó giấu tổng cộng mười tám b…","anchor":"chỉ là để đột phá đệ lục Động Thiên mà thôi"},{"text":"Tảng đá Tế Linh mang chữ khiêu khích 「Nắm Búa Nơi Tay, Ta Có Thiên Hạ」 do chính nó để lại được đưa lên trước ba ngàn tân đệ tử; Hùng Phi trưởng lão phát lệnh truy nã Nhóc siêu quậy ngay trong nội bộ môn phái, treo thưởng đệ tử trọng yếu nhất; Thạch Hạo trốn vào sâu trong đám người, cùng hô lớn 'bắt lấy tên nhóc này' để che giấu thân phận.; Đã thay đổi hình dạng thành mập ục ịch, giả khóc bám vào một cụ già xa lạ để trà trộn vào ba ngàn thiếu niê…","anchor":"Nắm Búa Nơi Tay, Ta Có Thiên Hạ","bridge":true,"khoang":"@c0106"},{"chuong":"@c0106","importance":"normal","tieuDe":"Trà trộn nhập môn Bổ Thiên các","text":"Giả khóc bám vào một cụ già xa lạ để trà trộn vào ba ngàn thiếu niên nhập môn Bổ Thiên các, an ủi xong lập tức ngừng khóc bỏ đi; quấy nhiễu dò hỏi về con gái Nhân Hoàng và Trùng Đồng giả (những nhân vật lai lịch lớn đã rời đi sớm).","anchor":"trên mặt ngay cả một giọt nước mắt cũng không có, xoay người rời đi"},{"chuong":"@c0106","importance":"normal","tieuDe":"Phát hiện Thanh Phong bị thương","text":"Được an trí tại khu núi đá, học văn tự Hoàn Cốt; mấy ngày không thấy Bóng Lông, vô tình thấy Thanh Phong trên người có máu ứ đọng nên âm thầm nắm chặt nắm đấm, quyết không mặc kệ vì thân như anh em ruột.","anchor":"tiểu Thanh Phong trên người bị thương, có máu ứ đọng lại"},{"chuong":"@c0106","importance":"normal","tieuDe":"Trà trộn nhập môn Bổ Thiên các","text":"Đã thay đổi hình dạng thành mập ục ịch, giả khóc bám vào một cụ già xa lạ để trà trộn vào ba ngàn đệ tử nhập môn, an ủi xong lập tức ngừng khóc bỏ đi; quấy nhiễu dò hỏi về Tổ sư, con gái Nhân Hoàng và Trùng Đồng giả.","anchor":"trên mặt ngay cả một giọt nước mắt cũng không có, xoay người rời đi"},{"chuong":"@c0106","importance":"major","tieuDe":"Thành tội phạm truy nã trong môn phái","text":"Chữ khiêu khích do chính nó để lại trên tảng đá Tế Linh bị đưa lên khiến ba ngàn người nhận ra tên nhóc siêu quậy khét tiếng; Hùng Phi phát lệnh truy nã ngay trong nội bộ, nó phải trốn vào sâu đám đông cùng hô bắt chính mình; cuối cùng lại bị chính Hùng Phi và Trác Vân — hai trưởng lão nó từng chọc đến hộc máu — chọn làm đệ tử.","anchor":"đám nhỏ này do ta cùng Trác Vân mang đi"},{"chuong":"@c0106","importance":"normal","tieuDe":"Nổi giận vì Thanh Phong bị thương","text":"Học văn tự Hoàn Cốt do hai trưởng lão giảng; mấy ngày không thấy Bóng Lông; vô tình thấy Thanh Phong trên người bị thương có máu ứ đọng, âm thầm nắm chặt nắm đấm, nghi bị khi dễ, dằn lòng cẩn thận vì đang ở Bổ Thiên các nhưng quyết hỏi cho ra lẽ.","anchor":"tiểu Thanh Phong trên người bị thương, có máu ứ đọng lại"},{"text":"Làm đệ tử mới Bổ Thiên các phải lao động khổ cực (xách nước tưới vườn thuốc, khai thác quặng tinh kim), bất mãn việc học chậm; biết Thanh Phong bị bắt nạt liền vạch kế trả thù, phát hiện chỗ dựa của bọn thiếu niên là thiên tài họ Vũ (nghi Vũ tộc ở Thạch Quốc), tính lôi kéo Thạch Nghị và chờ hai ngày sau thiên tài doanh tới mới ra tay.","anchor":"còn có chỗ dựa đằng sau là thiên tài họ Vũ","bridge":true,"khoang":"@c0107"},{"text":"Trốn trong đám đệ tử quan sát, thấy Thanh Phong bị ám toán thì ánh mắt lạnh; khao khát cho Bóng Lông vào Tàng Kinh các; sau đấm Chu Vũ Hào nở hoa mặt rồi hô hoán vu hắn là đồng bọn nhóc siêu quậy, kích động mấy trăm đệ tử mới đuổi đánh hắn đến răng bay hộc máu.","anchor":"bị một thằng nhóc con một quyền oanh ở trên mặt","bridge":true,"khoang":"@c0108"},{"text":"Thạch Hạo trà trộn trong đám đệ tử mới, hô hào kích động phản kháng, ra quyền đầu tiên và ra tay trọng thương ba người rồi lui về sau đắc ý, biến vụ Chu Vũ Hào bị đánh hội đồng thành nội chiến hơn ba ngàn người; sau đó nháy mắt tươi vui với Thanh Phong, tò mò hỏi về hồ lô Tế Linh, rồi đi khắp Bổ Thiên các nhìn thấy Thạch Nghị bước trên con đường vào Thượng Cổ Thánh Viện.; Trà trộn trong đám đệ tử mới, Thạch Hạo là kẻ kêu gào đầu, ra quyền đầu, d…","anchor":"người kêu gào đầu tiên tự nhiên là nó, người đánh một quyền cũng là nó, thời khắc mấu chốt ra tay trọng thương ba người kia cũng vẫn là nó","bridge":true,"khoang":"@c0109"},{"text":"Từ bỏ ý định vào Thượng Cổ Thánh Viện (mấy chục đến mấy trăm năm mới mở một lần cho một người, lần này chọn Thạch Nghị), nhóc tỳ nắm đuôi Bóng Lông lẻn vào khu vườn cổ hơn trăm dặm nơi Tế Linh ở ẩn; phát hiện vùng đất bị hút địa khí hóa sa mạc và thấy rõ Tế Linh của Bổ Thiên các là giàn dây hồ lô ố vàng ốm yếu; ngồi tu quán tưởng Nguyên Thủy Chân Giải thì lĩnh ngộ dễ dàng hơn nhờ Phù Văn hồ lô xanh lấp loé thiên địa đạo âm; khi rời đi chạm mặt l…","anchor":"Đây là nơi thần bí nhất của Bổ Thiên các, là nơi Tế Linh ở ẩn, có diện tích hơn trăm dặm","bridge":true,"khoang":"@c0110"},{"text":"Tại nơi ở Tế Linh trong Thượng Cổ Tịnh Thổ, Thạch Hạo bị một ông lão tử khí Thượng Cổ cản đường, tái tạo từ hư không mỗi khi bị né; cầu cứu Tế Linh bất thành, hồ lô vỏ xanh phát khí Hỗn Độn đẩy lui; ông lão đòi “Trả kiếm cho ta”, nó hứa sau này trả khiến trời đất biến sắc; sáu ngày sau ông lão hiện lần hai náo loạn các đệ tử; cuối cùng nó hết sợ, cưỡi lên cổ ông lão tóc xám.; Bị ông lão tử khí Thượng Cổ cắm cổ kiếm trên đầu liên tục cản đường tạ…","anchor":"lúc này nó lại cưỡi ở trên cổ ông lão tóc xám","bridge":true,"khoang":"@c0111"},{"text":"Giấu thân phận, cưỡi trên cổ vị thần quái Thượng Cổ bị kiếm đâm xuyên đầu, dùng đỉnh đồng gõ để nhổ thanh cổ kiếm mà nó tưởng là Bảo Cụ chí cường, định chiếm luôn; khi trưởng lão tới bèn ôm chặt kiếm đề phòng, rồi nghe chân tướng Tử Thần liền hoảng bám lấy trưởng lão suýt bóp Hùng Phi tắt thở, và biết mình phải đi Bách Đoạn sơn tìm kiếm thật của Tử Thần nếu không sẽ chết.; Cưỡi trên cổ vị thần quái Thượng Cổ bị kiếm đâm xuyên đầu, dùng đỉnh đồng…","anchor":"Lão bá, thanh kiếm trên đầu bác nhất định là Bảo Cụ chí cường","bridge":true,"khoang":"@c0112"},{"text":"Bốn lão già mắt ánh xanh của Bổ Thiên các thử thân thể nhóc tỳ, nó phản kích đấm trúng một lão gây tiếng sấm rền chấn động cung điện, được khen thân thể nghịch thiên; Hùng Phi chợt nhận ra nó chính là “thằng nhóc quỷ” từng gây loạn khiến hắn và Trác Vân khốn đốn — thân phận bại lộ; nó bị các nguyên lão du thuyết rồi ép vào Bách Đoạn sơn tìm Bất Lão thần tuyền (thưởng khắc Bất Hủ Thần Bi + vào Tàng Kinh các chọn Bảo Thuật), còn trộm ăn Tuyết Ngọc…","anchor":"Ngươi... Ngươi chính là thằng nhóc quỷ kia?!","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Bại lộ thân phận, nhận nhiệm vụ Bách Đoạn sơn","text":"Bị các nguyên lão Bổ Thiên các du thuyết vào Bách Đoạn sơn, mặc cả đòi chỗ tốt và tuyên bố muốn bắt một con Kim Sí Đại Bằng non khiến cả đoàn cứng đơ; bị bốn lão già mắt ánh xanh thử thân thể, nó phản kích đấm trúng một lão gây tiếng sấm chấn động cung điện, được khen thân thể nghịch thiên; Hùng Phi nhận ra nó chính là ‘thằng nhóc quỷ’ từng gây loạn — thân phận bại lộ; nhận nhiệm vụ tìm Bất Lão thần tuyền mang về; trộm ăn Tuyết Ngọc Sâm rồi đổ cho Đào Dã ‘cho’; tặng một cây linh dược cho ‘đệ đệ’ Thanh Phong ở Thiên tài doanh, mở kèo đánh cược và bị thiếu nữ áo xanh khiêu chiến.","anchor":"quả nhiên đủ mạnh, thân thể như vậy cũng có thể xem như nghịch thiên rồi"},{"text":"Bày trò “đổ chiến” cá cược với đám thiên tài ở Thiên tài doanh, buộc ai muốn đánh phải đặt chiến lợi phẩm xuống đất; dùng Phù Văn hai tay dệt búa bạc đánh tan Khổng Tước xanh của Ngạn Tâm rồi khống chế bắt sống nàng, tạo cối xay bạc nghiền tan chiến mâu của Phiêu Tuyết; đánh gục Chu Vũ Hào khiến hắn nhận ra thân phận; thắng liên tiếp 28 trận không ai địch nổi, chấn động toàn khu, tuyên bố công khai ai bắt nạt Thanh Phong là bắt nạt nó; sau đó dặ…","anchor":"Thanh Phong chính là đệ đệ của ta","bridge":true,"khoang":"@c0114"},{"text":"Theo đoàn Bổ Thiên các tới Đoạn Không thành trước khi Bách Đoạn sơn mở; hồn nhiên tham ăn đòi ăn thịt Bạch Hổ, thèm con Linh Tước năm màu; dò la thì phát hiện nhiều thế lực lớn muốn đối phó mình, có phe ra lệnh bắt sống (được làm mất tay chân nhưng phải giữ mạng), suy đoán kẻ săn mình phần lớn là gia tộc đã mất Xích Vũ Bảo Phiến và quyết vẫn tiến vào Bách Đoạn sơn.; Tại Đoạn Không thành, nhóc tỳ nghe ngóng rồi phải lét lút trốn vì nhiều thế lực…","anchor":"giống nhau đều là đối phó nhóc siêu quậy, bất quá yêu cầu này tương đối nghiêm khắc, nhất định phải bắt sống","bridge":true,"khoang":"@c0115"},{"text":"Cải trang thành nhóc tỳ trong đội năm thiên tài Bổ Thiên các tại Đoạn Không thành chờ vào Bách Đoạn sơn; chạm trán Thái Cổ di chủng Phì Di, né đòn quật đuôi rồi lớn tiếng cảnh cáo ngược khiến cả phố sững sờ, Phì Di cảm ứng được khí tức hung mãnh giống mình; giỡn cợt đánh mông sư tỷ khiến năm thiên tài đuổi đánh nhưng không dám truy trong thành; cuối chương Vũ tộc xác định tên thật của nó là Hạo Thiên và ra lệnh diệt trừ trong Bách Đoạn sơn.; Cải…","anchor":"nó tên là Hạo Thiên, hiện nay đã đến Đoạn Không thành","bridge":true,"khoang":"@c0116"},{"text":"Trong tiểu thế giới, nhóc tỳ săn đuổi Nhân Hùng một sừng để ăn thịt rồi đối đầu Hỏa Vân Tước đang trút mưa Hỏa văn; triệu khay bạc như Thần Nguyệt chắn nham thạch và lửa, dùng Ma Cầm thời Thái Cổ, tia chớp vàng cực tốc và vầng trăng bạc đả thương chim đỏ, chém rớt hơn hai mươi cân thịt; cả nhóm ăn thịt nhận ra là huyết nhục bảo dược, tinh khí lớn mạnh; khi sinh vật hình người ánh bạc phục kích đoạt bốn gốc Xích Lan, nhóc tỳ lao vào kéo sư huynh…","anchor":"Một khối thịt rớt ra, con chim rơi xuống cực nhanh.","bridge":true,"khoang":"@c0118"},{"text":"Đơn độc đấu sinh linh màu bạc (Thái Cổ di chủng, hậu duệ Vương tộc) tự xưng “Vương tương lai”; dùng chớp giật vàng cùng ba Bảo Cụ (Cốt Kính, Cốt Tiễn, quạt cướp được), triển bảo thuật Toan Nghê Vương, rút Cốt Tiễn vàng bẻ gãy chủy thủ bạc rồi chặt tay đối thủ; đuổi theo cắt cổ, đánh đầu thành tro; bi phẫn vì cây quạt bạc chiến lợi phẩm nát hơn nửa; sau đó không muốn ăn sinh linh hình người nên quyết đem di chủng đi trao đổi.; Hô lớn hỏi ai muốn…","anchor":"cánh tay trái của hắn bị cắt đứt, máu me tung tóe","bridge":true,"khoang":"@c0119"},{"text":"Trao đổi con sinh linh màu bạc (Linh Tộc) lấy Tử Vân Tâm theo quyết định của Hỏa Linh Nhi; bị đám thiên tài nhận ra là nhóc siêu quậy và vây bắt nên bỏ chạy vào rừng; sau vài ngày luyện hóa Tử Vân Tâm trong hang cổ, đột phá mở ra miệng Động Thiên thứ bảy, khí tức kinh khủng khiến mãnh thú chạy trốn; sau đó đánh chết sinh linh mọc sừng người của Vũ Vương và bắn mười tia chớp giết mấy Dị tộc còn lại; đồng ý gia nhập liên minh đi Thần Quật nhưng ôm thù muốn hầm con sư tử dị dạng, còn vỗ mông công chúa để trêu ngược.","anchor":"nhóc tỳ đột phá, mở ra trên người miệng Động Thiên thứ bảy","bridge":true,"khoang":"@c0120"},{"text":"Chạm mặt ba Thái Cổ di chủng cầm đầu — Hoàng Kim sư tử chín đầu, Ngân Huyết cự nhân, Vũ Vương; ba kẻ tranh nhau thu nhóc tỳ làm chiến sủng, nhóc tỳ từ chối và ngược lại đòi bắt chúng làm tôi tớ; đấm Ngân Huyết cự nhân chảy máu tay, đá Vũ Vương văng hộc máu, dùng bảo cốt Toan Nghê tế thành gương thi triển Nghịch chuyển phản đòn Sư Tử chín đầu; cuối cùng một mình đánh lui hai kẻ, ngang sức Sư Tử chín đầu; xác nhận đã ăn thịt Mộc Phong của Linh tộc…","anchor":"một người lại tấn công ba vị Thái Cổ di chủng, đánh lui hai người","bridge":true,"khoang":"@c0121"},{"chuong":"@c0121","importance":"normal","tieuDe":"Một mình đấu ba Thái Cổ di chủng tại Thần Quật","text":"Bị Hỏa Linh Nhi phun lửa hóa Chu Tước truy sát vì trò trêu ‘giảm béo’, nhóc tỳ bung Nguyệt bàn màu bạc chắn lửa; tới chân núi Thần Quật thì đối mặt ba Thái Cổ di chủng cầm đầu (Hoàng Kim sư tử chín đầu, Ngân Huyết cự nhân, Vũ Vương) tranh nhau thu nó làm chiến sủng. Nhóc tỳ từ chối, đấm Ngân Huyết cự nhân chảy máu tay, đá Vũ Vương văng hộc máu, rồi dùng bảo cốt Toan Nghê tế thành gương thi triển ‘Nghịch chuyển’ phản đòn Sư Tử chín đầu; một chọi ba đánh lui hai kẻ, ngang sức Sư Tử chín đầu. Nó còn thừa nhận đã ăn thịt Mộc Phong của Linh tộc và tuyên bố mục đích vào Bách Đoạn sơn là hàng phục một Thái cổ hung thú non.","anchor":"một người lại tấn công ba vị Thái Cổ di chủng, đánh lui hai người"},{"text":"Trên thảo nguyên Đại hoang, tuy cảnh giới thấp hơn Nhóc tỳ vẫn đại chiến ngang tài với Hoàng Kim sư tử, dùng bảo kính, Cốt Tiễn (Kim Giao tiễn), khay bạc, Bảo Thuật Toan Nghê và Thanh Lân Ưng; đây là lần đầu bị thương kể từ khi vào Tiểu Thế Giới; sau đó vận Nguyên Thủy Chân Giải cùng Chiến Thần Đồ Lục, tổ hợp Phù Văn thường hóa giải Vô Úy Sư Tử ấn rồi nhảy lên cưỡi trấn áp sư tử, do dự giữa làm thịt hay giữ làm thú cưỡi.","anchor":"Nhóc tỳ nhảy lên một cái, cưỡi trên người của Sư Tử chín đầu, nâng quyền lên mà đập mạnh, cực kỳ uy phong","bridge":true,"khoang":"@c0122"},{"text":"Cưỡi trấn áp và đánh bại Sư Tử chín đầu (Hoàng Kim sư tử), dùng Cốt Tiễn hóa hai giao long chém rụng bốn đầu lâu; hóa thân hải dương sấm sét chống ngang chín hạt niệm châu, khóe miệng rỉ máu; truy sát tới Thần Quật nhưng từ chối vào vì đòi vật cưỡi bị từ chối; hầm bốn đầu lâu sư tử với bốn cây linh dược thành lò bảo dược cùng sư huynh sư tỷ ăn, thất khiếu phát sáng; vừa mượn Tử Vân Tâm mở ra miệng Động Thiên thứ bảy nhưng chọn tạo cơ sở vững thay vì đột phá vội; sau đó cướp quả trứng vàng nghi hậu duệ Lang Thần rồi bỏ chạy đòi ăn.","anchor":"Nó vừa mượn Tử Vân Tâm để đột phá, mở ra miệng Động Thiên thứ bảy","bridge":true,"khoang":"@c0123"},{"text":"Ôm trứng thần màu vàng chạy trốn giữa đại thảo nguyên bạo động ban đêm, bị vô số cự lang cùng mấy chục Lang Vương hiểu Bảo Thuật truy sát; dùng Cốt Tiễn màu vàng phá vòng vây mở đường máu, đạp cốt kính bay cao rồi nhảy xuống sông cắt mùi; suy đoán trứng là hậu duệ Thần linh nên quyết định nhóm lửa nướng/luộc ăn, cuối cùng vỏ trứng vỡ ra ấp thành một thần linh non cuộn tròn trong lòng bàn tay.","anchor":"Nhóc tỳ vận dụng Cốt Tiễn màu vàng phá vòng vây mở ra một con đường máu xông về phương xa","bridge":true,"khoang":"@c0124"},{"text":"Đoạt Ấu Thần (hậu đại Lang Thần) từ vòng vây các thế lực, dùng Cốt Tiễn vàng kim chặt đứt một cánh tay Vũ Vương và đánh cháy đen tay Cự Nhân Ngân Huyết khiến cả đám rút lui; thí nghiệm điện giật sói con, dùng Tham Cốt pháp thăm dò cốt cách nhưng không thấy phù cốt/ấn ký; hỏi Hỏa Linh Nhi “có sữa không” bị đuổi đánh hai giờ; sau mấy ngày đại chiến thu phục Sư Tử chín đầu làm thú cưỡi kiêm tiểu đệ, ép Cửu Linh Vương đại lễ và nhờ tìm Bất Lão Thần…","anchor":"Cốt Tiễn vọt tới không những đánh gãy cốt đao mà còn chặt đứt một cánh tay của Vũ Vương rơi xuống, máu phun tung tóe.","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"major","tieuDe":"Cốt Tiễn đánh lui Ngân Huyết, chặt tay Vũ Vương","text":"Nhóc tỳ bọc lấy Ấu Thần vừa ra đời xông khỏi vòng vây; phun tia chớp đánh cháy đen bàn tay Người khổng lồ Ngân Huyết, rồi vung Cốt Tiễn vàng kim đánh gãy hung đao và chặt đứt một cánh tay Vũ Vương; dùng Tham Cốt pháp trong Nguyên Thủy Chân Giải thăm dò sói con nhưng không tìm thấy phù cốt lẫn ấn ký; điện giật thử khiến sói con lông cháy đen; hỏi Hỏa Linh Nhi có sữa không nên bị đuổi đánh suốt hai giờ.","anchor":"Cốt Tiễn vọt tới không những đánh gãy cốt đao mà còn chặt đứt một cánh tay của Vũ Vương rơi xuống, máu phun tung tóe."},{"chuong":"@c0125","importance":"major","tieuDe":"Thu phục Sư Tử chín đầu làm tiểu đệ","text":"Cùng đám thiên tài Bổ Thiên các truy sát bắt trói Ngân Huyết và Vũ Vương; đại chiến rồi cùng rơi xuống thác nước, cưỡi lên lưng thu phục Sư Tử chín đầu làm thú cưỡi/tiểu đệ; ép đòi Cửu Linh Vương ban đại lễ Linh dược và Thánh dược, đòi tìm Bất Lão Thần Tuyền; giao Ấu Thần cho Hỏa Linh Nhi nuôi.","anchor":"Thiếu niên Nhân tộc anh hùng, ta phục rồi, chúng ta kết bái làm huynh đệ nha."},{"text":"Hàng phục Sư Tử chín đầu làm tọa kỵ, cưỡi xông qua núi rừng khiến vạn thú tránh né; chia tay công chúa Hỏa quốc và các thiên tài Bổ Thiên các để đi tìm Bất Lão Thần Tuyền; đòi mượn bảo cụ của Sư Tử nhưng bị từ chối, tranh cãi uy hiếp qua lại; phá năm tầng sát trận Phù Văn ở vùng ngập nước rồi bị mười người Vũ tộc phục kích, chất vấn họ và cuối cùng vung bảo kính ra tay.","anchor":"một Hoàng Kim sư tử có huyết thống cao quý lại bị một thiếu niên Nhân tộc hàng phục, biến thành tọa kỵ","bridge":true,"khoang":"@c0126"},{"text":"Bị mười thiên tài Vũ tộc hợp lực Bảo Thuật vây công, dùng cốt kính Toan Nghê phản kích lôi đình giết sáu người tại chỗ rồi ba người sau; tự xưng chính là đứa trẻ năm đó đã mất Chí Tôn cốt hơn tám năm trước; cưỡi Sư Tử chín đầu đại khai sát giới đánh gục thêm mười tám thiên tài, tổng cộng giết hai mươi người; dùng bảo kính Toan Nghê giết người truyền tin nổ tung.","anchor":"Có thể nói cho ngươi biết, ta chính là đứa trẻ năm đó.","bridge":true,"khoang":"@c0127"},{"text":"Ngồi trên Sư Tử chín đầu nghênh chiến Vũ Tử Mạch; bắn mười tia chớp vàng phá Phù Văn, tạo cối xay bạc nghiền vỡ quyển sách cổ khiến Bảo Thuật Thông Linh mất hiệu lực; dùng bảo kính Toan Nghê phát lôi đình vàng khắc chế công pháp nước-lôi điện của Vũ tộc, đánh nàng ho ra máu; bắn Cốt Tiễn vàng cắt đứt Bảo Tán, đánh nổ tung Bảo Y của nàng; còn buông lời khiêu khích thân hình đối phương giữa trận.","anchor":"Nó hiểu được bảo thuật Lôi điện. Vừa vặn khắc chế công pháp Vũ tộc ta","bridge":true,"khoang":"@c0128"},{"chuong":"@c0128","importance":"normal","tieuDe":"Áp đảo Vũ Tử Mạch tại Bách Đoạn sơn","text":"Sau khi giết mười tám cao thủ Vũ tộc, bị Vũ Tử Mạch phụng lệnh truy giết; ngồi trên Sư Tử chín đầu, dùng cối xay màu bạc nghiền vỡ quyển sách cổ Phù Văn, thúc bảo kính Toan Nghê tế lôi đình và tự phát điện màu vàng khắc chế công pháp nước của Vũ tộc, đánh nàng ho ra máu, dùng Cốt Tiễn cắt Bảo Tán và bảo kính đánh nổ Bảo Y của nàng; trong trận một Bảo Cụ của hắn cũng bị Cốt Tiễn hủy.","anchor":"Nó hiểu được bảo thuật Lôi điện. Vừa vặn khắc chế công pháp Vũ tộc ta"},{"text":"Điên cuồng oanh kích Vũ Tử Mạch bằng tia chớp vàng, đánh tan ký hiệu Phù Văn cuối cùng, làm gãy hai cánh tay khiến đòn cuối bảo thuật Thông Linh của nàng thất bại; khi chuẩn bị đòn giết cuối bằng Cốt Tiễn màu vàng và bảo kính Toan Nghê thì bốn Người phong ấn Vũ tộc xuất hiện vây bắt; phát hiện tay chúng có nếp nhăn nên nhận ra là tiền bối vượt cấm chế tuổi tác Bách Đoạn sơn; cùng Sư Tử chín đầu giả liều mạng rồi bất ngờ dùng Bảo Cụ dưới chân phó…","anchor":"đây tuyệt đối không phải tay của một người thiếu niên","bridge":true,"khoang":"@c0129"},{"chuong":"@c0129","importance":"normal","tieuDe":"Đánh bại Vũ Tử Mạch, trốn khỏi bốn Người phong ấn","text":"Điên cuồng oanh kích, đánh tan Phù Văn cuối cùng trên người Vũ Tử Mạch làm gãy hai cánh tay nàng, khiến đòn cuối bảo thuật Thông Linh thất bại; khi chuẩn bị đòn giết cuối với Cốt Tiễn và bảo kính Toan Nghê thì bốn Người phong ấn Vũ tộc xuất hiện vây bắt; phát hiện tay chúng có nếp nhăn nên biết là tiền bối vượt cấm chế tuổi tác; cùng Sư Tử chín đầu giả liều mạng rồi bất ngờ dùng Bảo Cụ phóng lên trời bỏ chạy, biến Sư Tử chín đầu thành khiên thịt; chủ động chặn bốn đại cường giả để cứu Sư Tử chín đầu; bị bốn cường giả nghi là “đứa nhỏ năm đó” liên quan Thạch Tử Lăng.","anchor":"Nhóc tỳ quát to về phía Sư Tử chín đầu, nó chặn lại bốn đại cường giả, giúp Sư Tử chín đầu chặn đường."},{"text":"Bị bốn đại cường giả Vũ tộc do Vũ Côn dẫn đầu truy sát tận diệt vì lo sợ thiên tư đáng sợ của cậu; cậu phế cây quạt bạc phù cốt nổ tung đánh về bốn người, rồi giả ngã bên bờ hồ dẫn dụ Ngư Long trồi lên nuốt chết một cường giả và khiến một kẻ khác phải tự cắt hai chân mới thoát; cuối cùng bắt gục Hỏa Vân Tước Đại Hồng để cưỡi thoát thân.; Bị bốn đại cường giả Vũ tộc (có Vũ Côn) truy sát vì nghi là đứa bé năm xưa; phế cây quạt bạc rách nát cho nổ…","anchor":"cuối cùng cũng đánh gục được Hỏa Vân Tước, ôm chặt lấy cổ nó có chết cũng không buông tay","bridge":true,"khoang":"@c0130"},{"chuong":"@c0130","importance":"normal","tieuDe":"Dẫn dụ Ngư Long, bắt Đại Hồng thoát vây","text":"Bị bốn đại cường giả Vũ tộc (có Vũ Côn) truy sát tại Bách Đoạn sơn, biết chúng muốn diệt trừ vì lo thiên tư quật khởi dù mất Chí Tôn Cốt; vận bảo kính Toan Nghê truyền lực sấm sét kích hoạt quạt bạc rách nát (đoạt của Linh Tộc) rồi ném nổ tung phế bỏ luôn để phá vòng vây, khiến một lão râu tóc trắng bị thương; giả ngã bên bờ hồ lớn, tay giấu bảo kính nhắm mặt hồ, đánh tia sấm sét oanh vào nước triệu Ngư Long trồi lên táp nuốt một cường giả, một kẻ tự cắt hai chân thoát thân; định xông vào cấm địa kinh động nhân vật khủng bố hơn, giữa đường suýt đụng Hỏa Vân Tước Đại Hồng liền đánh gục ôm chặt cổ, cưỡi nó cùng đe dọa xin thịt buộc bay trốn khỏi hai cao thủ Vũ tộc còn lại; bị Đại Hồng ám ảnh gọi là Ma Vương.","anchor":"cuối cùng cũng đánh gục được Hỏa Vân Tước, ôm chặt lấy cổ nó có chết cũng không buông tay"},{"chuong":"@c0130","importance":"major","tieuDe":"Dẫn dụ Ngư Long nuốt cường giả Vũ tộc","text":"Bị bốn đại cường giả Vũ tộc truy sát trong Bách Đoạn sơn, Thạch Hạo phế cây quạt bạc nổ tung phá vòng vây, giả ngã bên bờ hồ dàn cảnh rồi dùng bảo kính Toan Nghê oanh sấm sét vào hồ dẫn dụ Ngư Long trồi lên nuốt chết một cường giả, một kẻ tự cắt hai chân thoát; sau đó đánh gục và bắt được Hỏa Vân Tước Đại Hồng để cưỡi thoát thân, đe dọa nó chở mình chạy trốn khỏi truy binh.","anchor":"Bỗng nhiên có hai người kêu thảm, bị một vùng Phù Văn bao phủ, một cái lưỡi lớn màu đỏ thắm cuốn tới"}],"tuViMoc":[{"chuong":"@c0101","canhGioi":"Đệ lục Động Thiên","text":"Chìm đáy sông tu hành suốt đêm, luyện hóa dược tính Hắc Sát Liên thành hỏa diễm đen rèn gân cốt, mở ra khẩu thứ sáu Động Thiên khi mới 9 tuổi rưỡi — cảnh giới kinh người, cảm thấy toàn thân đặc biệt cường đại.","importance":"major"},{"chuong":"@c0105","canhGioi":"Đệ lục Động Thiên","text":"Đột phá lên đệ lục Động Thiên nhờ ăn sống Hắc Sát Liên của Bổ Thiên các.","importance":"minor"},{"chuong":"@c0120","canhGioi":"Động Thiên thứ bảy","text":"Sau khi luyện hóa Tử Vân Tâm trong hang cổ, đột phá mở ra miệng Động Thiên thứ bảy trên người; dung nham trong miệng núi lửa cuồn cuộn chảy vào cơ thể, tốc độ đột phá liên tiếp trong thời gian ngắn được mô tả là hù chết người.","importance":"major"},{"chuong":"@c0123","canhGioi":"Động Thiên thứ bảy","text":"Vừa mượn Tử Vân Tâm để đột phá, mở ra miệng Động Thiên thứ bảy; sau khi ăn bảo dược đầu sư tử chứa thần tính, chọn hòa tinh khí thần vào huyết nhục xương cốt tạo cơ sở vững chắc thay vì đột phá ngay để tránh mầm họa.","importance":"major","anchor":"Nó vừa mượn Tử Vân Tâm để đột phá, mở ra miệng Động Thiên thứ bảy"}],"nhanMach":[{"ten":"Tiêu Thiên","tag":"doi-thu","quanHe":"Đối thủ tại chiến trường thứ hai — bị Nhóc tỳ đánh lén một búa quật ngã","ghiChu":"Tiêu Thiên từng đánh lén Nhóc tỳ một chưởng và kiêng kỵ vì đối phương giấu mặt"},{"ten":"Tiêu Thiên","tag":"doi-thu","quanHe":"Kẻ đối đầu qua lại đánh lén","ghiChu":"Nhóc tỳ đánh lén Tiêu Thiên ngất 2 lần, cướp rồi trả lại Bổ Thiên thạch, hẹn cả vốn lẫn lời phải hoàn lại (@c0102)"},{"ten":"Trác Vân","tag":"doi-thu","quanHe":"Trưởng lão Bổ Thiên các bị hắn trộm bảo dược, phun máu vì mất Hắc Sát Liên."},{"ten":"Hùng Phi","tag":"doi-thu","quanHe":"Trưởng lão Bổ Thiên các suy ra hắn là thủ phạm và ra lệnh truy lùng."},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Người giữ kỷ lục ở Hư Thần Giới bị hắn phá; được dự báo thành đối thủ tương lai."},{"ten":"Hùng Phi","tag":"su-mon","quanHe":"Trưởng lão chọn làm sư phụ (từng bị Thạch Hạo chọc đến hộc máu)","ghiChu":"@c0106"},{"ten":"Trác Vân","tag":"su-mon","quanHe":"Trưởng lão chọn làm sư phụ (từng bị Thạch Hạo chọc đến hộc máu)","ghiChu":"@c0106"},{"ten":"Thiếu nữ áo trắng","tag":"su-mon","quanHe":"Sư tỷ Bổ Thiên các dẫn dắt, nhéo má trêu","ghiChu":"@c0106"},{"ten":"Thanh Phong","tag":"ban-be","quanHe":"Thân như anh em ruột; phát hiện bị thương","ghiChu":"@c0106"},{"ten":"Thanh Phong","tag":"ban-be","quanHe":"Tiểu đệ thân thiết cần bảo vệ","ghiChu":"Vạch kế trừng trị bọn thiếu niên bắt nạt Thanh Phong. @c0107"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Người tính lôi kéo vào việc đối phó Vũ tộc","ghiChu":"@c0107"},{"ten":"Chu Vũ Hào","tag":"doi-thu","quanHe":"Kẻ ám toán Thanh Phong, bị nhóc tỳ gài trừng trị","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Người thân cùng bộ; được Thạch Hạo nhìn thấy đang bước trên con đường vào Thượng Cổ Thánh Viện","ghiChu":"@c0109"},{"ten":"Tử Thần","tag":"khac","quanHe":"U linh tử khí Thượng Cổ cản đường đòi trả kiếm; nó hứa tìm giúp trả kiếm rồi cưỡi lên cổ ông lão","ghiChu":"@c0111"},{"ten":"Bốn lão tiền bối Bổ Thiên các","tag":"su-mon","quanHe":"Bốn cường giả mắt ánh xanh thử thân thể nó rồi giao nhiệm vụ Bất Lão thần tuyền","ghiChu":"@c0113"},{"ten":"Thiếu nữ áo xanh","tag":"doi-thu","quanHe":"Thiếu nữ ~15-16 tuổi bước tới khiêu chiến để đoạt cây linh dược","ghiChu":"@c0113"},{"ten":"Thanh Phong","tag":"ho-hang","quanHe":"Đệ đệ","ghiChu":"Nhóc tỳ công khai bảo vệ, khích lệ Thanh Phong tu hành đột phá; ai bắt nạt Thanh Phong là bắt nạt nó (@c0114)."},{"ten":"Ngạn Tâm","tag":"doi-thu","quanHe":"Đối thủ đấu cược","ghiChu":"Đánh tan Khổng Tước xanh và lưới ngọc bích của nàng, khống chế bắt sống (@c0114)."},{"ten":"Phiêu Tuyết","tag":"doi-thu","quanHe":"Đối thủ đấu cược","ghiChu":"Nghiền tan chiến mâu, điểm eo phẩy chưởng thắng hoàn toàn (@c0114)."},{"ten":"Chu Vũ Hào","tag":"doi-thu","quanHe":"Cựu thù","ghiChu":"Đấm một quyền vào mặt khiến hắn hôn mê; hắn nhận ra nhóc tỳ là ca ca của Thanh Phong (@c0114)."},{"ten":"Vũ Phong","tag":"doi-thu","quanHe":"Cường giả quan sát","ghiChu":"Được giục ra áp chế nhưng lắc đầu không xuất thủ, chỉ lóe tinh quang trong mắt (@c0114)."},{"ten":"Đào Dã","tag":"an-nhan","quanHe":"Người báo tin","ghiChu":"Cho biết Thạch Nghị, con gái Nhân hoàng, hậu duệ Thái cổ di chủng đã được hộ tống đến Bách Đoạn sơn trước (@c0114)."},{"ten":"Đào Dã","tag":"su-mon","quanHe":"Nguyên lão Bổ Thiên các dẫn đội hộ tống","ghiChu":"Cùng đoàn tới Đoạn Không thành, Bách Đoạn sơn"},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Được nêu làm mốc so sánh sức mạnh","ghiChu":"Vũ tộc lưu ý thân thể Hạo Thiên kinh người không kém Nghị nhi"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Nghi liên hệ huyết thống","ghiChu":"Vũ tộc nhận xét lông mày khóe mắt Hạo Thiên giống Thạch Tử Lăng năm đó (chỉ là nhận xét giống, chưa khẳng định)"},{"ten":"Đào Dã","tag":"su-mon","quanHe":"Trưởng bối Bổ Thiên các hộ tống, nhiều lần bị Thạch Hạo chọc tức đến đen mặt","ghiChu":"@c0117"},{"ten":"Đại Hồng","tag":"doi-thu","quanHe":"Chim lửa bị Thạch Hạo đuổi bắt để làm đồ ăn","ghiChu":"@c0117"},{"ten":"Sinh vật hình người ánh bạc","tag":"doi-thu","quanHe":"Cường giả bí ẩn tự xưng làm vương/chủ nhân, muốn thu nhóc tỳ làm chiến bộc","ghiChu":"Đoạt bốn gốc Xích Lan, phục kích nhóm Bổ Thiên các @c0118"},{"ten":"Đại Hồng","tag":"doi-thu","quanHe":"Hung cầm Hỏa Vân Tước bị nhóc tỳ đả thương đoạt thịt","ghiChu":"@c0118"},{"ten":"Sinh linh màu bạc","tag":"doi-thu","quanHe":"Kẻ địch bị Thạch Hạo giết trong trận đơn đấu","ghiChu":"Thái Cổ di chủng hậu duệ Vương tộc"},{"ten":"Sư Tử chín đầu","tag":"doi-thu","quanHe":"Thái Cổ di chủng muốn thu Thạch Hạo làm chiến phó","ghiChu":"Chỉ được nhắc tên"},{"ten":"Hỏa Linh Nhi","tag":"su-mon","quanHe":"Con gái nhỏ của Nhân Hoàng, sư muội cùng môn Bổ Thiên các, đồng ý trao đổi di chủng","ghiChu":""},{"ten":"Hỏa Linh Nhi","tag":"dong-minh","quanHe":"Cùng Bổ Thiên các nên bị nhóc tỳ gọi đùa là sư muội; nàng quyết đổi Tử Vân Tâm lấy Linh Tộc rồi ra lệnh vây bắt, sau lại chiêu mộ nhóc tỳ vào liên minh đi Thần Quật; bị nhóc tỳ vỗ mông trêu ngược.","ghiChu":"@c0120"},{"ten":"Hoàng Kim sư tử chín đầu","tag":"doi-thu","quanHe":"Thái Cổ di chủng chặn ải Thần Quật, tranh thu nhóc tỳ làm chiến phó rồi giao chiến","ghiChu":"Mở tranh nhận diện, đại chiến ngang sức @c0121"},{"ten":"Ngân Huyết cự nhân","tag":"doi-thu","quanHe":"Bị nhóc tỳ đấm chảy máu bàn tay","ghiChu":"@c0121"},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Bị nhóc tỳ đá văng hộc máu","ghiChu":"@c0121"},{"ten":"Mộc Phong","tag":"doi-thu","quanHe":"Kẻ Linh tộc đi tìm nhóc tỳ, bị nhóc tỳ ăn thịt","ghiChu":"@c0121"},{"ten":"Sư Tử chín đầu","tag":"doi-thu","quanHe":"Đối thủ đại chiến trên thảo nguyên, bị đánh bại rồi bị cưỡi trấn áp làm thú cưỡi","ghiChu":"Gặp @c0122"},{"ten":"Hỏa Linh Nhi","tag":"doi-thu","quanHe":"Truy đuổi cướp trứng thần","ghiChu":"Xông vào đại chiến khi bắt gặp nhóc tỳ nướng trứng (@c0124)"},{"ten":"Ấu Thần","tag":"dong-minh","quanHe":"Linh thú Thạch Hạo đoạt được và nuôi","ghiChu":"Hậu đại Lang Thần, sói con bám dính Thạch Hạo"},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Thú cưỡi kiêm tiểu đệ bị thu phục","ghiChu":"Cháu Cửu Linh Vương, phát thệ dẫn tìm Bất Lão Thần Tuyền"},{"ten":"Cửu Linh Vương","tag":"doi-thu","quanHe":"Bị Thạch Hạo đòi đại lễ qua Sư Tử chín đầu","ghiChu":"Tổ phụ/họ hàng của Sư Tử chín đầu"},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Tọa kỵ do Thạch Hạo hàng phục","ghiChu":"Cùng phá năm tầng sát trận Phù Văn, tranh cãi về bảo cụ"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Người mang Chí Tôn cốt bị mẹ hắn trộm từ Thạch Hạo","ghiChu":"Mối thù đoạt cốt"},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Huynh đệ kết nghĩa, làm tọa kỵ","ghiChu":"Cùng săn giết thiên tài Vũ tộc, chở Thạch Hạo tiến trong mưa như Chiến Thần"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Bị người Vũ tộc so sánh, kỳ vọng trấn áp Thạch Hạo","ghiChu":"Được gọi Trời sinh Chí Tôn, đang xông Thượng Cổ cấm địa tìm Thiên Cốt"},{"ten":"Vũ Tử Mạch","tag":"doi-thu","quanHe":"Đối thủ Vũ tộc","ghiChu":"Thiếu nữ song kiệt phụng lệnh truy giết Thạch Hạo, bị hắn áp đảo tại Bách Đoạn sơn"},{"ten":"Vũ Tử Mạch","tag":"doi-thu","quanHe":"Đối thủ Vũ tộc bị Thạch Hạo đánh bại","ghiChu":"Đánh tan Phù Văn, làm gãy hai cánh tay nàng."},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Đồng bọn cùng trốn khỏi vòng vây","ghiChu":"Thạch Hạo chặn cường giả cứu Sư Tử chín đầu thoát."},{"ten":"Vũ Côn","tag":"doi-thu","quanHe":"Cường giả Vũ tộc truy nhìn chân thân Thạch Hạo","ghiChu":"Kể chuyện thúc tổ dùng Cốt Tiễn xuyên phổi Thạch Tử Lăng."},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Người mà chân mày Thạch Hạo lúc tức giận rất giống","ghiChu":"Bị nghi là hậu nhân/liên hệ huyết thống."},{"ten":"Vũ Côn","tag":"doi-thu","quanHe":"Cường giả Vũ tộc dẫn đầu nhóm truy sát, cười khinh miệt rồi nộ hỏa khi mất người","ghiChu":"@c0130"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Phụ thân, năm đó bị Vũ tộc phục kích đánh trọng thương suýt xuyên tim","ghiChu":"@c0130"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ mà phe Vũ tộc cho rằng cậu sẽ tranh cao thấp trong tương lai","ghiChu":"@c0130"},{"ten":"Đại Hồng","tag":"khac","quanHe":"Hỏa Vân Tước bị cậu bắt cưỡi thoát thân; từng bị cậu mượn hai mươi cân thịt nên ám ảnh gọi cậu là Ma Vương","ghiChu":"@c0130"},{"ten":"Tử Thần","tag":"khac","quanHe":"Cổ nhân bí ẩn","ghiChu":"Lão già tóc xám bị cổ kiếm xuyên đầu, không sinh mệnh mà di chuyển như hư không, chặn đường nhóc tỳ tại nơi Tế Linh ở ẩn @c0110"},{"ten":"Thanh Phong","tag":"ban-be","quanHe":"Bạn nhỏ bị bắt nạt, ra tay điều tra và vạch kế báo thù giúp","ghiChu":"Sai Bóng Lông đi thăm và điều tra @c0107"},{"ten":"Ông lão tóc xám (u linh Thượng Cổ)","tag":"khac","quanHe":"Tồn tại tử khí Thượng Cổ cản đường, đòi trả kiếm; Thạch Hạo hứa tìm giúp trả kiếm rồi cưỡi lên cổ","ghiChu":"@c0111"},{"ten":"Sinh vật hình người ánh bạc","tag":"doi-thu","quanHe":"Kẻ muốn thu phục làm chiến bộc","ghiChu":"Đoạt Xích Lan, chiêu dụ nhóc tỳ; bị nhóc tỳ coi như con mồi."},{"ten":"Hỏa Vân Tước","tag":"doi-thu","quanHe":"Hung cầm bị săn lấy thịt","ghiChu":"Gọi là Đại Hồng, đả thương đoạt thịt."},{"ten":"Nhân Hùng một sừng màu đen","tag":"doi-thu","quanHe":"Hung thú bị săn đuổi","ghiChu":"Định ăn thịt khiến nó bỏ chạy."},{"ten":"Hỏa Linh Nhi","tag":"su-mon","quanHe":"Sư muội đồng môn Bổ Thiên các","ghiChu":"Trêu nàng giảm béo khiến nàng phun lửa truy sát; nàng giục Sư Tử chín đầu thu phục Thạch Hạo"},{"ten":"Ngân Huyết cự nhân","tag":"doi-thu","quanHe":"Thái Cổ di chủng","ghiChu":"Bị Thạch Hạo đấm chảy máu bàn tay"},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Thái Cổ di chủng Vũ tộc","ghiChu":"Bị Thạch Hạo đá văng hộc máu"},{"ten":"Mộc Phong","tag":"doi-thu","quanHe":"Linh tộc đi tìm Thạch Hạo","ghiChu":"Bị Thạch Hạo ăn thịt"},{"ten":"Nữ tử song kiệt Vũ tộc","tag":"doi-thu","quanHe":"Đối thủ Vũ tộc","ghiChu":"Một trong song kiệt Vũ tộc lộ diện đối đầu."},{"ten":"Thiếu nữ song kiệt Vũ tộc","tag":"doi-thu","quanHe":"Đối thủ Vũ tộc","ghiChu":"Bóng người trước thông đạo đứng dậy đối đầu."},{"ten":"Người truyền tin Vũ tộc","tag":"doi-thu","quanHe":"Bị giết","ghiChu":"Bị bảo kính Toan Nghê bắn lôi đình nổ tung."},{"ten":"Lão già tóc xám","tag":"doi-thu","quanHe":"Cổ nhân Thượng Cổ bị cổ kiếm xuyên đầu, chặn đường nhóc tỳ khi rời nơi Tế Linh ở ẩn","ghiChu":"Chạm mặt @c0110"},{"ten":"Đào Dã","tag":"su-mon","quanHe":"Lão tiền bối Bổ Thiên các","ghiChu":"Chủ trì bàn bạc, giải thích chân tướng Tử Thần và nhiệm vụ Bách Đoạn sơn cho nó."},{"ten":"Tử Thần","tag":"doi-thu","quanHe":"Thần quái Thượng Cổ đã chọn trúng nó","ghiChu":"Chọn nó thay vì thiên tài, đặt lên nó nhiệm vụ sống-còn."},{"ten":"Thanh Phong","tag":"ho-hang","quanHe":"Đệ đệ, được Thạch Hạo công khai bảo vệ và khích lệ tu hành","ghiChu":"@c0114"},{"ten":"Ngạn Tâm","tag":"doi-thu","quanHe":"Đối thủ đầu tiên trong đổ chiến, bị khống chế bắt sống","ghiChu":"@c0114"},{"ten":"Phiêu Tuyết","tag":"doi-thu","quanHe":"Đối thủ thứ hai, bị nghiền tan chiến mâu, thua","ghiChu":"@c0114"},{"ten":"Chu Vũ Hào","tag":"doi-thu","quanHe":"Bị đánh gục, nhận ra Thạch Hạo là ca ca của Thanh Phong","ghiChu":"@c0114"},{"ten":"Vũ Phong","tag":"doi-thu","quanHe":"Cường giả áo trắng được giục ra áp chế nhưng từ chối xuất thủ","ghiChu":"@c0114"},{"ten":"Đào Dã","tag":"an-nhan","quanHe":"Báo tin các dòng dõi đỉnh cấp đã đến Bách Đoạn sơn trước","ghiChu":"@c0114"},{"ten":"Bốn lão tiền bối Bổ Thiên các","tag":"su-mon","quanHe":"Cường giả thử thân thể nó rồi giao nhiệm vụ tìm Bất Lão thần tuyền","ghiChu":"@c0113"},{"ten":"Phong nhi","tag":"doi-thu","quanHe":"Người Vũ tộc cài ở Bổ Thiên các, truyền tin xác định danh tính Hạo Thiên về cho Vũ tộc","ghiChu":"@c0116"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Vũ tộc nhận xét Hạo Thiên có lông mày khóe mắt giống Thạch Tử Lăng năm đó","ghiChu":"@c0116"},{"ten":"Hỏa Vân Tước","tag":"doi-thu","quanHe":"Hung cầm bị nhóc tỳ đả thương và đoạt thịt để ăn","ghiChu":"@c0118"},{"ten":"Sinh vật hình người ánh bạc","tag":"doi-thu","quanHe":"Sinh vật ánh bạc phục kích nhóm, chiêu dụ nhóc tỳ làm chiến bộc; nhóc tỳ coi như con mồi","ghiChu":"@c0118"},{"ten":"Đại Hồng","tag":"khac","quanHe":"Chim lửa bị Nhóc Tỳ đuổi bắt trong Bách Đoạn Sơn","ghiChu":"@c0117"},{"ten":"Hỏa Linh Nhi","tag":"su-mon","quanHe":"Sư muội cùng Bổ Thiên các","ghiChu":"Bị nhóc tỳ trêu chọc chuyện giảm béo, truy sát rồi lại giục Sư Tử chín đầu thu phục nhóc tỳ."},{"ten":"Hoàng Kim sư tử chín đầu","tag":"doi-thu","quanHe":"Thái Cổ di chủng đại chiến với nhóc tỳ","ghiChu":"Mở tranh nhận diện nhóc tỳ là chiến phó, chặn ải và giao chiến ngang sức."},{"ten":"Ngân Huyết cự nhân","tag":"doi-thu","quanHe":"Thái Cổ di chủng bị nhóc tỳ đấm chảy máu tay","ghiChu":"Muốn thu nhóc tỳ làm người hầu."},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Thái Cổ di chủng bị nhóc tỳ đá văng hộc máu","ghiChu":"Muốn thu nhóc tỳ vì Nhân tộc và Vũ tộc hình dáng gần giống."},{"ten":"Hoàng Kim sư tử chín đầu","tag":"doi-thu","quanHe":"Đối thủ bị Thạch Hạo cưỡi trấn áp và đánh bại","ghiChu":"Chém rụng bốn đầu lâu, truy sát tới Thần Quật đòi bảo cụ và Huyết dược đầu sư tử (@c0123)"},{"ten":"Hỏa Linh Nhi","tag":"khac","quanHe":"Vừa đồng hành vừa tranh chấp","ghiChu":"Qua lại đấu khẩu, bị nàng mắng là “quỷ nhát gan”; Thạch Hạo cướp quả trứng vàng nàng đoạt được (@c0123)"},{"ten":"Hỏa Linh Nhi","tag":"doi-thu","quanHe":"Đối thủ truy đuổi cướp trứng","ghiChu":"Dẫn đoàn đuổi bắt nhóc tỳ, giận đến run người muốn liều mạng."},{"ten":"Năm vị thiên tài Bổ Thiên các","tag":"su-mon","quanHe":"Đồng môn ra tay giúp","ghiChu":"Gọi nhóc tỳ là “sư đệ”, cùng đối kháng đám người."},{"ten":"Ấu Thần","tag":"dong-hanh","quanHe":"Sói con hậu đại Lang Thần được Thạch Hạo đoạt và nuôi, bám dính theo","ghiChu":"@c0125"},{"ten":"Sư Tử chín đầu","tag":"dong-hanh","quanHe":"Bị Thạch Hạo thu phục làm thú cưỡi kiêm tiểu đệ","ghiChu":"@c0125"},{"ten":"Hỏa Linh Nhi","tag":"dong-hanh","quanHe":"Bị Thạch Hạo hỏi “có sữa không” rồi giao Ấu Thần nhờ nuôi","ghiChu":"@c0125"},{"ten":"Cửu Linh Vương","tag":"doi-thu","quanHe":"Thạch Hạo đòi ông ta đại lễ Linh dược/Thánh dược thông qua Sư Tử chín đầu","ghiChu":"@c0125"},{"ten":"Người truyền tin Vũ tộc","tag":"doi-thu","quanHe":"Đối thủ Vũ tộc bị Thạch Hạo bắn tia chớp vàng nổ tung chết tại chỗ","ghiChu":"@c0127"},{"ten":"Nữ tử song kiệt Vũ tộc","tag":"doi-thu","quanHe":"Cao thủ Vũ tộc lộ diện đối đầu Thạch Hạo","ghiChu":"@c0127"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Phụ thân","ghiChu":"Năm đó bị Vũ tộc phục kích đánh trọng thương suýt xuyên tim"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Người mà Vũ tộc cho rằng sẽ tranh cao thấp trong tương lai"},{"ten":"Đại Hồng","tag":"khac","quanHe":"Hỏa Vân Tước bị bắt làm phương tiện chạy trốn","ghiChu":"Từng bị mượn hai mươi cân thịt, ám ảnh gọi Thạch Hạo là Ma Vương"},{"ten":"Vũ Tử Mạch","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Hạo đánh tan Phù Văn, gãy hai cánh tay, bại trận phun máu."},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Đồng bọn","ghiChu":"Cùng chạy trốn bốn Người phong ấn; Thạch Hạo chặn đường cứu Sư Tử chín đầu, được hứa xóa nợ cũ."},{"ten":"Vũ Côn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Cường giả Vũ tộc truy đuổi, mắt bắn thần mang muốn thấy chân thân Thạch Hạo."},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Người bị nghi liên hệ huyết thống","ghiChu":"Chân mày lúc nổi giận rất giống Thạch Tử Lăng; bị gọi là đứa nhỏ năm đó, tiểu nghiệt súc."},{"ten":"Tiêu Thiên","tag":"doi-thu","quanHe":"Nạn nhân bị nhóc tỳ đập búa ngất, cướp rồi trả lại Bổ Thiên Thạch; lột đan dược Long Tán và Hổ Dược","ghiChu":"@c0103"},{"ten":"Thanh Phong","tag":"ban-be","quanHe":"Được Thạch Hạo bảo vệ; kinh ngạc khi biết phong ba do một tay tiểu ca ca gây ra","ghiChu":"@c0109"},{"ten":"Chu Vũ Hào","tag":"doi-thu","quanHe":"Bị Thạch Hạo giật dây khiến bị đánh hội đồng tàn phế","ghiChu":"@c0109"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Được Thạch Hạo nhìn thấy đang đi trên con đường vào Thượng Cổ Thánh Viện","ghiChu":"@c0109"},{"ten":"Vũ Tử Mạch","tag":"doi-thu","quanHe":"Song kiệt Vũ tộc lộ diện đối đầu","ghiChu":"@c0127"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Bị nghi có liên hệ huyết thống","ghiChu":"Chân mày lúc nổi giận giống Thạch Tử Lăng; bị gọi “đứa nhỏ năm đó” (@c0129)."},{"ten":"Cửu Linh Vương","tag":"khac","quanHe":"Ân oán qua Sư Tử chín đầu","ghiChu":"Sư Tử chín đầu hứa xóa nợ cũ, không để Cửu Linh Vương tìm phiền (@c0129)."},{"ten":"Đại Hồng","tag":"khac","quanHe":"Thần điểu bị bắt cưỡi","ghiChu":"Từng bị Thạch Hạo mượn hai mươi cân thịt nên ám ảnh gọi cậu là Ma Vương; bị bắt chở chạy trốn"},{"ten":"Thiếu niên (huynh trong hai huynh muội)","tag":"khac","quanHe":"Gặp khi hai huynh muội nướng chim; nhóc tỳ cướp chân chim ăn, moi tin rồi tặng thuốc quý","ghiChu":"@c0103"},{"ten":"Tiểu cô nương (muội trong hai huynh muội)","tag":"khac","quanHe":"Thiếu nữ thí sinh tức nhóc tỳ cướp chân chim; được tặng Long Tán và Hổ Dược","ghiChu":"@c0103"},{"ten":"Ấu Thần","tag":"dong-hanh","quanHe":"Sinh linh Thái Cổ hung thú non được thu nhận","ghiChu":"Sói con bám dính lấy nhóc tỳ; giao Hỏa Linh Nhi nuôi mập"},{"ten":"Sư Tử chín đầu","tag":"dong-hanh","quanHe":"Thú cưỡi/tiểu đệ bị ép","ghiChu":"Thu phục sau khi cùng rơi thác, đòi đại lễ, sai đi tìm Bất Lão Thần Tuyền"},{"ten":"Người khổng lồ Ngân Huyết","tag":"doi-thu","quanHe":"Kẻ tranh cướp Ấu Thần","ghiChu":"Đánh cháy đen tay, sau bắt trói"},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Kẻ tranh cướp Ấu Thần","ghiChu":"Chặt đứt một cánh tay, sau bắt trói"},{"ten":"Hai huynh muội thí sinh","tag":"khac","quanHe":"Cùng ăn sáng, dò tin tức rồi được Thạch Hạo tặng Long Tán và Hổ Dược","ghiChu":"@c0103"},{"ten":"Hỏa Linh Nhi","tag":"dong-minh","quanHe":"Đồng hành bảo vệ Ấu Thần, bị nhóc tỳ chọc giận đuổi đánh; được giao nuôi Ấu Thần","ghiChu":"@c0125"},{"ten":"Sư Tử chín đầu","tag":"dong-minh","quanHe":"Thu phục làm thú cưỡi/tiểu đệ, ép phát thệ","ghiChu":"@c0125"},{"ten":"Người khổng lồ Ngân Huyết","tag":"doi-thu","quanHe":"Bị đánh cháy tay, truy sát bắt trói","ghiChu":"@c0125"},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Bị Cốt Tiễn chặt cánh tay, truy sát bắt trói","ghiChu":"@c0125"}],"tuiDo":{"phapBao":[{"ten":"Bạch cốt đại bổng","loai":"vũ khí","trangThai":"dang-co","moTa":"Cây gậy lớn bằng xương trắng, dùng như búa tập kích; hai búa đập vào gáy quật ngã Tiêu Thiên.","nguon":"@c0101"}],"danDuoc":[{"ten":"Hắc Sát Liên","trangThai":"da-dung","moTa":"Đào trộm từ địa quật Hắc hổ, ăn sạch luyện hóa để đột phá đệ lục Động Thiên.","nguon":"@c0101"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0101","@c0102","@c0105","@c0106","@c0107","@c0108","@c0109","@c0111","@c0112","@c0113","@c0114","@c0115","@c0116","@c0117","@c0118","@c0119","@c0120","@c0121","@c0122","@c0124","@c0125","@c0128","@c0129","@c0130","@c0110","@c0127","@c0123","@c0103"],"vaiTro":"Nhân vật chính — thiên tài trời sinh Chí Tôn cốt của Thạch Thôn","tinhCach":"Ngoan cường bất khuất, tu luyện khổ nhọc không sờn; thông tuệ nhạy bén, giỏi cốt văn từ nhỏ; trọng tình nghĩa, liều mình che chở người thân và bằng hữu; gan dạ hiếu chiến, dám một mình đối đầu cường địch","blurb":"Thạch Hạo là đứa trẻ trời sinh Nguyên thủy bảo cốt (Chí Tôn cốt) của Thạch Thôn, từ ba tuổi rưỡi đã có thần lực áp đảo và tinh thông cốt văn. Sau khi bị Lục tẩu cùng Thạch Nghị moi mất Chí Tôn cốt và rơi vào cửa tử, cậu được Liễu Thần khai thị, dựa vào Nguyên Thủy Chân Giải tái sinh rồi khổ tu từ Bàn Huyết cảnh lên Động Thiên cảnh. Rời Thạch Thôn vượt Đại Hoang tới Cổ quốc và gia nhập Bổ Thiên các, cậu liên tục mở tới Động Thiên thứ bảy, một mình đại chiến ba Thái Cổ di chủng, thu phục Sư Tử chín đầu và đoạt Ấu Thần.","theLuc":[{"ten":"Bổ Thiên Các","trangThai":"gia-mao"}]},{"id":"tieu-thien","name":"Tiêu Thiên","aliases":["Thiếu niên áo bào màu bạc","Thiếu niên áo bạc","Thiên hạ đệ nhất thiên tài","Nhân kiệt Tiêu Tộc","#tieu-thien-thieu-nien-ao-bac","#tieu-thien-tieu-toc"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiếu niên áo bạc tự nhận “đệ nhất thiên tài”, bị nhóc tỳ đập búa ngất rồi cướp Bổ Thiên Thạch; tỉnh dậy trong khe đá, nổi điên rống chấn động sơn hà nên bị các trưởng lão Bổ Thiên Các ngộ nhận là kỳ tài. (+) Thanh niên áo bào màu bạc tu vi kinh người tại chiến trường thứ hai, được xem là số một trong hơn chín vạn người; bị Nhóc tỳ một búa quật ngã. (+) Nhân kiệt Tiêu Tộc, đạt 28 viên Bổ Thiên Thạch đứng đầu thí luyện, nhưng trên trán có cục u to như sừng do bị đánh hai búa trong bóng tối. [CAN-SOAT-GOP]","vaiTro":"Đối thủ mạnh nhất của Nhóc tỳ tại chiến trường thứ hai.","tinhCach":[{"text":"Cường đại nhưng cẩn trọng, cảnh giác — bất an ám ảnh vì đối tượng giấu mặt từng đánh lén.","chuong":"@c0101"}],"tabs":{"diem":[{"text":"Một đêm chinh chiến thu được 16 khối Bổ Thiên thạch, đám bại trận cho là đứng thứ nhất trong hơn chín vạn người.","chuong":"@c0101"},{"text":"Tự nhận đệ nhất thiên tài nhưng bị nhóc tỳ đánh lén ngất, trán mọc cục u một sừng","chuong":"@c0103"},{"text":"Đạt 28 viên Bổ Thiên Thạch — thành tích đệ nhất nhân của thí luyện","chuong":"@c0104"},{"text":"Cục u to như sừng trên trán bị các trưởng lão gán là dị tượng, thiên tướng trời sinh","chuong":"@c0104"}],"kinhLich":[{"text":"Một đêm chinh chiến thu được 16 khối Bổ Thiên thạch, thắng cả thiếu niên Mộc tộc, được đám bại trận tán tụng là số một trong hơn chín vạn người; luôn bất an về đứa nhỏ giấu mặt từng bị hắn đánh lén một chưởng, cuối cùng bị Thạch Hạo dùng Bạch cốt đại bổng đánh lén sau gáy hai búa quật ngã.; Áo bào màu bạc, tu vi kinh người, một đêm chinh chiến thu 16 khối Bổ Thiên thạch, thắng cả thiếu niên Mộc tộc, nuốt bảo đan khôi phục cường thịnh và được tán…","anchor":"Tiêu Thiên tròng mắt trợn tròn, bị một búa quật ngã","bridge":true,"khoang":"@c0101"},{"text":"Tiêu Thiên bị Nhóc tỳ dùng Bạch cốt đại bổng đánh lén ngất, mất 25 khối Bổ Thiên thạch cùng 2 bình bảo đan, mọc cục u như sừng trên trán; tỉnh dậy đau đầu dữ dội, nhận ra kẻ tấn công là đứa nhỏ hắn từng đánh một chưởng để cướp Bổ Thiên thạch; sau đó lại bị đánh lén lần hai nện thẳng lên cục u chưa lành.","anchor":"Hắn lấy tay xoa xoa gáy, sau gáy giống như muốn nứt toát ra","bridge":true,"khoang":"@c0102"},{"text":"Tỉnh sau khi bị đập búa ngất cả đêm, kẹt trong khe đá bị bịt kín; phát hiện hơn hai mươi mấy viên Bổ Thiên Thạch bị cướp nay được trả lại trong ngực và túi da thú; phẫn uất nổi điên rống to giăng phù văn màu bạc chấn động sơn hà, bị các trưởng lão Bổ Thiên Các ngộ nhận là kỳ tài ngút trời; soi nước hồ thấy trên trán mọc cục u to như sừng do hai búa trúng cùng chỗ, hận đến ứa nước mắt.; Tỉnh dậy trong khe đá bị bịt kín với cục u một sừng trên trá…","anchor":"đếm cẩn thận thì thấy có những hai mươi mấy viên","bridge":true,"khoang":"@c0103"},{"chuong":"@c0103","importance":"normal","tieuDe":"Tỉnh dậy trong khe đá, nổi điên thi triển Âm Ba Công","text":"Tỉnh dậy trong khe đá bị bịt kín, đầu đau vì bị đập búa nhiều lần; phát hiện Bổ Thiên Thạch bị cướp nay được trả lại đầy đủ hơn hai mươi viên, phẫn uất vì bị đánh lén vẫn bị gõ thêm búa; nổi điên rống chấn động sơn hà, toàn thân giăng phù văn bạc thi triển Âm Ba Công, trán mọc cục u to như sừng, khiến các trưởng lão Bổ Thiên Các tưởng là kỳ tài mà tranh khen","anchor":"Toàn thân hắn giăng đầy phù văn màu bạc, hắn gần như nổi điên."},{"text":"Thiếu niên áo bạc từ Tiêu Tộc cách 30 vạn dặm ném túi da thú, bên trong lộ 28 viên Bổ Thiên Thạch khiến trưởng lão Bổ Thiên Các tuyên bố là biểu hiện đệ nhất nhân; cục u to như sừng trên trán do bị đánh hai búa trong bóng tối bị các trưởng lão hiểu nhầm thành dị tượng, thiên tướng trời sinh, còn nội tâm hắn thì căm hận muốn gào chửi mà phải im lặng.; Tiêu Thiên ném túi da thú xuống đất, bên trong 28 viên Bổ Thiên Thạch, trưởng lão Bổ Thiên Các t…","anchor":"Những hai mươi tám viên Bổ Thiên Thạch, thật sự là kinh người.","bridge":true,"khoang":"@c0104"},{"text":"Vị thiên tài số một bị cả Hư Thần giới đồn khối u to trên đầu là do nhóc tỳ dùng búa nện xuống, liên hệ hàng chữ trên tảng đá; đã được chuyển đi vì biểu hiện kinh người ở chiến trường thứ hai, suýt nổi khùng khi bị bàn tán trong Bổ Thiên các.","anchor":"Thiếu niên áo bào màu bạc trên đầu xuất hiện khối u thật lớn","bridge":true,"khoang":"@c0107"},{"text":"Một chiêu ánh bạc cuốn bay nữ đệ tử; nghe tán thưởng thì cứng đờ nổi gân xanh cố nhịn kích động rồi rút lui; sau bị đám đệ tử mới bao vây hỏi.","anchor":"trên trán nổi lên gân xanh, hắn cố nhịn xuống kích động, chậm rãi rút lui","bridge":true,"khoang":"@c0108"}],"tuViMoc":[],"tuVi":"Tu vi kinh người, được đám bại trận xem là số một trong hơn chín vạn người tham gia đợt kiểm tra (@c0101).","nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Nhóc tỳ (Thạch Hạo) đánh lén một búa quật ngã; từng đánh lén đối phương một chưởng.","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Nhóc tỳ đánh lén trả thù","ghiChu":"Tiêu Thiên từng đánh một chưởng cướp Bổ Thiên thạch của Nhóc tỳ, bị đánh lén báo thù 2 lần (@c0102)"},{"ten":"Cổ Ngạc","tag":"khac","quanHe":"Được nhắc qua bối cảnh Nhóc tỳ bị đuổi giết","ghiChu":"Nhóc tỳ từng bị Cổ Ngạc đuổi giết, khi ấy Tiêu Thiên đánh lén Nhóc tỳ (@c0102)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị đồn là kẻ nện búa lên đầu","ghiChu":"@c0107"},{"ten":"Hùng Phi","tag":"khac","quanHe":"Trưởng lão Bổ Thiên các khen ngợi thành tích của Tiêu Thiên","ghiChu":"@c0104"},{"ten":"Trác Vân","tag":"khac","quanHe":"Trưởng lão Bổ Thiên Các dẫn đoàn tiền bối tới xem các thiếu niên thiên tài.","ghiChu":"@c0104"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đập búa ngất, cướp rồi trả lại Bổ Thiên Thạch, còn bị lột Long Tán và Hổ Dược","ghiChu":"@c0103"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Từng đánh lén một chưởng đứa nhỏ giấu mặt, sau bị chính đứa đó (Thạch Hạo) quật ngã","ghiChu":"@c0101"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Kẻ đánh lén hắn ngất, cướp rồi trả lại Bổ Thiên Thạch","ghiChu":"Bị nhóc tỳ gõ búa hai lần trúng cùng một chỗ, không cho nhìn mặt"},{"ten":"Hùng Phi","tag":"khac","quanHe":"Trưởng lão Bổ Thiên Các khen ngợi Tiêu Thiên khi dẫn đoàn đi xem thiếu niên thiên tài","ghiChu":"@c0104"}],"tuiDo":{"phapBao":[],"danDuoc":[{"ten":"Bảo đan","trangThai":"da-dung","moTa":"Nuốt một viên khôi phục trạng thái cường thịnh sau ác chiến.","nguon":"@c0101"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Bổ Thiên thạch","moTa":"Thu được 16 khối trong một đêm chinh chiến.","nguon":"@c0101"}]}},"nguon":["@c0101","@c0102","@c0107","@c0108","@c0104","@c0103"]},{"id":"thieu-nien-moc-toc","name":"Thiếu niên Mộc tộc","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Mộc tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiếu niên tộc Mộc rất mạnh tại chiến trường thứ hai, đến muộn vẫn thắng liên tiếp bảy trận nhưng cuối cùng bại dưới tay Tiêu Thiên.","vaiTro":"Cường giả phe Mộc tộc trong đợt kiểm tra, làm nền cho sức mạnh của Tiêu Thiên.","tinhCach":[{"text":"Kiêu dũng, hiếu chiến — đến muộn vẫn liên tiếp áp đảo đối thủ.","chuong":"@c0101"}],"tabs":{"diem":[],"kinhLich":[{"text":"Đến muộn vẫn thắng liên tiếp bảy trận, nhưng cuối cùng thua Tiêu Thiên, toàn thân máu bỏ chạy.; Thiếu niên Mộc tộc rất mạnh, tuy đến muộn vẫn thắng liên tiếp bảy trận, nhưng cuối cùng thua Tiêu Thiên, toàn thân đầy máu bỏ chạy.; Dù đến muộn vẫn thắng liên tiếp bảy trận, nhưng cuối cùng thua Tiêu Thiên, toàn thân đầy máu bỏ chạy.","anchor":"còn chiến thắng liên tiếp bảy trận","bridge":true,"khoang":"@c0101"}],"tuViMoc":[],"tuVi":"Tu vi rất mạnh, thắng liên tiếp bảy trận trước khi bại dưới tay Tiêu Thiên (@c0101).","nhanMach":[{"ten":"Tiêu Thiên","tag":"doi-thu","quanHe":"Bị Tiêu Thiên đánh bại sau bảy trận thắng liên tiếp.","ghiChu":""},{"ten":"Tiêu Thiên","tag":"doi-thu","quanHe":"Bại dưới tay Tiêu Thiên sau khi thắng bảy trận","ghiChu":"@c0101"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0101"]},{"id":"hung-phi-truong-lao","name":"Hùng Phi","aliases":["Hùng Phi trưởng lão","#hung-phi"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ @c0111","trangThai":"song","blurb":"Trưởng lão Bổ Thiên các gần Linh Sơn; nghe báo náo quỷ thì biến sắc, run rẩy bỏ chạy đi mời lão tiền bối.","vaiTro":"Trưởng lão Bổ Thiên các","tinhCach":[{"text":"Kinh sợ trước hiện tượng thần quái Thượng Cổ, bỏ chạy trối chết","chuong":"@c0111"}],"tabs":{"kinhLich":[{"text":"Trưởng lão Bổ Thiên Các thề tính sổ thằng ranh, quyết bắt nó trong chiến trường thứ hai, đồng ý dẫn ba nghìn đứa nhỏ và người xem lễ vào; sau khen ngợi Tiêu Thiên là kỳ tài ngút trời.; Hằn học đòi tính sổ thằng ranh, dụ rằng nó đã tham gia thử luyện tức đã là đệ tử Bổ Thiên Các để không cho chạy thoát; dẫn ba nghìn thí sinh vào chiến trường thứ hai xem lễ; nghe tiếng rống của Tiêu Thiên liền ngộ nhận đó là kỳ tài.; Cay đắng vì phải tuyển đám đôn…","anchor":"Họ đã bày ra thiên la địa võng, sớm đã phong tỏa chiến trường thứ hai rồi","bridge":true,"khoang":"@c0103"},{"text":"Đề nghị đoàn tiền bối trước tiên đi thưởng thức phong thái các thiếu niên tài tuấn, khen ngợi Tiêu Thiên; đồng thời ôm ngọn lửa giận về thằng ranh đã khiến hơn ba nghìn người xông ra khu thứ tám và tàn phá sơn lâm, quyết tóm nó.; Hùng Phi trưởng lão đề nghị đi thưởng thức phong thái các thiếu niên tài tuấn, khen ngợi Tiêu Thiên; đồng thời mang ngọn lửa giận về thằng ranh siêu quậy đã khiến hơn ba nghìn người xông ra khu thứ tám, quyết tóm nó khi…","anchor":"Những hai mươi tám viên Bổ Thiên Thạch, thật sự là kinh người.","bridge":true,"khoang":"@c0104"},{"text":"Cùng Trác Vân xuất hiện điều tra vụ xung đột đẫm máu nhưng không tìm ra kẻ cầm đầu; rít gào nửa canh giờ rồi thu hồi Khuyển Ma Công, căm giận rời đi.","anchor":"căn bản không có ai là người đẫn đầu gây chuyện, chỉ có mấy kẻ xui xẻo","bridge":true,"khoang":"@c0109"},{"text":"Nghe báo hiện tượng u linh náo động các đệ tử, trưởng lão Hùng Phi biến sắc, run rẩy bỏ chạy cùng Trác Vân đi mời lão tiền bối vì đây là chuyện thần quái Thượng Cổ tất chết người.; Nghe báo náo quỷ thì biến sắc, run rẩy bỏ chạy cùng Trác Vân đi mời lão tiền bối; tiết lộ hiện tượng thần quái Thượng Cổ cách mấy trăm năm xuất hiện một lần, tất chết không ít người.","anchor":"cứ cách mấy trăm năm xuất hiện một lần, phàm là xuất hiện, tất nhiên sẽ chết không ít người","bridge":true,"khoang":"@c0111"},{"text":"Bối phận kém, bị nhóc tỳ hoảng loạn nhảy lên bám cổ ôm chặt không buông suýt bóp tắt thở, may nhờ Phù Văn trên người mới không xỉu; phải đi thụt lùi dẫn nhóc tỳ tới cung điện vì có thi thể cổ đứng trước mặt, thầm nghi ra thân phận nhóc tỳ so với thằng nhóc ở Hư Thần giới.; Trưởng lão bối phận kém của Bổ Thiên các, bị nhóc tỳ nhảy lên bám cổ ôm không buông suýt bóp tắt thở, nhờ Phù Văn trên người mới không xỉu, phải đi thụt lùi dẫn nhóc tỳ tới cu…","anchor":"so với thằng nhóc ở Hư Thần giới còn đáng ghét hơn","bridge":true,"khoang":"@c0112"},{"text":"Hùng Phi chợt nhận ra nhóc tỳ chính là thằng nhóc quỷ từng gây loạn khiến hắn và Trác Vân khốn đốn, uất ức nhưng không dám cãi lão tiền bối; sau đó bắt gặp nó gặm Tuyết Ngọc Sâm và tố nó ăn trộm.","anchor":"Ngươi... Ngươi chính là thằng nhóc quỷ kia?!","bridge":true,"khoang":"@c0113"}],"nhanMach":[{"ten":"Trác Vân","tag":"su-mon","quanHe":"Cùng là trưởng lão Bổ Thiên các, cùng bỏ chạy đi mời lão tiền bối","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử mới gây náo loạn khiến ông biến sắc bỏ chạy","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Bị nhóc tỳ bám cổ suýt ngất, nghi ra thân phận","ghiChu":"@c0112"},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Cùng trưởng lão Bổ Thiên các hộ tống nhóc tỳ","ghiChu":"@c0112"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhận ra nó là kẻ gây loạn khiến mình khốn đốn, tố nó trộm linh dược","ghiChu":"@c0113"},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Cùng khốn đốn vì nhóc tỳ gây loạn","ghiChu":"@c0113"},{"ten":"Tiêu Thiên","tag":"khac","quanHe":"Khen ngợi thành tích đệ nhất nhân của Tiêu Thiên","ghiChu":"@c0104"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nghe Thạch Hạo báo náo quỷ","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử được nó hộ tống","ghiChu":"Bị nó bám cổ suýt ngất; nghi ra thân phận nó."},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Trưởng lão cùng Bổ Thiên các","ghiChu":"Cùng dẫn nhóc tỳ tới cung điện."},{"ten":"Đào Dã","tag":"cap-tren","quanHe":"Lão tiền bối Bổ Thiên các","ghiChu":"Cùng bàn chuyện Tử Thần."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đòi tính sổ nhóc tỳ gây họa kỳ khảo","ghiChu":"@c0103"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0111","@c0112","@c0113","@c0104","@c0109","@c0103"]},{"id":"trac-van-truong-lao","name":"Trác Vân","aliases":["Trác Vân trưởng lão","#trac-van"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ @c0111","trangThai":"song","blurb":"Trưởng lão Bổ Thiên các gần Linh Sơn; tiết lộ chuyện thần quái Thượng Cổ cách mấy trăm năm xuất hiện một lần tất chết người rồi bỏ chạy.","vaiTro":"Trưởng lão Bổ Thiên các","tinhCach":[{"text":"Hiểu biết chuyện thần quái Thượng Cổ, kinh sợ bỏ chạy đi mời lão tiền bối","chuong":"@c0111"}],"tabs":{"kinhLich":[{"text":"Trưởng lão Bổ Thiên Các nhấn mạnh quyết bắt nhóc tỳ, hé lộ nội tình Bổ Thiên Các có gốc thuốc quý được chăm bằng Hắc Hổ Sát, tương lai có thể lột xác thành Thánh Dược.; Nhấn mạnh không thông qua cũng cho thông qua để giữ chân thí sinh; mời khách xem lễ và thưởng thức gốc thuốc quý được chăm bằng Hắc Hổ Sát, tương lai có thể lột xác thành Thánh Dược, nhằm oai chấn tứ phương thu hút thêm thiên tài gia nhập.; Nhấn mạnh ai đã thử luyện là đệ tử Bổ T…","anchor":"Họ đã bày ra thiên la địa võng, sớm đã phong tỏa chiến trường thứ hai rồi","bridge":true,"khoang":"@c0103"},{"text":"Kêu mọi người bình tĩnh giữ hình tượng khi các trưởng lão định tóm thằng siêu quậy; dẫn đoàn tới hố đất có Hắc Hổ Sát canh giữ, ung dung giới thiệu cây Thánh Dược đã 800 năm sắp lột xác, nhưng khi giơ tay chỉ thì phát hiện Hắc Sát Liên đã bị đào cả gốc lẫn ngọn chỉ còn cái hố, liền từ điềm tĩnh chuyển sang nổi điên gào giận.; Trác Vân trưởng lão điềm tĩnh khuyên mọi người bình tĩnh giữ hình tượng, dẫn đoàn tới chỗ Thánh Dược có Hắc Hổ Sát canh g…","anchor":"Hắc Sát Liên không còn tăm hơi nữa, bị kẻ khác đào cả gốc lẫn ngọn mất rồi!","bridge":true,"khoang":"@c0104"},{"text":"Cùng Hùng Phi xuất hiện điều tra vụ xung đột nhưng không ai nhận là kẻ cầm đầu, chỉ có mấy kẻ xui xẻo bị thương nặng; hắn chỉ vào Chu Vũ Hào chửi mắng xối xả, tức giận rồi rít gào thu hồi Khuyển Ma Công.","anchor":"căn bản không có ai là người đẫn đầu gây chuyện, chỉ có mấy kẻ xui xẻo","bridge":true,"khoang":"@c0109"},{"text":"Trưởng lão Trác Vân tiết lộ hiện tượng u linh này có từ Thượng Cổ, cứ cách mấy trăm năm xuất hiện một lần, phàm xuất hiện tất chết không ít người; cùng Hùng Phi biến sắc chạy đi mời lão tiền bối.; Cùng Hùng Phi biến sắc, tiết lộ chuyện thần quái Thượng Cổ cách mấy trăm năm xuất hiện một lần, phàm xuất hiện tất chết không ít người; hai trưởng lão chạy đi mời lão tiền bối.","anchor":"cứ cách mấy trăm năm xuất hiện một lần, phàm là xuất hiện, tất nhiên sẽ chết không ít người","bridge":true,"khoang":"@c0111"},{"text":"Bối phận kém, giải thích cho nhóc tỳ đây là bí ẩn thần quái Thượng Cổ, mỗi lần xuất hiện đều có một đám người phải chết đa số là thiên tài; bị nhóc tỳ hoảng loạn bám lấy trước rồi mới chuyển sang Hùng Phi.; Trưởng lão bối phận kém của Bổ Thiên các, người kể cho nhóc tỳ về truyền thuyết vị thần quái Thượng Cổ mỗi lần xuất hiện đều có một đám người phải chết đa số là thiên tài, bị nhóc tỳ bám trước rồi mới chuyển sang Hùng Phi.","anchor":"phàm là người bị hắn chọn trúng đều chết hết, không có một người sống sót","bridge":true,"khoang":"@c0112"}],"nhanMach":[{"ten":"Hùng Phi","tag":"su-mon","quanHe":"Cùng là trưởng lão Bổ Thiên các, cùng bỏ chạy đi mời lão tiền bối","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử mới gây náo loạn khiến ông biến sắc bỏ chạy","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Kể truyền thuyết Tử Thần, bị nhóc tỳ bám","ghiChu":"@c0112"},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Cùng trưởng lão Bổ Thiên các","ghiChu":"@c0112"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nghe Thạch Hạo báo náo quỷ","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử nghe nó kể truyền thuyết","ghiChu":"Bị nó bám lấy trước khi chuyển sang Hùng Phi."},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Trưởng lão cùng Bổ Thiên các","ghiChu":"Cùng hộ tống nhóc tỳ."},{"ten":"Đào Dã","tag":"cap-tren","quanHe":"Lão tiền bối Bổ Thiên các","ghiChu":"Cùng bàn chuyện Tử Thần."},{"ten":"Chu Vũ Hào","tag":"khac","quanHe":"Chỉ vào Chu Vũ Hào chửi mắng xối xả","ghiChu":"@c0109"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0111","@c0112","@c0104","@c0109","@c0103"]},{"id":"thach-nghi","name":"Thạch Nghị","aliases":["Nghị nhi"],"gioiTinh":"nam","trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Đứng đợi trong sơn môn Bổ Thiên các cùng nhóm thiếu niên quyền quý để cùng trải qua nghi thức nhập môn; kỷ lục của hắn ở Hư Thần Giới bị nhóc tỳ phá, được dự báo sẽ có đối thủ về sau.","anchor":"còn có một đám thiếu niên đang đứng đợi, có Thạch Nghị","bridge":true,"khoang":"@c0105"},{"text":"Được Thạch Hạo nhìn thấy đang bước trên con đường không tận cùng dẫn vào Thượng Cổ Thánh Viện, cộng hưởng cùng đại đạo, đi nhiều ngày mà không tới cuối; là tồn tại gần như thần trong các sinh linh cùng tuổi, được lợi ích to lớn dù chưa bước vào Thánh Viện.","anchor":"hắn đi trên trên con đường đó, tuy rằng vẫn không có bước vào Thượng Cổ Thánh Viện, thế nhưng như vậy cũng có thể được lợi ích to lớn","bridge":true,"khoang":"@c0109"},{"text":"Được nêu là một trong các kỳ tài mà Bổ Thiên các định phái đi Bách Đoạn sơn, xuất thân Thượng Cổ Thánh Viện, cùng danh sách với con gái Nhân Hoàng và dòng dõi Thái Cổ di chủng.; Được nêu tên như một trong các kỳ tài của Thượng Cổ Thánh Viện mà Bổ Thiên các định phái đi Bách Đoạn sơn tranh cơ duyên.","anchor":"hiện nay nơi đó có cơ duyên lớn","bridge":true,"khoang":"@c0112"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ phá kỷ lục của hắn ở Hư Thần Giới, được dự báo thành đối thủ tương lai."},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người thân được nhóc tỳ tính nhờ giúp","ghiChu":"@c0107"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người thân cùng bộ; được Thạch Hạo dõi theo trên con đường Thánh Viện","ghiChu":"@c0109"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0105","@c0107","@c0109","@c0112"]},{"id":"hac-ho-cu-thu","name":"Hắc hổ","aliases":[],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Cự thú khổng lồ đen nhánh trong địa quật Bổ Thiên các, từng chinh chiến với Thái cổ dị chủng.","tabs":{"diem":[],"kinhLich":[{"text":"Từ trong địa quật Bổ Thiên các, cự thú khổng lồ toàn thân đen nhánh có huyết mâu to lớn đi ra, tỏa sát khí đen cuồn cuộn; truyền thần niệm cho các trưởng lão báo đây là kế điệu hổ ly sơn rồi chậm rãi lui vào địa quật biến mất.; Cự thú thân cao hơn ngọn núi, toàn thân đen nhánh có huyết mâu to lớn, từng chinh chiến với Thái cổ dị chủng, năm xưa một tiền bối cực mạnh phá bảo cụ hao tâm mới hàng phục được; từ địa quật đi ra tỏa sát khí đen cuồn cuộ…","anchor":"đây là một con cự thú có thể chinh chiến với Thái cổ dị chủng","bridge":true,"khoang":"@c0105"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Hùng Phi","tag":"khac","quanHe":"Truyền thần niệm cho Hùng Phi báo kế điệu hổ ly sơn."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0105"]},{"id":"thieu-nu-ao-trang-bo-thien-cac","name":"Thiếu nữ áo trắng","aliases":["Sư tỷ áo trắng"],"gioiTinh":"nu","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Sư tỷ Bổ Thiên các dẫn dắt tân đệ tử","tabs":{"diem":[{"text":"Nữ tử áo trắng khoảng 18-19 tuổi, thích nhéo má trêu tân đệ tử","chuong":"@c0106"},{"text":"Nhéo má trêu Nhóc tỳ, kinh ngạc vì độ lém của nó","chuong":"@c0106"}],"kinhLich":[{"text":"Đến dẫn nhóm đi gặp sư phụ, nhéo má trêu Thạch Hạo và kinh ngạc vì độ lém của nó; sau khi Thạch Hạo được Hùng Phi và Trác Vân chọn, nàng nhéo má thêm quở trách đừng nói nhiều, bảo được hai trưởng lão dạy bảo là phúc khí; dẫn trăm tân đệ tử tới cùng núi, giảng quy củ và nghiêm khắc khuyên tuyệt đối đừng đi tới Tế Cư của Tế Linh.","anchor":"có thể được hai vị trưởng lão dạy bảo đó chính là phúc khí của các ngươi","bridge":true,"khoang":"@c0106"},{"chuong":"@c0106","importance":"normal","tieuDe":"Dẫn dắt an trí tân đệ tử","text":"Đến dẫn nhóm đi gặp sư phó, nhéo má trêu Nhóc tỳ, kinh ngạc vì nó khua môi múa mép; dẫn trăm tân đệ tử đến cùng núi, giảng quy củ và nghiêm khắc cảnh báo tuyệt đối đừng đi tới Tế Cư của Tế Linh.","anchor":"có thể được hai vị trưởng lão dạy bảo đó chính là phúc khí của các ngươi"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Tân đệ tử được nàng dẫn dắt, thường bị nhéo má","ghiChu":"@c0106"}],"tuiDo":{}},"nguon":["@c0106"],"tinhCach":[{"text":"Nghiêm túc răn dạy nhưng thích trêu chọc","chuong":"@c0106"}],"blurb":"Sư tỷ Bổ Thiên các chừng mười tám mười chín tuổi, dẫn dắt và an trí tân đệ tử."},{"id":"thieu-nien-ao-bao-mau-bac","name":"Thiếu niên áo bào màu bạc","gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Tân đệ tử Bổ Thiên các, nghi từng bị Nhóc siêu quậy chọc phá","tabs":{"diem":[{"text":"Phẫn nộ nghiến răng nổi gân xanh khi nhận ra chữ khiêu khích của Nhóc siêu quậy","chuong":"@c0106"},{"text":"Nghiến răng nổi gân xanh khi nhận ra thủ phạm","chuong":"@c0106"}],"kinhLich":[{"text":"Đứng trong ba ngàn tân đệ tử, khi tảng đá Tế Linh với chữ 「Nắm Búa Nơi Tay, Ta Có Thiên Hạ」 được đưa lên, thiếu niên áo bào màu bạc lập tức nhận ra là bút tích của Nhóc siêu quậy, phẫn nộ nghiến răng, nổi gân xanh.","anchor":"Nắm Búa Nơi Tay, Ta Có Thiên Hạ","bridge":true,"khoang":"@c0106"},{"chuong":"@c0106","importance":"normal","tieuDe":"Phẫn nộ nhận ra chữ khiêu khích","text":"Nghiến răng nổi gân xanh khi nhận ra chữ trên tảng đá là của Nhóc siêu quậy; nghi là kẻ từng bị Nhóc siêu quậy chọc phá.","anchor":"Nắm Búa Nơi Tay, Ta Có Thiên Hạ"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nghi từng bị Nhóc siêu quậy chọc phá, phẫn nộ khi nhận ra thủ phạm","ghiChu":"@c0106"}],"tuiDo":{}},"nguon":["@c0106"],"tinhCach":[{"text":"Nóng nảy, dễ phẫn nộ","chuong":"@c0106"}],"blurb":"Đệ tử Bổ Thiên các phẫn nộ khi nhận ra chữ trên tảng đá là của Nhóc siêu quậy."},{"id":"lao-nhan-tang-da-xanh-bo-thien-cac","name":"Lão nhân trên tảng đá xanh","gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Cao nhân Bổ Thiên các quyết định thu nhận tân đệ tử","tabs":{"diem":[{"text":"Ánh mắt phảng phất cảnh khai thiên tích địa, cao thâm khó lường","chuong":"@c0106"},{"text":"Mắt phảng phất cảnh khai thiên tích địa","chuong":"@c0106"}],"kinhLich":[{"text":"Ngồi xếp bằng trên tảng đá xanh nhức đầu vì đợt này số qua khảo nghiệm còn ba ngàn người (thường chỉ vài trăm mỗi năm); mắt phảng phất cảnh khai thiên tích địa, quyết định vẫn thu nhận thêm môn đồ.","anchor":"Dẫn về gần chín vạn thiếu niên không có thông qua được khảo nghiệm","bridge":true,"khoang":"@c0106"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0106"],"tinhCach":[{"text":"Điềm tĩnh, thực lực kinh người ẩn giấu","chuong":"@c0106"}],"blurb":"Cao nhân Bổ Thiên các ngồi xếp bằng trên tảng đá xanh, mắt phảng phất cảnh khai thiên tích địa."},{"id":"thanh-phong","name":"Thanh Phong","gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tiểu đệ tu vi yếu nhất thiên tài doanh, bị đánh bầm nửa người và cấy Phù Văn phá tu hành.","tabs":{"diem":[],"kinhLich":[{"text":"Tân đệ tử Bổ Thiên các thân với Nhóc tỳ như anh em ruột; qua mấy ngày trên người bị thương, có máu ứ đọng, bị nghi khi dễ do tu vi thấp, khiến Nhóc tỳ nổi giận âm thầm quyết truy cứu.","anchor":"trên người có một mãng lớn máu ứ đọng","bridge":true,"khoang":"@c0106"},{"chuong":"@c0106","importance":"normal","tieuDe":"Bị thương tại Bổ Thiên các","text":"Tân đệ tử thân với Nhóc tỳ như anh em ruột; trên người bị thương có mảng lớn máu ứ đọng, nghi bị người khi dễ, khiến Nhóc tỳ nổi giận âm thầm quyết truy cứu.","anchor":"trên người có một mãng lớn máu ứ đọng"},{"text":"Tu vi yếu nhất trong thiên tài doanh, bị các thiếu niên thiên tài đánh bầm nửa người và cấy Phù Văn chạy loạn trong vết thương nhằm kéo ngã tu vi để bị đào thải; vẫn cắn răng kiên trì tới đầu tháng lấy Dược Tán và Cốt Thư, và ghi nhớ kinh văn của Tế Linh giúp tiểu ca ca; được Bóng Lông vào thăm nhưng ngăn nó báo thù vì sợ bị phát hiện.","anchor":"một số Phù Văn ở bên trong vết thương chạy loạn","bridge":true,"khoang":"@c0107"},{"text":"Bị Chu Vũ Hào ép diễn võ rồi dùng Ngư Long Phù Văn đánh bay, ngũ tạng như bể nát; sau bị hắn mượn cớ khơi thông huyết mạch hại thêm, hất vào rừng trúc; mắt đầy lửa giận nhưng không dám phát tác, siết nắm đấm trắng bệch.","anchor":"chỉ biết siết chặc nắm đấm đến nỗi năm ngón tay đều trắng bệch ra","bridge":true,"khoang":"@c0108"},{"text":"Được Thạch Hạo bảo vệ trong loạn, kinh ngạc khi biết toàn bộ phong ba đẫm máu là do một tay tiểu ca ca gây ra, miệng tròn như quả trứng; được Thạch Hạo nháy mắt tươi vui.; Được Thạch Hạo bảo vệ trong cuộc xung đột; kinh ngạc khi biết toàn bộ phong ba đẫm máu đều do một tay tiểu ca ca gây ra, miệng tròn như quả trứng.","anchor":"đó là chí bảo của Bổ Thiên các chúng ta, do Tế Linh kết ra","bridge":true,"khoang":"@c0109"},{"text":"Thanh Phong là đệ tử Thiên tài doanh, được nhóc tỳ gọi là đệ đệ; mở gói thấy một cây linh dược nguyên vẹn nên kinh sợ tưởng đồ trộm từ vườn thuốc, vì đệ tử thiên tài cũng chỉ được dùng Dược tán; đám đông xem thường nhóc tỳ vì Thanh Phong thực lực không mạnh, thậm chí chưa vào được Thiên tài doanh.","anchor":"Hắn chính là đệ đệ của ta, ta đến để đưa thuốc cho hắn","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Nhận gói linh dược từ nhóc tỳ","text":"Được nhóc tỳ tới Thiên tài doanh tặng thuốc, mở gói thấy một cây linh dược nguyên vẹn (đệ tử thiên tài thường chỉ được dùng Dược tán) nên kinh sợ, tưởng là đồ trộm từ vườn thuốc; bị đám đông xem thường vì thực lực chưa mạnh, chưa tiến vào được Thiên tài doanh.","anchor":"Hắn chính là đệ đệ của ta, ta đến để đưa thuốc cho hắn"},{"text":"Đệ đệ của Thạch Hạo ở Thiên tài doanh, nhỏ tuổi hơn người khác; được khích lệ học theo, một quyền đánh ngã kẻ bắt nạt; được giao cho môn phái và Trưởng Lão hội chiếu cố khi Thạch Hạo lên đường Bách Đoạn sơn.; Ở Thiên tài doanh, nhỏ tuổi hơn người khác nên bị bắt nạt; được nhóc tỳ (ca ca) công khai bảo vệ, khích lệ học theo đánh ngã kẻ bắt nạt và yên tâm tu hành khi ca ca lên đường đi Bách Đoạn sơn.","anchor":"Thanh Phong chính là đệ đệ của ta","bridge":true,"khoang":"@c0114"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Tiểu ca ca thân thiết","ghiChu":"@c0107"},{"ten":"Bóng Lông","tag":"dong-minh","quanHe":"Bạn đồng hành lén tới thăm","ghiChu":"@c0107"},{"ten":"Chu Vũ Hào","tag":"doi-thu","quanHe":"Kẻ ức hiếp ám toán","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Sư huynh (nhóc tỳ) bảo vệ","ghiChu":"Nhóc tỳ gài Chu Vũ Hào để trả thù cho Thanh Phong"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Được Thạch Hạo bảo vệ trong xung đột","ghiChu":"@c0109"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Được nhóc tỳ gọi là đệ đệ, nhận gói linh dược","ghiChu":"@c0113"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Ca ca","ghiChu":"Ca ca bảo vệ và khích lệ tu hành (@c0114)."},{"ten":"Bóng Lông","tag":"dong-minh","quanHe":"Con vật nhỏ vào thăm, đồng cảm, muốn báo thù giúp nhưng bị ngăn","ghiChu":"@c0107"},{"ten":"Tế Linh","tag":"khac","quanHe":"Ghi nhớ kinh văn của Tế Linh để giúp tiểu ca ca","ghiChu":"@c0107"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Ca ca, công khai bảo vệ và khích lệ tu hành","ghiChu":"@c0114"}],"tuiDo":{}},"nguon":["@c0107","@c0108","@c0109","@c0113","@c0114","@c0106"],"aliases":["tiểu Thanh Phong"]},{"id":"bong-long","name":"Bóng Lông","gioiTinh":"khong-ro","theLuc":[],"trangThai":"song","blurb":"Con vật nhỏ đồng hành cùng Thạch Hạo, giỏi lang thang Linh sơn hái linh dược.","tabs":{"diem":[],"kinhLich":[{"text":"Sau nhiều ngày lang thang trên Linh sơn/Bảo Sơn chỉ hái được một cây linh thảo nên tức giận, tìm về phòng nhóc tỳ; bị tóm đuôi phát hiện mùi linh dược trên móng vuốt, được sai đi điều tra và thăm Thanh Phong, sau nửa đêm về báo lại toàn bộ tao ngộ.","anchor":"nhanh chóng nắm chặt lấy đuôi của Bóng Lông","bridge":true,"khoang":"@c0107"},{"text":"Bị nhóc tỳ xách đuôi lẻn vào khu vườn cổ nơi Tế Linh ở ẩn; sợ hãi nhảy lên vai trước sức mạnh ma quái hút địa khí; cùng nhóc tỳ muốn hái trái hồ lô xanh nhưng bị bản năng ngăn; hoảng sợ trước lão già tóc xám.","anchor":"nơi đó có từng tia khí Hỗn Độn lượn lờ, bao phủ hồ lô màu xanh","bridge":true,"khoang":"@c0110"},{"importance":"normal","chuong":"@c0111","tieuDe":"Sợ hãi trốn sau lưng Thạch Hạo","text":"Khi ông lão tử khí Thượng Cổ cản đường, Bóng Lông khẩn trương trốn sau lưng Thạch Hạo, nắm cổ áo như gấu túi, va vào đầu ông lão hét thảm.; Trốn sau lưng Thạch Hạo khẩn trương khi ông lão tử khí xuất hiện, nắm cổ áo như gấu túi, va vào đầu ông lão hét thảm.","anchor":"một ông lão không có sự sống cản đường nó"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Chủ nhân/bạn đồng hành","ghiChu":"@c0107"},{"ten":"Thanh Phong","tag":"dong-minh","quanHe":"Bạn nhỏ được lén thăm","ghiChu":"@c0107"},{"ten":"Thanh Phong","tag":"dong-minh","quanHe":"Vào thăm khi bị thương, muốn báo thù giúp nhưng bị ngăn","ghiChu":"@c0107"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Sinh linh nhỏ theo Thạch Hạo, sợ hãi trốn sau lưng","ghiChu":"@c0111"}],"tuiDo":{"linhThao":[{"ten":"Linh thảo Linh sơn","moTa":"Một cây linh thảo Bóng Lông hái được trên Linh sơn/Bảo Sơn khí lành, nguy hiểm mới lấy được.","nguon":"@c0107"}]}},"nguon":["@c0107","@c0111","@c0110"]},{"id":"vu-phong","name":"Vũ Phong","cn":"","aliases":["Bạch y Vũ Phong","Thiếu niên áo trắng"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiên tài áo trắng cao gầy, khí chất như ngọc, cường giả nổi danh từng đánh bại hơn mười cường giả vây công, có muội muội tên Vũ Lâm.","vaiTro":"Sư huynh thiên tài doanh, kêu gọi hòa khí giữa các đệ tử","tinhCach":[{"text":"Ôn hòa, khí chất như ngọc, mỉm cười nói chuyện, kêu gọi không tổn thương hòa khí"}],"tabs":{"diem":[{"text":"Cường giả nổi danh từng dẫn sấm sét, phù văn vàng đánh tan hơn mười cường giả vây công","chuong":"@c0108"}],"kinhLich":[{"text":"Tự giới thiệu với đệ tử mới, nhấn mạnh tu hành có trước sau nhưng không phân địa vị cao thấp; đồng ý tha Thanh Phong khi bị Chu Vũ Hào ức hiếp; bị nhóm thiếu nữ vây quanh thỉnh giáo đông nhất.","anchor":"Ta tên Vũ Phong, nhập môn sớm hơn mọi người mấy năm","bridge":true,"khoang":"@c0108"},{"text":"Muốn ngăn cản cuộc xung đột quy mô lớn giữa đệ tử mới và thiên tài doanh nhưng biết chắc không có tác dụng khi hơn ba ngàn người dùng Phù Văn đối kháng.","anchor":"người kêu gào đầu tiên tự nhiên là nó","bridge":true,"khoang":"@c0109"},{"text":"Cường giả áo trắng trong Thiên tài doanh, được người khác giục ra tay áp chế nhóc tỳ nhưng lắc đầu không xuất thủ, chỉ có tinh quang lóe trong mắt và chắp tay sau lưng — ám chỉ cường giả tiềm ẩn.","anchor":"Bạch y Vũ Phong lắc đầu, vẫn không xuất thủ","bridge":true,"khoang":"@c0114"}],"tuViMoc":[],"nhanMach":[{"ten":"Vũ Lâm","tag":"ho-hang","quanHe":"Muội muội","ghiChu":"Thiếu nữ thiên tài kiều diễm mỹ lệ"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Cường giả quan sát","ghiChu":"Không ra tay với nhóc tỳ, chỉ lóe tinh quang (@c0114)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Được giục ra áp chế nhưng từ chối xuất thủ","ghiChu":"@c0114"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0108","@c0109","@c0114"]},{"id":"vu-lam","name":"Vũ Lâm","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Muội muội của Vũ Phong, thiếu nữ thiên tài kiều diễm mỹ lệ.","vaiTro":"Thiếu nữ thiên tài, muội muội Vũ Phong","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Được nhắc là muội muội của Vũ Phong, cũng là thiếu nữ thiên tài kiều diễm.","anchor":"Ta tên Vũ Phong, nhập môn sớm hơn mọi người mấy năm","bridge":true,"khoang":"@c0108"}],"tuViMoc":[],"nhanMach":[{"ten":"Vũ Phong","tag":"ho-hang","quanHe":"Huynh trưởng","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0108"]},{"id":"chu-vu-hao","name":"Chu Vũ Hào","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiên tài da màu cổ đồng, mắt có Phù Văn, giả bộ sư huynh ôn hòa nhưng ám toán đánh trọng thương Thanh Phong, sau bị nhóc tỳ gài bẫy truy sát.","vaiTro":"Thiên tài Bổ Thiên các, kẻ ức hiếp Thanh Phong","tinhCach":[{"text":"Giả nhân giả nghĩa, ngoài mặt ôn hòa nhưng lén dùng ám kình hại người yếu hơn"},{"text":"Miệng nhanh hơn não, tự chuốc họa vì nói linh tinh"}],"tabs":{"diem":[{"text":"Giả bộ sư huynh tốt nhưng dùng ám kình đánh trọng thương Thanh Phong, sau bị nhóc tỳ gài cho mấy trăm người đuổi đánh","chuong":"@c0108"}],"kinhLich":[{"text":"Ép Thanh Phong diễn võ, dùng Ngư Long Phù Văn kèm ám kình đánh nó bay ngã ngũ tạng như bể nát; sau mượn cớ khơi thông huyết mạch hại thêm lần nữa; rồi bị nhóc tỳ đấm nở hoa mặt, vu là đồng bọn nhóc siêu quậy, mấy trăm đệ tử mới đuổi đánh đến răng bay hộc máu chạy trối chết.","anchor":"Một con Ngư Long phát sáng đánh nó bay ra ngoài","bridge":true,"khoang":"@c0108"},{"text":"Bị mấy trăm rồi hơn ngàn thiếu niên các bộ lạc đánh hội đồng vì trước đó tuyên bố biết chỗ nhóc siêu quậy; bị Phù Chưởng thần bí đánh gãy xương sườn trái, ngã xuống bị biển người giẫm đạp, gãy hết răng, gãy chín phần mười xương cốt, tàn phế, cần mấy tháng điều dưỡng bằng Dược Tán.","anchor":"Toàn bộ hàm răng của hắn đều bị đánh bay, bị mọi người vừa đạp vừa đánh khiến toàn thân vô lực.","bridge":true,"khoang":"@c0109"},{"text":"Đang bị thương phải nhờ Bảo Dược của tộc mới bình phục, núp trong đám người chỉ đặt cược ít vì tin nhóc tỳ sẽ bị dạy dỗ; bị Thạch Hạo chủ động đánh một quyền vào mặt hôn mê, trước khi ngất nhận ra cú đấm quen thuộc và hiểu nhóc tỳ chính là ca ca của Thanh Phong.; Đang bị thương (từng suýt bị giẫm chết trong xung đột đẫm máu trước, nhờ Bảo Dược của tộc mới bình phục), Chu Vũ Hào núp trong đám người chỉ đặt cược ít; bị nhóc tỳ chủ động đấm một quy…","anchor":"nó chính là ca ca của Thanh Phong","bridge":true,"khoang":"@c0114"}],"tuViMoc":[],"nhanMach":[{"ten":"Thanh Phong","tag":"doi-thu","quanHe":"Đệ tử bị hắn ức hiếp","ghiChu":"Cùng hai thiên tài khác từng đánh Thanh Phong"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ gài bẫy truy sát","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo giật dây đánh hội đồng, một quyền của hắn khiến mặt nở hoa","ghiChu":"@c0109"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Cựu thù","ghiChu":"Bị nhóc tỳ đấm gục, nhận ra là ca ca của Thanh Phong (@c0114)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo đánh gục, nhận ra thân phận","ghiChu":"@c0114"},{"ten":"Trác Vân","tag":"khac","quanHe":"Bị Trác Vân chỉ vào chửi mắng xối xả sau vụ việc","ghiChu":"@c0109"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Ngư Long Phù Văn","moTa":"Phù Văn hóa Ngư Long phát sáng, kèm ám kình","nguon":"@c0108"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0108","@c0109","@c0114"]},{"id":"ong-lao-cam-ho-lo-vo-vang","name":"Ông lão cầm hồ lô vỏ vàng","aliases":["Ông lão ngồi trước sơn môn","Lão tiền bối cầm hồ lô vàng","Ông lão cầm hồ lô vỏ vàng"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Cao tầng Bổ Thiên các ngồi trước sơn môn, dùng hồ lô vỏ vàng nuốt hết bão táp dẹp loạn cuộc nội chiến.","vaiTro":"Cao tầng Bổ Thiên các","tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0109","tieuDe":"Dùng hồ lô vỏ vàng dẹp loạn","text":"Ngồi trước sơn môn, triệu hồ lô vỏ vàng từ hư không nuốt hết bão táp đủ hủy diệt vùng núi như cá voi hút nước, ra lệnh người dẫn đầu gây chuyện diện bích ba năm rồi vung tay áo rời đi.; Từ hư không thả ra một hồ lô vỏ vàng nuốt hết bão táp mãnh liệt đủ hủy diệt vùng núi như cá voi hút nước; hồ lô thu nhỏ bằng lòng bàn tay rơi vào tay ông; ông ra lệnh người dẫn đầu gây chuyện diện bích ba năm rồi vung tay áo rời đi.","anchor":"một cái hồ lô vỏ vàng từ trong hư không xuất hiện, màu vàng óng, toả ra hi quang, sau đó giống như là cá voi hút nước, nuốt hết tất cả bão táp mãnh liệt"},{"text":"Cầm hồ lô vàng óng tràn khí Hỗn Độn dẫn đám trưởng lão tới giải cứu nhóc tỳ; giải thích vị thần quái xưng Tử Thần cách mấy trăm năm xuất thế một lần, thanh kiếm cắm đầu Hắn là của đối thủ ngày xưa còn kiếm thật rơi mất ở Bách Đoạn sơn mạch; nêu Bổ Thiên các định phái kỳ tài đi Bách Đoạn sơn tranh cơ duyên lớn, nếu Tử Thần chọn nhóc tỳ thì các thêm một suất.","anchor":"chúng ta không muốn thanh kiếm này, mà là tới giải cứu cháu","bridge":true,"khoang":"@c0112"}],"nhanMach":[]},"nguon":["@c0109","@c0112"]},{"id":"tu-than","name":"Tử Thần","aliases":["Ông lão tóc xám","Ông lão tử khí","U linh Thượng Cổ","Ông lão tóc xám (u linh Thượng Cổ)","u linh Thượng Cổ"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ (tồn tại tử khí Thượng Cổ) @c0111","trangThai":"khong-ro","blurb":"Tồn tại tử khí thời Thượng Cổ, tóc xám nhuốm máu đen khô cứng, y phục Thượng Cổ, một cổ kiếm rỉ sét cắm trên đầu, mắt trống rỗng; liên tục cản đường Thạch Hạo đòi trả kiếm.","vaiTro":"U linh Thượng Cổ bám theo Thạch Hạo","tinhCach":[{"text":"Cố chấp lặp đi lặp lại lời đòi trả kiếm, tái tạo từ hư không mỗi khi bị né tránh","chuong":"@c0111"}],"tabs":{"kinhLich":[{"text":"Ông lão tử khí Thượng Cổ với cổ kiếm rỉ sét cắm trên đầu, mắt trống rỗng, cản đường Thạch Hạo tại nơi ở Tế Linh, tái tạo từ hư không mỗi khi bị né; lặp lại “Trả kiếm cho ta”, khi Thạch Hạo hứa trả thì biến mất giữa sấm chớp; sáu ngày sau hiện lần hai bên giường, các đệ tử không nhìn thấy nhưng sờ được như tượng băng, cả đám kinh hoàng bỏ chạy.","anchor":"một ông lão không có sự sống cản đường nó","bridge":true,"khoang":"@c0111"},{"text":"Vị thần quái Thượng Cổ bị cổ kiếm đâm xuyên đầu, cách mấy trăm năm xuất thế một lần cùng dịp Bách Đoạn sơn mở ra; ai bị Hắn chọn trúng mà không giúp được đều chết. Lần này Hắn chọn một đệ tử bình thường thay vì thiên tài; kiếm thật của Hắn rơi mất ở Bách Đoạn sơn mạch cần người tìm về.; Vị tồn tại thần quái Thượng Cổ bị cổ kiếm đâm xuyên đầu, xưng Tử Thần, cách mấy trăm năm xuất thế một lần cùng dịp Bách Đoạn sơn mở ra; phàm người bị Hắn chọn tr…","anchor":"phàm là người bị hắn chọn trúng đều chết hết, không có một người sống sót","bridge":true,"khoang":"@c0112"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cản đường đòi trả kiếm; được Thạch Hạo hứa tìm giúp trả kiếm rồi bị cưỡi lên cổ","ghiChu":"@c0111"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chọn trúng nhóc tỳ (đệ tử bình thường) thay vì thiên tài","ghiChu":"@c0112"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đệ tử bị Hắn chọn trúng","ghiChu":"Đặt lên nó nhiệm vụ tìm kiếm thật ở Bách Đoạn sơn."},{"ten":"Đào Dã","tag":"khac","quanHe":"Người giải thích chân tướng Hắn","ghiChu":"Đào Dã kể lai lịch Tử Thần cho đám thiếu niên."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cản đường, đòi trả kiếm; chỉ Thạch Hạo nhìn thấy được, cuối cùng bị cưỡi lên cổ","ghiChu":"@c0111"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0111","@c0112"]},{"id":"dao-da","name":"Đào Dã","aliases":["Lão tiền bối cầm hồ lô vàng","Ông lão cầm hồ lô vỏ vàng","Lão quái vật","Nguyên lão Bổ Thiên các","Nguyên lão Đào Dã"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Dẫn đầu đám trưởng lão bay tới, cầm hồ lô vàng óng tràn khí Hỗn Độn; giải thích vị thần quái xưng Tử Thần cách mấy trăm năm xuất thế một lần, thanh kiếm cắm đầu Hắn là của đối thủ ngày xưa còn kiếm thật rơi mất ở Bách Đoạn sơn cần người tìm về, và nay nơi đó đã thành cơ duyên lớn để nhóc tỳ có thêm một suất.","anchor":"hiện nay nơi đó có cơ duyên lớn","bridge":true,"khoang":"@c0112"},{"text":"Đào Dã cầm đầu nhóm nguyên lão, giọng ôn hòa; dọa nếu nhóc tỳ không đi Bách Đoạn sơn thì Hắn không đáp ứng và nó sớm muộn mất mạng vì mang Tang thần bên người; cho Hùng Phi dẫn nó xuống bàn bạc; sau vụ trộm Tuyết Ngọc Sâm thì bất đắc dĩ dặn canh chừng, cấm nó lại gần vườn thuốc, hứa lần sau cho hẳn một sọt củ cải thật.","anchor":"sau này không có phép nó đến gần vườn thuốc nữa","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Ép nhóc tỳ đi, dặn canh vườn thuốc","text":"Cầm đầu nhóm nguyên lão, dùng ‘Hắn’ và Tang thần bên người nhóc tỳ để ép nó vào Bách Đoạn sơn; cho Hùng Phi dẫn nó xuống bàn bạc; bị nó lừa hỏi ‘củ cải’ ở vườn rau nên vô tình gật đầu cho ăn Tuyết Ngọc Sâm; bất đắc dĩ dặn canh chừng, cấm nó lại gần vườn thuốc, hứa lần sau cho hẳn một sọt củ cải thật.","anchor":"sau này không có phép nó đến gần vườn thuốc nữa"},{"text":"Cho biết Thạch Nghị, con gái Nhân hoàng cùng hậu duệ Thái cổ di chủng đã được tộc nhân hộ tống đến Bách Đoạn sơn mạch từ trước.; Đào Dã cho biết Thạch Nghị, con gái Nhân hoàng cùng hậu duệ Thái cổ di chủng đã được tộc nhân hộ tống đến Bách Đoạn sơn mạch từ trước, đặt sân khấu cho tuyến truyện với các dòng dõi đỉnh cấp.","anchor":"còn có hậu duệ của Thái cổ di chủng nữa","bridge":true,"khoang":"@c0114"},{"text":"Phụ trách dẫn đội hộ tống tiểu sư đệ và năm thiếu niên thiên tài (ba nam hai nữ) qua con đường Thanh Kim của Tế Linh vào Đoạn Không thành; giới thiệu Bách Đoạn sơn mấy trăm năm mở một lần; khi phu xe tiểu Bạch Hổ gây sự, lấy ra hồ lô vàng lưu chuyển Phù Văn xưng danh Bổ Thiên các (Thượng Cổ Tịnh Thổ) để dằn mặt.; Đào Dã dẫn đội hộ tống nhóc tỳ (tiểu sư đệ) và năm thiếu niên thiên tài qua con đường Thanh Kim vào Đoạn Không thành; khi tiểu Bạch Hổ…","anchor":"chúng ta tới từ Tây Lăng thú sơn","bridge":true,"khoang":"@c0115"},{"chuong":"@c0115","importance":"normal","tieuDe":"Dẫn đội tới Đoạn Không thành","text":"Dẫn đội Bổ Thiên các hộ tống nhóc tỳ và năm thiếu niên thiên tài qua con đường Thanh Kim vào Đoạn Không thành; khi xung đột với tiểu Bạch Hổ Tây Lăng thú sơn, Đào Dã lấy hồ lô vàng lưu chuyển Phù Văn ra dằn mặt phu xe, xưng danh Bổ Thiên các Thượng Cổ Tịnh Thổ.","anchor":"chúng ta tới từ Tây Lăng thú sơn"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Lão tiền bối ép nó đi Bách Đoạn sơn, bị nó lừa lấy Tuyết Ngọc Sâm","ghiChu":"@c0113"},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Sai Hùng Phi dẫn và canh chừng nhóc tỳ","ghiChu":"@c0113"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Báo tin","ghiChu":"Cho nhóc tỳ biết tin các dòng dõi đỉnh cấp đã đến Bách Đoạn sơn (@c0114)."},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Hộ tống tiểu sư đệ","ghiChu":"Dẫn đội tới Bách Đoạn sơn"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Tiểu sư đệ ranh mãnh khiến Đào Dã nhiều phen nghẹn họng","ghiChu":"@c0117"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử được Tử Thần chọn trúng","ghiChu":"Giải thích nhiệm vụ Bách Đoạn sơn cho nó."},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Trưởng lão cùng Bổ Thiên các","ghiChu":"Cùng tới hộ tống nhóc tỳ."},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Trưởng lão cùng Bổ Thiên các","ghiChu":"Cùng bàn bạc chuyện Tử Thần."},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Báo tin về các dòng dõi đỉnh cấp đã đến Bách Đoạn sơn","ghiChu":"@c0114"},{"ten":"Phu xe Tây Lăng thú sơn","tag":"doi-thu","quanHe":"Đối chọi khi phu xe gây sự với đệ tử","ghiChu":"Dằn mặt bằng hồ lô Phù Văn (@c0115)"},{"ten":"Nhóc tỳ","tag":"su-mon","quanHe":"Nguyên lão hộ tống tiểu sư đệ","ghiChu":"Dẫn đội bảo vệ nhóc tỳ tới Bách Đoạn sơn"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0113","@c0114","@c0115","@c0117","@c0112"],"vaiTro":"Nguyên lão Bổ Thiên các phụ trách dẫn đội, điềm tĩnh, dùng hồ lô Phù Văn dằn mặt phu xe Tây Lăng.","tinhCach":[{"text":"Điềm tĩnh, cứng rắn khi đối chọi","chuong":"@c0115"}],"blurb":"Nguyên lão Bổ Thiên các dẫn đội hộ tống các thiếu niên thiên tài tới Bách Đoạn sơn."},{"id":"bon-lao-tien-boi-bo-thien-cac","name":"Bốn lão tiền bối Bổ Thiên các","aliases":["Bốn lão già","Bốn vị lão tiền bối"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Bốn cường giả Bổ Thiên các mắt ánh xanh tuyên bố đánh nhóc tỳ một trận để thử; kinh ngạc khen thân thể nó nghịch thiên khi nó phản kích gây tiếng sấm; can Hùng Phi, dỗ nhóc tỳ rồi giao nó vào Bách Đoạn sơn tìm Bất Lão thần tuyền, hứa khắc Bất Hủ Thần Bi và cho vào Tàng Kinh các chọn Bảo Thuật.","anchor":"quả nhiên đủ mạnh, thân thể như vậy cũng có thể xem như nghịch thiên rồi","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Thử thân thể, giao nhiệm vụ thần tuyền","text":"Bốn lão già mắt ánh xanh thử thân thể nhóc tỳ, kinh ngạc khen thân thể nghịch thiên; can Hùng Phi, dỗ nhóc tỳ rồi giao nhiệm vụ vào Bách Đoạn sơn tìm Bất Lão thần tuyền mang về, hứa khắc tên lên Bất Hủ Thần Bi và cho vào Tàng Kinh các chọn Bảo Thuật; cảnh báo muốn tới gần thần tuyền phải phá Phù Văn của Thượng Cổ Thánh trận.","anchor":"Sau khi ngươi tiến vào Bách Đoạn sơn, nhất định phải lưu ý, tìm kiếm Bất Lão thần tuyền"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Thử thân thể nó rồi giao nhiệm vụ Bất Lão thần tuyền","ghiChu":"@c0113"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0113"]},{"id":"thieu-nu-ao-xanh-thien-tai-doanh","name":"Thiếu nữ áo xanh","gioiTinh":"nu","theLuc":[{"ten":"Thiên tài doanh","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Thiếu nữ ~15-16 tuổi, da trắng như tuyết, tóc như thác nước, mắt trong như thu thủy, bước tới nhận khiêu chiến nhóc tỳ để đoạt cây linh dược, mở màn ván tỉ thí.","anchor":"Ta tới khiêu chiến, thắng, có thể đưa cây linh dược của ngươi cho ta?","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Khiêu chiến đoạt linh dược","text":"Thiếu nữ chừng mười lăm mười sáu tuổi, da trắng như tuyết, tóc như thác nước, mắt trong như thu thủy, bước tới nhận khiêu chiến nhóc tỳ để đoạt cây linh dược; chấp nhận ván cược, đặt cược bằng báu vật Dược tán cùng vài vật linh tinh cho đủ tiền cược.","anchor":"Ta tới khiêu chiến, thắng, có thể đưa cây linh dược của ngươi cho ta?"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bước tới khiêu chiến để đoạt cây linh dược của nó","ghiChu":"@c0113"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0113"]},{"id":"thieu-nu-ao-da-thu-thien-tai-doanh","name":"Thiếu nữ áo da thú","gioiTinh":"nu","theLuc":[{"ten":"Thiên tài doanh","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Thiếu nữ da màu lúa mạch, cánh tay để trần, tính cách ngỗ ngược, bước lên nhận một phần cược trong ván đánh cược quanh cây linh dược, dọa cho nhóc tỳ không còn răng mà húp cháo.","anchor":"Ngươi quá tự tin, vậy thì tính ta một phần.","bridge":true,"khoang":"@c0113"},{"chuong":"@c0113","importance":"normal","tieuDe":"Nhận một phần ván cược","text":"Thiếu nữ mặc áo da thú, da màu lúa mạch, cánh tay để trần, tính cách ngỗ ngược bước lên nhận một phần ván cược, dọa cho nhóc tỳ ‘không còn răng mà húp cháo’.","anchor":"Ngươi quá tự tin, vậy thì tính ta một phần."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhận một phần ván cược, dọa đánh nhóc tỳ","ghiChu":"@c0113"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0113"]},{"id":"ngan-tam","name":"Ngạn Tâm","gioiTinh":"nu","trangThai":"song","blurb":"Thiếu nữ áo xanh da trắng ở Thiên tài doanh, dùng Phù Văn tạo gió cùng Khổng Tước xanh và lưới ngọc bích.","tabs":{"diem":[],"kinhLich":[{"text":"Ra tay đầu tiên trong đổ chiến, dùng Phù Văn tạo gió thả Khổng Tước xanh phát sáng và lưới ngọc bích tấn công; bị Thạch Hạo đánh tan Khổng Tước bằng búa bạc, đánh nát lưới rồi bắt cổ tay xoay ra sau lưng khống chế, thua nhanh và xấu hổ đỏ mặt.; Thiếu nữ áo xanh da trắng, dùng Phù Văn tạo gió dưới chân thả Khổng Tước xanh phát sáng tấn công rồi phản công bằng lưới ngọc bích; bị nhóc tỳ đánh tan Khổng Tước và lưới, bắt cổ tay xoay ra sau lưng đặt…","anchor":"liền nắm lấy cổ tay của Ngạn Tâm","bridge":true,"khoang":"@c0114"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đấu cược","ghiChu":"Bị nhóc tỳ khống chế bắt sống (@c0114)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo khống chế bắt sống","ghiChu":"@c0114"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0114"],"aliases":["Thiếu nữ áo xanh"]},{"id":"phieu-tuyet","name":"Phiêu Tuyết","gioiTinh":"nu","trangThai":"song","blurb":"Thiếu nữ áo da thú, da màu lúa mì, gợi cảm ngỗ ngược, dùng hào quang kết thành chiến mâu.","tabs":{"diem":[],"kinhLich":[{"text":"Đối thủ thứ hai trong đổ chiến, kết hào quang thành chiến mâu phá không đâm tới; bị Thạch Hạo tạo cối xay bạc nghiền tan vũ khí rồi vọt tới nhấn eo, phẩy chưởng làm rơi một cọng tóc, thua hoàn toàn.; Thiếu nữ áo da thú da màu lúa mì, dùng hào quang kết thành chiến mâu phá không đâm tới; bị nhóc tỳ né rồi tạo cối xay bạc nghiền tan chiến mâu, vọt tới nhấn eo phẩy chưởng làm rơi một cọng tóc — thua hoàn toàn.","anchor":"một cối xay màu bạc xuất hiện","bridge":true,"khoang":"@c0114"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đấu cược","ghiChu":"Bị nghiền tan chiến mâu, thua (@c0114)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo nghiền tan chiến mâu, thua","ghiChu":"@c0114"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0114"],"aliases":["Thiếu nữ áo da thú"]},{"id":"so-ha","name":"Sở Hạ","aliases":["Thiếu niên áo tím"],"gioiTinh":"nam","theLuc":[{"ten":"Sở gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (tu vi sâu không lường) @c0115","trangThai":"song","vaiTro":"Con cháu Thượng Cổ thế gia Sở gia ở Hỏa quốc","tabs":{"diem":[{"text":"Thiếu niên áo tím ~17-18 tuổi, tu vi sâu không lường, chủ động kết minh","chuong":"@c0115"}],"kinhLich":[{"text":"Thiếu niên áo tím ~17-18 tuổi tự xưng Sở Hạ, đến từ Hỏa quốc, con cháu Thượng Cổ thế gia Sở gia, tu vi sâu không lường, chủ động duỗi cành ô-liu kết minh với đoàn; bị thiếu niên họ Cổ ra mỉa mai chuyện lôi kéo đồng minh.; Thiếu niên áo tím tự xưng Sở Hạ, đến từ Hỏa quốc, con cháu Thượng Cổ thế gia Sở gia, duỗi cành ô-liu kết minh với đoàn Bổ Thiên các; bị thiếu niên họ Cổ ra mỉa mai chuyện lôi kéo đồng minh.","anchor":"Ta là Sở Hạ, đến từ Hỏa quốc.","bridge":true,"khoang":"@c0115"},{"chuong":"@c0115","importance":"normal","tieuDe":"Chào kết minh với Bổ Thiên các","text":"Thiếu niên áo tím tự xưng Sở Hạ, đến từ Hỏa quốc, con cháu Thượng Cổ thế gia Sở gia, tu vi sâu không lường, chủ động duỗi cành ô-liu kết minh với đoàn; bị thiếu niên họ Cổ mỉa mai.","anchor":"Ta là Sở Hạ, đến từ Hỏa quốc."}],"tuViMoc":[],"nhanMach":[{"ten":"Thiếu niên họ Cổ","tag":"doi-thu","quanHe":"Bị mỉa mai chuyện kết minh","ghiChu":"Cổ gia tuyên bố không kết minh"},{"ten":"Thiếu niên họ Cổ","tag":"doi-thu","quanHe":"Bị mỉa mai chuyện lôi kéo đồng minh","ghiChu":"Mâu thuẫn Sở gia vs Cổ gia (@c0115)"}],"tuiDo":{}},"nguon":["@c0115"],"tinhCach":[{"text":"Chủ động, khéo léo lôi kéo đồng minh","chuong":"@c0115"}],"blurb":"Thiếu niên áo tím Hỏa quốc, con cháu Thượng Cổ thế gia Sở gia, chủ động kết minh với đoàn Bổ Thiên các."},{"id":"thieu-nien-ho-co","name":"Thiếu niên họ Cổ","aliases":["Thiếu niên áo xanh Cổ gia"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ gia","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Con cháu Cổ gia, ngạo mạn không kết minh","tabs":{"diem":[{"text":"Thiếu niên áo xanh, mỉa mai kẻ lôi kéo đồng minh","chuong":"@c0115"}],"kinhLich":[{"text":"Thiếu niên áo xanh họ Cổ (Cổ gia) đi ra mỉa mai Sở Hạ lôi kéo đồng minh, tuyên bố Cổ gia không thèm kết minh.; Thiếu niên áo xanh của Cổ gia đi ra mỉa mai Sở Hạ lôi kéo đồng minh, tuyên bố Cổ gia không thèm kết minh.","anchor":"Ta là Sở Hạ, đến từ Hỏa quốc.","bridge":true,"khoang":"@c0115"},{"chuong":"@c0115","importance":"normal","tieuDe":"Từ chối kết minh","text":"Thiếu niên áo xanh của Cổ gia đi ra mỉa mai Sở Hạ lôi kéo đồng minh, tuyên bố Cổ gia không thèm kết minh.","anchor":"Ta là Sở Hạ, đến từ Hỏa quốc."}],"tuViMoc":[],"nhanMach":[{"ten":"Sở Hạ","tag":"doi-thu","quanHe":"Mỉa mai chuyện kết minh","ghiChu":""},{"ten":"Sở Hạ","tag":"doi-thu","quanHe":"Ra mỉa mai chuyện kết minh","ghiChu":"Mâu thuẫn Sở gia vs Cổ gia (@c0115)"}],"tuiDo":{}},"nguon":["@c0115"],"tinhCach":[{"text":"Kiêu ngạo, không thèm kết minh","chuong":"@c0115"}],"blurb":"Thiếu niên áo xanh Cổ gia, mỉa mai Sở Hạ và tuyên bố Cổ gia không kết minh."},{"id":"thieu-nien-nuoi-linh-tuoc","name":"Thiếu niên nuôi Linh Tước","aliases":["Thiếu niên uống trà"],"gioiTinh":"nam","trangThai":"song","vaiTro":"Chủ nhân con Linh Tước năm màu (Ma Cầm), thực lực khó lường","tabs":{"diem":[{"text":"Uống trà điềm nhiên, thả Linh Tước diệt sạch đám tranh đấu","chuong":"@c0115"}],"kinhLich":[{"text":"Đang uống trà ở quán trà thì con cháu hai gia tộc động thủ trên phố; vỗ bàn quát, con Linh Tước năm màu trên vai bay lên hút thành vòng xoáy nuốt mấy chục người, nghiền nát trong miệng rồi bay về; cả phố lặng ngắt. Nhóc tỳ nhìn con Linh Tước mà thèm chảy nước bọt.; Khi con cháu hai gia tộc động thủ trên phố, thiếu niên đang uống trà ở quán vỗ bàn quát; con Linh Tước năm màu trên vai bay lên hút thành vòng xoáy, nuốt mấy chục người và nghiền nát…","anchor":"mấy chục người vỡ nát trong miệng nó","bridge":true,"khoang":"@c0115"},{"chuong":"@c0115","importance":"normal","tieuDe":"Thả Ma Cầm diệt đám tranh đấu","text":"Thiếu niên đang uống trà ở quán trà vỗ bàn quát; con Linh Tước năm màu (Ma Cầm) trên vai hắn bay lên hút thành vòng xoáy, nuốt mấy chục người con cháu hai gia tộc động thủ, nghiền nát trong miệng rồi bay về, cả phố lặng ngắt.","anchor":"mấy chục người vỡ nát trong miệng nó"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"linhThu":[{"ten":"Linh Tước năm màu","moTa":"Ma Cầm năm màu trên vai, thần thông nuốt người thành vòng xoáy.","nguon":"@c0115"}]}},"nguon":["@c0115"],"tinhCach":[{"text":"Ung dung, thực lực khó lường","chuong":"@c0115"}],"blurb":"Thiếu niên uống trà ở quán, chủ nhân con Linh Tước năm màu (Ma Cầm) diệt sạch đám tranh đấu."},{"id":"phu-xe-tay-lang-thu-son","name":"Phu xe Tây Lăng thú sơn","aliases":["Phu xe Nhân tộc"],"gioiTinh":"nam","theLuc":[{"ten":"Tây Lăng thú sơn","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Cường giả Nhân tộc đánh xe cho tiểu Bạch Hổ","tabs":{"diem":[{"text":"Cứng rắn đối chọi Bổ Thiên các, truyền lời của Bạch Hổ","chuong":"@c0115"}],"kinhLich":[{"text":"Đánh xe cho tiểu Bạch Hổ (Thái Cổ dị chủng); khi nữ đệ tử Bổ Thiên các lỡ lời, bắt nàng tự vả miệng, Bạch Hổ muốn ăn thịt nàng; khi Đào Dã đưa hồ lô xưng danh Bổ Thiên các thì đổi sắc mặt nhưng đáp trả rằng họ đến từ Tây Lăng thú sơn, hẹn gặp lại ở Bách Đoạn sơn.; Phu xe Nhân tộc kéo xe cho tiểu Bạch Hổ; khi nữ đệ tử Bổ Thiên các lỡ lời, hắn bắt tự vả miệng, Bạch Hổ muốn ăn thịt nàng. Trước hồ lô Phù Văn của Đào Dã, phu xe đổi sắc mặt nhưng đáp…","anchor":"chúng ta tới từ Tây Lăng thú sơn","bridge":true,"khoang":"@c0115"},{"chuong":"@c0115","importance":"normal","tieuDe":"Đối chọi Bổ Thiên các","text":"Cường giả Nhân tộc đánh xe cho tiểu Bạch Hổ; khi nữ đệ tử Bổ Thiên các lỡ lời, phu xe bắt tự vả miệng; Đào Dã đưa hồ lô xưng danh Bổ Thiên các, phu xe đổi sắc mặt nhưng đáp trả rằng họ đến từ Tây Lăng thú sơn và hẹn gặp lại ở Bách Đoạn sơn.","anchor":"chúng ta tới từ Tây Lăng thú sơn"}],"tuViMoc":[],"nhanMach":[{"ten":"Đào Dã","tag":"doi-thu","quanHe":"Đối chọi trên phố Đoạn Không thành","ghiChu":""},{"ten":"Đào Dã","tag":"doi-thu","quanHe":"Đối chọi khi gây sự với đệ tử Bổ Thiên các","ghiChu":"Hẹn quyết chiến ở Bách Đoạn sơn (@c0115)"}],"tuiDo":{}},"nguon":["@c0115"],"tinhCach":[{"text":"Cứng rắn, không nhượng bộ","chuong":"@c0115"}],"blurb":"Cường giả Nhân tộc đánh xe cho tiểu Bạch Hổ Tây Lăng thú sơn, cứng rắn đối chọi Bổ Thiên các."},{"id":"phong-nhi","name":"Phong nhi","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"},{"ten":"Bổ Thiên các","trangThai":"gia-mao"}],"trangThai":"song","blurb":"Người của Vũ tộc cài cắm trong Bổ Thiên các, truyền tin xác định danh tính Hạo Thiên về cho Vũ tộc.","tabs":{"diem":[],"kinhLich":[{"text":"Người của Vũ tộc cài cắm ở Bổ Thiên các, truyền tin về xác định tên nhóc ở Hư Thần giới là Hạo Thiên, hiện đang ở Đoạn Không thành, giúp Vũ tộc quyết định mưu diệt.","anchor":"nó tên là Hạo Thiên, hiện nay đã đến Đoạn Không thành","bridge":true,"khoang":"@c0116"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Chỉ điểm danh tính","ghiChu":"Truyền tin xác định Hạo Thiên cho Vũ tộc"}],"tuiDo":{}},"nguon":["@c0116"]},{"id":"sinh-vat-hinh-nguoi-anh-bac","name":"Sinh vật hình người ánh bạc","aliases":["Sinh linh màu bạc","Sinh linh hình người màu bạc","Con ngươi màu bạc","Sinh vật hình người màu bạc","Kẻ ánh bạc"],"gioiTinh":"khong-ro","canhGioiCaoNhat":"Không rõ (@c0118)","trangThai":"song","blurb":"Cường giả bí ẩn toàn xương dáng người, con ngươi màu bạc, từ sâu dãy núi đi ra; muốn thu phục nhóc tỳ làm chiến bộc.","vaiTro":"Đối thủ mới trong tiểu thế giới","tabs":{"diem":[{"text":"Khắp thân ánh bạc, con ngươi màu bạc, khí tức lạnh giá, khi nói phát làn sóng chấn động như biển cả và sóng triều","chuong":"@c0118"},{"text":"Toàn thân ánh bạc, khí tức lạnh giá, phát ra chấn động như sóng triều khi lên tiếng","chuong":"@c0118"},{"text":"Con ngươi màu bạc, khí tức lạnh giá, phát ra khí tức chấn động kinh khủng như sóng triều khi lên tiếng.","chuong":"@c0118"}],"kinhLich":[{"text":"Sinh vật hình người khắp thân ánh bạc, con ngươi màu bạc từ sâu dãy núi đi ra, soi một bức tranh xác nhận mục tiêu rồi giẫm sập vách đá suýt chôn vùi sư huynh Bổ Thiên các và ngắt cả bốn gốc Xích Lan; nó tự xưng là “vương”/“chủ nhân” của nhóc tỳ, đòi nhóc tỳ theo làm chiến bộc lập chiến công, nhắc Hoàng Kim sư tử chín đầu muốn thu phục nhóc tỳ và hứa sau này thả về Nhân tộc chiếm đất xưng vương; khi nói phát ra làn sóng chấn động như biển cả, kh…","anchor":"Hoàng Kim sư tử chín đầu nói muốn thu phục ngươi, ta lại không muốn cho hắn được toại nguyện","bridge":true,"khoang":"@c0118"},{"chuong":"@c0118","importance":"normal","tieuDe":"Cướp Xích Lan, chiêu dụ nhóc tỳ","text":"Xuất hiện bên hồ nơi mọc bốn gốc Xích Lan; giẫm sập vách đá thả cự thạch vạn cân định chôn vùi sư huynh Bổ Thiên các rồi ngắt bốn gốc Linh dược; xem tranh xác nhận nhắm đúng nhóc tỳ, nhắc Hoàng Kim sư tử chín đầu muốn thu phục nó nhưng hắn không muốn, chiêu dụ nhóc tỳ làm chiến bộc và tự xưng là vương/chủ nhân, phát ra khí tức chấn động kinh khủng.","anchor":"Đi theo ta, trở thành chiến bộc của ta, sau này ta sẽ thả cho ngươi quay trở lại Nhân tộc"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu nhóc tỳ làm chiến bộc; bị nhóc tỳ coi như món ăn","ghiChu":"@c0118"},{"ten":"Sư Tử chín đầu","tag":"doi-thu","quanHe":"Nhắc Hoàng Kim sư tử chín đầu là kẻ tranh đoạt nhóc tỳ","ghiChu":"@c0118"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu phục làm chiến bộc","ghiChu":"Gọi nhóc tỳ là đứa bé đặc biệt của Nhân tộc; đoạt Xích Lan, đối đầu."},{"ten":"Hoàng Kim sư tử chín đầu","tag":"doi-thu","quanHe":"Kẻ tranh giành nhóc tỳ","ghiChu":"Nhắc tới là đối thủ cũng muốn thu phục nhóc tỳ."},{"ten":"Hoàng Kim sư tử chín đầu","tag":"doi-thu","quanHe":"Nhắc đến như kẻ tranh giành muốn thu phục nhóc tỳ","ghiChu":"@c0118"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0118"],"tinhCach":[{"text":"Lạnh lùng, ngạo mạn, tự xưng làm chủ nhân người khác","chuong":"@c0118"}]},{"id":"dai-hong","name":"Đại Hồng","aliases":["Hỏa Vân Tước","Chim ngốc"],"gioiTinh":"khong-ro","canhGioiCaoNhat":"Không rõ (@c0118)","trangThai":"song","blurb":"Hung cầm đỏ rực tính hung tợn, nghi là đời sau Thái Cổ di chủng; thịt là huyết nhục bảo dược.","vaiTro":"Hung cầm bị nhóc tỳ săn đuổi","tabs":{"diem":[{"text":"Chim đỏ rực nổi điên trút mưa Hỏa văn biến rừng thành biển lửa; nghi là đời sau Thái Cổ di chủng","chuong":"@c0118"}],"kinhLich":[{"text":"Hung cầm đỏ rực Hỏa Vân Tước nổi điên trút mưa Hỏa văn biến rừng thành biển lửa, nghi là đời sau Thái Cổ di chủng; bị nhóc tỳ dùng tia chớp vàng, trăng bạc và Ma Cầm đả thương, gia trì Bảo Thuật tăng tốc rồi giả chết bay sát đất trốn thoát, để rơi hơn hai mươi cân thịt là huyết nhục bảo dược.","anchor":"Một khối thịt rớt ra, con chim rơi xuống cực nhanh.","bridge":true,"khoang":"@c0118"},{"text":"Ác điểu phun lửa giống Thái Cổ thần điểu Chu Tước; nhận ra nhóc tỳ liền hoảng sợ bỏ chạy nhưng bị đánh gục, ôm chặt cổ ép làm phương tiện chạy trốn; từng định phản kháng bay về phía truy binh mong có người thu phục Ma Vương giải thoát cho mình, nhưng bị dọa xin thịt nên đành hóa thành áng lửa xẹt qua tầng mây chở nhóc tỳ đi.","anchor":"xoay người lại, bay thẳng về phía mấy tên truy binh","bridge":true,"khoang":"@c0130"},{"chuong":"@c0130","importance":"normal","tieuDe":"Bị bắt làm phương tiện chạy trốn","text":"Hỏa Vân Tước giống Chu Tước, nhận ra Thạch Hạo liền hoảng sợ bỏ chạy nhưng bị đánh gục và ôm chặt cổ; ám ảnh gọi Thạch Hạo là Ma Vương vì từng bị mượn hai mươi cân thịt. Định phản kháng xoay bay về phía truy binh mong có người thu phục Ma Vương, nhưng bị dọa xin thịt nên đành rụt cổ chở nó chạy trốn với tốc độ cực nhanh.","anchor":"cuối cùng cũng đánh gục được Hỏa Vân Tước, ôm chặt lấy cổ nó có chết cũng không buông tay"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đả thương và đoạt thịt","ghiChu":"@c0118"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị cậu bắt cưỡi thoát thân, ám ảnh gọi cậu là Ma Vương vì từng bị mượn hai mươi cân thịt","ghiChu":"@c0130"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị Nhóc Tỳ đuổi bắt","ghiChu":"@c0117"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị bắt làm phương tiện; ám ảnh gọi là Ma Vương"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Kẻ bắt cưỡi","ghiChu":"Ám ảnh gọi Thạch Hạo là Ma Vương vì từng bị mượn hai mươi cân thịt"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0118","@c0130","@c0117"]},{"id":"nhan-hung-mot-sung-mau-den","name":"Nhân Hùng một sừng màu đen","aliases":[],"gioiTinh":"khong-ro","canhGioiCaoNhat":"Không rõ (@c0118)","trangThai":"song","blurb":"Hung thú một sừng màu đen biết nói tiếng người, sợ nhóc tỳ hung tàn nên bỏ chạy.","vaiTro":"Hung thú thoáng qua","tabs":{"diem":[{"text":"Hung thú một sừng màu đen biết nói tiếng người, sợ hãi bỏ chạy vì nhóc tỳ vừa gặp đã định ăn thịt","chuong":"@c0118"}],"kinhLich":[{"text":"Nhân Hùng một sừng màu đen sợ hãi bỏ chạy vì nhóc tỳ vừa gặp đã định ăn thịt nó, khiến nhóc tỳ tiếc tay gấu bị chạy mất.","anchor":"Nhân Hùng một sừng màu đen sau","bridge":true,"khoang":"@c0118"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ định ăn thịt nên bỏ chạy","ghiChu":"@c0118"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị săn đuổi","ghiChu":"Sợ nhóc tỳ bỏ chạy."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0118"]},{"id":"sinh-linh-mau-bac","name":"Sinh linh màu bạc","aliases":["Vương tương lai"],"gioiTinh":"nam","theLuc":[{"ten":"Vương tộc (Thái Cổ di chủng)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cảnh giới cao hơn Thạch Hạo nhưng thua ở Bảo Cụ (@c0119)","trangThai":"tu-vong","blurb":"Thái Cổ di chủng hậu duệ Vương tộc, thân người phủ vảy bạc mắt bạc tóc bạc, tự xưng là một vị Vương trong tương lai; bị Thạch Hạo giết trong trận đơn đấu.","tabs":{"diem":[],"kinhLich":[{"text":"Bị nhóc tỳ đòi ăn thịt nên tức giận thu ngân quang lộ chân thân thân người phủ vảy bạc, tự xưng “Vương tương lai”; dùng Phù Văn, bảo phiến bạc, chủy thủ bạc giao chiến; nhận ra đối thủ chiếm Bảo cốt Toan Nghê luyện chí bảo; bị Cốt Tiễn vàng bẻ gãy chủy thủ, chặt tay trái, cưỡi bảo phiến bỏ chạy rồi bị cắt cổ, đầu lâu đánh thành tro.","anchor":"ngân quang thu lại, lộ ra chân thân","bridge":true,"khoang":"@c0119"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo giết trong trận đơn đấu","ghiChu":""},{"ten":"Sư Tử chín đầu","tag":"khac","quanHe":"Nhắc Sư Tử chín đầu muốn thu Thạch Hạo làm chiến phó","ghiChu":""}],"tuiDo":{"phapBao":[{"ten":"Cây quạt màu bạc","loai":"Bảo Cụ","trangThai":"bi-cuop","moTa":"Bảo phiến bạc phun ra tạo sóng bạc san bằng dãy núi; sau bị Thạch Hạo cướp và hủy hơn nửa.","nguon":"@c0119"},{"ten":"Chủy thủ màu bạc","loai":"Bảo Cụ","trangThai":"hong","moTa":"Dao găm xương bạc mài từ Bảo Cốt, phun ra như đòn thứ ba; bị Cốt Tiễn vàng xoắn đứt làm hai đoạn.","nguon":"@c0119"}]}},"nguon":["@c0119"]},{"id":"hoa-linh-nhi","name":"Hỏa Linh Nhi","aliases":["Công chúa Hỏa quốc","con gái Nhân Hoàng","Con gái nhỏ của Nhân Hoàng","Con gái Nhân Hoàng","Tiểu công chúa","Sư muội","Tiểu công chúa Hỏa quốc"],"gioiTinh":"nu","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"},{"ten":"Nhân Hoàng","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Con gái nhỏ của Nhân Hoàng, sư muội cùng môn Bổ Thiên các, được Nhân Hoàng thương yêu nhất; đi trên xe phượng đỏ thẫm có hơn bốn mươi thiên tài hộ tống.","tabs":{"diem":[],"kinhLich":[{"text":"Ngồi xe kéo mây đỏ lấp loé hào quang đỏ thẫm với hơn bốn mươi thiên tài hộ tống; được các thiên tài Bổ Thiên các nhận ra là con gái nhỏ của Nhân Hoàng và sư muội cùng môn; đồng ý trao đổi Thái Cổ di chủng với Thạch Hạo.","anchor":"chúng ta đồng ý trao đổi","bridge":true,"khoang":"@c0119"},{"importance":"normal","chuong":"@c0120","tieuDe":"Lộ diện và chiêu mộ nhóc tỳ","text":"Từ trong xe kéo quyết đổi Tử Vân Tâm lấy con Linh Tộc dù nhiều người can; vén rèm châu ngọc bước ra, lộ tên khi cười nhạo nhóc tỳ chiếm hô sư muội; nhận ra đây là nhóc siêu quậy nên ra lệnh vây bắt; về sau kìm nén kích động chủ động chiêu mộ nhóc tỳ, tiết lộ đã liên hệ Hoàng Kim sư tử chín đầu, Vũ Vương, Ngân Huyết Cự Nhân để đi Thần Quật đoạt chí bảo; cuối cùng bị nhóc tỳ vỗ mông.","anchor":"Khóe miệng Hỏa Linh Nhi hơi vểnh lên, mang theo một tia cười nhạo"},{"text":"Tức giận phun lửa hóa thành chim tước đỏ đánh nhóc tỳ, sau bị chọc “giảm béo” thì Phù Văn dệt thành đôi cánh Chu Tước hóa xích hỏa truy sát, biến thảo nguyên thành biển lửa; ra điều kiện tới Thần Quật không được xung đột Hoàng Kim sư tử; về sau giục Sư Tử chín đầu mau thu phục nhóc tỳ.; Công chúa Hỏa quốc nổi giận phun lửa hóa Chu Tước đánh Thạch Hạo, dệt Phù Văn thành đôi cánh Chu Tước biến thảo nguyên thành biển lửa vì bị chọc giảm béo; ra điề…","anchor":"Phù Văn đan dệt, ở phía sau lưng biến thành một đôi cánh Chu Tước","bridge":true,"khoang":"@c0121"},{"chuong":"@c0121","importance":"normal","tieuDe":"Truy sát nhóc tỳ và giục sư tử thu phục","text":"Công chúa Hỏa quốc nổi giận, hỏa diễm hóa thành chim tước đỏ (tái hiện Chu Tước) đánh nhóc tỳ; sau đó ra điều kiện tha thứ là không được sinh xung đột với Hoàng Kim sư tử. Bị nhóc tỳ chọc ‘giảm béo’, nàng phát điên dệt Phù Văn thành đôi cánh Chu Tước biến thảo nguyên thành biển lửa để truy sát. Cuối chương nàng nhắc lời Sư Tử chín đầu và giục nó mau thu phục nhóc tỳ.","anchor":"Phù Văn đan dệt, ở phía sau lưng biến thành một đôi cánh Chu Tước"},{"text":"Kêu gọi liên thủ tiến vào Thần Quật, mắng nhóc tỳ “quỷ nhát gan” rồi dẫn hơn mười thiên tài Nhân tộc cùng Ngân Huyết, Vũ Vương vào; thu được quả trứng vàng nghi là hậu duệ Lang Thần, bị thương lao ra và tranh giành khi trứng rơi, cuối cùng bị nhóc tỳ cướp trứng.","anchor":"Cuối cùng, Hỏa Linh Nhi dẫn theo hơn mười gã thiên tài Nhân tộc tiến vào Thần Quật.","bridge":true,"khoang":"@c0123"},{"text":"Chạy vòng cả đêm quanh thảo nguyên rồi quay về điểm xuất phát, tức đến hộc máu; nhờ U Lan Thảo tìm được nhóc tỳ đang nướng trứng, thân trắng tuyết túa ra Phù Văn, giận đến run người dùng hỏa thuật xông vào đại chiến — nhưng chính lửa của nàng lại bị nhóc tỳ lợi dụng để nấu trứng.; Cùng Ngân Huyết Cự Nhân và Vũ Vương chạy vòng cả đêm quanh thảo nguyên rồi quay về điểm xuất phát, tức đến hộc máu; nhờ U Lan Thảo tìm được nhóc tỳ đang nướng trứng li…","anchor":"Năm vị thiên tài của Bổ Thiên các cũng ra tay cùng đối kháng đám người kia","bridge":true,"khoang":"@c0124"},{"text":"Ngăn Thạch Hạo hành hạ và ăn sói con, bị hỏi “có sữa không” nổi trận lôi đình đuổi đánh suốt hai giờ; lấy hai cây Linh dược và trái tim hung thú (huyết nhục bảo dược) trong đỉnh ngọc cho sói con ăn; nhận nuôi Ấu Thần theo lời gửi gắm của Thạch Hạo, tức điên vì sói con tham ăn giống hắn.; Ngăn Thạch Hạo hành hạ sói con, bị hỏi có sữa không nên nổi trận lôi đình đuổi đánh hai giờ; đem hai cây Linh dược và trái tim hung thú trong đỉnh ngọc nuôi Ấu…","anchor":"Cuối cùng trận truy sát này kéo dài tận hai giờ thì mọi người mới ngồi lại.","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"normal","tieuDe":"Bảo vệ và nuôi dưỡng Ấu Thần","text":"Cùng Sư Tử chín đầu ngăn nhóc tỳ ăn/hành hạ Ấu Thần; cho sói con ăn hai cây Linh dược và đỉnh ngọc chứa trái tim hung thú; nổi trận lôi đình đuổi đánh nhóc tỳ hai giờ vì bị hỏi có sữa không; cùng truy sát bắt trói Ngân Huyết và Vũ Vương, được giao nuôi Ấu Thần.","anchor":"Cuối cùng trận truy sát này kéo dài tận hai giờ thì mọi người mới ngồi lại."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Sư huynh cùng môn, thỏa thuận trao đổi Thái Cổ di chủng","ghiChu":""},{"ten":"Nhân Hoàng","tag":"cha-me","quanHe":"Cha, thương yêu nàng nhất","ghiChu":""},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Bị nhóc tỳ gọi đùa là sư muội rồi ra lệnh vây bắt; sau lại chiêu mộ nhóc tỳ vào liên minh đi Thần Quật, bị nhóc tỳ vỗ mông trêu ngược.","ghiChu":"@c0120"},{"ten":"Nhân Hoàng","tag":"cha-me","quanHe":"Cha của Hỏa Linh Nhi, mời chào một nửa số thiên tài đi bảo vệ con gái.","ghiChu":"@c0120"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đồng môn Bổ Thiên các (sư huynh), bị nàng truy sát vì bị chọc","ghiChu":"@c0121"},{"ten":"Hoàng Kim sư tử chín đầu","tag":"khac","quanHe":"Giục nó mau thu phục nhóc tỳ","ghiChu":"@c0121"},{"ten":"Người khổng lồ Ngân Huyết","tag":"dong-hanh","quanHe":"Cùng dẫn vào Thần Quật","ghiChu":"@c0123"},{"ten":"Vũ Vương","tag":"dong-hanh","quanHe":"Cùng vào Thần Quật","ghiChu":"@c0123"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ giành trứng thần","ghiChu":"Bị nhóc tỳ trêu tức, hỏa thuật của nàng bị lợi dụng nấu trứng (@c0124)"},{"ten":"Ấu Thần","tag":"khac","quanHe":"Nuôi dưỡng Ấu Thần như cha mẹ nuôi","ghiChu":"Cho ăn Linh dược và trái tim hung thú"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Sư huynh đồng môn Bổ Thiên các","ghiChu":"Bị y trêu giảm béo nên truy sát"},{"ten":"Hoàng Kim sư tử chín đầu","tag":"khac","quanHe":"Thái Cổ di chủng","ghiChu":"Giục nó thu phục Thạch Hạo, nhắc lời nó về Thái Cổ hung thú thuần huyết"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Sư huynh cùng Bổ Thiên các","ghiChu":"Bị nhóc tỳ trêu chọc, truy sát rồi lại giục di chủng thu phục nhóc tỳ."},{"ten":"Hoàng Kim sư tử chín đầu","tag":"khac","quanHe":"Thái Cổ di chủng nàng kỳ vọng","ghiChu":"Nhắc lời sư tử từng nói ngày sau có hy vọng sánh vai Thái Cổ hung thú thuần huyết."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Vừa đồng hành vừa xung đột","ghiChu":"Mắng Thạch Hạo là “quỷ nhát gan”; bị Thạch Hạo cướp quả trứng vàng (@c0123)"},{"ten":"Ấu Thần","tag":"dong-hanh","quanHe":"Được Thạch Hạo giao nuôi, sói con xem như cha mẹ nuôi","ghiChu":"@c0125"},{"ten":"Ấu Thần","tag":"khac","quanHe":"Người nuôi dưỡng","ghiChu":"Cho sói con ăn Linh dược, huyết nhục bảo dược; được giao nuôi mập"},{"ten":"Ấu Thần","tag":"linh-thu","quanHe":"Được giao nuôi dưỡng Ấu Thần","ghiChu":"@c0125"},{"ten":"Ấu Thần","tag":"dong-minh","quanHe":"Được giao nuôi dưỡng Ấu Thần, cho ăn linh dược và huyết nhục bảo dược","ghiChu":"@c0125"},{"ten":"Hoàng Kim sư tử chín đầu","tag":"dong-minh","quanHe":"Kỳ vọng thu phục nhóc tỳ","ghiChu":"Nhắc lời sư tử từng nói ngày sau có hy vọng sánh vai Thái Cổ hung thú thuần huyết, giục nó mau thu phục nhóc tỳ @c0121"}]},"nguon":["@c0119","@c0120","@c0121","@c0123","@c0124","@c0125"]},{"id":"nguoi-mac-ao-khoac-mau-den","name":"Người mặc áo khoác màu đen","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Hỏa quốc","trangThai":"danh-nghia"}],"trangThai":"song","blurb":"Kẻ thần bí giọng khàn, khói đen lượn lờ quanh thân, phục vụ bên xe kéo công chúa Hỏa quốc.","vaiTro":"Người xác nhận Linh Tộc và trao Tử Vân Tâm trong thương lượng trao đổi.","tabs":{"diem":[],"kinhLich":[{"text":"Từ chỗ xe kéo ra xác nhận con sinh linh màu bạc là Linh Tộc, Thái Cổ di chủng có Vương huyết truyền thừa; cầm đỉnh ngọc hình vuông chứa Tử Vân Tâm đến trao đổi với nhóc tỳ.","anchor":"Đây chính là Tử Vân Tâm, là trái tim của một con Thái Cổ di chủng hung mãnh","bridge":true,"khoang":"@c0120"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Xác nhận Linh Tộc và trao đỉnh ngọc chứa Tử Vân Tâm để đổi lấy con sinh linh màu bạc của nhóc tỳ.","ghiChu":"@c0120"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0120"]},{"id":"sinh-linh-hinh-nguoi-moc-sung","name":"Sinh linh hình người mọc sừng","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vũ tộc (Hoàng Đô Thạch quốc)","trangThai":"gan-bo"}],"trangThai":"tu-vong","blurb":"Dị tộc người của Vũ Vương, đầu mọc một sừng, lưng mọc đôi lông cánh.","vaiTro":"Dị tộc rủ nhóc tỳ làm tôi tớ, bị đánh chết hóa than.","tabs":{"diem":[],"kinhLich":[{"text":"Đối chiếu tranh nhận ra nhóc tỳ là kẻ mà Hoàng Kim sư tử chín đầu tranh nhau muốn thu làm chiến sủng, rồi rủ nó đầu nhập Vương của hắn làm tôi tớ; bị nhóc tỳ nổi giận đánh một chưởng Phù Văn hóa thành than.","anchor":"mấy tên Dị tộc này đều bị xuyên thủng, hóa thành tro tàn","bridge":true,"khoang":"@c0120"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Rủ nhóc tỳ làm tôi tớ cho Vương của hắn, bị nhóc tỳ đánh chết hóa than.","ghiChu":"@c0120"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0120"]},{"id":"hoa-kim-su-tu-chin-dau-nv","name":"Hoàng Kim sư tử chín đầu","gioiTinh":"khac","aliases":["Sư Tử chín đầu","Hoàng Kim sư tử"],"canhGioiCaoNhat":"Không rõ","trangThai":"song","theLuc":[{"ten":"Thái Cổ di chủng","trangThai":"gan-bo"}],"vaiTro":"Thái Cổ di chủng cầm đầu chặn ải Thần Quật","tabs":{"diem":[],"kinhLich":[{"text":"Được sinh vật hình người ánh bạc nhắc tới như kẻ muốn thu phục nhóc tỳ, cho thấy nhiều thế lực đang tranh đoạt đứa bé đặc biệt của Nhân tộc.","anchor":"Hoàng Kim sư tử chín đầu nói muốn thu phục ngươi, ta lại không muốn cho hắn được toại nguyện","bridge":true,"khoang":"@c0118"},{"text":"Toàn thân vảy vàng ròng, cầm đầu ba Thái Cổ di chủng chờ sẵn ở chân núi Thần Quật; mở một bức tranh so sánh nhận ra nhóc tỳ là ‘chiến phó mạnh mẽ’ nó tìm, đánh văng hai kẻ kia để độc chiếm. Nó nhắc Mộc Phong đi tìm nhóc tỳ rồi mất tích, đòi nhóc tỳ qua ải, chín cái đầu mỗi đầu phun một phi kiếm hoàng kim; bị nhóc tỳ dùng ‘Nghịch chuyển’ phản đòn, hai bên đại chiến ngang sức.","anchor":"chín thanh phi kiếm đều có màu hoàng kim","bridge":true,"khoang":"@c0121"},{"text":"Phẫn nộ vì bị nhóc tỳ Nhân tộc bắt làm thú cưỡi, bộc phát hào quang vàng chống trả bằng chín hạt niệm châu và chín răng nanh hóa phi kiếm; định tự bạo nhưng thất bại, bị chém rụng bốn đầu lâu nên thu bảo cụ bỏ trốn vào Thần Quật; về sau lao ra cuối cùng đầy máu, tuyên bố đây là Ma thổ nuôi sói của Lang Thần và cùng tranh cướp quả trứng vàng.; Bộc phát hào quang vàng chống trả nhóc tỳ, phóng chín hạt niệm châu và chín răng nanh hóa phi kiếm; bị n…","anchor":"Nó không có nghịch thiên như nhóc tỳ, không thể lấy bảo thuật cứng rắn mà chống đỡ Long Giao tiễn được.","bridge":true,"khoang":"@c0123"},{"importance":"normal","chuong":"@c0125","tieuDe":"Bị thu phục làm thú cưỡi, phát thệ tìm Thần Tuyền","text":"Hung thú thân vàng kim chín đầu, tự xưng cháu Cửu Linh Vương, trốn trong bùn lầy nhưng bị sói con đánh hơi ra; đại chiến với Thạch Hạo mấy ngày, khi cùng rớt thác bị cưỡi lên lưng và ép làm thú cưỡi kiêm tiểu đệ; khoe tộc có cổ pháp hóa hung thú Thái Cổ thuần huyết, nhận ra sói con là Ấu Thần đã bị hàng phục nên khuất phục, phát thệ dẫn tìm Bất Lão Thần Tuyền và không được khó dễ Thạch Hạo.","anchor":"ta phục rồi, chúng ta kết bái làm huynh đệ nha"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu làm chiến phó rồi giao chiến ngang sức","ghiChu":"@c0121"},{"ten":"Ngân Huyết cự nhân","tag":"doi-thu","quanHe":"Cùng tranh thu nhóc tỳ, bị nó đánh văng","ghiChu":"@c0121"},{"ten":"Vũ Vương","tag":"doi-thu","quanHe":"Cùng tranh thu nhóc tỳ, bị nó đánh văng","ghiChu":"@c0121"},{"ten":"Hỏa Linh Nhi","tag":"doi-thu","quanHe":"Cùng đám sinh linh tranh đoạt trứng vàng, cùng vào Thần Quật","ghiChu":"@c0123"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu phục nhóc tỳ (được nhắc gián tiếp)","ghiChu":"@c0118"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo cưỡi trấn áp và đánh bại","ghiChu":"Bị chém rụng bốn đầu lâu; bị truy sát đòi trả bảo cụ và Huyết dược đầu sư tử (@c0123)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Bị Thạch Hạo thu phục làm thú cưỡi kiêm tiểu đệ","ghiChu":"@c0125"},{"ten":"Cửu Linh Vương","tag":"ho-hang","quanHe":"Tự xưng là cháu Cửu Linh Vương","ghiChu":"@c0125"},{"ten":"Hỏa Linh Nhi","tag":"dong-minh","quanHe":"Được kỳ vọng thu phục nhóc tỳ","ghiChu":"Hỏa Linh Nhi nhắc và giục nó mau thu phục nhóc tỳ @c0121"}],"tuiDo":{}},"nguon":["@c0121","@c0123","@c0118","@c0125"]},{"id":"ngan-huyet-cu-nhan","name":"Ngân Huyết cự nhân","gioiTinh":"khac","aliases":["Người khổng lồ Ngân Huyết","Người khổng lồ màu bạc"],"canhGioiCaoNhat":"Không rõ","trangThai":"song","theLuc":[{"ten":"Thái Cổ di chủng","trangThai":"gan-bo"}],"vaiTro":"Sinh linh khổng lồ màu bạc trong nhóm Thái Cổ di chủng chặn Thần Quật","tabs":{"diem":[],"kinhLich":[{"text":"Sinh linh khổng lồ màu bạc cao mười mấy mét, tự xưng “quá khứ vô địch”, muốn thu nhóc tỳ làm người hầu; bị nhóc tỳ đấm khiến bàn tay như gầu không ngừng chảy máu, bị đánh lui.","anchor":"bàn tay như cái gầu to không ngừng chảy máu","bridge":true,"khoang":"@c0121"},{"text":"Cùng đoàn Hỏa Linh Nhi truy đuổi nhóc tỳ suốt đêm, rống to tức giận khi vòng lại điểm xuất phát; tham gia đại chiến giành trứng thần.","anchor":"Tất cả mọi người đều đồng thời xông về phía trước","bridge":true,"khoang":"@c0124"},{"text":"Ra tay dùng Phù Văn cướp Ấu Thần nhưng bị nhóc tỳ phun chớp đánh cháy đen bàn tay rồi rút lui; sau bị nhóc tỳ, Hỏa Linh Nhi và thiên tài Bổ Thiên các truy sát bắt trói.","anchor":"bị bắt gọn trói như cái bánh chưng","bridge":true,"khoang":"@c0125"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu làm người hầu, bị nhóc tỳ đấm chảy máu tay","ghiChu":"@c0121"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đấm chảy máu tay","ghiChu":"Tranh thu nhóc tỳ làm người hầu."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đánh cháy tay và truy sát bắt trói","ghiChu":"@c0125"},{"ten":"Vũ Vương","tag":"dong-minh","quanHe":"Cùng cướp Ấu Thần và cùng bị bắt trói","ghiChu":"@c0125"}],"tuiDo":{}},"nguon":["@c0121","@c0125"]},{"id":"vu-vuong","name":"Vũ Vương","gioiTinh":"nam","aliases":[],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Sinh linh Vũ tộc hình người, sừng vàng, cánh ngũ sắc; muốn thu nhóc tỳ vì Nhân tộc và Vũ tộc hình dáng gần giống. Bị nhóc tỳ tung một đá — đùi phải nhóc tỳ phát tia chớp vàng óng — chấn văng ra tràn máu khóe miệng.","anchor":"Toàn bộ đùi phải của nhóc tỳ đều phát sáng, tia chớp màu vàng óng","bridge":true,"khoang":"@c0121"},{"text":"Cùng người khổng lồ Ngân Huyết theo đoàn Hỏa Linh Nhi tiến vào Thần Quật; sau đó đôi cánh năm màu nát bét vọt ra, thủ hạ chết gần hết, giật mình khi biết quả trứng vàng có thể là hậu duệ Lang Thần và cùng tranh cướp.","anchor":"Không phải Thần Quật, đây là Ma Quật mà!","bridge":true,"khoang":"@c0123"},{"text":"Cùng đoàn truy đuổi trứng thần, tức đến giậm chân khi chạy vòng cả đêm mà quay về điểm xuất phát; tham gia đại chiến giành trứng với nhóc tỳ.","anchor":"Tất cả mọi người đều đồng thời xông về phía trước","bridge":true,"khoang":"@c0124"},{"text":"Đôi cánh rách nát bắn thần mang, ra tay chém đao cướp hậu đại thần linh nhưng bị Cốt Tiễn chặt đứt một cánh tay (ráp lại rồi lùi); cùng Ngân Huyết định gọi người đánh tiếp nhưng bị Thạch Hạo và đám thiên tài Bổ Thiên các truy sát bắt trói.; Vung đao Phù Văn chém nhóc tỳ nhưng bị Cốt Tiễn đánh gãy cốt đao và chặt đứt một cánh tay, nhặt tay ráp lại rồi lùi; sau bị bắt trói cùng người khổng lồ Ngân Huyết.","anchor":"bị bắt gọn trói như cái bánh chưng","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"normal","tieuDe":"Bị chặt cánh tay rồi bị bắt trói","text":"Có đôi cánh rách nát bắn thần mang, xuất hung đao chém nhóc tỳ nhưng bị Cốt Tiễn đánh gãy đao và chặt đứt một cánh tay, phải nhặt ráp lại rồi lùi; sau bị nhóc tỳ và đồng bọn truy sát bắt trói.","anchor":"Cốt Tiễn vọt tới không những đánh gãy cốt đao mà còn chặt đứt một cánh tay của Vũ Vương rơi xuống, máu phun tung tóe."}],"tuViMoc":[],"nhanMach":[{"ten":"Hỏa Linh Nhi","tag":"dong-minh","quanHe":"Cùng tiến vào Thần Quật/Ma Quật","ghiChu":"Theo đoàn Hỏa Linh Nhi vào; cùng tranh cướp trứng vàng khi rút ra (@c0123)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Cốt Tiễn chặt cánh tay và truy sát bắt trói","ghiChu":"@c0125"},{"ten":"Người khổng lồ Ngân Huyết","tag":"dong-minh","quanHe":"Cùng cướp Ấu Thần và cùng bị bắt trói","ghiChu":"@c0125"},{"ten":"Ngân Huyết cự nhân","tag":"dong-minh","quanHe":"Cùng cướp Ấu Thần và cùng bị bắt trói","ghiChu":"@c0125"}],"tuiDo":{}},"nguon":["@c0123","@c0125","@c0121"],"theLuc":[{"ten":"Thái Cổ di chủng","trangThai":"gan-bo"}]},{"id":"moc-phong-linh-toc","name":"Mộc Phong","gioiTinh":"nam","aliases":[],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","theLuc":[{"ten":"Hư Thần Giới","trangThai":"gan-bo"}],"vaiTro":"Nhân vật Linh tộc đi tìm nhóc tỳ và bị ăn thịt","tabs":{"diem":[],"kinhLich":[{"text":"Mấy ngày trước Mộc Phong của Linh tộc đi tìm nhóc tỳ nhưng một đi không trở lại; tại Thần Quật, nhóc tỳ xác nhận đã ăn thịt Mộc Phong, khiến cả đám Dị tộc kinh sợ.","anchor":"Bị ta ăn thịt rồi.","bridge":true,"khoang":"@c0121"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đi tìm nhóc tỳ rồi bị nhóc tỳ ăn thịt","ghiChu":"@c0121"}],"tuiDo":{}},"nguon":["@c0121"]},{"id":"nguoi-khong-lo-ngan-huyet","name":"Người khổng lồ Ngân Huyết","cn":"","aliases":["Ngân Huyết cự nhân","Cự Nhân"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Sinh linh Dị tộc người khổng lồ Ngân Huyết, theo đoàn Hỏa Linh Nhi vào Thần Quật rồi lao ra đầy máu tuyên bố đây là Ma Quật.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Do dự cân nhắc trước hiểm nguy, tranh đoạt bảo vật quyết liệt","chuong":"@c0123"}],"tabs":{"diem":[{"text":"Sinh linh Dị tộc thân hình khổng lồ, thuộc nhóm cường giả tiến vào Thần Quật","chuong":"@c0123"}],"kinhLich":[{"text":"Do dự rồi theo đoàn Hỏa Linh Nhi vào Thần Quật; sáng sớm lao ra đầy máu tuyên bố đây không phải Thần Quật mà là Ma Quật, thủ hạ chết gần hết; cùng tranh cướp quả trứng vàng khi trứng rơi ra.","anchor":"Không phải Thần Quật, đây là Ma Quật mà!","bridge":true,"khoang":"@c0123"},{"text":"Quát đòi để lại Ấu Thần, vung bàn tay lớn/Phù Văn tấn công và cướp Ấu Thần nhưng bị nhóc tỳ phun tia chớp đánh cháy đen tay phải rút lui; sau bị nhóc tỳ và thiên tài Bổ Thiên các truy sát bắt trói.; Hét “Để lại Ấu Thần”, ra tay cướp hậu đại thần linh nhưng bị Thạch Hạo phun tia chớp đánh cháy đen bàn tay rồi rút lui; cùng Vũ Vương định gọi người đánh tiếp nhưng bị truy sát bắt gọn.","anchor":"bị bắt gọn trói như cái bánh chưng","bridge":true,"khoang":"@c0125"}],"tuViMoc":[],"nhanMach":[{"ten":"Hỏa Linh Nhi","tag":"dong-hanh","quanHe":"Cùng vào Thần Quật, sau tranh trứng vàng","ghiChu":"@c0123"},{"ten":"Hỏa Linh Nhi","tag":"dong-minh","quanHe":"Cùng tiến vào Thần Quật/Ma Quật","ghiChu":"Theo đoàn Hỏa Linh Nhi vào; cùng tranh cướp trứng vàng (@c0123)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0123","@c0125"]},{"id":"muoi-nguoi-vu-toc","name":"Mười người Vũ tộc","gioiTinh":"khac","theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nhóm mười thiếu niên cường giả Vũ tộc bố trí trận pháp phục kích Thạch Hạo; hiện bảo quang trong mưa.","vaiTro":"Nhóm phục kích thăm dò thân phận Thạch Hạo","tabs":{"diem":[{"text":"Vũ tộc tắm mình trong mưa lớn thì thần năng tăng vượt bậc; họ dẫn mây mù mưa lớn tới","chuong":"@c0126"}],"kinhLich":[{"text":"Mười thiếu niên cường giả tới, kinh sợ khi thấy sát trận Phù Văn bị phá và một người một sư đi ra; nhận ra Thạch Hạo là tên nhóc siêu quậy ở Hư Thần giới; một người kể chuyện tám năm trước bộ tộc điều cao thủ đánh vợ chồng Thạch Tử Lăng máu nhuộm Tây Cương để thăm dò thân phận nhóc tỳ.","anchor":"Bọn họ kinh ngạc thốt lên, nhìn thấy một người một sư từ trong bụi mù đi ra","bridge":true,"khoang":"@c0126"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối tượng bị phục kích và thăm dò","ghiChu":"Ân oán Chí Tôn cốt"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Vợ chồng bị bộ tộc đánh trọng thương tám năm trước","ghiChu":""}],"tuiDo":{}}},{"id":"su-tu-chin-dau","name":"Sư Tử chín đầu","aliases":["Hoàng Kim sư tử","Thần Vương thời Thái cổ","Sư tử vàng kim","Hoàng Kim sư tử chín đầu","Cửu đầu sư tử","#sư-tu-chin-dau"],"gioiTinh":"khong-ro","canhGioiCaoNhat":"Không rõ","trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Tại tế đàn cổ trong Đoạn Không thành, con sư tử chín đầu cận thuần huyết hống lên tuyên bố đã chọn kẻ nhân loại (Hạo Thiên) làm nô bộc, cấm kẻ khác tranh; sư tỷ nhắc nó cách thuần huyết không xa, hiếm thiên tài Nhân tộc đối kháng nổi ngoài Thạch Nghị và vài người.","anchor":"kẻ nhân loại này ta đã chọn rồi","bridge":true,"khoang":"@c0116"},{"text":"Đại chiến Nhóc tỳ trên thảo nguyên, tung Sư Hống công, chín răng nanh phi kiếm do trưởng bối tặng, chuỗi niệm châu vàng và cả thần thông trấn tộc Vô Úy Sư Tử ấn; bị Cốt Tiễn của Nhóc tỳ làm một đầu lâu suýt nứt, huyết thấm đỏ mắt; tiêu hao quá nhiều tinh khí thần nên bỏ chạy, cuối cùng bị Nhóc tỳ nhảy lên lưng dùng sấm sét trấn áp.","anchor":"một cái đầu lâu suýt chút nữa nứt ra, xuất hiện một vết thương cực kỳ kinh khủng","bridge":true,"khoang":"@c0122"},{"text":"Bị nhóc tỳ truy đuổi nhiều ngày, cả hai rơi xuống thác nước, bị cưỡi lên lưng và dùng thân phát sáng thu phục; tự xưng cháu Cửu Linh Vương, cầu kết bái nhưng bị ép làm tiểu đệ, đòi đại lễ Linh dược/Thánh dược khiến nó hộc máu; phát thệ giúp tìm Bất Lão Thần Tuyền để không bị làm khó.; Thái Cổ di chủng lông vàng kim cảnh cáo không được ăn Ấu Thần rồi nhịn không xông lên khi thấy thua; chạy trốn bị sói con đánh hơi, đại chiến với nhóc tỳ rồi cùng…","anchor":"Ta chính là cháu của Cửu Linh Vương","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"normal","tieuDe":"Bị thu phục và khai lai lịch cháu Cửu Linh Vương","text":"Là Thái Cổ di chủng lông vàng kim thuần huyết, cảnh cáo không được ăn Ấu Thần; chạy trốn nhưng bị sói con đánh hơi, đại chiến với nhóc tỳ rồi cùng rơi xuống thác nước và bị thu phục làm thú cưỡi/tiểu đệ; tự xưng cháu Cửu Linh Vương, khai tộc mình có cổ pháp hóa hung thú thuần huyết; nhận ra sói con có thể là một Ấu Thần và phát thệ giúp tìm Bất Lão Thần Tuyền.","anchor":"đây có thể là một con Ấu Thần"},{"importance":"normal","chuong":"@c0126","tieuDe":"Bị hàng phục làm tọa kỵ, cùng phá trận","text":"Di chủng Vương tộc Thái Cổ có thuần huyết bị Thạch Hạo hàng phục làm tọa kỵ, khiến vô số sinh linh kinh sợ; giữ chặt chuỗi niệm châu và kim kiếm, dọa tự bạo để không đưa bảo cụ; phun chuỗi niệm châu phá năm tầng sát trận Phù Văn, bị Phù Văn quét trúng bả vai chảy máu.","anchor":"một Hoàng Kim sư tử có huyết thống cao quý lại bị một thiếu niên Nhân tộc hàng phục, biến thành tọa kỵ"},{"text":"Dùng chuỗi niệm châu vàng bay lên né Phù Văn thủy hệ, cõng nhóc tỳ tiến bước như Chiến Thần hàng thế; suy đoán Vũ tộc dùng biện pháp đặc biệt lừa qua cửa ải đưa đông người vào; người Vũ tộc kinh sợ nhận ra nó vốn được xưng Thần Vương thời Thái cổ mà nay làm tọa kỵ.","anchor":"Ở thời Thái cổ được xưng là Thần Vương, tại sao lại làm tọa kỵ cho nó","bridge":true,"khoang":"@c0127"},{"chuong":"@c0127","importance":"normal","tieuDe":"Thần Vương Thái cổ làm tọa kỵ","text":"Dùng chuỗi niệm châu màu vàng nâng thân bay lên né Phù Văn thủy hệ của Vũ tộc; cõng Thạch Hạo đại khai sát giới, suy đoán Vũ tộc dùng biện pháp đặc biệt lừa qua cửa ải đưa đông người vào; khiến Vũ tộc kinh sợ vì từng được xưng Thần Vương thời Thái cổ nay lại làm tọa kỵ.","anchor":"Ở thời Thái cổ được xưng là Thần Vương"},{"text":"Nhận ra bốn bóng người là Người phong ấn; cùng Thạch Hạo giả liều mạng rồi bất ngờ dùng Bảo Cụ dưới chân phóng lên trời bỏ chạy, than phiền bị Thạch Hạo biến thành khiên thịt; bị màn mưa thần lực bắn thủng ngực phải như cái sàng, lảo đảo gần rơi; cảm động vì Thạch Hạo chặn đường cứu nên hứa nếu Thạch Hạo sống sẽ không để Cửu Linh Vương gia gia gây phiền, xóa món nợ cũ; cuối cùng phóng hào quang hoàng kim biến mất cuối chân trời.; Nhận ra bốn kẻ…","anchor":"cả người hào quang hoàng kim chói lọi, trong phút chốc đã đi rất xa, biến mất ở nơi cuối chân trời.","bridge":true,"khoang":"@c0129"},{"chuong":"@c0129","importance":"normal","tieuDe":"Được nhóc tỳ cứu, thoát vòng vây","text":"Nhận ra bốn Người phong ấn Vũ tộc, cùng nhóc tỳ giả liều mạng rồi dùng Bảo Cụ phóng lên trời chạy trốn, than phiền bị biến thành khiên thịt; bị màn mưa thần lực bắn thủng ngực phải như cái sàng, máu me khắp người; cảm động vì nhóc tỳ chủ động chặn bốn đại cường giả cứu mình nên hứa xóa nợ cũ và không để Cửu Linh Vương gia gia gây phiền; phóng hào quang hoàng kim biến mất cuối chân trời.","anchor":"cả người hào quang hoàng kim chói lọi, trong phút chốc đã đi rất xa, biến mất ở nơi cuối chân trời."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Huynh đệ kết nghĩa, làm tọa kỵ","ghiChu":"Cùng săn giết thiên tài Vũ tộc"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn được Thạch Hạo cứu thoát vây","ghiChu":"Hứa xóa nợ cũ nếu Thạch Hạo sống sót."},{"ten":"Cửu Linh Vương","tag":"ho-hang","quanHe":"Gia gia của Sư Tử chín đầu","ghiChu":"Hứa không để Cửu Linh Vương gây phiền cho Thạch Hạo."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn","ghiChu":"Được Thạch Hạo chặn đường cứu, hứa xóa nợ cũ."},{"ten":"Cửu Linh Vương","tag":"ho-hang","quanHe":"Gia gia","ghiChu":"Hứa sẽ không để Cửu Linh Vương gia gia tìm Thạch Hạo gây phiền."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn, được Thạch Hạo cứu","ghiChu":"Bị biến thành khiên thịt nhưng được Thạch Hạo chặn cường giả cứu (@c0129)."},{"ten":"Cửu Linh Vương","tag":"ho-hang","quanHe":"Tổ phụ/họ hàng","ghiChu":"Nguồn tặng đại lễ Linh dược/Thánh dược"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Bị nhóc tỳ thu phục làm thú cưỡi/tiểu đệ, phát thệ","ghiChu":"@c0125"},{"ten":"Cửu Linh Vương","tag":"ho-hang","quanHe":"Tổ phụ của Sư Tử chín đầu","ghiChu":"@c0125"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn bắt làm nô bộc","ghiChu":"Chọn kẻ nhân loại Hạo Thiên làm nô bộc, cấm kẻ khác tranh"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Muốn thu phục nhóc tỳ","ghiChu":"@c0118"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đánh bại mình và cưỡi khống chế làm thú cưỡi","ghiChu":"Gặp @c0122"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Chủ nhân đã hàng phục làm tọa kỵ","ghiChu":"Tranh cãi về bảo cụ, cùng phá trận"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Huynh đệ kết nghĩa, làm tọa kỵ","ghiChu":"@c0127"},{"ten":"Ấu Thần","tag":"khac","quanHe":"Nhận ra sói con là Ấu Thần Thái Cổ hung thú non","ghiChu":"@c0125"}],"tuiDo":{}},"nguon":["@c0129","@c0125","@c0116","@c0118","@c0122","@c0127"],"blurb":"Sinh linh Hoàng Kim sư tử chín đầu cận thuần huyết, hống lên tuyên bố chọn kẻ nhân loại (Hạo Thiên) làm nô bộc.","tinhCach":[{"text":"Trọng tình nghĩa, cảm động trước hành vi hy sinh của nhóc tỳ","chuong":"@c0129"}]},{"id":"nu-tu-song-kiet-vu-toc","name":"Thiếu nữ song kiệt Vũ tộc","aliases":["Nữ tử song kiệt Vũ tộc","Song kiệt Vũ tộc (nữ)","Thiếu nữ song kiệt Vũ tộc","song kiệt Vũ tộc (nữ)"],"gioiTinh":"nu","canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một trong song kiệt của Vũ tộc, nổi danh Hoàng Đô, tuổi chừng mười lăm mười sáu.","vaiTro":"Cao thủ trẻ Vũ tộc mai phục.","tabs":{"diem":[],"kinhLich":[{"text":"Bàn về Thạch Nghị và tiểu Ma vương cùng người canh thông đạo; tự xưng là một trong song kiệt của Vũ tộc nổi danh Hoàng Đô; sau khi nghe tin người của Vũ tộc chết hết, đứng dậy với Phù Văn lấp lóe đầy trời khi Thạch Hạo cưỡi Sư Tử chín đầu tiến tới.; Tự xưng là một trong song kiệt của Vũ tộc, nổi danh Hoàng Đô; cùng người canh thông đạo bàn về Thạch Nghị và tiểu Ma vương, nhắc Thạch Nghị là biểu đệ đang xông Thượng Cổ cấm địa tìm Thiên Cốt.; Một…","anchor":"nàng lộ ra hình dáng là một thiếu nữa trong song kiệt của Vũ tộc, tuổi chừng mười lăm mười sáu","bridge":true,"khoang":"@c0127"},{"chuong":"@c0127","importance":"normal","tieuDe":"Thiếu nữ song kiệt lộ diện","text":"Bóng người ngồi xếp bằng trước thông đạo đột nhiên đứng dậy, Phù Văn lấp lóe đầy trời, lộ ra hình dáng thiếu nữ trong song kiệt của Vũ tộc, tuổi chừng mười lăm mười sáu, sẵn sàng đối đầu Thạch Hạo.","anchor":"một thiếu nữa trong song kiệt của Vũ tộc, tuổi chừng mười lăm mười sáu"}],"tuViMoc":[],"nhanMach":[{"ten":"Nam tử song kiệt Vũ tộc","tag":"dong-minh","quanHe":"Cùng là song kiệt Vũ tộc","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Gọi Thạch Nghị là biểu đệ","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Biểu đệ","ghiChu":"Nhắc Thạch Nghị là biểu đệ đang xông Thượng Cổ cấm địa."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Tiểu Ma vương tàn sát người Vũ tộc."},{"ten":"Nam tử song kiệt Vũ tộc (canh thông đạo)","tag":"dong-minh","quanHe":"Cùng là song kiệt của Vũ tộc","ghiChu":"@c0127"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối đầu tiểu Ma vương giết người Vũ tộc","ghiChu":"@c0127"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Chuẩn bị đối đầu thiếu niên cưỡi Sư Tử chín đầu","ghiChu":"@c0127"}],"tuiDo":{}},"nguon":["@c0127"]},{"id":"nam-tu-song-kiet-vu-toc","name":"Nam tử song kiệt Vũ tộc","aliases":["Nam tử canh thông đạo Vũ tộc","Song kiệt Vũ tộc (nam)","Người canh thông đạo Vũ tộc","song kiệt Vũ tộc (nam)","Nam tử canh thông đạo"],"gioiTinh":"nam","canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một trong song kiệt Vũ tộc, ngồi xếp bằng canh thông đạo, khí tức khủng bố.","vaiTro":"Cao thủ trẻ Vũ tộc canh thông đạo.","tabs":{"diem":[],"kinhLich":[{"text":"Một trong song kiệt Vũ tộc, ngồi xếp bằng canh thông đạo với khí tức khủng bố và Phù Văn dày đặc; thời nhỏ từng xông qua mười ngàn dặm Đại Hoang, đánh bại nhiều vương hầu tử đệ.; Ngồi xếp bằng canh thông đạo với khí tức khủng bố, Phù Văn dày đặc; thời nhỏ từng xông qua mười ngàn dặm Đại Hoang, đánh bại nhiều vương hầu tử đệ; là một trong song kiệt Vũ tộc.","anchor":"cái tên tiểu Ma vương kia đã giết tới rồi, người của chúng ra đều chết hết rồi!","bridge":true,"khoang":"@c0127"}],"tuViMoc":[],"nhanMach":[{"ten":"Nữ tử song kiệt Vũ tộc","tag":"dong-minh","quanHe":"Cùng là song kiệt Vũ tộc","ghiChu":""},{"ten":"Nữ tử song kiệt Vũ tộc","tag":"dong-minh","quanHe":"Song kiệt cùng nhóm","ghiChu":"Cùng là song kiệt của Vũ tộc."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Tiểu Ma vương tàn sát người Vũ tộc."},{"ten":"Nữ tử song kiệt Vũ tộc","tag":"dong-minh","quanHe":"Cùng là song kiệt của Vũ tộc","ghiChu":"@c0127"}],"tuiDo":{}},"nguon":["@c0127"]},{"id":"luc-ty-vu-toc","name":"Lục tỷ (Vũ tộc)","aliases":["Lục tỷ"],"gioiTinh":"nu","canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Người Vũ tộc được báo tin về cái chết của các thiên tài, vai chị/tỷ trong nhóm.","vaiTro":"Đầu mối nhóm Vũ tộc mai phục.","tabs":{"diem":[],"kinhLich":[{"text":"Được người Vũ tộc bị thương nặng báo rằng mười vị thiên tài khác họ do bộ tộc bồi dưỡng cùng mấy vị đường huynh đều đã chết hết trước tay tiểu Ma vương.; Được người truyền tin Vũ tộc bị thương nặng báo rằng mười vị thiên tài khác họ do bộ tộc bồi dưỡng cùng mấy đường huynh đều đã chết, tiểu Ma vương xuất hiện từ một thông đạo khác; tổng cộng Vũ tộc trước sau chết hơn mười thiên tài.","anchor":"trước sau tổng cộng chết đi mười mấy gã thiên tài","bridge":true,"khoang":"@c0127"}],"tuViMoc":[],"nhanMach":[{"ten":"Người truyền tin Vũ tộc","tag":"dong-minh","quanHe":"Người báo tin cho Lục tỷ","ghiChu":""},{"ten":"Người truyền tin Vũ tộc","tag":"dong-minh","quanHe":"Đồng tộc","ghiChu":"Người truyền tin báo tổn thất cho Lục tỷ."}],"tuiDo":{}},"nguon":["@c0127"]},{"id":"nguoi-truyen-tin-vu-toc","name":"Người truyền tin Vũ tộc","aliases":["Cường giả Vũ tộc báo tin"],"gioiTinh":"nam","canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","blurb":"Cường giả Vũ tộc máu me nửa người cháy đen chạy tới báo tiểu Ma vương đã giết sạch người, sau bị tia chớp đánh nổ tung.","vaiTro":"Người truyền tin bị Thạch Hạo giết lập uy.","tabs":{"diem":[],"kinhLich":[{"text":"Toàn thân xẹt điện miệng chảy máu, báo cho Lục tỷ về tổn thất nặng của Vũ tộc; sau đó trúng đòn bảo kính Toan Nghê của thiếu niên, nổ tung chia năm xẻ bảy chết tại chỗ.; Toàn thân xẹt điện, miệng chảy máu, chạy tới báo cho Lục tỷ rằng mười vị thiên tài khác họ cùng mấy đường huynh đều đã chết, tiểu Ma vương xuất hiện từ thông đạo khác; sau đó bị Thạch Hạo dùng bảo kính Toan Nghê bắn tia chớp vàng, nổ tung chia năm xẻ bảy chết tại chỗ.; Bị thương…","anchor":"trực tiếp nổ tung chia năm xẻ bảy, chết ngay tại chổ","bridge":true,"khoang":"@c0127"},{"chuong":"@c0127","importance":"normal","tieuDe":"Bị bảo kính Toan Nghê giết","text":"Bị thương nặng chạy về báo tin cho Lục tỷ về cái chết của các thiên tài Vũ tộc; sau đó trúng tia chớp vàng từ bảo kính Toan Nghê của Thạch Hạo đánh về bên hồ, nổ tung chết tại chỗ.","anchor":"nổ tung chia năm xẻ bảy, chết ngay tại chổ"}],"tuViMoc":[],"nhanMach":[{"ten":"Lục tỷ (Vũ tộc)","tag":"dong-minh","quanHe":"Báo tin cho Lục tỷ","ghiChu":""},{"ten":"Lục tỷ (Vũ tộc)","tag":"dong-minh","quanHe":"Đồng tộc","ghiChu":"Báo tin cho Lục tỷ."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị giết bởi","ghiChu":"Bị bảo kính Toan Nghê giết."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị tiểu Ma vương bắn tia chớp vàng nổ tung chết","ghiChu":"@c0127"},{"ten":"Lục tỷ (Vũ tộc)","tag":"dong-minh","quanHe":"Báo tin tổn thất cho Lục tỷ","ghiChu":"@c0127"}],"tuiDo":{}},"nguon":["@c0127"]},{"id":"vu-tu-mach","name":"Vũ Tử Mạch","cn":"","aliases":["Thiếu nữ thiên tài Vũ tộc","Thiếu nữ thiên tài Nhân tộc","Thiếu nữ Vũ tộc tà áo xanh"],"gioiTinh":"nu","theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0128)","trangThai":"song","blurb":"Thiếu nữ tà áo xanh của Vũ tộc, một trong “song kiệt” thiên phú dị bẩm, sở hữu Thông Linh Thần Giác; phụng lệnh vào Bách Đoạn sơn giết nhóc tỳ.","vaiTro":"Thiên tài Vũ tộc, đối thủ của Thạch Hạo tại Bách Đoạn sơn","tinhCach":[{"text":"Kiêu hãnh, tập trung khi chiến đấu nhưng dễ nổi giận khi bị khiêu khích về thân hình","chuong":"@c0128"}],"tabs":{"diem":[{"text":"Sở hữu Thông Linh Thần Giác — giác quan thần kỳ có thể hiểu chút nhân quả","chuong":"@c0128"},{"text":"Một trong “song kiệt” Vũ tộc cùng Thạch Nghị, thiên phú dị bẩm","chuong":"@c0128"},{"text":"Một trong ‘song kiệt’ Vũ tộc cùng Thạch Nghị; nếu không có Thạch Nghị thì nàng còn tỏa sáng hơn","chuong":"@c0128"}],"kinhLich":[{"text":"Thi triển Bảo Thuật Thông Linh “Nhất Thế Họa Quyển” phong ấn nhóc tỳ nhưng bị cối xay bạc phá vỡ sách cổ; chuyển sang “Trong mưa sinh điện” đánh nứt tòa núi nhỏ thành bốn mảnh, song bị nhóc tỳ dùng bảo kính Toan Nghê khắc chế lôi điện, nhiều lần trúng đòn ho ra máu; Bảo Tán bị Cốt Tiễn cắt đứt, Bảo Y lông chim tím bị đánh nổ tung hóa tro bụi, phải tái triển Thông Linh phòng ngự.; Ra mặt với thân phận thiếu nữ tà áo xanh, một trong “song kiệt” Vũ…","anchor":"Bảo Y ở trên người nàng lấp lánh như ánh bình minh, nhưng cuối cùng lại nổ tung, không địch lại bảo kính Toan Nghê","bridge":true,"khoang":"@c0128"},{"chuong":"@c0128","importance":"normal","tieuDe":"Ra mặt tử chiến nhóc tỳ tại Bách Đoạn sơn","text":"Phụng lệnh trưởng bối vào Bách Đoạn sơn toàn lực giết nhóc tỳ (kẻ đã giết mười tám cao thủ Vũ tộc); dùng Thông Linh Thần Giác nhìn nhưng thấy hắn bị sương mù bao phủ, không nhìn thấu giống Thạch Nghị; thi triển Bảo Thuật Thông Linh ‘Nhất Thế Họa Quyển’ và ‘Trong mưa sinh điện’ phá nát tòa núi nhỏ, nhưng bị nhóc tỳ dùng lôi điện khắc chế, nhiều lần bị đánh ho ra máu, Bảo Tán và Bảo Y lần lượt bị hủy.","anchor":"Hắn cũng giống như Thạch Nghị, nhìn không thấu, không thể nhìn thấy được do có một luồng sương mù bao phủ lại"},{"text":"Bị Thạch Hạo đánh tổn hại Sách cổ nhiều màu Phù Văn, đánh tan ký hiệu cuối cùng trên người rồi ho ra máu; tung đòn cuối bảo thuật Thông Linh tạo lưới kỳ quang và đọc Thần âm “Phong” nhưng hai cánh tay gãy, thần lực khủng bố truyền vào cơ thể khiến nàng phải phân tán luồng lực rồi bay sang một bên phun máu; nhận ra lực lượng thân thể cuồng bạo của Thạch Hạo chỉ từng thấy ở Thạch Nghị vài năm trước.; Bị Thạch Hạo đánh tan sách cổ nhiều màu Phù Văn…","anchor":"Vừa mới tiếp xúc hai cánh tay của nàng liền gãy","bridge":true,"khoang":"@c0129"},{"chuong":"@c0129","importance":"normal","tieuDe":"Bại trận trước nhóc tỳ","text":"Bị nhóc tỳ đánh tan sách cổ nhiều màu (Phù Văn) và ký hiệu cuối cùng trên người, ho ra máu; tung đòn cuối bảo thuật Thông Linh dệt lưới kỳ quang và đọc Thần âm “Phong!” bắt chéo hai tay ngăn cú đấm nhưng hai cánh tay gãy, phải phân tán thần lực khắp thân để khỏi vỡ nát rồi bay sang phun máu; nhận ra lực lượng thân thể cuồng bạo của nhóc tỳ giống lực từng thấy ở Thạch Nghị vài năm trước.","anchor":"lực lượng thân thể cuồng bạo vừa nãy nàng chỉ thấy được ở trên người của Thạch Nghị vài năm trước"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ tại Bách Đoạn sơn","ghiChu":"Nhóc tỳ mà nàng phụng lệnh truy giết; áp đảo nàng bằng lôi điện và bảo kính Toan Nghê"},{"ten":"Thạch Nghị","tag":"dong-minh","quanHe":"Cùng là “song kiệt” Vũ tộc","ghiChu":"Thông Linh Thần Giác cũng không nhìn thấu Thạch Nghị; nếu không có Thạch Nghị thì nàng còn tỏa sáng hơn"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ đánh bại nàng","ghiChu":"Đánh tan Phù Văn, làm gãy hai cánh tay."},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Người mà nàng liên hệ lực lượng thân thể cuồng bạo của Thạch Hạo","ghiChu":"Từng thấy lực tương tự ở Thạch Nghị vài năm trước."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đánh bại nàng, làm gãy hai cánh tay."},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Người từng chứng kiến sức mạnh","ghiChu":"Từng thấy lực lượng thân thể cuồng bạo ở Thạch Nghị vài năm trước."},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Người có lực lượng thân thể tương tự Thạch Hạo","ghiChu":"Nàng liên hệ thần lực Thạch Hạo với Thạch Nghị vài năm trước (@c0129)."},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Đối thủ giao chiến","ghiChu":"Bị nhóc tỳ đánh bại"}],"tuiDo":{"phapBao":[{"ten":"Bảo Tán (dù)","loai":"bao-cu","trangThai":"hong","moTa":"Cây dù lớn che lôi điện, bị Cốt Tiễn cắt đứt rách nát","nguon":"@c0128"},{"ten":"Bảo Y lông chim màu tím","loai":"bao-cu","trangThai":"hong","moTa":"Áo giáp bện từ lông chim tím, bị bảo kính Toan Nghê đánh nổ tung hóa tro bụi","nguon":"@c0128"},{"ten":"Quyển sách cổ nhiều màu","loai":"phap-bao","trangThai":"hong","moTa":"Quyển sách cổ Phù Văn dùng thi triển Bảo Thuật Thông Linh, bị cối xay bạc phá vỡ","nguon":"@c0128"}],"congPhap":[{"ten":"Bảo Thuật Thông Linh","moTa":"Bảo thuật “Nhất Thế Họa Quyển” dệt Phù Văn phong ấn địch","nguon":"@c0128"}]}},"nguon":["@c0128","@c0129"]},{"id":"vu-con","name":"Vũ Côn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Trung niên cường giả nổi danh Vũ tộc; kể chuyện thúc tổ năm xưa dùng Cốt Tiễn xuyên phổi Thạch Tử Lăng, truy nhìn chân thân Thạch Hạo.","vaiTro":"Cường giả Vũ tộc, một trong bốn Người phong ấn truy đuổi Thạch Hạo và Sư Tử chín đầu.","tinhCach":[{"text":"Sắc bén, kiên định truy tìm chân thân đối thủ.","chuong":"@c0129"}],"tabs":{"diem":[{"text":"Cường giả nổi danh Vũ tộc, mắt bắn thần mang khi nhìn chằm chằm đối thủ.","chuong":"@c0129"}],"kinhLich":[{"text":"Trung niên trong nhóm bốn Người phong ấn Vũ tộc; kể thúc tổ hắn năm đó chỉ huy trận chiến, từ Hoàng Đô đuổi tới Tây Cương, dùng Cốt Tiễn xuyên thủng lá phổi Thạch Tử Lăng suýt trúng tim; mắt bắn thần mang nhìn chằm chằm muốn thấy chân thân Thạch Hạo.; Cùng ba cường giả Người phong ấn thu mưa bụi lộ chân thân; kể thúc tổ hắn năm đó chỉ huy trận chiến từ Hoàng Đô đuổi tới Tây Cương, dùng Cốt Tiễn xuyên thủng lá phổi Thạch Tử Lăng suýt trúng tim; m…","anchor":"Hắn tên là Vũ Côn, là một cường giả rất nổi danh trong Vũ tộc.","bridge":true,"khoang":"@c0129"},{"chuong":"@c0129","importance":"normal","tieuDe":"Lộ danh tính, kể trận chiến năm xưa","text":"Cùng ba cường giả Vũ tộc vây bắt rồi truy đuổi nhóc tỳ và Sư Tử chín đầu; lộ chân thân, tự xưng tên, kể thúc tổ hắn năm xưa từ Hoàng Đô đuổi tới Tây Cương dùng Cốt Tiễn xuyên thủng lá phổi Thạch Tử Lăng suýt trúng tim; mắt bắn thần mang truy nhìn chân thân nhóc tỳ.","anchor":"Hắn tên là Vũ Côn, là một cường giả rất nổi danh trong Vũ tộc."},{"text":"Một trong bốn đại cường giả Vũ tộc truy sát Thạch Hạo trong Bách Đoạn sơn; ban đầu cười khinh miệt, sau nộ hỏa muốn róc xương khi một đồng bọn bị Ngư Long nuốt chết và một kẻ tự cắt hai chân; cuối cùng con mồi cưỡi Hỏa Vân Tước bay mất.; Dẫn đầu bốn đại cường giả Vũ tộc quyết tốc chiến diệt trừ nhóc tỳ, cười khinh miệt khi cậu chảy máu đầm đìa ngã bên hồ; sau đó nộ hỏa muốn róc xương cậu khi Ngư Long nuốt mất một đồng bọn và một kẻ khác tự cắt h…","anchor":"Năm đó ta không thể giết phụ thân ngươi, chỉ là đánh trọng thương hắn mà thôi","bridge":true,"khoang":"@c0130"},{"chuong":"@c0130","importance":"normal","tieuDe":"Truy sát nhóc tỳ, mất đồng đội bên hồ","text":"Cùng ba cường giả Vũ tộc quyết bắt trực tiếp nhóc tỳ tra hỏi rồi diệt trừ, tránh để Vũ Vương phủ biết chuyện; ban đầu cười khinh miệt khi nhóc tỳ ngã bên hồ, nhắc năm đó không giết được Thạch Tử Lăng chỉ đánh trọng thương và dọa Thạch Tử Lăng sẽ phát điên khi biết con bị giết; sau khi Ngư Long trồi lên nuốt một đồng bọn, tàn phế một kẻ khác, nộ hỏa muốn róc xương nhóc tỳ nhưng không dám liều với Ngư Long, cùng đồng bọn còn lại điều động Bảo Cụ tiếp tục truy sát.","anchor":"Năm đó ta không thể giết phụ thân ngươi, chỉ là đánh trọng thương hắn mà thôi"},{"chuong":"@c0130","importance":"normal","tieuDe":"Truy sát Thạch Hạo bất thành","text":"Cùng ba cường giả Vũ tộc truy sát Thạch Hạo, cười khinh miệt khi thấy nó ngã bên hồ; sau khi Ngư Long nuốt mất một đồng bọn và tàn phế một kẻ khác, Vũ Côn nộ hỏa muốn róc xương Thạch Hạo, điều động Bảo Cụ truy sát tiếp nhưng con mồi cưỡi Đại Hồng bay đi mất.","anchor":"Năm đó ta không thể giết phụ thân ngươi, chỉ là đánh trọng thương hắn mà thôi"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Truy nhìn chân thân Thạch Hạo","ghiChu":"Nghi Thạch Hạo là “đứa nhỏ năm đó” liên quan Thạch Tử Lăng."},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Thúc tổ Vũ Côn từng dùng Cốt Tiễn xuyên phổi Thạch Tử Lăng","ghiChu":"Trận chiến năm xưa từ Hoàng Đô tới Tây Cương."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Con Thạch Tử Lăng, mục tiêu truy sát","ghiChu":"@c0130"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Mục tiêu truy sát"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ truy đuổi","ghiChu":"Muốn thấy chân thân Thạch Hạo, nghi liên quan Thạch Tử Lăng."},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ dòng họ","ghiChu":"Thúc tổ hắn từng dùng Cốt Tiễn xuyên phổi Thạch Tử Lăng năm xưa."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối tượng truy đuổi","ghiChu":"Muốn thấy chân thân Thạch Hạo (@c0129)."},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Nạn nhân năm xưa của phe Vũ tộc","ghiChu":"Thúc tổ hắn từng dùng Cốt Tiễn xuyên phổi Thạch Tử Lăng (@c0129)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối tượng truy sát","ghiChu":"Quyết diệt Thạch Hạo vì lo thiên tư đáng sợ; từng đánh trọng thương phụ thân cậu năm đó"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Đối thủ truy sát","ghiChu":"Nghi ngờ nhóc tỳ liên quan Thạch Tử Lăng, muốn thấy rõ mặt"}],"tuiDo":{}},"nguon":["@c0129","@c0130"]},{"id":"te-linh","name":"Tế Linh","gioiTinh":"khong-ro","tabs":{"kinhLich":[{"text":"Tồn tại trong giàn dây hồ lô khô vàng ở Thượng Cổ Tịnh Thổ, không phản ứng cứu Thạch Hạo; trái hồ lô vỏ xanh phát khí Hỗn Độn, hiển hóa Phù Văn đẩy lui nhóc tỳ; nghi có quen biết với ông lão Thượng Cổ.","anchor":"hồ lô vỏ xanh kia liền phát ra khí Hỗn Độn","bridge":true,"khoang":"@c0111"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Thạch Hạo cầu cứu nhưng không phản ứng","ghiChu":"@c0111"}],"tuViMoc":[]},"nguon":["@c0111"]},{"id":"ong-lao-toc-xam-u-linh-thuong-co","name":"Ông lão tóc xám (u linh Thượng Cổ)","cn":"","aliases":["Ông lão tử khí","Ông lão tóc xám"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Tồn tại tử khí thời Thượng Cổ, tóc xám máu đen khô cứng, cổ kiếm rỉ sét cắm trên đầu, liên tục cản đường Thạch Hạo đòi trả kiếm.","vaiTro":"Thực thể thần quái xuất hiện tại nơi ở Tế Linh","tinhCach":[{"text":"Cố chấp, lặp đi lặp lại đòi trả kiếm","chuong":"@c0111"}],"tabs":{"diem":[{"text":"Không có sự sống, tái tạo từ hư không mỗi khi bị né tránh","chuong":"@c0111"},{"text":"Chỉ Thạch Hạo nhìn thấy, người khác chỉ sờ được như tượng băng","chuong":"@c0111"}],"kinhLich":[{"text":"Xuất hiện tại nơi ở Tế Linh với cổ kiếm cắm trên đầu, tái tạo từ hư không cản đường Thạch Hạo, lặp 'Trả kiếm cho ta'; sau lời hứa của Thạch Hạo thì biến mất giữa sấm chớp; hiện lần hai bên giường, các đệ tử không nhìn thấy nhưng sờ được như tượng băng lạnh giá thấu xương.","anchor":"cảm giác sờ tới một bức tượng băng, lạnh giá thấu xương","bridge":true,"khoang":"@c0111"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cản đường đòi trả kiếm; được Thạch Hạo hứa tìm giúp trả kiếm rồi bị cưỡi lên cổ","ghiChu":"@c0111"}]},"nguon":["@c0111"]},{"id":"hoa-van-tuoc-dai-hong","name":"Hỏa Vân Tước","cn":"","aliases":["Đại Hồng"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Hung cầm đỏ rực tính hung tợn trong tiểu thế giới, nghi là đời sau Thái Cổ di chủng; bị nhóc tỳ đả thương, giả chết trốn thoát, thịt là huyết nhục bảo dược.","vaiTro":"Hung cầm bị nhóc tỳ săn đuổi lấy thịt.","tinhCach":[{"text":"Hung tợn, dễ nổi điên; giảo hoạt giả chết để trốn.","chuong":"@c0118"}],"tabs":{"diem":[{"text":"Chim đỏ rực trút mưa Hỏa văn biến rừng thành biển lửa; thịt là huyết nhục bảo dược.","chuong":"@c0118"}],"kinhLich":[{"text":"Hỏa Vân Tước nổi điên trút mưa Hỏa văn biến rừng thành biển lửa, bị nhóc tỳ dùng tia chớp vàng, trăng bạc và Ma Cầm đả thương làm rớt hơn hai mươi cân thịt; gia trì Bảo Thuật, giả chết bay sát đất trốn thoát.","anchor":"Một khối thịt rớt ra, con chim rơi xuống cực nhanh.","bridge":true,"khoang":"@c0118"},{"text":"Đang bay trên dãy núi trong tầng mây thì suýt đụng nhóc tỳ, nhận ra liền hoảng sợ bỏ chạy nhưng bị đánh gục và ôm chặt cổ; ám ảnh gọi nhóc tỳ là Ma Vương/Ma đầu vì trước đây bị mượn hai mươi cân thịt để ninh ăn; định phản kháng bằng cách xoay người bay thẳng về phía truy binh Vũ tộc với suy nghĩ địch nhân của địch nhân là bằng hữu, mong có người thu phục nhóc tỳ giải thoát cho nó; bị nhóc tỳ dọa xin thịt, đành rụt cổ hóa thành áng lửa xẹt qua tầng mây với tốc độ kinh người, chở nhóc tỳ trốn thoát hai cao thủ Vũ tộc.","anchor":"xoay người lại, bay thẳng về phía mấy tên truy binh","bridge":true,"khoang":"@c0130"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị săn đuổi đả thương","ghiChu":"Bị nhóc tỳ gọi là Đại Hồng, đoạt thịt."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0118","@c0130"]},{"id":"hoa-kim-su-tu-chin-dau-thai-co","name":"Hoàng Kim sư tử chín đầu","cn":"","aliases":["Sư Tử chín đầu","Hoàng Kim sư tử"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thái Cổ di chủng","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Thái Cổ di chủng cầm đầu tại Thần Quật, toàn thân vảy vàng ròng, chín đầu mỗi đầu phun một phi kiếm hoàng kim.","vaiTro":"Đối thủ dị chủng chặn ải Thần Quật, tranh thu Thạch Hạo làm chiến sủng.","tinhCach":[{"text":"Uy nghiêm, ngạo mạn, huyết mạch kinh người","chuong":"@c0121"}],"tabs":{"diem":[{"text":"Toàn thân vảy vàng ròng, Phù Văn cao siêu, huyết mạch kinh người","chuong":"@c0121"},{"text":"Mở bức tranh so sánh nhận ra Thạch Hạo là chiến phó mạnh mẽ nó tìm","chuong":"@c0121"}],"kinhLich":[{"text":"Cầm đầu ba Thái Cổ di chủng chờ tại chân núi Thần Quật, mở tranh nhận diện Thạch Hạo là chiến phó, đánh văng hai kẻ kia để độc chiếm; đòi Thạch Hạo qua ải, chín đầu mỗi đầu phun một phi kiếm hoàng kim chém tới rồi đại chiến ngang sức với nhóc tỳ.","anchor":"chín thanh phi kiếm đều có màu hoàng kim","bridge":true,"khoang":"@c0121"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhóc tỳ Nhân tộc muốn thu làm chiến phó","ghiChu":"Giao chiến ngang sức"},{"ten":"Ngân Huyết cự nhân","tag":"dong-minh","quanHe":"Cùng nhóm Thái Cổ di chủng","ghiChu":"Tranh giành Thạch Hạo"},{"ten":"Vũ Vương","tag":"dong-minh","quanHe":"Cùng nhóm Thái Cổ di chủng","ghiChu":"Tranh giành Thạch Hạo"},{"ten":"Hỏa Linh Nhi","tag":"khac","quanHe":"Công chúa Hỏa quốc","ghiChu":"Giục nó thu phục Thạch Hạo"}],"tuiDo":{"congPhap":[{"ten":"Chín phi kiếm hoàng kim","loai":"thần thông","moTa":"Chín cái đầu mỗi đầu phun ra một thanh phi kiếm màu hoàng kim rực rỡ chém tới.","nguon":"@c0121"},{"ten":"Di hình hoán vị","loai":"thân pháp","moTa":"Thân biến mất tại chỗ né đòn, xuất hiện nơi phương xa.","nguon":"@c0121"}]}}},{"id":"nguoi-khong-lo-ngan-huyet-cu-nhan","name":"Ngân Huyết cự nhân","cn":"","aliases":["Người khổng lồ Ngân Huyết","Cự Nhân"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thái Cổ di chủng","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Sinh linh khổng lồ màu bạc cao mười mấy mét, tự xưng quá khứ vô địch, tranh thu Thạch Hạo làm người hầu.","vaiTro":"Đối thủ dị chủng tại chân núi Thần Quật.","tinhCach":[{"text":"Ngạo mạn, tự phụ quá khứ vô địch","chuong":"@c0121"}],"tabs":{"diem":[{"text":"Sinh linh khổng lồ màu bạc cao mười mấy mét","chuong":"@c0121"},{"text":"Ra tay cướp Ấu Thần dùng Phù Văn nhưng bị nhóc tỳ phun chớp đánh cháy đen bàn tay","chuong":"@c0125"}],"kinhLich":[{"text":"Cùng hai Thái Cổ di chủng chờ tại Thần Quật, tranh thu Thạch Hạo làm người hầu; bị Thạch Hạo đấm khiến bàn tay như cái gầu to không ngừng chảy máu.","anchor":"bàn tay như cái gầu to không ngừng chảy máu","bridge":true,"khoang":"@c0121"},{"text":"Muốn cướp Ấu Thần, ra tay dùng Phù Văn nhưng bị nhóc tỳ phun chớp đánh cháy đen bàn tay phải rút lui; sau đó cùng Vũ Vương định gọi thêm người thì bị nhóc tỳ, Hỏa Linh Nhi và thiên tài Bổ Thiên các truy sát bắt trói.","anchor":"bị bắt gọn trói như cái bánh chưng","bridge":true,"khoang":"@c0125"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhóc tỳ Nhân tộc","ghiChu":"Bị y đấm chảy máu tay"},{"ten":"Hoàng Kim sư tử chín đầu","tag":"dong-minh","quanHe":"Cùng nhóm Thái Cổ di chủng","ghiChu":"Bị sư tử đánh văng để độc chiếm Thạch Hạo"},{"ten":"Vũ Vương","tag":"dong-minh","quanHe":"Cùng cướp Ấu Thần và cùng bị bắt trói","ghiChu":"@c0125"}]},"nguon":["@c0125"]},{"id":"cuong-gia-vu-toc-bao-tin","name":"Cường giả Vũ tộc báo tin","aliases":["Kẻ cháy đen báo tin"],"gioiTinh":"nam","theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Cường giả Vũ tộc máu me nửa người cháy đen chạy tới báo tiểu Ma vương đã giết sạch người.","vaiTro":"Người báo tin Vũ tộc.","tinhCach":[{"text":"Hoảng loạn khi báo tin dữ.","chuong":"@c0127"}],"tabs":{"kinhLich":[{"text":"Kẻ máu me nửa người cháy đen chạy tới báo song kiệt Vũ tộc rằng tiểu Ma vương đã giết sạch người của họ.","anchor":"cái tên tiểu Ma vương kia đã giết tới rồi, người của chúng ra đều chết hết rồi!","bridge":true,"khoang":"@c0127"},{"chuong":"@c0127","importance":"normal","tieuDe":"Chạy về báo tin đại bại","text":"Toàn thân nửa người cháy đen chạy tới chỗ song kiệt Vũ tộc canh thông đạo, báo rằng tiểu Ma vương đã giết tới, người của họ đều đã chết hết.","anchor":"cái tên tiểu Ma vương kia đã giết tới rồi"}],"nhanMach":[{"ten":"Nữ tử song kiệt Vũ tộc","tag":"dong-minh","quanHe":"Đồng tộc","ghiChu":"Báo tin cho song kiệt."}]},"nguon":["@c0127"]},{"id":"lao-gia-toc-xam-co-kiem-xuyen-dau","name":"Lão già tóc xám","aliases":["Cổ nhân bị cổ kiếm xuyên đầu"],"gioiTinh":"nam","trangThai":"khong-ro","blurb":"Cổ nhân thời Thượng Cổ, đầu bị cổ kiếm rỉ sét xuyên thủng, không sinh mệnh mà di chuyển như hư không, phát tiếng ô ô như khóc.","vaiTro":"Cổ nhân bí ẩn nơi Tế Linh ở ẩn","tabs":{"kinhLich":[{"text":"Khi Thạch Hạo rời nơi Tế Linh ở ẩn, lão già tóc xám xuất hiện ngoài cửa, đầu bị cổ kiếm rỉ sét xuyên thủng, biến mất rồi hiện sau lưng, giữa đống ngói vỡ, phát tiếng ô ô như khóc rồi chặn đường nhóc tỳ.; Xuất hiện ngoài cửa khu vườn cổ với mái tóc xám, hai mắt trống rỗng, đầu bị một thanh cổ kiếm rỉ sét xuyên thủng, móng tay đen dài nửa thước, mặc y phục Thượng Cổ; không hô hấp không tim đập, biến mất rồi xuất hiện sau lưng nhóc tỳ, phát tiếng ô…","anchor":"ngoài cửa có một lão già, mái tóc màu xám, hai mắt trống rỗng, trên đầu cắm vào một thanh cổ kiếm, xuyên thấu mà qua","bridge":true,"khoang":"@c0110"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Chặn đường nhóc tỳ khi nó rời nơi Tế Linh ở ẩn","ghiChu":"@c0110"}],"tuViMoc":[],"diem":[{"text":"Đầu bị cổ kiếm rỉ sét xuyên thủng, mắt trống rỗng, không hô hấp không tim đập","chuong":"@c0110"},{"text":"Di chuyển như từ hư không, chợt đông chợt tây, phát tiếng ô ô như khóc","chuong":"@c0110"}]},"nguon":["@c0110"],"canhGioiCaoNhat":"không rõ","tinhCach":[{"text":"Câm lặng, di chuyển thất thường, phát tiếng ô ô như khóc","chuong":"@c0110"}]},{"id":"au-than-soi-con","name":"Ấu Thần","aliases":["Sói con","hậu đại Lang Thần"],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Sinh linh thần linh Thượng Cổ mới chào đời, hậu đại của Lang Thần, hình sói con lông xám có sừng và đôi cánh nhỏ.","tabs":{"kinhLich":[{"text":"Sinh linh thần linh Thượng Cổ hình sói con được ánh sáng ngũ sắc bao phủ, hấp thu toàn bộ thần quang/tia điện của các thế lực tấn công để trưởng thành; bị nhóc tỳ điện giật cháy đen lông, được Hỏa Linh Nhi cho ăn Linh dược và huyết nhục bảo dược, sau bám chặt lấy nhóc tỳ.; Sinh linh nhỏ bọc sương ánh sáng ngũ sắc chào đời, hấp thu mọi bảo thuật/tia điện của các thế lực để trưởng thành; hiện hình sói con dài hơn một xích, lông xám xù, hai sừng, đ…","anchor":"Là Ấu Thần, nó đang hấp thu sức mạnh để trưởng thành!","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"major","tieuDe":"Ấu Thần ra đời và được nhận là hậu đại Lang Thần","text":"Sinh linh nhỏ bọc trong ánh sáng ra đời, hấp thu mọi bảo thuật và tia điện để trưởng thành; lộ hình sói con lông xám có sừng nhú và đôi cánh nhỏ, được xác nhận là hậu đại Lang Thần; bị nhóc tỳ điện giật thử khiến lông cháy đen; ăn hai Linh dược và trái tim hung thú của Hỏa Linh Nhi rồi bám vai nhóc tỳ; về sau Sư Tử chín đầu nhận ra nó có thể là một Ấu Thần Thái Cổ hung thú non.","anchor":"Là Ấu Thần, nó đang hấp thu sức mạnh để trưởng thành!"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Được Thạch Hạo đoạt và nuôi, bám dính theo","ghiChu":"@c0125"},{"ten":"Hỏa Linh Nhi","tag":"dong-hanh","quanHe":"Được Hỏa Linh Nhi cho ăn và nuôi, xem như cha mẹ nuôi","ghiChu":"@c0125"},{"ten":"Lang Thần","tag":"ho-hang","quanHe":"Tổ tiên (thần linh Thượng Cổ)","ghiChu":"Ấu Thần là hậu đại của Lang Thần"},{"ten":"Hỏa Linh Nhi","tag":"an-nhan","quanHe":"Người nuôi dưỡng","ghiChu":"Cho sói con ăn Linh dược, huyết nhục bảo dược; được giao nuôi mập"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được nhóc tỳ đoạt và nuôi giữ","ghiChu":"@c0125"},{"ten":"Hỏa Linh Nhi","tag":"khac","quanHe":"Được giao nuôi dưỡng","ghiChu":"@c0125"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được nhóc tỳ bọc bảo vệ và định nuôi lớn, bám vai nhóc tỳ","ghiChu":"@c0125"},{"ten":"Sư Tử chín đầu","tag":"khac","quanHe":"Sư Tử chín đầu nhận ra nó là Ấu Thần Thái Cổ hung thú non","ghiChu":"@c0125"}],"tuViMoc":[],"diem":[{"text":"Sinh linh mới sinh hình sói con lông xám, có sừng nhú và đôi cánh nhỏ, mắt to đen như đá quý","chuong":"@c0125"},{"text":"Hấp thu mọi bảo thuật, mưa ánh sáng, tia điện để trưởng thành","chuong":"@c0125"}]},"nguon":["@c0125"],"vaiTro":"Thái Cổ hung thú non được nhóc tỳ nuôi dưỡng","tinhCach":[{"text":"Non nớt, tham ăn, cảnh giác nhưng quyến luyến người nuôi","chuong":"@c0125"}]},{"id":"cuu-linh-vuong","name":"Cửu Linh Vương","gioiTinh":"nam","trangThai":"khong-ro","blurb":"Tổ phụ/họ hàng của Sư Tử chín đầu, bị Thạch Hạo đòi đại lễ Linh dược qua Sư Tử.","tabs":{"kinhLich":[{"text":"Tổ phụ của Sư Tử chín đầu; bị nhóc tỳ đòi ban đại lễ mấy trăm cân Linh dược, tốt nhất một cây Thánh dược để chuộc cháu.; Được nhắc là tổ phụ/họ hàng của Sư Tử chín đầu; Thạch Hạo đòi ông ta đại lễ mấy trăm cân Linh dược, tốt hơn là một cây Thánh dược.","anchor":"Nếu như tìm được Bất Lão Thần Tuyền thì còn trị tốt được cho mấy cái đầu bị mất của ngươi nữa đấy.","bridge":true,"khoang":"@c0125"},{"chuong":"@c0125","importance":"normal","tieuDe":"Bị đòi ban đại lễ cho tiểu đệ","text":"Là tổ phụ của Sư Tử chín đầu; sau khi cháu bị nhóc tỳ thu phục, bị đòi ban đại lễ mấy trăm cân Linh dược, tốt nhất là một cây Thánh dược.","anchor":"Nếu như tìm được Bất Lão Thần Tuyền thì còn trị tốt được cho mấy cái đầu bị mất của ngươi nữa đấy."}],"nhanMach":[{"ten":"Sư Tử chín đầu","tag":"ho-hang","quanHe":"Sư Tử chín đầu tự xưng là cháu của ông","ghiChu":"@c0125"},{"ten":"Sư Tử chín đầu","tag":"ho-hang","quanHe":"Cháu","ghiChu":"Sư Tử chín đầu tự xưng là cháu của Cửu Linh Vương"},{"ten":"Sư Tử chín đầu","tag":"ho-hang","quanHe":"Cháu của Cửu Linh Vương","ghiChu":"@c0125"}],"tuViMoc":[]},"nguon":["@c0125"]},{"id":"hai-huynh-muoi-thi-sinh-c0103","name":"Hai huynh muội thí sinh","aliases":["Thiếu niên và tiểu cô nương"],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Cặp thí sinh huynh muội ăn sáng cùng nhóc tỳ, cung cấp tin về việc Bổ Thiên Các phong tỏa chiến trường thứ hai và cho người xem lễ.","vaiTro":"Thí sinh cung cấp tin cho nhóc tỳ","tabs":{"kinhLich":[{"text":"Mời nhóc tỳ ăn chung buổi sáng, qua trò chuyện tiết lộ kỳ khảo phải làm lại từ đầu vì thằng ranh nhân thần cộng phẫn gây họa, Bổ Thiên Các đã bày thiên la địa võng phong tỏa chiến trường thứ hai và cho người ngoài xem lễ; được nhóc tỳ tặng mỗi người một viên Long Tán và Hổ Dược.","anchor":"Họ đã bày ra thiên la địa võng, sớm đã phong tỏa chiến trường thứ hai rồi","bridge":true,"khoang":"@c0103"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Ăn sáng cùng nhóc tỳ và được tặng thuốc quý","ghiChu":"@c0103"}]}},{"id":"thieu-nien-huynh-hai-huynh-muoi-c0103","name":"Thiếu niên (huynh trong hai huynh muội)","gioiTinh":"nam","aliases":[],"theLuc":[],"trangThai":"song","blurb":"Thí sinh vượt ải thử luyện Bổ Thiên Các; cùng muội nướng chim ăn, kể cho nhóc tỳ về việc phong tỏa chiến trường thứ hai.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Cởi mở, sẵn lòng kể chuyện cho người lạ","chuong":"@c0103"}],"tabs":{"diem":[{"text":"Thí sinh vượt ải, moi được tin tình hình Bổ Thiên Các","chuong":"@c0103"},{"text":"Kể chuyện Bổ Thiên Các cho phép người ngoài xem lễ để bắt thằng ranh","chuong":"@c0103"}],"kinhLich":[{"text":"Đang nướng chim ăn cùng muội thì gặp nhóc tỳ cướp chân chim; kể cho nhóc tỳ biết Bổ Thiên Các đã bày thiên la địa võng phong tỏa chiến trường thứ hai để bắt thằng ranh và cho người ngoài xem lễ; được nhóc tỳ tặng viên Long Tán và Hổ Dược trước khi đi.","anchor":"Họ đã bày ra thiên la địa võng, sớm đã phong tỏa chiến trường thứ hai rồi","bridge":true,"khoang":"@c0103"},{"chuong":"@c0103","importance":"normal","tieuDe":"Gặp nhóc tỳ, kể tình hình phong tỏa","text":"Cùng em gái nướng chim ăn sáng thì gặp nhóc tỳ; kể lại vì thằng ranh nhân thần cộng phẫn mà mọi người phải vượt ải lại từ đầu, Bổ Thiên Các bày thiên la địa võng phong tỏa chiến trường thứ hai và cho người ngoài xem lễ; được nhóc tỳ tặng một viên đan dược trước khi chia tay","anchor":"Nghe nói Bổ Thiên Các đặc biệt cho phép người ngoài 'xem lễ'."}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị nhóc tỳ cướp chân chim; cung cấp tin tình hình rồi được tặng thuốc quý","ghiChu":"@c0103"},{"ten":"Tiểu cô nương (muội trong hai huynh muội)","tag":"ho-hang","quanHe":"Muội gái, cùng nướng chim vượt ải","ghiChu":"@c0103"}],"tuiDo":{"danDuoc":[{"ten":"Long Tán","moTa":"Thuốc quý cường gân tráng cốt, khôi phục nguyên khí trong nháy mắt; được nhóc tỳ tặng","nguon":"@c0103"},{"ten":"Hổ Dược","moTa":"Thuốc quý trị thương công hiệu thần kỳ; được nhóc tỳ tặng","nguon":"@c0103"}]}},"nguon":["@c0103"]},{"id":"tieu-co-nuong-muoi-hai-huynh-muoi-c0103","name":"Tiểu cô nương (muội trong hai huynh muội)","gioiTinh":"nu","aliases":["Thiếu nữ (muội)"],"theLuc":[],"trangThai":"song","blurb":"Thiếu nữ thí sinh vượt ải Bổ Thiên Các; tính bạo lực, tức nhóc tỳ cướp chân chim.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Bạo lực, dễ tức giận","chuong":"@c0103"},{"text":"Hưng phấn khi kể chuyện dạy dỗ thằng ranh đáng ghét","chuong":"@c0103"}],"tabs":{"diem":[{"text":"Thiếu nữ thí sinh vượt ải, tính bạo lực","chuong":"@c0103"},{"text":"Tiếc chân chim bị nhóc tỳ cướp ăn, hưng phấn muốn bắt thằng ranh quậy","chuong":"@c0103"}],"kinhLich":[{"text":"Đang nướng chim ăn thì bị nhóc tỳ cướp chân chim, tức giận; hưng phấn kể về việc dạy dỗ thằng ranh đáng ghét và tình hình vượt ải; được nhóc tỳ tặng Long Tán và Hổ Dược.","anchor":"Họ đã bày ra thiên la địa võng, sớm đã phong tỏa chiến trường thứ hai rồi","bridge":true,"khoang":"@c0103"},{"chuong":"@c0103","importance":"normal","tieuDe":"Bị nhóc tỳ cướp ăn chân chim","text":"Cùng anh trai nướng chim ăn sáng thì gặp nhóc tỳ, bị cướp ăn chân chim mà tiếc rẻ; hưng phấn muốn dạy thằng ranh nhân thần cộng phẫn một trận, rồi được nhóc tỳ tặng một viên đan dược trước khi chia tay","anchor":"Nghe nói Bổ Thiên Các đặc biệt cho phép người ngoài 'xem lễ'."}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị nhóc tỳ cướp chân chim nên tức giận; được tặng thuốc quý","ghiChu":"@c0103"},{"ten":"Thiếu niên (huynh trong hai huynh muội)","tag":"ho-hang","quanHe":"Huynh trai, cùng nướng chim vượt ải","ghiChu":"@c0103"}],"tuiDo":{"danDuoc":[{"ten":"Long Tán","moTa":"Thuốc quý cường gân tráng cốt, khôi phục nguyên khí; được nhóc tỳ tặng","nguon":"@c0103"},{"ten":"Hổ Dược","moTa":"Thuốc quý trị thương công hiệu thần kỳ; được nhóc tỳ tặng","nguon":"@c0103"}]}},"nguon":["@c0103"]},{"id":"thieu-nien-huynh-thi-sinh-c0103","name":"Thiếu niên (huynh thí sinh)","gioiTinh":"nam","aliases":["Huynh"],"trangThai":"song","blurb":"Một trong hai huynh muội cùng ăn sáng với nhóc tỳ ở khu thứ tám, kể tình hình phong tỏa chiến trường thứ hai.","vaiTro":"Nhân vật phụ","tabs":{"kinhLich":[{"text":"Cùng em gái ăn sáng với nhóc tỳ, kể chuyện Bổ Thiên Các phong tỏa chiến trường thứ hai để bắt thằng ranh và việc cho người ngoài xem lễ; được nhóc tỳ tặng một viên đan dược trước khi chia tay.","anchor":"Nghe nói Bổ Thiên Các đặc biệt cho phép người ngoài 'xem lễ'.","bridge":true,"khoang":"@c0103"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cùng ăn sáng, bị cướp chân chim rồi được tặng đan dược","ghiChu":"@c0103"}],"tuiDo":{}},"nguon":["@c0103"]},{"id":"thieu-nu-muoi-thi-sinh-c0103","name":"Tiểu cô nương (muội thí sinh)","gioiTinh":"nu","aliases":["Muội","Thiếu nữ"],"trangThai":"song","blurb":"Em gái đi cùng thiếu niên thí sinh, tiếc chân chim bị nhóc tỳ cướp ăn, hưng phấn muốn dạy thằng ranh một trận.","vaiTro":"Nhân vật phụ","tabs":{"kinhLich":[{"text":"Cùng anh trai ăn sáng thì bị nhóc tỳ cướp ăn chân chim; hưng phấn muốn dạy thằng ranh nhân thần cộng phẫn một trận; được nhóc tỳ tặng một viên đan dược trước khi chia tay.","anchor":"Nghe nói Bổ Thiên Các đặc biệt cho phép người ngoài 'xem lễ'.","bridge":true,"khoang":"@c0103"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị cướp ăn chân chim rồi được tặng đan dược","ghiChu":"@c0103"}],"tuiDo":{}},"nguon":["@c0103"]},{"id":"trac-van","tabs":{"kinhLich":[{"text":"Nhấn mạnh ai đã thử luyện là đệ tử Bổ Thiên Các không chạy được; hé lộ với các đạo huynh gốc thuốc quý hiếm được chăm bón bằng Hắc Hổ Sát, tương lai có thể lột xác thành Thánh Dược, dùng để oai chấn tứ phương chiêu mộ thiên tài","anchor":"nó là vật báu được chăm bón bằng Hắc Hổ Sát, tương lai có thể lột xác thành Thánh Dược","bridge":true,"khoang":"@c0103"},{"chuong":"@c0105","importance":"normal","tieuDe":"Mất Hắc Sát Liên, phát điên","text":"Phát hiện Hắc Sát Liên (bảo dược có thể lột xác thành thánh dược) trong địa quật biến mất, từ dáng vẻ hiền lành chuyển sang điên cuồng gào thét chấn động thiên địa, phun máu; cùng Hùng Phi truy lùng nhóc tỳ bất thành rồi tuyên bố khảo nghiệm kết thúc.","anchor":"miệng mở thật rộng, điên cuồng gào thét không ngớt, làm cho thiên địa chấn động nổ vang"},{"text":"Trưởng lão Bổ Thiên các, sắc mặt đen vì sự việc; sai người mang tảng đá lên cho mọi người xem, cùng Hùng Phi bất đắc dĩ thu nhận một trăm môn đồ và chọn trúng nhóm Nhóc tỳ.","anchor":"hai người cộng lại thu nhận một trăm môn đồ","bridge":true,"khoang":"@c0106"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Nhận làm đệ tử","ghiChu":"Từng bị Nhóc tỳ chọc đến hộc máu."},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Trưởng lão cùng đoàn, đồng cảnh ngộ","ghiChu":"Cùng nhận trăm môn đồ."}]},"nguon":["@c0105","@c0103","@c0106"],"trangThai":"song","gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên Các","trangThai":"gan-bo"}],"aliases":["Trác Vân trưởng lão"]},{"id":"hung-phi","tabs":{"kinhLich":[{"text":"Cay đắng vì phải tuyển đám đông chất lượng thấp, thề tính sổ với thằng ranh quậy phá; nghe tiếng rống của Tiêu Thiên lại tưởng là kỳ tài ngút trời mà khen ngợi","anchor":"Nghe nói Bổ Thiên Các đặc biệt cho phép người ngoài 'xem lễ'.","bridge":true,"khoang":"@c0103"},{"text":"Trưởng lão đầu tiên suy đoán thủ phạm trộm Hắc Sát Liên là nhóc siêu quậy, ra lệnh bày thiên la địa võng phong tỏa chiến trường thứ hai truy tung; cùng Trác Vân nghi nhóc tỳ là ấu tể thái cổ hung thú, cuối cùng tuyên bố khảo nghiệm kết thúc.","anchor":"Chậm rãi tìm kiếm, chỉ cần tiến vào Bổ Thiên các, không tin là tìm không ra!","bridge":true,"khoang":"@c0105"},{"text":"Trưởng lão Bổ Thiên các dẫn đoàn nhập môn, mất mặt vì số người quá đông; khi tảng đá lộ chữ khiêu khích, trực tiếp phát lệnh truy nã Nhóc siêu quậy, treo thưởng đệ tử trọng yếu nhất; cuối cùng cùng Trác Vân bất đắc dĩ nhận trăm môn đồ, trong đó có chính Nhóc tỳ.","anchor":"Hùng Phi trưởng lão lại trực tiếp phát ra một lệnh truy nã","bridge":true,"khoang":"@c0106"},{"text":"Được lệnh dẫn nhóc tỳ xuống bàn bạc; khi nhóc tỳ phản kích chấn động cung điện, Hùng Phi chợt nhận ra nó chính là ‘thằng nhóc quỷ’ từng khiến hắn và Trác Vân khốn đốn, uất ức nhưng không dám cãi lão tiền bối; sau còn bắt gặp nó gặm trộm Tuyết Ngọc Sâm ở cửa cung điện.","anchor":"Ngươi... Ngươi chính là thằng nhóc quỷ kia?!","bridge":true,"khoang":"@c0113"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Nhận làm đệ tử","ghiChu":"Từng bị Nhóc tỳ chọc đến hộc máu; nay lại chọn trúng nhóm nó."},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Trưởng lão cùng đoàn, đồng cảnh ngộ","ghiChu":"Cùng nhận trăm môn đồ do phạm lỗi nặng."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"kẻ gây loạn","ghiChu":"Nhận ra nhóc tỳ là ‘thằng nhóc quỷ’ từng khiến hắn và Trác Vân khốn đốn."}]},"nguon":["@c0105","@c0103","@c0106","@c0113"],"trangThai":"song","gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên Các","trangThai":"gan-bo"}],"aliases":["Hùng Phi trưởng lão"]},{"id":"tieu-thien-nhan-kiet-tieu-toc","name":"Tiêu Thiên","cn":"","aliases":["Thiếu niên áo bạc"],"gioiTinh":"nam","theLuc":[{"ten":"Tiêu Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Nhân kiệt Tiêu Tộc, đạt 28 viên Bổ Thiên Thạch đứng đầu thí luyện; mang cục u to như sừng trên trán do bị đánh hai búa trong bóng tối, phong thái phi phàm bị hiểu nhầm là cậy tài khinh người.","vaiTro":"Thiếu niên thiên tài đệ nhất trong sự kiện thí luyện Bổ Thiên Các, quê Tiêu Tộc cách 30 vạn dặm.","tinhCach":[{"text":"Khí thế siêu trần thoát tục, phong thái phi phàm","chuong":"@c0104"},{"text":"Nội tâm căm hận, ngoài mặt phải nhẫn nhịn im lặng","chuong":"@c0104"}],"tabs":{"diem":[{"text":"Đạt thành tích 28 viên Bổ Thiên Thạch — đệ nhất nhân","chuong":"@c0104"},{"text":"Cục u to như sừng trên trán bị các trưởng lão gán thành thiên tướng","chuong":"@c0104"}],"kinhLich":[{"text":"Thiếu niên áo bạc quê Tiêu Tộc ném túi da thú xuống, bên trong 28 viên Bổ Thiên Thạch, được trưởng lão Bổ Thiên Các tuyên bố là biểu hiện đệ nhất nhân; cục u to như sừng trên trán bị hiểu nhầm thành thiên tướng, trong lòng căm hận vì bị đánh hai búa trong bóng tối.","anchor":"Những hai mươi tám viên Bổ Thiên Thạch, thật sự là kinh người.","bridge":true,"khoang":"@c0104"}],"tuViMoc":[],"nhanMach":[{"ten":"Hùng Phi","tag":"khac","quanHe":"Trưởng lão Bổ Thiên Các khen ngợi thành tích","ghiChu":"Hùng Phi dẫn đoàn tiền bối tới xem, tán thưởng Tiêu Thiên"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[{"ten":"Bổ Thiên Thạch","loai":"khoáng thạch","trangThai":"dang-co","moTa":"Gom được 28 viên trong thí luyện, đứng đầu thành tích, được coi là đệ nhất nhân.","nguon":"@c0104"}],"linhThao":[],"khac":[]}},"nguon":["@c0104"]},{"id":"nhoc-ty","name":"Thạch Hạo","cn":"","aliases":["Nhóc tỳ","Tiểu sư đệ","Nhóc siêu quậy"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"kinhLich":[{"text":"Được Bổ Thiên các hộ tống tới Bách Đoạn sơn, hồn nhiên tham ăn (đòi ăn thịt Bạch Hổ, thèm con Linh Tước); vào thành phát hiện nhiều thế lực lớn muốn bắt sống mình, suy đoán kẻ săn hơn phân nửa là gia tộc đã mất Xích Vũ Bảo Phiến, quyết tâm tiến vào Bách Đoạn sơn.","anchor":"Muốn bắt sống ta, hơn phân nửa là gia tộc mất đi Xích Vũ Bảo Phiến","bridge":true,"khoang":"@c0115"}],"nhanMach":[{"ten":"Đào Dã","tag":"su-mon","quanHe":"Được nguyên lão Bổ Thiên các hộ tống","ghiChu":"Dẫn đội bảo vệ tới Bách Đoạn sơn"}],"tuiDo":{"phapBao":[{"ten":"Xích Vũ Bảo Phiến","loai":"pháp bảo","trangThai":"dang-co","moTa":"Bảo Cụ trấn tộc của một gia tộc mà nhóc tỳ đang giữ; vì mất nó mà gia tộc kia muốn bắt sống nhóc tỳ.","nguon":"@c0115"}]}},"blurb":"Nhóc tỳ tham ăn trung tâm đoàn Bổ Thiên các, bị nhiều thế lực truy sát vì giữ Xích Vũ Bảo Phiến.","vaiTro":"Nhân vật trung tâm của đoàn, hồn nhiên tham ăn, bị nhiều thế lực truy lùng bắt sống.","tinhCach":[{"text":"Hồn nhiên, tham ăn","chuong":"@c0115"},{"text":"Gan lì, quyết tâm dấn thân nguy hiểm","chuong":"@c0115"}],"nguon":["@c0115"]},{"id":"chu-nhoc-than-thon","name":"Thạch Hạo","aliases":["Nhóc tỳ","Thằng bé hung tàn","Tiểu sư đệ Bổ Thiên các"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Truy đuổi Nhân Hùng một sừng bất thành, tiếc nuối tay gấu; triệu khay bạc ngăn thế lửa của Hỏa Vân Tước rồi dùng Ma Cầm thời Thái Cổ, tia chớp vàng và vầng trăng bạc đánh rụng thịt con chim; cùng nhóm Bổ Thiên các nấu ăn thịt Hỏa Vân Tước (huyết nhục bảo dược) khiến toàn thân phát sáng; nhảy vào cứu sư huynh khỏi cự thạch của kẻ ánh bạc; bị kẻ ánh bạc chiêu dụ làm chiến bộc nhưng chỉ nghĩ chuyện ăn được hay không, đen mặt đe dọa xử lý sinh vật kia.","anchor":"Nó bắt được cánh tay của sư huynh lôi mạnh ra ngoài","bridge":true,"khoang":"@c0118"}],"tuViMoc":[],"nhanMach":[{"ten":"Sinh vật hình người ánh bạc","tag":"doi-thu","quanHe":"Kẻ ánh bạc truy tìm theo tranh, chiêu dụ nhóc tỳ làm chiến bộc","ghiChu":"@c0118"}],"tuiDo":{"phapBao":[{"ten":"Khay bạc","loai":"Bảo Cụ","trangThai":"dang-co","moTa":"Pháp bảo hiện sau lưng cao gần bằng người, tinh khiết thần thánh như Thần Nguyệt, ngăn nham thạch và lửa.","nguon":"@c0118"}],"danDuoc":[{"ten":"Huyết nhục bảo dược (thịt Hỏa Vân Tước)","loai":"dược liệu","trangThai":"da-dung","moTa":"Thịt Hỏa Vân Tước nghi là đời sau Thái Cổ di chủng, ăn vào tăng tinh khí, cả người phát sáng.","nguon":"@c0118"}],"congPhap":[{"ten":"Ma Cầm thời Thái Cổ","loai":"thần thông","moTa":"Xòe năm ngón tay dệt ngân quang như tia chớp tạo thành con Ma Cầm bay đánh Hỏa Vân Tước.","nguon":"@c0118"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0118"],"blurb":"Tiểu tử Nhân tộc thân thể cường hãn, mê ăn thịt hung thú; săn đuổi Nhân Hùng, đánh lui Hỏa Vân Tước và cứu sư huynh khỏi cự thạch, rồi bị kẻ ánh bạc nhắm chiêu dụ."}]};
