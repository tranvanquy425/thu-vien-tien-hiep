/* characters q01 (153 mục) — R4.9 đổi tên thon-thien-tuoc → Thôn Thiên Tước - gop theo danh sach 2026-07-04 - gop kinhLich trung-chuong 2026-07-04 (V2-Steward 1moc-ghim) */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["the-gioi-hoan-my"]=window.__LIBQ["the-gioi-hoan-my"]||{};window.__LIBQ["the-gioi-hoan-my"]["q01"]=window.__LIBQ["the-gioi-hoan-my"]["q01"]||{};window.__LIBQ["the-gioi-hoan-my"]["q01"]["characters"]={"updatedAt":"2026-07-04","count":151,"chars":[{"id":"thach-van-phong","name":"Thạch Vân Phong","cn":"","aliases":["lão tộc trưởng","Lão tộc trưởng","Tộc trưởng","Tộc trưởng Thạch thôn","Ông tộc trưởng","tộc trưởng Thạch Thôn","tộc trưởng","Tộc trưởng Thạch Thôn","Lão tộc trưởng Thạch Thôn"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (@c0001)","trangThai":"song","blurb":"Thạch Vân Phong là lão tộc trưởng đứng đầu Thạch Thôn, chủ trì việc cầu khấn Tế Linh cùng các quyết định trọng đại của thôn. Thời trẻ lão từng cùng huynh đệ đồng môn tu Cốt Văn đi thí luyện, đạt tới Động Thiên Cảnh song về sau gián đoạn, và tận mắt chứng kiến Liễu Thần rơi xuống trong biển sét nơi Đại Hoang. Lão nhân hậu nuôi nấng, bồi dưỡng đứa trẻ mồ côi Thạch Hạo, dốc sức chỉ dạy Cốt Văn cùng tri thức Thái Cổ cho lũ trẻ trong thôn.","vaiTro":"Lão tộc trưởng đứng đầu Thạch Thôn, chủ trì cầu khấn Tế Linh và quyết định lớn của thôn","tinhCach":"Nhân hậu, tận tâm — đích thân chưng cất dược thảo, đun canh thịt bồi bổ cho Thạch Hạo; ổn trọng, thận trọng — cảnh báo không hành động tùy tiện, muốn củng cố căn cơ; giàu kinh nghiệm, uyên bác về Cốt Văn và truyền thuyết Thái Cổ; quả cảm — thời trẻ từng xông pha thế giới bên ngoài","tabs":{"diem":[{"text":"Lão tộc trưởng dẫn đầu thanh niên cầu khấn Tế Linh và chủ trì các quyết định trọng đại của Thạch Thôn","chuong":"@c0001"},{"text":"Thời trẻ từng cùng huynh đệ đồng môn tu Cốt Văn đi thí luyện, đạt Động Thiên Cảnh song về sau gián đoạn","chuong":"@c0079"},{"text":"Ngày đêm chưng cất dược thảo, chủ trì tắm thuốc trong hắc đỉnh và đun canh thịt bồi bổ cho Thạch Hạo","chuong":"@c0006"},{"text":"Giàu tri thức Cốt Văn và truyền thuyết Thái Cổ, đích thân giảng dạy cho lũ trẻ về Phù văn nguyên thủy","chuong":"@c0029"},{"text":"Thận trọng, ổn trọng — cảnh báo không hành động tùy tiện và muốn củng cố căn cơ khi Thạch Hạo tu hành quá nhanh","chuong":"@c0054"},{"text":"Mấy chục năm trước tận mắt chứng kiến Liễu Thần rơi xuống trong biển sét kèm cục xương trắng","chuong":"@c0063"}],"kinhLich":[{"text":"Khi đội săn chuẩn bị vào núi vì sắp hết thức ăn, Thạch Vân Phong dẫn đầu mấy chục thanh niên cầu khấn trước gốc liễu già, xin Tế Linh bảo hộ săn bắn bình an.; Trong cuộc bàn với các bậc trưởng lão, Thạch Vân Phong nhận định sâu trong Đại Hoang có thể xuất hiện thứ không tầm thường, thu hút các chủng tộc sót lại từ Thái Cổ kéo đến.; Sau bữa sáng, Thạch Vân Phong cùng các bô lão bàn về việc hồng hoang hung thú đêm đêm đi qua, cho rằng sâu trong Đạ…","anchor":"đời đời cúng tế phụng dưỡng người","bridge":true,"khoang":"@c0001"},{"text":"Lão kể hồi trẻ từng cùng hơn mười tộc nhân cường đại xông pha thế giới bên ngoài, chỉ hai người đẫm máu trở về và một người sớm chết, chỉ mình lão sống sót; lão giảng về Đại Hoang rộng lớn và các chủng tộc Thái Cổ, tay sờ miếng ngọc cốt kỳ dị trong ngực áo với ánh mắt khác thường.; Sau lễ tiễn đội săn vào núi, Thạch Vân Phong dẫn lũ trẻ về bãi cỏ đầu thôn giảng giải cốt văn — những ký tự hiển hóa bẩm sinh trên xương cốt của chủng tộc mạnh mẽ thờ…","anchor":"chỉ có hai người toàn thân đẫm máu trở về, một trong số đó không lâu sau thì chết, chỉ có một mình Thạch Vân Phong sống sót","bridge":true,"khoang":"@c0002"},{"text":"Giải thích Tế Linh là Linh mà bộ tộc cúng tế phụng dưỡng, bảo vệ thôn làng chấn nhiếp hung thú Đại Hoang; tiết lộ đời trước là một hòn đá lạ hấp thu quá nửa tinh huyết vật tế, đời nay là cây liễu già không đụng cống phẩm.; Dẫn già trẻ gái trai Thạch Thôn bước lên đàn tế cầu khấn cây liễu già phù hộ dân làng sau buổi săn bội thu; giải thích Tế Linh quý ở tấm lòng thành, thành kính đối đãi thì người mới phù hộ thôn.; Khi còn là thiếu niên, tận mắt…","anchor":"Tế Linh là Linh mà chúng ta cúng tế và phụng dưỡng, quý ở tấm lòng thành","bridge":true,"khoang":"@c0003"},{"text":"Thạch Vân Phong chủ trì việc tắm thuốc trong hắc đỉnh đặc biệt cho nhóc tỳ. Lão mở hai bình đ���c biệt, dùng cốt văn sáng trong lòng bàn tay vỗ tan con Tỳ Hưu dài bằng bàn tay và đập tan con tê giác hai đầu đỏ rực, cả hai hóa huyết dịch rơi vào đỉnh.; Lão tự tay cầm chùy Tử Kim đập đoạn quý nhất trên sừng voi sừng rồng, thêm xương móng vuốt Tỳ Hưu và sừng đỏ Hỏa Tê mài bột, trộn chân huyết bỏ vào nồi sữa thú cùng thảo dược kỳ dị nấu thành chất s…","anchor":"Một chiếc bình khác phóng ra một con tê giác hai đầu, đỏ rực như lửa","bridge":true,"khoang":"@c0004"},{"text":"Lo khởi điểm Thạch Hạo thấp, Thạch Vân Phong ngày đêm chưng cất dược thảo, dùng cốt văn chưng cất tinh hoa máu mãnh thú thành huyết dược để chuẩn bị tẩy lễ năm tuổi cho Thạch Hạo, mỗi con thú cuối cùng chỉ còn một giọt máu vào bình ngọc.; Tộc trưởng kể năm xưa cùng hơn mười huynh đệ đi xa đến các thế tộc môn đình, đổi máu và mạng đem về ít cốt thư; cuối cùng chỉ mình lão sống sót trở về, mang một thân ám tật, còn ẩn tình chưa kể.; Bàn về khoảng…","anchor":"mỗi con mãnh thú cuối cùng chỉ rơi ra một giọt chảy vào trong bình ngọc","bridge":true,"khoang":"@c0006"},{"text":"Nghe tin Thanh Lân Ưng làm loạn gần thôn và đám nhóc lâm nguy, tộc trưởng Thạch Vân Phong ra lệnh lấy hai cái Tổ Khí, dẫn nhóm đàn ông cường tráng nhất lên đường cứu, chỉ huy phòng thủ và tế bảo khí.; Hay tin Thanh Lân Ưng làm loạn gần thôn và đám nhóc lâm nguy, tộc trưởng Thạch Vân Phong ra lệnh lấy hai cái Tổ Khí, dẫn nhóm đàn ông cường tráng nhất lên đường cứu; ngoài động lệnh mọi người tụ lại phòng thủ để Thạch Lâm Hổ tế Tổ Khí.; Phát giác T…","anchor":"Mau đi lấy hai cái Tổ Khí lại đây, chúng ta cùng nhau đi","bridge":true,"khoang":"@c0009"},{"text":"Kể cho lũ trẻ về đại chiến hai năm trước khi sơn bảo sâu trong dãy núi thu hút chủng tộc Thái Cổ, lửa đỏ thiêu vỡ bầu trời cháy suốt mấy chục ngày, nghi có Hỏa Thú/Thần Tước.; Ra lệnh tế hai Tổ Khí rồi thừa cơ dẫn đoàn rút về thôn, lý do là cốt văn của Lâm Hổ và Phi Giao chưa đủ tinh thâm để phát huy uy lực thật của tổ khí; bản thân lão tự nhận có ám tật không hợp chiến đấu.; Tộc trưởng Thạch Vân Phong lệnh tế hai Tổ Khí rồi thừa cơ chỉ huy dân…","anchor":"đứng ở thôn ta cũng lờ mờ trông thấy lửa cháy không ngừng suốt mấy chục ngày liền","bridge":true,"khoang":"@c0010"},{"text":"Sau khi cành liễu già phất qua, một quả trứng tỏa hào quang và nổi lên vô số ký hiệu phức tạp. Thạch Vân Phong nhận định Sinh mệnh lạc ấn truyền thừa từ Thái Cổ Ma Cầm đã hồi phục, quả trứng xảy ra phản tổ, huyết mạch cao quý hơn cả bố mẹ, nếu nở sẽ vượt xa Thanh Lân Ưng.; Nhận định quả trứng bị cành liễu già phất qua đã xảy ra hiện tượng phản tổ, Sinh mệnh lạc ấn truyền thừa từ Thái Cổ Ma Cầm hồi phục, huyết mạch cao quý hơn cả bố mẹ; khẳng địn…","anchor":"Quả trứng này nếu nở ra khẳng định sẽ vượt xa Thanh Lân Ưng!","bridge":true,"khoang":"@c0011"},{"text":"Kích động khen Thạch Hạo thiên tư kinh người, dặn phù văn nguyên thủy là “Bí Cốt Bảo Thư” đừng tùy tiện thi triển, nói nó đã có thể phân cao thấp với đám Lâm Hổ.; Tộc trưởng kinh động khi Thạch Hạo thi triển bảo phù, xác nhận phù văn đó có thể xưng Bí Cốt Bảo Thư và dặn không đến lúc mấu chốt đừng tùy tiện thi triển.; Tộc trưởng cho Thạch Hạo ở cạnh ba chim non để nghiên cứu, kích động khen thiên tư kinh người, nhưng nhắc nhở Bí Cốt Bảo Thư cực…","anchor":"Phù văn nguyên thủy mà cháu vừa sử dụng tuyệt đối có thể xưng là","bridge":true,"khoang":"@c0012"},{"text":"Đích thân rút mũi tên khỏi người Thủ Sơn, dùng hào quang ký hiệu nơi lòng bàn tay cầm máu khép vết thương rồi lấy hai viên thuốc tím trong bình ngọc cứu chữa; sau đó phán đoán Bái Thôn sinh dị biến và ra lệnh phòng bị nghiêm ngặt.; Rút mũi tên khỏi người Thủ Sơn, lòng bàn tay lóe hào quang ký hiệu ấn xuống cầm máu khép vết thương, rồi lấy bình ngọc cho hai viên thuốc màu tím trị thương; phán đoán Bái Thôn có biến và ra lệnh phòng bị.","anchor":"lòng bàn tay lóe hào quang, ký hiệu sáng lên như sao","bridge":true,"khoang":"@c0013"},{"text":"Được người bẩm báo con Toan Nghê kinh khủng ở sâu trong dãy núi sắp chết già, đang rít gào giãy dụa; nếu rút được chân huyết và khắc Nguyên Thủy Bảo Phù trên bộ xương thì chẳng khác nào mở một kho báu động trời.; Tộc trưởng nhận bẩm báo về con Toan Nghê Thái Cổ Di Chủng sắp chết già rít gào trong núi, cân nhắc việc rút chân huyết và khắc Nguyên Thủy Bảo Phù trên bộ xương như mở kho báu động trời.; Được người trong tộc bẩm báo con Toan Nghê kinh…","anchor":"con Toan Nghê kinh khủng ở sâu trong dãy núi","bridge":true,"khoang":"@c0016"},{"text":"Tộc trưởng cảnh báo không được hành động tùy tiện, phải kiên nhẫn chờ; sau khi Toan Nghê ra ngoại vi chờ chết, ông quyết định dẫn cả tộc vào núi lấy di thể, cảnh báo sẽ có động vật và bộ lạc khác tranh cướp, rồi hét lệnh xông lên khi Toan Nghê chết trong sơn động.","anchor":"chúng ta phải bắt đầu hành động rồi","bridge":true,"khoang":"@c0017"},{"text":"Trên đường vào tranh di thể Toan Nghê, tộc trưởng bỗng kinh hãi cảm nhận luồng khí tức nguy hiểm của Hồng Hoang Cự Thú đang rình mò khu vực. Ông lệnh tộc nhân lập tức rút lui, không tiếp cận núi đá sụp đổ, khẳng định mạng người quan trọng hơn cả bảo vật — nhờ vậy Thạch Thôn thoát nạn quần thú bạo động.; Tộc trưởng cảm nhận luồng khí tức nguy hiểm của Hồng Hoang Cự Thú rình mò khu vực, lệnh tộc nhân rút lui không tranh trước di thể Toan Nghê, khẳ…","anchor":"Ông ấy cảm giác được một luồng khí tức nguy hiểm","bridge":true,"khoang":"@c0018"},{"text":"Lo lắng cho Thạch Hạo, tộc trưởng hô ngăn cậu đừng mạo hiểm nhưng không kịp, đành dặn cẩn thận rồi hạ lệnh rút cả Thạch Thôn về vì vùng núi tranh đoạt quá nguy hiểm.; Lo lắng can ngăn Thạch Hạo đừng mạo hiểm nhưng không kịp, đành dặn dò cẩn thận rồi hạ lệnh rút cả tộc Thạch Thôn về vì vùng núi tranh đoạt quá nguy hiểm.","anchor":"Nhóc tỳ, đừng đi mạo hiểm!","bridge":true,"khoang":"@c0019"},{"text":"Được nhắc lại qua ký ức Thạch Hạo: từ nhỏ tộc trưởng gia gia từng kể về Ly Hỏa Ngưu Ma — Hỏa Ngưu có thần uy kinh động Đại Hoang — nay quả thật hiện thân ở dãy núi ngoại vi.; Được nhắc tới qua ký ức: từ nhỏ lão tộc trưởng từng nghe người già kể về Hỏa Ngưu thần uy kinh động Đại Hoang sâu trong dãy núi, chính là Ly Hỏa Ngưu Ma nay vẫn còn sống. Hiện tại ông đang dần già đi theo năm tháng.","anchor":"Đây lẽ nào chính là Ly Hỏa Ngưu Ma mà tộc trưởng gia gia từng kể?","bridge":true,"khoang":"@c0020"},{"text":"Lão tộc trưởng Thạch Thôn dẫn Thạch Lâm Hổ, Thạch Phi Giao ập tới, quát Bái Lý Thanh phá quy củ Đại Hoang và đổ đan giải độc cứu Thanh Lân Ưng, mở màn cuộc hỗn chiến hai tộc.","anchor":"Người của Thạch Thôn đã tới rồi, dẫn đầu chính là lão tộc trưởng Thạch Vân Phong","bridge":true,"khoang":"@c0023"},{"text":"Thạch Vân Phong rắc thuốc giải độc cứu Thanh Lân Ưng, nhắc nhóc tỳ về nguồn gốc Bảo cụ do Tế linh ban; khi sinh vật kinh khủng của Bái thôn tới gần, ông gọi Lâm Hổ và Phi Giao chuẩn bị giết Tế linh.; Giải độc cho Thanh Lân Ưng, nhắc nhở nhóc tỳ về Bảo cụ (do Tế linh ban, còn Tế linh sống thì không cần Cốt văn cũng dùng được); khi sinh vật kinh khủng tới gần, gọi Lâm Hổ và Phi Giao chuẩn bị giết Tế linh nếu nó dám xuất hiện.; Giải độc cho Thanh L…","anchor":"Con mẹ nó, Tế linh Bái thôn dám xuất hiện thì chúng ta giết nó!!!","bridge":true,"khoang":"@c0024"},{"text":"Dùng hết các loại thuốc nhuyễn và lấy máu tươi từ sừng đỏ dị chủng Thái cổ cho Thanh Lân Ưng ăn để chữa thương.; Trổ hết thủ đoạn dùng thuốc nhuyễn và móc máu tươi từ sừng đỏ dị chủng Thái cổ cho Thanh Lân Ưng ăn để chữa thương; dùng mưu lừa Tế linh, ra lệnh dùng Tổ khí phá vây và toan giết sạch người Bái thôn để giữ bí mật Tổ khí.; Lạnh lùng tính kế giết sạch người Bái thôn từng thấy Tổ khí để giữ bí mật; đồng thời ra lệnh dùng Tổ khí phá vây k…","anchor":"trổ hết thủ đoạn dùng hết các loại thuốc nhuyễn hàng ngày chế được, lại càng lấy một cái sừng đỏ chót như ngọc của dị chủng Thái cổ móc ra một ít máu tươi cho hung cầm ăn.","bridge":true,"khoang":"@c0025"},{"text":"Sau khi Thạch Thôn thắng thú triều, tộc trưởng ra lệnh cứu người bị thương rồi sai Thạch Lâm Hổ và Thạch Phi Giao mang Tổ Khí đi chặn giết sạch Bái Thôn để bịt bí mật Tổ Khí; sau lại ngờ ngợ trước cảnh chim đỏ đấu chân vàng ở sâu Đại Hoang, sợ đại chiến Thái Cổ Di Chủng hai năm trước chưa kết thúc.","anchor":"giết sạch hết cho ta!","bridge":true,"khoang":"@c0027"},{"text":"Với vai tộc trưởng Thạch thôn, Thạch Vân Phong giảng cho Nhóc tỳ về Cốt văn — phù văn tộc Người mô phỏng Ấn ký nguyên thủy các chủng tộc — và lên kế hoạch dùng chân huyết Toan Nghê, sừng bảo, cánh tay Vược Ác Ma giúp Nhóc tỳ lột xác trước năm tuổi.","anchor":"Cốt văn là phù văn thần bí mà tộc Người bắt chước theo Ấn ký nguyên thủy","bridge":true,"khoang":"@c0028"},{"text":"Ngâm câu cổ về Thời đại Thái cổ, giảng cho Thạch Hạo nguồn gốc Phù văn nguyên thủy, tiên dân Thượng cổ, hung thú Thái cổ và sự yếu kém của Nhân tộc. Cuối buổi lão sờ khối xương trắng trước ngực rồi thân run rẩy một cơn, hé lộ ám thương cổ quái năm xưa cần Thiên địa bảo dược truyền thuyết mới chữa khỏi.; Giảng cho Thạch Hạo về Thời đại Thái cổ, nguồn gốc Cốt văn từ di cốt sinh vật chí cường, lịch sử Tiên dân khai phá phù văn; truyền mấy bộ Cốt th…","anchor":"thân thể bỗng run rẩy một cơn","bridge":true,"khoang":"@c0029"},{"text":"Dù Thạch Hạo chưa đủ năm tuổi, tộc trưởng vẫn quyết dùng bảo thể Toan Nghê, sừng Ly Hỏa Ngưu Ma và tay Ác Ma Viên Vương tẩy lễ cho nó ngay hôm nay, mong nó không kém các thiên tài của những bộ tộc lớn.; Tộc trưởng Thạch Thôn quyết định dùng bảo thể Toan Nghê, sừng Ly Hỏa Ngưu Ma và tay Ác Ma Viên Vương tẩy lễ cho Thạch Hạo ngay trong hôm nay, dù nó chưa đủ năm tuổi, để không kém thiên tài các bộ tộc lớn.; Nhận thấy Thạch Hạo đã dung nhập Cốt Văn…","anchor":"Tiến hành ngay trong hôm nay đi!","bridge":true,"khoang":"@c0030"},{"text":"Khi phát hiện ấn ký Bảo Thuật chí cường còn lưu trên xương trán Toan Nghê, Thạch Vân Phong kích động và hạ lệnh giữ bí mật tuyệt đối để tránh nguy cơ với các tộc lớn.; Đích thân chủ trì tẩy lễ cho Thạch Hạo: ném cổ dược, đập độc trùng thành phụ dược, dùng đao ngọc đào tim chí bảo Toan Nghê đặt vào đỉnh và đổ bảo huyết thay nước suối.; Thạch Vân Phong tự tay chủ trì tẩy lễ: đứng trước đỉnh đen tổ truyền ném cổ dược, đập vỡ đầu các độc trùng thành…","anchor":"Tộc trưởng, trên mảnh xương này có ký hiệu, có chảy một loại sức mạnh thần bí!","bridge":true,"khoang":"@c0031"},{"text":"Trong lúc chỉ đạo tẩy lễ, Thạch Vân Phong kinh dị nhận ra chiếc đỉnh đen tổ tiên Cổ khí tộc truyền lại thực là một bảo đỉnh chế thuốc ghê gớm; ông quyết định cho thêm chân huyết ba Di chủng Thái cổ và đại hỉ khi nhóc tỳ lột xác thành công.","anchor":"Tổ tiên truyền xuống cái báu vật này, tựa hồ thật sự là một toà dược đỉnh ghê gớm!","bridge":true,"khoang":"@c0032"},{"text":"Chủ trì tẩy lễ toàn Thạch thôn bằng bảo huyết Di chủng Thái cổ (pha loãng cho trẻ nhỏ); lấy khối xương giữa trán Toan Nghê có Phù văn nguyên thủy giao Thạch Hạo ghi nhớ, đồng thời răn dạy nó không được kiêu ngạo.","anchor":"Ngày này trong Thạch thôn tràn ngập tiếng gào khóc thảm thiết","bridge":true,"khoang":"@c0033"},{"text":"Xuất quan trước hạn sau khi Liễu Thần thi triển đại pháp cứu cả thôn thoát Đại Hoang, trấn an thôn dân đã tích đủ lương thực sống qua mấy tháng; khi thôn thoát không gian kỳ lạ tới vùng đất mới, ông nhận biết Long Tu Ngư và Ngũ Sắc Kê quý giá nên dặn không được bắt giết tùy tiện; biến sắc khi nghe nhóc tỳ nhắc ký ức lạ và hỏi cha mẹ.; Sau khi Liễu Thần thi triển vô thượng đại pháp cứu thôn khỏi thú triều, Thạch Vân Phong xuất quan trước hạn trấn…","anchor":"Liễu Thần thi triển vô thượng đại pháp, để chúng ta tránh được một tai họa lớn.","bridge":true,"khoang":"@c0050"},{"text":"Tiết lộ Thạch Thôn có lai lịch từ thời Thượng Cổ, là tổ địa của một bộ tộc cổ quốc hùng mạnh nhưng truyền thừa đã đứt đoạn; kể chuyện đôi vợ chồng trẻ từ cổ quốc mang nhóc tỳ tìm về, rồi trịnh trọng dặn cất kỹ chiếc lông đỏ tín vật của tước đỏ.; Kể cho nhóc tỳ nghe Thạch Thôn là tổ địa của một bộ tộc cổ quốc hùng mạnh từ thời Thượng Cổ, truyền thừa đã đứt đoạn; kể chuyện đôi vợ chồng trẻ từ cổ quốc mang nhóc tỳ tìm về tổ địa.; Lo lắng cho nhóc t…","anchor":"Bọn họ tới từ một cổ quốc, nói Thạch Thôn là tổ địa của bộ tộc bọn họ","bridge":true,"khoang":"@c0051"},{"text":"Lão tộc trưởng kể lại năm xưa cha mẹ Thạch Hạo chăm nó ở thôn mấy tháng rồi rời đi tìm Thánh dược trị tận gốc bệnh, không nỡ bỏ rơi nó; đồng thời cổ vũ lũ nam nhi phải tự cường, có lý tưởng cao cả để tái hiện huy hoàng cho tổ địa.; Kể lại chuyện năm xưa cha mẹ Thạch Hạo chăm nó mấy tháng rồi rời đi tìm Thánh dược trị tận gốc bệnh, không nỡ bỏ nó; cổ vũ lũ nam nhi Thạch thôn phải tự cường, có lý tưởng cao cả và tái hiện huy hoàng cho tổ địa; nói…","anchor":"bọn họ muốm tìm Thánh dược để trị tận gốc bệnh tình của cháu","bridge":true,"khoang":"@c0052"},{"text":"Tới xem sinh linh quả cầu vàng nhóc tỳ mang về, nâng chân nó thấy đỏ rực như than lửa; kể truyền thuyết Thái Cổ về hung thú tuyệt thế Chu Yếm giống khỉ chân đỏ đầu trắng, xuất hiện báo hiệu đại loạn; vì đầu nó không trắng nên kết luận đây là Thái Cổ Di Chủng huyết mạch không thuần khiết, tuy không thuần chủng nhưng vẫn đáng sợ.; Được đưa tới xem quả cầu vàng Thạch Hạo mang về, tộc trưởng nâng chân nó thấy đỏ rực như than lửa và kể truyền thuyết…","anchor":"Ở trong truyền thuyết thời Thái Cổ có một loại hung thú tuyệt thế được gọi là Chu Yêm","bridge":true,"khoang":"@c0053"},{"text":"Kinh ngạc trước tốc độ tu hành quá nhanh của Thạch Hạo, lão không cho phép cậu tiến cao thêm mà muốn củng cố căn cơ, chờ Liễu Thần tỉnh dậy chỉ dẫn.; Là trưởng bối lão tộc, Thạch Vân Phong không cho Thạch Hạo đột phá gấp, muốn củng cố căn cơ và chờ Liễu Thần tỉnh; kể lại quá trình tu hành của nhóc tỳ và hỏi ý kiến Liễu Thần.; Thạch Vân Phong kinh ngạc trước tốc độ tu hành quá nhanh của nhóc tỳ nên không cho phép cậu đột phá gấp, muốn củng cố căn…","anchor":"lão cảm thấy tốc độ tu hành của nhóc tỳ thật nhanh quá, mới có tí tuổi mà đã đi hết đường của một đời rất nhiều người.","bridge":true,"khoang":"@c0054"},{"text":"Tiết lộ mấy chục năm trước tận mắt chứng kiến Liễu Thần rơi xuống trong biển sét kèm cục xương trắng; nhiều lần cúng bái cây liễu nhưng không được đáp lại; trịnh trọng trao cục xương cho nhóc tỳ, dặn chỉ nhìn một cái rồi quay đi vì nhìn lâu sẽ phun máu.; Tiếc nuối truyền thừa Cốt Văn và Bảo Thuật của tộc đã mai một, tộc trưởng lấy từ ngực ra cục xương trắng khắc ký hiệu, kể mấy chục năm nó rơi cùng Liễu Thần trong biển sét; ông từng nhiều lần cầ…","anchor":"Ông có một cục xương, độ ảo diệu của ký hiệu phía trên làm cho người ta nhìn thấy một cái liền đủ để phun máu.","bridge":true,"khoang":"@c0063"},{"text":"Hỏi hộ nhóc tỳ cách tu hành; ngày ngày đun đỉnh canh thịt cùng thuốc cổ, Long Cân Xà, Long Tu Ngư bồi bổ cho nó; đích thân luyện đỉnh, khi nhỏ giọt máu vàng Chu Yếm vào thì đỉnh đen tỏa sáng, phát dị tượng chư thần ngâm xướng khiến cả thôn chấn động.; Hỏi hộ nhóc tỳ cách tu hành, run sợ trước yêu cầu khắc nghiệt của Nguyên Thủy Chân Giải. Ngày ngày đun đỉnh canh thịt Long Cân Xà kèm thuốc cổ bồi bổ cho nhóc tỳ. Phụ trách luyện đỉnh đen khi nhỏ m…","anchor":"Có từng hồi tiếng như chư thần ngâm xướng truyền ra","bridge":true,"khoang":"@c0064"},{"text":"Căn dặn Thạch Hạo cẩn thận vì nó đã hộc máu nhiều lần khi tham ngộ khối xương; cùng thôn nhân kịch liệt phản đối chuyến đi ba mươi vạn dặm tới tổ địa thứ hai vì đường xa nguy hiểm.","anchor":"Gia gia! Cháu muốn đi xa","bridge":true,"khoang":"@c0067"},{"text":"Vốn ổn trọng nhưng phát run vì mừng khi Thạch Hạo sống sót vượt thí luyện Đại Hoang tàn khốc trở về; cùng các tộc lão xúc động rơi nước mắt, coi đó là thần tích có thể tái hiện phong thái Thượng Cổ của Thạch thôn.","anchor":"Đây đã từng là thí luyện tàn khốc đối với thú con của các loài Thái Cổ Hung Thú","bridge":true,"khoang":"@c0077"},{"text":"Mừng khi đàn Độc Giác Thú thân thiết đám trẻ, an ủi Thanh Phong lúc trị thương; nghe tin thôn hơn hai trăm hộ bị đám cướp tàn sát vì Hắc Kim liền ho khan lo âu, hồi tưởng năm xưa ra ngoài lưu lạc chỉ mình sống sót trở về, tiết lộ đám người đáng sợ đến để tìm kiếm Chí Tôn Thần Tàng.","anchor":"「chúng đến vì... vì tìm kiếm Chí Tôn Thần Tàng」","bridge":true,"khoang":"@c0078"},{"text":"Lần đầu kể chuyện cũ: cùng huynh đệ đồng môn tu Cốt Văn đi thí luyện gặp động phủ Chí Tôn lộ ra do sấm sét, tìm được nhiều Cốt Thư nhưng không phá được cửa trung tâm; bị các thế lực truy sát, huynh đệ chết hết chỉ mình lão sống sót; Chí Tôn địa vật đổi sao dời chìm vào lòng đất; bị sương mù trong động phủ tổn thương thân thể khiến tu vi gián đoạn; nay hoạch định nén nhục 20 ngày, mang Tổ Khí ra quyết chiến với hung khấu và Tế Linh; ngăn thôn dân và nhóc tỳ liều mạng vì chênh lệch Động Thiên Cảnh quá lớn.","anchor":"năm đó toàn bộ hảo huynh đệ đều chết hết, chỉ có một mình lão còn sống","bridge":true,"khoang":"@c0079"},{"text":"Mừng rỡ đón Thạch Hạo trở về khiêng theo Giao Báo, hỏi và xác nhận nhóc tỳ đã đột phá thành cao thủ Động Thiên cảnh dù còn là một em bé.","anchor":"mới chỉ là một em bé thôi nhưng đã là cao thủ Động Thiên cảnh","bridge":true,"khoang":"@c0081"},{"text":"Cùng các tộc lão kinh hãi lo lắng khi nghe nhóc tỳ sắp tới nơi rèn luyện có thể chạm trán thú con Cùng Kỳ, Tất Phương, Tiêu Đồ và cả Trùng Đồng giả Thạch Nghị.","anchor":"Nơi có thể chiến đấu với thú con của các loài Cùng Kỳ, Tất Phương, Tiêu Đồ","bridge":true,"khoang":"@c0087"}],"tuViMoc":[{"chuong":"@c0001","canhGioi":"Phàm nhân","text":"Lão tộc trưởng phàm nhân, tinh khí thần sung túc nhờ rèn luyện và hít thở tinh khí đất trời.","importance":"minor"},{"chuong":"@c0079","canhGioi":"Động Thiên Cảnh (gián đoạn)","text":"Xác nhận năm xưa đã đạt Động Thiên Cảnh khi đi thí luyện, nhưng sau khi bị sương mù trong động phủ tổn thương thân thể và trọng thương lúc bị truy sát, tu vi từ đó không tiến thêm, dùng bí lực Cốt Văn rất khó.","importance":"major"}],"nhanMach":[{"ten":"Chú nhóc (chưa đặt tên)","tag":"an-nhan","quanHe":"Người được chăm sóc","ghiChu":"Nấu sữa thú nuôi chú nhóc mồ côi."},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc trưởng đời sau","ghiChu":"Thủ lĩnh đội săn, người kế vị Thạch Thôn."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Thủ lĩnh đội săn cùng thôn","ghiChu":"Thạch Lâm Hổ dẫn đội săn trở về báo tin cự thú và dấu chân khổng lồ cho tộc trưởng"},{"ten":"Chú nhóc (chưa đặt tên)","tag":"khac","quanHe":"Nuôi dưỡng chú nhóc mồ côi bằng sữa thú.","ghiChu":"Nấu sữa bách thú có dược thảo cho chú nhóc bú."},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc trưởng đương nhiệm và thủ lĩnh đội săn — tộc trưởng đời sau.","ghiChu":"Cùng quyết định việc đội săn vào núi."},{"ten":"Chú nhóc (chưa đặt tên)","tag":"khac","quanHe":"Người được nuôi dưỡng","ghiChu":"Nấu sữa bách thú nuôi đứa trẻ mồ côi"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Thủ lĩnh đội săn dưới quyền, tộc trưởng đời sau","ghiChu":"Cùng bàn việc vào núi săn"},{"ten":"Chú nhóc Thạch Thôn","tag":"an-nhan","quanHe":"Nuôi nấng đứa trẻ mồ côi bằng sữa bách thú","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc trưởng đời sau, thủ lĩnh đội săn dưới quyền","ghiChu":""},{"ten":"Chú nhóc Thạch Thôn","tag":"ho-hang","quanHe":"Cha nuôi","ghiChu":"Nhận nuôi nhóc tỳ (bú sữa bách thú, ăn chực trăm nhà), lấy làm đối tượng nghiên cứu cốt văn tốt nhất."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Thủ lĩnh đội săn của thôn","ghiChu":"Thạch Lâm Hổ về báo tin dấu chân khổng lồ; tộc trưởng dẫn mọi người đặt xác thú lên đài tế."},{"ten":"Chú nhóc Thạch Thôn","tag":"khac","quanHe":"Nấu sữa thú nuôi đứa trẻ mồ côi","ghiChu":"Chăm bẵm chú nhóc mất cha mẹ từ nửa tuổi."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Thủ lĩnh đội săn, tộc trưởng đời sau","ghiChu":"Cùng bàn việc vào núi săn."},{"ten":"Chú nhóc Thạch Thôn","tag":"ho-hang","quanHe":"Nhận nuôi nhóc tỳ (bú sữa bách thú, ăn chực trăm nhà), lấy làm đối tượng nghiên cứu cốt văn tốt nhất","ghiChu":"@c0002"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Tộc trưởng và thủ lĩnh đội săn cùng thôn","ghiChu":"@c0002"},{"ten":"Cậu thiếu niên thắc mắc","tag":"khac","quanHe":"Dân làng nhỏ tuổi","ghiChu":"Vỗ vai cậu nhóc nhẫn nại giải thích nhận được tâm ý là tốt rồi khi cậu thắc mắc về Tế Linh."},{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Chăm sóc, chế tắm thuốc và bảo dược đặc biệt bồi dưỡng nhóc tỳ","ghiChu":"Có chủ đích bồi dưỡng lâu dài"},{"ten":"Nhóc tỳ","tag":"an-nhan","quanHe":"Đứa trẻ được lão chăm sóc đặc biệt, nấu bảo dược riêng","ghiChu":"Đặt kỳ vọng đặc biệt vào nó"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc lão thuộc quyền, được lệnh tế Tổ Khí đẩy lui hung cầm"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nhóc tỳ trong thôn được cứu khỏi hung cầm"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ, quát vì phá quy củ Đại Hoang","ghiChu":"@c0023"},{"ten":"Thanh Lân Ưng","tag":"khac","quanHe":"Giải độc cứu hung cầm của tộc","ghiChu":"@c0023"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Cùng bàn chuyện Sơn bảo","ghiChu":"Đồng tộc Thạch thôn"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Truyền dạy Cốt văn cho Thạch Hạo, được nhóc tỳ hứa hái bảo dược chữa ám thương","ghiChu":"@c0029"},{"ten":"Chu Yếm (quả cầu vàng)","tag":"khac","quanHe":"Nhận diện sinh linh là di chủng Chu Yếm huyết mạch không thuần","ghiChu":"@c0053"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Ủng hộ và cảnh báo cậu về Bí Cốt Bảo Thư","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Dặn dò về Bí Cốt Bảo Thư","ghiChu":""},{"ten":"Nhóc tỳ","tag":"su-mon","quanHe":"Tộc trưởng chủ trì tẩy lễ cho nhóc tỳ","ghiChu":"@c0032"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Tộc lão Thạch Thôn cùng dẫn đội cứu viện","ghiChu":""},{"ten":"Thạch Thủ Sơn","tag":"khac","quanHe":"Tộc nhân được cứu chữa","ghiChu":"Rút tên và trị thương @c0013"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Quát trách Bái Lý Thanh phá quy củ Đại Hoang, giao chiến với Bái Thôn","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Giao khối xương Phù văn Toan Nghê cho ghi nhớ, răn dạy","ghiChu":"@c0033"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Tiết lộ thân thế cho nhóc tỳ","ghiChu":"@c0051"},{"ten":"Chu Yếm","tag":"khac","quanHe":"Người nhận diện","ghiChu":"Nhận ra thân phận di chủng Chu Yếm của sinh linh Thạch Hạo mang về (@c0053)"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng phe Thạch thôn, được gọi chuẩn bị đối phó Tế linh","ghiChu":"@c0024"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Cùng phe Thạch thôn, được gọi chuẩn bị đối phó Tế linh","ghiChu":"@c0024"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc nhân","ghiChu":"Sai đi truy sát Bái Thôn."},{"ten":"Thạch Phi Giao","tag":"su-mon","quanHe":"Tộc nhân","ghiChu":"Sai đi truy sát Bái Thôn."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Tộc lão dưới quyền, người tế Tổ Khí đẩy lui hung cầm","ghiChu":"@c0009"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Tộc trưởng nghe Nhóc tỳ kể chuyện","ghiChu":"Thưởng sữa thú cho Thạch Hạo vì chuyện Tiểu Hồng (@c0010)."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Quát tội tộc trưởng Bái Thôn phá quy củ, khai chiến","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Dẫn người cứu Thạch Hạo đang bị vây","ghiChu":"@c0023"},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Đổ đan giải độc cứu hung cầm Thạch Thôn","ghiChu":"@c0023"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng dẫn dân Thạch Thôn tới cứu viện","ghiChu":"@c0023"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Theo tới cứu viện","ghiChu":"@c0023"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Tộc trưởng Bái thôn đối địch","ghiChu":"@c0025"},{"ten":"Bái già","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Chỉ huy Thạch Thôn chống lại đàn cự thú và con Bái già."},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử/hậu bối được truyền dạy","ghiChu":"Dạy Thạch Hạo Cốt văn từ khi còn rất bé, xem như ‘chủng đạo’; kỳ vọng thành Chí tôn."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nghe Nhóc tỳ kể chuyện Tiểu Hồng, thưởng sữa thú","ghiChu":"@c0010"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Nuôi dưỡng, che chở, cho Thạch Hạo ở cạnh ba con chim non","ghiChu":"@c0012"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Quát tộc trưởng Bái Thôn phá quy củ Đại Hoang khi tới cứu","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đích thân dạy Cốt văn và lo việc lột xác cho Nhóc tỳ","ghiChu":"@c0028"},{"ten":"Thạch Lâm Hổ","tag":"dong-toc","quanHe":"Cùng bàn chuyện tranh Sơn bảo","ghiChu":"@c0028"},{"ten":"Nhóc tỳ","tag":"su-mon","quanHe":"Hướng dẫn Nhóc tỳ tu Cốt văn, chuẩn bị lột xác","ghiChu":"@c0028"},{"ten":"Nhóc tỳ","tag":"su-mon","quanHe":"Đích thân chỉ đạo tẩy lễ và quyết định thêm chân huyết ba Di chủng để nhóc tỳ lột xác.","ghiChu":"@c0032"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Tộc trưởng dìu dắt","ghiChu":"Răn dạy Thạch Hạo chớ kiêu ngạo, giao khối xương phù văn Toan Nghê cho ghi nhớ"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc nhân được sai mang Tổ Khí truy sát Bái Thôn","ghiChu":"@c0027"},{"ten":"Thạch Phi Giao","tag":"su-mon","quanHe":"Tộc nhân được sai mang Tổ Khí truy sát Bái Thôn","ghiChu":"@c0027"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nhóc tỳ trong thôn","ghiChu":"Che chở nhóc tỳ; tâm tình phức tạp không biết trả lời khi nhóc hỏi cha mẹ còn sống không"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Cây liễu đầu thôn cứu cả thôn","ghiChu":"Nhờ đại pháp của Liễu Thần mà cả thôn thoát tai họa lớn"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng là người chủ sự Thạch Thôn"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Cùng là người chủ sự Thạch Thôn"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Tộc trưởng che chở nhóc tỳ","ghiChu":"Lo lắng cho nhóc tỳ, kể cho cậu nghe lai lịch bản thân (@c0051)."},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Tộc trưởng đối với hậu bối trong thôn","ghiChu":"Kể lại thân thế cha mẹ và an ủi, cổ vũ Thạch Hạo tự cường."},{"ten":"Chu Yếm","tag":"khac","quanHe":"Sinh linh di chủng do ông nhận diện thân phận","ghiChu":"@c0053"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Nuôi dưỡng nhóc tỳ, biến sắc khi nhóc hỏi về cha mẹ","ghiChu":"@c0050"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng là chủ sự Thạch Thôn, cùng trấn an thôn dân","ghiChu":"@c0050"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Cùng là chủ sự Thạch Thôn, cùng ứng phó Độc Giác Thú","ghiChu":"@c0050"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Kể cho nhóc tỳ thân thế Thạch Thôn và cha mẹ","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Lão tộc trưởng Thạch thôn, kể cho Thạch Hạo thân thế cha mẹ","ghiChu":""},{"ten":"Chu Yếm","tag":"khac","quanHe":"Người nhận diện thân phận sinh linh","ghiChu":"Xác định nó là di chủng Chu Yếm."},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Không cho Thạch Hạo đột phá gấp, muốn củng cố căn cơ","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đứa trẻ trong tộc, được ông trao lại cục xương Nguyên Thủy Chân Giải","ghiChu":"@c0063"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Con cháu Thạch Thôn ông chăm lo","ghiChu":"Phản đối chuyến đi mài giũa của nó (@c0067)"},{"ten":"Nhị Mãnh","tag":"khac","quanHe":"Tộc nhân Thạch Thôn","ghiChu":"Cha Nhị Mãnh góp lời đòi lấy Tổ Khí liều mạng @c0079"},{"ten":"Tam gia","tag":"khac","quanHe":"Tộc lão Thạch Thôn","ghiChu":"Bị đầu lĩnh hung khấu đánh trọng thương khi tiến lên hỏi @c0079"},{"ten":"Đầu lĩnh hung khấu vết đao","tag":"doi-thu","quanHe":"Kẻ đe dọa Thạch Thôn","ghiChu":"Ra hạn 20 ngày nộp 500 cân hắc kim @c0079"}],"tuiDo":{}},"uuTien":80,"nguon":["@c0001","@c0002","@c0003","@c0004","@c0006","@c0009","@c0010","@c0011","@c0012","@c0013","@c0016","@c0017","@c0018","@c0019","@c0023","@c0024","@c0025","@c0026","@c0027","@c0028","@c0029","@c0031","@c0050","@c0051","@c0053","@c0054","@c0032","@c0033","@c0030","@c0052","@c0020","@c0063","@c0064","@c0067","@c0077","@c0078","@c0079","@c0081","@c0087"]},{"id":"thach-lam-ho","name":"Thạch Lâm Hổ","cn":"","aliases":["Lâm Hổ thúc","Lâm Hổ","Hổ ca","A Thúc","Thạch Lâm Hồ","Thạch Trung Hầu","#nguoi-trung-nien-day-tre"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (@c0001)","trangThai":"song","blurb":"Thạch Lâm Hổ là tráng sĩ thể chất cường tráng của Thạch Thôn, thủ lĩnh đội săn kiêm tộc trưởng kế vị, hai tay đạt tới năm sáu ngàn cân thần lực. Ông gánh việc kiếm thức ăn, nhiều lần dẫn người xông pha bảo vệ tộc trước Bái Thôn cùng các cường giả các tộc, cuối cùng đột phá vào Bàn Huyết cảnh. Ông cũng là bậc trưởng bối thân thiết, chỉ dạy đám trẻ rèn luyện và lo toan chuyện hôn nhân cho hậu bối.","vaiTro":"Thủ lĩnh đội săn kiêm tộc trưởng kế vị của Thạch Thôn","tinhCach":"Gánh vác sinh kế và trách nhiệm với thôn dân; can trường xông pha đầu trận bảo vệ tộc; nóng nảy quyết liệt trước kẻ thù; thân thiết chăm lo, chỉ dạy hậu bối","tabs":{"diem":[{"text":"Thủ lĩnh đội săn, hai tay đạt năm sáu ngàn cân thần lực nhưng nhiều năm chưa bước qua cảnh giới phàm nhân","chuong":"@c0054"},{"text":"Hòa xương cánh tay hung thú cổ đại (Tổ Khí) làm một với xương tay mình, thân cao vọt lên","chuong":"@c0010"},{"text":"Dẫn đội săn báo tin cha Bì Hầu bị Bái Thôn bắn tên, tố cáo Bái Thôn vượt giới cướp con mồi trước tộc trưởng","chuong":"@c0013"},{"text":"Dùng kiếm bản to gạt văng mũi tên bắn lén nhắm vào mắt Thanh Lân Ưng, mũi tên cắm sâu vào núi đá","chuong":"@c0025"},{"text":"Đứng ra đuổi toàn bộ cường giả các tộc chạy khỏi Thạch Thôn sau khi cây liễu đại thắng, kết thúc cuộc vây ép","chuong":"@c0040"},{"text":"Cùng Thạch Phi Giao đột phá vào Bàn Huyết cảnh","chuong":"@c0086"}],"kinhLich":[{"text":"Lâm Hổ báo trong núi có mấy dấu chân lớn hình dạng giống chân người dài gần trăm mét, khiến dân làng và bô lão thót dạ, càng chắc chắn sâu trong núi đã phát sinh chuyện bất thường.; Chiều tà, Thạch Lâm Hổ dẫn đội săn trở về, gần như ai cũng kéo theo một con mãnh thú khổng lồ mà không ai bị thương; lão giải thích mấy đêm trong núi có cự thú siêu cấp đi qua dẫm thương vô số thú rừng nên đoàn lần theo giết hung thú trọng thương, đồng thời báo tin t…","anchor":"Trong núi có mấy dấu chân lớn hình dạng giống chân người, nhưng thực sự quá lớn, dài đến gần trăm mét!","bridge":true,"khoang":"@c0002"},{"text":"Khi dân làng nghi Thạch Hạo dùng sức mạnh cốt văn thần bí để ném chiếc đỉnh ngàn cân, thủ lĩnh đội săn Thạch Lâm Hổ khẳng định đó là sức mạnh cơ thể thuần túy. Sau đó lão dẫn đội săn trở về và tặng Thạch Hạo túi Tương Quả.; Thủ lĩnh đội săn Thạch Lâm Hổ khẳng định việc Thạch Hạo nhấc đỉnh ngàn cân là sức mạnh cơ thể thuần túy, không phải cốt văn; sau khi đội săn về, ông hái Tương Quả tặng Thạch Hạo.; Thủ lĩnh đội săn khẳng định sức mạnh Thạch Hạ…","anchor":"đây là sức mạnh cơ thể thuần túy","bridge":true,"khoang":"@c0006"},{"text":"Được nhắc tới cùng tộc trưởng như người lớn có uy tín trong Thạch Thôn; bọn trẻ kỳ vọng sẽ được nhìn nhận khác sau vụ trộm trứng, nhưng bản thân chưa ra mặt.","anchor":"Thôn làng ở ngay phía trước không xa, mau xông lên!","bridge":true,"khoang":"@c0008"},{"text":"Thạch Lâm Hổ lấy cục xương tay hung thú, tay trái nổi cốt văn rực rỡ, ấn cục xương lên tay phát ra luồng hơi thở như vua vạn thú sống lại khiến Thanh Lân Ưng chấn động bay xa; cục xương dung hợp vào cánh tay trái, ngưng thành phù hiệu cổ xưa.; Trong đội cứu viện, Thạch Lâm Hổ lấy ra cục xương tay hung thú làm Tổ Khí, tay trái nổi cốt văn rồi ấn cục xương lên, phát luồng hơi thở như vua vạn thú sống lại khiến Thanh Lân Ưng chấn động bay lên xa; c…","anchor":"như thể vua của vạn thú sống lại khiến cho con hung cầm ở trên không chấn động","bridge":true,"khoang":"@c0009"},{"text":"Thạch Lâm Hổ hòa xương cánh tay hung thú cổ đại (Tổ Khí thứ nhất) làm một với xương tay mình, thân cao vọt từ hai mét lên ba mét, huyết khí kinh người, sát cánh cùng Thạch Phi Giao phóng sức mạnh tổ khí uy áp bức lui Thanh Lân Ưng.; Hòa xương cánh tay hung thú cổ đại (Tổ Khí thứ nhất của Thạch Thôn) vào xương tay mình, thân hình vọt cao khó tin, huyết khí kinh người, uy hiếp Thanh Lân Ưng.; Trong cuộc đối đầu Thanh Lân Ưng, Thạch Lâm Hổ dung hợp…","anchor":"Xương cánh tay hung thú cùng xương tay Thạch Lâm Hổ hòa làm một thể, ánh sáng chói lòa!","bridge":true,"khoang":"@c0010"},{"text":"Thạch Lâm Hổ hỏi tộc trưởng có nên giữ lại quả trứng phản tổ không, sau khi tộc quyết trả trứng thì giao việc ấp ba quả trứng cho đám nhóc trong thôn.","anchor":"Thôi, trả trứng lại cho con chim không lông kia đi.","bridge":true,"khoang":"@c0011"},{"text":"Dẫn đội săn về với thu hoạch ít, sắc mặt không tốt báo tin cha Bì Hầu bị người Bái Thôn bắn tên trúng lá phổi khi tranh đoạt mồi săn.; Đi trong đội săn, sắc mặt không tốt khi báo tin cha Bì Hầu bị người Bái Thôn bắn một mũi tên trúng lá phổi.; Thành viên đội săn trở về với sắc mặt không tốt, báo tin người Bái Thôn cách mấy chục dặm xâm nhập khu săn bắn tranh mồi, suýt bắn chết cha Bì Hầu.; Thành viên đội săn về thôn, báo tin cha của Bì Hầu bị ng…","anchor":"cha Bì Hầu bị thương không nhẹ, bị người ta bắn một mũi tên, bị thương lá phổi","bridge":true,"khoang":"@c0012"},{"text":"Sơ cứu vết thương cho Thủ Sơn rồi trong sân tộc trưởng tố cáo người Bái Thôn vượt giới cướp con Lục Túc Đà và ra tay tàn nhẫn; sau đó triệu tập vận chuyển xác dị thú và phẫn nộ khi bị Bái Thôn chặn cướp.; Xử lý sơ vết thương cho Thủ Sơn, tố cáo người Bái Thôn vượt giới cướp con Lục Túc Đà và ra tay tàn nhẫn; sau đó triệu tập tộc nhân đi vận chuyển bãi xác dị thú.; Sơ cứu vết thương Thủ Sơn bằng thuốc lâu năm cắn nát và thuốc chân huyết hung thú…","anchor":"thật sự là người của Bái Thôn gây chuyện, vượt giới tới chỗ chúng ta để cướp một con Lục Túc Đà","bridge":true,"khoang":"@c0013"},{"text":"Giáo dục Thạch Hạo là ra tay quá nhẹ rất nguy hiểm, ngồi lên người Bái Phong, nhắc tội Bái Thôn cướp con mồi và bắn tên. Ra lệnh dọa chặt đầu Bái Phong buộc Bái Thôn giao toàn bộ vũ khí mới thả người, dẫn phe thắng lợi trở về.; Hán tử cao gần hai mét rưỡi chỉ huy phe Thạch Thôn, nhắc tội cướp con mồi và chặn giết tộc nhân của Bái Thôn, ra lệnh dọa chặt đầu Bái Phong buộc đối phương giao toàn bộ vũ khí và rút khỏi vùng núi.","anchor":"chặt đầu thằng oắt này xuống trả lại Bái Thôn cho ta","bridge":true,"khoang":"@c0016"},{"text":"Sốt ruột dẫn đoàn Thạch Thôn xông sâu vào núi tranh di thể Toan Nghê. Khi hai con Bưu ập tới, ông cùng Thạch Phi Giao vung kiếm bản to nghênh chiến nhưng bị con Bưu thứ hai đánh bay vũ khí, rách bụng trọng thương; sau đó an ủi Thạch Hạo vừa giết thú lần đầu.; Sốt ruột dẫn đầu vào núi tranh di thể Toan Nghê; khi hai con Bưu tấn công, vung kiếm bản to xông tới nhưng bị đánh bay vũ khí, rách bụng trọng thương. Sau đó an ủi Thạch Hạo khi nó lần đầu…","anchor":"Lại là loài Bưu đáng sợ, hơn nữa còn những hai con!","bridge":true,"khoang":"@c0018"},{"text":"A thúc của Thạch Thôn nhắc nhở Thạch Hạo cẩn thận trước khi cậu cưỡi Thanh Lân Ưng lao vào vùng núi tranh đoạt.","anchor":"Thạch Hạo vèo một tiếng nhảy lên cao năm sáu mét, hạ xuống lưng chim rộng rãi","bridge":true,"khoang":"@c0019"},{"chuong":"@c0023","importance":"bridge","khoang":"@c0023","text":"Theo Thạch Vân Phong tới cứu viện, rống chửi Bái Thôn tạp chủng rồi lao vào giao chiến quyết liệt.","anchor":"Bọn tạp chủng Bái Thôn, chúng mày đi chết cả đi!"},{"text":"Dùng kiếm bản to gạt văng mũi tên bắn lén (lực 5-6 ngàn cân) nhắm vào mắt Thanh Lân Ưng, mũi tên cắm vào núi đá; sau còn ném mâu sắt cứu người trước đám sói.; Khi Bái thôn bắn lén mũi tên (lực 5-6 ngàn cân) nhắm mắt Thanh Lân Ưng, Thạch Lâm Hổ dùng kiếm bản to gạt văng; còn ném mâu sắt cắm vào sói to, cầm xương cánh tay Tổ khí.","anchor":"mục tiêu chính con mắt Thanh Lân Ưng, sắc bén kinh người","bridge":true,"khoang":"@c0025"},{"text":"Cùng người trong tộc cười vui trước biểu hiện đột phá của Thạch Hạo, ví nhóc tỳ tương lai có thể là Chí tôn của Thạch thôn.; Cùng cả thôn vui mừng trước việc Thạch Hạo đột phá cảnh giới Thay máu lập kỷ lục.","anchor":"Thạch thôn chúng ta tương lai có lẽ sẽ xuất hiện một Chí tôn","bridge":true,"khoang":"@c0029"},{"text":"Thạch Lâm Hổ cùng thanh niên trai tráng trong thôn chặt Hắc Giao Mộc làm nguồn lửa, rồi dùng thần lực năm sáu nghìn cân khó khăn chém xác Toan Nghê theo vết nứt để lấy chân huyết chuẩn bị cho tẩy lễ của Thạch Hạo.; Cùng thanh niên trai tráng Thạch Thôn chặt Hắc Giao Mộc làm nguồn lửa, rồi khó khăn chém xác Toan Nghê theo vết nứt để lấy chân huyết chuẩn bị tẩy lễ.; Dẫn thanh niên trai tráng Thạch Thôn chặt Hắc Giao Mộc làm nguồn lửa nấu chân huyế…","anchor":"Vì tẩy lễ cho Thạch Hạo, trong thôn đã tiến hành các loại chuẩn bị.","bridge":true,"khoang":"@c0031"},{"text":"Thạch Lâm Hổ đổ chân huyết Thái cổ từ sừng Bò ma Ly Hỏa và chất lỏng đen từ cánh tay Vượn Ác ma vào đỉnh cho lần luyện thứ hai; sau đó đùa nhóc tỳ khi trưởng thành phải săn một con Chân Hống cho hắn.","anchor":"ba loại chân huyết hỗn hợp ở chung một chỗ","bridge":true,"khoang":"@c0032"},{"text":"Được bọn trẻ Thạch Thôn nhắc tới: từng xin hai Tổ Khí từ tộc trưởng để dám truy đuổi Độc Giác Thú như điên ở Đại Hoang.","anchor":"Bọn nó mấy ngày nay vừa ăn thịt Toan Nghê, vừa dùng chân huyết tẩy lễ.","bridge":true,"khoang":"@c0034"},{"text":"Bị kinh động dẫn đám người Thạch Thôn xông đến khi ba con chim non bị Giao Bằng bắn, nín giận theo hiệu của Thạch Hạo.","anchor":"muốn cướp bảo cốt Toan Nghê của Thạch Thôn, nhưng khổ nỗi lại không có cớ","bridge":true,"khoang":"@c0037"},{"text":"Cùng người Thạch Thôn phẫn nộ trước sự khinh người của cường giả đòi bảo cốt Toan Nghê, thề thà làm ngọc nát còn hơn làm ngói lành, quyết huyết chiến đến giọt máu cuối cùng.; Phẫn nộ trước sự khinh người của các cường giả La Phù, thề quyết huyết chiến đến giọt máu cuối cùng để giữ bảo cốt.; Người Thạch Thôn thề thà làm ngọc nát còn hơn làm ngói lành, quyết huyết chiến đến cùng chống các cường giả đòi bảo cốt Toan Nghê.; Cùng người Thạch Thôn phẫ…","anchor":"Thà làm ngọc nát còn hơn làm ngói lành","bridge":true,"khoang":"@c0039"},{"text":"Sau khi cây liễu đại thắng, đứng ra đuổi toàn bộ cường giả các tộc chạy khỏi Thạch thôn, kết thúc cuộc vây ép.; Sau khi cây liễu tàn sát các cường giả, Thạch Lâm Hổ đứng ra đuổi đám cường giả các tộc đại bại chạy khỏi Thạch thôn.; Sau khi Liễu Thần phế Giao Thương và thủ lĩnh Kim Lang, Thạch Lâm Hổ đứng ra đuổi các cường giả các tộc rời khỏi Thạch thôn; cả đám chạy bắn khói ra khỏi thôn.","anchor":"Một đám lại một đám chạy bắn khói ra khỏi Thạch thôn","bridge":true,"khoang":"@c0040"},{"text":"Cùng Thạch Phi Giao hành động ăn ý, Thạch Lâm Hổ đã nhạy bén phát giác Thạch Thôn bị bốn tộc bao vây từ trước khi tiếng báo động vang lên.; Cùng Thạch Phi Giao sát cánh, đã nhạy bén phát giác việc Thạch Thôn bị bốn tộc bao vây từ trước khi nhóc tỳ báo động.; Thạch Lâm Hổ sát cánh ăn ý cùng Thạch Phi Giao, cả hai đã nhạy bén phát giác việc Thạch Thôn bị bốn tộc bao vây từ trước khi nhóc tỳ hô hoán.","anchor":"Thạch Lâm Hổ, Thạch Phi Giao cũng đã phát giác từ lúc trước rồi.","bridge":true,"khoang":"@c0043"},{"text":"Người Thạch Thôn, đau lòng nhận ra Độc Giác Mã một ngày đi vạn dặm bị cây liễu đâm xuyên cuốn về làm thức ăn.; Đau lòng nhận ra Độc Giác Mã một ngày đi vạn dặm bị cây liễu đâm xuyên thu về Thạch Thôn cùng mấy trăm tọa kỵ khác của các tộc.","anchor":"đều bị đâm xuyên ở trên cành liễu rồi cuốn về Thạch Thôn","bridge":true,"khoang":"@c0045"},{"text":"Cùng Thạch Phi Giao nói nhỏ, hai người lo lắng bất an trước trận đại chiến của các tồn tại chí cao và không biết trận đại họa sẽ kéo dài bao lâu.; Thạch Lâm Hổ cùng Thạch Phi Giao nói nhỏ, hai người lo lắng bất an về trận đại chiến chấn động và sức mạnh thần bí khóa sơn hà đang uy hiếp Thạch thôn.","anchor":"Thạch Phi Giao và Thạch Lâm Hổ nói nhỏ, hai người lo lắng bất an không biết trận đại họa này sẽ kéo dài bao lâu","bridge":true,"khoang":"@c0047"},{"text":"Là người chủ sự Thạch Thôn, cùng tộc trưởng trấn an thôn dân ở vùng đất mới; khi nghe nhóc tỳ nhắc ký ức mơ hồ, ông cùng các chủ sự biến sắc không còn nhìn chằm chằm Độc Giác Thú nữa.; Cùng tộc trưởng Thạch Vân Phong và Thạch Phi Giao trấn an thôn dân ở vùng đất mới; biến sắc khi nhóc tỳ nhắc ký ức mơ hồ về vùng đất và quý tộc đi săn.","anchor":"kể cả là mấy người Thạch Lâm Hổ và Thạch Phi Giao cũng biến sắc","bridge":true,"khoang":"@c0050"},{"text":"Cùng thôn nhân sợ hãi trước uy thế của tước đỏ, lông tóc dựng đứng, không dám động đậy.","anchor":"từ xa một con chim nhỏ đỏ như lửa đại chiến ở trong Thương Mãng Sơn Mạch","bridge":true,"khoang":"@c0051"},{"text":"Đề nghị và ra lệnh cho Thạch Hạo cưỡi Thanh Lân Ưng đi dò xét vị trí định cư của thôn.","anchor":"Cương vực một trăm ngàn dặm đã thành một vùng tử địa","bridge":true,"khoang":"@c0052"},{"text":"Tráng sĩ mạnh mẽ của Thạch thôn, hai tay đạt tới năm sáu ngàn cân thần lực nhưng vẫn chưa bước qua được cảnh giới Bàn Huyết — dùng làm mốc đối chiếu thực lực vượt trội của Thạch Hạo.","anchor":"hai tay bọn họ cũng đã mạnh đến năm sáu ngàn cân thần lực.","bridge":true,"khoang":"@c0054"},{"text":"Cùng các tộc lão thán phục lô bảo dược mới luyện; khẳng định có đỉnh cổ tổ truyền thì bảo dược Thạch Thôn không thua cổ quốc, sai thôn nhân lục tìm đồ cổ tổ truyền để bồi dưỡng Thạch Hạo.","anchor":"Đây đã coi là một lô thuốc quý rồi!","bridge":true,"khoang":"@c0065"},{"text":"Thanh niên trưởng thành Thạch Thôn, cùng nhóm Thạch Phi Giao đang lên kế hoạch bắt Độc Giác Thú nhưng không dám lỗ mãng ra tay.","anchor":"Kể cả là đám thanh niên trưởng thành như Thạch Lâm Hổ hay Thạch Phi Giao cũng vẫn đang lên kế hoạch.","bridge":true,"khoang":"@c0068"},{"text":"Cùng Thạch Phi Giao dẫn thôn nhân giương Long Giác Cung nhắm về phía hung khấu, thề chết bảo vệ thôn; nhìn con Tế Linh Xuyên Sơn Giáp dài mấy chục mét thì cảm thấy vô lực; trước khi hung khấu rời đi bị roi Phù Văn quất làm da thịt mặt rách toác chảy máu, phẫn uất đòi đánh trả.","anchor":"Thôn nhân lo lắng, đám người Thạch Lâm Hổ, Thạch Phi Giao đứng đầu thôn đều giương Long Giác Cung nhắm kĩ ở phương xa","bridge":true,"khoang":"@c0079"},{"text":"Mặt mang vết thương do roi ngựa đánh vẫn đang chảy máu, cắn răng chửi bọn Bái Thôn là lũ cướp đáng chết sau vụ tập kích làm nhục cả tộc.","anchor":"Thạch Lâm Hổ cắn răng nói, hắn lấy tay quệt máu dính ở trên mặt","bridge":true,"khoang":"@c0080"},{"text":"Thân thiết như A thúc của nhóc tỳ, đề nghị cậu đính hôn với con gái Hổ Nữu và giục Đại Tráng, Nhị Mãnh, Bì Hầu thành hôn; sau nửa năm ăn Tế Linh và tích lũy Cốt Văn, cùng Thạch Phi Giao thăng cấp vào Bàn Huyết cảnh với tu vi thâm hậu.","anchor":"Thạch Lâm Hổ và Thạch Phi Giao cùng thăng cấp vào Bàn Huyết cảnh","bridge":true,"khoang":"@c0086"},{"text":"Người trung niên chỉ dạy đám trẻ rèn luyện thân thể dưới mây sớm, giảng rằng lúc mặt trời mới mọc sinh khí mạnh nhất giúp bồi đắp sinh cơ để có vốn sinh tồn trong mãng sơn.; Đứng chỉ điểm và giảng cho lũ trẻ rằng lúc mặt trời mới mọc sinh khí mạnh nhất, rèn luyện dưới mây sớm giúp bồi đắp sinh cơ, cường gân tráng cốt.; Buổi sáng, ông chỉ điểm đám trẻ trên khoảng đất trống trước thôn, giảng rằng lúc mặt trời mới mọc sinh khí mạnh nhất, rèn luyện……","anchor":"Lúc mặt trời mới mọc là lúc vạn vật khởi đầu, sinh khí mạnh nhất","bridge":true,"khoang":"@c0001"}],"tuViMoc":[{"chuong":"@c0001","canhGioi":"Phàm nhân","text":"Tráng sĩ phàm nhân thể chất cường tráng, mang đại kiếm nặng hơn ba trăm cân.","importance":"minor"},{"chuong":"@c0086","canhGioi":"Bàn Huyết cảnh","text":"Cùng Thạch Phi Giao đột phá vào Bàn Huyết cảnh, cảnh giới không thấp, tu vi thâm hậu.","importance":"major"},{"chuong":"@c0001","canhGioi":"Phàm nhân","text":"Người trung niên phàm nhân thể chất cường tráng của Thạch Thôn.","importance":"minor"}],"nhanMach":[{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Lão tộc trưởng","ghiChu":"Bậc đứng đầu thôn, người tiền nhiệm."},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Tộc trưởng Thạch Thôn","ghiChu":"Báo tin cự thú và dấu chân khổng lồ cho tộc trưởng"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng đương nhiệm — Thạch Lâm Hổ là tộc trưởng đời sau.","ghiChu":"Cùng quyết định việc đội săn vào núi."},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Lão tộc trưởng dẫn dắt; ông là tộc trưởng đời sau kế nhiệm","ghiChu":""},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Tộc trưởng của thôn","ghiChu":"Báo tin cho tộc trưởng; tộc trưởng dẫn mọi người đặt xác thú lên đài tế."},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Lão tộc trưởng Thạch Thôn","ghiChu":"Cùng bàn việc vào núi săn."},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Tặng Thạch Hạo túi Tương Quả","ghiChu":"@c0006"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng ra lệnh cứu viện, cùng chỉ huy phòng thủ và tế Tổ Khí"},{"ten":"Bì Hầu","tag":"khac","quanHe":"Nhớ ra bọn Bì Hầu từng thò đầu nghe chuyện, lần ra manh mối đám nhóc"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Địch thủ đấu tiễn ngang tài"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Ngồi lên người, dọa chặt đầu để ép bồi thường","ghiChu":""},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến Bái Thôn","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Đồng tộc Thạch Thôn","ghiChu":"Ném nhóc tỳ lên trời để triệu Bệ Ngạn đánh con Bái (@c0026)"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bắn tên trúng lưng tộc trưởng Bái Thôn trong cuộc truy sát."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Cùng Thạch Thôn quyết chiến bảo vệ bảo cốt","ghiChu":"@c0039"},{"ten":"Nhóc tỳ","tag":"ho-hang","quanHe":"Người trong Thạch thôn, hô nhóc tỳ lớn lên phải săn Chân Hống","ghiChu":"@c0032"},{"ten":"Bì Hầu","tag":"dong-minh","quanHe":"Đồng thôn, báo tin cha Bì Hầu bị thương","ghiChu":"@c0012"},{"ten":"Nhóc tỳ","tag":"ho-hang","quanHe":"Đứa nhỏ trong thôn được ước hẹn săn Chân Hống cho mình","ghiChu":"@c0032"},{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Người thôn Thạch thôn","ghiChu":"Hẹn nhóc tỳ lớn lên săn Chân Hống cho mình."},{"ten":"Nhóc tỳ","tag":"su-mon","quanHe":"Người thôn giúp nhóc tỳ lột xác, đặt kỳ vọng săn Chân Hống","ghiChu":"@c0032"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Nhóc Thạch Thôn được cứu","ghiChu":""},{"ten":"Thạch Thủ Sơn","tag":"dong-minh","quanHe":"Tộc nhân sơ cứu","ghiChu":"Xử lý vết thương @c0013"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Đấu tiễn ngang tài","ghiChu":"Đấu tên mười mấy hiệp không phân thắng bại (@c0014)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Nín giận theo hiệu Thạch Hạo @c0037"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người Thạch Thôn cùng bảo vệ làng","ghiChu":"Cùng dân làng quyết chiến bảo vệ nhóc tỳ và bảo cốt @c0039"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Cùng thôn","ghiChu":"Khích lệ rồi cõng Thạch Hạo kiệt sức (@c0027)"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Bắn tên trúng lưng Bái Lý Thanh."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Tộc nhân","ghiChu":"Khích lệ rồi cõng Thạch Hạo khi kiệt sức."},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Đồng chiến binh Thạch Thôn","ghiChu":"Sát cánh cùng tế tổ khí chống Thanh Lân Ưng (@c0010)."},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đấu tiễn ngang tài, hai bên bắn liên tiếp mười mấy mũi tên va chạm."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Dọa chặt đầu Bái Phong để ép Bái Thôn bồi thường","ghiChu":"@c0016"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Giáo dục Thạch Hạo về chiến đấu","ghiChu":"@c0016"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Theo tộc trưởng tới cứu viện","ghiChu":"@c0023"},{"ten":"Bái Thôn","tag":"doi-thu","quanHe":"Giao chiến, chửi mắng Bái Thôn","ghiChu":"@c0023"},{"ten":"Bái già","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị con Bái già đánh du kích, ngưng Nguyên Thủy Bảo Phù ép đến kiệt sức."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ bị Lâm Hổ bắn trúng","ghiChu":"Bắn tên trúng lưng tộc trưởng Bái Thôn trong cuộc truy sát, dọn đường cho Thạch Phi Giao chém đầu."},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Đàn em được Lâm Hổ cõng","ghiChu":"Khích lệ Thạch Hạo giết Bái Sơn rồi cõng cậu khi cậu kiệt sức ngất đi."},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Đấu tiễn ngang tài, mỗi bên bắn mười mấy mũi tên không phân cao thấp; suýt bị bắn xuyên cổ","ghiChu":"@c0014"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Che chở nhóc tỳ, phá ba trong bốn mũi tên khi thiếu niên Bái Thôn bắn Thạch Hạo","ghiChu":"@c0014"},{"ten":"Con Bái dữ","tag":"doi-thu","quanHe":"Kẻ địch điều động đàn cự thú vây đánh Thạch Thôn","ghiChu":"Đối đầu trực diện, khiến Bái già thổ huyết vì kém Cốt Văn @c0026"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Tộc nhân Thạch Thôn","ghiChu":"Khích lệ rồi cõng Thạch Hạo về khi cậu kiệt sức ngất đi (@c0027)."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Tộc trưởng địch bị Lâm Hổ bắn trúng","ghiChu":"Bắn tên trúng lưng Bái Lý Thanh @c0027"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng chỉ huy đội cứu viện","ghiChu":"@c0009"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Đồng tộc cùng chiến đấu","ghiChu":"Sát cánh dùng Tổ Khí chống Thanh Lân Ưng @c0010"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Đối thủ đấu tiễn ngang tài, suýt bị bắn lén xuyên cổ họng","ghiChu":"@c0014"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Dọa chặt đầu để ép Bái Thôn bồi thường","ghiChu":"@c0016"},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Theo lão tộc trưởng dẫn quân cứu viện Thạch Hạo","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đàn em cùng thôn","ghiChu":"Khích lệ rồi cõng Thạch Hạo kiệt sức về sau khi cậu giết Bái Sơn (@c0027)"},{"ten":"Thạch Vân Phong","tag":"dong-toc","quanHe":"Cùng bàn chuyện tranh Sơn bảo","ghiChu":"@c0028"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Khích lệ rồi cõng Thạch Hạo kiệt sức về sau khi cậu ngất","ghiChu":"@c0027"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Bắn tên trúng lưng tộc trưởng Bái Thôn trong lúc truy sát","ghiChu":"@c0027"},{"ten":"Nhóc tỳ","tag":"an-nhan","quanHe":"Góp chân huyết Di chủng giúp nhóc tỳ hoàn tất tẩy lễ; trêu nhóc tỳ săn Chân Hống cho mình.","ghiChu":"@c0032"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng tộc, khích lệ rồi cõng Thạch Hạo về khi cậu kiệt sức ngất đi","ghiChu":"@c0027"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng thôn","ghiChu":"Theo hiệu của Thạch Hạo nín giận (@c0037)"},{"ten":"Liễu Thần","tag":"dong-minh","quanHe":"Tế linh trấn thôn","ghiChu":"Liễu Thần dọn sạch cường giả các tộc, Thạch Lâm Hổ tiếp lời đuổi đi (@c0040)"},{"ten":"Thạch Phi Giao","tag":"ban-be","quanHe":"Bạn thân cùng thôn, luôn sát cánh","ghiChu":"Cùng lo lắng bất an về đại họa (@c0047)"},{"ten":"Liễu Thần","tag":"dong-minh","quanHe":"Người Thạch thôn được cây liễu bảo hộ","ghiChu":"@c0040"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Cùng thôn, hành động ăn ý sát cánh","ghiChu":"Cùng phát giác vòng vây bốn tộc @c0043"},{"ten":"Thạch Phi Giao","tag":"ban-be","quanHe":"Thân thiết, luôn sát cánh"},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Cùng là chủ sự / tộc trưởng Thạch Thôn","ghiChu":"@c0050"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Cùng chủ sự Thạch Thôn","ghiChu":"@c0050"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Người Thạch thôn thân thiết, luôn sát cánh","ghiChu":"Cùng nói nhỏ, lo lắng bất an về đại họa (@c0047)"},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Đồng đội đứng đầu thôn","ghiChu":"Cùng giương Long Giác Cung phòng thủ, cùng bị đánh rách mặt @c0079"},{"ten":"Đầu lĩnh hung khấu vết đao","tag":"doi-thu","quanHe":"Kẻ quất roi Phù Văn làm rách mặt @c0079"}],"tuiDo":{"phapBao":[{"ten":"Đại kiếm kim loại đen","loai":"vũ khí","trangThai":"dang-co","moTa":"Đại kiếm rèn từ kim loại màu đen nặng hơn ba trăm cân, đeo sau lưng.","nguon":"@c0001"}]}},"uuTien":70,"nguon":["@c0001","@c0002","@c0006","@c0008","@c0009","@c0010","@c0011","@c0012","@c0013","@c0014","@c0016","@c0017","@c0018","@c0019","@c0023","@c0025","@c0026","@c0027","@c0028","@c0029","@c0031","@c0039","@c0040","@c0043","@c0045","@c0047","@c0050","@c0032","@c0033","@c0037","@c0034","@c0036","@c0051","@c0052","@c0054","@c0065","@c0068","@c0079","@c0080","@c0086"]},{"id":"cac-bo-lao-thach-thon","name":"Nhóm bô lão Thạch Thôn","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nhóm bô lão Thạch Thôn phụ giúp chủ trì tục tắm thuốc và bàn luận về thể chất nhóc tỳ.","vaiTro":"Trưởng bối phụ tr�� trong Thạch Thôn.","tinhCach":[{"text":"Lo toan, tiết kiệm chân huyết quý, có kinh nghiệm chế thuốc","chuong":"@c0004"}],"tabs":{"diem":[],"kinhLich":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0004"],"aliases":["Tiểu Thạch Hạo","Nhóc tỳ (chủ nhóc Thạch Thôn)"]},{"id":"anh-ba","name":"Anh Ba","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thanh niên trong Thạch Thôn được nhắc tới như tấm gương dùng cối đá rèn luyện khí lực.","vaiTro":"Nhân vật phụ được nhắc tên.","tinhCach":[{"text":"Chăm rèn luyện khí lực","chuong":"@c0004"}],"tabs":{"diem":[],"kinhLich":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0004"]},{"id":"thach-manh","name":"Thạch Mãnh","cn":"","aliases":["Nhị Mãnh","nhóc thò lò mũi xanh","#cau-thieu-nien-thac-mac","#thach-manh-nhi"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (luyện thể) @c0005","trangThai":"song","blurb":"Thạch Mãnh, còn gọi Nhị Mãnh hay nhóc thò lò mũi xanh, là thiếu niên da đen nhẻm của Thạch Thôn, tám tuổi rưỡi đã vật ngã trâu mộng và nhấc nổi đỉnh đồng ngàn cân nhờ được tẩy lễ bằng chân huyết Toan Nghê. Tính hay thắc mắc, cứng đầu nhưng gan dạ, cậu cùng đám trẻ trải qua vụ trộm trứng Thanh Lân Ưng và biến cố di thôn. Sau hai năm rèn luyện, bản lĩnh cường đại nhưng vẫn bị người lớn ngăn ra ngoài vì tu vi còn kém.","vaiTro":"Thiếu niên khỏe mạnh của Thạch Thôn, con thứ hai trong nhà","tinhCach":"hay thắc mắc, cứng đầu trước điều vô lý; sức vóc mạnh mẽ, gan dạ xung phong; tham ăn, ngờ nghệch; trung thành, phẫn nộ trước bất công với bộ tộc","tabs":{"diem":[{"text":"Tám tuổi rưỡi vật ngã trâu mộng xanh đen và nhấc nổi đỉnh đồng ngàn cân giữa chừng","chuong":"@c0005"},{"text":"Sức tăng vọt nhờ được tẩy lễ bằng chân huyết Toan Nghê, dễ dàng nâng đỉnh cổ nặng ngàn cân","chuong":"@c0035"},{"text":"Xung phong ném đá dò tổ Ngô Sào để dò xét Thanh Lân Ưng, dặn mọi người tìm chỗ trốn","chuong":"@c0007"},{"text":"Người đầu tiên chạm vào quả trứng bích ngọc phát sáng trong vụ trộm trứng và bị tê","chuong":"@c0008"},{"text":"Cứng đầu khẳng định Liễu thần vẫn thủ hộ bộ tộc trước dò xét của cường giả","chuong":"@c0036"},{"text":"Cùng Đại Tráng và Bì Hầu tiến bộ thần tốc trong hai năm, bản lĩnh cường đại","chuong":"@c0086"}],"kinhLich":[{"text":"Thạch Mãnh tám tuổi rưỡi vật ngã con trâu mộng xanh đen, khi thử nâng đỉnh đồng ngàn cân đã nhấc lên giữa không trung nhưng chưa qua đầu thì run tay quăng xuống.; Thạch Mãnh vật ngã một con trâu mộng xanh đen; khi thi nâng đỉnh, nó nhấc được đỉnh lên giữa không trung nhưng chưa qua đầu thì run tay quăng xuống.; Nhị Mãnh mới tám tuổi rưỡi đã vật ngã được một con trâu mộng; khi thử nâng đỉnh đồng ngàn cân nó nhấc lên giữa không trung nhưng chưa qu…","anchor":"nhấc được cả những cái chùy đồng nặng hơn trăm cân","bridge":true,"khoang":"@c0005"},{"text":"Xung phong ném thử một hòn đá lên gần Ngô Sào để dò xem Thanh Lân Ưng có ở tổ không, bảo mọi người trốn vào khe đá; không thấy hung cầm nên cả nhóm quyết trèo lên.; Trước sào huyệt Thanh Lân Ưng, Nhị Mãnh ném đá thử xem hung cầm có trong tổ không; không thấy động tĩnh nên đoàn trẻ quyết định trèo lên vách đá.; Ném đá thử vào Ngô Sào để thăm dò xem Thanh Lân Ưng có trong tổ không, rồi cùng đoàn trèo lên vách đá.","anchor":"Tất cả trốn hết vào trong khe đá, để tao ném thử một hòn đá xem sao","bridge":true,"khoang":"@c0007"},{"text":"Nhị Mãnh da đen nhẻm, tính tình ngờ nghệch, là người đầu tiên chạm vào quả trứng bích ngọc phát sáng và bị tê rần như điện giật; cả nhóm hí hửng vì chọc được cái tổ hung cầm lớn nhất từng thấy.; Cùng nhóm trẻ chọc được cái tổ hung cầm lớn nhất từng thấy, là người chạm vào quả trứng bích ngọc đầu tiên nên bị tê rần như điện giật.; Nhị Mãnh nước da đen nhẻm, tính ngờ nghệch, là người chạm vào quả trứng bích ngọc đầu tiên và bị tê rần như điện giật…","anchor":"Nhị Mãnh nước da đen nhẻm nở nụ cười ngờ nghệch, nước dãi sắp chảy thòng lòng cả ra ngoài.","bridge":true,"khoang":"@c0008"},{"text":"Nhị Mãnh hỏi Lâm Hổ thúc phải làm gì với ba quả trứng khi tộc bàn chuyện giữ hay trả trứng cho Thanh Lân Ưng.","anchor":"Thôi, trả trứng lại cho con chim không lông kia đi.","bridge":true,"khoang":"@c0011"},{"text":"Tham ăn, muốn ăn thịt Giao và bàn chuyện giết Tế Linh cùng bọn trẻ Thạch Thôn khi đứng xem hỗn chiến ba tộc.; Nhị Mãnh thản nhiên nói muốn ăn thịt Giao và bàn chuyện giết Tế Linh, dùng chân huyết tẩy lễ, khiến đám cường giả ngoài thôn sững sờ tưởng đây là gia tộc ẩn thế khủng bố.","anchor":"Bọn nó mấy ngày nay vừa ăn thịt Toan Nghê, vừa dùng chân huyết tẩy lễ.","bridge":true,"khoang":"@c0034"},{"text":"Làu bàu hỏi vì sao nhiều năm qua Tế Linh chưa từng đụng đến cống phẩm mà vẫn phải cúng tế; bị cha định đánh, được lão tộc trưởng xua tay ngăn; mặt đỏ bừng phân trần không phải mình không thành tâm.","anchor":"Tế Linh là Linh mà chúng ta cúng tế và phụng dưỡng, quý ở tấm lòng thành","bridge":true,"khoang":"@c0003"},{"text":"Nhị Mãnh nhặt tảng đá to bằng mặt người ném trúng đầu hung cầm nhưng đá vỡ nát, vẩy không hề hấn; sau đó cùng Thạch Hạo và Thạch Đại Tráng — ba đứa khỏe nhất — chuyên ném thiết mâu vào hai mắt Thanh Lân Ưng.; Ném tảng đá bằng mặt người trúng đầu Thanh Lân Ưng nhưng đá vỡ nát, vẩy nó cứng như kim loại không hề hấn; sau là một trong ba đứa khỏe nhất chuyên ném thiết mâu vào hai mắt hung cầm để câu giờ.; Khi Thanh Lân Ưng ló đầu vào cửa động, Nhị M…","anchor":"Nhị Mãnh thật sự rất mạnh mẽ, vừa nói vừa nhặt một tảng đá to bằng mặt người rồi dùng sức ném ra.","bridge":true,"khoang":"@c0009"},{"text":"Nhóc tám chín tuổi nhờ tẩy lễ bằng chân huyết Toan Nghê nên sức tăng vọt, dễ dàng nâng đỉnh cổ nặng ngàn cân; tính ngáo ngơ nên lỡ miệng lộ chuyện tộc đã ăn một con Toan Nghê rất mạnh và chuyện tộc trưởng bế quan, bị cha vỗ đầu răn.; Nhị Mãnh (tám chín tuổi) dễ dàng nâng cái đỉnh nặng ngàn cân nhờ tẩy lễ chân huyết Toan Nghê, ngáo ngơ hỏi đại thúc chuyện dẫn Phi Giao về nuôi, rồi vô tình lộ chuyện tộc trưởng đã bế quan.; Nhị Mãnh tám chín tuổi d…","anchor":"vừa nói vừa nâng một cái đỉnh nặng ngàn cân lên","bridge":true,"khoang":"@c0035"},{"text":"Trước dò xét của cường giả, Nhị Mãnh cứng đầu khẳng định Liễu thần rất tốt và vẫn thủ hộ bộ tộc; sau đó bị Giao Bằng trở mặt mắng là thùng rỗng kêu to.","anchor":"Liễu thần rất tốt, vẫn thủ hộ tộc bọn tôi","bridge":true,"khoang":"@c0036"},{"text":"Cùng Bì Hầu và nhóc thò lò mũi xanh phẫn nộ trước hành vi bắn ba con chim non của Giao Bằng.","anchor":"làm cho Nhị Mãnh, Bì Hầu và nhóc thò lò mũi xanh đều phẫn nộ","bridge":true,"khoang":"@c0037"},{"text":"Cùng nhóc mũi xanh và đám nhóc Thạch thôn khơi lại chuyện các tộc bàn nhau tàn sát Thạch thôn, cướp xương quý Toan Nghê, khiến các cường giả sợ hãi quay ra nhã nhặn.","anchor":"một đám cao thủ từ La Phù Đại Trạch bị giết chỉ trong một hơi thở","bridge":true,"khoang":"@c0040"},{"text":"Trẻ Thạch Thôn, khi cả thôn tới vùng đất mới đã nhận ra cảnh vật hoàn toàn không giống núi rừng quen thuộc ở ngoài thôn.; Ở vùng đất mới, nhận ra cảnh vật hoàn toàn khác núi rừng quen thuộc quê nhà.; Cùng đám trẻ Thạch Thôn tới vùng đất mới, nhận ra cảnh vật hoàn toàn không giống núi rừng quê nhà.","anchor":"những gì ở trước mắt hoàn toàn không giống với núi rừng ở ngoài thôn","bridge":true,"khoang":"@c0050"},{"text":"Trêu Chu Yếm về việc bóng lông giật bát uống thuốc luyện từ chính máu vàng của nó.","anchor":"Đây đã coi là một lô thuốc quý rồi!","bridge":true,"khoang":"@c0065"},{"text":"Vô tình cưỡi một con Độc Giác Thú bạc chạy điên quanh hồ rồi bị hất xuống; về sau thuần phục được ngựa quý khiến người lớn trong thôn kinh ngạc thán phục vì họ không làm được, rồi cùng Đại Tráng, Hổ Tử đi mạo hiểm vào núi và phát hiện khói lửa thôn bị đốt.","anchor":"「Nhị Mãnh thật bản lĩnh, rõ ràng muốn thuần phục một con ngựa quý!」","bridge":true,"khoang":"@c0078"},{"text":"Cha Nhị Mãnh cùng Thạch Lâm Hổ, Thạch Phi Giao phẫn nộ đòi mang Tổ Khí ra 'cá chết lưới rách' với hung khấu, nhưng bị Thạch Vân Phong ngăn lại vì thôn không ai đủ Cốt Văn cao thâm phát huy uy lực Tổ Khí.","anchor":"Phụ thân của Nhị Mãnh cũng góp vào.","bridge":true,"khoang":"@c0079"},{"text":"Cùng Đại Tráng, Bì Hầu tiến bộ thần tốc trong hai năm, bản lĩnh cường đại, đến tuổi được người lớn giục thành hôn.","anchor":"Đại Tráng, Nhị Mãnh, Bì Hầu tiến bộ thần tốc trong hai năm qua, bản lĩnh cường đại, cũng nên thành hôn rồi.","bridge":true,"khoang":"@c0086"},{"text":"Cùng Bì Hầu đòi đi ra ngoài nhìn ngắm thế giới bên ngoài nhưng bị từ chối vì tu vi kém và được khuyên nên kết hôn trước.","anchor":"Bọn Nhị Mãnh, Bì Hầu bu lại, chúng nó cũng muốn đi ra nhìn ngắm thế giới bên ngoài.","bridge":true,"khoang":"@c0095"}],"tuViMoc":[],"tuVi":"Hài đồng phàm nhân của Thạch Thôn.","nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đứa em nhỏ cùng thôn có thể chất kinh người.","ghiChu":"@c0005"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn cùng đoàn","ghiChu":"@c0007"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đàn em cùng thôn","ghiChu":"Cùng thi thố sức lực @c0005"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":"@c0007"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn thuở nhỏ","ghiChu":"@c0007"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn thuở nhỏ","ghiChu":"@c0007"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn trong thôn, tranh luận về cách xử lý hung thú","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng dự thi thố sức lực"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng thôn tranh cãi","ghiChu":"@c0034"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Tộc trưởng thôn","ghiChu":"Được lão tộc trưởng vỗ vai nhẫn nại giải thích Tế Linh quý ở tấm lòng thành."},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đoàn trẻ, sức đứng sau Thạch Hạo","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng ném thiết mâu vào mắt hung cầm"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Cùng nhóm ba đứa khỏe nhất chống hung cầm"},{"ten":"Cha của Nhị Mãnh","tag":"cha-me","quanHe":"Cha","ghiChu":"Giải thích chuyện dẫn Hung Giao về nuôi sinh sản là kế dài lâu."},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đám nhóc Thạch Thôn chống hung cầm","ghiChu":""},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị Giao Bằng mắng và định động thủ","ghiChu":"@c0036"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Cùng phẫn nộ với Giao Bằng @c0037"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Thần thủ hộ Thạch thôn","ghiChu":"Nhị Mãnh bênh Liễu thần trước cường giả (@c0036)"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn thân đồng thôn","ghiChu":"Cùng phẫn nộ trước Giao Bằng (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ hại chim non","ghiChu":"Phẫn nộ trước hành vi của Giao Bằng (@c0037)"},{"ten":"Nhóc mũi xanh","tag":"ban-be","quanHe":"Bạn nhóc cùng thôn","ghiChu":"Cùng khơi lại âm mưu các tộc (@c0040)"},{"ten":"Cha của Nhị Mãnh","tag":"cha-me","quanHe":"Cha ruột — vỗ đầu răn khi Nhị Mãnh nói năng bộp chộp","ghiChu":"@c0035"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị mắng chửi","ghiChu":"Bị Giao Bằng mắng thùng rỗng kêu to."},{"ten":"Cha của Nhị Mãnh","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"@c0050"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị uy hiếp","ghiChu":"Bị Giao Bằng trở mặt mắng và muốn động thủ (@c0036)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Giao Bằng mắng Nhị Mãnh là thùng rỗng kêu to, muốn động thủ. @c0036"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị cường giả La Phù trở mặt mắng","ghiChu":"Bị mắng thùng rỗng kêu to khi Giao Bằng động thủ (@c0036)"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Tộc trưởng Thạch Thôn","ghiChu":"Cha Nhị Mãnh góp lời trong cuộc bàn bạc @c0079"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn thân thuở nhỏ ở Thạch thôn","ghiChu":"Muốn đi theo nhưng bị từ chối"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0005","@c0007","@c0008","@c0035","@c0050","@c0009","@c0034","@c0011","@c0032","@c0003","@c0040","@c0036","@c0037","@c0065","@c0078","@c0079","@c0086","@c0095"]},{"id":"thach-dai-trang","name":"Thạch Đại Tráng","cn":"","aliases":["Đại Tráng","Đại Tráng ca"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (luyện thể) @c0005","trangThai":"song","blurb":"Bé trai chín tuổi của Thạch Thôn, mày rậm mắt to thân hình cao lớn, được khen trời sinh thần lực.","vaiTro":"Thiếu niên có sức lực nổi trội trong đám trẻ Thạch Thôn.","tinhCach":[{"text":"Mạnh mẽ, tự tin vào sức vóc.","chuong":"@c0005"}],"tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0005","tieuDe":"Chín tuổi nâng đỉnh qua đầu","text":"Thạch Đại Tráng chín tuổi, mày rậm mắt to thân hình cao lớn, nâng bổng chiếc đỉnh đồng ngàn cân qua đỉnh đầu thành công, được cả thôn khen là trời sinh thần lực.; Thạch Đại Tráng chín tuổi nhấc bổng đỉnh đồng ngàn cân qua đỉnh đầu thành công, được cả thôn ca ngợi là trời sinh thần lực.; Thạch Đại Tráng chín tuổi bước lên nhấc bổng đỉnh đồng ngàn cân qua đỉnh đầu thành công, được cả thôn ca ngợi là trời sinh thần lực.; Thạch Đại Tráng bước lên và…","anchor":"nhấc bổng lên và nhanh chóng nâng quá đỉnh đầu"},{"importance":"normal","chuong":"@c0007","tieuDe":"Dẫn đầu đoàn trẻ vào rừng nguyên thủy","text":"Mày rậm mắt to, chiều cao gần bằng người lớn, từng nâng đỉnh đồng ngàn cân; dẫn đầu hơn mười đứa trẻ trốn người lớn rời Thạch Thôn vào rừng nguyên thủy đầy hung thú để lấy trứng Thanh Lân Ưng, luôn dặn cẩn thận.; Làm thủ lĩnh đoàn trẻ Thạch Thôn, chỉ huy cả bọn lẻn vào rừng nguyên thủy để lấy trứng hung cầm, dặn mọi người cẩn thận và cùng trèo vách theo sau Thạch Hạo.; Dẫn đầu mười mấy đứa trẻ trốn người lớn vào rừng nguyên thủy tới sào huyệt Th…","anchor":"chúng nó trốn người lớn rời khỏi Thạch Thôn để vào rừng"},{"importance":"normal","chuong":"@c0008","tieuDe":"Dẫm phải vảy trong tổ","text":"Thạch Đại Tráng cao lớn vạm vỡ giục cả nhóm rời đi; khi thu dọn tổ, cậu dẫm phải tấm vảy kim loại ẩn trong cỏ Kim Ti, đế giày bị đâm thủng, lòng bàn chân tóe máu.; Cao lớn vạm vỡ và ổn trọng, giục đồng bọn rời tổ; khi dẫm phải tấm vảy kim loại sắc lẻm bị đâm thủng đế giày, tóe máu chân.; Vác trứng Thanh Lân Ưng cất vào túi da thú, giục cả nhóm rời đi thì dẫm phải tấm vảy kim loại ẩn trong cỏ Kim Ti, thủng đế giày, chân tóe máu.","anchor":"đế giày bị đâm thủng, lòng bàn chân tóe máu"},{"importance":"normal","chuong":"@c0009","tieuDe":"Đề xuất kế chọc giận hung cầm","text":"Đề xuất dốc sức chọc giận Thanh Lân Ưng để nó gây ra động tĩnh lớn, giúp Thạch Thôn nghe thấy mà đến cứu; cùng Thạch Hạo và Nhị Mãnh chuyên ném thiết mâu vào hai mắt hung cầm.; Khi bị Thanh Lân Ưng vây trong thạch động, Thạch Đại Tráng đề xuất dốc hết sức chọc giận hung cầm để tạo động tĩnh lớn cho Thạch Thôn nghe thấy mà đến cứu; là một trong ba đứa khỏe nhất chuyên ném thiết mâu vào hai mắt nó.; Trong lúc bị vây trong thạch động, Thạch Đại Trá…","anchor":"chúng ta dốc hết sức tấn công, chọc giận nó để nó làm ra động tĩnh lớn hơn nữa"},{"importance":"normal","chuong":"@c0034","tieuDe":"Bàn chuyện Độc Giác Thú","text":"Cùng bọn trẻ Thạch Thôn ra xem cuộc hỗn chiến, kể chuyện Thạch Lâm Hổ xin Tổ Khí từ tộc trưởng để truy sát Độc Giác Thú ở Đại Hoang.; Trong lúc bọn trẻ Thạch Thôn thản nhiên bàn tán, Thạch Đại Tráng kể về Độc Giác Thú và việc đám Thạch Lâm Hổ truy sát nó, khiến cường giả ngoài thôn kinh hãi.","anchor":"Bọn nó mấy ngày nay vừa ăn thịt Toan Nghê, vừa dùng chân huyết tẩy lễ."},{"importance":"normal","chuong":"@c0037","tieuDe":"Nhấc đỉnh đồng định xông lên","text":"Thấy ba con chim non bị bắn, Thạch Đại Tráng lộ thần lực nhấc đỉnh đồng ngàn cân muốn xông về phía trước cứu, nhưng bị Thạch Hạo ra hiệu ngăn lại.; Người Thạch Thôn có thần lực, nhấc đỉnh đồng ngàn cân định xông lên trợ chiến nhưng bị Thạch Hạo ngăn lại.; Nhấc đỉnh đồng ngàn cân định xông về phía trước ngăn Giao Bằng, nhưng bị Thạch Hạo ra hiệu ngăn lại.","anchor":"nhấc tay liền cầm lấy một cái đỉnh đồng ngàn cân, muốn xông về phía trước"},{"text":"Trước sự khinh người của các cường giả đòi giao bảo cốt Toan Nghê, tức giận run lên, cùng người Thạch Thôn thề huyết chiến đến giọt máu cuối cùng.; Người Thạch Thôn tức giận run lên trước sự khinh người của các cường giả đòi bảo cốt, thề huyết chiến đến giọt máu cuối cùng bảo vệ làng.","anchor":"Thà làm ngọc nát còn hơn làm ngói lành","bridge":true,"khoang":"@c0039"},{"text":"Xác nhận nhớ chuyện Thạch Hạo mất cha mẹ, nhớ mang máng vị thúc thúc oai hùng mang bệnh và a di xinh đẹp.","anchor":"bọn họ muốm tìm Thánh dược để trị tận gốc bệnh tình của cháu","bridge":true,"khoang":"@c0052"},{"text":"Cưỡi Độc Giác Thú theo đám trẻ vào núi đi săn, cùng gật đầu đồng lòng mạo hiểm; là người chỉ ra bóng dáng khổng lồ ở chân trời và cảnh thi thể la liệt ở thôn bị thảm sát.","anchor":"「Mấy đứa Đại Tráng, Nhị Mãnh, Hổ Tử, nhóc thò lò mũi xanh đều gật đầu」","bridge":true,"khoang":"@c0078"}],"tuViMoc":[],"tuVi":"Hài đồng phàm nhân của Thạch Thôn.","nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đứa em nhỏ cùng thôn nâng đỉnh sau nó.","ghiChu":"@c0005"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đoàn trẻ, cùng trèo vách","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng câu giờ chống hung cầm"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Cùng nhóm ba đứa khỏe nhất ném thiết mâu"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Cùng Thạch Thôn quyết chiến bảo vệ bảo cốt","ghiChu":"@c0039"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn nòng cốt trong đoàn","ghiChu":"@c0007"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"bạn cùng nhóm trẻ Thạch Thôn","ghiChu":"Được Thạch Hạo đỡ khi bị thương."},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đám nhóc Thạch Thôn chống hung cầm","ghiChu":""},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Cùng nhóm ba đứa khỏe nhất ném thiết mâu","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Người lớn Thạch Thôn được nhắc tới","ghiChu":""},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người Thạch Thôn, bị Thạch Hạo ngăn xông lên @c0037"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người Thạch Thôn cùng quyết chiến","ghiChu":"Tức giận run lên trước sự khinh người, cùng dân làng thề huyết chiến @c0039"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đàn em cùng thôn","ghiChu":"Cùng dự buổi thi nâng đỉnh @c0005"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm nòng cốt","ghiChu":"@c0007"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn thuở nhỏ hay đi cùng","ghiChu":"@c0007"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn thuở nhỏ hay đi cùng","ghiChu":"@c0007"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Người lớn trong thôn được nhắc tới trong chuyện kể","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng dự thi nâng đỉnh"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":"Cùng vào rừng đá lấy trứng"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Trưởng bối Thạch Thôn","ghiChu":"@c0034"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng thôn","ghiChu":"Được Thạch Hạo ra hiệu ngăn lại khi định xông lên (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ định hại chim non thôn","ghiChu":"Định xông lên ngăn Giao Bằng (@c0037)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0005","@c0007","@c0008","@c0009","@c0039","@c0034","@c0037","@c0052","@c0078"]},{"id":"thach-giao","name":"Thạch Giao","cn":"","aliases":["Thạch Giao","Phi Giao"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (luyện thể) @c0005","trangThai":"song","blurb":"Bé trai của Thạch Thôn, thử nâng đỉnh nhưng chỉ nhấc được khỏi mặt đất và suýt trẹo hông.","vaiTro":"Thiếu niên góp mặt trong cuộc thi nâng đỉnh của Thạch Thôn.","tinhCach":[{"text":"Hăng hái tham gia thử sức dù chưa đủ lực.","chuong":"@c0005"}],"tabs":{"diem":[],"kinhLich":[{"text":"Thạch Giao góp mặt trong cuộc thi nâng đỉnh đồng ngàn cân nhưng chỉ nhấc được khỏi mặt đất, suýt trẹo cả hông.; Thạch Giao dự thi nâng đỉnh nhưng chỉ nhấc được khỏi mặt đất, suýt trẹo hông.","anchor":"có mấy đứa còn nhấc được cả những cái chùy đồng nặng hơn trăm cân","bridge":true,"khoang":"@c0005"}],"tuViMoc":[],"tuVi":"Hài đồng phàm nhân của Thạch Thôn.","nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng thôn, cùng dự cuộc thi nâng đỉnh.","ghiChu":"@c0005"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0005","@c0010","@c0013","@c0014"]},{"id":"bi-hau","name":"Thạch Trung Hầu","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thạch Trung Hầu (biệt danh Bì Hầu) là thiếu niên gầy còm mà khỏe của Thạch Thôn, được cha đặt tên với kỳ vọng phong hầu xưng vương. Từ cậu bé cầm đầu đám trẻ trộm trứng Thanh Lân Ưng, cậu trải qua biến cố cha bị người Bái Thôn bắn trọng thương rồi thề khổ tu, hai năm tiến bộ thần tốc trở thành trang thiếu niên cường đại của tộc.","vaiTro":"Nhân vật phụ — thiếu niên Thạch Thôn của Thạch Hạo","tinhCach":"gan lì, khỏe khoắn hơn người; tinh ranh, tò mò hay bày trò; giàu tình cảm, hiếu thảo với cha; nóng nảy, ương ngạnh khi bất bình","tabs":{"kinhLich":[{"text":"Bì Hầu gầy nhom cười giống khỉ núi, cùng nhóm trẻ trộm trứng Thanh Lân Ưng, nhận xét về độ cứng của vảy hung cầm và nhắc công lao sẽ được Lâm Hổ thúc công nhận.; Vác một quả trứng Thanh Lân Ưng, ước lượng vảy hung cầm cứng đến mức đại kiếm mấy trăm cân cũng khó chém đứt; kỳ vọng người lớn trong thôn sẽ nhìn bọn trẻ khác đi sau vụ trộm trứng.; Bì Hầu gầy nhom, lúc cười giống hệt con khỉ núi, tham gia chọc tổ trộm trứng và bàn tán về độ cứng của v…","anchor":"Đây là cái tổ chim to nhất tao từng chọc","bridge":true,"khoang":"@c0008"},{"text":"Trên đường trốn, Bì Hầu bị đá bay đập trúng cánh tay chảy máu; trong động cậu giương cung cứng bằng sừng rồng bắn Thanh Lân Ưng, nhưng tên chỉ tóe lửa không xuyên thủng vẩy.; Bị đá bay đập trúng cánh tay chảy máu khi chạy trốn; trong động bắn cung sừng rồng vào đầu Thanh Lân Ưng nhưng tên chỉ tóe lửa, không xuyên thủng lớp vẩy.; Bì Hầu bị đá bay đập trúng cánh tay chảy máu khi chạy trốn; trong động cậu giương cung cứng bằng sừng rồng bắn tên vào…","anchor":"Bì Hầu giương cung cài tên, đó là một cây cung cứng bằng sừng rồng","bridge":true,"khoang":"@c0009"},{"text":"Sau vụ trộm trứng bị người lớn đánh phạt, Bì Hầu tò mò và tị nạnh hỏi vì sao Nhóc tỳ Thạch Hạo không bị đánh mà còn được uống sữa thú.; Sau vụ đám trẻ trộm trứng chọc ổ Thanh Lân Ưng, Bì Hầu cùng lũ trẻ bị người lớn quất mông phạt đòn; nó tò mò thắc mắc vì sao chỉ mình Nhóc tỳ được uống sữa thú mà không bị đánh.","anchor":"Tụi huynh đều bị đánh, tại sao đệ còn được uống sữa thú vậy?","bridge":true,"khoang":"@c0010"},{"text":"Dân làng Thạch Thôn; cha của Bì Hầu theo đội săn bị người Bái Thôn bắn một mũi tên trúng lá phổi, bị thương không nhẹ nhưng không chết.; Cha của Bì Hầu bị người Bái Thôn bắn một mũi tên trúng lá phổi khi đội săn gặp người Bái Thôn tranh mồi, được khiêng về thôn.; Cha của Bì Hầu đi săn bị người Bái Thôn bắn một mũi tên trúng lá phổi, thương nặng nhưng không chết, khiến xung đột giữa hai thôn bùng lên.; Cha của Bì Hầu theo đội săn ra khu săn bắn t…","anchor":"cha Bì Hầu bị thương không nhẹ, bị người ta bắn một mũi tên, bị thương lá phổi","bridge":true,"khoang":"@c0012"},{"text":"Thấy cha Thạch Thủ Sơn bị bắn trọng thương trở về, Bì Hầu khóc lớn xông ra khỏi thôn ôm lấy cha, nhưng bị cha mắng không cho khóc.; Khi cha là Thạch Thủ Sơn trọng thương trở về, Bì Hầu khóc lớn xông ra khỏi thôn ôm lấy cánh tay cha, bị cha trợn mắt mắng không cho khóc.","anchor":"Bì Hầu khóc lớn, nó xông ra khỏi thôn, ôm một cánh tay của Thạch Thủ Sơn","bridge":true,"khoang":"@c0013"},{"text":"Cùng đám nhóc trong tộc xông vào đá và chế nhạo Bái Phong, vì hắn từng suýt bắn chết cha mình.; Nhóc trong tộc xông vào đá và chế nhạo Bái Phong vì hắn suýt bắn chết cha mình.; Nhóc trong tộc, xông vào đá và chế nhạo Bái Phong vì hắn suýt bắn chết cha mình.; Cùng đám nhóc trong tộc xông vào đá và chế nhạo Bái Phong, vì trước đó hắn suýt bắn chết cha mình.","anchor":"xương ngực của Bái Phong lập tức đứt mất mấy cây","bridge":true,"khoang":"@c0016"},{"text":"Nhóc trong thôn hồn nhiên tiết lộ cây liễu già là Tế Linh, cứ gọi là “Liễu Thần”, khiến cả đám cường giả các tộc sốc nặng lảo đảo.; Nhóc trong thôn tiết lộ cây liễu già là Tế Linh, gọi là Liễu Thần, khiến cả đám cường giả sốc nặng lảo đảo.; Nhóc trong thôn lỡ tiết lộ cây liễu già chính là Tế Linh, được gọi là “Liễu Thần”, khiến cả đám cường giả sốc nặng lảo đảo.","anchor":"cứ gọi là Tế Linh thôi, hoặc gọi là Liễu Thần","bridge":true,"khoang":"@c0035"},{"text":"Cùng Nhị Mãnh và nhóc thò lò mũi xanh phẫn nộ trước hành vi bắn ba con chim non của Giao Bằng.","anchor":"làm cho Nhị Mãnh, Bì Hầu và nhóc thò lò mũi xanh đều phẫn nộ","bridge":true,"khoang":"@c0037"},{"text":"Cùng Thạch Đại Tráng nhớ mang máng về vị thúc thúc oai hùng mang bệnh và a di xinh đẹp là cha mẹ Thạch Hạo.","anchor":"bọn họ muốm tìm Thánh dược để trị tận gốc bệnh tình của cháu","bridge":true,"khoang":"@c0052"},{"text":"Rủ đám nhóc đua Độc Giác Thú và đi săn; sau cú hoảng loạn trước Thứ Thú khổng lồ, thề khổ tu luyện cốt văn đến xuất thần nhập hóa để sớm thành đại cao thủ.","anchor":"「tớ muốn khổ tu, nhất định phải luyện tập cốt văn đến xuất thần nhập hóa, sớm ngày trở thành đại cao thủ.」","bridge":true,"khoang":"@c0078"},{"text":"Cùng Hổ Tử cưỡi Độc Giác Thú đi tra xét, phát hiện một thôn xóm ngoài 600 dặm đã bị tàn sát đẫm máu toàn bộ; mang về Thạch Thôn tin không hay: người sống sót duy nhất kịp nói kẻ tấn công đòi cống nạp Nguyên Thủy Bảo Cốt và kim loại quý.","anchor":"Mấy ngày sau, Bì Hầu, Hổ Tử mang đến một tin tức không hay.","bridge":true,"khoang":"@c0079"},{"text":"Cùng Đại Tráng, Nhị Mãnh tiến bộ thần tốc trong hai năm, bản lĩnh cường đại, đến tuổi được người lớn giục thành hôn.","anchor":"Đại Tráng, Nhị Mãnh, Bì Hầu tiến bộ thần tốc trong hai năm qua, bản lĩnh cường đại, cũng nên thành hôn rồi.","bridge":true,"khoang":"@c0086"},{"text":"Cùng Nhị Mãnh đòi đi ra ngoài nhìn ngắm thế giới nhưng bị từ chối vì tu vi kém và được khuyên nên kết hôn trước.","anchor":"Nhị Mãnh, Bì Hầu, các cháu cũng đã mười hai mười ba tuổi rồi, cũng nên kết hôn rồi","bridge":true,"khoang":"@c0095"},{"text":"Thạch Trung Hầu tám chín tuổi gầy còm mà khỏe, quăng cối đá xa mười mấy mét trong buổi thi thố; cha đặt tên Thạch Trung Hầu với kỳ vọng phong hầu xưng vương.; Bì Hầu gầy còm mà khỏe, quăng cối đá xa mười mấy mét; cha đặt tên nó là Thạch Trung Hầu với kỳ vọng mai sau phong hầu xưng vương.; Bì Hầu tám chín tuổi trông còm nhom nhưng rất khỏe, quăng cối đá xa mười mấy mét; cha đặt tên nó là Thạch Trung Hầu với mong ước sau này ra khỏi núi phong hầu…","anchor":"nhấc được cả những cái chùy đồng nặng hơn trăm cân","bridge":true,"khoang":"@c0005"},{"text":"Nghe lén Lâm Hổ thúc kể về tập quán hung cầm, Bì Hầu nắm được vị trí tổ Thanh Lân Ưng và dẫn đoàn trẻ băng qua rừng đá đầy di cốt cự thú tới đúng vách núi có Ngô Sào.; Nghe lén thông tin từ Lâm Hổ thúc về tập quán của Thanh Lân Ưng, dẫn đoàn trẻ vào rừng đá tìm tổ hung cầm ở vách núi sâu, rồi cùng ba đứa lớn trèo lên vách.; Theo lời Lâm Hổ thúc, dẫn cả nhóm trẻ tới tổ hung cầm ở vách núi sâu trong rừng đá đầy hài cốt cự thú, đề xuất mang trứng v…","anchor":"tổ của nó ở trên vách núi sâu trong rừng đá","bridge":true,"khoang":"@c0007"},{"text":"Ở đầu Thạch Thôn xem hỗn chiến, phản bác Nhị Mãnh — nói Giao dùng để luyện thuốc, tiếc Tế Linh không ăn được; đứng đầu đám nhóc bị Giao Bằng xông vào tấn công.; Bì Hầu phản bác chuyện ăn thịt Giao, cho rằng nên dùng luyện thuốc; sau đó bị Giao Bằng tức giận xông vào đầu thôn tấn công, nhưng được nhóc tỳ ra tay đỡ.","anchor":"Bọn nó mấy ngày nay vừa ăn thịt Toan Nghê, vừa dùng chân huyết tẩy lễ.","bridge":true,"khoang":"@c0034"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng trốn hung cầm trong thạch động"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng chống hung cầm"},{"ten":"Thạch Thủ Sơn","tag":"cha-me","quanHe":"Cha của Bì Hầu","ghiChu":"Bì Hầu ôm khóc khi cha trọng thương."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Xông vào đá và chế nhạo Bái Phong","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng thôn, người báo tin cha Bì Hầu bị thương","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đám nhóc Thạch Thôn trốn hung cầm","ghiChu":""},{"ten":"Thạch Thủ Sơn","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Cha bị trọng thương @c0013"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Cùng phẫn nộ với Giao Bằng @c0037"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ","ghiChu":"Cùng nhóm trẻ chọc ổ ma cầm (@c0010)."},{"ten":"Thạch Thủ Sơn","tag":"cha-me","quanHe":"Cha con","ghiChu":"Cha ruột, bị Bái Thôn bắn trọng thương."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đá và chế nhạo Bái Phong","ghiChu":"@c0016"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn thân đồng thôn","ghiChu":"Cùng phẫn nộ trước Giao Bằng (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ hại chim non","ghiChu":"Phẫn nộ trước hành vi của Giao Bằng (@c0037)"},{"ten":"Tử Sơn Thọ","tag":"khac","quanHe":"Cường giả bị Bì Hầu vô tình làm khiếp vía khi lộ danh xưng Liễu Thần","ghiChu":"@c0035"},{"ten":"Hổ Tử","tag":"ban-be","quanHe":"Đồng đội trinh sát","ghiChu":"Cùng cưỡi Độc Giác Thú đi tra xét @c0079"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn thân thuở nhỏ ở Thạch thôn","ghiChu":"Muốn đi theo nhưng bị từ chối"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng thôn, cùng dự cuộc thi thố.","ghiChu":"@c0005"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng đoàn trẻ Thạch Thôn","ghiChu":""},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Cùng đoàn trẻ, dưới quyền chỉ huy","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"khac","quanHe":"Người lớn cung cấp thông tin về sào huyệt (bị nghe lén)","ghiChu":"@c0007"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng bọn cùng đoàn","ghiChu":"@c0007"},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"người lớn trong thôn","ghiChu":"Bì Hầu tin sẽ được Lâm Hổ thúc công nhận công lao."},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đàn em cùng thôn","ghiChu":"Cùng thi thố sức lực @c0005"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":"@c0007"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn thuở nhỏ","ghiChu":"@c0007"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn thuở nhỏ","ghiChu":"@c0007"},{"ten":"Thạch Thủ Sơn","tag":"cha-me","quanHe":"Cha","ghiChu":"Cha của Bì Hầu, thợ săn Thạch Thôn bị Bái Thôn bắn trọng thương."},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn trong thôn, tranh luận về cách xử lý hung thú","ghiChu":""},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị Giao Bằng xông vào tấn công","ghiChu":""},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng đám trẻ Thạch Thôn"},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Lâm Hổ thúc — người lớn trong thôn","ghiChu":"Cung cấp thông tin về tập quán và sào huyệt Thanh Lân Ưng"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":""},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng thôn tranh cãi","ghiChu":"@c0034"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Bị xông vào tấn công","ghiChu":"@c0034"}],"tuViMoc":[],"tuVi":"Hài đồng phàm nhân của Thạch Thôn.","diem":[{"text":"Tám chín tuổi gầy còm mà khỏe khác thường, quăng cối đá xa mười mấy mét trong buổi thi thố","chuong":"@c0005"},{"text":"Nghe lén tập quán hung cầm rồi cầm đầu đám trẻ băng núi trộm trứng Thanh Lân Ưng","chuong":"@c0008"},{"text":"Khóc lớn xông ra ôm cha Thạch Thủ Sơn khi cha bị người Bái Thôn bắn trọng thương trúng lá phổi","chuong":"@c0013"},{"text":"Sau cú hoảng loạn trước Thứ Thú khổng lồ, thề khổ tu luyện cốt văn","chuong":"@c0078"},{"text":"Cùng Hổ Tử cưỡi Độc Giác Thú tra xét, phát hiện thôn xóm ngoài 600 dặm bị tàn sát toàn bộ","chuong":"@c0079"},{"text":"Cùng Đại Tráng và Nhị Mãnh tiến bộ thần tốc trong hai năm, bản lĩnh cường đại đến tuổi được giục thành hôn","chuong":"@c0086"}]},"nguon":["@c0008","@c0009","@c0010","@c0012","@c0013","@c0016","@c0035","@c0037","@c0052","@c0078","@c0079","@c0086","@c0095","@c0005","@c0007","@c0034"],"aliases":["Bì Hầu","Thạch Trung Hầu"]},{"id":"tu-van","name":"Tử Vân","gioiTinh":"khong-ro","trangThai":"song","blurb":"Chim non thứ ba (lão tam) trong ba con Thanh Lân Ưng, vảy tím, linh tính nhất, xảy ra hiện tượng phản tổ.","vaiTro":"Linh thú thân cận của Thạch Hạo, kế thừa một phần ấn ký Thái Cổ Ma Cầm.","tabs":{"diem":[{"text":"Linh tính nhất, mạnh nổi bật, thông minh hơn cả người khi học cốt văn.","chuong":"@c0012"}],"kinhLich":[{"importance":"major","chuong":"@c0012","tieuDe":"Phản tổ, Bí cốt bảo thư","text":"Xảy ra hiện tượng phản tổ, kế thừa một phần ấn ký Thái Cổ Ma Cầm; phù văn trong cơ thể được coi là Bí cốt bảo thư, nếu truyền ra sẽ khiến nhiều bộ tộc động lòng.; Được lũ trẻ đặt tên Tử Vân, là lão tam trong ba con Thanh Lân Ưng; linh tính nhất, từng vỗ cánh ra khỏi thôn xé xác hổ sói, học cốt văn cực hăng và ngày càng thân với Thạch Hạo.; Bé út linh tính và mạnh nhất, thân nhất với Thạch Hạo, xảy ra hiện tượng phản tổ kế thừa một phần ấn ký Thá…","anchor":"nó xảy ra hiện tượng phản tổ"},{"text":"Thanh Lân Ưng cùng nhóc tỳ xuống xác nhận Toan Nghê chết thật, tha về xác Toan Nghê, cánh tay Ác Ma Viên chứa chân huyết và sừng Ly Hỏa Ngưu Ma. Nó lảo đảo vì trúng độc Tử Kim Xà cắn từ trận trước, lại từng bị Huyết Điêu và Thử Vương đánh lén nên độc phát nhanh, gắng gượng bay về Thạch Thôn cầu tộc trưởng giải độc.","anchor":"đại thẩm trúng độc rồi, còn chưa có khử hết","bridge":true,"khoang":"@c0021"},{"importance":"normal","chuong":"@c0022","tieuDe":"Dẫn đầu chạy về cứu","text":"Cùng Đại Bằng và Tiểu Thanh chạy ở trên cùng, vô cùng lo lắng cho chim mẹ, dẫn đầu đoàn người Thạch Thôn xông tới hiện trường phục kích cứu Thạch Hạo.; Tử Vân cùng Đại Bằng, Tiểu Thanh dẫn đầu người Thạch Thôn xông tới cứu Thạch Hạo khi bị Bái Thôn phục kích.; Khi chim mẹ và Thạch Hạo gặp nạn, Tử Vân cùng Đại Bằng và Tiểu Thanh vô cùng lo lắng, chạy ở trên cùng dẫn đầu người Thạch Thôn xông tới tiếp ứng.","anchor":"ba con chim non đang vô cùng lo lắng"},{"chuong":"@c0023","importance":"normal","tieuDe":"Lấy thân che tên cho chim mẹ","text":"Cùng Đại Bằng, Tiểu Thanh vỗ cánh giậm đất xông đến cứu ứng, lấy thân che mưa tên cho chim mẹ Thanh Lân Ưng.; Cùng Đại Bằng và Tiểu Thanh vỗ cánh xông đến cứu ứng, lấy thân che tên cho chim mẹ Thanh Lân Ưng.","anchor":"Đại Bằng, Tiểu Thanh, Tử Vân vỗ cánh, giậm đất xông đến."},{"chuong":"@c0036","importance":"normal","tieuDe":"Biến dị vảy lưng xán lạn","text":"Tử Vân là một trong ba con chim non thân thiết bên nhóc tỳ; sau khi biến dị nhờ máu thịt Toan Nghê, vảy trên lưng càng xán lạn nổi bật hơn Đại Bằng, Tiểu Thanh; bị cường giả nhắm bảo cung.","anchor":"còn vảy trên lưng của Tử Vân lại càng xán lạn hơn"},{"text":"Chim non màu tím vàng bị Giao Bằng nhắm bắn đầu tiên; nhờ lực phòng ngự vảy vượt trội hơn hai con kia nên trong ba con chỉ mình Tử Vân không bị thương.; Là mục tiêu ban đầu Giao Bằng muốn bắt sống nhưng khi bị tập kích chỉ mình Tử Vân không bị thương nhờ vảy phòng ngự vượt trội.","anchor":"trừ Tử Vân ra thì Đại Bằng và Tiểu Thanh đều bị thượng, vảy rơi mấy cái, máu tươi bắn ra","bridge":true,"khoang":"@c0037"},{"importance":"normal","chuong":"@c0052","tieuDe":"Trưởng thành, dẫn phát hiện hồ khô","text":"Đã dài bốn mét, tung cánh phá không bay lượn trên tầng mây với tốc độ cực nhanh; cõng Thạch Hạo bay đi tham ngộ di tích chiến trường hướng Tây và kêu to ra hiệu dưới đáy hồ khô có sinh vật sống.; Tại hồ nước khô cạn, Tử Vân kêu to ra hiệu rằng dưới đáy hồ có sinh vật sống, dẫn tới việc phát hiện con khỉ ba tay bị vùi lấp.; Sau một năm, Tử Vân thân dài bốn mét, đã tung cánh phá không nhào lượn trên tầng mây với tốc độ cực nhanh và chở Thạch Hạo b…","anchor":"Đột nhiên Tử Vân kêu to, ra hiệu rằng ở dưới kia có sinh vật sống."},{"chuong":"@c0068","importance":"minor","text":"Đòi đi theo Thạch Hạo tới Cổ quốc nhưng không được cho phép vì chưa trưởng thành, đường quá nguy hiểm; cùng Đại Bằng, Tiểu Thanh tiễn hơn trăm dặm rồi quay về. Tuy bất phàm, biết phi thiên độn địa nhưng chưa trưởng thành; trên thân có thể hình thành nguyên thủy bảo cốt.","anchor":"Tử Vân, Đại Bằng và Tiểu Thanh mặc dù bất phàm, có thể phi thiên độn địa, nhưng dù sao chúng vẫn chưa trưởng thành."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Chủ nhân thân thiết","ghiChu":"Cực thân với Thạch Hạo, được nó dạy cốt văn."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Dẫn người Thạch Thôn tới cứu Thạch Hạo","ghiChu":"@c0022"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dạy thân nhất, dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Người nuôi và dạy cốt văn, thân thiết nhất","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân thân nhất, dạy cốt văn"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Đồng bào (lão đại)"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Đồng bào (lão nhị)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Thanh Lân Ưng thân thiết nhất, cho Thạch Hạo học phù văn nguyên thủy","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người nuôi dạy, nghiên cứu phù văn trong cơ thể","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Bạn thân, hiến hóa ấn ký cốt bảo cho Thạch Hạo nghiên cứu","ghiChu":""},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"con của Thanh Lân Ưng mẹ (bé út)","ghiChu":"@c0012"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"anh em cùng ổ (lão tam)","ghiChu":"@c0012"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"anh em cùng ổ (lão tam)","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"thân thiết, chủ động hiến ấn ký phù văn cho Thạch Hạo nghiên cứu","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được Thạch Hạo chắn tên bảo vệ @c0037"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Thân nhất với nhóc tỳ, hiến ấn ký cốt bảo cho hắn nghiên cứu","ghiChu":"@c0012"},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"Chim mẹ","ghiChu":"Cùng Đại Bằng, Tiểu Thanh vô cùng lo lắng khi chim mẹ trọng thương. @c0022"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Anh em","ghiChu":"Cùng chạy đầu đoàn Thạch Thôn về cứu. @c0022"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Anh em","ghiChu":"Cùng chạy đầu đoàn Thạch Thôn về cứu. @c0022"},{"ten":"Thanh Lân Ưng","tag":"ho-hang","quanHe":"Chim non lấy thân che tên cho chim mẹ","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Chủ nhân thân thiết nhất, được Tử Vân hiến hóa ấn ký cốt bảo","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên bảo vệ khi bị nhắm bắn (@c0036)"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Đi theo học Cốt Văn","ghiChu":"Được Thạch Hạo cản tên bảo vệ (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ săn","ghiChu":"Là mục tiêu ban đầu của Giao Bằng (@c0037)"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên ngăn cường giả bắn."},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Cùng bầy chim non","ghiChu":"Cùng lứa Thanh Lân Ưng ở Thạch thôn."}],"tuiDo":{}},"nguon":["@c0012","@c0021","@c0022","@c0023","@c0047","@c0052","@c0033","@c0036","@c0037","@c0050","@c0068"],"aliases":["Thanh Lân Ưng","Đại thẩm","Lão tam","Thanh Lân Ưng lão tam","Tử Vận","#tu-van-di-cam"]},{"id":"dai-bang-chim","name":"Đại Bằng","gioiTinh":"khong-ro","trangThai":"song","blurb":"Chim non thứ nhất (lão đại) trong ba con Thanh Lân Ưng.","vaiTro":"Linh thú của Thạch Thôn.","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0012","tieuDe":"Được đặt tên và học cốt văn","text":"Lớn nhanh trong một tháng dài gần hai mét, được lũ trẻ đặt tên lão đại Đại Bằng, được Thạch Hạo dạy cốt văn loài người.; Được lũ trẻ đặt tên Đại Bằng, là lão đại trong ba con Thanh Lân Ưng; chỉ một tháng đã dài gần hai mét, được Thạch Hạo dạy cốt văn.; Thanh Lân Ưng lão đại, được lũ trẻ đặt tên. Sau một tháng dài gần hai mét, có linh tính hiểu tiếng người, được Thạch Hạo dạy cốt văn.; Cùng hai chim non khác được lũ trẻ Thạch Thôn đặt tên; là lão…","anchor":"Lão đại tên là Đại Bằng, lão nhị Tiểu Thanh, lão tam Tử Vân."},{"chuong":"@c0017","importance":"minor","tieuDe":"Muốn theo Thạch Hạo vào núi","text":"Cùng Tiểu Thanh và A Tử dụi đầu vào tay Thạch Hạo tỏ vẻ thân thiết, muốn đi theo vào núi nhưng bị dặn ở lại thôn.","anchor":"Đại Bằng, Tiểu Thanh, A Tử tiến lại gần, dùng đầu cọ vào tay nhóc tỳ, tỏ vẻ vô cùng thân thiết, cũng muốn đi theo."},{"importance":"normal","chuong":"@c0022","tieuDe":"Cùng anh em xông tới cứu","text":"Đại Bằng cùng Tử Vân và Tiểu Thanh vô cùng lo lắng cho chim mẹ và Thạch Hạo, chạy ở trên cùng dẫn đầu người Thạch Thôn xông tới tiếp ứng.; Cùng Tử Vân và Tiểu Thanh chạy ở trên cùng, vô cùng lo lắng cho chim mẹ Thanh Lân Ưng, dẫn đầu người Thạch Thôn xông tới nơi Thạch Hạo bị phục kích.","anchor":"Chạy ở trên cùng là Tử Vân, Đại Bằng, Tiểu Thanh ba con chim non đang vô cùng lo lắng."},{"chuong":"@c0023","importance":"normal","tieuDe":"Lấy thân che tên cho chim mẹ","text":"Cùng Tiểu Thanh, Tử Vân vỗ cánh giậm đất xông tới, lấy thân che mưa tên cho chim mẹ Thanh Lân Ưng dù vảy chưa cứng nên bị thương.; Cùng Tiểu Thanh và Tử Vân vỗ cánh giậm đất xông đến, lấy thân che mưa tên cho chim mẹ Thanh Lân Ưng dù vảy chưa cứng.","anchor":"Đại Bằng, Tiểu Thanh, Tử Vân vỗ cánh, giậm đất xông đến."},{"chuong":"@c0036","importance":"normal","tieuDe":"Biến dị lộ mắt vàng kim","text":"Nhờ ăn máu thịt Toan Nghê, Đại Bằng biến hóa thành dị cầm có chân huyết hung cầm Thái cổ, con mắt biến thành màu vàng kim; chạy tới bên nhóc tỳ và bị cường giả nhắm bảo cung.","anchor":"Con mắt Đại Bằng đã biến thành màu vàng kim"},{"text":"Chim non mới nở khoảng ba tháng, rất biết tính người; chấn động hai cánh dùng lực đánh tên sắt của Giao Bằng nhưng vẫn bị thương, máu tươi chảy, vảy xanh rụng mấy cái.; Dùng cánh đập tên sắt của Giao Bằng, vảy xanh rụng mấy cái, máu tươi chảy nhưng vẫn không chịu khuất phục.","anchor":"Đại Bằng kêu lên, chấn động hai cánh, dùng lực đánh tên sắt, mặc dù có vảy cứng bảo vệ nhưng vẫn bị thương, máu tươi chảy xuống, vảy xanh rụng mất mấy cái.","bridge":true,"khoang":"@c0037"},{"importance":"normal","chuong":"@c0052","tieuDe":"Biến dị, dò xét đáy hồ","text":"Sau khi ăn thịt Toan Nghê đã biến dị, thân dài bốn mét bay phá không; toàn thân tỏa hào quang vàng nhạt lao xuống đáy hồ khô cạn để xem xét sinh linh bị vùi lấp.; Đại Bằng cùng Tiểu Thanh sau khi ăn thịt Toan Nghê đã biến dị; nay toàn thân tỏa hào quang vàng nhạt, lao xuống đáy hồ khô cạn xem xét sinh linh bên dưới.; Đại Bằng đã biến dị sau khi ăn thịt Toan Nghê, toàn thân tỏa hào quang vàng nhạt lao xuống đáy hồ khô cạn xem xét sinh linh bị lấp…","anchor":"Đại Bằng toàn thân tỏa hào quang vàng nhạt lao xuống một đoạn gần rồi đi vòng quanh xem xét."},{"chuong":"@c0068","importance":"minor","text":"Cùng Tử Vân, Tiểu Thanh quấn quýt bên Thạch Hạo, đòi đi theo nhưng bị từ chối vì chưa trưởng thành; tiễn hơn trăm dặm rồi quay về. Tuy bất phàm, biết phi thiên độn địa nhưng chưa trưởng thành; trên thân có thể hình thành nguyên thủy bảo cốt.","anchor":"Lúc đó có thể sẽ hình thành nguyên thủy bảo cốt giống như bọn Tử Vân và Đại Bằng ấy."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dạy, dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Người nuôi và dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân/người thân cận","ghiChu":"Thạch Hạo dạy cốt văn cho ba chim non."},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Đồng bào (lão nhị)"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"Đồng bào (lão tam)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Được Thạch Hạo nuôi và nghiên cứu phù văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người nuôi dạy, nghiên cứu phù văn","ghiChu":"@c0012"},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"con của Thanh Lân Ưng mẹ","ghiChu":"@c0012"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"anh em cùng ổ (lão đại)","ghiChu":"@c0012"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"anh em cùng ổ (lão đại)","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được Thạch Hạo lấy thân chắn tên @c0037"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dưỡng, rất thân thiết","ghiChu":"@c0017"},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"Chim mẹ","ghiChu":"Lo lắng khi chim mẹ trọng thương rơi xuống. @c0022"},{"ten":"Thanh Lân Ưng","tag":"ho-hang","quanHe":"Chim non lấy thân che tên cho chim mẹ","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên bảo vệ khi bị nhắm bắn (@c0036)"},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Đi theo học Cốt Văn","ghiChu":"Được Thạch Hạo lấy thân che chở (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ săn","ghiChu":"Bị Giao Bằng bắn trúng vảy rụng (@c0037)"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên ngăn cường giả bắn."},{"ten":"Tiểu Thanh","tag":"ho-hang","quanHe":"Cùng bầy chim non","ghiChu":"Cùng lứa Thanh Lân Ưng ở Thạch thôn."},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"Cùng bầy chim non","ghiChu":"Cùng lứa Thanh Lân Ưng ở Thạch thôn."}],"tuiDo":{}},"nguon":["@c0012","@c0023","@c0047","@c0052","@c0033","@c0036","@c0037","@c0050","@c0017","@c0022","@c0068"],"aliases":["Lão đại","Thanh Lân Ưng lão đại"]},{"id":"tieu-thanh-chim","name":"Tiểu Thanh","gioiTinh":"khong-ro","trangThai":"song","blurb":"Chim non thứ hai (lão nhị) trong ba con Thanh Lân Ưng.","vaiTro":"Linh thú của Thạch Thôn.","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0012","tieuDe":"Được đặt tên và học cốt văn","text":"Lớn nhanh trong một tháng dài gần hai mét, được lũ trẻ đặt tên lão nhị Tiểu Thanh, được Thạch Hạo dạy cốt văn loài người.; Được lũ trẻ đặt tên Tiểu Thanh, là lão nhị trong ba con Thanh Lân Ưng; lớn nhanh trong một tháng, được Thạch Hạo dạy cốt văn.; Thanh Lân Ưng lão nhị, được lũ trẻ đặt tên. Sau một tháng dài gần hai mét, có linh tính hiểu tiếng người, được Thạch Hạo dạy cốt văn.; Cùng hai chim non khác được lũ trẻ Thạch Thôn đặt tên; là lão nh…","anchor":"Lão đại tên là Đại Bằng, lão nhị Tiểu Thanh, lão tam Tử Vân."},{"chuong":"@c0017","importance":"minor","tieuDe":"Quấn quýt bên Thạch Hạo","text":"Cực kỳ thân thiết, dụi đầu vào tay Thạch Hạo, muốn theo cậu vào núi nhưng được dặn ở lại thôn.","anchor":"dùng đầu cọ vào tay nhóc tỳ, tỏ vẻ vô cùng thân thiết"},{"importance":"normal","chuong":"@c0022","tieuDe":"Cùng anh em xông tới cứu","text":"Tiểu Thanh cùng Tử Vân và Đại Bằng vô cùng lo lắng, chạy ở trên cùng dẫn đầu người Thạch Thôn xông tới cứu chim mẹ và Thạch Hạo.; Cùng Tử Vân và Đại Bằng chạy ở trên cùng, vô cùng lo lắng cho chim mẹ Thanh Lân Ưng, dẫn đầu người Thạch Thôn xông tới hiện trường phục kích.","anchor":"Chạy ở trên cùng là Tử Vân, Đại Bằng, Tiểu Thanh ba con chim non đang vô cùng lo lắng."},{"chuong":"@c0023","importance":"normal","tieuDe":"Lấy thân che tên cho chim mẹ","text":"Cùng Đại Bằng, Tử Vân vỗ cánh giậm đất xông tới, dũng cảm lấy thân che mưa tên cho chim mẹ Thanh Lân Ưng.; Cùng Đại Bằng và Tử Vân xông tới lấy thân che tên bảo vệ chim mẹ Thanh Lân Ưng.","anchor":"Đại Bằng, Tiểu Thanh, Tử Vân vỗ cánh, giậm đất xông đến."},{"chuong":"@c0036","importance":"normal","tieuDe":"Biến dị lộ sọc cánh rực rỡ","text":"Cùng biến hóa nhờ máu thịt Toan Nghê, hai cánh Tiểu Thanh xuất hiện lốm đốm sọc rực rỡ, thành dị cầm chân huyết hung cầm Thái cổ; bị cường giả định bắt làm con mồi.","anchor":"hai cánh Tiểu Thanh xuất hiện lốm đốm sọc rực rỡ"},{"text":"Chim non trí tuệ không thua kém nhân loại; trúng tên của Giao Bằng, gào thét, máu văng lên, vảy phòng ngự kém Thanh Lân Ưng trưởng thành nên bị thương.; Bị trúng tên hàn quang của Giao Bằng, phát ra tiếng gào thét, có vòi máu văng lên; vảy phòng ngự kém Thanh Lân Ưng trưởng thành nên bị thương.","anchor":"Tiểu Thanh phát ra tiếng gào thét, có vòi máu văng lên","bridge":true,"khoang":"@c0037"},{"importance":"normal","chuong":"@c0052","tieuDe":"Biến dị sau khi ăn Toan Nghê","text":"Cùng Đại Bằng biến dị sau khi ăn thịt Toan Nghê, thân hiện lên từng đoạn vằn sáng óng ánh; kêu to lao về hướng thung lũng mà thực ra là một hồ nước đã khô cạn.; Tiểu Thanh cùng Đại Bằng đã biến dị sau khi ăn thịt Toan Nghê; khi lao về hướng thung lũng, thân nó hiện lên từng đoạn vằn sáng óng ánh và dẫn cả nhóm tới hồ nước khô cạn.; Tiểu Thanh đã biến dị sau khi ăn thịt Toan Nghê, thân hiện lên từng đoạn vằn sáng óng ánh; kêu to lao về hướng hồ n…","anchor":"nó với Đại Bằng sau khi ăn thịt Toan Nghê cũng đã biến dị"},{"chuong":"@c0068","importance":"minor","text":"Anh em với Tử Vân và Đại Bằng; đòi theo Thạch Hạo nhưng chưa trưởng thành nên không được cho đi, cùng tiễn hơn trăm dặm rồi quay về. Bất phàm, biết phi thiên độn địa nhưng vẫn chưa trưởng thành.","anchor":"Tử Vân, Đại Bằng và Tiểu Thanh mặc dù bất phàm, có thể phi thiên độn địa, nhưng dù sao chúng vẫn chưa trưởng thành."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dạy, dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Người nuôi và dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân/người thân cận"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Đồng bào (lão đại)"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"Đồng bào (lão tam)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Được Thạch Hạo nuôi","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người nuôi dạy, nghiên cứu phù văn","ghiChu":"@c0012"},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"con của Thanh Lân Ưng mẹ","ghiChu":"@c0012"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"anh em cùng ổ (lão nhị)","ghiChu":"@c0012"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"anh em cùng ổ (lão nhị)","ghiChu":"@c0012"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được Thạch Hạo chắn tên bảo vệ @c0037"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dưỡng, rất thân thiết","ghiChu":"@c0017"},{"ten":"Thanh Lân Ưng","tag":"cha-me","quanHe":"Chim mẹ","ghiChu":"Lo lắng khi chim mẹ trọng thương rơi xuống. @c0022"},{"ten":"Thanh Lân Ưng","tag":"ho-hang","quanHe":"Chim non lấy thân che tên cho chim mẹ","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên bảo vệ khi bị nhắm bắn (@c0036)"},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Tử Vân","tag":"ho-hang","quanHe":"Anh em ba chim non","ghiChu":"Ba con chim non cùng chạy tới nhóc tỳ (@c0036)"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Đi theo học Cốt Văn","ghiChu":"Được Thạch Hạo lấy thân che chở (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ săn","ghiChu":"Bị Giao Bằng bắn trúng gào thét (@c0037)"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được nhóc tỳ bảo vệ","ghiChu":"Nhóc tỳ gầm lên ngăn cường giả bắn."},{"ten":"Đại Bằng","tag":"ho-hang","quanHe":"Cùng bầy chim non","ghiChu":"Cùng lứa Thanh Lân Ưng ở Thạch thôn."}],"tuiDo":{}},"nguon":["@c0012","@c0023","@c0047","@c0052","@c0033","@c0036","@c0037","@c0050","@c0017","@c0022","@c0068"],"aliases":["Lão nhị","Thanh Lân Ưng lão nhị"]},{"id":"thach-phuc","name":"Thạch Phúc","aliases":["A Phúc thúc","A Phúc"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Người Thạch Thôn thường hái quả mọng cho nhóc tỳ, bị thương trong vụ Bái Thôn chặn cướp.","vaiTro":"Nhân vật phụ Thạch Thôn.","tabs":{"kinhLich":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Hái quả mọng cho nhóc tỳ","ghiChu":"Được nhóc tỳ an ủi khi bị thương."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Người thân cận, hay hái quả cho Thạch Hạo","ghiChu":"Được Thạch Hạo an ủi khi bị thương @c0013"}],"tuViMoc":[]},"nguon":["@c0013"]},{"id":"cha-nhi-manh","name":"Cha của Nhị Mãnh","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Người Thạch Thôn toàn thân máu, kể lại việc thằng nhóc Bái Thôn bắn tên và lão già lắc đầu.","vaiTro":"Nhân vật phụ Thạch Thôn.","tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0016","tieuDe":"Nổi giận đánh rách mặt Bái Phong","text":"Nổi giận đùng đùng, vung bàn tay to đánh rách mặt Bái Phong trong lúc người Thạch Thôn thay nhau trút giận lên tù binh.; Nổi giận đùng đùng, vung tay to đánh rách mặt Bái Phong trong lúc người Thạch Thôn trút giận tra tấn tù nhân.; Nổi giận đùng đùng vung bàn tay to đánh rách mặt Bái Phong, góp phần khiến hắn gần như không còn hình người trong cuộc trút giận của người Thạch Thôn.","anchor":"trong mắt toàn là oán hận và giận dữ"},{"text":"Khi Nhóc tỳ đá Bái Phong bay tới trước mặt người Thạch thôn, cha của Nhị Mãnh vung kiếm lớn chém bay đầu Bái Phong, kết liễu thiên tài tàn phế của Bái thôn.","anchor":"XẸT một cái chặt bay đầu của Bái Phong rớt ra lăn lông lốc","bridge":true,"khoang":"@c0025"},{"text":"Giải thích cho Nhị Mãnh việc dẫn Hung Giao về nuôi sinh sản là kế lâu dài, đồng thời vỗ đầu răn con khi nó nói lung tung; khí tức bị hắn giấu kín khiến cường giả các tộc không cảm nhận được thực lực, sinh nghi.","anchor":"Cha của Nhị Mãnh 'bốp' một tiếng vỗ vào đầu nó","bridge":true,"khoang":"@c0035"},{"text":"Người Thạch Thôn, ở vùng đất mới nhận ra đàn chim rực rỡ là Ngũ Sắc Kê (Tiểu Loan Điểu), nói từng thấy một con trong núi.","anchor":"hoàn toàn không giống với núi rừng ở ngoài thôn","bridge":true,"khoang":"@c0050"}],"nhanMach":[{"ten":"Nhị Mãnh","tag":"cha-me","quanHe":"Cha của Nhị Mãnh","ghiChu":""},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đánh rách mặt Bái Phong","ghiChu":""},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Người chém đầu Bái Phong","ghiChu":"Ra tay giết Bái Phong @c0025"},{"ten":"Thạch Mãnh","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Cha của Nhị Mãnh @c0013"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ bị chém","ghiChu":"Vung kiếm chém bay đầu Bái Phong @c0025"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ bị ông chém bay đầu","ghiChu":"@c0025"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ bị mình chém đầu","ghiChu":"Chém bay đầu Bái Phong khiến Bái Lý Thanh nổi cơn thù hận (@c0025)"},{"ten":"Nhị Mãnh","tag":"cha-me","quanHe":"Con ruột","ghiChu":"@c0050"}],"tuViMoc":[]},"nguon":["@c0013","@c0016","@c0025","@c0050","@c0035"]},{"id":"thu-linh-doi-san-bai-thon","name":"Thủ lĩnh đội săn Bái Thôn","gioiTinh":"nam","theLuc":[{"ten":"Bái Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Trung niên Bái Thôn vạm vỡ cao 2m4, ngang ngược, thủ lĩnh đội săn khiêu chiến Thạch Thôn.","vaiTro":"Thủ lĩnh đội săn Bái Thôn","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0022","importance":"normal","tieuDe":"Cầm đầu phục kích Thạch Hạo","text":"Hán tử cao hai mét ba bốn cơ bắp cuồn cuộn, dẫn hơn hai mươi người Bái Thôn cầm cung cứng tên sắt vây bắn Thạch Hạo để cướp bảo thể Toan Nghê và sừng, bội thề dù Thạch Thôn từng thả chúng.; Bắn tên sắt sạt qua cổ họng Thạch Hạo mở màn phục kích, dẫn hơn hai mươi người Bái Thôn vây bắt. Bị Bảo Nguyệt chém rách bụng suýt lòi ruột, sắc mặt tái nhợt ra lệnh rút lui.; Bị Bảo Nguyệt của Thạch Hạo chém rách bụng suýt lòi ruột, sắc mặt tái nhợt ra lệnh…","anchor":"một mũi tên sắt lạnh lẽo bắn sạt qua cổ họng nó"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Phục kích Thạch Hạo nhưng bị chém rách bụng","ghiChu":"@c0022"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Đối đầu khai chiến","ghiChu":"Khiêu chiến Thạch Thôn (@c0014)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ bị đánh bại trong cuộc phục kích","ghiChu":"@c0022"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Ngang ngược khiêu chiến Thạch Thôn, đối đầu khi Thạch Phi Giao gầm khai chiến","ghiChu":"@c0014"}],"tuiDo":{}},"nguon":["@c0014","@c0022"]},{"id":"thach-phi-giao","name":"Thạch Phi Giao","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0015)","trangThai":"song","blurb":"Thạch Phi Giao là một trong những cao thủ chủ sự đứng đầu Thạch Thôn, thần lực song thủ đạt năm sáu ngàn cân, luôn sát cánh cùng Thạch Lâm Hổ gánh vác việc phòng thủ và chinh chiến của thôn. Từ những trận huyết chiến với Bái Thôn và hung thú đến khi cùng tộc trưởng tu hành, ông là trụ cột chở che cho tộc nhân và dành nhiều quan tâm cho thiếu niên Thạch Hạo. Cuối cùng, sau khi học Cốt Văn, ông cùng Thạch Lâm Hổ đột phá vào Bàn Huyết cảnh.","vaiTro":"Cao thủ chủ sự của Thạch Thôn, sát cánh cùng Thạch Lâm Hổ","tinhCach":"Hung hãn, cương mãnh trong chiến đấu; trọng tình với người trong tộc, đặc biệt quý mến Thạch Hạo; cẩn trọng, lo xa trước hiểm nguy","tabs":{"diem":[{"text":"Thần lực song thủ đạt năm sáu ngàn cân, là cao thủ ngang hàng Thạch Lâm Hổ trong thôn","chuong":"@c0054"},{"text":"Cùng Thạch Lâm Hổ và tộc trưởng truy sát Bái Thôn, vung đại kiếm chém bay đối thủ khi cầm Tổ Khí","chuong":"@c0027"},{"text":"Chém xác Toan Nghê và phát hiện phù hiệu ấn ký còn giữ trên mảnh xương trán","chuong":"@c0031"},{"text":"Dùng Bảo Thuật diễn hóa Hung Giao thành Hung Tiễn dù đã bị đánh bại thê thảm","chuong":"@c0039"},{"text":"Là người chủ sự Thạch Thôn, cùng tộc trưởng và Thạch Lâm Hổ ứng phó Độc Giác Thú ở vùng đất mới","chuong":"@c0050"},{"text":"Học Cốt Văn rồi cùng Thạch Lâm Hổ đột phá vào Bàn Huyết cảnh","chuong":"@c0086"}],"kinhLich":[{"text":"Thạch Phi Giao vứt Lang Nha Đại Bổng, lấy tấm da thú cổ lấm máu khô ấn lên ngực; da thú dung hợp thành da thịt gã, kết kí tự thần bí hiện bóng hung thú, phát tiếng thú gầm rung núi. Gã cũng kể từng thấy sinh vật hình người cao chọc mây cầm Hắc Thiết Côn trong đại chiến Thái Cổ hai năm trước.; Vứt Lang Nha Đại Bổng, ấn tấm da thú cổ lấm máu khô lên ngực; da thú dung hợp thành da thịt, kết kí tự thần bí, hiện bóng hung thú và phát tiếng thú gầm ru…","anchor":"tấm da thú cũ kĩ cổ xưa không ngờ lại dung hợp làm một cùng với lồng ngực gã","bridge":true,"khoang":"@c0010"},{"text":"Mô tả kẻ ra tay là thằng nhóc Bái Thôn trắng trẻo mà độc ác; về sau đi được nửa đường thì toàn thân đẫm máu tóc bù xù dẫn tộc nhân chạy về, báo Bái Thôn chặn giết cướp số thú săn còn lại. Gã là một trong hai người của thôn bắn xuyên nổi giáp thép.; Mô tả thằng nhóc Bái Thôn độc ác; sau toàn thân đẫm máu dẫn tộc nhân chạy về báo Bái Thôn chặn giết cướp số thú săn còn lại, nhiều người bị thương nặng.","anchor":"nhìn thấy Thạch Phi Giao toàn thân đẫm máu, dẫn theo một đám tộc nhân chạy về","bridge":true,"khoang":"@c0013"},{"text":"Thạch Phi Giao ở Thạch Thôn chứng kiến Thạch Hạo đấu Bái Phong, mắng Bái Phong ác độc khi thiếu niên dùng chiêu tên nỏ giấu sau lưng, dự đoán tiểu tử này sau trưởng thành sẽ là tai họa.; Thạch Phi Giao tức giận mắng Bái Phong ác độc khi hắn giở chiêu bẩn giấu tên nỏ sau lưng bắn lén Thạch Hạo, và dự đoán tiểu tử này sau khi trưởng thành sẽ là một tai họa.; Chứng kiến trận đấu, Thạch Phi Giao tức giận trước sự ác độc trong trận chiến và dự đoán t…","anchor":"hàng loạt điểm sáng khuếch tán ra đánh vỡ toàn bộ tên nỏ","bridge":true,"khoang":"@c0015"},{"text":"Người Thạch Thôn hung hăng, đá một cước làm gãy mấy cây xương ngực Bái Phong, quát mắng đòi bồi thường.; Hung hăng đá một cước làm gãy mấy cây xương ngực của Bái Phong, quát mắng đòi bồi thường trong trận thắng của Thạch Thôn.","anchor":"xương ngực của Bái Phong lập tức đứt mất mấy cây","bridge":true,"khoang":"@c0016"},{"text":"Ức chế vì phải bỏ lỡ di thể Toan Nghê, khi hai con Bưu tấn công Thạch Thôn, anh cùng Thạch Lâm Hổ vung kiếm bản to xông tới nghênh chiến và bị đánh rách bụng trọng thương, sau đó cổ vũ Thạch Hạo.; Ức chế vì bỏ lỡ di thể Toan Nghê; khi hai con Bưu tấn công thôn nhân, vung kiếm bản to cùng Thạch Lâm Hổ xông tới nhưng bị đánh bay vũ khí, rách bụng trọng thương, sau đó cổ vũ Thạch Hạo.","anchor":"Lại là loài Bưu đáng sợ, hơn nữa còn những hai con!","bridge":true,"khoang":"@c0018"},{"text":"Cùng Thạch Lâm Hổ theo lão tộc trưởng Thạch Vân Phong ập tới ứng cứu Thạch Hạo trong trận hỗn chiến với Bái Thôn.; Theo Thạch Vân Phong tới cứu viện Thạch Hạo, cùng người Thạch Thôn giao chiến với Bái Thôn.","anchor":"dẫn đầu chính là lão tộc trưởng Thạch Vân Phong, còn có bọn Thạch Lâm Hổ và Thạch Phi Giao.","bridge":true,"khoang":"@c0023"},{"text":"Túm cái đầu nhầy nhụa máu me của Bái Phong quăng ra xa, bảo người Bái thôn mang về mai táng.; Túm đầu Bái Phong quăng ra xa bảo mang về mai táng; dẫn đội vận chuyển Toan Nghê, sừng đỏ, cánh tay Vượn Ác Ma; cảnh báo bí mật Tổ khí bại lộ sẽ gây phiền toái lớn.; Dẫn đội phụ trách vận chuyển và bảo vệ Toan Nghê, sừng đỏ và cánh tay Vượn Ác Ma; lo lắng bí mật Tổ khí bại lộ sẽ gây phiền toái lớn.","anchor":"Thạch Phi Giao túm cái đầu nhầy nhụa máu me kia quăng ra xa","bridge":true,"khoang":"@c0025"},{"text":"Cầm Tổ Khí truy sát Bái Thôn; sau khi Thạch Lâm Hổ bắn tên trúng lưng Bái Lý Thanh thì vung đại kiếm chém bay đầu ông ta, đồng thời khích lệ Thạch Hạo phải biết sát sinh để sống ở Đại Hoang.","anchor":"Thạch Phi Giao cũng ra tay, vung lên đại kiếm trong tay chém tới","bridge":true,"khoang":"@c0027"},{"text":"Cùng người trong tộc cười vui trước thành tựu đột phá của Thạch Hạo, ví nhóc tỳ tương lai có thể trở thành Chí tôn.","anchor":"Thạch thôn chúng ta tương lai có lẽ sẽ xuất hiện một Chí tôn","bridge":true,"khoang":"@c0029"},{"text":"Thạch Phi Giao cùng chém xác Toan Nghê, rồi phát hiện trên mảnh xương trán vẫn còn giữ được phù hiệu ấn ký nguyên thủy đang chảy ra sức mạnh thần bí. Toan Nghê không kịp tự hủy ấn ký do trước đó phải đánh với Ly Hỏa Ngưu Ma và Ác Ma Viên.; Với thần lực năm sáu nghìn cân, cùng chém xác Toan Nghê và là người phát hiện phù hiệu ấn ký nguyên thủy còn giữ được trên xương trán Toan Nghê.; Cùng chém xác Toan Nghê, Thạch Phi Giao phát hiện trên mảnh xươ…","anchor":"Tộc trưởng, trên mảnh xương này có ký hiệu, có chảy một loại sức mạnh thần bí!","bridge":true,"khoang":"@c0031"},{"text":"Bị đánh bại thê thảm nhưng vẫn hung hăng, dùng Bảo Thuật diễn hóa Hung Giao thành Hung Tiễn bắn lén sau gáy Thạch Hạo; bị cối xay đá đập gãy sống mũi rụng cả hàm răng; sau đó cưỡi Phi Giao đe dọa huyết tẩy Thạch Thôn, lệnh Phi Giao xông xuống.","anchor":"trực tiếp dùng Bảo Thuật diễn hóa Hung Giao thành 'Hung Tiễn', đặt trên dây cung rồi bắn ra, tiến hành chặn giết.","bridge":true,"khoang":"@c0039"},{"text":"Sau khi các thế lực bên ngoài rời đi và nguy cơ qua, Thạch Phi Giao tiến lên vuốt tóc và véo mặt bé Hạo thân thiết như quý mến.; Sau khi nguy cơ đã qua, Thạch Phi Giao thân thiết vuốt mái tóc và véo khuôn mặt nhỏ của nhóc tỳ (bé Hạo), thể hiện sự quý mến với đứa bé.; Sau khi các thế lực rời Thạch thôn và nguy cơ tạm qua, Thạch Phi Giao tiến lên vuốt mái tóc và véo khuôn mặt nhỏ của nhóc tỳ Thạch Hạo, tỏ rõ sự quý mến.","anchor":"Thạch Phi Giao tiến lên, vuốt mái tóc của nó, lại véo véo khuôn mặt nhỏ như quả táo đỏ","bridge":true,"khoang":"@c0041"},{"text":"Sát cánh cùng Thạch Lâm Hổ, Thạch Phi Giao cũng đã phát giác việc Thạch Thôn bị vây từ trước, sẵn sàng ứng phó đại quân bốn tộc.; Cùng Thạch Lâm Hổ nhạy bén phát giác Thạch Thôn bị bốn tộc bao vây từ trước khi nhóc tỳ hô báo động.; Thạch Phi Giao cùng Thạch Lâm Hổ đã phát giác vòng vây của bốn tộc từ trước, cho thấy phản ứng nhanh nhạy khiến cường giả bốn tộc kinh hãi.","anchor":"Thạch Lâm Hổ, Thạch Phi Giao cũng đã phát giác từ lúc trước rồi.","bridge":true,"khoang":"@c0043"},{"text":"Cùng Thạch Lâm Hổ nói nhỏ, bàn tính lo lắng bất an về trận đại chiến kéo dài mấy ngày và sức mạnh thần bí khóa sơn hà, không biết đại họa này sẽ kéo dài bao lâu và giáng xuống thôn thế nào.; Thạch Phi Giao sát cánh cùng Thạch Lâm Hổ nói nhỏ, cả hai lo lắng bất an bàn về trận đại chiến và sức mạnh thần bí đang khóa sơn hà, không biết đại họa sẽ kéo dài bao lâu.","anchor":"Thạch Phi Giao và Thạch Lâm Hổ nói nhỏ, hai người lo lắng bất an không biết trận đại họa này sẽ kéo dài bao lâu","bridge":true,"khoang":"@c0047"},{"text":"Là người chủ sự Thạch Thôn, cùng tộc trưởng và Thạch Lâm Hổ ứng phó khi gặp Độc Giác Thú ở vùng đất mới; biến sắc không còn nhìn chằm chằm mãnh thú khi nghe nhóc tỳ nhắc ký ức.; Là thành viên cốt cán, cùng tộc trưởng và Thạch Lâm Hổ ứng phó ở vùng đất mới, bàn chuyện bắt Độc Giác Thú; biến sắc khi nhóc tỳ nhắc ký ức mơ hồ về vùng đất.; Là thành viên cốt cán cùng tộc trưởng ứng phó mãnh thú, bàn chuyện bắt đàn Độc Giác Thú ánh bạc ở vùng đất mới…","anchor":"kể cả là mấy người Thạch Lâm Hổ và Thạch Phi Giao cũng biến sắc, không còn nhìn chằm chằm Độc Giác Thú nữa","bridge":true,"khoang":"@c0050"},{"text":"Cùng mấy người cẩn thận muốn kéo nhóc tỳ đi khỏi tước đỏ vì lo cho an nguy của cậu.","anchor":"từ xa một con chim nhỏ đỏ như lửa đại chiến ở trong Thương Mãng Sơn Mạch","bridge":true,"khoang":"@c0051"},{"text":"Hỏi dồn Thạch Hạo về kết quả thám sát vùng tử địa sau khi nó dò xét về.","anchor":"Cương vực một trăm ngàn dặm đã thành một vùng tử địa","bridge":true,"khoang":"@c0052"},{"text":"Sau gần một năm tu hành theo tộc trưởng, nhận ra ba đầu sáu tay của sinh linh chính là Bảo Thuật vô thượng trong truyền thuyết thời cổ đại.; Đã tu hành theo tộc trưởng gần một năm, nhận ra ba đầu sáu tay của sinh linh là Bảo Thuật vô thượng trong truyền thuyết.","anchor":"Sinh linh nhìn giống như khỉ này đột nhiên tỏa kim quang khắp người","bridge":true,"khoang":"@c0053"},{"text":"Cao thủ của thôn ngang hàng Thạch Lâm Hổ, hai tay đạt tới năm sáu ngàn cân thần lực song chưa vào Bàn Huyết cảnh — cùng làm mốc đo sức mạnh khác thường của Thạch Hạo.","anchor":"trấn áp bọn Thạch Lâm Hổ, Thạch Phi Giao mà hai tay bọn họ cũng đã mạnh đến năm sáu ngàn cân thần lực","bridge":true,"khoang":"@c0054"},{"text":"Kích động khẳng định dựa vào đỉnh cổ tổ truyền cộng máu vàng Chu Yếm, thuốc Thạch Thôn nấu ra không kém cổ quốc.","anchor":"Đây đã coi là một lô thuốc quý rồi!","bridge":true,"khoang":"@c0065"},{"text":"Thanh niên trưởng thành Thạch Thôn, cùng Thạch Lâm Hổ nhiều ngày lên kế hoạch bắt Độc Giác Thú mà không dám ra tay; thán phục thân pháp và thần lực của Thạch Hạo khi nó bắt sống được một con.","anchor":"Kể cả là đám thanh niên trưởng thành như Thạch Lâm Hổ hay Thạch Phi Giao cũng vẫn đang lên kế hoạch.","bridge":true,"khoang":"@c0068"},{"text":"Cùng Thạch Lâm Hổ đứng đầu thôn giương Long Giác Cung phòng thủ hung khấu; cảm thấy vô lực trước Tế Linh Xuyên Sơn Giáp; bị đầu lĩnh hung khấu quất roi Phù Văn làm da thịt mặt tóe máu; cùng cha Nhị Mãnh phẫn nộ đòi mang Tổ Khí ra liều 'cá chết lưới rách' nhưng bị tộc trưởng ngăn lại.","anchor":"trên mặt đám người Thạch Lâm Hổ và Thạch Phi Giao bỗng vang lên tiếng đùng một cái, da thịt tóe ra","bridge":true,"khoang":"@c0079"},{"text":"Dẫn nhóm người Thạch thôn tiến lên cầm trọng khí đập bọn hung khấu đã bị Thạch Hạo đánh gục, mỗi đập một vòi máu phọt, đám hung đồ nằm rạp trên mặt đất van xin tha mạng.","anchor":"mỗi một đập đều có một vòi máu phọt lên","bridge":true,"khoang":"@c0081"},{"importance":"normal","chuong":"@c0086","tieuDe":"Đột phá Bàn Huyết cảnh","text":"Học Cốt Văn từ khi tộc trưởng về từ ngoại giới, cùng Thạch Lâm Hổ thăng cấp vào Bàn Huyết cảnh với tu vi thâm hậu; có con gái đòi đính hôn với nhóc tỳ.","anchor":"Thạch Lâm Hổ và Thạch Phi Giao cùng thăng cấp vào Bàn Huyết cảnh"},{"text":"Nghe tin liền cùng đám người chạy đến, cả kinh lo lắng cho chuyến đi nguy hiểm của nhóc tỳ vào nơi rèn luyện của Thần Linh.","anchor":"Nơi có thể chiến đấu với thú con của các loài Cùng Kỳ, Tất Phương, Tiêu Đồ","bridge":true,"khoang":"@c0087"}],"tuViMoc":[{"chuong":"@c0086","canhGioi":"Bàn Huyết cảnh","text":"Cùng Thạch Lâm Hổ đột phá vào Bàn Huyết cảnh.","importance":"major"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Người cùng Thạch Thôn","ghiChu":"Bênh Thạch Hạo, mắng Bái Phong khi hắn dùng chiêu bẩn."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Người thôn đối địch","ghiChu":"Mắng Bái Phong ác độc, dự đoán hắn sẽ thành tai họa."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đá gãy xương Bái Phong","ghiChu":""},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến Bái Thôn","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Đồng tộc Thạch Thôn","ghiChu":"Nhường Tổ Khí da thú cho nhóc tỳ vì Cốt Văn nhóc tỳ cao hơn (@c0026)"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Chém bay đầu tộc trưởng Bái Thôn."},{"ten":"Thằng nhóc Bái Thôn","tag":"doi-thu","quanHe":"Kẻ chặn cướp đoàn Thạch Thôn","ghiChu":"Bắn xuyên giáp ba lớp @c0013"},{"ten":"Thủ lĩnh đội săn Bái Thôn","tag":"doi-thu","quanHe":"Đối đầu khai chiến","ghiChu":"Gầm chiến trước sự khiêu chiến của thủ lĩnh Bái Thôn (@c0014)"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ Bái Thôn","ghiChu":"Mắng Bái Phong ác độc, dự đoán hắn thành tai họa (@c0015)."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Kẻ thù, tộc trưởng Bái Thôn","ghiChu":"Phi Giao chém bay đầu Bái Lý Thanh (@c0027)"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Chém bay đầu Bái Lý Thanh."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Tộc nhân","ghiChu":"Khích Thạch Hạo tự tay giết Bái Sơn."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng chiến binh Thạch Thôn","ghiChu":"Cùng tế tổ khí đối kháng Thanh Lân Ưng (@c0010)."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đá gãy xương ngực Bái Phong","ghiChu":"@c0016"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Theo tộc trưởng tới cứu viện","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Người được nhường Tổ Khí","ghiChu":"Giao Tổ Khí da thú cho nhóc tỳ dùng."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Đối thủ bị Phi Giao chém đầu","ghiChu":"Vung đại kiếm chém bay đầu tộc trưởng Bái Thôn sau khi ông ta trúng tên của Thạch Lâm Hổ."},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Đàn em được Phi Giao khích lệ","ghiChu":"Khích Thạch Hạo giết người: nam nhi sống ở Đại Hoang sao có thể không sát sinh."},{"ten":"Thủ lĩnh đội săn Bái Thôn","tag":"doi-thu","quanHe":"Gầm lên khai chiến khi Bái Thôn ngang ngược khiêu chiến, dẫn tới hai bên hỗn chiến","ghiChu":"@c0014"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Người được mình nhường Tổ Khí thứ hai (da thú)","ghiChu":"Nhường vì Cốt Văn của nhóc tỳ cao thâm hơn @c0026"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Kẻ thù bị giết","ghiChu":"Phi Giao vung đại kiếm chém bay đầu tộc trưởng Bái Thôn Bái Lý Thanh (@c0027)."},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Tộc trưởng địch bị Phi Giao chém đầu","ghiChu":"Chém bay đầu Bái Lý Thanh @c0027"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng ra lệnh tế tổ khí","ghiChu":"@c0010"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Thiếu niên Bái Thôn bị Thạch Phi Giao cảnh báo","ghiChu":"Mắng Bái Phong ác độc, dự đoán thành tai họa (@c0015)"},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Theo lão tộc trưởng đi cứu viện","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đàn em cùng thôn","ghiChu":"Khích lệ Thạch Hạo phải biết sát sinh trong cuộc truy sát Bái Thôn (@c0027)"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Vung đại kiếm chém bay đầu tộc trưởng Bái Thôn","ghiChu":"@c0027"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Khích lệ Thạch Hạo phải biết sát sinh để sống ở Đại Hoang","ghiChu":"@c0027"},{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Suýt bị nhóc tỳ đẩy ngã khi thử thần lực sau lột xác dù bản thân có khí lực năm sáu nghìn cân.","ghiChu":"@c0032"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Tộc trưởng Bái Thôn bị Phi Giao chém đầu","ghiChu":"@c0027"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đồng tộc, khích lệ Thạch Hạo sát sinh","ghiChu":"@c0027"},{"ten":"Thủ lĩnh bộ lạc Kim Lang","tag":"doi-thu","quanHe":"Dò hỏi Sơn bảo","ghiChu":"Thủ lĩnh Kim Lang bắt chuyện dò hỏi Sơn bảo (@c0036)"},{"ten":"Thạch Lâm Hổ","tag":"ban-be","quanHe":"Bạn thân cùng thôn, luôn sát cánh","ghiChu":"Cùng lo lắng bất an về đại họa (@c0047)"},{"ten":"Thủ lĩnh bộ lạc Kim Lang","tag":"doi-thu","quanHe":"Bị dò hỏi Sơn bảo","ghiChu":"Thủ lĩnh Kim Lang bắt chuyện dò Sơn bảo."},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người trong Thạch thôn, quý mến bé Hạo","ghiChu":"Vuốt tóc, véo mặt bé Hạo sau khi nguy cơ qua"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng thôn, hành động ăn ý sát cánh","ghiChu":"Cùng phát giác vòng vây bốn tộc @c0043"},{"ten":"Thạch Lâm Hổ","tag":"ban-be","quanHe":"Thân thiết, luôn sát cánh"},{"ten":"Thạch Vân Phong","tag":"dong-minh","quanHe":"Cùng là chủ sự / tộc trưởng Thạch Thôn","ghiChu":"@c0050"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Cùng chủ sự Thạch Thôn","ghiChu":"@c0050"},{"ten":"Thủ lĩnh bộ lạc Kim Lang","tag":"doi-thu","quanHe":"Bị dò hỏi","ghiChu":"Thủ lĩnh bộ lạc Kim Lang bắt chuyện Thạch Phi Giao để dò hỏi về Sơn bảo trên núi (@c0036)."},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người thôn thân thiết","ghiChu":"Quý mến nhóc tỳ, hay vuốt tóc véo mặt nó"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Người Thạch thôn thân thiết, luôn sát cánh","ghiChu":"Cùng nói nhỏ, lo lắng bất an về đại họa (@c0047)"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng đội đứng đầu thôn","ghiChu":"Cùng phòng thủ Thạch Thôn @c0079"},{"ten":"Đầu lĩnh hung khấu vết đao","tag":"doi-thu","quanHe":"Kẻ đánh rách mặt @c0079"}],"tuiDo":{}},"nguon":["@c0015","@c0016","@c0017","@c0018","@c0023","@c0025","@c0026","@c0027","@c0029","@c0031","@c0043","@c0047","@c0050","@c0053","@c0032","@c0010","@c0013","@c0014","@c0036","@c0041","@c0039","@c0051","@c0052","@c0054","@c0065","@c0068","@c0079","@c0081","@c0086","@c0087"],"aliases":["Phi Giao"]},{"id":"bai-ly-thanh","name":"Lão già Bái Thôn","cn":"","aliases":["Tộc trưởng Bái Thôn","lão già Bái Thôn"],"gioiTinh":"nam","theLuc":[{"ten":"Bái Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Người lớn tuổi trong Bái Thôn lắc đầu ngăn, nhờ đó thằng nhóc không giết thêm nhiều người Thạch Thôn. (+) Lão tộc trưởng Bái Thôn giả nhân từ, dùng mưu phục kích cướp bảo thể Toan Nghê. [CAN-SOAT-GOP]","vaiTro":"Tộc trưởng Bái Thôn, kẻ cầm đầu cuộc phục kích Thạch Hạo.","tinhCach":[{"text":"Giả nhân từ, thâm hiểm, sẵn sàng phá quy củ Đại Hoang vì lợi ích tộc","chuong":"@c0023"}],"tabs":{"diem":[{"text":"Giả khuyên nhủ để trói chân đối phương rồi ra lệnh giết","chuong":"@c0023"}],"kinhLich":[{"text":"Trong vụ Bái Thôn chặn cướp thú săn, một lão già Bái Thôn lắc đầu ngăn cản, nhờ đó thằng nhóc mới không giết thêm nhiều người Thạch Thôn.","anchor":"lại là bọn Bái Thôn, chúng nó chặn giết chúng ta, cướp đi số thú săn còn lại","bridge":true,"khoang":"@c0013"},{"chuong":"@c0023","importance":"normal","tieuDe":"Chỉ huy phục kích cướp Toan Nghê","text":"Lão tộc trưởng Bái Thôn dẫn hơn trăm người phục kích, giả nhân từ khuyên Thạch Hạo giao bảo thể Toan Nghê nhưng thực chất định giết cả nhóc lẫn hung cầm, ra lệnh bắn Thanh Lân Ưng để trói chân đối thủ.; Lão tộc trưởng Bái Thôn giả nhân từ khuyên Thạch Hạo giao bảo thể rồi ra lệnh bắn Thanh Lân Ưng để trói chân nhóc, tiết lộ Tế Linh của tộc sắp đột phá nên cần gấp một lượng lớn chân huyết, bất chấp quy củ Đại Hoang mà khai chiến với Thạch Thôn.…","anchor":"Bắn tên, trước tiên giết con Thanh Lân Ưng kia đã!"},{"chuong":"@c0025","importance":"normal","tieuDe":"Mất cháu đích tôn Bái Phong","text":"Cháu đích tôn Bái Phong bị người Thạch thôn chém bay đầu ngay trước mặt, Bái Lý Thanh đau đớn kêu than, thù hận dâng cao.; Đau đớn vì Bái Phong (cháu đích tôn) bị chém đầu, Bái Lý Thanh cưỡi sói trắng bạc dẫn thanh niên Bái thôn cưỡi sói trở lại đòi diệt Thạch thôn; khi Tế Linh áp sát, hô mọi người mau leo lên lưng sói nhưng không kịp.; Cưỡi con sói trắng bạc dẫn thanh niên Bái thôn cưỡi sói quay lại vây Thạch thôn, cùng thú triều do con bái già…","anchor":"XẸT một cái chặt bay đầu của Bái Phong rớt ra lăn lông lốc"},{"chuong":"@c0027","importance":"major","tieuDe":"Tử trận dưới truy sát Thạch Thôn","text":"Tộc trưởng Bái Thôn dẫn tàn quân suy sụp sau thú triều bị Thạch Thôn truy sát; trúng tên của Thạch Lâm Hổ vào lưng, rống lên hận thù rồi bị Thạch Phi Giao vung đại kiếm chém bay đầu.","anchor":"một cái đầu nhuốm máu bay nghiêng ra xa mấy mét rồi rơi xuống đất"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ thù, kẻ mưu cướp bảo thể và giết nhóc","ghiChu":"Ra lệnh vây giết Thạch Hạo @c0023"},{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Bị Thạch Vân Phong quát vì phá quy củ Đại Hoang","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"ho-hang","quanHe":"Cháu đích tôn","ghiChu":"Đau đớn vì Bái Phong bị chém đầu @c0025"},{"ten":"Bái Sơn","tag":"su-mon","quanHe":"Trưởng đội săn dưới quyền","ghiChu":"@c0025"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Lâm Hổ bắn tên trúng lưng."},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Phi Giao chém bay đầu."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Mục tiêu phục kích để cướp bảo thể Toan Nghê","ghiChu":"@c0023"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Kẻ giết mình","ghiChu":"Phi Giao chém bay đầu Bái Lý Thanh (@c0027)"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Lâm Hổ bắn tên trúng lưng ông ta (@c0027)"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Bị Phi Giao chém bay đầu."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhắm cướp bảo thể Toan Nghê, mưu giết Thạch Hạo","ghiChu":"@c0023"},{"ten":"Bái Sơn","tag":"dong-minh","quanHe":"Thủ lĩnh săn thú dưới trướng, cùng phục kích","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"dong-minh","quanHe":"Thiếu niên thiên tài cùng tộc, dùng Bảo Cụ tập kích Thạch Hạo","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"ho-hang","quanHe":"Cháu đích tôn, bị Thạch thôn chém đầu","ghiChu":"@c0025"},{"ten":"Bái Sơn","tag":"su-mon","quanHe":"Trưởng đội săn Bái thôn dưới quyền","ghiChu":"@c0025"},{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Tộc trưởng Thạch thôn đối địch","ghiChu":"@c0025"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Kẻ chém đầu Bái Lý Thanh","ghiChu":"Vung đại kiếm chém bay đầu Bái Lý Thanh trong cuộc truy sát diệt Bái Thôn."},{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Tộc trưởng đối địch","ghiChu":"Bị Thạch Vân Phong quát phá quy củ Đại Hoang khi dẫn người tới cứu. @c0023"},{"ten":"Bái Sơn","tag":"dong-minh","quanHe":"Cùng Bái thôn","ghiChu":"Cùng dẫn quân Bái thôn trở lại đòi diệt Thạch thôn."},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Kẻ giết","ghiChu":"Bị Phi Giao chém bay đầu (@c0027)."},{"ten":"Bái Sơn","tag":"su-mon","quanHe":"Đồng tộc Bái Thôn","ghiChu":"Cùng thuộc Bái Thôn @c0027"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bày mưu vây giết để cướp bảo thể Toan Nghê","ghiChu":"@c0023"},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Kẻ chém đầu cháu mình","ghiChu":"Vung kiếm chặt bay đầu Bái Phong (@c0025)"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Bị Phi Giao chém bay đầu","ghiChu":"@c0027"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Bị Lâm Hổ bắn tên trúng lưng","ghiChu":"@c0027"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Bị Thạch Lâm Hổ bắn tên trúng lưng","ghiChu":"@c0027"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Bị Thạch Phi Giao chém bay đầu","ghiChu":"@c0027"},{"ten":"Thằng nhóc Bái Thôn","tag":"su-mon","quanHe":"Trưởng bối ngăn hắn","ghiChu":"Lắc đầu ngăn thằng nhóc giết thêm @c0013"}],"tuiDo":{}},"nguon":["@c0023","@c0024","@c0025","@c0027","@c0013"]},{"id":"bai-son","name":"Bái Sơn","cn":"","aliases":["Thủ lĩnh đội săn thú Bái Thôn","thủ lĩnh đội săn thú Bái Thôn"],"gioiTinh":"nam","theLuc":[{"ten":"Bái Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Thủ lĩnh đội săn thú Bái Thôn, núp bắn xuyên tay Thạch Hạo.","vaiTro":"Thủ lĩnh săn thú Bái Thôn, tay bắn cung tập kích.","tinhCach":[{"text":"Hiểm độc, chuyên núp tập kích","chuong":"@c0023"}],"tabs":{"diem":[{"text":"Trước bị trăng bạc rạch bụng, sau núp lùm cây bắn lén","chuong":"@c0023"}],"kinhLich":[{"text":"Thủ lĩnh đội săn thú Bái Thôn, sắc mặt tái nhợt vì trước bị trăng bạc rạch bụng, núp trong lùm cây nhắm tim và yết hầu, bắn xuyên tay Thạch Hạo.","anchor":"chính hắn đã bắn tên xuyên tay của nhóc tỳ","bridge":true,"khoang":"@c0023"},{"chuong":"@c0025","importance":"normal","tieuDe":"Đòi diệt Thạch thôn sát nhập","text":"Trưởng đội săn Bái thôn, bắn trộm và đòi diệt Thạch thôn, bắt phụ nữ trẻ con để sát nhập hai thôn giúp Tế linh tộc đột phá; cùng lúc con bái già triệu thú triều càn quét.; Khi Bái Lý Thanh cưỡi sói dẫn quân trở lại, Bái Sơn (trưởng đội săn) đòi diệt tộc, bắt phụ nữ trẻ con để sát nhập hai thôn giúp Tế linh tộc đột phá; dùng cung tên bắn trộm.","anchor":"con bái già đáng chết kia đuổi đến một đám thú lớn muốn càn quét nơi này"},{"chuong":"@c0027","importance":"major","tieuDe":"Bị Thạch Hạo chém đầu","text":"Thủ lĩnh đội săn thú Bái Thôn cao hơn 2m3, cơ bắp ánh đồng cổ, kẻ từng bắn lén xuyên cánh tay Thạch Hạo; trong cuộc truy sát lại bắn lén Thạch Hạo lần nữa nhưng bị cậu dùng vòng răng thú đánh gãy tứ chi rồi chém chết.","anchor":"Bốn mươi hai cái răng thú óng ánh phân biệt bay ra"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ, bắn lén xuyên tay","ghiChu":"@c0023"},{"ten":"Bái Lý Thanh","tag":"su-mon","quanHe":"Cùng Bái thôn, dưới quyền tộc trưởng","ghiChu":"Cùng dẫn quân báo thù @c0025"},{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Đối đầu — đòi diệt Thạch thôn","ghiChu":"@c0025"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Bắn lén Thạch Hạo hai lần, bị cậu chém chết."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Núp bắn lén xuyên tay Thạch Hạo trong trận phục kích","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ giết mình","ghiChu":"Bái Sơn bắn lén Thạch Hạo rồi bị cậu đánh gãy tứ chi và chém đầu (@c0027)"},{"ten":"A Văn thúc","tag":"doi-thu","quanHe":"Nạn nhân","ghiChu":"Bái Sơn từng bắn xuyên lồng ngực A Văn thúc của Thạch Thôn (@c0027)"},{"ten":"Bái Lý Thanh","tag":"su-mon","quanHe":"Tộc trưởng Bái Thôn ra lệnh phục kích","ghiChu":"@c0023"},{"ten":"Bái Lý Thanh","tag":"su-mon","quanHe":"Cùng Bái thôn, phối hợp đòi diệt Thạch thôn","ghiChu":"@c0025"},{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Đối đầu, đòi diệt tộc Thạch thôn","ghiChu":"@c0025"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ giết Bái Sơn","ghiChu":"Bái Sơn bắn lén xuyên cánh tay Thạch Hạo; cuối cùng bị Thạch Hạo đánh gãy tứ chi rồi chém đầu."},{"ten":"A Văn thúc","tag":"doi-thu","quanHe":"Nạn nhân của Bái Sơn","ghiChu":"Bị Bái Sơn bắn xuyên lồng ngực; mối thù này thôi thúc Thạch Hạo giết Bái Sơn."},{"ten":"Bái Lý Thanh","tag":"su-mon","quanHe":"Cùng Bái thôn","ghiChu":"Cưỡi sói dẫn quân cùng Bái Lý Thanh trở lại đòi diệt Thạch thôn."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ thù giết mình","ghiChu":"Bắn lén Thạch Hạo hai lần; bị Thạch Hạo dùng vòng răng thú gãy tứ chi rồi chém đầu (@c0027)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ bị Thạch Hạo giết","ghiChu":"Bắn lén Thạch Hạo, bị chém đầu @c0027"},{"ten":"Bái Lý Thanh","tag":"su-mon","quanHe":"Đồng tộc Bái Thôn","ghiChu":"Cùng thuộc Bái Thôn @c0027"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nạn nhân bị bắn lén","ghiChu":"Bái Sơn bắn lén Thạch Hạo, bị cậu giết trong cuộc truy sát Bái Thôn (@c0027)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bắn lén xuyên cánh tay Thạch Hạo, sau bị cậu giết chết","ghiChu":"@c0027"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bắn lén Thạch Hạo, cuối cùng bị cậu chém chết","ghiChu":"@c0027"},{"ten":"A Văn thúc","tag":"doi-thu","quanHe":"Từng bắn xuyên lồng ngực A Văn thúc của Thạch Thôn","ghiChu":"Hồi tưởng @c0027"}],"tuiDo":{}},"nguon":["@c0023","@c0024","@c0025","@c0027"]},{"id":"bai-phong","name":"Thiếu niên trên cáng (Bái Thôn)","cn":"","aliases":["Thiếu niên trên cáng (Bái Thôn)","Thiếu niên Bái Thôn","nhóc tỳ (Bái Phong)","thằng nhóc Bái Thôn","cha-me-nhoc-ty","#thieu-nien-cang-bai-thon","Tiểu Thạch Hạo","Nhóc tỳ Thạch Thôn"],"gioiTinh":"nam","theLuc":[{"ten":"Bái Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Thiếu niên Bái Thôn chừng mười bốn mười lăm tuổi, trắng trẻo đẹp trai nhưng độc ác, bắn tên lạnh lùng xuyên thủng giáp ba lớp. (+) Thiếu niên thiên tài Bái Thôn từng thua Thạch Hạo, dùng Bảo Cụ vòng răng thú tập kích báo thù. (+) Thiếu niên Bái Thôn sắc mặt tái, ánh mắt lạnh, đi cùng viện binh Bái Thôn. [CAN-SOAT-GOP] (+) Thiếu niên Bái Thôn chừng 14-15 tuổi, tuấn tú nhưng ánh mắt lạnh tàn khốc, thần tiễn thủ với cung sừng rồng, thần lực ngang cơ người mạnh nhất Thạch Thôn. [CAN-SOAT-GOP]","vaiTro":"Thiên tài Bái Thôn, đối thủ ôm hận Thạch Hạo.","tinhCach":[{"text":"Ôm hận, lạnh lùng tập kích; tự nhận lần trước quá hiền lành nên thả đối phương, lần này quyết không tha","chuong":"@c0023"}],"tabs":{"diem":[{"text":"Cốt Văn còn dùng được cả Bảo Cụ khiến đám đông kinh ngạc","chuong":"@c0023"},{"text":"Thiếu niên 14-15 tuổi đã ngang cơ người mạnh nhất Thạch Thôn, thần lực nâng đỉnh đồng năm sáu ngàn cân.","chuong":"@c0014"}],"kinhLich":[{"importance":"normal","chuong":"@c0015","tieuDe":"Bại dưới tay Thạch Hạo","text":"Thiếu niên thiên tài mười bốn tuổi của Bái Thôn, thần lực kinh người, dùng cung tên sắt, trường mâu Huyết Văn Thiết rồi mảng tên nỏ giấu sau lưng liên tiếp tấn công Thạch Hạo nhưng đều bị hóa giải; cuối cùng bị đánh phun máu văng ngang, đụng gãy cành cây đại thụ mà trọng thương.; Bái Phong mười bốn tuổi, thần lực kinh người rung tay nâng năm sáu đỉnh đồng, dùng cung tên sắt, trường mâu Huyết Văn Thiết và tên nỏ giấu sau lưng đánh Thạch Hạo nhưng…","anchor":"Bái Phong phun ra một bụm máu tươi, người bay ngang ra, đụng gãy rất nhiều cành cây đại thụ"},{"importance":"normal","chuong":"@c0016","tieuDe":"Bị bắt và tra tấn thê thảm","text":"Thiếu niên thiên tư của Bái Thôn bị Thạch Hạo hạ gục, bắt sống làm tù binh; Thạch Phi Giao, cha Nhị Mãnh cùng nhiều người thay nhau đá đấm khiến gãy nhiều xương, mặt rách, gần như không còn hình người. Cuối cùng được thả sau khi Bái Thôn giao nộp vũ khí bồi thường.; Thiếu niên thiên tư của Bái Thôn bị Thạch Hạo hạ gục và bắt sống, bị người Thạch Thôn thay nhau đá đấm gãy nhiều xương, mặt rách, gần không còn hình người; Bái Thôn phải giao vũ khí…","anchor":"xương ngực của Bái Phong lập tức đứt mất mấy cây"},{"chuong":"@c0023","importance":"normal","tieuDe":"Vòng răng thú, quyết không tha","text":"Mưa ánh sáng vờn quanh cổ tay hóa thành vòng răng thú trắng óng — khiến đám đông kinh ngạc vì Cốt Văn cũng dùng được Bảo Cụ; thấy đám trung niên bị mình đánh trọng thương, y vẫn giương tay phóng tiếp, tuyên bố lần này quyết không tha.; Thiếu niên thiên tài từng bị Thạch Hạo đánh bại và bị người Thạch Thôn đánh gãy xương, nay núp tập kích bằng Bảo Cụ phóng điểm sáng đánh xuyên sáu bảy người Thạch Thôn, làm rách vai và suýt xuyên yết hầu Thạch Hạo…","anchor":"hóa thành một cái vòng răng thú, cái nào cũng trắng tinh óng ánh"},{"importance":"normal","chuong":"@c0024","tieuDe":"Bại trận, bị cắt tứ chi tàn phế","text":"Bái Phong dùng Bảo cụ 42 răng thú áp đảo nhóc tỳ nhưng bị đảo ngược khi nhóc tỳ ngộ thêm tầng Bảo thuật; hắn bị đá gãy gò má trái, gãy xương sườn, ngực bể nát rồi bị trăng bạc cắt đứt cả hai tay hai chân, tàn phế và mất luôn Bảo cụ.; Dùng Bảo cụ 42 răng thú áp chế nhóc tỳ nhưng kinh hãi phát hiện đối thủ vận dụng sức mạnh Cốt văn thần bí; khi nhóc tỳ ngộ thêm tầng Bảo thuật, Bái Phong bị đánh phọt máu, đá vỡ nửa mặt và ngực, gãy xương, cuối cùng…","anchor":"hay tay hai chân Bái Phong đều bị cắt đứt"},{"chuong":"@c0025","importance":"major","tieuDe":"Bị chém đầu chết","text":"Sau khi bị tàn phế và mất Bảo cụ, Bái Phong bị Nhóc tỳ đá bay tới trước mặt người Thạch thôn, bị cha Nhị Mãnh vung kiếm chém bay đầu; Thạch Phi Giao quăng đầu bảo mang về mai táng.","anchor":"XẸT một cái chặt bay đầu của Bái Phong rớt ra lăn lông lốc"},{"importance":"normal","chuong":"@c0013","tieuDe":"Bắn xuyên giáp ba lớp","text":"Trong vụ Bái Thôn chặn cướp thú săn, chính hắn bắn tên xuyên thủng cả ba lớp giáp thép tinh chế của người Thạch Thôn, bắn trọng thương nhiều người; nhờ một lão già Bái Thôn lắc đầu ngăn mới không giết thêm.; Trong vụ chặn cướp thú, ra tay bắn xuyên toàn bộ ba lớp giáp thép tinh chế của người Thạch Thôn, khiến nhiều người bị thương nặng; chỉ nhờ lão già Bái Thôn lắc đầu mới không giết thêm.; Thiếu niên Bái Thôn khoảng 14-15 tuổi, trắng trẻo đẹp t…","anchor":"mấy huynh đệ trước ngực đều lót ba lớp giáp thép tinh chế dày, nhưng toàn bộ đều bị nó bắn xuyên"},{"importance":"normal","chuong":"@c0022","tieuDe":"Thưởng thức vòng răng thú","text":"Đi theo đoàn viện binh Bái Thôn tới hiện trường phục kích, thưởng thức vòng răng thú trong khi các ông già bàn về việc Tế Linh sẽ tự đến vì bảo thể Toan Nghê.; Nằm trên cáng thưởng thức vòng răng thú, đi cùng làn sóng viện binh Bái Thôn đang kéo tới sau khi đội săn thú rút lui.","anchor":"ba con chim non đang vô cùng lo lắng"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ thù, từng thua Thạch Hạo nay tập kích báo thù","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đánh bại, tàn phế và cướp Bảo cụ"},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Người chém đầu mình","ghiChu":"@c0025"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đấu tiễn ngang tài","ghiChu":"Hai bên bắn nhau mười mấy hiệp (@c0014)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ nhắm giết nhóc tỳ Thạch Thôn","ghiChu":"Bắn 4 mũi tên vào Thạch Hạo (@c0014)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ địch","ghiChu":"Bị Thạch Hạo đánh bại trong lần chạm mặt đầu (@c0015)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ — bị nhóc tỳ đá gục và bắt sống","ghiChu":"@c0016"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Từng thua Thạch Hạo, ôm hận và dùng Bảo Cụ tập kích trả thù","ghiChu":"@c0023"},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Kẻ chém đầu","ghiChu":"Vung kiếm lớn chặt bay đầu Bái Phong @c0025"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Kẻ đá bay","ghiChu":"Đá Bái Phong bay tới trước người Thạch thôn @c0025"},{"ten":"Bái Lý Thanh","tag":"ho-hang","quanHe":"Ông nội (cháu đích tôn)","ghiChu":"Bái Phong là cháu đích tôn, cái chết khiến Bái Lý Thanh đau đớn @c0025"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đánh bại, tàn phế Bái Phong và cướp Bảo cụ răng thú","ghiChu":"@c0024"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đứa bé Thạch Thôn đánh bại Bái Phong","ghiChu":"@c0015"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ Thạch Hạo đá gục và bắt sống","ghiChu":"@c0016"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Bị Thạch Lâm Hổ dọa chặt đầu ép Bái Thôn thỏa hiệp","ghiChu":"@c0016"},{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Bị Thạch Phi Giao đá gãy xương ngực","ghiChu":"@c0016"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Ôm hận vì từng thua, tập kích lạnh lùng bằng Bảo Cụ","ghiChu":"@c0023"},{"ten":"Bái Lý Thanh","tag":"dong-minh","quanHe":"Cùng tộc Bái Thôn phục kích Thạch Thôn","ghiChu":"@c0023"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Nhóc tỳ Thạch thôn đánh bại và tàn phế Bái Phong, cướp Bảo cụ (@c0024)."},{"ten":"Bái Lý Thanh","tag":"ho-hang","quanHe":"Cháu đích tôn của Bái Lý Thanh, cái chết khiến lão đau đớn","ghiChu":"@c0025"},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Người chém bay đầu Bái Phong","ghiChu":"@c0025"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ thù ôm hận","ghiChu":"Từng thua Thạch Hạo, dùng Bảo Cụ tập kích lạnh lùng để báo thù. @c0023"},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Người chém đầu","ghiChu":"Bị cha Nhị Mãnh vung kiếm chém bay đầu."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ Thạch Thôn","ghiChu":"Bị Thạch Hạo (chưa đầy bốn tuổi) đánh bại, phun máu bay ngang (@c0015)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo đá gục và bắt sống","ghiChu":"@c0016"},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Bị Thạch Lâm Hổ ngồi lên người, dọa chặt đầu","ghiChu":"@c0016"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ đánh bại và tàn phế mình","ghiChu":"Bị nhóc tỳ đá vỡ mặt, cắt đứt tứ chi và cướp Bảo cụ răng thú."},{"ten":"Cha của Nhị Mãnh","tag":"doi-thu","quanHe":"Kẻ chém đầu mình","ghiChu":"Vung kiếm chặt bay đầu Bái Phong (@c0025)"},{"ten":"Lão già Bái Thôn","tag":"su-mon","quanHe":"Người lớn Bái Thôn ngăn nó giết thêm","ghiChu":"Lắc đầu ngăn nó @c0013"},{"ten":"Thạch Thủ Sơn","tag":"doi-thu","quanHe":"Bắn trọng thương","ghiChu":"Xuyên phổi Thủ Sơn @c0013"},{"ten":"Lão già Bái Thôn","tag":"su-mon","quanHe":"Người Bái Thôn cùng phe","ghiChu":"Lão già lắc đầu ngăn nên nó không giết thêm nhiều người"},{"ten":"Lão già Bái Thôn","tag":"su-mon","quanHe":"Bậc trưởng bối Bái Thôn ra hiệu ngăn cản","ghiChu":"Lão già lắc đầu khiến hắn dừng tay không giết thêm nhiều người Thạch Thôn."},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đối thủ đấu tiễn ngang tài"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhắm bắn giết nhưng bị nhóc tỳ chém hất mũi tên và phản công"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ giao đấu","ghiChu":"Bị Thạch Hạo đánh bại phun máu bay ngang."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo đá gục và bắt sống","ghiChu":"Trở thành tù nhân của Thạch Thôn."},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Bị Thạch Lâm Hổ ngồi lên người, dọa chặt đầu","ghiChu":""},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đấu tiễn ngang tài trong trận đụng độ hai thôn."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Nhắm bắn liền bốn mũi tên vào nhóc tỳ, bị nó chặn và lao tới phản công."},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đấu tiễn ngang tài, suýt bắn xuyên cổ y","ghiChu":"@c0014"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bắn bốn mũi tên vào nhóc tỳ, bị nó chặn mũi cuối rồi lao tới","ghiChu":"@c0014"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhắm bắn Thạch Hạo bốn mũi tên; bị Thạch Hạo lao tới phản kích","ghiChu":"@c0014"}],"tuiDo":{"khac":[{"ten":"Vòng răng thú (Bảo Cụ)","loai":"bảo cụ","trangThai":"dang-co","moTa":"Mưa ánh sáng vờn quanh cổ tay hóa thành vòng răng thú trắng tinh óng ánh, phóng ra điểm sáng như mưa sao băng, lực sát thương kinh người, đánh xuyên tạng phủ người.","nguon":"@c0023"}]}},"nguon":["@c0023","@c0024","@c0025","@c0014","@c0015","@c0016","@c0013","@c0022"]},{"id":"toc-chu-bo-lac-ngua-vay-sung","name":"Tộc chủ bộ lạc Ngựa vảy sừng","gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Ngựa vảy sừng","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"kinhLich":[],"nhanMach":[],"tuViMoc":[]},"nguon":["@c0028"]},{"id":"chi-ton-mat-troi-tim","name":"Chí tôn mặt trời tím","aliases":["Vương hầu Đá kim cương","vương hầu Đá kim cương"],"gioiTinh":"nam","theLuc":[{"ten":"Vương hầu mặt trời tím","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"kinhLich":[],"nhanMach":[],"tuViMoc":[]},"nguon":["@c0028"]},{"id":"tu-son-hau","name":"Tử Sơn hầu","gioiTinh":"nam","theLuc":[{"ten":"Tử Sơn hầu","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"kinhLich":[{"chuong":"@c0028","importance":"normal","tieuDe":"Đối đầu Lôi Hậu qua lớp trẻ","text":"Tử Sơn hầu là vương hầu đối thủ của Lôi Hậu; dòng dõi thiên tài của gia tộc sắp ra ngoài tranh Sơn bảo, hai lão đối thủ chắc chắn sẽ mượn chuyện cho lớp trẻ quyết đấu.","anchor":"Tử Sơn hầu cùng Lôi Hậu hai lão đối thủ chắc chắn sẽ nhân chuyện cho lớp trẻ quyết đấu"},{"text":"Được xác nhận là cha/trưởng bối yêu thương Tử Sơn Côn nhất, đứng sau con trai đến gần Thạch Thôn để đối đầu Lôi Tộc và La Phù.","anchor":"Vốn muốn đối phó với đứa con được Tử Sơn Hầu yêu thương nhất là Tử Sơn Côn","bridge":true,"khoang":"@c0034"},{"text":"Lão chú ruột của gã, đi cùng đoàn cường giả các tộc, bị cành liễu vươn xa hơn nửa cây số chém mất bàn tay để cảnh cáo.","anchor":"một cành liễu như cành tiên phóng tới kéo theo một luồng hào quang, căng dài hơn nửa cây số vọt đến","bridge":true,"khoang":"@c0040"},{"importance":"normal","chuong":"@c0042","tieuDe":"Xuất thế tiến về Thạch thôn","text":"Được xưng là đệ nhất cường giả trong bán kính 25 ngàn cây số, chỉ trừ Vân tộc thần bí; có Tế linh đệ nhất là Sói thần vàng kim và từng một mình diệt nhiều bộ lạc cường đại. Hiện thân thành vầng Mặt trời màu tím lướt qua Tiểu Cô Sơn trấn, bay vào rừng cùng Lôi tộc, La Phù Đại Trạch và bộ lạc Kim Lang, cùng nhắm mục tiêu Thạch thôn.; Là đệ nhất cường giả trong bán kính 25 ngàn cây số (trừ Vân tộc), hiện thân là vầng Mặt trời màu tím, lướt qua Tiểu…","anchor":"Tử Sơn Hầu từng một mình diệt qua rất nhiều bộ lạc cường đại."},{"importance":"normal","chuong":"@c0043","tieuDe":"Đệ nhất cường giả ra tay","text":"Cuối chương, ở hướng chính đông tử khí ùn ùn kéo đến che lấp núi rừng khi đệ nhất cường giả Tử Sơn Tộc là Tử Sơn Hầu cũng ra tay tấn công Thạch Thôn.; Ở hướng chính đông, tử khí ùn ùn kéo đến che lấp núi rừng khi đệ nhất cường giả Tử Sơn Hầu cuối cùng cũng ra tay vây đánh Thạch Thôn.; Ở hướng chính đông, đệ nhất cường giả Tử Sơn Tộc tung tử khí ùn ùn che lấp núi rừng, cùng ba tộc chủ khác đồng loạt ra tay hủy diệt Thạch Thôn.","anchor":"Đệ nhất cường giả Tử Sơn Hầu cũng đã ra tay rồi."},{"importance":"normal","chuong":"@c0044","tieuDe":"Tử vong dưới lốc xoáy cây liễu","text":"Đích thân công kích Thạch thôn, hóa mây mù thành người tím khổng lồ giẫm chân xuống cây liễu đầu thôn; bị cành non khuấy tạo vòng xoáy xanh lục thông thiên cuốn vào, xoắn xé nát bấy mà chết.; Khi Tử Sơn Hầu giẫm chân xuống, cây liễu khuấy cành non tạo vòng xoáy xanh lục thông thiên; người tím khổng lồ bị cuốn vào xoắn xé nát bấy, Tử Sơn Hầu tử vong.; Cùng tứ đại cường giả bao vây Thạch thôn, giẫm chân tím khổng lồ xuống cây liễu. Cây liễu khuấy…","anchor":"toàn bộ đều bị cuốn vào trong cái lốc xoáy thông thiên, bị xoắn xé nát bấy"},{"importance":"normal","chuong":"@c0045","tieuDe":"Bỏ trốn nhờ Bảo Cụ thế thân","text":"Khi cây liễu bùng nổ tận diệt tứ đại cường giả, Tử Sơn Hầu để lại một Bảo Cụ ngưng tụ thành hình người chịu chết thay, còn bản thân hóa thành vầng thái dương màu tím áp sát mặt đất xông vào nguyên thủy sơn mạch; cành liễu chỉ có một nên chỉ kịp đâm xuyên Bảo Cụ, hắn trở thành tộc chủ duy nhất thoát nạn.; Khi cây liễu tận diệt tứ đại cường giả, Tử Sơn Hầu để lại một Bảo Cụ ngưng thành hình người chịu chết thay rồi bỏ chạy vào rừng, trở thành tộc…","anchor":"Tử Sơn Hầu cũng đã bỏ chạy rồi!"},{"importance":"normal","chuong":"@c0049","tieuDe":"Kẻ sống sót duy nhất của Tử Sơn Tộc","text":"Khi hung thú mắt xanh nuốt chửng cả vương thành và toàn bộ nhân khẩu Tử Sơn Tộc, Tử Sơn Hầu vì không rõ ở đâu nên thoát nạn, trở thành người duy nhất còn sống của cả tộc, để ngỏ khả năng trở lại về sau.; Khi hung thú mắt xanh nuốt trọn vương thành và cả nhân khẩu Tử Sơn Tộc, Tử Sơn Hầu vắng mặt tại lãnh địa nên trở thành người duy nhất còn sống của cả tộc, để ngỏ khả năng trở lại báo thù hoặc tái lập tộc.; Khi hung thú mắt xanh nuốt chửng cả vươ…","anchor":"Tử Sơn Tộc đã bị diệt tộc, trừ một Tử Sơn Hầu đang không biết ở đâu ra"}],"nhanMach":[{"ten":"Lôi Hậu","tag":"doi-thu","quanHe":"Hai lão đối thủ, cho lớp trẻ quyết đấu"},{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"dong-minh","quanHe":"Cùng tiến vào núi đánh Thạch thôn","ghiChu":""},{"ten":"Lôi Hậu","tag":"doi-thu","quanHe":"Lão đối thủ lâu năm, sắp cho lớp trẻ hai nhà quyết đấu","ghiChu":"@c0028"},{"ten":"Tử Sơn Côn","tag":"cha-me","quanHe":"Con trai yêu thương nhất","ghiChu":"@c0034"},{"ten":"Lôi Hậu","tag":"doi-thu","quanHe":"Hai lão đối thủ, mượn lớp trẻ quyết đấu","ghiChu":"@c0028"},{"ten":"Lôi Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng tứ đại cường giả liên thủ vây công Thạch thôn @c0044"},{"ten":"Tộc chủ La Phù Đại Trạch","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng vây công Thạch thôn @c0044"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Đối thủ chí mạng","ghiChu":"Giẫm chân tím xuống cây liễu nhưng bị lốc xoáy thông thiên của nó cuốn xé nát"},{"ten":"Thạch thôn","tag":"doi-thu","quanHe":"Các tộc (gồm nhà Tử Sơn) tới vây ép Thạch thôn và bị cây liễu đánh bại."},{"ten":"Lôi Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ vây công Thạch thôn","ghiChu":"Cùng tứ đại cường giả bao vây thôn (@c0044)"}],"tuViMoc":[]},"nguon":["@c0028","@c0042","@c0043","@c0044","@c0045","@c0049","@c0034","@c0040"],"aliases":["Tử Sơn hầu"]},{"id":"loi-hau","name":"Lôi Hậu","gioiTinh":"nam","theLuc":[{"ten":"Lôi Hậu","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"kinhLich":[{"chuong":"@c0028","importance":"normal","tieuDe":"Lệnh đánh thiên tài Tử Sơn hầu","text":"Vương hầu Lôi Hậu, giọng như sấm chớp giật màu đen, lệnh Vân Khôn dẫn lớp trẻ ra ngoài tranh Sơn bảo, dặn hễ gặp thiên tài nhà đối thủ Tử Sơn hầu thì đánh dằn mặt.","anchor":"nếu gặp mấy đứa thiên tài của nhà Tử Sơn hầu thì đánh chúng cho ta!"},{"importance":"normal","chuong":"@c0034","tieuDe":"Mẹ của Lôi Minh Viễn được nhắc","text":"Được xác nhận là mẹ của Lôi Minh Viễn — con út đến từ lãnh địa Vương Hầu tham chiến với ảo nghĩa Lôi Điện.","anchor":"Vậy thì đánh một trận sinh tử đối quyết đi, mày dám không?"},{"text":"Nhận ra Sơn bảo vô duyên với mình, đòi Thạch thôn bồi thường bảo thể Toan Nghê rồi cùng các đại tộc tiến về Thạch thôn.","anchor":"Mấy đại tộc vậy mà đều cùng đi một hướng, mục tiêu chính là: THẠCH THÔN.","bridge":true,"khoang":"@c0042"},{"importance":"normal","chuong":"@c0043","tieuDe":"Tung lôi quang chặn cành liễu","text":"Ở hướng chính bắc, Vương Hầu Lôi Tộc dùng hết toàn lực tung loạt lôi quang đen như hóa thân Lôi Thần, chặn đánh cành liễu Thạch Thôn khi nó đâm lên trời.; Ở hướng chính bắc, tung loạt lôi quang màu đen bổ xuống, hóa thân thành Lôi Thần dùng hết toàn lực chặn đánh cành liễu phòng ngự của Thạch Thôn (không đánh thân cây).; Ở hướng chính bắc, Vương Hầu Lôi Tộc dốc toàn lực tung loạt lôi quang đen như hóa thân Lôi Thần, chặn đánh cành liễu xanh biếc…","anchor":"Lôi Hầu đã ra tay, một vị Vương Hầu mạnh mẽ lúc dùng hết toàn lực"},{"importance":"major","chuong":"@c0044","tieuDe":"Bị bắt sống treo đầu thôn","text":"Dùng lôi quang mấy chục tầng công kích nhưng cây liễu càng xanh thẳm, hấp thu sạch sấm sét khiến hắn lần đầu mất lòng tin vào bản thân; hóa quả cầu sét chống cự vẫn bị cây liễu quấn chặt kéo về treo lơ lửng đầu thôn để liên tục thi triển Bảo thuật cung cấp sấm sét cho nó tẩm bổ.; Lôi Hầu rống to triệu mấy chục tầng lôi quang, hóa quả cầu sét công kích nhưng cây liễu càng xanh thẳm càng hấp thu sạch sấm sét; hắn lần đầu mất lòng tin vào bản thân…","anchor":"Lôi Hầu bị treo trên cây liễu đầu thôn"},{"importance":"major","chuong":"@c0045","tieuDe":"Bị treo trên cây liễu đến chết","text":"Lôi Hầu bị cây liễu treo lên, dùng Lôi Quang chống cự nhưng sức cùng lực kiệt, cuối cùng toàn thân khô héo rơi xuống đất vỡ nát mà chết.; Bị cành liễu treo lơ lửng, Lôi Hầu vắt kiệt Lôi Quang chống cự nhưng sức cùng lực kiệt, cuối cùng toàn thân khô héo rơi xuống đất vỡ nát mà chết.; Bị cây liễu treo lên, sức cùng lực kiệt, toàn thân khô héo rồi rơi xuống đất vỡ nát.; Bị cây liễu treo lên, dùng Lôi Quang chống cự đến sức cùng lực kiệt, cuối cùng…","anchor":"toàn thân khô héo, rơi xuống đất giống như một cái bình trà vỡ"}],"nhanMach":[{"ten":"Tử Sơn hầu","tag":"doi-thu","quanHe":"Hai lão đối thủ"},{"ten":"Vân Khôn","tag":"su-mon","quanHe":"Người dưới trướng, được lệnh dẫn em đi"},{"ten":"Tử Sơn hầu","tag":"doi-thu","quanHe":"Hai lão đối thủ, thường mượn chuyện cho lớp trẻ quyết đấu","ghiChu":"@c0028"},{"ten":"Vân Khôn","tag":"cap-tren","quanHe":"Chủ nhân ra lệnh, Vân Khôn là người dưới trướng","ghiChu":"@c0028"},{"ten":"Vân Khôn","tag":"cap-tren","quanHe":"Ra lệnh cho Vân Khôn dẫn em ra ngoài","ghiChu":"@c0028"},{"ten":"Tử Sơn hầu","tag":"doi-thu","quanHe":"Lão đối thủ, ra lệnh đánh thiên tài nhà đối phương","ghiChu":"@c0028"},{"ten":"Lôi Minh Viễn","tag":"cha-me","quanHe":"Con út","ghiChu":"@c0034"},{"ten":"Vân Khôn","tag":"dong-minh","quanHe":"Thuộc hạ được lệnh dẫn lớp trẻ ra ngoài","ghiChu":"@c0028"},{"ten":"Tử Sơn Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng vây công Thạch thôn @c0044"},{"ten":"Tộc chủ La Phù Đại Trạch","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng vây công Thạch thôn @c0044"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Đối thủ bắt sống","ghiChu":"Lôi quang của hắn lại nuôi lớn cây liễu; bị nó quấn bắt treo đầu thôn làm nguồn sấm sét"},{"ten":"Tử Sơn Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ vây công Thạch thôn","ghiChu":"@c0044"}],"tuViMoc":[]},"nguon":["@c0028","@c0038","@c0043","@c0044","@c0045","@c0034","@c0042"],"aliases":["Lôi Hậu","Vương Hầu Lôi Tộc"]},{"id":"giao-bang","name":"Giao Bằng","cn":"","gioiTinh":"nam","theLuc":[{"ten":"La Phù Đại Trạch","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Đứa trẻ năm sáu tuổi của La Phù Đại Trạch, khí thế hung mãnh như Kim Sí Đại Bằng non.","vaiTro":"Thiên tài trẻ của La Phù Đại Trạch.","tinhCach":[{"text":"Hung mãnh, hiếu chiến","chuong":"@c0030"}],"tabs":{"diem":[{"text":"Khí thế hung mãnh như Kim Sí Đại Bằng non","chuong":"@c0030"}],"kinhLich":[{"importance":"normal","chuong":"@c0030","tieuDe":"Đòi giết Tế Linh lấy máu","text":"Đứa nhỏ nhất năm sáu tuổi của La Phù Đại Trạch, khí thế hung mãnh, vừa tới trấn đã đòi tam thúc giết Tế Linh Tiểu Cô Sơn lấy máu tôi luyện thân thể, bị chú mắng cấm động vào vì sợ chọc Sơn Thần; sau đó khiêu chiến cháu của Tử Sơn Tộc.; Nhảy từ trên cao xuống với khí thế hung mãnh, đòi tam thúc giết Tế Linh Tiểu Cô Sơn lấy máu tôi luyện thân thể nhưng bị chú mắng cấm động vào. Sau đó khiêu chiến đấu với cháu của Tử Sơn Tộc, châm ngòi cuộc so tài…","anchor":"Tế Linh loại đá núi không thể động vào, nếu không nói không chừng sẽ chọc phải một vị Sơn Thần đó."},{"importance":"normal","chuong":"@c0034","tieuDe":"Bị nhóc tỳ đánh bay","text":"Tức giận xông vào đầu Thạch Thôn tấn công đám Bì Hầu, Giao Bằng bị một nhóc tỳ chưa cai sữa vỗ một chưởng phát tiếng sấm, lảo đảo lùi mười mấy mét suýt ngã.; Vì thù cũ giữa các tộc, Giao Bằng cùng Tử Sơn Côn và Lôi Minh Viễn lời qua tiếng lại rồi khai chiến sinh tử, thi triển Bảo Thuật Thái Cổ Hung Giao đấu một địch hai.; Cùng Tử Sơn Côn và Lôi Minh Viễn khai chiến sinh tử ngoài rừng Thạch Thôn, tranh giành cành liễu, thi triển Bảo Thuật Thái Cổ…","anchor":"toàn thân Giao Bằng như bị sét đánh, lảo đảo lùi lại"},{"importance":"normal","chuong":"@c0035","tieuDe":"Bại dưới tay nhóc tỳ Thạch Thôn","text":"Thiên tài đến từ La Phù Đại Trạch bị nhóc tỳ đánh lui, cánh tay co giật, mất mặt; bị người đàn ông La Phù Đại Trạch kéo lại không cho xung động, sau đó tò mò hỏi chuyện tộc đã ăn Toan Nghê.; Thiên tài của La Phù Đại Trạch bị nhóc tỳ chưa tới bốn tuổi đẩy lui, cánh tay co giật, mất hết mặt mũi. Sau đó tò mò hỏi chuyện Thạch Thôn ăn Toan Nghê.; Thiên tài từ La Phù Đại Trạch bị Tiểu Thạch Hạo đẩy lui, cánh tay co giật, mất mặt trước đám cường giả…","anchor":"Lúc này Giao Bằng đã bị người đàn ông của La Phù Đại Trạch đó kéo lại, không để nó xung động."},{"chuong":"@c0036","importance":"normal","tieuDe":"Trở mặt, đòi động thủ với Thạch thôn","text":"Sau khi thám thính biết Liễu thần chỉ mới xuất hiện mấy chục năm, nghi Tế linh đã mất năng lực, Giao Bằng trở mặt mắng Nhị Mãnh và đám nhóc là thùng rỗng kêu to rồi muốn động thủ; cũng chính hắn (được gọi Giao Long trong cảnh này) lấy bảo cung định bắn ba con chim non làm con mồi.","anchor":"sao lại trở mặt nhanh như vậy?"},{"importance":"normal","chuong":"@c0037","tieuDe":"Khai chiến bị đánh bay","text":"Kéo bảo cung bắn liên châu tiễn vào ba con chim non; khi Thạch Hạo cản đường, Giao Bằng vận Cốt Văn khiến hai tay hiện hai con Hung Giao dữ tợn, tự tin xông tới nhưng bị Thạch Hạo đánh bay ngang mười mấy mét, gan bàn tay vỡ nát máu đầm đìa, chỉ nhờ Cốt Văn mà xương tay không gãy.; Kéo bảo cung bắn mũi tên hàn quang nhắm Tử Vân, tuyên bố ba con hung cầm là vật săn của mình; bắn liên châu tiễn khiến Đại Bằng và Tiểu Thanh trúng tên.; Kéo bảo cung…","anchor":"vừa mới giao thủ mà Giao Bằng đã bị đánh bay rồi!"},{"importance":"normal","chuong":"@c0038","tieuDe":"Buộc dùng Bảo Thuật rồi bại thảm","text":"Mặt đầy máu gần biến dạng, Giao Bằng tức giận tuyên bố bị ép phải dùng Bảo Thuật, thả một con Hung Giao màu tro xám từ ký tự cổ trong lòng bàn tay tấn công Thạch Hạo; Hung Giao bị Thái Cổ Ma Cầm xé đứt, bản thân bị đá cằm chảy máu rồi trúng cối xay đá vào đầu, phun máu bọt và rụng hai răng.; Thiên tài đại tộc bị dồn ép, mặt đầy máu, buộc phải dùng Bảo Thuật chân chính thả một con Hung Giao tro xám tấn công Thạch Hạo, nhưng bị Thái Cổ Ma Cầm xé đ…","anchor":"một con Hung Giao màu tro xám hóa hình bay ra từ trong cái ký hiệu đó"},{"importance":"normal","chuong":"@c0039","tieuDe":"Bắn lén thất bại, đe dọa huyết tẩy","text":"Dù được tha mạng, Giao Bằng bò dậy diễn hóa Hung Giao thành Hung Tiễn bắn lén sau gáy Thạch Hạo nhưng bị cối xay nghiền nát; bị đá bay, tra tấn cối xay đến gãy sống mũi, rụng cả hàm răng; sau đó cưỡi Phi Giao đe dọa huyết tẩy Thạch Thôn, ra lệnh Phi Giao xông xuống.; Bị Thạch Hạo đập cối xay lên mặt gãy mũi rụng răng; sau đó cưỡi Phi Giao đe dọa huyết tẩy Thạch Thôn, ra lệnh Phi Giao xông xuống nhưng bị cành liễu non chặn đứng.; Không nể việc đư…","anchor":"trực tiếp dùng Bảo Thuật diễn hóa Hung Giao thành 'Hung Tiễn', đặt trên dây cung rồi bắn ra, tiến hành chặn giết."},{"text":"Kinh hãi té rớt khỏi Phi Giao đã bị diệt, chạy trốn, sau đó bị cánh tay khô của chú Giao Thương đập trúng rồi hôn mê.","anchor":"cành liễu như đóng đinh con Phi Giao ở giữa không trung","bridge":true,"khoang":"@c0040"}],"nhanMach":[{"ten":"Người trung niên La Phù Đại Trạch","tag":"ho-hang","quanHe":"Tam thúc/chú","ghiChu":"Cấm Giao Bằng động Tế Linh"},{"ten":"Chú ruột của Tử Sơn Hầu","tag":"khac","quanHe":"Được ông lão khen ngợi"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":"Khai chiến sinh tử tại rừng gần Thạch Thôn."},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":"Khai chiến sinh tử tại rừng gần Thạch Thôn."},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cùng thế lực","ghiChu":"Cùng thuộc La Phù Đại Trạch; Giao Thương khoanh tay quan sát khi Giao Bằng trở mặt."},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Giao Bằng mắng Nhị Mãnh và đám nhóc là thùng rỗng kêu to."},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cường giả cùng thế lực La Phù Đại Trạch, lạnh lùng không ngăn cản","ghiChu":"@c0037"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo đánh bại, tra tấn","ghiChu":"@c0039"},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cùng thế lực La Phù Đại Trạch","ghiChu":"@c0039"},{"ten":"Giao Thương","tag":"ho-hang","quanHe":"Chú ruột"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ quyết đấu","ghiChu":"Bị Thạch Hạo đánh bại trong quyết đấu Bảo Thuật (@c0038)."},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Thiên tài cùng lứa các tộc, sắp so tài phân cao thấp tại Tiểu Cô Sơn Trấn","ghiChu":"@c0030"},{"ten":"Nha Nha","tag":"doi-thu","quanHe":"Thiên tài Lôi Tộc cùng lứa, sắp so tài","ghiChu":"@c0030"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến ba thiên tài","ghiChu":"Khai chiến sinh tử ngoài rừng Thạch Thôn"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến ba thiên tài","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ Thạch Hạo đẩy lui hai lần","ghiChu":"@c0035"},{"ten":"Giao Thương","tag":"ho-hang","quanHe":"Chú ruột (La Phù Đại Trạch)","ghiChu":"@c0035"},{"ten":"Giao Thương","tag":"ho-hang","quanHe":"Trưởng bối/thủ lĩnh La Phù Đại Trạch khoanh tay quan sát khi Giao Bằng trở mặt","ghiChu":"@c0036"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Bị nhóc tỳ ngăn cản khi định động thủ và bắt chim non","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị đánh bay vỡ gan bàn tay @c0037"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"đồng cảnh ngộ ba thiên tài cùng bị ép dùng Bảo Thuật","ghiChu":"Tử Sơn Côn chế nhạo Giao Bằng khi bị ép (@c0038)"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"cùng phe ba thiên tài đại tộc dồn Thạch Hạo","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đánh bại Giao Bằng","ghiChu":"Bị Thạch Hạo áp đảo, tra tấn; cưỡi Phi Giao đe dọa huyết tẩy Thạch Thôn @c0039"},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Mắng Nhị Mãnh là thùng rỗng kêu to, muốn động thủ","ghiChu":"@c0036"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Định bắn ba con chim non của nhóc tỳ, bị nhóc tỳ gầm lên ngăn","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ giao chiến","ghiChu":"Bị Thạch Hạo đánh bay vỡ nát gan bàn tay khi săn ba con chim non (@c0037)."},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cùng La Phù Đại Trạch","ghiChu":"Giao Thương lạnh lùng không ngăn cản khi Giao Bằng khai chiến (@c0037)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ đánh bại trong quyết đấu bảo thuật","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo phản công đánh bay, gan bàn tay vỡ nát","ghiChu":"@c0037"},{"ten":"Người trung niên La Phù Đại Trạch","tag":"ho-hang","quanHe":"Tam thúc","ghiChu":"Cấm Giao Bằng động vào Tế Linh vì sợ chọc Sơn Thần."},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Bị nhóc tỳ Thạch Thôn đánh bay","ghiChu":""},{"ten":"Người trung niên La Phù Đại Trạch","tag":"ho-hang","quanHe":"Tam thúc/chú dẫn dắt Giao Bằng","ghiChu":"Cấm Giao Bằng động vào Tế Linh"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ khai chiến sinh tử","ghiChu":"Hỗn chiến ba bên @c0034"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ khai chiến sinh tử","ghiChu":"Hỗn chiến ba bên @c0034"},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Bị đánh bay bởi nhóc tỳ Thạch Thôn","ghiChu":"@c0034"},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Mắng ở Thạch thôn","ghiChu":"Mắng Nhị Mãnh và đám nhóc thôn thùng rỗng kêu to (@c0036)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ địch trực diện","ghiChu":"Bị Thạch Hạo đánh bay, gan bàn tay vỡ nát (@c0037)"},{"ten":"Giao Thương","tag":"ho-hang","quanHe":"Cường giả cùng La Phù Đại Trạch","ghiChu":"Giao Thương lạnh lùng không ngăn cản (@c0037)"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Kẻ diệt Phi Giao và phế chú mình","ghiChu":"(@c0040)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ nhí — bị Thạch Hạo đánh bại lần nữa bằng sức cơ thể","ghiChu":"@c0035"},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Mắng chửi","ghiChu":"Trở mặt mắng thùng rỗng kêu to."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Nhóc tỳ ngăn khi định động thủ."},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Kẻ uy hiếp","ghiChu":"Mắng Nhị Mãnh và đám nhóc thùng rỗng kêu to, muốn động thủ (@c0036)."},{"ten":"Giao Thương","tag":"su-mon","quanHe":"Đồng tộc La Phù Đại Trạch","ghiChu":"Giao Thương khoanh tay đứng nhìn, không ngăn Giao Bằng trở mặt (@c0036)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ ngăn cản và gầm lên bảo vệ chim non khi Giao Bằng định động thủ","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Thua nhóc tỳ dù nhóc chỉ dùng sức thân thể"},{"ten":"Nhị Mãnh","tag":"doi-thu","quanHe":"Mắng là thùng rỗng kêu to","ghiChu":"Trở mặt gây hấn với đám nhóc Thạch thôn (@c0036)"}],"tuViMoc":[{"chuong":"@c0037","canhGioi":"Phàm nhân","text":"Hơn năm tuổi, hai tay vung một cái đã có sức mạnh mấy nghìn cân, biết vận dụng Cốt Văn hiện hai Hung Giao ban tốc độ và thần lực.","importance":"normal"}]},"nguon":["@c0030","@c0034","@c0035","@c0036","@c0037","@c0038","@c0039","@c0040"],"aliases":["Giao Long","Hôi Giao"]},{"id":"thanh-nien-loi-toc","name":"Thanh niên Lôi Tộc","cn":"","gioiTinh":"nam","theLuc":[{"ten":"Lôi Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thanh niên hai mươi mấy tuổi hùng tráng, thân mang lôi điện đen.","vaiTro":"Trưởng đoàn Lôi Tộc dẫn Minh Viễn và Nha Nha.","tinhCach":[{"text":"Cường thế, chủ động ganh đua","chuong":"@c0030"}],"tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0030","tieuDe":"Dẫn Lôi Tộc tới trấn, đặt cược","text":"Thanh niên hai mươi mấy tuổi hùng tráng, thân mang lôi điện đen, cưỡi da thú cổ đưa người Lôi Tộc tới Tiểu Cô Sơn Trấn; sai Minh Viễn và Nha Nha ra so tài và đặt bảo huyết làm cược.; Cưỡi da thú cổ bay tới trấn, thân toát tiếng sấm và lôi điện đen. Sai Minh Viễn và Nha Nha ra trấn áp hai cháu yêu của Tử Sơn Hầu, cũng đặt bảo huyết làm cược.; Thanh niên hùng tráng thân mang lôi điện đen cưỡi tấm da thú cổ tới trấn, sai Minh Viễn và Nha Nha ra trấ…","anchor":"Đều là thiên tài cả, rốt cuộc ai mạnh nhất đây."}],"nhanMach":[{"ten":"Minh Viễn","tag":"cap-tren","quanHe":"Sai đi trấn áp cháu Tử Sơn Hầu"},{"ten":"Nha Nha","tag":"cap-tren","quanHe":"Sai đi trấn áp cháu Tử Sơn Hầu"}],"tuViMoc":[]},"nguon":["@c0030"]},{"id":"nha-nha","name":"Nha Nha","cn":"","gioiTinh":"nu","theLuc":[{"ten":"Lôi Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Bé gái trắng trẻo xinh đẹp của Lôi Tộc.","vaiTro":"Thiên tài nhỏ của Lôi Tộc.","tinhCach":[{"text":"Trắng trẻo xinh đẹp","chuong":"@c0030"}],"tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0030","tieuDe":"Được sai ra so tài","text":"Bé gái trắng trẻo xinh đẹp của Lôi Tộc, cùng Minh Viễn được thanh niên Lôi Tộc sai ra trấn áp cháu của Tử Sơn Hầu trong cuộc tranh tài giữa bọn trẻ các bộ tộc lớn.; Cùng Minh Viễn được thanh niên Lôi Tộc sai ra để trấn áp hai đứa cháu yêu của Tử Sơn Hầu trong cuộc so tài giữa các thiên tài trẻ.","anchor":"Đều là thiên tài cả, rốt cuộc ai mạnh nhất đây."}],"nhanMach":[{"ten":"Thanh niên Lôi Tộc","tag":"su-mon","quanHe":"Được sai bảo"},{"ten":"Minh Viễn","tag":"dong-minh","quanHe":"Cùng tộc Lôi Tộc"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"Cùng Lôi Tộc, được sai ra trấn chung","ghiChu":""}],"tuViMoc":[]},"nguon":["@c0030"]},{"id":"tu-son-con","name":"Tử Sơn Côn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tử Sơn Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Con được Tử Sơn Hầu yêu thương nhất, bình tĩnh, dùng Bảo Thuật trấn tộc Tử Sơn (thái dương màu tím, Hỏa Lân).","vaiTro":"Thiên tài Tử Sơn Tộc trong cuộc hỗn chiến.","tinhCach":[{"text":"Bình tĩnh","chuong":"@c0034"}],"tabs":{"diem":[{"text":"Con được Tử Sơn Hầu yêu thương nhất","chuong":"@c0034"}],"kinhLich":[{"importance":"normal","chuong":"@c0034","tieuDe":"Hỗn chiến với Giao Bằng, Lôi Minh Viễn","text":"Khai chiến sinh tử với Giao Bằng (La Phù) và Lôi Minh Viễn (Lôi Tộc) ngoài rừng Thạch Thôn, phun ánh sáng hóa thái dương màu tím triệu Hỏa Lân.; Vì thù cũ giữa các tộc, Tử Sơn Côn tham gia trận hỗn chiến sinh tử ba tộc gần Thạch Thôn, thi triển Bảo Thuật trấn tộc Tử Sơn phun ánh sáng hóa thái dương màu tím triệu Hỏa Lân.","anchor":"Vốn muốn đối phó với đứa con được Tử Sơn Hầu yêu thương nhất là Tử Sơn Côn"},{"importance":"normal","chuong":"@c0035","tieuDe":"Thiên tài Tử Sơn Tộc lên tiếng dò hỏi","text":"Thiên tài Tử Sơn Tộc được nêu tên sánh ngang Giao Bằng, lên tiếng hỏi về hung thú với vẻ kỳ dị khi cảm nhận hung khí trong Thạch Thôn.; Được nêu tên như thiên tài nổi bật của Tử Sơn Tộc, sánh ngang Giao Bằng; lên tiếng hỏi về hung thú với vẻ kỳ dị khi vào Thạch Thôn dò xét.; Thiên tài Tử Sơn Tộc, được nêu tên như thiên tài sánh với Giao Bằng, hỏi về hung thú tại Thạch Thôn.; Thiên tài Tử Sơn Tộc được nhắc tên sánh ngang Giao Bằng; lên tiếng hỏi…","anchor":"Thiên tài Tử Sơn Côn lên tiếng, lộ ra vẻ kỳ dị"},{"chuong":"@c0036","importance":"normal","tieuDe":"Nhắm bảo cung vào ba chim non","text":"Cùng Giao Long và Lôi Minh Viễn, Tử Sơn Côn lấy bảo cung coi ba con chim non biến dị là con mồi, chuẩn bị bắt lại thì bị nhóc tỳ gầm lên ngăn cản.","anchor":"cũng lấy xuống bảo cung, coi ba con chim non là con mồi chuẩn bị bắt lại"},{"importance":"normal","chuong":"@c0037","tieuDe":"Săn chim non, cung bị đánh gãy","text":"Sợ tụt hậu sau Giao Bằng, cùng Lôi Minh Viễn cầm bảo cung tên sắt săn đuổi ba con chim non; khi thừa cơ giương cung nhắm bầy chim thì bị Thạch Hạo đá đỉnh đồng ngàn cân bay tới, bảo cung bị đánh gãy đôi.; Thiên tài Tử Sơn Tộc, cùng Lôi Minh Viễn giương bảo cung tên sắt săn đuổi ba con chim non; bảo cung bị đỉnh đồng do Thạch Hạo đá văng đánh gãy đôi.; Cùng Lôi Minh Viễn săn đuổi ba con chim non, bị Thạch Hạo đá văng đỉnh đồng ngàn cân đánh gãy b…","anchor":"Cuối cùng, bảo cung của Tử Sơn Côn vẫn bị đánh gãy"},{"importance":"normal","chuong":"@c0038","tieuDe":"Hỏa Lân tím bị Ma Cầm xuyên đầu","text":"Vốn tâm cao khí ngạo, Tử Sơn Côn chế nhạo Giao Bằng nhưng mắt lóe lãnh quang vì bảo cung bị hủy; khi Thạch Hạo xông vào, tay nó đau như rạn xương, nhờ vòng xương trên ngón cái phát sáng mới phá giải mà vẫn bị đá văng mười mấy mét. Nó thả Hỏa Lân màu tím bằng Bảo Thuật nhưng bị Thái Cổ Ma Cầm ấn chân xuyên thủng đầu, Hỏa Lân vỡ nát.; Thiên tài Tử Sơn Tộc tâm cao khí ngạo, chế nhạo Giao Bằng nhưng hận vì bảo cung bị hủy. Đỡ chưởng Thạch Hạo đến rạ…","anchor":"Tử Sơn Côn hét lớn, toàn thân phát sáng, tử khí xung thiên"},{"importance":"normal","chuong":"@c0039","tieuDe":"Bị áp chế phun máu","text":"Xông lên tấn công nhưng bị nhóc tỳ áp chế, muốn chạy mà thất bại; bị đạp phun máu, ho sằng sặc thành quả bóng lăn, bị tra tấn bằng cối xay đá.; Cùng hai thiên tài bị Thái Cổ Ma Cầm nghiền nát dị cầm; bị Thạch Hạo đạp phun máu và xếp hàng tra tấn cối xay.; Thiên tài Tử Sơn Tộc cùng xông lên tấn công Thạch Hạo nhưng bị áp chế, bị đạp phun máu và tra tấn bằng cối xay đá.; Cùng Lôi Minh Viễn và Giao Bằng xông lên tấn công nhóc tỳ nhưng bị đánh bay…","anchor":"lập tức nằm oặt ra đấy, đau buốt khắp người"}],"tuViMoc":[],"nhanMach":[{"ten":"Tử Sơn Hầu","tag":"cha-me","quanHe":"Trưởng bối yêu thương nhất","ghiChu":"Được Tử Sơn Hầu yêu thương nhất."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":""},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo áp chế, đạp phun máu","ghiChu":"@c0039"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Hạo đá văng và giẫm vỡ Hỏa Lân (@c0038)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến","ghiChu":""},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ, hai tộc có thù cũ","ghiChu":""},{"ten":"Tử Sơn Hầu","tag":"cha-me","quanHe":"Trưởng bối Tử Sơn Tộc yêu thương nhất","ghiChu":""},{"ten":"Nhóc tỳ","tag":"doi-thu","quanHe":"Bị nhóc tỳ gầm lên bảo vệ chim non","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị đá đỉnh đồng làm gãy bảo cung @c0037"},{"ten":"Giao Bằng","tag":"dong-minh","quanHe":"Cùng khai chiến săn ba chim non @c0037"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"Cùng săn đuổi ba con chim non @c0037"},{"ten":"Giao Bằng","tag":"dong-minh","quanHe":"cùng phe ba thiên tài, có chế nhạo qua lại","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ áp chế Tử Sơn Côn","ghiChu":"Bị đạp phun máu, tra tấn cối xay @c0039"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"Cùng lấy bảo cung định bắt ba con chim non biến dị","ghiChu":"@c0036"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"Cùng săn đuổi","ghiChu":"Cùng Lôi Minh Viễn săn đuổi ba con chim non (@c0037)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ, Hỏa Lân bị Ma Cầm của nhóc tỳ diệt","ghiChu":"@c0038"},{"ten":"Tử Sơn Hầu","tag":"ho-hang","quanHe":"Được Tử Sơn Hầu yêu thương nhất","ghiChu":""},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến","ghiChu":""},{"ten":"Tử Sơn Hầu","tag":"cha-me","quanHe":"Cha (trưởng bối yêu thương nhất)","ghiChu":"@c0034"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ khai chiến sinh tử","ghiChu":"@c0034"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ khai chiến sinh tử; thù cũ giữa Tử Sơn Tộc và Lôi Tộc","ghiChu":"@c0034"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhóc tỳ gầm lên ngăn cản","ghiChu":"Tử Sơn Côn định bắn chim non, nhóc tỳ ngăn (@c0036)"},{"ten":"Lôi Minh Viễn","tag":"dong-minh","quanHe":"Cùng săn chim non","ghiChu":"Song hành trong cuộc săn (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ cạnh tranh","ghiChu":"Sợ tụt hậu sau Giao Bằng nên ra tay (@c0037)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ đánh văng và diệt Bảo Thuật Hỏa Lân của mình","ghiChu":"@c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Cùng lứa thiên tài, được nhắc tên sánh ngang","ghiChu":"@c0035"},{"ten":"Tử Sơn hầu","tag":"su-mon","quanHe":"Thuộc Tử Sơn Tộc / Tử Sơn Hầu","ghiChu":"@c0035"},{"ten":"Tử Sơn Thọ","tag":"dong-minh","quanHe":"Cùng Tử Sơn tộc","ghiChu":"Đồng hành trong đợt dò xét Thạch thôn."}],"tuiDo":{}},"nguon":["@c0034","@c0035","@c0037","@c0038","@c0039","@c0036"]},{"id":"loi-minh-vien","name":"Lôi Minh Viễn","cn":"","aliases":["Minh Viễn"],"gioiTinh":"nam","theLuc":[{"ten":"Lôi Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Con út của Lôi Hậu, đến từ lãnh địa Vương Hầu, dùng ảo nghĩa Lôi Điện bí mật bất truyền của Lôi Tộc. (+) Bé trai khỏe mạnh kháu khỉnh của Lôi Tộc. [CAN-SOAT-GOP]","vaiTro":"Thiên tài Lôi Tộc trong cuộc hỗn chiến.","tinhCach":[],"tabs":{"diem":[{"text":"Con út của Lôi Hậu, đến từ lãnh địa Vương Hầu","chuong":"@c0034"}],"kinhLich":[{"importance":"normal","chuong":"@c0034","tieuDe":"Hỗn chiến sinh tử ba bên","text":"Đến từ lãnh địa Vương Hầu, khai chiến sinh tử với Giao Bằng và Tử Sơn Côn, thi triển ảo nghĩa Lôi Điện — ký hiệu kỳ lạ ở lòng bàn tay, hóa điện mang đen triệu hung điểu.; Lôi Minh Viễn cùng Giao Bằng và Tử Sơn Côn khai chiến sinh tử gần Thạch Thôn, thi triển ảo nghĩa Lôi Điện hóa điện mang đen, triệu hung điểu trong điện quang.","anchor":"Vậy thì đánh một trận sinh tử đối quyết đi, mày dám không?"},{"text":"Thiếu niên hơn sáu tuổi, tính cách tàn nhẫn, cười cợt trên nỗi đau của Giao Bằng khi thiên tài này bại trận trước nhóc Thạch Thôn.; Thiếu niên hơn sáu tuổi, cười trên nỗi đau Giao Bằng khi thiên tài này bị nhóc tỳ Thạch Thôn đánh lui.","anchor":"Lôi Minh Viễn hơn sáu tuổi liền cười trên nỗi đau người khác","bridge":true,"khoang":"@c0035"},{"importance":"normal","chuong":"@c0037","tieuDe":"Cùng săn ba con chim non","text":"Là thiên tài Lôi Tộc, cùng Tử Sơn Côn hùa theo Giao Bằng cầm bảo cung tên sắt săn đuổi Đại Bằng, Tiểu Thanh, Tử Vân, rồi cùng bị Thạch Hạo dùng đỉnh đồng đánh đuổi.; Thiên tài Lôi Tộc, sợ tụt hậu sau Giao Bằng nên cầm bảo cung tên sắt cùng Tử Sơn Côn săn đuổi ba con chim non, cùng bị đỉnh đồng bay tới ép né tránh.; Cầm bảo cung tên sắt cùng Tử Sơn Côn săn đuổi Đại Bằng, Tiểu Thanh, Tử Vân, bị đỉnh đồng ngàn cân do Thạch Hạo đá văng ép né tránh.","anchor":"Nếu Giao Bằng, Tử Sơn Côn và Lôi Minh Viễn là thiên tài, vậy thằng bé chưa đủ bốn tuổi này là cái gì?"},{"importance":"normal","chuong":"@c0038","tieuDe":"Sấm sét đen bị đè bẹp","text":"Lôi Minh Viễn tuyên bố ở thế giới này Bảo Thuật mới mạnh nhất, cơ thể bành trướng tạo cỗ điện quang màu đen, ấn ký hiệu sấm sét bắn tia chớp đen về Thạch Hạo; nhưng bị Cốt Văn dung hóa tia chớp, rồi bị Thạch Hạo đá đạp trọng thương, tay nhờ Tá Lực Phù Văn của Lôi Hầu mới không gãy.; Thiên tài Lôi Tộc đề cao Bảo Thuật hơn thể chất, tạo cỗ điện quang màu đen, ấn ký hiệu sấm sét bắn tia chớp lớn về Thạch Hạo. Cốt Văn của Thạch Hạo hiện thành mảng k…","anchor":"cơ thể bành trướng tạo ra một cỗ điện quang màu đen, lòng bàn tay xuất hiện một cái ký hiệu, sấm sét đan xen, ấn về phía trước"},{"importance":"normal","chuong":"@c0039","tieuDe":"Lôi Cầm bị nuốt, bị tra tấn","text":"Triệu một con Hung Cầm mang tia chớp màu đen tấn công nhóc tỳ nhưng con Lôi Cầm bị Thái Cổ Ma Cầm nuốt chửng tan rã; bị đạp phun máu, ho ra máu và bị đập cối xay kêu thảm dù cơ thể mạnh mẽ.; Con Lôi Cầm của Lôi Minh Viễn bị Thái Cổ Hung Cầm của Thạch Hạo nuốt chửng tan rã; bản thân bị đánh bay ho ra máu và bị tra tấn cối xay.; Thả Lôi Cầm ra thì bị Thái Cổ Hung Cầm của Thạch Hạo nuốt chửng khiến nó tan rã; bản thân bị đánh bay ho ra máu, bị đập…","anchor":"trong điện quang chói mắt có một con Hung Cầm bay ra, mang theo tia chớp màu đen đánh về nhóc tỳ"},{"importance":"normal","chuong":"@c0030","tieuDe":"Được sai trấn áp cháu Tử Sơn Hầu","text":"Bé trai khỏe mạnh của Lôi Tộc, được thanh niên Lôi Tộc sai cùng Nha Nha ra trấn áp hai đứa cháu yêu của Tử Sơn Hầu trong cuộc đọ sức các thiên tài trẻ.; Cùng Nha Nha được thanh niên Lôi Tộc sai ra để trấn áp hai đứa cháu yêu của Tử Sơn Hầu trong cuộc so tài giữa các thiên tài trẻ.; Bé trai khỏe mạnh kháu khỉnh của Lôi Tộc, được thanh niên Lôi Tộc sai cùng Nha Nha ra trấn áp hai đứa cháu yêu của Tử Sơn Hầu trong cuộc so tài giữa các thiên tài trẻ.","anchor":"Đều là thiên tài cả, rốt cuộc ai mạnh nhất đây."}],"tuViMoc":[],"nhanMach":[{"ten":"Lôi Hậu","tag":"cha-me","quanHe":"Mẹ ruột","ghiChu":"Là con út của Lôi Hậu."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":""},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ trong hỗn chiến","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo nuốt Lôi Cầm, đánh bay","ghiChu":"@c0039"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Hạo trọng thương (@c0038)."},{"ten":"Lôi Hầu","tag":"su-mon","quanHe":"Người sáng tạo Tá Lực Phù Văn của tộc","ghiChu":"Tá Lực Phù Văn giúp Lôi Minh Viễn không gãy tay do Lôi Hầu sáng tạo (@c0038)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến","ghiChu":""},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ, hai tộc có thù cũ","ghiChu":""},{"ten":"Lôi Hậu","tag":"cha-me","quanHe":"Mẹ của Lôi Minh Viễn","ghiChu":""},{"ten":"Lôi Vân Khôn","tag":"ho-hang","quanHe":"Cùng thuộc Lôi Tộc trú đóng gần Thạch thôn","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị đe dọa bởi đỉnh đồng Thạch Hạo đá văng @c0037"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng săn đuổi ba con chim non @c0037"},{"ten":"Giao Bằng","tag":"dong-minh","quanHe":"Cùng khai chiến bắn ba chim non @c0037"},{"ten":"Lôi Hầu","tag":"su-mon","quanHe":"tiền bối Lôi Tộc, người sáng tạo Tá Lực Phù Văn cứu tay Lôi Minh Viễn","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ áp chế Lôi Minh Viễn","ghiChu":"Bị nuốt Lôi Cầm, đánh bay, tra tấn cối xay @c0039"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng lấy bảo cung định bắt ba con chim non biến dị","ghiChu":"@c0036"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng săn đuổi","ghiChu":"Cùng Tử Sơn Côn săn đuổi ba con chim non (@c0037)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ, bị nhóc tỳ đá đạp trọng thương","ghiChu":"@c0038"},{"ten":"Lôi Hậu","tag":"cha-me","quanHe":"Con út của Lôi Hậu","ghiChu":""},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ trong trận hỗn chiến; có thù tộc","ghiChu":""},{"ten":"Nha Nha","tag":"dong-minh","quanHe":"Cùng Lôi Tộc, được sai ra trấn chung","ghiChu":""},{"ten":"Lôi Hậu","tag":"cha-me","quanHe":"Mẹ","ghiChu":"@c0034"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ; thù cũ Lôi Tộc – Tử Sơn Tộc","ghiChu":"@c0034"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ khai chiến sinh tử","ghiChu":"@c0034"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng bắt chim non","ghiChu":"Cùng lấy bảo cung định bắn chim non (@c0036)"},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng săn chim non","ghiChu":"Song hành trong cuộc săn (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ cạnh tranh","ghiChu":"Cùng cạnh tranh săn chim non (@c0037)"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo đá đạp trọng thương trong quyết đấu","ghiChu":"@c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Cười cợt trên nỗi đau khi Giao Bằng bại trận","ghiChu":"@c0035"},{"ten":"Lôi Vân Khôn","tag":"dong-minh","quanHe":"Cùng Lôi Tộc","ghiChu":"Đồng hành trong đợt dò xét Thạch thôn."},{"ten":"Tử Sơn Côn","tag":"dong-minh","quanHe":"Cùng nhắm bắn chim non","ghiChu":"Cùng lấy bảo cung định bắt ba con chim non làm con mồi (@c0036)"},{"ten":"Thanh niên Lôi Tộc","tag":"su-mon","quanHe":"Được sai bảo"},{"ten":"Nha Nha","tag":"dong-minh","quanHe":"Cùng tộc Lôi Tộc"}],"tuiDo":{}},"nguon":["@c0034","@c0035","@c0037","@c0038","@c0039","@c0030","@c0036"]},{"id":"hai-tieu-co-nuong-tuyet-vu","name":"Hai tiểu cô nương (trên Tuyết Vũ)","cn":"","aliases":["Hai tiểu cô nương (trên Tuyết Vũ)","Song sinh Tuyết Vũ"],"gioiTinh":"nu","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Hai bé gái tướng mạo giống hệt nhau, xinh đẹp, cưỡi Tuyết Vũ đứng xem hỗn chiến và thích thú với nhóc tỳ.","vaiTro":"Song sinh tuyệt sắc chưa lộ tên của Thạch Thôn.","tinhCach":[{"text":"Thích thú, cười đùa vô tư","chuong":"@c0034"}],"tabs":{"diem":[{"text":"Hai bé gái giống hệt nhau, cưỡi Tuyết Vũ","chuong":"@c0034"}],"kinhLich":[{"text":"Hai tiểu cô nương giống hệt nhau đứng trên Tuyết Vũ ở Thạch Thôn, cười đùa nhìn cuộc hỗn chiến ba tộc và nhóc tỳ đánh bay Giao Bằng.","anchor":"toàn thân Giao Bằng như bị sét đánh, lảo đảo lùi lại","bridge":true,"khoang":"@c0034"},{"text":"Hai cô gái giống hệt nhau dụ Thạch Hạo gia nhập Vân Thiên Cung bằng sữa thú và lời hứa dẫn đi xem Tuyết Hải, sau lo lắng xin gia gia cứu Thạch Thôn.","anchor":"Bộ lạc Kim Lang của ta muốn thu đồ đệ, không biết cháu có muốn gia nhập không?","bridge":true,"khoang":"@c0039"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Dụ Thạch Hạo bằng sữa thú","ghiChu":"@c0039"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Dụ Thạch Hạo gia nhập Vân Thiên Cung","ghiChu":"Dụ bằng sữa thú và hứa dẫn đi xem Tuyết Hải; lo lắng xin gia gia cứu Thạch Thôn @c0039"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Cùng xuất hiện ở đầu thôn","ghiChu":"@c0034"}],"tuiDo":{}},"nguon":["@c0034","@c0039"]},{"id":"tu-son-tho","name":"Tử Sơn Thọ","gioiTinh":"nam","theLuc":[{"ten":"Tử Sơn Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tộc thúc bối phận cao của Tử Sơn Hầu, quyền thế lớn, dẫn cường giả vào Thạch Thôn dò xét. (+) Ông lão áo lông, kim quan, tỏa tử khí; chú ruột của Tử Sơn Hầu. [CAN-SOAT-GOP]","vaiTro":"Cường giả Tử Sơn Tộc, bối phận cao dò xét Thạch Thôn.","tabs":{"kinhLich":[{"text":"Tộc thúc bối phận cực cao của Tử Sơn Hầu, một thân áo lông đầu đội kim quan lởn vởn tử khí, hòa nhã dò hỏi tộc trưởng và cây liễu; dẫn cường giả Tử Sơn Tộc và La Phù Đại Trạch vào Thạch Thôn xem xét; khiếp vía lảo đảo khi nghe danh xưng Liễu Thần.; Tộc thúc bối phận cao của Tử Sơn Hầu, một thân áo lông đầu đội kim quan lởn vởn tử khí, hòa nhã hỏi han xin vào làng nghỉ, dò hỏi chuyện tộc trưởng và cây liễu; khiếp vía lảo đảo khi nghe danh xưng Li…","anchor":"Tộc thúc Tử Sơn Thọ của Tử Sơn Hầu ho khan, ông ấy có bối phận cực cao, sở hữu quyền thế khổng lồ","bridge":true,"khoang":"@c0035"},{"importance":"normal","chuong":"@c0030","tieuDe":"Chú Tử Sơn Hầu tới trấn, đặt cược","text":"Ông lão áo lông, kim quan tỏa tử khí cưỡi xương thú Bảo Cụ tới trấn, khen ngợi Giao Bằng và đặt cược một bình chân huyết hung thú hiếm cho cuộc so tài của lũ trẻ các tộc.; Cưỡi xương thú Bảo Cụ bay sát đất tới trấn, tỏa tử khí. Khen Giao Bằng và tiên đoán mười năm sau ắt danh động mảnh đại địa, đặt cược một bình chân huyết hung thú hiếm cho cuộc so tài giữa bọn trẻ các tộc.; Ông lão áo lông, đội kim quan, tỏa tử khí, cưỡi xương thú Bảo Cụ chở th…","anchor":"Ông lão là chú ruột của Tử Sơn Hầu"}],"nhanMach":[{"ten":"Tử Sơn Hầu","tag":"ho-hang","quanHe":"Tộc thúc bối phận cao","ghiChu":""},{"ten":"Tử Sơn Côn","tag":"su-mon","quanHe":"Cùng Tử Sơn tộc","ghiChu":"Cùng thuộc Tử Sơn tộc trú đóng quanh Thạch thôn."},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cùng vào Thạch Thôn dò xét, nhìn nhau nghi tộc trưởng khó lường","ghiChu":"@c0035"},{"ten":"Tử Sơn Côn","tag":"ho-hang","quanHe":"Cùng thuộc Tử Sơn tộc","ghiChu":"@c0036"},{"ten":"Tử Sơn hầu","tag":"ho-hang","quanHe":"Tộc thúc bối phận cực cao","ghiChu":"@c0035"},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Cùng dò xét Thạch Thôn, nhìn nhau lo lắng khi cảm nhận tộc trưởng khó lường","ghiChu":"@c0035"},{"ten":"Bì Hầu","tag":"khac","quanHe":"Nhóc trong thôn tiết lộ danh xưng Liễu Thần khiến ông sốc nặng","ghiChu":"@c0035"},{"ten":"Tử Sơn hầu","tag":"ho-hang","quanHe":"Tộc thúc của Tử Sơn Hầu","ghiChu":"Bối phận cực cao, quyền thế khổng lồ"},{"ten":"Tử Sơn Hầu","tag":"ho-hang","quanHe":"Cháu ruột"},{"ten":"Giao Bằng","tag":"khac","quanHe":"Khen ngợi thiên tài trẻ"},{"ten":"Tử Sơn Hầu","tag":"ho-hang","quanHe":"Cháu (Tử Sơn Hầu là cháu của ông lão)","ghiChu":""},{"ten":"Tử Sơn hầu","tag":"ho-hang","quanHe":"Cháu (là hầu của Tử Sơn Tộc)","ghiChu":""}],"tuViMoc":[]},"nguon":["@c0035","@c0036","@c0030"],"aliases":["Chú ruột của Tử Sơn Hầu","Chú ruột Tử Sơn Hầu"]},{"id":"loi-van-khon","name":"Lôi Vân Khôn","gioiTinh":"nam","theLuc":[{"ten":"Lôi Hậu","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Con thứ tư của Lôi Hầu, thanh niên cao to cường tráng, ánh mắt có thiểm điệm màu đen.","tabs":{"kinhLich":[{"text":"Thanh niên hai mươi mấy tuổi, con thứ tư của Lôi Hầu, cảm ứng hung khí trên các đỉnh cổ và hỏi về Tế Linh cây liễu.","anchor":"cường giả tới từ các thế lực lớn như Tử Sơn Tộc, La Phù Đại Trạch đều đi vào Thạch Thôn","bridge":true,"khoang":"@c0035"},{"chuong":"@c0028","importance":"normal","tieuDe":"Được lệnh dẫn em ra ngoài","text":"Chủ nhân thế lực Lôi Hậu lệnh Vân Khôn mang theo mấy người em rời lãnh địa đi kiến thức, dặn nếu gặp thiên tài nhà Tử Sơn hầu thì ra tay đánh.","anchor":"Vân Khôn ngươi cũng mang theo mấy người em cũng đi luôn đi"}],"nhanMach":[{"ten":"Lôi Hậu","tag":"cha-me","quanHe":"Con thứ tư","ghiChu":""},{"ten":"Lôi Minh Viễn","tag":"su-mon","quanHe":"Cùng Lôi Tộc","ghiChu":"Cùng thuộc Lôi Tộc trú đóng quanh Thạch thôn."},{"ten":"Lôi Minh Viễn","tag":"ho-hang","quanHe":"Cùng thuộc Lôi Tộc trú đóng gần Thạch thôn","ghiChu":"@c0036"},{"ten":"Tử Sơn Thọ","tag":"dong-minh","quanHe":"Cùng đoàn cường giả các tộc vào Thạch Thôn dò xét","ghiChu":"@c0035"},{"ten":"Nhị Mãnh","tag":"khac","quanHe":"Trẻ Thạch thôn được mời uống linh hoa","ghiChu":"Tiếp cận qua chén nước linh hoa."},{"ten":"Lôi Hậu","tag":"cap-tren","quanHe":"Chủ nhân ra lệnh"},{"ten":"Lôi Hậu","tag":"cap-tren","quanHe":"Chủ nhân thế lực Lôi Hậu ra lệnh cho Vân Khôn","ghiChu":"@c0028"},{"ten":"Lôi Hậu","tag":"cap-tren","quanHe":"Chủ nhân thế lực ra lệnh cho Vân Khôn","ghiChu":"@c0028"},{"ten":"Lôi Hậu","tag":"cap-tren","quanHe":"Chủ nhân thế lực, ra lệnh cho Vân Khôn dẫn người ra ngoài","ghiChu":"@c0028"}],"tuViMoc":[]},"nguon":["@c0035","@c0036","@c0028"],"aliases":["Vân Khôn"]},{"id":"giao-thuong","name":"Giao Thương","gioiTinh":"nam","trangThai":"song","blurb":"Cường giả nhìn nhau với Tử Sơn Thọ, cho rằng tộc trưởng Thạch Thôn khó lường. (+) Tam thúc của Giao Bằng, tóc đen mắt vàng, cưỡi Giao có cánh. [CAN-SOAT-GOP]","tabs":{"kinhLich":[{"chuong":"@c0035","importance":"normal","tieuDe":"Cùng đoàn dò xét Thạch Thôn","text":"Cùng Tử Sơn Thọ dẫn cường giả các tộc vào Thạch Thôn xem xét; nhìn nhau lo lắng khi cảm nhận tộc trưởng Thạch Thôn khó lường sau khi nghe tin bế quan.; Cường giả nhìn nhau với Tử Sơn Thọ, cho rằng tộc trưởng Thạch Thôn bế quan là kẻ khó lường, thực lực cường đại.","anchor":"cường giả tới từ các thế lực lớn như Tử Sơn Tộc, La Phù Đại Trạch đều đi vào Thạch Thôn"},{"text":"Đứng nhìn lạnh lùng không ngăn cản khi Giao Bằng khai chiến bắn ba con chim non của Thạch Thôn.","anchor":"muốn cướp bảo cốt Toan Nghê của Thạch Thôn, nhưng khổ nỗi lại không có cớ","bridge":true,"khoang":"@c0037"},{"text":"Cường giả trung niên La Phù Đại Trạch thờ ơ đòi Thạch Thôn giao bảo cốt Toan Nghê cùng ba con chim non, không thèm hỏi ý dân làng, mặc Giao Bằng ra lệnh Phi Giao xông xuống.","anchor":"Thà làm ngọc nát còn hơn làm ngói lành","bridge":true,"khoang":"@c0039"},{"importance":"major","chuong":"@c0040","tieuDe":"Bị phế cánh tay và tu vi","text":"Van xin cây liễu tha thứ nhưng bị cành liễu đâm xuyên cánh tay phải, hút cạn ánh sáng thần khiến tay khô quắt gãy rớt, tu vi bị tàn phế hoàn toàn.; Xin tha thứ nhưng bị cành liễu đâm xuyên cánh tay phải, hút ánh sáng thần khiến tay khô quắt gãy rớt và tu vi bị tàn phế hoàn toàn.; Xin tha thứ trước Liễu Thần nhưng bị cành liễu đâm xuyên cánh tay phải, hút ánh sáng thần khiến tay khô quắt gãy rớt, tu vi tàn phế hoàn toàn.","anchor":"cánh tay gã dần khô quắt lại, rồi Rắc! một tiếng như gỗ mục bị gãy rớt xuống dưới đất"},{"importance":"normal","chuong":"@c0030","tieuDe":"Cấm Giao Bằng động Tế Linh, đặt cược","text":"Người trung niên tóc đen mắt vàng cưỡi Giao có cánh đưa Giao Bằng cùng mấy đứa trẻ tới trấn; ngăn Giao Bằng động vào Tế Linh vì sợ chọc Sơn Thần, đồng thời đặt cược một bình máu dị chủng hung cầm cho cuộc so tài.; Cưỡi Giao có cánh dài hơn hai mươi mét đưa người La Phù Đại Trạch cùng ba đứa trẻ tới trấn. Cấm Giao Bằng động vào Tế Linh vì sợ chọc Sơn Thần, và đặt cược một bình máu dị chủng hung cầm cho cuộc so tài.","anchor":"Tế Linh loại đá núi không thể động vào, nếu không nói không chừng sẽ chọc phải một vị Sơn Thần đó."}],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đòi bảo cốt Toan Nghê từ Thạch Hạo","ghiChu":"@c0039"},{"ten":"Giao Bằng","tag":"dong-minh","quanHe":"Cùng thế lực La Phù Đại Trạch","ghiChu":"@c0039"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Chú ruột","ghiChu":"Chú của Giao Bằng."},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Hậu bối/thiên tài La Phù Đại Trạch mà Giao Thương thả cho trở mặt","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Cường giả La Phù đòi bảo cốt","ghiChu":"Thờ ơ đòi Thạch Thôn giao bảo cốt Toan Nghê và ba chim non, mặc Giao Bằng ra lệnh Phi Giao xông xuống @c0039"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Cháu ruột","ghiChu":"Chú của Giao Bằng, cùng thuộc La Phù Đại Trạch"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Bị Liễu Thần phế tay và tu vi"},{"ten":"Giao Bằng","tag":"dong-minh","quanHe":"Cùng La Phù Đại Trạch","ghiChu":"Không ngăn cản khi Giao Bằng khai chiến bắn chim non (@c0037)."},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Đối diện ở Thạch thôn","ghiChu":"Ông lão nhìn về phía Giao Thương khi can Giao Bằng (@c0036)"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Cùng thế lực","ghiChu":"Dung túng cho Giao Bằng ra tay (@c0037)"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Cháu","ghiChu":"Giao Bằng ngất khi thấy chú bị phế (@c0040)"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Kẻ phế tu vi mình","ghiChu":"Cành liễu đâm xuyên tay, hút ánh sáng thần (@c0040)"},{"ten":"Tử Sơn Thọ","tag":"dong-minh","quanHe":"Cùng đoàn cường giả vào Thạch Thôn dò xét","ghiChu":"@c0035"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Bị nhìn về phía","ghiChu":"Ông lão Vân Thiên Cung nhìn về phía Giao Thương bày tỏ thái độ."},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Bị cây liễu đâm phế cánh tay và tu vi","ghiChu":"@c0040"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Chú của Giao Bằng","ghiChu":"@c0040"},{"ten":"Giao Bằng","tag":"su-mon","quanHe":"Đồng tộc La Phù Đại Trạch","ghiChu":"Khi Giao Bằng trở mặt, Giao Thương khoanh tay đứng nhìn không ngăn, thử phản ứng của thôn (@c0036)."},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Đại diện thế lực khác","ghiChu":"Ông lão Vân Thiên Cung đứng ra can rồi nhìn về phía Giao Thương La Phù Đại Trạch (@c0036)."},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Cháu (tam thúc)"},{"ten":"Giao Bằng","tag":"ho-hang","quanHe":"Cháu trong tộc mà ông dẫn dắt","ghiChu":""}],"tuViMoc":[]},"nguon":["@c0035","@c0039","@c0040","@c0036","@c0037","@c0030"],"aliases":["Người trung niên La Phù Đại Trạch","Chú của Giao Bằng","chú Giao Bằng","tam thúc của Giao Bằng","#nguoi-trung-nien-la-phu"]},{"id":"ong-lao-van-thien-cung","name":"Ông lão Vân Thiên Cung","cn":"","gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Cung","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Lão giả Vân Thiên Cung cầm tấm lông tuyết, đứng ra can Giao Bằng khi tình thế căng thẳng.","vaiTro":"Trưởng lão Vân Thiên Cung","tinhCach":[{"text":"Điềm tĩnh, biết chừng mực","chuong":"@c0036"}],"tabs":{"diem":[],"kinhLich":[{"text":"Khuyên bảo Giao Bằng dừng tay hai lần rồi thôi, sau chứng kiến Thạch Hạo đánh bay Giao Bằng thì thán phục thần lực của nhóc tỳ.","anchor":"sức mạnh cơ thể của nhóc tỳ sớm đã vượt xa loại thiên tài như Giao Bằng","bridge":true,"khoang":"@c0037"},{"text":"Cuối chương khi Phi Giao chuẩn bị xông xuống Thạch Thôn thì đột nhiên toàn thân lông tóc dựng đứng, thốt lên chữ Xích — báo hiệu lai lịch phi thường của cây liễu cháy đen mà nhóc tỳ vừa khấn.; Nhiều lần tán thưởng thiên phú diễn hóa Bảo Thuật của Thạch Hạo; cuối chương bỗng sợ hãi lông tóc dựng đứng, thốt lên khi cảm nhận uy năng của cành liễu.","anchor":"một cành liễu non xanh biếc như điêu khắc bằng thần ngọc","bridge":true,"khoang":"@c0039"},{"text":"Dẫn hai cô bé rời Thạch thôn mà không tổn thất; cản hai cô bé muốn bắt chuyện, giữ khoảng cách với biến cố các tộc.","anchor":"Một đám lại một đám chạy bắn khói ra khỏi Thạch thôn","bridge":true,"khoang":"@c0040"}],"tuViMoc":[],"nhanMach":[{"ten":"Giao Bằng","tag":"khac","quanHe":"Người can ngăn","ghiChu":"Đứng ra can Giao Bằng khi hắn muốn động thủ với người Thạch thôn."},{"ten":"Giao Thương","tag":"khac","quanHe":"Đối thoại","ghiChu":"Nhìn về phía Giao Thương La Phù Đại Trạch trong lúc can ngăn."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Tán thưởng thiên phú của Thạch Hạo, muốn chiêu mộ","ghiChu":"@c0039"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được Thạch Hạo mời làm trọng tài trận đấu","ghiChu":"@c0038"},{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Được nhờ làm trọng tài","ghiChu":"Thạch Hạo nhờ chủ trì công đạo @c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Can khi Giao Bằng muốn động thủ Thạch thôn","ghiChu":"@c0036"},{"ten":"Giao Thương","tag":"doi-thu","quanHe":"Nhìn chòng chọc để răn về hành xử của hậu bối La Phù","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Thán phục thần lực Thạch Hạo @c0037"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"được nhóc tỳ tin tưởng mời làm trọng tài","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cường giả muốn chiêu mộ Thạch Hạo","ghiChu":"Nhiều lần tán thưởng thiên phú diễn hóa Bảo Thuật; cuối chương bỗng sợ hãi lông tóc dựng đứng, thốt Xích @c0039"},{"ten":"Hai tiểu cô nương Vân Thiên Cung","tag":"ho-hang","quanHe":"Gia gia của hai tiểu cô nương","ghiChu":"Được hai cô cháu xin cứu Thạch Thôn @c0039"},{"ten":"Giao Bằng","tag":"khac","quanHe":"Đứng ra can Giao Bằng khi y trở mặt muốn động thủ","ghiChu":"@c0036"},{"ten":"Giao Thương","tag":"khac","quanHe":"Nhìn về phía Giao Thương La Phù Đại Trạch khi can ngăn","ghiChu":"@c0036"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được nhóc tỳ mời làm trọng tài phân thắng bại vì còn giữ công đạo","ghiChu":"@c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Can ngăn","ghiChu":"Can Giao Bằng khi ông ta muốn động thủ (@c0036)"},{"ten":"Giao Thương","tag":"khac","quanHe":"Nhìn về phía thủ lĩnh La Phù Đại Trạch","ghiChu":"Nhìn Giao Thương khi can Giao Bằng (@c0036)"},{"ten":"Giao Bằng","tag":"khac","quanHe":"Người được khuyên bảo","ghiChu":"Khuyên bảo nhưng Giao Bằng bỏ ngoài tai (@c0037)"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Kính nể","ghiChu":"Thán phục thần lực nhóc tỳ Thạch Hạo (@c0037)"},{"ten":"Hai tiểu cô nương Vân Thiên Cung","tag":"ho-hang","quanHe":"Hai đứa cháu gái, xin gia gia cứu Thạch Thôn khi cành liễu chưa hiện.","ghiChu":"@c0039"},{"ten":"Vân Thiên Cung","tag":"su-mon","quanHe":"Người của Vân Thiên Cung","ghiChu":"Dẫn hai cô bé đi cùng (@c0040)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đứng ra can","ghiChu":"Ngăn Giao Bằng trở mặt hại người thôn."},{"ten":"Giao Thương","tag":"khac","quanHe":"Đối trọng thế lực","ghiChu":"Nhìn về Giao Thương La Phù Đại Trạch bày tỏ thái độ."},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Đứng về phía nhóc tỳ","ghiChu":"Can Giao Bằng trong lúc nhóc tỳ ra ngăn."},{"ten":"Giao Thương","tag":"khac","quanHe":"Đại diện thế lực La Phù","ghiChu":"Sau khi can, nhìn về phía Giao Thương La Phù Đại Trạch (@c0036)."}],"tuiDo":{}},"nguon":["@c0036","@c0039","@c0038","@c0037","@c0040"],"aliases":["lão giả cầm lông tuyết","Ông lão tay cầm lông tuyết"]},{"id":"doi-ty-muoi-sinh-doi","name":"Đôi tỷ muội sinh đôi","gioiTinh":"nu","trangThai":"song","blurb":"Hai thiếu nữ quan chiến khuôn mặt giống hệt nhau, linh tính hiếm có.","tabs":{"kinhLich":[],"nhanMach":[{"ten":"Tiểu Thạch Hạo","tag":"khac","quanHe":"khen Thạch Hạo là em bé sứ khi quan chiến","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Quan chiến, khen Thạch Hạo","ghiChu":"Khen em bé sứ lợi hại (@c0038)."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"quan chiến, ngưỡng mộ tài nghệ của nhóc tỳ","ghiChu":"@c0038"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Hai thiếu nữ thiên tài quan chiến, trầm trồ trước sức mạnh của nhóc tỳ","ghiChu":"@c0038"}],"tuViMoc":[]},"nguon":["@c0038"]},{"id":"nhoc-mui-xanh","name":"Nhóc mũi xanh","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nhóc con Thạch thôn hùa theo Nhị Mãnh khơi lại chuyện các tộc đòi cướp bảo vật.","tabs":{"kinhLich":[{"text":"Cùng Nhị Mãnh khơi lại chuyện các tộc bàn nhau tàn sát Thạch thôn và cướp xương quý Toan Nghê, khiến các cường giả co rúm và quay ra nhã nhặn.","anchor":"một đám cao thủ từ La Phù Đại Trạch bị giết chỉ trong một hơi thở","bridge":true,"khoang":"@c0040"}],"nhanMach":[{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn nhóc cùng thôn","ghiChu":"Cùng khơi lại âm mưu các tộc (@c0040)"}],"tuViMoc":[]},"nguon":["@c0040","@c0050"],"aliases":["Nhóc thò lò mũi xanh"]},{"id":"ba-do-kim-lang","name":"Ba Đồ","cn":"","aliases":["Ba Đồ"],"gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Kim Lang","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Người cụt tay của bộ lạc Kim Lang, sống sót trở về báo tin Thạch thôn có xương quý Toan Nghê.","vaiTro":"Nhân vật phụ — kẻ báo tin khơi mào cuộc kéo quân của Kim Lang tới Thạch thôn.","tinhCach":[{"text":"Mang thù hận, khát báo thù sau khi bị thương nặng.","chuong":"@c0041"}],"tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0041","tieuDe":"Cụt tay về tộc báo tin Thạch thôn","text":"Ba Đồ cụt tay chạy về bộ lạc Kim Lang, ngất lịm rồi bừng tỉnh gào báo thù; hắn kể cho tộc trưởng chuyện vào thôn cổ quái phát hiện xương quý Toan Nghê chí bảo và hậu duệ ma cầm Thái cổ, nhưng bị cây liễu bị sét đánh chém giết.; Cụt tay, ngất lịm khi về tới bộ lạc Kim Lang rồi bừng tỉnh kêu tộc trưởng báo thù; kể lại việc trong thôn cổ có xương quý Toan Nghê chí bảo cùng hậu duệ ma cầm Thái cổ, và cây liễu bị sét đánh đã chém giết cao thủ.; Người…","anchor":"Bọn tôi đã vào một cái thôn cổ quái, phát hiện ở đây có xương quý Toàn Nghê chí bảo"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cap-tren","quanHe":"Tộc trưởng bộ lạc, người Ba Đồ báo tin cầu báo thù","ghiChu":"Ba Đồ kêu tộc trưởng dẫn quân tới Thạch thôn."},{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cap-tren","quanHe":"Tộc trưởng của mình, được báo tin và cầu báo thù","ghiChu":"@c0041"},{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cap-tren","quanHe":"Tộc trưởng của bộ lạc Kim Lang","ghiChu":"Báo tin, xin tộc trưởng báo thù"},{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cap-tren","quanHe":"Tộc trưởng của Ba Đồ","ghiChu":"Ba Đồ về báo tin, cầu tộc trưởng báo thù"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0041"]},{"id":"toc-truong-kim-lang","name":"Tộc trưởng bộ lạc Kim Lang","cn":"","aliases":["Tộc chủ Kim Lang","Tộc chủ bộ lạc Kim Lang","Lão tộc trưởng Kim Lang"],"gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Kim Lang","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (Chí cường giả) @c0041","trangThai":"song","blurb":"Lão tộc trưởng cao to dũng mãnh của bộ lạc Kim Lang, con ngươi bắn kim quang, lòng bàn tay có phù văn vàng kim chữa thương.","vaiTro":"Thủ lĩnh bộ lạc Kim Lang, quyết định dẫn Sói thần tới Thạch thôn tranh đoạt chí bảo.","tinhCach":[{"text":"Thận trọng, mưu tính kỹ, muốn ổn thỏa nên mời Sói thần theo.","chuong":"@c0041"}],"tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0041","tieuDe":"Quyết đến Thạch thôn cùng Sói thần","text":"Nghe Ba Đồ báo về xương quý Toan Nghê và cây liễu thần bí, tộc trưởng Kim Lang hỏi rõ sự tình rồi quyết định đích thân đến Thạch thôn, còn định mời Sói thần vàng kim theo cùng cho ổn thỏa; quanh lều bùng lên cơn lốc xoáy vàng kim.; Nghe Ba Đồ kể chuyện xương quý Toan Nghê và cây liễu chém giết, lão liền quyết định đích thân tới Thạch thôn, còn mời sinh linh Sói thần vàng kim đi cùng cho ổn thỏa. Sau đó đích thân tới Tiểu Cô Sơn trấn.; Nghe Ba Đồ…","anchor":"Để ổn thỏa hơn sẽ đi mời Sói thần, để nó cũng theo ta một chuyến này."},{"text":"Đứng trên khối núi cùng con Sói thần nhìn thú triều, lão là người đầu tiên nhận ra Di Chủng đang phụng mệnh lùa bầy thú, hiểu có Chí cường bí ẩn đang dọn bãi để Sơn bảo xuất thế. Sau đó tuyên bố sẽ diệt Thạch thôn nhờ Sói thần vàng kim.","anchor":"Mơ hồ, lão đã rõ nơi sâu bên trong có tồn tại Chí cường đang dọn bãi săn bảo","bridge":true,"khoang":"@c0042"},{"importance":"normal","chuong":"@c0043","tieuDe":"Chiếm phương chính nam","text":"Ông lão cao lớn con ngươi vàng nhạt có tia chớp, đi cùng con Thần Lang vàng mạnh nhất phương viên năm vạn dặm, ra lệnh thiết kỵ Kim Lang lùi một dặm rồi hóa ánh sáng vàng chiếm phương chính nam để hủy diệt Thạch Thôn.; Ra lệnh thiết kỵ Kim Lang lùi một dặm chờ lệnh rồi hóa ánh sáng vàng tới đỉnh núi cách Thạch Thôn một dặm; đi cùng con Thần Lang màu vàng — Tế Linh mạnh nhất phương viên năm vạn dặm — chiếm một phương để hủy diệt thôn.; Ông lão ca…","anchor":"Mỗi người chiếm cứ một phương, đây là muốn triển khai thủ đoạn lôi đình"},{"importance":"major","chuong":"@c0045","tieuDe":"Chết cùng Tổ Khí trong gió xoáy","text":"Tộc trưởng bộ lạc Kim Lang mang Tổ Khí Lang Nha Chủy đến nhưng bị cuốn vào mắt gió xoáy màu xanh của cây liễu; Tổ Khí không đỡ nổi, thân hắn tan thành vũng máu, Lang Nha Chủy ảm đạm rơi xuống trước mặt tộc nhân.; Điều khiển vùng cương thổ bao la, mang Tổ Khí Lang Nha Chủy đến nhưng bị cuốn vào mắt gió xoáy, dùng Tổ Khí thất bại nên thân tan thành vũng máu, Tổ Khí ảm đạm rơi xuống được một tộc lão nâng lên.; Bị cuốn vào mắt gió xoáy của cây liễu…","anchor":"cơ thể tan vỡ từng tấc, huyết vụ bay lên"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Ba Đồ","tag":"khac","quanHe":"Thuộc hạ báo tin về Thạch thôn","ghiChu":""},{"ten":"Thiếu tộc trưởng bộ lạc Kim Lang","tag":"cha-me","quanHe":"Con ruột","ghiChu":"Cùng đến vây Thạch Thôn"},{"ten":"Ba Đồ","tag":"su-mon","quanHe":"Thuộc hạ bộ lạc, kẻ báo tin về Thạch thôn","ghiChu":"@c0041"},{"ten":"Tử Sơn Hầu","tag":"dong-minh","quanHe":"Cùng nằm trong tứ đại tộc kéo về đánh Thạch thôn","ghiChu":""},{"ten":"Ba Đồ","tag":"khac","quanHe":"Thuộc hạ cụt tay báo tin","ghiChu":"Nghe Ba Đồ kể chuyện Thạch thôn"},{"ten":"Thiếu tộc trưởng bộ lạc Kim Lang","tag":"cha-me","quanHe":"Con trai","ghiChu":"Con nối dõi, đòi báo thù rồi cũng bị cây liễu chém chết."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0041","@c0042","@c0043","@c0045"]},{"id":"chi-cuong-gia-mat-troi-tim-bao-dien","name":"Chí cường giả trong bảo điện (lãnh địa vương hầu)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Lãnh địa vương hầu (tòa thành cổ tường đen ánh kim)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (Chí cường giả) @c0041","trangThai":"song","blurb":"Chí cường giả ngồi giữa bảo điện lãnh địa vương hầu, hiện thân vầng mặt trời màu tím, khí tức như biển.","vaiTro":"Cường giả lãnh địa vương hầu, nghe tin Tế linh liền động lòng.","tinhCach":[{"text":"Uy nghi, khí tức mênh mông như biển.","chuong":"@c0041"}],"tabs":{"diem":[],"kinhLich":[{"text":"Ngồi giữa bảo điện tòa thành cổ tường đen ánh kim của lãnh địa vương hầu dân số mấy chục triệu, hiện thân vầng mặt trời màu tím, khí tức mênh mông như biển; nghe tin dãy núi Thương Mãng xuất hiện Tế linh liền động lòng.; Trong bảo điện tòa thành cổ tường đen ánh kim của lãnh địa vương hầu, một Chí cường giả hiện thân vầng mặt trời màu tím, khí tức như biển, nghe tin về Tế linh và xương quý Toan Nghê cũng động lòng.; Ngồi giữa bảo điện của lãnh đ…","anchor":"dãy núi Thương Mang xuất hiện một Tế linh ghê gớm","bridge":true,"khoang":"@c0041"}],"tuViMoc":[],"tuVi":"","nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0041"]},{"id":"chu-nhan-la-phu-dai-trach","name":"Chủ nhân La Phù Đại Trạch","gioiTinh":"nam","theLuc":[{"ten":"La Phù Đại Trạch","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chí cường giả (@c0043)","trangThai":"song","blurb":"Chí cường giả chủ nhân La Phù Đại Trạch, thúc huyết tinh dùng Bảo Thuật hóa hình một con Hung Giao khổng lồ tấn công.","vaiTro":"Một trong tứ đại tộc chủ vây đánh Thạch Thôn, phục thù cho Giao Thương.","tinhCach":[{"text":"Tàn bạo, quyết phục thù","chuong":"@c0043"}],"tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0043","tieuDe":"Hóa Hung Giao công phá Thạch Thôn","text":"Đứng ở hướng chính tây bên sông lớn, chủ nhân La Phù Đại Trạch thúc huyết tinh hóa hình một con Hung Giao khổng lồ dài hơn hai trăm trượng thoát khỏi lưng, nhào về Thạch Thôn phun hào quang đánh vỡ đá núi, nứt mặt đất.; Ở hướng chính tây ven sông lớn, thúc huyết tinh hóa một con Hung Giao khổng lồ (to một trượng, dài hơn hai trăm trượng) nhào về Thạch Thôn, phun hào quang đánh vỡ đá núi nứt mặt đất.; Đứng ở hướng chính tây bên sông lớn, chủ nhân…","anchor":"Gào một tiếng, Hung Giao màu tro đứng thẳng người lên, nhào về phía Thạch Thôn."},{"importance":"normal","chuong":"@c0044","tieuDe":"Chết dưới cành liễu","text":"Cường giả nhất La Phù Đại Trạch hóa hung giao dài hơn ba trăm mét công kích; Bảo thuật bị cây liễu hút khô khiến hắn phun máu, dùng khối xương thú thế thân cũng bị đánh nát, cuối cùng bị cành liễu chém đứt làm hai, tinh hoa mất sạch.; Dùng Bảo thuật hóa hung giao dài hơn ba trăm mét công kích, bị cành liễu xuyên thủng trán, quấn cổ hút khô tinh khí thần. Dùng khối xương thú thế thân vẫn bị đánh nát; cành liễu vươn tới con sông phương Tây chém đứ…","anchor":"đơn giản chét đứt hắn ra làm hai"},{"importance":"major","chuong":"@c0045","tieuDe":"Bị cây liễu giết","text":"Chủ nhân La Phù Đại Trạch bị cây liễu giết mất mạng ngay trong đợt bùng nổ tận diệt tứ đại cường giả.; Ngay đợt bùng nổ đầu tiên của cây liễu, chủ nhân La Phù Đại Trạch không kịp phản ứng đã mất mạng, để lại phe cánh rối loạn đòi báo thù.; Bị cây liễu giết chết ngay đầu cuộc tận diệt tứ đại cường giả.","anchor":"Chủ nhân của La Phù Đại Trạch bị mất mạng"}],"tuViMoc":[],"nhanMach":[{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Người cùng thế lực La Phù Đại Trạch bị mất một tay, là lý do phục thù"},{"ten":"Giao Thương","tag":"dong-minh","quanHe":"Thuộc hạ La Phù Đại Trạch","ghiChu":"Việc Giao Thương mất một tay thành phế nhân là cớ để La Phù Đại Trạch kéo quân phục thù Thạch Thôn. @c0043"},{"ten":"Giao Thương","tag":"su-mon","quanHe":"Người La Phù Đại Trạch, bị mất một tay ở trận trước","ghiChu":"Là lý do La Phù Đại Trạch đòi phục thù @c0043"}],"tuiDo":{}},"nguon":["@c0043","@c0044","@c0045"],"aliases":["Tộc chủ La Phù Đại Trạch"]},{"id":"thieu-toc-truong-kim-lang","name":"Thiếu tộc trưởng bộ lạc Kim Lang","gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Kim Lang","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","blurb":"Con của tộc trưởng Kim Lang, thanh niên hùng tráng mắt như sói, đòi báo thù và chủ trương vây khốn Thạch Thôn, cuối cùng bị cành liễu chém bay đầu.","vaiTro":"Người kế thừa bộ lạc Kim Lang, chủ trương vây khốn Thạch Thôn","tinhCach":[{"text":"Cứng cỏi, giận dữ đòi báo thù cho cha","chuong":"@c0045"},{"text":"Tính toán chiến thuật, phán đoán tầm với của cây liễu","chuong":"@c0045"}],"tabs":{"diem":[{"text":"Thanh niên hùng tráng mắt như sói, chủ trương vây khốn cho Thạch Thôn chết đói","chuong":"@c0045"}],"kinhLich":[{"importance":"major","chuong":"@c0045","tieuDe":"Chủ trương vây khốn rồi bị chém bay đầu","text":"Sau khi cha chết, thiếu tộc trưởng phán đoán cây liễu chỉ vươn được hơn một dặm nên chủ trương vây khốn Thạch Thôn cho chết đói; bị Thần Lang tát bay khi Tế Linh cướp Tổ Khí, rồi khi cây liễu tận diệt lần hai (cành kéo dài bốn năm dặm) thì bị chém bay đầu cùng các nhân vật nắm quyền các tộc.; Sau khi cha chết, hắn gào đòi báo thù và cầm đầu phe vây khốn; bị Thần Lang tát bay khi cố giữ Tổ Khí, rồi khi cành liễu bất ngờ kéo dài bốn năm dặm san bằ…","anchor":"Thiếu tộc trưởng của bộ lạc Kim Lang hét lớn, đầu bay lên"}],"tuViMoc":[],"nhanMach":[{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Cha chết dưới vòng xoáy cây liễu"},{"ten":"Thần Lang","tag":"doi-thu","quanHe":"Bị Thần Lang tát bay để cướp Tổ Khí (@c0045)"},{"ten":"Tộc trưởng bộ lạc Kim Lang","tag":"cha-me","quanHe":"Cha","ghiChu":"Cha bị cây liễu giết trước, hắn đòi báo thù."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0045"],"aliases":["Con tộc trưởng Kim Lang"]},{"id":"em-ruot-thu-linh-la-phu","name":"Em ruột thủ lĩnh La Phù Đại Trạch","gioiTinh":"nam","theLuc":[{"ten":"La Phù Đại Trạch","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Em ruột chủ nhân La Phù Đại Trạch, quyết không rút lui, đòi vây khốn báo thù cho huynh trưởng bị cây liễu giết.","vaiTro":"Người cầm đầu phe chủ chiến của La Phù Đại Trạch sau khi thủ lĩnh chết","tinhCach":[{"text":"Cứng đầu, đòi báo thù bằng mọi giá gây nội loạn nội bộ","chuong":"@c0045"}],"tabs":{"diem":[{"text":"Quyết không rút lui, đòi vây khốn báo thù cho huynh trưởng","chuong":"@c0045"}],"kinhLich":[{"text":"Sau khi chủ nhân La Phù Đại Trạch bị giết, quyết không rút lui mà đòi vây khốn báo thù cho huynh trưởng, khiến phe La Phù Đại Trạch suýt bạo động nội bộ giữa người muốn chạy và người ở lại.","anchor":"Chủ nhân của La Phù Đại Trạch bị mất mạng","bridge":true,"khoang":"@c0045"}],"tuViMoc":[],"nhanMach":[{"ten":"Chủ nhân La Phù Đại Trạch","tag":"ho-hang","quanHe":"Anh ruột","ghiChu":"Anh trai bị cây liễu giết"},{"ten":"Chủ nhân La Phù Đại Trạch","tag":"ho-hang","quanHe":"Anh trai","ghiChu":"Huynh trưởng bị cây liễu giết."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0045"]},{"id":"lieu-than-thach-thon","name":"Liễu Thần","cn":"","aliases":["Cây liễu cổ Thạch Thôn","cây liễu cổ Thạch Thôn","cây liễu cháy đen","cây liễu đầu thôn","Tế linh Thạch thôn","Cây liễu lớn","cổ liễu Thạch thôn","Cây liễu cháy đen","cây liễu","Cây Liễu","Liễu thụ","Cây liễu Thạch Thôn","Liễu thần"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0046)","trangThai":"song","blurb":"Liễu Thần là cây liễu cổ đầu Thạch Thôn được thôn dân tôn thờ, nhiều lần hiển linh diệt cường địch và cứu cả thôn thoát Đại Hoang. Sau nhiều chục năm im lặng, nó thức tỉnh để truyền dạy Nguyên Thủy Chân Giải, mài giũa thể phách và dẫn dắt Thạch Hạo. Cuối cùng nó mọc thêm cành non, mở Thông Thiên lữ trình đưa nhóc tỳ vào giới rồi hẹn ngày tái ngộ.","vaiTro":"Thần vật che chở Thạch Thôn — cây liễu cổ dẫn dắt Thạch Hạo","tinhCach":"Trầm mặc, ngủ say hàng chục năm mới lên tiếng; che chở tận tụy cho Thạch Thôn; nghiêm khắc mà tận tâm khi rèn giũa, dẫn dắt hậu bối","tabs":{"diem":[{"text":"Vọt cành liễu non đâm xuyên giết chết con Phi Giao của La Phù Đại Trạch, hút cạn tinh khí khiến thân nó phân hủy","chuong":"@c0040"},{"text":"Xuyên thủng trán, quấn cổ hút chết tộc chủ La Phù Đại Trạch khi kẻ này hóa hung giao dài hơn ba trăm mét","chuong":"@c0044"},{"text":"Thi triển vô thượng đại pháp chuyển cả Thạch Thôn thoát Đại Hoang cùng thú triều ở Thương Mãng Sơn Mạch","chuong":"@c0050"},{"text":"Chỉ điểm Thạch Hạo tu Nguyên Thủy Chân Giải — buộc nâng thần thiết mười vạn cân bằng sức cơ thể để rèn thân","chuong":"@c0064"},{"text":"Kiểm chứng thành quả rèn thân của nhóc tỳ, kinh thán khi một tay phát lực đã đạt mười vạn tám ngàn cân","chuong":"@c0066"},{"text":"Mọc thêm bốn cành non thành năm cành, mở Thông Thiên lữ trình bằng năm cành hóa xích thần trật tự dẫn Thạch Hạo vào giới","chuong":"@c0087"}],"kinhLich":[{"text":"Khi Phi Giao há mồm xông tới định huyết tẩy Thạch Thôn, một cành liễu non xanh biếc như điêu khắc bằng thần ngọc phát hào quang xán lạn chọc thủng trời cao, ví như xích thần trật tự, đâm thủng cơ thể con Phi Giao khiến nó im bặt — lần đầu hiển lộ uy năng phi thường, ứng lời cầu khấn của Thạch Hạo.; Sau lời khấn của Thạch Hạo, một cành liễu non xanh biếc như điêu khắc bằng thần ngọc từ cây liễu cháy đen phóng lên, phát hào quang xán lạn chọc thủn…","anchor":"một cành liễu non xanh biếc như điêu khắc bằng thần ngọc","bridge":true,"khoang":"@c0039"},{"text":"Cành liễu vọt ra đâm xuyên giết chết con Phi Giao của La Phù Đại Trạch, hút tinh khí khiến thân nó phân hủy đứt thành mấy khối; hóa dây xích chém đứt hơn chục cường giả ẩn nấp chỉ trong một hơi thở; đâm phế cánh tay phải cùng tu vi Giao Thương và thủ lĩnh bộ lạc Kim Lang; cuối cùng vươn xa hơn nửa cây số chém ngang kẻ định bẩm báo tộc chủ, chém mất bàn tay lão Lôi tộc và chú ruột Tử Sơn Hầu để cảnh cáo.; Cành liễu hóa dây xích xanh sắc hơn đao t…","anchor":"cành liễu như đóng đinh con Phi Giao ở giữa không trung","bridge":true,"khoang":"@c0040"},{"text":"Tộc chủ La Phù Đại Trạch hóa hung giao dài hơn ba trăm mét công kích; cành liễu xuyên thủng trán, quấn cổ hút khô tinh khí thần, rồi vươn tới con sông phương Tây chém đứt hắn làm hai, xác khô quắt như già mấy nghìn năm.; Khi Thạch thôn bị bốn cường giả liên thủ vây công từ mọi hướng, cây liễu bừng tỉnh phản kích: cành liễu hóa thần thông quét sạch bốn phe, biến trận vây diệt thôn thành màn ra oai chấn động bốn phương.; Lôi Hầu triệu mấy chục tần…","anchor":"đơn giản chét đứt hắn ra làm hai","bridge":true,"khoang":"@c0044"},{"text":"Sau mấy chục năm im lặng, cây liễu cổ lên tiếng lần đầu, dặn thôn dân trữ lương chuẩn bị tai họa lớn; một sức mạnh thần bí lan ra gần giống lực lượng lễ bái của tiên dân Thượng Cổ trong Cốt Thư, khiến đỉnh cổ tổ truyền cộng minh.; Cây liễu cổ ở Thạch Thôn lên tiếng lần đầu sau mấy chục năm, thôn dân dập đầu bái lạy cầu bảo vệ; Liễu Thần dặn trữ lương chuẩn bị tai họa lớn sắp tới, một sức mạnh thần bí lan ra gần giống lực lượng lễ bái của tiên dâ…","anchor":"Nghe lời căn dặn của Liễu Thần, bắt đầu trữ lương ngay","bridge":true,"khoang":"@c0046"},{"chuong":"@c0050","importance":"normal","tieuDe":"Thi Triển Đại Pháp Cứu Thôn","text":"Thi triển vô thượng đại pháp đưa cả Thạch Thôn thoát Đại Hoang / thú triều ở Thương Mãng Sơn Mạch, chuyển cả thôn vào không gian kỳ lạ rồi ra vùng đất mới; vỏ cây cháy đen nứt nẻ, cành liễu non duy nhất mất đi vẻ xanh biếc.","anchor":"Liễu Thần thi triển vô thượng đại pháp, để chúng ta tránh được một tai họa lớn"},{"text":"Cây liễu cháy đen phát hào quang xanh, cành liễu tiết giọt nước trong suốt như Tiên Châu, chữa lành vết thương xuyên bụng ngực và các lỗ trên đầu tước đỏ, khử hết ký hiệu phá hủy sinh cơ; tước đỏ tự nhận nợ một ân tình rất lớn.","anchor":"tất cả vết thương trên người nó hoàn toàn bị trừ khử","bridge":true,"khoang":"@c0051"},{"text":"Đáp lời cầu xin nhìn rõ tiềm thức của Thạch Hạo, cây liễu báo sắp ngủ một thời gian dài, hẹn chờ khi huyết khí Thạch Hạo mạnh hơn sẽ giúp nó nhìn rõ mảnh ký ức trong tiềm thức.; Khi Thạch Hạo cầu giúp nhìn rõ mảnh ký ức lạnh lùng trong tiềm thức, cây liễu thần báo sắp ngủ một thời gian dài, hẹn chờ một hai năm nữa khi huyết khí Thạch Hạo mạnh hơn.; Cây liễu báo sắp ngủ một thời gian dài, hẹn giúp Thạch Hạo nhìn rõ tiềm thức khi huyết khí nó mạnh…","anchor":"Ta sắp ngủ một thời gian dài, chờ ngươi lớn hơn chút nữa","bridge":true,"khoang":"@c0052"},{"text":"Cây liễu đầu thôn tỏa sáng bao phủ Thạch thôn, tỉnh dậy sau hơn một năm ngủ say; trói rồi thả Mao Cầu, giải thích nó là Di Chủng Thái Cổ; răn Thạch Hạo đừng đột phá gấp mà rèn thân đạt cửa ải trăm ngàn cân, nhắc tới hung thú Thái cổ như Chân Hống, Đại Bàng Kim Sí; đồng ý soi tiềm thức Thạch Hạo để hé lộ chuyện năm đó.; Khi màn đêm buông, cây liễu đầu thôn tỏa sáng bao phủ cả Thạch thôn — Liễu Thần tỉnh lại sau hơn một năm ngủ say. Nó dùng cành l…","anchor":"Hơn một năm nay nó đã ngủ say, đến bây giờ mới tỉnh dậy.","bridge":true,"khoang":"@c0054"},{"text":"Truyền âm chiếu lại trận chiến Thạch phủ Hoàng Đô cho nhóc tỳ đứng dưới gốc xem như chuyện đã qua; đối đáp triết lý với nhóc tỳ về Chí Tôn cốt, khen nó thiện lương không để cừu hận làm mất lý trí dù mất Chí Tôn cốt; vui mừng hứa cho biết một bí mật, gợi mở bằng hình ảnh cây cỏ khô héo có thể xanh tươi trở lại; Cây liễu bị cháy đen nhưng có linh trí, truyền âm chiếu lại trận chiến quá khứ cho nhóc tỳ xem, khen nó thiện lương không bị cừu hận chi…","anchor":"Cháu đã bao giờ thấy cây cỏ khô héo lại xanh tươi trở lại?","bridge":true,"khoang":"@c0062"},{"text":"Truyền âm bài kệ về niết bàn tái sinh, tiết lộ nhóc tỳ năm xưa tự tái sinh sinh cơ mà sống sót chứ Liễu Thần chỉ đứng nhìn, cảm thấy đồng bệnh tương lân; sau khi tộc trưởng trao cục xương trắng, Liễu Thần im lặng hồi lâu rồi lên tiếng đặt tên bốn chữ: Nguyên Thủy Chân Giải.; Tộc trưởng kể mấy chục năm trước một đêm sấm sét, Liễu Thần tắm trong biển sét, cành hóa thần liên đâm xuyên trời rồi gãy cháy đen rơi xuống kèm cục xương trắng. Con Chu Yếm…","anchor":"Lúc cháu sắp sửa khô kiệt thì sinh cơ lại tái hiện, từng bước từng bước tăng trưởng.","bridge":true,"khoang":"@c0063"},{"text":"Chỉ điểm nhóc tỳ cách tu Nguyên Thủy Chân Giải — lúc nhỏ phải nâng thần thiết mười vạn cân bằng sức cơ thể, mài ý chí cứng hơn sắt; trao phương thuốc trúc cơ cho Thái Cổ Hung Thú non và chỉ dùng máu Chu Yếm làm chủ dược, đồng thời chỉ nơi tu luyện nghịch dòng thác đá.; Chỉ nhóc tỳ tới vùng thác nước đá ngoài bảy mươi dặm tu luyện và cho phương thuốc chuyên trúc cơ Thái Cổ Hung Thú non; cho phép dùng đồ thường thay phụ liệu trừ chủ dược, định lấy…","anchor":"Bảo nó cứ cách mỗi ngày hiến ra một giọt máu làm chủ dược là được rồi","bridge":true,"khoang":"@c0064"},{"text":"Được Thạch Hạo nhớ lại như người từng nói về Bàn Huyết Cảnh và dùng tiêu chuẩn Thái Cổ Hung Thú để so sánh, sau khi nhóc tỳ ngộ chân nghĩa cảnh giới này.","anchor":"Đây mới là chân nghĩa của Bàn Huyết Cảnh mà Liễu Thần nói sao?","bridge":true,"khoang":"@c0065"},{"text":"Kiểm chứng thành quả rèn thân của nhóc tỳ, trầm mặc rồi kinh thán một tay phát lực đã có mười vạn tám ngàn cân thần lực, sánh với thú non mạnh nhất; chấp nhận cho nhóc tỳ tu luyện Nguyên Thủy Chân Giải và dặn tự nghiền ngẫm, không để lộ cho người khác.","anchor":"Một tay phát lực loáng cái đã có mười vạn tám ngàn cân thần lực","bridge":true,"khoang":"@c0066"},{"text":"Sắp xếp cho Thạch Hạo ra ngoài mài giũa nơi hiểm ác, dùng biện pháp rèn thú non của Chân Hống, Tỳ Hưu để tôi luyện nó, cảnh báo Đại Hoang nhiều dị chủng phải tránh.","anchor":"ta chỉ là áp dụng biện pháp mài giũa thú non của các loài hung thú Thái Cổ - Chân Hống, Tỳ Hưu để rèn luyện ngươi","bridge":true,"khoang":"@c0067"},{"text":"Truyền âm khen Thạch Hạo hoàn thành thí luyện thời Thái Cổ rồi tuyên bố bế quan, suốt một năm ngủ say không thể bảo vệ thôn dân; vỏ cây già cháy đen tróc ra, cành nhô mấy cái bướu như có vật muốn chui ra; dặn riêng nhóc tỳ đừng lãng phí thiên tư, khi tỉnh sẽ cho thấy ‘một vùng thế giới bất đồng khác’; từ đó thân cây ảm đạm, cành xanh biếc không còn phát sáng ban đêm.","anchor":"Ta muốn bế quan, trong vòng một năm đều sẽ ngủ say","bridge":true,"khoang":"@c0077"},{"text":"Đúng lúc hung khấu đe dọa Thạch Thôn thì Liễu Thần đã ngủ say, không thể ra tay bảo vệ, khiến tộc trưởng phải tự hoạch định dùng Tổ Khí quyết chiến.","anchor":"Ta nghĩ nơi Chí Tôn địa kia hẳn là còn ở khu vực này","bridge":true,"khoang":"@c0079"},{"importance":"normal","chuong":"@c0086","tieuDe":"Thức tỉnh, tiết lộ cực hạn động thiên","text":"Cây Liễu đầu thôn phát sáng, Liễu Thần thức tỉnh sau gần một năm trầm miên, mọc thêm bốn cành non (tổng năm cành), thân đen phục hồi một phần màu xanh lục và mạnh hơn trước; tiết lộ tám động thiên chỉ là tiêu chuẩn nhân tộc, chín động thiên có thực, mười động thiên mới là cực hạn — tôn sư chân chính, rồi hứa dẫn nhóc tỳ vào một thế giới thần bí nơi có thể gặp Thạch Nghị.","anchor":"A, Liễu Thần thức tỉnh rồi!"},{"importance":"normal","chuong":"@c0087","tieuDe":"Mở Thông Thiên lữ trình dẫn nhóc tỳ vào giới","text":"Giục Thạch Hạo báo tộc nhân rồi mở Thông Thiên lữ trình bằng năm cành liễu hóa xích thần trật tự xuyên thủng bầu trời, dẫn nhóc tỳ vào Hư Thần Giới; giảng giải bản chất, nguồn gốc và cách vào thế giới tinh thần này, đính chính rằng nhóc tỳ hiện chỉ là ý chí tinh thần, rồi dừng lại để nó tự đi tới nơi rèn luyện.","anchor":"năm cành liễu tỏa sáng rực rỡ xuyên thủng bầu trời, giống như mở ra một cánh cửa pháp tắc"},{"text":"Từ chối cho nhóc tỳ quay lại Hư Thần Giới, hẹn hai năm sau; bộc phát thần lực — năm cành non xuyên thủng bầu trời mở cửa Hư Không đưa ý chí nhóc tỳ về Thạch thôn; dặn phải trở về tẩy lễ trước 12 tuổi.","anchor":"năm cành non phóng đại, dài không biết bao nhiêu dặm, vọt lên xuyên thủng bầu trời.","bridge":true,"khoang":"@c0095"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Răn dạy Thạch Hạo về tu hành, đồng ý giúp xem tiềm thức"},{"ten":"Chu Yếm","tag":"khac","quanHe":"Trói rồi thả Mao Cầu khi nó gặm chồi liễu"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Thần linh được nhóc tỳ cầu khấn","ghiChu":"Hiển linh cứu Thạch Thôn sau lời khấn của nhóc tỳ @c0039"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Răn dạy và đồng ý giúp Thạch Hạo xem tiềm thức","ghiChu":"@c0054"},{"ten":"Chu Yếm","tag":"khac","quanHe":"Trói treo rồi thả Mao Cầu; để ý lai lịch Di Chủng Thái Cổ của nó","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nhóc tỳ khấn Liễu Thần xin bảo vệ Thạch Thôn, tin cây liễu có thể nghe lời.","ghiChu":"@c0039"},{"ten":"Thạch thôn","tag":"khac","quanHe":"Tế linh trấn giữ","ghiChu":"Bảo hộ toàn thôn, đêm tỏa vầng sáng bao phủ (@c0040)"},{"ten":"Giao Thương","tag":"doi-thu","quanHe":"Người bị phế bởi cành liễu","ghiChu":"Đâm xuyên cánh tay phải, hút ánh sáng thần (@c0040)"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Trưởng bối Thạch thôn cùng phe","ghiChu":"Cùng đuổi các tộc (@c0040)"},{"ten":"Tiểu Hồng","tag":"an-nhan","quanHe":"Được cứu trị và nợ ân tình","ghiChu":"Trị lành mọi thương thế cho tước đỏ (@c0051)."},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Bảo hộ và chỉ dẫn Thạch Hạo","ghiChu":"Hẹn tỉnh dậy sau một hai năm để giúp Thạch Hạo nhìn rõ tiềm thức."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"chỉ điểm nhóc tỳ cách tu hành và cung cấp phương thuốc trúc cơ","ghiChu":"@c0064"},{"ten":"Chu Yếm","tag":"doi-thu","quanHe":"chỉ định máu Chu Yếm làm chủ dược khiến nó nổi giận","ghiChu":"@c0064"},{"ten":"Giao Thương","tag":"doi-thu","quanHe":"Đối phương bị Liễu Thần đâm phế cánh tay và tu vi","ghiChu":"@c0040"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Người Thạch thôn được Liễu Thần bảo hộ","ghiChu":"@c0040"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Cây liễu cổ giúp Thạch Hạo, hẹn tỉnh dậy giúp nhìn rõ tiềm thức","ghiChu":""},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Răn dạy và đồng ý xem tiềm thức Thạch Hạo về quá khứ","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nhóc tỳ nghe truyền âm, được hứa tiết lộ bí mật","ghiChu":""},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được cầu khấn bảo hộ","ghiChu":"Thạch Hạo tin cây liễu cháy đen có thể nghe lời và bảo vệ làng."},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Răn dạy Thạch Hạo và đồng ý soi tiềm thức giúp cậu biết quá khứ","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử/hậu bối được chỉ dẫn","ghiChu":"Cho tu Nguyên Thủy Chân Giải sau khi thân thể đạt cực cảnh (@c0066)"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đệ tử được chỉ dẫn tu hành","ghiChu":"Được Liễu Thần sắp xếp đi mài giũa (@c0067)"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Đứa trẻ được bảo hộ và dẫn dắt","ghiChu":"Trông nom khi thần du, dặn tẩy lễ"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0046","@c0050","@c0054","@c0026","@c0039","@c0044","@c0052","@c0040","@c0051","@c0062","@c0063","@c0064","@c0065","@c0066","@c0067","@c0068","@c0077","@c0079","@c0086","@c0087","@c0095"]},{"id":"sinh-vat-mat-xanh-biec","name":"Sinh vật mắt xanh biếc","cn":"","aliases":["Hung thú mắt xanh","Hung thú khổng lồ mắt xanh"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tán tu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chí cường giả (@c0046)","trangThai":"song","blurb":"Sinh vật khổng lồ đỉnh thiên lập địa, mắt xanh biếc đường kính mấy dặm, tranh đoạt thánh vật trong Thương Mãng Sơn Mạch.","vaiTro":"Một trong bốn sinh vật cực mạnh tranh báu vật","tinhCach":[{"text":"Hung tợn, sát khí kinh thiên, ngạo mạn tuyên bố thánh vật là của mình","chuong":"@c0046"}],"tabs":{"diem":[{"text":"Sinh vật đỉnh thiên lập địa, mắt xanh biếc đường kính mấy dặm, sát khí kinh thiên","chuong":"@c0046"}],"kinhLich":[{"importance":"normal","chuong":"@c0046","tieuDe":"Tranh thánh vật giữa đại chiến sơn mạch","text":"Cái bóng khổng lồ đỉnh thiên lập địa với đôi mắt xanh biếc đường kính mấy dặm tuyên bố thánh vật là của mình, thi triển Bảo Thuật phun hào quang đấu với đối thủ dùng côn sắt; sau khuyên đối thủ rút lui vì sợ lưỡng bại câu thương với con chim đỏ nhỏ.; Sinh vật đỉnh thiên lập địa, mắt xanh biếc đường kính mấy dặm, sát khí kinh thiên, tuyên bố thánh vật là của mình; giao chiến với đối thủ dùng côn sắt, thò bàn chân che phủ mấy dải núi và khuyên đối…","anchor":"Thánh vật này là của ta"},{"importance":"normal","chuong":"@c0049","tieuDe":"Nuốt chửng Tử Sơn Tộc, hô hào tuyệt diệt","text":"Hung thú đỉnh thiên lập địa ẩn trong sương mù, giao đấu chim đỏ rồi lao đến lãnh địa Tử Sơn Tộc, há mồm như biển máu nuốt cả vương thành và nhân khẩu khiến Tế Linh nổ tung; tuyên bố trong mười vạn dặm sẽ không còn sinh linh nào tồn tại, hứa cho con nổi bật đi theo tu luyện ở Thần Sơn.; Cùng Thôn Thiên Tước điên cuồng hô hào huyết tẩy vùng đất mười vạn dặm bất kể Nhân Tộc hay tộc quần khác, hứa cho con nào nổi bật được đi theo tu luyện ở Thần Sơn…","anchor":"Tử Sơn Tộc đã bị diệt tộc, trừ một Tử Sơn Hầu đang không biết ở đâu ra"}],"tuViMoc":[],"tuVi":"Chí cường giả, chưa rõ cảnh giới cụ thể.","nhanMach":[{"ten":"Sinh vật dùng côn sắt","tag":"doi-thu","quanHe":"Đối thủ tranh thánh vật trong dãy núi","ghiChu":"Giao chiến bằng côn sắt (@c0046)"},{"ten":"Đối thủ dùng côn sắt (chưa lộ tên)","tag":"doi-thu","quanHe":"Giao chiến tranh đoạt thánh vật giữa Thương Mãng Sơn Mạch","ghiChu":"@c0046"},{"ten":"Đối thủ dùng côn sắt (chưa lộ tên)","tag":"doi-thu","quanHe":"Đối thủ giao chiến tranh thánh vật trong sâu Thương Mãng Sơn Mạch","ghiChu":"@c0046"},{"ten":"Con chim đỏ nhỏ","tag":"khac","quanHe":"Cùng nằm trong bốn sinh vật cực mạnh đại chiến tranh hỗn độn chí bảo","ghiChu":"@c0046"},{"ten":"Đối thủ dùng côn sắt (chưa lộ tên)","tag":"doi-thu","quanHe":"Tranh đoạt thánh vật, giao chiến trong sâu dãy núi","ghiChu":"@c0046"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0046","@c0047","@c0049"]},{"id":"sinh-vat-con-sat","name":"Sinh vật dùng côn sắt","cn":"","aliases":["Đối thủ dùng côn sắt"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tán tu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chí cường giả (@c0046)","trangThai":"song","blurb":"Sinh vật khổng lồ dùng thanh côn sắt to như cột chống trời, được ký hiệu nguyên thủy gia trì, đối đầu sinh vật mắt xanh.","vaiTro":"Một trong bốn sinh vật cực mạnh tranh báu vật","tinhCach":[{"text":"Cường hãn, dùng côn sắt khổng lồ đánh trả","chuong":"@c0046"}],"tabs":{"diem":[{"text":"Sinh vật khổng lồ dùng thanh côn sắt to như cột chống trời, được ký hiệu nguyên thủy gia trì","chuong":"@c0046"}],"kinhLich":[{"text":"Ẩn trong sương mù, dùng côn sắt khổng lồ quét sụp cả vòm trời đối đầu Thôn Thiên Tước, mở mắt dọc giữa mi tâm phát kim quang hóa Tiên Kiếm chém về Thiên Địa Hồng Lô đen, cùng chim đỏ giằng co hai chí tôn tà ác để hạn chế tổn thất mười vạn dặm.","anchor":"Đây là một trận chiến sinh tử, bọn chúng đã dồn hết sức mình","bridge":true,"khoang":"@c0049"}],"tuViMoc":[],"tuVi":"Chí cường giả, chưa rõ cảnh giới cụ thể.","nhanMach":[{"ten":"Sinh vật mắt xanh biếc","tag":"doi-thu","quanHe":"Đối thủ tranh thánh vật","ghiChu":"Giao chiến trong Thương Mãng Sơn Mạch (@c0046)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0046","@c0049"]},{"id":"thon-thien-tuoc","name":"Thôn Thiên Tước","cn":"","aliases":["Ma Cầm khổng lồ","Thôn Thiên Tước","Thanh Lân Ưng"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tán tu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Hung cầm khổng lồ trong truyền thuyết, mắt trăng máu, thân lớn hơn mây đen, há mỏ phun ô quang nuốt trọn sinh linh để hấp thu huyết khí.","vaiTro":"Thần thú/hung cầm cổ xưa, xuất hiện trong họa loạn Đại Hoang, diệt Lôi tộc để nuốt huyết khí.","tinhCach":[{"text":"Tàn bạo, hung hãn, nuốt trọn cả tộc người để bổ sung huyết khí","chuong":"@c0048"}],"tabs":{"diem":[{"text":"Hung cầm truyền thuyết, mắt trăng máu, thân hình lớn hơn cả mây đen","chuong":"@c0048"},{"text":"Há mỏ phun chùm ô quang hút trọn sinh linh, nghiền nát thành sương máu để hấp thu huyết khí","chuong":"@c0048"}],"kinhLich":[{"importance":"normal","chuong":"@c0048","tieuDe":"Diệt Lôi tộc, nuốt huyết khí phục hồi","text":"Con hung cầm mắt trăng máu bắt được Thánh vật rồi lao tới lãnh địa vương hầu của Lôi tộc mấy ngàn vạn nhân khẩu, há mỏ phun chùm ô quang hút trọn toàn bộ dân chúng vào mỏ, nổ nát thành sương máu; nhờ hấp thu lượng huyết khí cực lớn mà được tẩm bổ, tinh thần phấn chấn, hết vẻ mệt mỏi, tự nhủ miễn cưỡng cũng đủ no nhẹ.; Con hung cầm khổng lồ mắt trăng máu, thân lớn hơn mây đen, bắt được Thánh vật trắng nõn rồi bay ra xa, lao tới lãnh địa vương hầu…","anchor":"trời ơi là một con Thôn Thiên Tước trong truyền thuyết!"},{"importance":"normal","chuong":"@c0049","tieuDe":"Diệt Lôi Tộc, huyết tẩy mười vạn dặm","text":"Là một trong tứ đại chí tôn, thân hình lớn hơn núi Thái Cổ, dùng lông đen ngưng luyện Thiên Địa Hồng Lô đối đầu sinh linh cầm côn sắt; nuốt chửng mấy nghìn vạn người cùng mấy chục tòa thành của Lôi Tộc khiến tộc này tuyệt diệt, rồi cùng hung thú mắt xanh hạ lệnh huyết tẩy vùng đất.; Trên bầu trời vùng đất mười vạn dặm, Thôn Thiên Tước triển Thiên Địa Hồng Lô đối đầu sinh linh cầm côn sắt có mắt dọc mi tâm, đồng thời nuốt chửng mấy nghìn vạn ngườ…","anchor":"Lôi Tộc hùng mạnh nhất, từng thống trị vùng đất này đã trở thành khói bụi lịch sử"}],"tuViMoc":[],"tuVi":"Hung cầm cổ xưa cấp truyền thuyết, sức mạnh khủng bố đủ diệt cả một tộc vương hầu.","nhanMach":[],"tuiDo":{"phapBao":[{"ten":"Thánh vật (trắng nõn óng ánh)","loai":"thánh vật","trangThai":"dang-co","moTa":"Vật phẩm mà tứ đại sinh linh Chí tôn quyết chiến tranh đoạt; Thôn Thiên Tước bắt được rồi bay ra xa.","nguon":"@c0048"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0048","@c0049","@c0047"]},{"id":"toan-nghe-hoang-kim","name":"Toan Nghê Hoàng Kim","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tán tu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Cổ thú hung mãnh từng đại chiến Bò Ma Ly Hỏa và đánh gãy một sừng lửa của nó.","vaiTro":"Được nhắc tới như đối thủ cũ của Bò Ma Ly Hỏa; không xuất hiện trực tiếp.","tinhCach":[],"tabs":{"diem":[{"text":"Từng đại chiến Bò Ma Ly Hỏa và đánh gãy một sừng lửa của nó","chuong":"@c0048"}],"kinhLich":[],"tuViMoc":[],"tuVi":"Cổ thú hung mãnh, sức chiến đủ làm gãy sừng lửa của Bò Ma Ly Hỏa.","nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0048"]},{"id":"cha-me-thach-hao","name":"Cha mẹ Thạch Hạo","aliases":["Thúc thúc oai hùng mang bệnh","A di xinh đẹp","Tử Lăng (cha)","thúc thúc oai hùng mang bệnh","a di xinh đẹp","Đôi vợ chồng trẻ"],"gioiTinh":"khac","trangThai":"mat-tich","blurb":"Cha mẹ ruột của Thạch Hạo, chăm sóc nó ở Thạch thôn mấy tháng rồi rời đi tìm Thánh dược trị tận gốc bệnh cho nó, chưa lộ tên.","vaiTro":"Cha mẹ ruột của nhân vật chính, đi tìm Thánh dược ở cổ địa nguyên thủy nguy hiểm rồi mất tích.","tabs":{"diem":[],"kinhLich":[{"text":"Chăm sóc Thạch Hạo ở thôn mấy tháng, khi biết con sẽ sống sót thì rời đi tìm Thánh dược trị tận gốc bệnh cho nó; thúc thúc oai hùng mang bệnh, a di xinh đẹp, tung tích để ngỏ.","anchor":"bọn họ muốm tìm Thánh dược để trị tận gốc bệnh tình của cháu","bridge":true,"khoang":"@c0052"},{"text":"Trong ký ức tế trời của cổ quốc, người đàn ông cao lớn và người phụ nữ xinh đẹp như hoa bế Hạo Nhi quấn tã, định khuyên can khi Lão Thập Ngũ nhỏ bảo huyết Thần Cầm cho con vì con còn nhỏ.","anchor":"Cháu trai ngoan, nếm thử bảo huyết của Thần Cầm này. Tương lai cháu nhất định sẽ vượt xa gia gia và cha của cháu đấy.","bridge":true,"khoang":"@c0055"},{"chuong":"@c0057","importance":"normal","tieuDe":"Bí mật tối cao về Chí Tôn Cốt của con","text":"Chỉ vợ chồng ông biết Thạch Hạo mang Chí Tôn Cốt bẩm sinh; chuyện này được liệt vào hàng tuyệt mật của Thạch Tộc, chỉ vài người rõ.; Trước khi rời đi, cha mẹ Thạch Hạo đem con nhờ Tứ Thái Gia và một người khác (Lão Ngũ) trông hộ; Tứ Thái Gia còn sai cao thủ ngầm đi theo bảo vệ.","anchor":"chỉ có họ mới biết về Chí Tôn Cốt trong cơ thể nó, chuyện này được liệt vào hàng tuyệt mật."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột, để lại thôn khi đi tìm Thánh dược","ghiChu":"@c0052"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (Hạo Nhi)","ghiChu":"Bế Hạo Nhi lúc quấn tã tại đại lễ. (@c0055)"},{"ten":"Thập Ngũ Gia","tag":"cha-me","quanHe":"Cha / cha chồng","ghiChu":"Đôi vợ chồng trẻ gọi Lão Thập Ngũ là Cha. (@c0055)"},{"ten":"Tứ Thái Gia","tag":"an-nhan","quanHe":"Trưởng bối bối phận cực cao được gửi trông nom Thạch Hạo; xưng hô thân thiết với Tử Lăng","ghiChu":"@c0057"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột","ghiChu":"Rời thôn đi tìm Thánh dược trị bệnh cho Thạch Hạo."},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Cha mẹ ruột của Thạch Hạo (Hạo Nhi)"},{"ten":"Lão Thập Ngũ","tag":"ho-hang","quanHe":"Gọi ông là ‘Cha’ — Lão Thập Ngũ là gia gia của con họ"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (Hạo Nhi) thời sơ sinh","ghiChu":"@c0055"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Trưởng bối nhỏ bảo huyết Thần Cầm cho con họ","ghiChu":"@c0055"}],"tuiDo":{}},"nguon":["@c0052","@c0055","@c0057"]},{"id":"chu-yem-di-chung","name":"Chu Yếm (quả cầu vàng)","cn":"朱厭","aliases":["Quả cầu vàng","Sinh linh ba đầu sáu tay","Tiểu Chu","Mao Cầu"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ (bị trọng thương) @c0053","trangThai":"song","blurb":"Sinh linh giống khỉ chân đỏ có hai sừng, được cho là Thái Cổ Di Chủng huyết mạch không thuần liên hệ hung thú Chu Yếm truyền thuyết; tính tham ăn, biết dùng Bảo Thuật ba đầu sáu tay.","vaiTro":"Sinh linh kỳ dị được nhóc tỳ thu nhận về Thạch Thôn.","tinhCach":[{"text":"Tham ăn, hiền lành khi được cho ăn, mặc người nghịch cũng không giận.","chuong":"@c0053"}],"tabs":{"diem":[{"text":"Chân đỏ rực như than lửa, đầu ẩn hai sừng trong lông vàng — khác mô tả Chu Yếm truyền thuyết.","chuong":"@c0053"},{"text":"Biết dùng Bảo Thuật ba đầu sáu tay, khi thu lại trở về một đầu hai tay bình thường.","chuong":"@c0053"}],"kinhLich":[{"importance":"normal","chuong":"@c0053","tieuDe":"Lột xác thu Bảo Thuật","text":"Tỏa kim quang, toàn thân rạn nứt bong da cũ, ba đầu sáu tay biến về một đầu hai tay, thu nhỏ còn hơn ba tấc tròn vo màu vàng.; Bị trọng thương, một chân kẹt trong bùn cứng dưới đáy hồ lớn khô cạn, đói khát; được Tiểu Thạch Hạo cho ăn thịt khô.; Về Thạch Thôn ăn sạch túi thịt khô; tộc trưởng Thạch Vân Phong nâng chân thấy đỏ rực, kết luận đây là Thái Cổ Di Chủng huyết mạch Chu Yếm không thuần; nhóc tỳ phát hiện hai sừng ẩn trong lông vàng.","anchor":"Sinh linh nhìn giống như khỉ này đột nhiên tỏa kim quang khắp người"},{"text":"Mao Cầu trộm hai mươi mấy quả trứng dị cầm; đêm định gặm chồi non chí cường của cây liễu đầu thôn thì bị cành liễu trói treo giữa không trung. Thạch Hạo giải thích nó cũng là Di Chủng Thái Cổ nhưng phù văn bể nát, quên hết quá khứ; Liễu Thần thả nó ra.; Quả cầu vàng kim Chu Yếm chuyên ăn trộm đồ ăn khắp Thạch thôn, bị Hổ thẩm đuổi đánh bằng cục xương nhưng đánh vào kêu coong như thiết thạch không hề đau. Bị nhốt dưới đáy hồ một năm không ăn uống…","anchor":"nó không phải là khỉ, nó là con Chu Yếm đó","bridge":true,"khoang":"@c0054"}],"tuViMoc":[],"nhanMach":[{"ten":"Nhóc tỳ","tag":"an-nhan","quanHe":"Được nhóc tỳ cứu, cho ăn và thu nhận về Thạch Thôn","ghiChu":"Nhóc tỳ đau lòng rơi lệ khi thấy sừng của nó @c0053"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Được tộc trưởng nhận diện là di chủng Chu Yếm huyết mạch không thuần","ghiChu":"@c0053"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Được Thạch Hạo đặt tên, nhận ra thân phận Di Chủng Thái Cổ"},{"ten":"Liễu Thần","tag":"khac","quanHe":"Bị Liễu Thần trói rồi thả khi gặm chồi liễu"}],"tuiDo":{}},"nguon":["@c0053","@c0054"]},{"id":"ho-tham-thach-thon","name":"Hổ thẩm","gioiTinh":"nu","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Người phụ nữ trung niên cao lớn, vợ Lâm Hổ thúc (Thạch Lâm Hổ).","tabs":{"diem":[],"kinhLich":[{"text":"Hổ thẩm đuổi đánh quả cầu vàng Chu Yếm bằng cục xương vì lần thứ sáu trong nửa tháng nó trộm giò thú, nhưng đánh vào chỉ kêu coong như bổ vào thiết thạch, không làm nó đau.; Hổ thẩm đuổi đánh Chu Yếm bằng cục xương vì lần thứ sáu trong nửa tháng nó trộm giò thú, nhưng đánh vào chỉ kêu coong như bổ vào thiết thạch.","anchor":"nó không phải là khỉ, nó là con Chu Yếm đó","bridge":true,"khoang":"@c0054"},{"text":"Cùng đám tộc trưởng, phụ nữ, đàn ông và bọn trẻ vây tới lau nước mắt cho nhóc tỳ, khẳng định Thạch Thôn mãi là nhà, họ mãi là người thân của nó dù nó có biết thân thế hay không.","anchor":"Nơi đây chính là nhà của nhóc tỳ cháu.","bridge":true,"khoang":"@c0063"}],"nhanMach":[{"ten":"Thạch Lâm Hổ","tag":"the-thiep","quanHe":"Vợ của Lâm Hổ thúc (Thạch Lâm Hổ)"},{"ten":"Chu Yếm","tag":"doi-thu","quanHe":"Đuổi đánh Mao Cầu vì trộm đồ ăn"},{"ten":"Thạch Lâm Hổ","tag":"the-thiep","quanHe":"Vợ của Lâm Hổ thúc","ghiChu":"@c0054"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0054","@c0063"]},{"id":"bi-hau-cha","name":"Cha của Bì Hầu","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Hán tử cường tráng Thạch Thôn, bị Bái Thôn bắn tên xuyên phổi trọng thương nhưng kiên cường không cho vợ con khóc. (+) Dân Thạch Thôn, bị người Bái Thôn bắn tên trúng lá phổi khi tranh đoạt mồi săn. [CAN-SOAT-GOP] (+) Thành viên đội săn của Thạch Thôn, bị người Bái Thôn bắn tên trúng lá phổi. [CAN-SOAT-GOP]","tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0012","tieuDe":"Bị người Bái Thôn bắn trọng thương","text":"Là thành viên đội săn Thạch Thôn; khi người Bái Thôn cách mấy chục dặm xâm nhập khu săn bắn tranh mồi, cha Bì Hầu bị bắn một mũi tên trúng lá phổi, suýt mất mạng.; Đi săn cùng đội, bị người Bái Thôn bắn tên trúng lá phổi khi tranh đoạt mồi săn trong khu săn bắn Thạch Thôn, được khiêng về.; Trong lần đội săn Thạch Thôn ra khu săn bắn, người Bái Thôn cách mấy chục dặm xâm nhập tranh đoạt mồi săn. Cha Bì Hầu bị bắn một mũi tên trúng lá phổi, thương…","anchor":"còn suýt nữa bắn chết cha của Bì Hầu"},{"importance":"normal","chuong":"@c0013","tieuDe":"Trọng thương vì tên Bái Thôn","text":"Bị người Bái Thôn vượt giới bắn một mũi tên sắt dài một mét ba xuyên thủng giáp hộ thân, thấu phổi phải ra tới sau lưng, suýt mất mạng; được Thạch Lâm Hổ sơ cứu rồi tộc trưởng rút tên, cầm máu và cho thuốc tím cứu sống.; Bị một mũi tên sắt bắn thủng giáp hộ thân, xuyên phổi phải ra tới sau lưng, suýt mất mạng; kiên cường trợn mắt mắng không cho vợ con khóc, được tộc trưởng rút tên và cho thuốc tím trị thương.; Bị một mũi tên sắt dài một mét ba b…","anchor":"một mũi tên sắt đã bắn thủng giáp hộ thân của hắn, xuyên qua phổi phải ra tới sau lưng"}],"nhanMach":[{"ten":"Bì Hầu","tag":"cha-me","quanHe":"Cha của Bì Hầu","ghiChu":"@c0012"},{"ten":"Bì Hầu","tag":"cha-me","quanHe":"Con trai của Thạch Thủ Sơn","ghiChu":"Bì Hầu khóc lớn ôm cha khi hắn trọng thương."},{"ten":"Thạch Trung Hầu","tag":"cha-me","quanHe":"cha ruột của Bì Hầu","ghiChu":"@c0012"},{"ten":"Bì Hầu","tag":"cha-me","quanHe":"Con trai","ghiChu":"Con trai ôm khóc khi cha trọng thương về @c0013"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Tộc trưởng cứu mạng","ghiChu":"Rút tên và trị thương cho hắn @c0013"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng tộc sơ cứu","ghiChu":"Xử lý vết thương ban đầu @c0013"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Tộc trưởng cứu chữa","ghiChu":"Rút mũi tên và trị thương cầm máu cho hắn"},{"ten":"Thạch Trung Hầu","tag":"cha-me","quanHe":"Con trai","ghiChu":"Bì Hầu khóc lớn xông ra ôm cha khi hắn trọng thương trở về."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng tộc, người sơ cứu vết thương","ghiChu":"Lâm Hổ dán thuốc lâu năm và nấu thuốc chân huyết hung thú cứu Thủ Sơn."},{"ten":"Bì Hầu","tag":"cha-me","quanHe":"Cha con","ghiChu":"Con trai; khi Thủ Sơn bị thương thì khóc lớn xông ra ôm cha."},{"ten":"Bì Hầu","tag":"cha-me","quanHe":"Cha của Bì Hầu","ghiChu":""}],"tuViMoc":[]},"nguon":["@c0012","@c0013"],"aliases":["cha của Bì Hầu","Thủ Sơn","Bì Hầu","cha Bì Hầu","Tộc trưởng bộ lạc Kim Lang","#thach-thu-son"]},{"id":"ho-nuu-thach-thon","name":"Hổ Nữu","gioiTinh":"nu","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Con gái chú Hổ ở Thạch thôn, được tộc nhân nhắc chuyện đính ước với nhóc tỳ.","vaiTro":"Nhân vật phụ Thạch thôn.","tabs":{"diem":[],"kinhLich":[{"text":"Con gái Thạch Lâm Hổ, tuổi nhỏ hơn nhóc tỳ; được cha đề nghị đính hôn với nhóc tỳ và cùng Thạch Phi Giao ‘bức cung’ đòi cậu cưới mình.","anchor":"cháu xem Hổ Nữu nhà ta thế nào","bridge":true,"khoang":"@c0086"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"the-thiep","quanHe":"Được nhắc chuyện đính ước","ghiChu":"@c0033"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được cha Thạch Lâm Hổ đề nghị đính hôn","ghiChu":"@c0086"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0033","@c0086"]},{"id":"ong-lao-long-tuyet-van-thien-cung","name":"Ông lão cầm lông tuyết","aliases":["Ông lão Vân Thiên Cung","lão cầm lông tuyết"],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Cung","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Cường giả tới từ Vân Thiên Cung, được Thạch Hạo nhờ làm trọng tài phân định mạnh yếu.","vaiTro":"Trọng tài chủ trì công đạo trong trận đấu Bảo Thuật.","tabs":{"kinhLich":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được Thạch Hạo mời làm trọng tài","ghiChu":"Thạch Hạo mời ông lão chủ trì công đạo (@c0038)."}],"tuViMoc":[]},"nguon":["@c0038"]},{"id":"thach-hao","name":"Thạch Hạo","gioiTinh":"nam","canhGioiCaoNhat":"Phàm nhân (@c0012)","trangThai":"song","tabs":{"diem":[{"text":"Trời sinh Chí Tôn cốt (Nguyên thủy bảo cốt cực hiếm), được cha xác nhận từ sơ sinh","chuong":"@c0056"},{"text":"Lột xác qua tẩy lễ dược đỉnh bằng huyết thanh vàng kim và chân huyết ba Di chủng Thái cổ, đạt thần lực tám ngàn cân khi chưa đủ bốn tuổi","chuong":"@c0032"},{"text":"Bị Lục tẩu cùng bóng đen moi mất Chí Tôn cốt cấy sang Thạch Nghị, rơi vào cửa tử","chuong":"@c0056"},{"text":"Đột phá Động Thiên cảnh, mở liền ba Động Thiên trong một lần — điều chưa từng thấy","chuong":"@c0082"},{"text":"Thu phục Sư Tử chín đầu (Hoàng Kim sư tử) làm tọa kỵ và đoạt Ấu Thần giữa vòng vây","chuong":"@c0125"},{"text":"Khí tức Chí Tôn cốt tái sinh khi luyện hóa Thái Nhất Chân Thủy, hé lộ thân thế","chuong":"@c0135"}],"kinhLich":[{"importance":"normal","chuong":"@c0005","tieuDe":"Nâng bổng đỉnh đồng ngàn cân","text":"Trong buổi thi thố ở Thạch Thôn, Thạch Hạo ba tuổi rưỡi bê trục đá, ném cối đá xa sáu bảy mươi mét, vật ngã trâu mộng; vì thấp không với tới quai đỉnh, nó ngồi sụp nâng đáy đỉnh, nhấc bổng đỉnh đồng ngàn cân qua chỏm đầu khiến cả thôn sững sờ, ví nó như hung thú non Thái Cổ.; Hai năm trôi qua, nhóc tỳ nay ba tuổi rưỡi, chính thức mang tên riêng Thạch Hạo, thể chất khỏe kinh người, thường theo đám đàn anh chạy nhảy khắp thôn.; Trong buổi thi thố……","anchor":"nhấc bổng đỉnh đồng lên khỏi mặt đất, đỉnh bị nó nhấc lên quá chỏm đầu"},{"text":"Thạch Hạo hiểu chuyện, khuyên tộc trưởng nghỉ ngơi; khi đội săn trở về, Thạch Lâm Hổ hái tặng nó túi Tương Quả — món quả nó thích ăn nhất. Nó chưa biết tộc trưởng đang âm thầm chuẩn bị nghi thức tẩy lễ cho mình.; Thạch Hạo mới ba tuổi nhấc bổng chiếc đỉnh đồng nặng ngàn cân rồi ném xuống đất, khiến cả dân làng sững sờ. Thủ lĩnh đội săn Thạch Lâm Hổ khẳng định đó là sức mạnh cơ thể thuần túy chứ không phải nhờ cốt văn, một điều hiếm thấy ngay cả……","anchor":"mỗi con mãnh thú cuối cùng chỉ rơi ra một giọt chảy vào trong bình ngọc","bridge":true,"khoang":"@c0006"},{"text":"Cùng bọn trẻ Thạch Thôn trốn người lớn vào rừng nguyên thủy, tới sào huyệt Thanh Lân Ưng trong rừng đá. Ném đá thăm dò không thấy hung cầm, cậu trèo lên trước vách đá cao chừng ba trăm mét, cùng bọn trẻ phát hiện ba quả trứng Thanh Lân Ưng nằm trong Ngô Sào.; Cùng đám trẻ Thạch Thôn trốn người lớn vào rừng nguyên thủy tìm sào huyệt Thanh Lân Ưng. Sau khi ném đá thăm dò không thấy hung cầm, Thạch Hạo trèo vách đá cao khoảng ba trăm mét lên trước……","anchor":"giống như một con khỉ con, vèo một tiếng nhanh chóng trèo thoăn thoắt lên dốc đá","bridge":true,"khoang":"@c0007"},{"text":"Nhờ ngày nào cũng học cốt văn, nhận ra ba quả trứng trộm được là trứng Thanh Lân Ưng — đời sau Thái Cổ Ma Cầm, huyết mạch còn mảnh vụn phù văn truyền thừa; thu các tấm vảy kim loại và đỡ Thạch Đại Tráng rời Thạch Lâm trước khi hung cầm về tổ.; Trong lần cùng nhóm trẻ trộm ba quả trứng hung cầm ở Thạch Lâm, nhờ ngày nào cũng học cốt văn, Thạch Hạo nhận ra đây là trứng Thanh Lân Ưng — đời sau của Thái Cổ Ma Cầm, huyết mạch còn giữ mảnh vụn phù văn…","anchor":"Thanh Lân Ưng là đời sau của Thái Cổ Ma Cầm","bridge":true,"khoang":"@c0008"},{"text":"Thạch Hạo mượn thiết mâu nặng bốn năm chục cân, lấy đà tăng tốc ném về mắt Thanh Lân Ưng, làm bong một miếng vẩy ở khóe mắt khiến nó chảy máu; sau đó đề xuất chọc giận hung cầm để tạo động tĩnh lớn chờ cứu viện.; Bị Thanh Lân Ưng truy sát không kịp về thôn, Thạch Hạo dẫn cả bọn chui vào một thạch động ẩm ướt nó từng tìm ra khi đuổi theo con chim tước đỏ, chạy sâu mấy chục mét để né hung cầm.; Mượn cây thiết mâu nặng bốn năm chục cân, Thạch Hạo l…","anchor":"ở khóe mắt con hung cầm này cũng đã bong mất một miếng vẩy","bridge":true,"khoang":"@c0009"},{"text":"Bé Thạch Hạo ba tuổi rưỡi không bị phạt đòn mà còn được uống sữa thú vì kể cho tộc trưởng nghe chuyện Tiểu Hồng — con chim sẻ đỏ rực (nghi Chu Tước/Thần Tước truyền thuyết) nó từng đuổi bắt, dù lũ trẻ không tin. Nhóc tỳ cũng góp ý trả ba quả trứng cho Thanh Lân Ưng đang canh ngoài thôn.; Không bị phạt đòn, còn được thưởng sữa thú vì kể cho tộc trưởng nghe chuyện con chim sẻ đỏ rực (Tiểu Hồng, gợi truyền thuyết Chu Tước/Thần Tước) mà nó từng đuổi…","anchor":"Tiểu Hồng chính là con chim sẻ toàn thân đỏ rực đó.","bridge":true,"khoang":"@c0010"},{"importance":"normal","chuong":"@c0012","tieuDe":"Lĩnh ngộ Bí Cốt Bảo Thư","text":"Ôm cổ Tử Vân nghiên cứu ấn ký phù văn nguyên thủy, đối chiếu phù văn Đại Bằng và Tiểu Thanh; ngộ ra và thi triển vầng trăng bạc thần thánh chém đôi tảng đá cao năm sáu mét, mặt cắt bằng phẳng. Được tộc trưởng Thạch Vân Phong khen thiên tư kinh người, dặn đây là Bí Cốt Bảo Thư cực hiếm không nên tùy tiện thi triển.; Thạch Hạo dạy cốt văn cho ba con Thanh Lân Ưng rồi nghiên cứu phù văn nguyên thủy trong cơ thể chúng, lĩnh ngộ được bảo phù Bí Cốt B…","anchor":"một vầng trăng sáng lộng lẫy và thần thánh bay ra"},{"text":"Chưa đầy bốn tuổi, Thạch Hạo đấu tay đôi với thiếu niên Bái Phong mười bốn tuổi: né tám mũi tên sắt, dùng văn lạc chém đứt trường mâu Huyết Văn Thiết mà tay không tổn thương, tạo vầng trăng lưỡi liềm phá tan mảng tên nỏ giấu sau lưng, cuối cùng đánh Bái Phong phun máu bay ngang rơi xuống đất rồi đuổi theo.; Thạch Hạo — đứa bé chưa đến bốn tuổi — đấu tay đôi với thiếu niên Bái Phong mười bốn tuổi thần lực kinh người: né tám mũi tên sắt, nâng tảng…","anchor":"Bái Phong phun ra một bụm máu tươi, người bay ngang ra","bridge":true,"khoang":"@c0015"},{"text":"Nhóc tỳ hơn ba tuổi rưỡi lần đầu liều mạng xông lên, vút người đá một cước vào ngực khiến Bái Phong ngã ngửa không dậy nổi; sau đó nắm cổ áo nhấc hắn lên làm lá chắn, tay còn lại tỏa ánh sáng cùng ký hiệu chuyển động đánh trọng thương, rồi ném hắn về phe Thạch Thôn. Được cả tộc khen ngợi.; Nhóc tỳ hơn ba tuổi rưỡi liều mạng xông lên, đá một cước vào ngực khiến Bái Phong ngã ngửa, rồi nắm cổ áo nhấc lên làm lá chắn và dùng tay tỏa ánh sáng đánh t…","anchor":"một cước đá xuống, đạp ở trên ngực hắn","bridge":true,"khoang":"@c0016"},{"text":"Nhận ra Bảo Thuật vừa giết được hung thú vừa cứu người, Thạch Hạo khao khát có được ký hiệu nguyên thủy của Toan Nghê. Nó gọi Thanh Lân Ưng đại thẩm chở mình đi cùng tranh đoạt bảo thể Vạn Thú Vương.; Khi hai con Bưu dữ tấn công Thạch Thôn khiến Thạch Lâm Hổ và Thạch Phi Giao trọng thương, Thạch Hạo tức giận vận Bảo Thuật của Thanh Lân Ưng, ký hiệu sáng như vì sao trong lòng bàn tay tạo vầng trăng bạc chặt đứt chân rồi chém đầu cả hai con Bưu. Đ…","anchor":"Chúng ta cùng nhau đi tranh đoạt bảo thể của Toan Nghê.","bridge":true,"khoang":"@c0018"},{"text":"Bất chấp tộc trưởng can ngăn, Thạch Hạo nhảy lên lưng Thanh Lân Ưng lao tới vùng núi tranh đoạt thi thể Toan Nghê, dùng trăng bạc chém đứt sừng và đầu Sơn Miêu phục kích từ sau lưng.; Nhảy lên lưng Thanh Lân Ưng lao tới vùng núi tranh đoạt thi thể Toan Nghê bất chấp tộc trưởng can ngăn, dùng trăng bạc chém đứt sừng và đầu Sơn Miêu phục kích, hỗ trợ đối phó Tử Kim Xà và Huyết Điêu.; Trong trận đào bới, Thanh Lân Ưng bị Tử Kim Xà tập kích trúng độ…","anchor":"Thạch Hạo vèo một tiếng nhảy lên cao năm sáu mét, hạ xuống lưng chim rộng rãi","bridge":true,"khoang":"@c0019"},{"text":"Nằm trên lưng Thanh Lân Ưng giữa đại loạn tranh đoạt xác Toan Nghê, Thạch Hạo vận Cốt Văn khiến hai mắt sáng lên nhìn xa, liên tiếp chém ra vầng trăng bạc; kết hợp ký hiệu Nguyên Thủy Bảo Phú của Thanh Lân Ưng, cuối cùng đánh gãy một bộ phận xương Thử Vương khiến chuột tím trọng thương rơi xuống.; Trong lúc bầy hung thú tranh đoạt bảo thể Toan Nghê, Thạch Hạo nằm trên lưng Thanh Lân Ưng, vận Cốt Văn cho hai mắt sáng lên quan sát biến cố. Khi Thử…","anchor":"xương của Thử Vương gãy một bộ phận, bị thương trầm trọng","bridge":true,"khoang":"@c0020"},{"text":"Trên lưng Thanh Lân Ưng, Thạch Hạo nhận ra Toan Nghê cố tình giả chết để dụ Ác Ma Viên và Ly Hỏa Ngưu Ma tới rồi tiêu diệt, khen chủng tộc này có trí tuệ.; Ngồi trên lưng Thanh Lân Ưng, Thạch Hạo nhận ra Toan Nghê cố tình giả chết để dụ Ác Ma Viên và Ly Hỏa Ngưu Ma tới rồi tiêu diệt, tấm tắc khen loài này có trí tuệ. Sau đại chiến, cậu khiêng cái sừng dài mấy mét của Ly Hỏa Ngưu Ma cùng Thanh Lân Ưng gom đủ ba con Thái Cổ Di Chủng, mừng vì đã có…","anchor":"Toan Nghê giả chết vì muốn tiêu diệt kẻ thù","bridge":true,"khoang":"@c0021"},{"text":"Hơn hai mươi người Bái Thôn bắn tên sắt phục kích; Thạch Hạo giương tay triệu Bảo Nguyệt chém gãy tên mâu, làm bị thương mười mấy người và chém rách bụng thủ lĩnh, buộc chúng rút lui, nhưng tay và tim vẫn run vì không nỡ hạ sát.; Chém thịt dính bảo huyết trong sừng Thái Cổ Di Chủng nhét vào mỏ hung cầm trọng thương, tin sừng có thể giải độc như sừng Linh Tê; ánh mắt Thanh Lân Ưng lộ vẻ nhu hòa như với con mình.; Thấy Thanh Lân Ưng kiệt sức rơi x…","anchor":"hai tay giương ra, vẽ ra một vầng trăng óng ánh lóa mắt","bridge":true,"khoang":"@c0022"},{"text":"Bái Phong núp tập kích bằng Bảo Cụ vòng răng thú, một đốm sáng làm rách vai và suýt đâm xuyên yết hầu Thạch Hạo, khơi lại ân oán giữa hai người.; Trong đêm tối, Thạch Hạo một mình thủ hộ bảo thể Toan Nghê và Thanh Lân Ưng đang trúng độc, dùng mâu sắt cùng trăng bạc chém giết mãnh thú rồi phản kích đám phục kích Bái Thôn, hạ mười bảy mười tám người dù bị bắn xuyên tay và chân — lần đầu trong đời bị trúng tên nặng.; Một mình thủ hộ bảo thể Toan Ng…","anchor":"Không chỉ ngươi mới có Bảo Cụ, ta cũng có đây","bridge":true,"khoang":"@c0023"},{"text":"Nhóc tỳ nhảy cao đá vỡ nửa mặt và ngực Bái Phong, giẫm nát xương, rồi dùng trăng bạc chém đứt cả tứ chi khiến hắn tàn phế; sau đó thu xâu 42 răng thú chí bảo của Bái thôn và đeo lên cổ tay mình.; Trong trận vất vả chống Bảo cụ 42 răng thú của Bái Phong, nhóc tỳ ở thời khắc then chốt ngộ thêm một tầng Nguyên thủy bảo thuật; hai vầng trăng bạc hợp lại hóa con ma cầm, đánh Bái Phong phọt máu khiến 42 răng thú rơi rụng, Bảo cụ ảm đạm.; Trong trận vớ…","anchor":"hay tay hai chân Bái Phong đều bị cắt đứt","bridge":true,"khoang":"@c0024"},{"text":"Thiếu niên Thạch thôn, kinh ngạc chứng kiến uy lực xâu răng thú của Nhóc tỳ xuyên thủng thân thể người Bái thôn.; Nổi giận dùng Bảo cụ xâu chuỗi 42 răng thú trắng khắc phù văn (nhờ hiểu Cốt văn nên uy lực cực mạnh) phóng ánh sáng xuyên thủng thân thể nhiều người Bái thôn khiến chúng suy sụp bỏ chạy.; Nổi giận dùng xâu chuỗi 42 răng thú trắng khắc phù văn (hiểu Cốt văn nên uy lực rất mạnh) tách ra bay như mưa ánh sáng xuyên thủng nhiều người Bái…","anchor":"răng thú trắng loáng xuyên thủng thân thể rất nhiều người","bridge":true,"khoang":"@c0025"},{"text":"Sau đại chiến kiệt sức vẫn xin tham gia truy sát Bái Thôn; dùng vòng răng thú đánh gãy tứ chi Bái Sơn, nhớ cảnh A Văn thúc bị bắn xuyên lồng ngực nên chém chết hắn — lần đầu sát nhân, sau đó kiệt sức ngất đi được Thạch Lâm Hổ cõng về.","anchor":"Bốn mươi hai cái răng thú óng ánh phân biệt bay ra","bridge":true,"khoang":"@c0027"},{"importance":"normal","chuong":"@c0029","tieuDe":"Đột phá cảnh giới Thay máu","text":"Được tộc trưởng truyền mấy bộ Cốt thư cùng phù văn cuối cùng, Thạch Hạo học phương thức đưa phù văn hóa nhập cơ thể thành hào quang, kết thành Lô thần Vĩnh hằng trong mỗi tấc máu thịt, dẫn thần tinh nhập thể. Chỉ trong mấy ngày cậu đột phá cảnh giới Thay máu, lập kỷ lục thời gian (người thường mất mấy năm, thiên tài mấy tháng), khiến cả tộc mừng rỡ và kỳ vọng cậu thành Chí tôn.; Thành tựu của Thạch Hạo khiến cả Thạch thôn mừng rỡ ăn uống; tộc tr…","anchor":"Vẻn vẹn trong mấy ngày, nhóc tỳ đã có đột phá phi phàm."},{"text":"Tộc trưởng Thạch Vân Phong quyết định dùng bảo thể Toan Nghê, sừng Ly Hỏa Ngưu Ma và tay Ác Ma Viên Vương để tẩy lễ cho Thạch Hạo ngay trong hôm nay, dù nó chưa đủ năm tuổi; Thạch Hạo khẳng định chịu được.; Chỉ mất nửa tháng, Thạch Hạo tu hành xong, dung nhập Cốt Văn vào trong máu thịt; toàn thân trong suốt, từ nay dùng Bảo Thuật không còn tổn hao sức của bản thân.; Chỉ trong nửa tháng, Thạch Hạo tu hành xong, dung nhập Cốt Văn vào máu thịt khiế…","anchor":"Tiến hành ngay trong hôm nay đi!","bridge":true,"khoang":"@c0030"},{"importance":"normal","chuong":"@c0031","tieuDe":"Nhảy vào đỉnh tẩy lễ","text":"Sau khi được rửa ráy sạch sẽ, toàn thân óng ánh, Thạch Hạo tự tung mình nhảy vào chiếc đỉnh đen tổ truyền đang sôi sùng sục chứa chân huyết Toan Nghê để bắt đầu tẩy lễ; thôn nhân đậy nắp đỉnh kín, chính thức luyện hóa chân huyết Thái Cổ Di Chủng vào huyết nhục.; Thạch Hạo được tắm rửa sạch sẽ trên hòn ngọc thạch, toàn thân óng ánh rồi tự tung người nhảy vào đỉnh đen tổ truyền chứa bảo huyết Toan Nghê đang sôi. Thôn nhân đậy nắp kín để bắt đầu qu…","anchor":"Nó tung người nhảy một cái liền rơi vào trong cái đỉnh lớn đang sôi sùng sục"},{"text":"Chưa đủ bốn tuổi, sau khi tẩy lễ thành công có thần lực tám ngàn cân, nâng đỉnh Hống văn nặng tám ngàn cân đi vòng quanh đất trống, nhảy cao hơn ba mươi mét làm đất nứt khiến cả thôn kinh ngạc.; Ôm khối xương trán Toan Nghê quan sát tới đêm khuya, khắc Phù văn nguyên thủy vào lòng trước khi hoạt tính biến mất, tuy nhớ được nhưng tạm chưa hiểu Bảo thuật Toan Nghê.","anchor":"nhóc tỳ ra sức nhảy một cái liền cao cách mặt đất đến ba mươi mấy mét","bridge":true,"khoang":"@c0033"},{"text":"Nhóc tỳ Thạch Thôn còn dính sữa ở khóe miệng ra tay đỡ đòn Giao Bằng, chỉ vỗ một chưởng phát ra tiếng sấm khiến thiên tài La Phù Đại Trạch lảo đảo lùi mười mấy mét suýt ngã, khiến toàn bộ đám cường giả bên ngoài kinh ngạc.; Khi Giao Bằng xông vào đầu thôn tấn công đám Bì Hầu, nhóc tỳ ra tay đỡ, chỉ vỗ một chưởng phát ra tiếng sấm khiến Giao Bằng lùi mười mấy mét suýt ngã, cả đám cường giả ngoài thôn kinh ngạc.","anchor":"toàn thân Giao Bằng như bị sét đánh, lảo đảo lùi lại","bridge":true,"khoang":"@c0034"},{"text":"Nhóc tỳ chưa tới bốn tuổi chỉ dùng sức mạnh cơ thể thuần túy, không dùng Bảo Thuật, đẩy lui thiên tài Giao Bằng của La Phù Đại Trạch, khiến mặt đất nứt lớp lớp và cánh tay đối phương co giật; cả đám cường giả kinh hãi khi biết tuổi thật của nó.; Nhóc tỳ sắp bốn tuổi lần nữa đánh lui Giao Bằng — thiên tài tới từ La Phù Đại Trạch — chỉ bằng sức mạnh cơ thể thuần túy, không dùng Bảo Thuật, khiến mặt đất nứt lớp lớp, cánh tay Giao Bằng co giật. Cả đ…","anchor":"thằng bé dễ thương này sử dụng quả nhiên là sức mạnh cơ thể thuần túy","bridge":true,"khoang":"@c0035"},{"text":"Khi Giao Bằng trở mặt đòi động thủ, nhóc tỳ ra ngăn, nói năng thật thà xin bình yên cho thôn; đến khi Giao Long, Tử Sơn Côn, Lôi Minh Viễn lấy bảo cung định bắn Đại Bằng, Tiểu Thanh, Tử Vân làm con mồi thì nhóc tỳ nổi giận gầm lên chắn bảo vệ.","anchor":"Không được hại chúng nó!","bridge":true,"khoang":"@c0036"},{"text":"Khi Giao Bằng bắn ba con chim non, Thạch Hạo lấy nhục thân chắn tên bảo vệ Đại Bằng, Tiểu Thanh, Tử Vân; một chưởng đánh bay Giao Bằng làm gan bàn tay đối phương vỡ nát; đá văng đỉnh đồng ngàn cân đánh gãy cung Tử Sơn Côn; rồi thách cả ba thiên tài cùng nhào vô, khiến cường giả các tộc kinh ngạc trước một đứa bé chưa đủ bốn tuổi.; Hai bàn tay chạm nhau, Thạch Hạo phát hào quang thần thánh, ngón tay trắng óng, đánh Giao Bằng bay ngang mười mấy mé…","anchor":"sức mạnh cơ thể của nhóc tỳ sớm đã vượt xa loại thiên tài như Giao Bằng, có thể xưng là thiên túng kỳ tài.","bridge":true,"khoang":"@c0037"},{"text":"Trong cuộc quyết đấu ở sơn thôn, Thạch Hạo mời ông lão Vân Thiên Cung làm trọng tài rồi cận chiến áp đảo ba thiên tài; đá văng Tử Sơn Côn, đấm đạp trọng thương Lôi Minh Viễn với thần lực tám ngàn cân, dùng Cốt Văn dung hóa tia chớp; sau đó thi triển Nguyên Thủy Bảo Thuật — vầng trăng bạc hiện Thái Cổ Ma Cầm xé đứt Hung Giao của Giao Bằng, xuyên đầu Hỏa Lân của Tử Sơn Côn, rồi nắm cối xay đá đập đầu Giao Bằng khiến nó phun máu rụng hai răng.; Tro…","anchor":"Hai tay của nhóc tỳ vung một cái còn có thần lực tám ngàn cân","bridge":true,"khoang":"@c0038"},{"text":"Nhóc tỳ chủ động khống chế sức mạnh, không lấy mạng Giao Bằng vì sợ La Phù Đại Trạch huyết tẩy Thạch Thôn; dùng Bảo Thuật và Thái Cổ Ma Cầm nuốt Lôi Cầm, xé Hôi Giao thành ba đoạn, nghiền nát ba dị cầm; tạo hai vầng trăng hợp thành cối xay trắng đập tan Hung Tiễn bắn lén; tra tấn ba thiên tài, đập cối xay lên mặt Giao Bằng đến gãy mũi rụng răng; khéo léo từ chối các thế lực chiêu mộ; tuyên bố bảo cốt Toan Nghê và ba chim non là của mình; rồi cầu…","anchor":"hai vầng trăng giao hòa với nhau, hóa thành một cái cối xay trắng tinh","bridge":true,"khoang":"@c0039"},{"text":"Đang lén đun sữa thú, Thạch Hạo nhạy bén thấy chim chóc hung cầm bay loạn ở bốn phía cách đều hai ba dặm, liền hét lớn báo động cho thôn nhân biết Thạch Thôn đã bị bao vây.; Đang lén đun sữa thú thì thấy chim chóc hung cầm bay loạn ở bốn phía cách đều hai ba dặm; nhạy bén phát giác Thạch Thôn bị bao vây và hét lớn báo động cho thôn nhân.","anchor":"có hung thú hoặc người đã bao vây nơi này rồi!","bridge":true,"khoang":"@c0043"},{"text":"Nhóc tỳ tròn bốn tuổi, sức mạnh phi thường nhảy một cái ba bốn mươi mét trở thành đệ nhất cao thủ Thạch Thôn; khi cả thôn thoát không gian kỳ lạ tới vùng đất mới trù phú, cậu ngây ngẩn nhận ra như đã từng thấy nơi này — hồ lớn, chim rực rỡ, có quý tộc đi săn — khiến tộc trưởng và các chủ sự biến sắc; lần đầu hỏi thẳng liệu cha mẹ còn tại thế hay không.; Trước cảnh hồ lớn ở vùng đất mới, nhóc tỳ ngây ngẩn lẩm bẩm như đã từng thấy nơi này (hồ lớn……","anchor":"Bọn họ rốt cuộc có còn tại thế hay không vậy? Cháu thật sự rất nhớ họ!","bridge":true,"khoang":"@c0050"},{"text":"Dỗ tước đỏ Tiểu Hồng bình tĩnh và đoán trúng ý định nó tới nhờ Liễu Thần trị thương; sau đó nghe tộc trưởng kể lai lịch Thạch Thôn cùng chuyện cha mẹ mình từ cổ quốc tìm về tổ địa, đau lòng rơi lệ khi mơ hồ nhớ lại người thân.; Dỗ tước đỏ bình tĩnh, đoán trúng nó tới tìm Liễu Thần trị thương; sau đó nghe tộc trưởng kể lai lịch Thạch Thôn cùng câu chuyện cha mẹ, mơ hồ nhớ lại mà đau lòng rơi lệ.; Dỗ Tiểu Hồng (tước đỏ chí cường) bình tĩnh, khẳng……","anchor":"nhịn không được mà đau lòng rơi lẹ, nước mắt dọc theo má chảy xuống","bridge":true,"khoang":"@c0051"},{"importance":"normal","chuong":"@c0052","tieuDe":"Biết thân thế, quyết tự cường","text":"Nghe Thạch Vân Phong kể cha mẹ rời thôn đi tìm Thánh dược trị tận gốc bệnh cho mình chứ không nỡ bỏ rơi, Thạch Hạo mơ hồ thấy mảnh ký ức lạnh lùng trong tiềm thức và quyết tâm tự cường để truy tìm tung tích cha mẹ; một năm sau đã sáu tuổi, nâng nổi cự thạch ba mươi ngàn cân, cưỡi Thanh Lân Ưng rồi Tử Vân đi thám sát vùng tử địa trăm ngàn dặm và phát hiện con khỉ ba tay dưới đáy một hồ nước khô cạn.; Cưỡi Thanh Lân Ưng dò xét theo lệnh Thạch Lâm…","anchor":"Cháu đã sáu tuổi, lại có thể nâng cự thạch đến ba mươi ngàn cân"},{"text":"Cưỡi Tử Vân tìm thấy sinh linh ba đầu sáu tay dài một xích kẹt dưới đáy hồ khô cạn, ném thịt khô cho nó ăn; dùng Cốt Văn tuôn mưa ánh sáng dò xét, phát hiện nó bị trọng thương và ký hiệu trong cơ thể sắp phai mờ; sau khi nó lột xác thu Bảo Thuật thành quả cầu vàng, cậu mang về Thạch Thôn nuôi; cuối cùng sờ đầu nó thấy hai cái sừng ẩn trong lông vàng thì bỗng như thấy điều gì đó mà đau lòng rơi lệ.; Cuối chương sờ đầu sinh linh phát hiện hai cái……","anchor":"Đây là một loại tác dụng của Cốt Văn, có thể dò xét thực hư của kẻ địch","bridge":true,"khoang":"@c0053"},{"importance":"normal","chuong":"@c0054","tieuDe":"Bước vào đỉnh cao Bàn Huyết","text":"Sau gần hai năm khổ tu, Thạch Hạo (6 tuổi) chỉ bằng sức cơ bắp đã nâng cự thạch ba mươi ngàn cân, bước vào đỉnh cao Bàn Huyết cảnh, vượt xa các tráng sĩ trong thôn; đọc nghiền ngẫm hết Cốt thư lão tộc trưởng sưu tầm và nghiên cứu hai Bảo thuật — phù văn nguyên thủy của ma cầm Thái cổ cùng đại thần thông của Toan Nghê; xin Liễu Thần giúp soi sâu tiềm thức để biết chuyện năm đó dù sợ chân tướng tàn khốc.; Sau gần hai năm khổ tu bên hồ, Thạch Hạo m…","anchor":"bằng vào sức mạnh cơ bắp đã nâng lên được cự thạch ba mươi ngàn cân"},{"chuong":"@c0055","importance":"normal","tieuDe":"Ký ức thân thế hoàng tộc tái hiện","text":"Đứng bất động dưới cây liễu cháy đen giữa tầng sương mù hỗn độn, ký ức tiềm thức thời sơ sinh tái hiện — hé lộ Thạch Hạo vốn xuất thân dòng họ hoàng thân có hoàng huyết của cổ quốc Nhân Hoàng, từng được Lão Thập Ngũ nhỏ bảo huyết Thái Cổ Thần Cầm vào miệng khi còn quấn tã.; Cây liễu cháy phát sương mù hỗn độn bao phủ riêng mình Tiểu Thạch Hạo, khai mở ký ức tiềm thức lộ thân thế thật: là hoàng thân cổ quốc mang hoàng huyết gần Nhân Hoàng, theo q…","anchor":"Cảnh tượng mà nó đã từng thấy nhưng vì tuổi nhỏ mà không thể nhớ nổi, giấu ở trong tiềm thức đang tái hiện ở trước mắt."},{"chuong":"@c0056","importance":"normal","tieuDe":"Bị Lục tẩu chiết mất Chí Tôn cốt","text":"Cha mẹ đi Bách tộc chiến trường tìm ông nội, giao Hạo cho Lục tẩu; ả lừa xuống mật thất dưới trang viên, phù văn điểm huyệt bị Bảo cốt phát sáng hóa giải, rồi bóng u linh dùng đao bạc cứa lồng ngực chiết Chí Tôn cốt — Hạo gào khóc đau đớn không ngất, cuối cùng bị tách mất bảo cốt, hôn mê trên giường lạnh băng lẩm bẩm gọi Mẹ ơi.; Được cha tra xét xác nhận trời sinh Chí Tôn cốt; cha mẹ rời phủ giao cho Lục tẩu chăm; lớn nhanh biết đi biết nói sớm…","anchor":"Bỗng một thanh đao bạc lướt qua lóe lên một tia ánh sáng lạnh lẽo, cứa nhẹ vào lồng ngực nhóc tỳ"},{"importance":"normal","chuong":"@c0057","tieuDe":"Bị moi Chí Tôn Cốt và rút chân huyết","text":"Thiếu phụ (bá thẩm) cùng bóng đen u linh moi Chí Tôn Cốt trong lồng ngực Hạo Nhi cấy sang Thạch Nghị, rồi rút cạn chân huyết còn sót để tẩm bổ; nhóc tỳ hôn mê co rúm góc giường lạnh, thều thào gọi mẹ và đại nương, được Tứ Thái Gia phá cửa địa cung xông vào ôm vào lòng vận Bảo Phù bọc thụy hà cứu chữa.; Chí Tôn Cốt bẩm sinh trong lồng ngực Thạch Hạo bị thiếu phụ và bóng đen moi ra cấy sang Thạch Nghị; sau đó bị rút cạn chân huyết còn sót để tẩm b…","anchor":"ký hiệu ngưng tụ hóa thành một miếng Chí Tôn Cốt, ẩn vào trong lồng ngực của Thạch Nghị"},{"text":"Sau khi Chí Tôn cốt bị móc, tinh khí kiệt quệ, mỗi nửa đêm xương cốt rung động đùng đùng, thân thể co rút như nhỏ đi mấy tháng; dần quên cả Tứ thái gia và A Man, cô chú trong tộc lạnh nhạt không thăm hỏi.; Bị móc Chí Tôn cốt, mỗi đêm xương cốt rung động, thân thể co rút như nhỏ đi mấy tháng; mất dần tinh khí lẫn trí nhớ, quên cả Tứ thái gia và A Man, sinh mệnh thoi thóp.; Sau khi bị móc Chí Tôn cốt, thân thể Thạch Hạo teo rút như nhỏ đi mấy thán…","anchor":"xương cốt nhóc tỳ sẽ rung động đùng đùng, toàn bộ thân thể nhỏ bé lại rút ngắn","bridge":true,"khoang":"@c0058"},{"text":"Bị mẹ ôm đi theo cha vào cứ địa nhánh Thạch Nghị; mắt ngày càng mờ mịt, lồng ngực thoi thóp, chỉ kêu ê a không nói được; hé lộ trước đó Thập Ngũ Gia đã dùng máu Tỳ Hưu huyết mạch tinh khiết gột rửa thân thể cho hắn.; Bị cướp Chí Tôn cốt, mạng sống thoi thóp, mắt ngày càng mờ mịt, lồng ngực thoi thóp; được mẹ ôm đi theo cha, mơ màng nhìn hình bóng cha, tay bé nhỏ với tới, chỉ kêu ê a không nói được — một đứa trẻ thông minh hoạt bát bị thoái hoá t…","anchor":"một đứa trẻ thông minh hoạt bát lại bị thoái hoá thành như bây giờ","bridge":true,"khoang":"@c0059"},{"text":"Được nhắc trong lời Thạch Tử Lăng: con hắn (Hạo Nhi) sinh ra có Chí Tôn Cốt bị cướp cấy sang Thạch Nghị, thân thể thoái hóa đến người thân không nhận ra, đang hấp hối mà chẳng ai thương xót.; Con của Thạch Tử Lăng, chủ nhân gốc của Chí Tôn Cốt bị cướp cấy vào thân Thạch Nghị; thân thể thoái hóa đến người thân không nhận ra, đang hấp hối mạng khó giữ — trở thành động cơ khiến Thạch Tử Lăng phẫn nộ đòi trả bảo cốt.","anchor":"Trả lại Chí Tôn Cốt cho con ta!","bridge":true,"khoang":"@c0061"},{"chuong":"@c0062","importance":"major","tieuDe":"Mất Chí Tôn cốt, thoi thóp bên bờ sinh tử","text":"Bị Thạch Nghị đoạt Chí Tôn cốt trong đại chiến Thạch phủ Hoàng Đô, thoi thóp bên bờ sinh tử, được mẹ ôm vào chiến trường hợp lực cha tế bảo thuật Tâm hữu linh tê nhất điểm thông rồi ngất trong ngực mẹ; bị Thạch Nghị liếc bằng ánh mắt ngạo thị vì coi như đã phế bỏ; sau đó theo cha mẹ bị đày tới Man Hoang khổ địa (tổ địa thứ hai) dưỡng thương dưới sự giám sát của đối phương theo ước định; Bị mất Chí Tôn cốt, coi như phế bỏ; mẹ ôm vào chiến trường…","anchor":"đã mất đi Chí Tôn cốt, cuộc đời này coi như phế bỏ"},{"importance":"normal","chuong":"@c0063","tieuDe":"Ngộ đạo tái sinh & nhận Nguyên Thủy Chân Giải","text":"Liễu Thần khai thị rằng Chí Tôn Cốt có khả năng tái sinh trong cơ thể nhóc tỳ, tiết lộ năm xưa chính nhóc tỳ tự tái sinh sinh cơ mà sống sót chứ Liễu Thần chỉ đứng nhìn; nhóc tỳ quyết chí trở nên mạnh mẽ để về cổ quốc đòi công bằng; tộc trưởng Thạch Vân Phong trao cục xương trắng khắc ký hiệu bí ẩn — bảo vật rơi cùng Liễu Thần mấy chục năm trước — Liễu Thần đặt tên bốn chữ: Nguyên Thủy Chân Giải.; Khi chỉ còn ba người, lão tộc trưởng Thạch Vân P…","anchor":"cây liễu mới lên tiếng, chỉ nói đúng bốn chữ"},{"text":"Bắt đầu tu hành gian khổ theo Nguyên Thủy Chân Giải dưới chỉ điểm của Liễu Thần. Mỗi ngày vác sống Long Giác Tượng mấy vạn cân chổng bốn vó chạy về thôn, nửa tháng liên tiếp rồi đổi sang thú khác; được tộc trưởng đun đỉnh canh thịt thuốc cổ bồi bổ. Ba tháng sau nâng được năm vạn cân không dùng Cốt Văn khi mới hơn sáu tuổi. Tu luyện nghịch dòng thác đá ngoài bảy mươi dặm, bị sóng đánh đá rơi, về thôn người chỗ xanh chỗ tím — lần đầu bị thương tro…","anchor":"nhóc tỳ đã có thể nâng được vật nặng năm vạn cân rồi","bridge":true,"khoang":"@c0064"},{"importance":"normal","chuong":"@c0065","tieuDe":"Ngộ chân nghĩa Bàn Huyết Cảnh","text":"Chọi cứng đá mấy nghìn cân, cơ thể tự phát bảo quang mà không cần Cốt Văn — ngộ ra chân nghĩa Bàn Huyết Cảnh mà Liễu Thần từng nói: sức mạnh thuần huyết khí tự động hộ thân.; Uống một bát thuốc luyện từ máu vàng Chu Yếm trong đỉnh cổ tổ truyền; cả người bốc lửa, mồ hôi đầm đìa, máu bầm tan, xương cốt sáng óng, tạng phủ trong suốt — cơ thể được tẩy tủy cường thân.; Ngày ngày tới vùng thác nước đá, chống thác trắng xóa mà trèo, để đá nặng đập vào…","anchor":"Đây là sức mạnh thuần huyết khí, tự động hộ thân."},{"text":"Nhóc tỳ nâng cự thạch mười vạn cân đứng sừng sững dưới ánh bình minh khiến cả Đại Hoang chấn động; suốt nửa năm khổ tu giữa hồng thủy bão táp, đi ngược cơn lũ đá, chọc giận giao chiến hung thú khổng lồ, ăn chất lỏng vàng kim trong dược đỉnh khiến thể chất lột xác; một tay nâng cự thạch, thân tự phát quang huy — Liễu Thần xác nhận đã đạt mười vạn tám ngàn cân thần lực rồi cho phép tu Nguyên Thủy Chân Giải, nhóc tỳ đọc Cốt Thư đến hộc máu mấy lần.","anchor":"nó nâng lên cự thạch mười vạn cân đứng sừng sững dưới ánh bình minh","bridge":true,"khoang":"@c0066"},{"text":"Ôm khối xương trắng tham ngộ Nguyên Thủy Chân Giải đến ngây dại, nhiều lần ói máu; sau khi ngộ bổn nguyên Phù Văn thì trùng tu và hoàn thành Bàn Huyết Cảnh viên mãn, thân thể bóng loáng như đúc từ ôn ngọc; bắt Long Tu Ngư Vương hơn ba trăm cân rồi thả cho đẻ trứng; xin lão tộc trưởng đi ba mươi vạn dặm tới tổ địa thứ hai để mài giũa và dò tin cha mẹ.","anchor":"Cuối cùng cũng thành, nó tu hành đã đến được cực điểm, hoàn thành Bàn Huyết Cảnh viên mãn","bridge":true,"khoang":"@c0067"},{"chuong":"@c0068","importance":"major","tieuDe":"Rời Thạch Thôn hướng Cổ quốc","text":"Quyết định rời Thạch Thôn đi ba trăm ngàn dặm tới Cổ quốc, không cho Tử Vân, Đại Bằng, Tiểu Thanh theo vì đường xa đầy hung cầm khổng lồ; dùng thân pháp Kim Bằng lĩnh ngộ từ Chiến Thần Đồ Lục xông vào bầy Độc Giác Thú bên hồ, đẩy văng bảy tám con rồi nhảy lên lưng bắt sống con cao lớn thần tuấn, đặt tên Tiểu Bạch và hứa dạy Cốt Văn; sáng hôm sau từ biệt cả thôn, cưỡi Độc Giác Thú lên đường, Chu Yếm bám theo.","anchor":"Ba trăm ngàn dặm, hành trình dài như vậy phải đi qua không biết bao nhiêu là dãy núi"},{"text":"Cưỡi Độc Giác Thú cùng Bóng Lông huyết chiến xuyên Đại Hoang hướng biên cương cổ quốc, đi xa Thạch Thôn hai mươi vạn dặm qua vùng núi tử khí có móng vuốt khổng lồ bị xích; bị Ngạc Giao tập kích trong hàn đàm gây thương tích nặng nhất đời, thịt rách lộ xương, phải vận thần lực xé nát một chân Ngạc Giao rồi được Độc Giác Thú cứu thoát.","anchor":"vận lên mười vạn tám ngàn cân thần lực xé nát một cái chân của Ngạc Giao","bridge":true,"khoang":"@c0069"},{"text":"Cùng Bóng Lông và Tiểu Bạch cướp được trứng Ngũ Sắc Khổng Tước, khiến con hung cầm phát điên truy sát; Thạch Hạo hút chất lỏng chứa thần tinh trong trứng, người phát sáng ký hiệu chi chít suýt tiến vào cảnh giới tiếp theo; nhớ lời Liễu Thần dặn áp chế một tháng, vận đạo lý học từ Nguyên Thủy Chân Giải hóa ký hiệu thành Thần Lô nhỏ cất giấu thần tinh thay vì đột phá; ra lệnh Tiểu Bạch nhảy xuống sông đen hàn khí cực mạnh khiến Khổng Tước không dám vào nước, thần niệm bị dòng sông cắt đứt phải bỏ đi; lên bờ người tím ngắt phun băng, dùng thần hi tẩm bổ và giục Bóng Lông nhỏ máu cứu Tiểu Bạch trọng thương.","anchor":"Không ngờ nó lại sắp đột phá, tiến vào cảnh giới tiếp theo","bridge":true,"khoang":"@c0070"},{"text":"Cải trang thành nhóc tỳ áo da rách, mang Bóng Lông giả đần trên vai, gặp nhóm tu sĩ do Hạ U Vũ dẫn đầu và đóng vai trẻ chất phác nói “gia gia” dẫn đi rèn luyện Đại Hoang; khi cô gái áo trắng bất ngờ xuất thủ thử thực lực, phản đòn tóm cánh tay, bóp cổ và ấn ngón tay ký hiệu khống chế nàng trong nhất thời trước khi nàng thoát; xưng tên giả “Hạo Thiên”, nhận phù bài Bổ Thiên Các cuối cùng rồi cưỡi Độc Giác Thú rời đi; bị bà lão xác nhận thần lực tám chín vạn cân, gần cửa ải Cực Cảnh","anchor":"Tay phải thò ra, 'bịch' một tiếng liền tóm lấy cánh tay ngọc đó","bridge":true,"khoang":"@c0071"},{"text":"Hơn bảy tuổi, cưỡi độc giác thú vượt Đại Hoang, trong một tháng đi ba mươi vạn dặm, đại chiến vô số hung cầm dị thú, từng bị thương nặng vẫn vượt qua; ra khỏi Đại Hoang thì lệch hơn hai vạn dặm do rơi vào con sông đen, tới phụ cận Xung Vân trấn biên thùy Thạch quốc; chứng kiến tế linh Xung Vân dùng xích kiếm diệt sạch thú triều.","anchor":"Trong vòng một tháng, một đứa bé vượt qua vô tận sơn mạch, đại chiến rất nhiều hung cầm dị thú, vượt qua ba mươi vạn dặm","bridge":true,"khoang":"@c0072"},{"text":"Vòng hơn nghìn dặm vào Thạch quốc tới tổ địa rách nát; phát hiện đứa bé bệnh tật gầy yếu, chân tật, sống cô độc chính là ‘một mình khác’ của mình — kẻ thay hắn ở lại chịu khổ. Hắn sờ khối phù bài trong lòng, thề bằng mọi giá đưa đứa bé đến Bổ Thiên Các; sau đó biết người hầu đã bị mua chuộc, ngược đãi đứa bé nên tức giận siết nắm đấm.; Đứng xa quan sát trận cây Tế linh diệt thủ lĩnh hung cầm ở thành Trùng Vân, hắn nhận ra phù văn có thể dựng vũ…","anchor":"Ta muốn đưa ngươi đến Bổ Thiên Các, dù cho xa xôi thế nào ta cũng sẽ mang ngươi đi cùng","bridge":true,"khoang":"@c0073"},{"text":"Khoe với lão nhân “một tay có thể nhấc mười vạn tám ngàn cân” khiến ông hồi quang phản chiếu mãn nguyện; khi lão nhân trối trăng muốn đặt tay đứa bé vào tay mình, Thạch Hạo nắm hai bàn tay lại hứa sẽ thay ông chăm sóc đứa bé thế mạng, gánh trách nhiệm mà mấy lão nhân trong điền trang từng làm cho gia đình mình.; Sau mấy ngày quan sát xác nhận không có cao thủ, Thạch Hạo bí mật lẻn vào điền trang cũ nát ở Tây Cương; nhờ Liễu Thần cho thấy chuyện…","anchor":"cháu sẽ chiếu cố thật tốt cho nó","bridge":true,"khoang":"@c0074"},{"text":"Ẩn trong rừng quan sát cha con họ Hải diệt sát thủ Vũ Tộc; hiện thân cảnh báo họ rời đi vì Tây Cương sắp động đất lớn; gom thi thể cao thủ, phóng hỏa thiêu rụi thôn trang tổ địa thứ hai của Thạch Tộc; tuyên bố tổ địa của mình chỉ có một, không phải chỗ này, cắt đứt hoàn toàn quan hệ với Thạch Quốc, nhắc lại mối thù bị cướp Chí Tôn Cốt.","anchor":"Cháu và Thạch Quốc không còn có quan hệ gì nữa cả","bridge":true,"khoang":"@c0075"},{"text":"Chở Thạch Thanh Phong vượt Đại Hoang hơn hai mươi ngày, cả người nhuộm máu thú về đến Thạch thôn — nơi cậu gọi là ‘tổ địa thật sự’; báo với tộc trưởng chưa đột phá nhưng muốn ở lại thôn bế quan để xông cảnh giới cao hơn, sau đó mới đi Bổ Thiên các.","anchor":"Cuối cùng, lặn lội hơn hai mươi ngày hai đứa cũng về đến Thạch thôn","bridge":true,"khoang":"@c0077"},{"text":"Luyện một đỉnh bảo dược (có máu Chu Yếm) và dùng phù văn cùng Nguyên Thủy Chân Giải chữa liền gân cốt chân Thanh Phong; dẫn đám trẻ cưỡi Độc Giác Thú vào núi đi săn, chọc phải Thứ Thú khổng lồ phun lửa phải bỏ chạy; đến thôn hơn hai trăm hộ bị thảm sát cháy rụi, nhận ra bóng khổng lồ ở chân trời là một hung thú Tế Linh được đám người sùng bái vây quanh, Nguyên Thủy Bảo Cốt của Tế Linh thôn bị đoạt.","anchor":"「Đó là một con hung thú, trên người lập lòe phù văn, được một đám người sùng bái vây quanh」","bridge":true,"khoang":"@c0078"},{"text":"Vào núi khổ tu một mình, ngồi tĩnh lặng giữa mưa gió sấm chớp lĩnh ngộ đạo quả Động Thiên cảnh suốt mười lăm ngày; dùng thiên cốt nghiên cứu Nguyên Thủy Chân Giải, cảm ngộ chân nghĩa Chiến Thần Đồ Lục; rồi đột phá vào Động Thiên cảnh, hoàn thành lột xác với miệng núi lửa nâu xám trên đỉnh đầu; tiếp đó lần lượt mở thêm động thiên thứ hai và thứ ba, thành cao thủ Động Thiên trung kỳ — điều chưa từng nghe nói, nhờ liên tục luyện hóa bảo trứng Ngũ Sắc Khổng Tước Vương.","anchor":"Nhóc tỳ đột phá tiến vào Động Thiên cảnh","bridge":true,"khoang":"@c0080"},{"importance":"major","chuong":"@c0081","tieuDe":"Củng cố Động Thiên, trấn áp hung khấu","text":"Củng cố hoàn toàn Động Thiên cảnh với ba động thiên như ba ngọn núi lửa cuồn cuộn tinh khí; đứng yên chưa ra tay đã dọa lui bá chủ hung thú sừng kỳ lân và bầy ác điểu trong núi; khiêng con Giao Báo dài hơn mười mét về Thạch thôn; rồi khi đám hung khấu kéo tới đòi Hắc Kim thì một tay bắt roi, quật nát thủ lĩnh, một chưởng đánh gãy xương cả đám và dập tắt Hỏa Quang Thuật; đồng thời xác định kẻ địch lớn thật sự là con Tế Linh.","anchor":"tất cả bọn hung khấu đều bị đánh đến gãy xương đứt cốt"},{"text":"Từ chối để lão tộc trưởng đi cùng (ông có nội thương không dùng được Cốt Văn), một mình cưỡi Độc Giác Thú Tiểu Bạch xông vào sơn trại cướp; càn quét hơn hai mươi lính gác bằng phù văn xoáy hút cắn nát tên sắt; đánh gãy hai tay và lõm ngực thủ lĩnh giáp vảy Xuyên Sơn Giáp, xác nhận vảy chưa đạt Bảo Cụ; dùng Bảo Thuật trăng bạc (vầng trăng bạc đường kính một trượng) hóa giải Hỏa Quang Thuật của đại thủ lĩnh; triệu Thái Cổ Ma Cầm từ Thần Nguyệt xé cụt tay-vai đại thủ lĩnh (Động Thiên Cảnh, hơn 50 tuổi), khiến hắn bại trận và lộ ra việc bản thân đột phá liền mở ba Động Thiên; sau cùng đối mặt Tế Linh vàng nhạt cao như núi, bình tĩnh dù chưa từng giết con Tế Linh nào.","anchor":"Một vầng trăng bạc khổng lồ xuất hiện ở sau lưng nó, đường kính phải cỡ một trượng","bridge":true,"khoang":"@c0082"},{"text":"Bé trai tám tuổi đơn độc đối đầu con Tế Linh Xuyên Sơn Giáp vàng kim khổng lồ, đại chiến mấy trăm chiêu; vận mười vạn tám ngàn cân thần lực cứng đối cứng đỡ móng vuốt, ôm đuôi đầy vảy quật con thú vào vách núi, đạp nát lớp vảy trên đầu khiến nó phụt máu; nhưng bị đuôi và móng vuốt đánh trọng thương suýt gãy cột sống, nhận ra Tế Linh đang có bệnh nên tính chuyện chạy trốn, cuối cùng bị ba vảy vàng kim Bảo Cụ bắn xuyên thủng người thành ba lỗ.","anchor":"hai cánh tay nhỏ ôm lấy cái đuôi đầy vảy cứng rồi quật mạnh lên không","bridge":true,"khoang":"@c0083"},{"text":"Huyết chiến ác linh Tế Linh (Xuyên Sơn Giáp) màu vàng: chịu mưa vảy vàng bằng vầng Thần Nguyệt rồi bất ngờ kích nổ nó đánh tan toàn bộ vảy; nhân lúc địch mất vảy hộ thân, phóng chớp giật lôi điện trọng thương, triển Thái Cổ Ma Cầm suýt xẻ đôi địch; né được cốt tiễn xương vàng cắt núi, giải mã điểm yếu Tế Linh tự tổn mệnh nguyên vì tế luyện xương ngoại lai; giăng sương mù ẩn núp, ném một hung khấu làm mồi dụ địch lộ sơ hở, rồi dùng bảo kính của Toan Nghê phá nát nội tạng trọng thương chí mạng Tế Linh trước khi ẩn vào bóng tối chờ đòn cuối.","anchor":"vầng Thần Nguyệt kia nổ tung, ánh sáng thần thánh sôi trào đánh tan tất cả vảy sáng màu vàng","bridge":true,"khoang":"@c0084"},{"text":"Bất chấp trọng thương, Thạch Hạo nhặt cốt tiễn vàng óng làm từ xương hàm Cầu Long trên xác Tế Linh; thử uy lực xoắn đứt cả một dãy núi nhưng gần cạn tinh khí thần, nhận ra vì sao Tế Linh dùng bảo vật này mà nổ thân, nên chọn không phục sinh mà thu cốt tiễn vào miệng núi lửa trong thân làm bảo cụ; xuất vòng răng thú phế tinh khí phù văn đám cướp, để Đại Hoang tinh lọc ác nhân; thẩm vấn lộ ra hung khấu phục tùng Tiểu Tây Thiên, đang tìm Chí Tôn Thần Tàng và thu Hắc kim phá cổ trận; nuốt bảo đan luyện từ máu Bóng Lông chữa thương rồi cùng làng mang chiến lợi phẩm về Thạch thôn ăn mừng.","anchor":"Cốt tiễn hóa thành một vệt sáng vàng chui vào trong một miệng núi lửa trong người nhóc tỳ","bridge":true,"khoang":"@c0085"},{"importance":"normal","chuong":"@c0086","tieuDe":"Mở Động Thiên thứ tư, định tới Bổ Thiên các","text":"Tám tuổi rưỡi, dùng bảo dược máu thịt Tế Linh mở ‘Miệng núi lửa’ thứ tư sau lưng (đủ bốn bất hủ thông đạo), tộc trưởng khen là kỳ tích nhưng cậu chọn không vượt cửa; định đưa Thanh Phong tới Bổ Thiên các vừa đi vừa tu, đợi Liễu Thần tỉnh để được dẫn vào thế giới thần bí, rồi kiên định nhận lời mời ấy.","anchor":"mở ra 'Miệng núi lửa' thứ bốn xuất hiện ở sau lưng"},{"text":"Từ biệt tộc nhân rồi xếp bằng dưới gốc cây cháy đen, được Cây Liễu đưa qua cửa pháp tắc vào Hư Thần Giới; kinh ngạc biết thân xác hiện tại chỉ là ý chí tinh thần chứ không phải chân thân, cơ chế rèn tinh thần sẽ mang cảm ngộ về thân thể thật; tới Sơ Thủy Địa liền ngây ngô đào Nguyên Thủy Bảo Cốt, phá hỏng thông đạo và bị đám tu sĩ vây quanh chê cười là người nguyên thủy.","anchor":"bây giờ ngươi cũng không phải chân thân, mà chỉ là ý chí tinh thần","bridge":true,"khoang":"@c0087"},{"text":"Vào Hư Thần Giới học tập, ngồi nghiên cứu cốt phù và đòi đào Bảo Cốt ngay trên thông đạo — điều xưa nay chưa ai làm — nên bị mọi người chế giễu là “cực phẩm”; mượn cây búa hai ngàn cân đập tảng đá đến gãy đầu búa; sau khi nghe thiếu nữ giảng quy tắc Sơ Thủy Địa, phát hiện dùng Phù Văn càng nhiều thì Bảo Cốt phòng ngự càng mạnh nên chuyển sang chỉ dùng sức mạnh thân thể oanh kích, phá vỡ tảng đá, khai sáng kỷ lục tốc độ và đoạt được một khối Bảo Cốt trắng noãn.","anchor":"tảng đá lớn chia năm sẻ bảy, mấy khối Bảo Cốt óng ánh rơi rụng trên thảm cỏ","bridge":true,"khoang":"@c0088"},{"text":"Thạch Hạo đánh vỡ thông đạo Sơ Thủy Địa của Hư Thần Giới, đoạt được một khối Phù Cốt trắng trong ẩn phù văn, lập kỷ lục mới khiến cả Hư Thần Giới chấn động; sau đó khắc bừa danh hiệu “Thích Nhất Uống Sữa Thú” và lĩnh vực “Cực tốc” lên bia đá, từ chối đổi bảo cốt lấy tinh bích, đi vòng Sơ Thủy Địa làm quen địa hình dù bị cảnh báo có kẻ nhắm vào bảo cốt; đọc bảng kỷ lục thấy tên quen thuộc Thạch Nghị.","anchor":"Thằng nhóc này sau khi đi vào liền giống như đứa hám tiền, hơn nữa cuối cùng không ngờ còn lấy được một cục xương.","bridge":true,"khoang":"@c0089"},{"importance":"normal","chuong":"@c0090","tieuDe":"Cối xay bạc Thần Nguyệt đoạt lại bảo cốt","text":"Bị bọn cướp giả vờ ‘mua’ bảo cốt bằng mười viên tinh bích rồi cưỡng đoạt; nhóc tỳ lướt ngang, hai vầng Thần Nguyệt dung hợp thành cối xay bạc đánh bay bọn cướp, đoạt lại bảo cốt.; Nhóc tỳ đọc bia đá ghi chiến tích Thạch Nghị chém chín Thú Vương tại Sơ Thủy Địa; nghe danh xưng ‘Chí Tôn trời sinh’ liền hiện ký ức cô bé nô tỳ A Man căn dặn bên giường bệnh, gợi lại thân phận thiếu gia mờ nhạt; ngông nghênh tuyên bố phá mọi kỷ lục của Thạch Nghị.; Ca…","anchor":"hai vầng Thần Nguyệt xuất hiện rồi chạm vào nhau, dung hợp tạo thành một cái cối xay bạc"},{"text":"Tại Sơ Thủy Địa (Hư Thần Giới) — nơi mọi người chỉ phát huy được sức mạnh Bàn Huyết Cảnh — Thạch Hạo đạp hạ hai tộc lão, thu mười tám Thần Vũ vào ngực rồi nâng hai đại nhân vật dưới chân vung như cối xay gió, một mình độc chiến hơn trăm cao thủ bộ tộc lớn; nó dùng Xích Vũ thiêu chân ba trung niên dẫn đầu, bắt toàn bộ làm tù binh và bắt thêm một thiếu niên được cho là đệ đệ Xích Vân công tử. Nó ra giá ‘sư tử ngoạm’, đòi Bảo Thuật trấn tộc hoặc Bảo Cụ làm vật chuộc người; cuối cùng lập kỷ lục ‘Cướp giỏi nhất’ ở Sơ Thủy Địa khi cướp 563 người trong thời gian ngắn nhất, khiến cả Hư Thần Giới chấn động.","anchor":"một mình nhóc tỳ ở trong thời gian ngắn nhất cướp năm trăm sáu mươi ba người","bridge":true,"khoang":"@c0091"},{"text":"Ở Sơ Thủy Địa bắt 563 cường giả bốn bộ tộc chất thành bốn ngọn núi người; phá cổ trận bốn khối bảo cốt bằng khối bảo cốt trắng, chọi cứng tứ đại cao thủ khiến hai địch nổ tung thành huyết quang; cả ngày đánh bại vô số cao thủ tới khiêu chiến, ép bốn đại tộc dâng bốn bình ngọc chân huyết hung thú chuộc người; sau đó tuyên bố tới lĩnh vực Động Thiên Cảnh phá kỷ lục của Thạch Nghị.","anchor":"cường giả bị bắt của bốn bộ tộc tổng cộng có năm trăm sáu mươi ba người, bị chất thành bốn ngọn núi","bridge":true,"khoang":"@c0092"},{"text":"Bị Hư Thần Giới trục xuất khỏi thần du vì đập vỡ thông đạo và bia kỷ lục; Liễu thần đưa ý chí về Thạch thôn, dặn tẩy lễ trước 12 tuổi; quyết định rời thôn cùng Thanh Phong hướng Bổ Thiên Các, mang Mao cầu theo; cưỡi hung thú vượt hơn nửa năm qua 300.000 dặm Đại Hoang, mở động thiên thứ năm khi hơn 9 tuổi; vào Thạch quốc, sai Thanh Phong dò tin Hư Thần Giới — được biết bản thân đã thành nhân vật truyền thuyết ở đó.","anchor":"nhóc tỳ đã mở ra động thiên thứ năm, một ngọn núi lửa nữa xuất hiện","bridge":true,"khoang":"@c0095"},{"text":"Cùng Thanh Phong và Bóng Lông tự lên đường hàng chục đến trăm vạn dặm, huyết chiến qua Đại Hoang đầy mãnh thú Hồng Hoang để rèn luyện; tới gần Bổ Thiên Các chứng kiến phong vân tụ hội, khó chịu khi bị ám chỉ là “thằng nhóc kỳ hoa”, khẳng định đám đông không tới vì mình.","anchor":"nhóc tỳ và Thanh Phong đã lại lên đường","bridge":true,"khoang":"@c0096"},{"text":"Cùng Thanh Phong tới ngoại vi Bổ Thiên các nơi vạn người chờ tuyển đệ tử; cho Bóng Lông biến lông xám trắng và tự biến mặt tròn múp míp như trái táo để tránh nhiều thế lực đang săn tìm; nhường phù bài cho Thanh Phong vào thẳng sơn môn, còn mình định ở lại lấy bảo vật ở Bảo Sơn.","anchor":"Nhanh biến thành bộ dạng phổ thông, đừng để người ta nhận ra","bridge":true,"khoang":"@c0097"},{"text":"Đào được mười tám khối phù cốt óng ánh đầy phù văn ở khu vực thứ tám; dùng bảo thuật Toan Nghê phá bình phong ánh sáng để vào tầng thứ hai cổ chiến trường; chia bảo cốt thành sáu nhóm chôn giấu ở đầm lầy, khe nước và tổ chim bỏ hoang; hành động này khiến 8927 người vượt ải kỷ lục và bị Bổ Thiên Các truy tìm dưới biệt danh Hùng hài tử","anchor":"nhóc tỳ vác một cái bao da thú khổng lồ, tổng cộng đào được mười tám khối phù cốt","bridge":true,"khoang":"@c0099"},{"text":"Trong chiến trường thứ hai Bổ Thiên các, đá cước ngang ngửa móng vuốt Cổ Ngạc rồi bắn mười tia chớp vàng làm nó cháy đen bong vảy; bị một kẻ phát sáng như Chiến Linh màu bạc đánh lén một chưởng khủng bố vì tranh Bổ Thiên Thạch rồi biến mất; sau đó tìm được khối bia phù quang nhả ra một Bổ Thiên Thạch và hiểu luật ải: giữ hai khối mới tính qua ải, mười khối được môn phái trọng điểm bồi dưỡng; quyết vào sâu núi tìm linh vật trong sào huyệt Hắc Hổ, phát hiện Hắc Sát Liên cắm rễ miệng hang và dù thấy dấu ấn Bổ Thiên Các vẫn rón rén tới hang hổ định hái để mở động thiên thứ sáu.","anchor":"hắn trực tiếp đánh nhóc tỳ một chưởng","bridge":true,"khoang":"@c0100"},{"importance":"normal","chuong":"@c0001","tieuDe":"Trà trộn rèn luyện và bú sữa thú","text":"Chú nhóc mới tập đi tự bám theo đám trẻ rèn luyện thân thể dưới mây sớm, bi bô bắt chước động tác xiêu vẹo. Mồ côi từ nửa tuổi, bú sữa bách thú lớn lên, nay được hơn một tuổi vẫn chưa cai sữa nên bị đám trẻ lớn trêu, song nó không để bụng mà múc sữa uống ngon lành.; Chú nhóc một tuổi rưỡi trà trộn vào đám trẻ rèn luyện dưới mây sớm, bi bô bắt chước động tác, sau đó đuổi theo con chim sẻ năm màu. Được lão tộc trưởng Thạch Vân Phong nấu sữa thú ch…","anchor":"Chú nhóc mất cha mẹ từ khi mới nửa tuổi, bú sữa bách thú lớn lên"},{"text":"Theo yêu cầu lũ trẻ, nhóc tỳ giơ hai bàn tay dùng sức, một quầng sáng và ký tự kỳ lạ như đúc kim loại nổi lên trên lòng bàn tay, nhấc bổng khối đá xanh còn cao hơn người mình rồi ném xuống cười vô tư — khiến lũ trẻ kinh ngạc.; Theo yêu cầu lũ trẻ, nhóc tỳ giơ hai bàn tay dùng sức, một ký tự kỳ lạ như đúc kim loại nổi lên cả hai lòng bàn tay, nhấc bổng khối đá xanh cao hơn người mình khiến lũ trẻ kinh ngạc.","anchor":"lòng bàn tay nó xuất hiện một quầng sáng, một kí tự kì lạ nổi lên","bridge":true,"khoang":"@c0002"},{"chuong":"@c0017","importance":"normal","tieuDe":"Phát Bảo Thuật vầng trăng bạc","text":"Triệu ra một vầng trăng bạc hoàn chỉnh treo sau đầu, bên trong hiện cung điện và gốc cây kèm tiếng chim kêu; trăng bạc bay ra cắt đứt liền ba tảng đá lớn (lần trước chỉ cắt một), được tộc trưởng và tộc lão xác nhận là một môn Bảo Thuật thai nghén từ Nguyên Thủy Bảo Phù.; Xin đi cùng đoàn vào núi lấy di thể Toan Nghê và được chấp nhận vì đã nắm được Bảo Thuật; dặn ba con chim non ở lại thôn và tiếp tục khuyên Thanh Lân Ưng đến giúp.","anchor":"lần này lại có thể trực tiếp cắt đứt ba tảng đá, thật là lợi hại!"},{"text":"Nhóc tỳ được tắm thuốc một mình trong hắc đỉnh đặc biệt chỉ thêm chút nước trắng, còn lại toàn chân huyết và bột xương hung thú; tộc trưởng đập tan Tỳ Hưu và tê giác hai đầu phóng từ hai bình thành huyết dịch rơi vào đỉnh. Nhờ thể chất cực mạnh và cốt văn tự vận chuyển luyện hóa dược lực, nó chịu được, uống no thuốc rồi ngủ say trong lòng Thạch Vân Phong.; Sau khi ăn ngấu nghiến hết nồi bảo dược riêng do Thạch Vân Phong nấu, dược kình quá mạnh k…","anchor":"thân hình nhỏ bé ngã vào trong lòng Thạch Vân Phong","bridge":true,"khoang":"@c0004"},{"chuong":"@c0028","importance":"normal","tieuDe":"Được dạy Cốt văn, định lột xác","text":"Thạch Vân Phong tiết lộ Nhóc tỳ có thiên phú Cốt văn kinh người, sẽ hướng dẫn lột xác bằng chân huyết Toan Nghê, sừng bảo đỏ thẫm và cánh tay Vược Ác Ma trước năm tuổi kẻo thần tính chân huyết suy giảm.","anchor":"Cốt văn là phù văn thần bí mà tộc Người bắt chước theo Ấn ký nguyên thủy"},{"chuong":"@c0032","importance":"major","tieuDe":"Lột xác qua tẩy lễ dược đỉnh","text":"Sau nhiều ngày tẩy lễ trong đỉnh đen với huyết thanh vàng kim và chân huyết ba Di chủng Thái cổ (Toan Nghê, Bò ma Ly Hỏa, Vượn Ác ma), nhóc tỳ chịu nứt xương xoắn thịt rồi lột xác thành công, da chết đen bóc ra từng mảng lộ thân thể trắng nõn óng ánh.; Trong đỉnh đen, con Toan Nghê vàng kim (mảnh vỡ thần tính tổ hoàng Thái cổ) tấn công nhóc tỳ nhưng bị các điểm sáng quanh người tịnh hóa và dung luyện vào bản thân.; Chưa tới bốn tuổi, nhóc tỳ suý…","anchor":"nó như lột da, da chết màu đen bóc ra từng mảng"}],"tuViMoc":[{"chuong":"@c0032","canhGioi":"Luyện thể","text":"Thân thể được tẩm bổ qua tẩy lễ, xương rắn chắc trắng loáng, nâng nổi đỉnh Hống văn tám nghìn cân — thần lực vượt xa người thường trong tộc.","importance":"major"},{"chuong":"@c0029","canhGioi":"Thay máu","text":"Nhờ tu Cốt văn nhập thể theo phương thức mới, Thạch Hạo đột phá lên cảnh giới Thay máu chỉ trong mấy ngày, mỗi tấc máu thịt phát sáng như có thần linh Viễn cổ ẩn trong thân. Con đường phía trước là sinh Thánh cốt, xuất Ấn ký nguyên thủy và Bảo thuật nguyên thủy.","importance":"major"},{"chuong":"@c0033","canhGioi":"Đã tẩy lễ (thần lực tám ngàn cân)","text":"Tẩy lễ thành công bằng bảo huyết Di chủng Thái cổ: phủ tạng óng ánh, xương cốt trong suốt, đạt thần lực tám ngàn cân, tinh lực dồi dào dùng mãi không hết.","importance":"major"},{"chuong":"@c0052","canhGioi":"Phàm nhân","text":"Sáu tuổi (tính cả tuổi thực), nâng nổi cự thạch ba mươi ngàn cân — thân thể khổ tu Cốt văn thấy rõ tiến bộ.","importance":"minor"},{"chuong":"@c0054","canhGioi":"Bàn Huyết cảnh","text":"Sáu tuổi bước vào Bàn Huyết cảnh, nâng cự thạch ba mươi ngàn cân, đạt tới đỉnh cao Bàn Huyết; được Thạch Vân Phong khuyên củng cố căn cơ, chưa vội đột phá lĩnh vực cao hơn.","importance":"major"},{"chuong":"@c0017","canhGioi":"Phàm nhân","text":"Lĩnh ngộ được Bảo Thuật vầng trăng bạc phát ra từ Nguyên Thủy Bảo Phù — thuộc hệ Bảo Thuật/thần thông, không phải cảnh giới tu vi chính; uy lực tăng, cắt đứt liền ba tảng đá lớn.","importance":"major"},{"chuong":"@c0005","canhGioi":"Phàm nhân (luyện thể)","text":"Ba tuổi rưỡi, thể chất siêu phàm nhờ được nuôi dưỡng luyện thể, đã nâng bổng đỉnh đồng ngàn cân qua đầu — được ví như hung thú non Thái Cổ.","importance":"major"},{"chuong":"@c0033","canhGioi":"Tẩy lễ thành công","text":"Tẩy lễ bằng bảo huyết Di chủng Thái cổ hoàn tất, phủ tạng óng ánh, xương cốt trong suốt, phù văn hợp nhất máu thịt, đạt thần lực tám ngàn cân.","importance":"normal"},{"chuong":"@c0005","canhGioi":"Phàm thân (luyện thể hài đồng)","text":"Ba tuổi rưỡi đã có thể lực áp đảo đám thiếu niên lớn tuổi, nâng bổng đỉnh đồng ngàn cân.","importance":"minor"},{"chuong":"@c0032","canhGioi":"Phàm thể phi thường","text":"Qua tẩy lễ trong dược đỉnh và dung nhập ba chân huyết Di chủng Thái cổ (Toan Nghê, Bò ma Ly Hỏa, Vượn Ác ma), thân thể lột xác, sở hữu thần lực vượt xa người thường dù mới ba tuổi. Đây là nền tảng thể chất, không thuộc hệ tu vi chính.","importance":"major"},{"chuong":"@c0033","canhGioi":"Tẩy lễ","text":"Tẩy lễ thành công bằng bảo huyết Di chủng Thái cổ, phủ tạng óng ánh, xương cốt trong suốt, đạt thần lực tám ngàn cân.","importance":"minor"},{"chuong":"@c0037","canhGioi":"Phàm nhân","text":"Chưa đủ bốn tuổi nhưng thần lực kinh người, được đánh giá là thiên túng kỳ tài, vượt xa thiên tài Giao Bằng.","importance":"major"},{"chuong":"@c0064","canhGioi":"Bàn Huyết cảnh","text":"Bắt đầu tu Nguyên Thủy Chân Giải theo lộ trình cơ sở Thái Cổ Hung Thú non; ba tháng nâng năm vạn cân bằng sức thân thể, không dùng Cốt Văn.","importance":"major"},{"chuong":"@c0064","canhGioi":"Bàn Huyết Cảnh","importance":"normal","text":"Sau ba tháng bồi bổ canh thịt cường gân tráng cốt, thuốc cổ và Long Tu Ngư, hơn sáu tuổi đã nâng được vật nặng năm vạn cân mà không cần dùng tới sức mạnh Cốt Văn.","anchor":"nhóc tỳ đã có thể nâng được vật nặng năm vạn cân rồi"},{"chuong":"@c0056","canhGioi":"Phàm nhân (trời sinh Chí Tôn cốt)","text":"Được cha xác nhận trời sinh Chí Tôn cốt (Nguyên thủy bảo cốt), Bảo cốt có thể tự phát sáng hóa giải pháp thuật; bị chiết mất Chí Tôn cốt.","importance":"major"},{"chuong":"@c0056","canhGioi":"Phàm nhân (sơ sinh)","text":"Trời sinh Chí Tôn cốt — Nguyên thủy bảo cốt cực hiếm, tự phát sáng hóa giải pháp thuật hôn mê; nhưng bị Lục tẩu chiết mất trong chương này.","importance":"major"},{"chuong":"@c0064","canhGioi":"Bàn Huyết Cảnh (rèn thân)","text":"Theo Nguyên Thủy Chân Giải rèn cường gân tráng cốt; ba tháng nâng được năm vạn cân bằng sức cơ thể, không mượn Cốt Văn, hướng tới cảnh giới thân thể đỉnh phong của Thái Cổ Hung Thú Thiên Giai.","importance":"major"},{"chuong":"@c0065","canhGioi":"Bàn Huyết Cảnh — Thập Vạn Cực Cảnh","text":"Ngộ chân nghĩa Bàn Huyết Cảnh (huyết khí tự hộ thân, không cần Cốt Văn) rồi đột phá Thập Vạn Cực Cảnh — giơ được đá mười vạn cân, mốc chỉ Thái Cổ Hung Thú Thiên Giai non mới đạt.","importance":"major"},{"chuong":"@c0066","canhGioi":"Cực cảnh rèn thân (một tay mười vạn tám ngàn cân thần lực)","text":"Sau nửa năm khổ tu giữa thiên uy, một tay nâng cự thạch mười vạn cân, toàn thân tự phát quang huy — đạt cực cảnh rèn thân hoàn toàn, sánh với thú non mạnh nhất như Kim Sí Đại Bằng, Chân Hống.","importance":"major"},{"chuong":"@c0067","canhGioi":"Bàn Huyết Cảnh","text":"Sau khi ngộ Nguyên Thủy Chân Giải, trùng tu và hoàn thành Bàn Huyết Cảnh viên mãn; giữ cảnh giới một tháng không đột phá vội theo lời Liễu Thần để củng cố thể ngộ.","importance":"major"},{"chuong":"@c0070","canhGioi":"Áp chế (chưa đột phá)","text":"Hút thần tinh trong trứng ngũ sắc, khí tức suýt tiến vào cảnh giới kế tiếp nhưng chủ động hóa Thần Lô cất giấu tinh khí để giữ nền tảng vững, theo lời dặn của Liễu Thần.","importance":"minor"},{"chuong":"@c0078","canhGioi":"Bàn Huyết","importance":"minor","text":"Nghiên cứu Nguyên Thủy Chân Giải trong núi sâu, tích lũy Bàn Huyết cảnh thâm hậu để bộc phát mạnh khi đột phá cảnh Động Thiên kế tiếp.","anchor":"「Cảnh giới tiếp theo là “Động Thiên”, đây là cảnh giới rất quan trọng với người tu hành」"},{"chuong":"@c0080","canhGioi":"Động Thiên cảnh","text":"Đột phá vào Động Thiên cảnh, hoàn thành lột xác sinh mệnh thăng hoa, rồi mở liền ba động thiên (dung nham đỏ, bạc, tím) trở thành cao thủ Động Thiên trung kỳ.","importance":"major"},{"chuong":"@c0081","canhGioi":"Động Thiên cảnh","text":"Sau một ngày một đêm tu luyện, ba động thiên như ba ngọn núi lửa dung nham chảy vào thân, cảnh giới Động Thiên được củng cố hoàn toàn, ba núi lửa ẩn vào trong.","importance":"minor"},{"chuong":"@c0082","canhGioi":"Động Thiên Cảnh","text":"Lộ ra khi đột phá đã mở liền ba cái Động Thiên — điều chưa từng nghe, chấn động cả đại thủ lĩnh (30 tuổi mới lên Động Thiên); chưa tới 8 tuổi mà đã ngang tầm cường giả Động Thiên hơn 50 tuổi.","importance":"major"},{"chuong":"@c0086","canhGioi":"Động Thiên cảnh","text":"Mở Động Thiên (Miệng núi lửa) thứ tư sau lưng nhờ bảo dược máu thịt Tế Linh; đủ bốn bất hủ thông đạo, đủ sức vượt cửa nhưng chưa dùng.","importance":"major"},{"chuong":"@c0095","canhGioi":"Động thiên thứ năm","text":"Mở động thiên thứ năm trong hành trình vượt Đại Hoang khi mới hơn chín tuổi — núi lửa phun chất lỏng vàng, đỉnh đầu/hai bên/trước ngực/sau lưng đều được núi lửa bao phủ.","importance":"major"},{"chuong":"@c0001","canhGioi":"Phàm nhân","text":"Còn là bé trai một tuổi rưỡi ở Thạch Thôn, chưa tu luyện.","importance":"minor"},{"chuong":"@c0033","canhGioi":"Thần lực tám ngàn cân","text":"Tẩy lễ thành công, tinh lực dồi dào, khí lực dùng không hết, nâng nổi đỉnh Hống văn tám ngàn cân.","importance":"major"},{"chuong":"@c0001","canhGioi":"Phàm nhân","text":"Đứa trẻ một tuổi rưỡi bình thường, mới biết đi chưa lâu, được nuôi bằng sữa bách thú.","importance":"minor"},{"chuong":"@c0004","canhGioi":"Phàm nhân","text":"Qua tắm thuốc và bảo dược, thể chất, tốc độ và sức mạnh tăng mạnh; cốt văn lan từ lòng bàn tay lên cả cánh tay, song chưa đến mức thoát thai hoán cốt.","importance":"minor"},{"chuong":"@c0029","canhGioi":"Thay máu","text":"Học Cốt văn thần tốc, chỉ mấy ngày đã đột phá cảnh giới Thay máu, phá kỷ lục thời gian.","importance":"minor"},{"chuong":"@c0052","canhGioi":"Phàm nhân","text":"Sáu tuổi (tính cả tuổi thực), nâng cự thạch ba mươi ngàn cân nhờ khổ tu Cốt văn rèn huyết khí.","importance":"minor"},{"chuong":"@c0054","canhGioi":"Bàn Huyết cảnh","text":"Đạt đỉnh cao Bàn Huyết cảnh — điều động tinh huyết dung luyện cùng Cốt văn; sức cơ bắp nâng cự thạch ba mươi ngàn cân.","importance":"major"},{"chuong":"@c0032","canhGioi":"Bàn Huyết cảnh (tẩy lễ thân thể)","text":"Hoàn thành tẩy lễ và lột xác kinh người trong đỉnh dược, hấp thu thần tính Toan Nghê cùng ba chân huyết Di chủng Thái cổ; thân thể trắng noãn óng ánh bảo quang, khí lực vượt xa người có năm sáu nghìn cân, nâng nổi đỉnh Hống văn tám nghìn cân.","importance":"major"},{"chuong":"@c0032","canhGioi":"Phàm nhân (luyện thể)","text":"Trải qua tẩy lễ thân xác bằng huyết thanh vàng kim và ba chân huyết Di chủng Thái cổ, nứt xương xoắn thịt chặt gân, thân thể được tẩm bổ rắn chắc, đạt thần lực tám nghìn cân dù chưa tới bốn tuổi.","importance":"major"}],"nhanMach":[{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng ủng hộ, xác nhận và cảnh báo về Bí Cốt Bảo Thư","ghiChu":"@c0012"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Thanh Lân Ưng lão tam do Thạch Hạo nuôi dạy, phản tổ kế thừa ấn ký Thái Cổ ma cầm","ghiChu":"@c0012"},{"ten":"Đại Bằng","tag":"dong-minh","quanHe":"Thanh Lân Ưng lão đại do Thạch Hạo nuôi dạy","ghiChu":"@c0012"},{"ten":"Tiểu Thanh","tag":"dong-minh","quanHe":"Thanh Lân Ưng lão nhị do Thạch Hạo nuôi dạy","ghiChu":"@c0012"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Bạn thân, hiến hóa ấn ký cốt bảo cho Thạch Hạo nghiên cứu","ghiChu":""},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng dặn dò về Bí Cốt Bảo Thư","ghiChu":""},{"ten":"Thạch Đại Tráng","tag":"dong-minh","quanHe":"Đồng bọn trong đoàn trẻ Thạch Thôn","ghiChu":"Cùng lẻn vào rừng đá lấy trứng (@c0007)"},{"ten":"Thạch Trung Hầu","tag":"dong-minh","quanHe":"Đồng bọn, người dẫn đường tới sào huyệt","ghiChu":"@c0007"},{"ten":"Thạch Mãnh","tag":"dong-minh","quanHe":"Đồng bọn cùng đoàn","ghiChu":"@c0007"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"bạn cùng nhóm trẻ Thạch Thôn","ghiChu":"Cùng đi trộm trứng, được Thạch Hạo đỡ khi bị thương chân."},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Cùng đám nhóc Thạch Thôn cùng chống Thanh Lân Ưng","ghiChu":"Cùng nhóm ba đứa khỏe nhất ném thiết mâu"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Tộc lão Thạch Thôn dẫn đội cứu viện","ghiChu":"Người tế Tổ Khí cứu đám nhóc"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng Thạch Thôn cử đội cứu viện","ghiChu":""},{"ten":"Tử Vân","tag":"khac","quanHe":"thân thiết, được Tử Vân hiến ấn ký cốt bảo cho nghiên cứu","ghiChu":"@c0012"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Kẻ địch bắn tên nhắm giết","ghiChu":"Thiếu niên Bái Thôn bắn 4 mũi tên nhắm Thạch Hạo (@c0014)"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ địch","ghiChu":"Đánh bại Bái Phong trong trận đầu chạm mặt, khiến hắn phun máu bay ngang (@c0015)."},{"ten":"Thạch Phi Giao","tag":"ho-hang","quanHe":"Người Thạch Thôn","ghiChu":"Thạch Phi Giao chứng kiến trận đấu, mắng Bái Phong ác độc (@c0015)."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ — đích thân đá gục và bắt sống","ghiChu":"@c0016"},{"ten":"Thanh Lân Ưng","tag":"an-nhan","quanHe":"Đại thẩm Thanh Lân Ưng nhào xuống chở Thạch Hạo đi tranh đoạt bảo thể Toan Nghê","ghiChu":"Nhóc tỳ gọi thân mật là ‘đại thẩm’ (@c0018)"},{"ten":"Thanh Lân Ưng","tag":"dong-hanh","quanHe":"Hung cầm chở Thạch Hạo ra trận, cùng nhau chiến đấu và che chở cho nhau giữa bầy cự thú","ghiChu":"Thạch Hạo dùng trăng bạc giữ lưng cho Thanh Lân Ưng, g_ap @c0019"},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Được Thanh Lân Ưng mang trên lưng, phối hợp tấn công hung thú","ghiChu":"@c0020"},{"ten":"Thử Vương","tag":"doi-thu","quanHe":"Truy kích, đánh gãy xương khiến Thử Vương trọng thương","ghiChu":"@c0020"},{"ten":"Thanh Lân Ưng","tag":"khac","quanHe":"Hung cầm được Thạch Hạo cứu chữa và bảo vệ","ghiChu":"Cho ăn bảo huyết sừng Thái Cổ Di Chủng @c0022"},{"ten":"Thủ lĩnh đội săn thú Bái Thôn","tag":"doi-thu","quanHe":"Kẻ cầm đầu phục kích Thạch Hạo","ghiChu":"Bị Bảo Nguyệt chém rách bụng @c0022"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Tộc trưởng Bái Thôn phục kích cướp bảo thể, ra lệnh giết cả Thạch Hạo lẫn hung cầm","ghiChu":"@c0023"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Núp trong lùm cây bắn tên xuyên tay Thạch Hạo","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Thiếu niên thiên tài từng bị Thạch Hạo đánh bại, nay dùng Bảo Cụ tập kích trả thù","ghiChu":"@c0023"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Bái Sơn bắn lén Thạch Hạo; Thạch Hạo dùng vòng răng thú đánh gãy tứ chi rồi chém chết hắn (@c0027)"},{"ten":"Hổ Nữu","tag":"the-thiep","quanHe":"Được đề cập đính ước với Thạch Hạo","ghiChu":"Con gái chú Hổ (@c0033)"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng giao khối xương Phù văn Toan Nghê cho ghi nhớ, răn dạy chớ kiêu ngạo","ghiChu":"@c0033"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đánh bay khi hắn xông vào đầu thôn","ghiChu":""},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ — đẩy lui Giao Bằng chỉ bằng sức cơ thể thuần túy","ghiChu":"@c0035"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ khai chiến bắn ba chim non","ghiChu":"Bị Thạch Hạo đánh bay vỡ gan bàn tay @c0037"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Thiên tài Tử Sơn Tộc cùng săn chim non","ghiChu":"Cung bị Thạch Hạo đá đỉnh đồng đánh gãy @c0037"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Thiên tài Lôi Tộc cùng săn chim non @c0037"},{"ten":"Ông lão Vân Thiên Cung","tag":"an-nhan","quanHe":"được mời làm trọng tài phân thắng bại","ghiChu":"Nhóc tỳ chủ động mời vì thấy ông còn giữ công đạo (@c0038)"},{"ten":"Đôi tỷ muội sinh đôi","tag":"khac","quanHe":"quan chiến trầm trồ khi nhóc tỳ thi triển võ nghệ","ghiChu":"@c0038"},{"ten":"Tiểu Hồng","tag":"dong-minh","quanHe":"Sinh linh chí cường được nhóc tỳ dỗ bình tĩnh, tặng tín vật lông đỏ cho Thạch Thôn","ghiChu":"@c0051"},{"ten":"Con khỉ ba tay","tag":"khac","quanHe":"Tình cờ phát hiện dưới đáy hồ khô cạn","ghiChu":"Sinh linh bí ẩn bị lấp nhiều năm, chỉ còn con mắt sáng — chưa lộ tên. @c0052"},{"ten":"Chu Yếm","tag":"khac","quanHe":"Sinh linh thu nhận","ghiChu":"Phát hiện, cho ăn và mang di chủng Chu Yếm về Thạch Thôn (@c0053)"},{"ten":"Chu Yếm","tag":"khac","quanHe":"Đặt tên cho Chu Yếm là Tiểu Chu / Mao Cầu","ghiChu":"Thạch Hạo hiểu Chu Yếm là Di Chủng Thái Cổ mất trí nhớ, phù văn cơ thể bể nát (@c0054)"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Được Liễu Thần răn dạy và đồng ý giúp xem tiềm thức","ghiChu":"@c0054"},{"ten":"Tiểu Hồng","tag":"khac","quanHe":"Con chim sẻ đỏ rực nhóc tỳ từng đuổi bắt và đặt tên","ghiChu":"Thạch Hạo kể lại cho tộc trưởng, gợi liên hệ với Hỏa Thú/Thần Tước sâu trong núi."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ Bái thôn dùng Bảo cụ; bị nhóc tỳ đánh bại, tàn phế và cướp mất Bảo cụ","ghiChu":"@c0024"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ thù, thủ lĩnh đội săn thú Bái Thôn","ghiChu":"Bắn lén Thạch Hạo, bị cậu đánh gãy tứ chi rồi chém chết (@c0027)"},{"ten":"A Văn thúc","tag":"khac","quanHe":"Người Thạch Thôn","ghiChu":"Bị Bái Sơn bắn xuyên lồng ngực; hồi ức thôi thúc Thạch Hạo hạ sát Bái Sơn (@c0027)"},{"ten":"Cha mẹ Thạch Hạo","tag":"cha-me","quanHe":"Cha mẹ ruột","ghiChu":"Rời thôn đi tìm Thánh dược trị bệnh cho Thạch Hạo, chưa lộ tên."},{"ten":"Con khỉ ba tay","tag":"khac","quanHe":"Sinh linh phát hiện dưới đáy hồ khô cạn","ghiChu":"Nằm bất động bị đất cát phủ, còn một con mắt sáng chưa chết."},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Được nhóc tỳ khuyên đến giúp tộc","ghiChu":"Nhóc tỳ dặn ba chim non tiếp tục khuyên Thanh Lân Ưng đến trợ giúp khi tộc vào núi. @c0017"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Đàn anh cùng thôn","ghiChu":"Cùng thi thố sức lực trong buổi nâng đỉnh @c0005"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Đàn anh cùng thôn","ghiChu":"Cùng dự buổi thi nâng đỉnh @c0005"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Đàn anh cùng thôn","ghiChu":"Cùng dự buổi thi thố @c0005"},{"ten":"Thạch Lâm Hổ","tag":"an-nhan","quanHe":"Thúc bối yêu thương","ghiChu":"Hái Tương Quả tặng cậu, tự xưng A Thúc (@c0006)."},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm, thủ lĩnh đoàn trẻ đi trộm trứng","ghiChu":"Cùng trèo vách lấy trứng @c0007"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm, đứa dẫn đường tới sào huyệt","ghiChu":"@c0007"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm, cùng ném đá thăm dò tổ","ghiChu":"@c0007"},{"ten":"Thạch Lâm Hổ","tag":"khac","quanHe":"Người lớn trong thôn, nguồn thông tin về tập quán Thanh Lân Ưng bị bọn trẻ nghe lén","ghiChu":"@c0007"},{"ten":"Nhị Mãnh","tag":"dong-hanh","quanHe":"Bạn cùng trộm trứng ở Thạch Thôn","ghiChu":"Cùng chọc tổ Thanh Lân Ưng @c0008"},{"ten":"Bì Hầu","tag":"dong-hanh","quanHe":"Bạn cùng trộm trứng ở Thạch Thôn","ghiChu":"Cùng chọc tổ Thanh Lân Ưng @c0008"},{"ten":"Thạch Đại Tráng","tag":"dong-hanh","quanHe":"Bạn cùng trộm trứng ở Thạch Thôn","ghiChu":"Thạch Hạo đỡ Đại Tráng khi cậu bị thương chân @c0008"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ","ghiChu":"Bì Hầu tị nạnh vì Nhóc tỳ được uống sữa (@c0010)."},{"ten":"Tử Vân","tag":"khac","quanHe":"Linh cầm thân thiết nhất, chủ động hiến ấn ký cốt bảo cho Thạch Hạo nghiên cứu","ghiChu":"@c0012"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Tộc trưởng nuôi dưỡng che chở, khen thiên tư và dặn dò về Bí Cốt Bảo Thư","ghiChu":"@c0012"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị thiếu niên Bái Thôn nhắm bắn liền bốn mũi tên, sau đó lao tới phản công."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Thiếu niên Bái Thôn giao đấu với Thạch Hạo và bại trận","ghiChu":"@c0015"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ Bái Thôn bị Thạch Hạo đá gục và bắt sống","ghiChu":"@c0016"},{"ten":"Đại Bằng","tag":"dong-hanh","quanHe":"Chim non nuôi thân thiết, dụi đầu vào tay tỏ vẻ quyến luyến muốn đi theo","ghiChu":"@c0017"},{"ten":"Tiểu Thanh","tag":"dong-hanh","quanHe":"Chim non nuôi thân thiết, quấn quýt cọ đầu vào tay nhóc tỳ","ghiChu":"@c0017"},{"ten":"Thủ lĩnh đội săn thú Bái Thôn","tag":"doi-thu","quanHe":"Đối thủ phục kích","ghiChu":"Bị Thạch Hạo chém rách bụng suýt lòi ruột trong trận phục kích. @c0022"},{"ten":"Thiếu niên trên cáng (Bái Thôn)","tag":"doi-thu","quanHe":"Đối thủ Bái Thôn","ghiChu":"Có mặt trong đoàn viện binh Bái Thôn, thưởng thức vòng răng thú. @c0022"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Thủ lĩnh săn thú Bái Thôn núp bắn xuyên tay Thạch Hạo","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Thiếu niên từng bị nó đánh bại, nay tập kích bằng Bảo Cụ","ghiChu":"@c0023"},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Hung cầm Thạch Thôn nó tử thủ bảo vệ khi trúng độc","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Thiên tài Bái thôn, bị nhóc tỳ đánh bại, cắt đứt tứ chi và cướp mất Bảo cụ răng thú (@c0024)."},{"ten":"Thạch Phi Giao","tag":"an-nhan","quanHe":"Người nhường Tổ Khí","ghiChu":"Nhường Tổ Khí da thú cho nhóc tỳ vì Cốt Văn nhóc tỳ cao hơn."},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Đồng tộc Thạch Thôn","ghiChu":"Được Thạch Lâm Hổ ném lên trời để tung đòn quyết định."},{"ten":"Bái già","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Ra đòn sát thủ trọng thương con Bái già."},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ địch bị Thạch Hạo giết","ghiChu":"Thủ lĩnh đội săn thú Bái Thôn, bắn lén xuyên cánh tay Thạch Hạo; bị Thạch Hạo dùng vòng răng thú đánh gãy tứ chi rồi chém đầu — nạn nhân đầu tiên dưới tay cậu."},{"ten":"A Văn thúc","tag":"khac","quanHe":"Người cùng thôn bị Bái Sơn hại","ghiChu":"Bị Bái Sơn bắn xuyên lồng ngực; hồi tưởng về A Văn thúc thôi thúc Thạch Hạo hạ quyết tâm chém đầu Bái Sơn."},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Tộc nhân khích lệ và cõng Thạch Hạo","ghiChu":"Khích lệ Thạch Hạo trong trận diệt Bái Sơn, rồi cõng cậu khi cậu kiệt sức ngất đi."},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Kẻ địch bắn liền bốn mũi tên vào Thạch Hạo; nó chặn mũi tên rồi nhảy lao tới tấn công","ghiChu":"@c0014"},{"ten":"Thạch Lâm Hổ","tag":"an-nhan","quanHe":"Che chở Thạch Hạo, phá ba trong bốn mũi tên khi thiếu niên Bái Thôn nhắm bắn nhóc tỳ","ghiChu":"@c0014"},{"ten":"Đại Bằng","tag":"dong-minh","quanHe":"Chim non thân thiết dụi đầu vào tay, muốn đi theo","ghiChu":"@c0017 — Đại Bằng, Tiểu Thanh, A Tử cọ đầu vào tay nhóc tỳ tỏ vẻ thân thiết, muốn theo vào núi nhưng bị dặn ở lại."},{"ten":"Tiểu Thanh","tag":"dong-minh","quanHe":"Chim non quấn quýt, cọ đầu vào tay tỏ vẻ thân thiết","ghiChu":"@c0017 — cùng Đại Bằng, A Tử muốn theo Thạch Hạo."},{"ten":"A Tử","tag":"dong-minh","quanHe":"Chim non thân thiết, muốn đi theo Thạch Hạo","ghiChu":"@c0017 — cùng Đại Bằng, Tiểu Thanh cọ đầu vào tay nhóc tỳ."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ thù thiếu niên","ghiChu":"Từng bị Thạch Hạo đánh bại, nay dùng Bảo Cụ tập kích suýt lấy mạng nhóc. @c0023"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ phục kích","ghiChu":"Núp trong lùm cây bắn xuyên tay Thạch Hạo. @c0023"},{"ten":"Thạch Phi Giao","tag":"an-nhan","quanHe":"Người nhường Tổ Khí thứ hai (da thú) cho nhóc tỳ giữ","ghiChu":"Nhường vì Cốt Văn của nhóc tỳ cao thâm hơn @c0026"},{"ten":"Con Bái dữ","tag":"doi-thu","quanHe":"Kẻ địch bị nhóc tỳ tung đòn sát thủ trọng thương","ghiChu":"Hung thú Bệ Ngạn của nhóc tỳ đánh nát nửa thân sau con Bái @c0026"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ thù bị giết","ghiChu":"Bái Sơn bắn lén xuyên cánh tay Thạch Hạo; Thạch Hạo dùng vòng răng thú đánh gãy tứ chi rồi chém đầu Bái Sơn (@c0027)."},{"ten":"A Văn thúc","tag":"ho-hang","quanHe":"Trưởng bối Thạch Thôn","ghiChu":"Hồi tưởng A Văn thúc bị Bái Sơn bắn xuyên lồng ngực khiến Thạch Hạo quyết chém chết Bái Sơn (@c0027)."},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Tộc nhân Thạch Thôn","ghiChu":"Khích lệ Thạch Hạo giết người rồi cõng cậu về khi kiệt sức ngất đi (@c0027)."},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Hung cầm bảo hộ Thạch thôn","ghiChu":"Hồi phục nhờ chân huyết Bò ma Ly Hỏa và máu thịt Toan Nghê, rời đi tìm chỗ bế quan đột phá (@c0033)."},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ bị Thạch Hạo giết","ghiChu":"Bái Sơn bắn lén, bị Thạch Hạo chém đầu @c0027"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng tham gia cuộc thi thố sức lực trong thôn"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng dự thi nâng đỉnh"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Đồng thôn đồng lứa","ghiChu":"Cùng đám trẻ Thạch Thôn"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm","ghiChu":"Cùng trèo vách đá"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm, người dẫn đường","ghiChu":"Dẫn đoàn tới sào huyệt Thanh Lân Ưng"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ đi trộm trứng","ghiChu":"Cùng chọc tổ Thanh Lân Ưng ở Thạch Lâm (@c0008)"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ","ghiChu":"Cùng đi trộm trứng (@c0008)"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ","ghiChu":"Được Thạch Hạo đỡ khi dẫm phải vảy (@c0008)"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm nhóc Thạch Thôn","ghiChu":"Cùng ném thiết mâu vào mắt Thanh Lân Ưng (@c0009)"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm nhóc Thạch Thôn","ghiChu":"Một trong ba đứa khỏe nhất cùng ném thiết mâu (@c0009)"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng bọn trốn động","ghiChu":"@c0009"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Được tộc trưởng thưởng sữa thú vì kể chuyện Tiểu Hồng","ghiChu":"@c0010"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ, thắc mắc vì sao Nhóc tỳ được uống sữa","ghiChu":"@c0010"},{"ten":"Đại Bằng","tag":"dong-hanh","quanHe":"Chim non được Thạch Hạo dạy cốt văn","ghiChu":"@c0012"},{"ten":"Tiểu Thanh","tag":"dong-hanh","quanHe":"Chim non được Thạch Hạo dạy cốt văn","ghiChu":"@c0012"},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Kẻ địch — nhắm bắn Thạch Hạo bốn mũi tên; Thạch Hạo lao thẳng tới phản kích","ghiChu":"@c0014"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ Bái Thôn","ghiChu":"Giao đấu tại vùng núi rừng, Thạch Hạo đánh bại khiến Bái Phong phun máu bay ngang (@c0015)"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ bị Thạch Hạo đá gục và bắt sống","ghiChu":"Chạm mặt tại vùng núi tranh chấp @c0016"},{"ten":"Thử Vương","tag":"doi-thu","quanHe":"Đối thủ trong loạn tranh đoạt Toan Nghê","ghiChu":"Thạch Hạo cùng Thanh Lân Ưng đánh gãy xương Thử Vương, khiến nó trọng thương (@c0020)."},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Thần điểu cưu mang, cùng chiến đấu và thu hoạch bảo vật","ghiChu":"Cùng tha ba Thái Cổ Di Chủng về Thạch Thôn (@c0021)"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Thủ lĩnh đội săn Bái Thôn núp bắn xuyên tay Thạch Hạo","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ địch trong trận tử chiến","ghiChu":"Nhóc tỳ đánh bại, đá vỡ mặt, cắt tứ chi tàn phế và đoạt Bảo cụ răng thú của Bái Phong."},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ thù bắn lén","ghiChu":"Thủ lĩnh đội săn thú Bái Thôn bắn lén Thạch Hạo, bị cậu dùng vòng răng thú đánh gãy tứ chi rồi chém đầu trong cuộc truy sát (@c0027)"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng chỉ dạy Cốt văn và lo liệu việc lột xác","ghiChu":"@c0028"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đánh bay ở đầu thôn","ghiChu":"@c0034"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Bái Sơn bắn lén xuyên tay Thạch Hạo lúc khai chiến; bị Thạch Hạo dùng vòng răng thú giết chết","ghiChu":"@c0027"},{"ten":"A Văn thúc","tag":"an-nhan","quanHe":"Người Thạch Thôn bị Bái Sơn bắn xuyên lồng ngực; hồi tưởng thôi thúc Thạch Hạo ra tay","ghiChu":"@c0027"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Khích lệ rồi cõng Thạch Hạo kiệt sức về sau khi cậu ngất","ghiChu":"@c0027"},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Tộc nhân","ghiChu":"Cho Thạch Hạo thử kéo bảo cung Tê giác lớn nhất tộc, nhưng tay quá ngắn không kéo căng"},{"ten":"Hổ Nữu","tag":"the-thiep","quanHe":"Được nhắc đính ước","ghiChu":"Con gái chú Hổ, được đề cập đính ước với nhóc tỳ"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ bắn lén xuyên cánh tay, bị Thạch Hạo chém chết","ghiChu":"Truy sát Bái Thôn @c0027"},{"ten":"Thạch Lâm Hổ","tag":"dong-minh","quanHe":"Đồng tộc khích lệ rồi cõng về khi ngất","ghiChu":"@c0027"},{"ten":"A Văn thúc","tag":"khac","quanHe":"Đồng tộc Thạch Thôn bị Bái Sơn bắn xuyên ngực, thành động cơ giết Bái Sơn","ghiChu":"Hồi tưởng @c0027"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ nhỏ tuổi","ghiChu":"Hai lần đẩy lui Giao Bằng bằng sức thân (@c0035)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu ở Thạch thôn","ghiChu":"Giao Bằng trở mặt muốn động thủ, nhóc tỳ ra ngăn (@c0036)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ địch trực diện","ghiChu":"Đánh bay Giao Bằng khi hắn muốn bắt ba con chim non (@c0037)"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đá đỉnh đồng làm gãy bảo cung của Tử Sơn Côn (@c0037)"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Cùng bị đỉnh đồng ép né tránh (@c0037)"},{"ten":"Đại Bằng","tag":"dong-hanh","quanHe":"Chim non đi theo học Cốt Văn","ghiChu":"Chở che, chắn tên khi bị Giao Bằng săn (@c0037)"},{"ten":"Tiểu Thanh","tag":"dong-hanh","quanHe":"Chim non đi theo học Cốt Văn","ghiChu":"Chở che khi bị Giao Bằng bắn trúng (@c0037)"},{"ten":"Tử Vân","tag":"dong-hanh","quanHe":"Chim non đi theo học Cốt Văn","ghiChu":"Mục tiêu ban đầu Giao Bằng muốn bắt sống (@c0037)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong quyết đấu, bị Thạch Hạo đánh bại phun máu rụng răng","ghiChu":"@c0038"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ, bị đá văng và Hỏa Lân bị Ma Cầm diệt","ghiChu":"@c0038"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ, bị đá đạp trọng thương","ghiChu":"@c0038"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Được Thạch Hạo mời làm trọng tài phân thắng bại","ghiChu":"@c0038"},{"ten":"Hai tiểu cô nương Vân Thiên Cung","tag":"khac","quanHe":"Hai tỷ tỷ Vân Thiên Cung dụ nhóc tỳ đi Tuyết Hải uống sữa thú, sau lo lắng xin gia gia cứu Thạch Thôn.","ghiChu":"@c0039"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Tộc trưởng che chở","ghiChu":"Nhóc tỳ hỏi thẳng tộc trưởng liệu cha mẹ còn tại thế không; tộc trưởng tâm tình phức tạp không biết trả lời"},{"ten":"Tiểu Hồng","tag":"khac","quanHe":"Linh thú / bạn đồng hành","ghiChu":"Tiểu Hồng trọng thương rơi xuống trước mặt nhóc tỳ, lườm nhóc tỳ đầy u oán tức giận"},{"ten":"Tiểu Hồng","tag":"dong-minh","quanHe":"Con tước đỏ được cậu dỗ bình tĩnh","ghiChu":"Nhóc tỳ khẳng định tước đỏ không có địch ý và dỗ nó bình tĩnh (@c0051)."},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Cây liễu thần bảo hộ Thạch thôn","ghiChu":"Hẹn sẽ ngủ một thời gian dài, chờ một hai năm khi huyết khí Thạch Hạo mạnh hơn sẽ giúp nhìn rõ mảnh ký ức trong tiềm thức."},{"ten":"Chu Yếm","tag":"dong-minh","quanHe":"Sinh linh di chủng do Thạch Hạo cứu và thu nhận về Thạch Thôn","ghiChu":"Phát hiện dưới đáy hồ khô cạn, mang về nuôi (@c0053)"},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"Di Chủng Thái Cổ được Thạch Hạo đặt tên Mao Cầu / Tiểu Chu, nuôi trong thôn","ghiChu":"Thạch Hạo giải thích Chu Yếm cũng là Di Chủng Thái Cổ nhưng phù văn bể nát, quên hết quá khứ."},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Cây liễu Thần đầu thôn răn dạy Thạch Hạo và đồng ý giúp xem tiềm thức về quá khứ"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Anh cùng dòng họ (Nghị Nhi)","ghiChu":"Trong ký ức được nhắc cùng Hạo Nhi, được kỳ vọng như thiên tài trọng đồng của dòng họ. (@c0055)"},{"ten":"Lão Thập Ngũ","tag":"ho-hang","quanHe":"Gia gia (ông nội) trong ký ức","ghiChu":"Đích thân nhỏ bảo huyết Thần Cầm cho Hạo Nhi lúc còn quấn tã. (@c0055)"},{"ten":"Nhân Hoàng","tag":"ho-hang","quanHe":"Bậc trên cùng cổ quốc, cùng hoàng huyết","ghiChu":"Dòng họ Thạch Hạo là hoàng thân, có thể tranh ngôi Nhân Hoàng. (@c0055)"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Anh em họ; Thạch Nghị được cấy Chí Tôn Cốt lấy từ Thạch Hạo","ghiChu":"@c0057"},{"ten":"Tứ Thái Gia","tag":"an-nhan","quanHe":"Bối phận cực cao trong Thạch Tộc, được cha mẹ gửi trông nom; phá cửa cứu Thạch Hạo, vận Bảo Phù cứu chữa","ghiChu":"@c0057"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Chủ sự bối phận cực cao trong tộc, ngăn Tứ Thái Gia giết mẹ Thạch Nghị (hậu nhân chi mình)","ghiChu":"@c0057"},{"ten":"A Man","tag":"ban-be","quanHe":"Bé gái người hầu chăm sóc, ngày ngày khóc nhắc Hạo nhớ mình là Chí Tôn.","ghiChu":"@c0058"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ được cấy Chí Tôn cốt móc từ thân Hạo, dung hợp thành công thành một thể.","ghiChu":"@c0058"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ đoạt Chí Tôn cốt của mình — tuyến đối đầu trọng đại","ghiChu":"@c0059"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Ông nội — từng bắn thú con Tỳ Hưu lấy máu gột rửa thân thể cho hắn","ghiChu":"@c0059"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ đoạt Chí Tôn cốt, nhìn nhóc tỳ với ánh mắt ngạo thị khinh miệt; đối nghịch định mệnh.","ghiChu":"@c0062"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Cây liễu Thạch thôn có linh trí, truyền âm chiếu lại quá khứ và hứa tiết lộ bí mật cho nhóc tỳ.","ghiChu":"@c0062"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Thần thụ Thạch Thôn khai thị","ghiChu":"Khai thị đạo lý niết bàn tái sinh, gợi mở khả năng Chí Tôn Cốt tái sinh trong thân nhóc tỳ (@c0063)"},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"linh thú thân cận, bị chọn làm nguồn chủ dược cho phương thuốc trúc cơ, thân phận phi phàm","ghiChu":"@c0064"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"thần linh cây liễu truyền âm chỉ điểm cách tu Nguyên Thủy Chân Giải và trao phương thuốc trúc cơ Thái Cổ Hung Thú","ghiChu":"@c0064"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cùng dòng họ hoàng thân; Nghị Nhi được ví là huynh trưởng thiên tài, cả tộc kỳ vọng Hạo sẽ thành cánh tay phải.","ghiChu":"@c0055"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Gia gia (ông) trong ký ức; đích thân nhỏ bảo huyết Thần Cầm cho Hạo uống.","ghiChu":"@c0055"},{"ten":"Nhân Hoàng","tag":"ho-hang","quanHe":"Chủ nhân cổ quốc; dòng họ Thạch Hạo là hoàng thân cùng hoàng huyết, theo quy củ có thể tranh ngôi Nhân Hoàng.","ghiChu":"@c0055"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Cha","ghiChu":"Phát điên báo thù vì con bị đoạt cốt"},{"ten":"Mẹ Thạch Hạo","tag":"cha-me","quanHe":"Mẹ","ghiChu":"Ôm bồng đi theo cha"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Ông (từng bắn thú Tỳ Hưu lấy máu gột rửa thân thể cho cháu)","ghiChu":""},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"Linh thú nhỏ lông vàng Thạch Hạo nuôi (trước gọi bóng lông), lộ tên thật ở chương này; bị chọn làm nguồn chủ dược, Thạch Hạo dỗ dành hứa đưa tới Thái Cổ Thần Sơn ăn bảo dược.","ghiChu":"@c0064"},{"ten":"Nhân Hoàng","tag":"khac","quanHe":"Kẻ thống trị cổ quốc; dòng họ Thạch Hạo là hoàng thân mang hoàng huyết gần dòng Nhân Hoàng","ghiChu":"@c0055"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ nhí — bị Thạch Hạo đẩy lui bằng sức cơ thể thuần túy","ghiChu":"@c0035"},{"ten":"Đại Bằng","tag":"khac","quanHe":"Chim non thân thiết","ghiChu":"Chạy tới quấn quýt bên nhóc tỳ."},{"ten":"Tiểu Thanh","tag":"khac","quanHe":"Chim non thân thiết","ghiChu":"Chạy tới quấn quýt bên nhóc tỳ."},{"ten":"Tử Vân","tag":"khac","quanHe":"Chim non thân thiết","ghiChu":"Chạy tới quấn quýt bên nhóc tỳ."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Ra ngăn khi Giao Bằng trở mặt định động thủ."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu — cản tên rồi đánh bay Giao Bằng để bảo vệ ba con chim non","ghiChu":"@c0037"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Trọng tài quyết đấu","ghiChu":"Được Thạch Hạo mời phân thắng bại vì còn giữ công đạo giữa đám cường giả bất thiện."},{"ten":"Đôi tỷ muội sinh đôi","tag":"khac","quanHe":"Người quan chiến","ghiChu":"Hai thiếu nữ thiên tài trầm trồ khi thấy nhóc tỳ lợi hại."},{"ten":"Hai tiểu cô nương Vân Thiên Cung","tag":"khac","quanHe":"dụ Thạch Hạo bằng sữa thú và Tuyết Hải","ghiChu":"nhóc tỳ khéo léo từ chối"},{"ten":"Tiểu Hồng","tag":"dong-minh","quanHe":"Con chim đỏ của nhóc tỳ, rơi xuống bị trọng thương lườm nhóc đầy u oán","ghiChu":"@c0050"},{"ten":"Tiểu Hồng","tag":"khac","quanHe":"Dỗ tước đỏ bình tĩnh, hiểu ý định của nó","ghiChu":"@c0051"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng kể cho nhóc tỳ nghe thân thế Thạch Thôn và cha mẹ","ghiChu":"@c0051"},{"ten":"Cha mẹ nhóc tỳ","tag":"cha-me","quanHe":"Đôi vợ chồng trẻ từ cổ quốc mang nhóc tỳ về tổ địa, đã thất lạc","ghiChu":"@c0051"},{"ten":"Con khỉ ba tay","tag":"khac","quanHe":"Sinh linh dưới đáy hồ khô cạn do Thạch Hạo phát hiện","ghiChu":"Con khỉ dài một thước có ba cái tay, bị đất cát phủ nhiều năm, con mắt còn sáng."},{"ten":"Chu Yếm","tag":"khac","quanHe":"Sinh linh được cứu và nuôi dưỡng","ghiChu":"Tìm thấy dưới đáy hồ khô cạn."},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"Đặt tên cho Mao Cầu, giải thích nó là Di Chủng Thái Cổ mất trí nhớ","ghiChu":"@c0054"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Ông (gia gia) trong ký ức","ghiChu":"Đích thân nhỏ bảo huyết Thần Cầm cho Hạo Nhi lúc còn quấn tã, gọi là cháu trai. @c0055"},{"ten":"Thập Nhất đệ","tag":"cha-me","quanHe":"Cha","ghiChu":"Người đầu tiên xác nhận Chí Tôn cốt, rời phủ đi tìm ông nội"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Ông nội","ghiChu":"Mất tích sau khi bị Tỳ Hưu đuổi giết"},{"ten":"Lục tẩu","tag":"doi-thu","quanHe":"Bá mẫu (Đại nương)","ghiChu":"Lừa chiết Chí Tôn cốt"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Huynh đệ trong tộc","ghiChu":"Dửng dưng chứng kiến chiết xương, được cấy Chí Tôn cốt"},{"ten":"A Man","tag":"ban-be","quanHe":"Tỷ tỷ hạ nhân","ghiChu":"Hay kể chuyện xưa cho Hạo nghe"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Anh em họ trong Thạch Tộc; Chí Tôn Cốt của Thạch Hạo bị cấy sang Thạch Nghị","ghiChu":""},{"ten":"Tứ Thái Gia","tag":"an-nhan","quanHe":"Chủ sự trong tộc được cha mẹ Thạch Hạo nhờ trông nom; phá cửa cứu chữa Thạch Hạo","ghiChu":""},{"ten":"Vợ Thạch Tử Lăng (mẹ nhóc tỳ)","tag":"cha-me","quanHe":"Mẹ","ghiChu":"Ôm nhóc tỳ đi theo chồng"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Cha ruột, vì hắn mà đòi trả Chí Tôn Cốt","ghiChu":"@c0061"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Cây liễu truyền âm chiếu lại quá khứ, hứa tiết lộ bí mật","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Người cùng dòng họ hoàng thân, huynh trưởng thiên túng kỳ tài mang trọng đồng","ghiChu":"Cùng dòng họ cổ quốc, được kỳ vọng trấn áp bát hoang"},{"ten":"Lão Thập Ngũ","tag":"ho-hang","quanHe":"Gia gia (ông), đích thân nhỏ bảo huyết Thần Cầm cho uống thuở quấn tã"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ trở mặt uy hiếp Thạch thôn, đòi động thủ và nhắm bắn chim non của nhóc tỳ","ghiChu":"@c0036"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Ông (gia gia)","ghiChu":"Gọi Hạo là cháu trai, tự tay nhỏ bảo huyết Thần Cầm cho uống @c0055"},{"ten":"Nhân Hoàng","tag":"khac","quanHe":"Cùng hoàng thất cổ quốc","ghiChu":"Dòng họ Thạch Hạo là hoàng thân có hoàng huyết trong cổ quốc do Nhân Hoàng thống trị @c0055"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Trưởng bối dòng họ, nhỏ bảo huyết Thần Cầm bồi bổ cho Thạch Hạo từ sơ sinh","ghiChu":"@c0055"},{"ten":"Cha mẹ Thạch Hạo","tag":"cha-me","quanHe":"Đôi vợ chồng trẻ bế Hạo Nhi quấn tã trong ký ức","ghiChu":"@c0055"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ bại trận","ghiChu":"Bị nhóc tỳ đẩy lui hai lần dù nhóc chỉ dùng sức cơ thể"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu tại Thạch Thôn, đánh bay Giao Bằng khi bảo vệ ba con chim non","ghiChu":"@c0037"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đá văng đỉnh đồng đánh gãy cung Tử Sơn Côn","ghiChu":"@c0037"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Cùng phe săn đuổi ba con chim non, bị Thạch Hạo ngăn cản","ghiChu":"@c0037"},{"ten":"Ông lão Vân Thiên Cung","tag":"an-nhan","quanHe":"trọng tài được mời phân thắng bại","ghiChu":"Thạch Hạo mời làm trọng tài giữ công đạo giữa đám cường giả (@c0038)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Thiên tài La Phù Đại Trạch bị nhóc tỳ đánh bại thê thảm, tra tấn bằng cối xay."},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Thần cây liễu bảo hộ","ghiChu":"Nhóc tỳ cầu khấn, cành liễu non hiển linh đâm chết Phi Giao cứu Thạch Thôn."},{"ten":"Tiểu Hồng","tag":"khac","quanHe":"Dỗ dành và giúp tước đỏ chí cường Tiểu Hồng khi nó rơi xuống Thạch Thôn mang trọng thương","ghiChu":"@c0051"},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"Phát hiện con khỉ ba tay còn sống dưới đáy hồ khô cạn","ghiChu":"@c0052"},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"Sinh linh di chủng cậu cứu và thu nuôi từ đáy hồ khô","ghiChu":"Cứu khi nó bị thương kẹt trong bùn, mang về Thạch Thôn."},{"ten":"Chu Yếm","tag":"dong-minh","quanHe":"Đặt tên cho Di Chủng Thái Cổ hình cầu vàng là Tiểu Chu / Mao Cầu, giải thích lai lịch nó cho Liễu Thần","ghiChu":"@c0054"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Người cùng dòng họ, thần đồng trọng đồng được cả tộc kỳ vọng","ghiChu":"Xuất hiện trong ký ức tế trời cổ quốc"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Trưởng bối dòng họ nhỏ bảo huyết Thần Cầm cho khi còn sơ sinh"},{"ten":"Thập Nhất đệ","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Người tra xét xác nhận Chí Tôn cốt của Hạo; rời phủ đi Bách tộc chiến trường tìm Thập Ngũ gia."},{"ten":"Mẹ Thạch Hạo","tag":"cha-me","quanHe":"Mẹ ruột","ghiChu":"Ôm con hôn thắm thiết, khẳng định dù có Chí Tôn cốt vẫn phải cho con tuổi thơ vui vẻ; theo chồng đi Bách tộc chiến trường."},{"ten":"Thập Ngũ gia","tag":"ho-hang","quanHe":"Ông nội","ghiChu":"Bắn chết con Tỳ Hưu ở Bách tộc chiến trường, bị truy sát mất tích."},{"ten":"Lục tẩu","tag":"doi-thu","quanHe":"Bá mẫu (vợ huynh trưởng của cha) — kẻ chủ mưu chiết xương","ghiChu":"Ngoài mặt hiền hòa nhận nuôi Hạo, thực chất lừa xuống mật thất chiết Chí Tôn cốt cho con ruột."},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Anh họ — kẻ được cấy Chí Tôn cốt cướp","ghiChu":"Dùng Trọng Đồng phát hiện Chí Tôn cốt của Hạo; dửng dưng chứng kiến mẹ chiết xương Hạo."},{"ten":"A Man","tag":"ban-be","quanHe":"Tỷ tỷ hạ nhân trong phủ","ghiChu":"Hiền lành xinh đẹp, hay kể chuyện xưa cho tiểu Hạo về Xích Vũ Hạc."},{"ten":"Bóng u linh","tag":"doi-thu","quanHe":"Sát thủ Lục tẩu triệu","ghiChu":"Kẻ cầm đao bạc cứa lồng ngực Hạo chiết Chí Tôn cốt."},{"ten":"Thiếu phụ (bá thẩm, mẹ Thạch Nghị)","tag":"ho-hang","quanHe":"bá thẩm — kẻ hại","ghiChu":"Chủ mưu moi Chí Tôn Cốt và rút chân huyết Hạo Nhi (@c0057)"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"đường huynh đệ","ghiChu":"Kẻ nhận Chí Tôn Cốt cấy từ Hạo Nhi (@c0057)"},{"ten":"Tứ Thái Gia","tag":"an-nhan","quanHe":"tộc trưởng bối cao — cứu mạng","ghiChu":"Phá cửa địa cung, vận Bảo Phù cứu Hạo Nhi (@c0057)"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"tộc trưởng bối cao","ghiChu":"Bao che chi mình, ngăn Tứ Thái Gia giết thiếu phụ (@c0057)"},{"ten":"Tử Lăng","tag":"cha-me","quanHe":"cha ruột","ghiChu":"Sẽ trở về đòi công đạo cho con (@c0057)"},{"ten":"Mẹ Thạch Hạo","tag":"cha-me","quanHe":"mẹ ruột","ghiChu":"Rời đi khi Hạo Nhi mấy tháng tuổi, chỉ còn ấn tượng mơ hồ (@c0057)"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"cha ruột","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"kẻ được cấy Chí Tôn Cốt vốn của mình","ghiChu":"@c0061"},{"ten":"Đại Bằng","tag":"dong-minh","quanHe":"Linh cầm thủ hộ thân thiết","ghiChu":"Chim non chạy tới bên nhóc tỳ, được bảo vệ khi cường giả định bắt (@c0036)"},{"ten":"Tiểu Thanh","tag":"dong-minh","quanHe":"Linh cầm thủ hộ thân thiết","ghiChu":"Chim non chạy tới bên nhóc tỳ (@c0036)"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Linh cầm thủ hộ thân thiết","ghiChu":"Chim non vảy lưng xán lạn, quấn quýt bên nhóc tỳ (@c0036)"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Cường giả La Phù trở mặt","ghiChu":"Trở mặt đòi động thủ với thôn, định bắn ba con chim non của nhóc tỳ (@c0036)"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn nhỏ cùng Thạch thôn","ghiChu":"Cùng đối mặt cường giả trở mặt (@c0036)"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối thủ định mệnh — Thượng Cổ Thánh Nhân nhà Vương Hầu cổ quốc, được cả tộc bồi dưỡng để cạnh tranh với Thạch Hạo.","ghiChu":"Nhắc tên @c0065; chưa gặp mặt."},{"ten":"Liễu Thần","tag":"su-mon","quanHe":"Sư phụ/thần linh bảo hộ","ghiChu":"Kiểm chứng thành quả rèn thân, cho phép tu Nguyên Thủy Chân Giải (@c0066)"},{"ten":"Liễu Thần","tag":"su-mon","quanHe":"Ân sư, vị thần Thạch Thôn chỉ dẫn tu hành","ghiChu":"Sắp xếp chuyến mài giũa tới tổ địa thứ hai, dạy cách rèn theo chuẩn hung thú Thái Cổ (@c0067)"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Lão tộc trưởng Thạch Thôn","ghiChu":"Căn dặn cẩn thận, kịch liệt phản đối chuyến đi xa (@c0067)"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Cha mẹ","ghiChu":"Nhiều năm không về sau khi vào Thái Cổ Thần Sơn vì nó (@c0067)"},{"ten":"Tiểu Bạch","tag":"dong-hanh","quanHe":"Thú cưỡi do Thạch Hạo bắt sống và thuần phục","ghiChu":"Bắt bên hồ Thạch Thôn, hứa dạy Cốt Văn (@c0068)"},{"ten":"Cô gái áo trắng","tag":"doi-thu","quanHe":"Thủ lĩnh đám săn trứng vây tới cuối chương","ghiChu":"Nhóc tỳ nói dối đi cùng gia gia để che giấu việc đi một mình. @c0070"},{"ten":"Bà lão cầm mảnh vỏ trứng","tag":"doi-thu","quanHe":"Cường giả truy tìm, cảm ứng ra việc Thạch Hạo trộm và ăn trứng hậu duệ Thái cổ thần điểu","ghiChu":"@c0072"},{"ten":"Cô gái áo trắng","tag":"an-nhan","quanHe":"Mong Thạch Hạo gia nhập Bổ Thiên các, không bị thế lực khác cướp","ghiChu":"@c0072"},{"ten":"Đứa bé tổ địa rách nát","tag":"ho-hang","quanHe":"‘một mình khác’ — bản thân khác thay hắn chịu khổ","ghiChu":"Thạch Hạo thề đưa đứa bé đến Bổ Thiên Các (@c0073)"},{"ten":"Chu Yếm","tag":"dong-hanh","quanHe":"bạn đồng hành","ghiChu":"Cùng đứng xa quan sát tổ địa rách nát, đề phòng mai phục (@c0073)"},{"ten":"Lão nhân tổ gia gia điền trang","tag":"ho-hang","quanHe":"Ông chú (anh em ruột với tổ gia gia của Thạch Hạo); được Thạch Hạo tới thăm lúc hấp hối và thay ông gánh trách nhiệm chăm đứa bé thế mạng","ghiChu":"@c0074"},{"ten":"Đứa bé thế mạng","tag":"an-nhan","quanHe":"Đứa bé bệnh tật chân què từng được mấy lão nhân dùng để thế mạng cho Thạch Hạo; Thạch Hạo hứa chiếu cố và sẽ đưa tới Bổ Thiên Các","ghiChu":"@c0074"},{"ten":"Hải gia gia","tag":"an-nhan","quanHe":"Ân nhân che chở, được cậu cảnh báo trước đại họa Tây Cương","ghiChu":"@c0075"},{"ten":"Hải đại thúc","tag":"an-nhan","quanHe":"Con Hải gia gia, cùng phe che chở","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"khac","quanHe":"Đứa thế thân trùng tên năm xưa, ở thôn trang tổ địa bị đốt","ghiChu":"@c0075"},{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Cao thủ Vũ Tộc phe truy sát, dán bản mặt kẻ thù","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"ho-hang","quanHe":"Nhận làm đệ đệ, đưa về Thạch thôn dưỡng thương","ghiChu":"Bạn đồng hành thời nhỏ, được Thạch Hạo hứa dùng bảo dược chữa chân bị Độc Giao cắn","gap":"@c0077"},{"ten":"Xuyên Sơn Giáp (Tế Linh vàng kim)","tag":"doi-thu","quanHe":"Kẻ tử chiến","ghiChu":"Đại chiến mấy trăm chiêu, gây thương tổn cho nhau; nhóc tỳ bị Bảo Cụ vảy vàng kim bắn thủng người (@c0083)."},{"ten":"Đại thủ lĩnh hung khấu vùng man hoang","tag":"doi-thu","quanHe":"Kẻ theo dõi","ghiChu":"Cầm đầu đám hung khấu đứng xa quan sát, kinh hãi nghi nhóc tỳ là hậu đại hung thú Thái Cổ (@c0083)."},{"ten":"Tế Linh (Xuyên Sơn Giáp)","tag":"doi-thu","quanHe":"Kẻ đối đầu sinh tử","ghiChu":"Bị Thạch Hạo trọng thương rồi tự bại vong trong trận @c0084"},{"ten":"Hổ Nữu","tag":"khac","quanHe":"Được Thạch Lâm Hổ đề nghị đính hôn với cậu","ghiChu":"@c0086"},{"ten":"Người trung niên Sơ Thủy Địa","tag":"khac","quanHe":"Tu sĩ giải thích quy tắc thông đạo phù văn cho Thạch Hạo ở Sơ Thủy Địa","ghiChu":"@c0087"},{"ten":"Lão già Sơ Thủy Địa","tag":"khac","quanHe":"Tu sĩ ra giá đổi tinh bích lấy Phù Cốt nếu Thạch Hạo đào được","ghiChu":"@c0087"},{"ten":"Thải Loan","tag":"ban-be","quanHe":"Thiếu nữ hảo tâm ở Sơ Thủy Địa chỉ cách khắc kỷ lục và cảnh báo có kẻ nhắm bảo cốt","ghiChu":"@c0089"},{"ten":"Tinh Bích đại gia","tag":"khac","quanHe":"Ông lão râu tóc hoa râm đòi dùng tinh bích đổi bảo cốt, bị từ chối","ghiChu":"@c0089"},{"ten":"Chùy thúc","tag":"khac","quanHe":"Người trung niên cho mượn búa, mượn danh xin mua bảo cốt","ghiChu":"@c0089"},{"ten":"Điểu gia","tag":"khac","quanHe":"Ông lão có chim ngũ sắc trên vai, nhắc khắc kỷ lục và cảnh báo bảo cốt bị nhắm","ghiChu":"@c0089"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Tên đồng họ trên bảng kỷ lục Sơ Thủy Địa, gây chú ý cho Thạch Hạo","ghiChu":"@c0089"},{"ten":"Xích Phong","tag":"doi-thu","quanHe":"Bị nhóc tỳ một chưởng đánh nát phù văn, gãy xương nửa người, bị đoạt Bảo Phiến","ghiChu":"@c0090"},{"ten":"Xích Vân công tử","tag":"doi-thu","quanHe":"Chủ nhân Bảo Cụ Xích Vũ mà nhóc tỳ đoạt; anh của Xích Phong bị nhóc tỳ đánh trọng thương","ghiChu":"@c0090"},{"ten":"Xích Vân công tử","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Anh của thiếu niên bị Thạch Hạo bắt làm con tin ở Sơ Thủy Địa; thiếu niên này là người duy nhất từng tặng được Thạch Hạo một Bảo Cụ (@c0091)."},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối tượng phá kỷ lục","ghiChu":"Thạch Hạo tuyên bố sẽ phá từng kỷ lục của Thạch Nghị. @c0092"},{"ten":"Tinh Bích đại gia","tag":"dong-minh","quanHe":"Người hỗ trợ tìm ngọn núi kỷ lục","ghiChu":"Báo tin đã tìm được ngọn núi giữ kỷ lục Thạch Nghị cách mấy dặm. @c0092"},{"ten":"Chùy thúc","tag":"dong-minh","quanHe":"Nhóm hỗ trợ ở Sơ Thủy Địa","ghiChu":"Được Thạch Hạo gọi cùng để hỏi tìm ngọn núi. @c0092"},{"ten":"Điểu gia","tag":"dong-minh","quanHe":"Nhóm hỗ trợ ở Sơ Thủy Địa","ghiChu":"Được Thạch Hạo gọi cùng để hỏi tìm ngọn núi. @c0092"},{"ten":"Hạ U Vũ","tag":"an-nhan","quanHe":"Người tặng phù bài Bổ Thiên Các","ghiChu":"Cô gái áo trắng dẫn nhóm, thử thực lực Thạch Hạo rồi tặng phù bài cuối cùng @c0071"},{"ten":"Liễu Thần","tag":"su-mon","quanHe":"Người từng giảng cho cậu rằng đồ vật trong Hư Thần Giới đối ứng thế giới thực, đều có nguyên hình","ghiChu":"Được nhắc lại ở @c0088"},{"ten":"Tiểu Bạch","tag":"dong-minh","quanHe":"Độc Giác Thú do Thạch Hạo bắt sống và thuần phục, đặt tên, thành thú cưỡi lên đường tới Cổ quốc","ghiChu":"Hứa dạy Cốt Văn để nó hình thành nguyên thủy bảo cốt (@c0068)"},{"ten":"Tiểu Bạch","tag":"khac","quanHe":"Thú cưỡi (Độc Giác Thú) do Thạch Hạo bắt sống và thuần phục","ghiChu":"Đặt tên Tiểu Bạch, hứa dạy Cốt Văn để hình thành nguyên thủy bảo cốt @c0068"},{"ten":"Thanh Phong","tag":"dong-hanh","quanHe":"Bạn đồng hành rời Thạch thôn cùng đi Bổ Thiên Các","ghiChu":"Được nhóc tỳ đưa đi để tới Bổ Thiên Các"},{"ten":"Liễu Thần","tag":"su-mon","quanHe":"Sư trưởng bảo hộ, dặn dò tẩy lễ trước 12 tuổi","ghiChu":"Dùng thần lực đưa ý chí nhóc tỳ về Thạch thôn"},{"ten":"Mao cầu","tag":"dong-hanh","quanHe":"Linh vật nhỏ theo cùng lên đường","ghiChu":"Nhảy lên vai nhóc tỳ khi xuất phát"},{"ten":"Thanh Phong","tag":"dong-hanh","quanHe":"Bạn đồng hành cùng băng Đại Hoang tới Bổ Thiên Các","ghiChu":"Gọi Thạch Hạo là ca/tiểu ca ca, nài cùng vào Bổ Thiên Các"},{"ten":"Thanh Phong","tag":"dong-minh","quanHe":"Người từng được bảo vệ","ghiChu":"Nhóc tỳ từng bảo vệ khi xông pha Đại Hoang"},{"ten":"Hùng Phi","tag":"doi-thu","quanHe":"Trưởng lão truy tìm","ghiChu":"Xác định nhóc tỳ là thủ phạm phá trận, rơi lệ đầy mặt"},{"ten":"Trác Vân","tag":"doi-thu","quanHe":"Trưởng lão truy phạt","ghiChu":"Dọa đánh mông nhóc tỳ vì phá hỏng nơi thí luyện"},{"ten":"Nữ Chiến Thần Trục Lộc thư viện","tag":"su-mon","quanHe":"Người chiêu mộ","ghiChu":"Công khai chiêu mộ nhóc tỳ, nói cửa Trục Lộc thư viện luôn mở rộng với tiểu huynh đệ"},{"ten":"Nữ Chiến Thần Trục Lộc thư viện","tag":"khac","quanHe":"Chiến tướng Trục Lộc học viện đến chiến trường tìm nhóc tỳ","ghiChu":"Đứng ngoài quan sát, thực chất đến tìm Thạch Hạo @c0100"},{"ten":"Thanh Phong","tag":"dong-hanh","quanHe":"Từng cùng bị đuổi giết hai ngày hai đêm sau khi hái linh dược ở Đại Hoang","ghiChu":"Nhắc trong hồi ức @c0100"},{"ten":"Thanh Phong","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":"Nhường phù bài cho Thanh Phong vào thẳng sơn môn Bổ Thiên các"},{"ten":"Chu Yếm","tag":"dong-minh","quanHe":"Linh thú của Thạch Hạo (Bóng Lông)","ghiChu":"Cho biến lông xám trắng nguỵ trang"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Người chăm sóc","ghiChu":"Lão tộc trưởng nấu sữa thú nuôi chú nhóc mồ côi từ nhỏ."},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Người nhận nuôi","ghiChu":"Được Thạch Vân Phong nhận nuôi và làm đối tượng nghiên cứu cốt văn tốt nhất"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Lão tộc trưởng nấu sữa thú nuôi dưỡng chú nhóc.","ghiChu":"Chăm sóc chú nhóc mồ côi tại nhà mình ở đầu thôn."},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Lão tộc trưởng nuôi dưỡng","ghiChu":"Nấu sữa bách thú trộn dược thảo nuôi chú nhóc mồ côi"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Lão tộc trưởng nuôi nấng, nấu sữa bách thú chăm sóc","ghiChu":"Cha mẹ chú nhóc đã mất từ khi nó nửa tuổi"},{"ten":"Thạch Vân Phong","tag":"ho-hang","quanHe":"Cha nuôi","ghiChu":"Được Thạch Vân Phong nhận nuôi và chọn làm đối tượng nghiên cứu cốt văn tốt nhất."},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Lão tộc trưởng nấu sữa thú trộn dược thảo nuôi nấng","ghiChu":"Chăm bẵm đứa trẻ mồ côi từ nửa tuổi."},{"ten":"Thạch Vân Phong","tag":"ho-hang","quanHe":"Được tộc trưởng nhận nuôi và lấy làm đối tượng nghiên cứu cốt văn","ghiChu":"@c0002"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Giao Bằng trở mặt muốn động thủ với thôn và định bắn ba con chim non của nhóc tỳ, khiến nhóc tỳ nổi giận ngăn cản (@c0036)."},{"ten":"Ông lão Vân Thiên Cung","tag":"an-nhan","quanHe":"Người can thiệp","ghiChu":"Lão giả Vân Thiên Cung đứng ra can Giao Bằng, làm dịu tình thế căng thẳng với thôn (@c0036)."},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Được tộc trưởng chăm sóc, chế tắm thuốc và bảo dược đặc biệt","ghiChu":"Thạch Vân Phong có chủ đích bồi dưỡng nhóc tỳ lâu dài"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Người chăm sóc, nấu bảo dược riêng và bế nó khi ngủ say","ghiChu":"Tộc trưởng dành cho nó sự chăm sóc đặc biệt hơn hẳn lũ trẻ khác"},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Đàn anh cùng thôn, cùng thi thố sức lực.","ghiChu":"Cùng dự cuộc nâng đỉnh @c0005"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Thiếu niên cùng thôn, người nâng đỉnh thành công trước Thạch Hạo.","ghiChu":"@c0005"},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Đàn anh cùng thôn cùng dự thi thố.","ghiChu":"@c0005"},{"ten":"Thạch Lâm Hổ","tag":"an-nhan","quanHe":"Thủ lĩnh đội săn tặng Thạch Hạo túi Tương Quả","ghiChu":"@c0006"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Thủ lĩnh đoàn trẻ Thạch Thôn, cùng trèo vách","ghiChu":""},{"ten":"Thạch Trung Hầu","tag":"ban-be","quanHe":"Bạn trong đoàn, dẫn đường tới rừng đá","ghiChu":""},{"ten":"Thạch Mãnh","tag":"ban-be","quanHe":"Bạn trong đoàn, sức đứng sau Thạch Hạo và Đại Tráng","ghiChu":""},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn đi trộm trứng"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn đi trộm trứng"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm trẻ Thạch Thôn đi trộm trứng"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng trốn hung cầm trong thạch động","ghiChu":"Cùng đám nhóc Thạch Thôn né Thanh Lân Ưng"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng ném thiết mâu vào mắt hung cầm","ghiChu":"Một trong ba đứa khỏe nhất"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng câu giờ chống hung cầm","ghiChu":"Đề xuất chọc giận hung cầm tạo động tĩnh"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Chim non thân thiết nhất","ghiChu":"Tử Vân linh tính nhất trong ba chim, cực thân với Thạch Hạo."},{"ten":"Thạch Phúc","tag":"an-nhan","quanHe":"A Phúc thúc thường hái quả mọng cho nhóc tỳ","ghiChu":"Nhóc tỳ an ủi khi A Phúc thúc bị thương."},{"ten":"Thiếu niên Bái Thôn","tag":"doi-thu","quanHe":"Địch thủ đối đầu","ghiChu":"Bị thiếu niên Bái Thôn bắn tên nhắm giết, nhóc tỳ chém hất mũi tên rồi lao tới tấn công y."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ giao đấu","ghiChu":"Thiếu niên Bái Thôn đấu tay đôi với Thạch Hạo, bị nó đánh bại phun máu."},{"ten":"Thạch Phi Giao","tag":"dong-minh","quanHe":"Người cùng Thạch Thôn","ghiChu":"Mắng Bái Phong ác độc khi hắn giở chiêu bẩn với Thạch Hạo."},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Đối thủ bị hạ gục và bắt sống","ghiChu":"Đá gục và bắt Bái Phong tại chiến trận ranh giới hai thôn."},{"ten":"Thanh Lân Ưng","tag":"dong-hanh","quanHe":"Cùng cưỡi ra trận tranh đoạt bảo thể Toan Nghê, phối hợp chiến đấu chống đàn cự thú","ghiChu":"@c0019"},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Hung cầm được Thạch Hạo cứu chữa, ánh mắt nhu hòa như đối con mình","ghiChu":"@c0022"},{"ten":"Thủ lĩnh đội săn thú Bái Thôn","tag":"doi-thu","quanHe":"Kẻ cầm đầu phục kích, bị Thạch Hạo chém rách bụng","ghiChu":"@c0022"},{"ten":"Bái Lý Thanh","tag":"doi-thu","quanHe":"Kẻ thù, tộc trưởng Bái Thôn mưu cướp bảo thể và giết mình","ghiChu":"@c0023"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Đối thủ, bắn lén xuyên tay","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ thù cũ, tập kích bằng Bảo Cụ","ghiChu":"@c0023"},{"ten":"Thanh Lân Ưng","tag":"dong-minh","quanHe":"Hung cầm được nhóc liều mình thủ hộ","ghiChu":"@c0023"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ địch bị nhóc tỳ đánh bại, tàn phế và cướp Bảo cụ","ghiChu":"Đối đầu trận chiến chương 24"},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Đồng tộc Thạch Thôn","ghiChu":"Được Thạch Lâm Hổ ném lên trời để triệu Bệ Ngạn (@c0026)"},{"ten":"Thạch Phi Giao","tag":"ho-hang","quanHe":"Đồng tộc Thạch Thôn","ghiChu":"Nhận Tổ Khí da thú vốn Thạch Phi Giao giữ vì Cốt Văn cao hơn (@c0026)"},{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Thủ lĩnh đội săn Bái Thôn bắn lén Thạch Hạo, bị Thạch Hạo chém chết."},{"ten":"A Văn thúc","tag":"su-mon","quanHe":"Người cùng thôn","ghiChu":"Người Thạch Thôn bị Bái Sơn bắn xuyên lồng ngực; Thạch Hạo nhớ đến mà quyết giết Bái Sơn."},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Được tộc trưởng truyền dạy Cốt văn, hứa hái bảo dược chữa ám thương cho lão","ghiChu":"@c0029"},{"ten":"Thanh Lân Ưng","tag":"khac","quanHe":"Hung cầm dì của nhóc tỳ","ghiChu":"Bị thương trong tranh đoạt bảo thể Toan Nghê, hồi phục rồi rời đi tìm chỗ bế quan đột phá (@c0033)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Giao Bằng trở mặt định bắt ba con chim non của Nhóc tỳ, cậu ngăn cản và bảo vệ."},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Người can ngăn","ghiChu":"Lão giả Vân Thiên Cung đứng ra can Giao Bằng trong lúc căng thẳng."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Kẻ khai chiến bắn ba con chim non, bị Thạch Hạo đánh bay vỡ nát gan bàn tay","ghiChu":"@c0037"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Cùng săn đuổi chim non, bị Thạch Hạo đá đỉnh đồng đánh gãy cung","ghiChu":"@c0037"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Cùng săn đuổi ba con chim non","ghiChu":"@c0037"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Được Thạch Hạo mời làm trọng tài phân xử trận đấu","ghiChu":"@c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ La Phù Đại Trạch bị Thạch Hạo đánh bại thê thảm, tra tấn bằng cối xay","ghiChu":"@c0039"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Thiên tài Lôi Tộc bị Thạch Hạo đánh bay, nuốt Lôi Cầm","ghiChu":"@c0039"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Thiên tài Tử Sơn Tộc bị Thạch Hạo áp chế, đạp phun máu","ghiChu":"@c0039"},{"ten":"Giao Thương","tag":"doi-thu","quanHe":"Cường giả La Phù Đại Trạch đòi bảo cốt Toan Nghê","ghiChu":"@c0039"},{"ten":"Tiểu Hồng","tag":"khac","quanHe":"Sinh linh chí cường mà nhóc tỳ dỗ bình tĩnh, đặt tên Tiểu Hồng","ghiChu":"Tước đỏ như lửa tới Thạch Thôn nhờ Liễu Thần trị thương"},{"ten":"Cha mẹ nhóc tỳ","tag":"cha-me","quanHe":"Cha mẹ từ cổ quốc mang nhóc tỳ về tổ địa Thạch Thôn","ghiChu":"Người thân đã thành toàn tiểu ca ca"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Lão tộc trưởng kể lại thân thế cha mẹ, cổ vũ tự cường","ghiChu":"@c0052"},{"ten":"Cha mẹ Thạch Hạo","tag":"cha-me","quanHe":"Cha mẹ ruột, rời thôn đi tìm Thánh dược trị bệnh cho nó","ghiChu":"@c0052"},{"ten":"Chu Yếm (quả cầu vàng)","tag":"khac","quanHe":"Cứu, cho ăn và thu nhận sinh linh Chu Yếm về Thạch Thôn","ghiChu":"@c0053"},{"ten":"Chu Yếm","tag":"dong-minh","quanHe":"Sinh vật Thạch Hạo đặt tên (Tiểu Chu / Mao Cầu)","ghiChu":"Thạch Hạo đặt tên cho quả cầu vàng, nhận ra nó là Di Chủng Thái Cổ mất trí nhớ."},{"ten":"Tử Vân","tag":"dong-hanh","quanHe":"Thanh Lân Ưng bé út thân nhất, được Thạch Hạo dạy cốt văn","ghiChu":"@c0012"},{"ten":"Đại Bằng","tag":"dong-hanh","quanHe":"Thanh Lân Ưng lão đại do Thạch Hạo nuôi dạy","ghiChu":"@c0012"},{"ten":"Tiểu Thanh","tag":"dong-hanh","quanHe":"Thanh Lân Ưng lão nhị do Thạch Hạo nuôi dạy","ghiChu":"@c0012"},{"ten":"Hổ Nữu","tag":"the-thiep","quanHe":"Con gái chú Hổ, được tộc nhân nhắc chuyện đính ước với nhóc tỳ","ghiChu":"@c0033"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Được nhóc tỳ nhờ làm trọng tài chủ trì công đạo cho cuộc quyết đấu.","ghiChu":"@c0038"},{"ten":"Tử Vân","tag":"linh-thu","quanHe":"Thanh Lân Ưng thân thiết nhất, học cốt văn hăng say","ghiChu":"@c0012"},{"ten":"Hổ Nữu","tag":"the-thiep","quanHe":"Được đề cập đính ước với nhóc tỳ","ghiChu":"Con gái chú Hổ (@c0033)"},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Người trong Thạch thôn nuôi dưỡng, hô nhóc tỳ lớn lên phải săn Chân Hống cho hắn","ghiChu":"@c0032"},{"ten":"Đôi tỷ muội sinh đôi","tag":"khac","quanHe":"hai thiếu nữ quan chiến khen Thạch Hạo là em bé sứ","ghiChu":"@c0038"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Trọng tài do Thạch Hạo mời","ghiChu":"Thạch Hạo mời ông lão cầm lông tuyết làm trọng tài chủ trì công đạo (@c0038)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ quyết đấu","ghiChu":"Thạch Hạo đánh xuyên Cốt Văn và đập cối xay vào đầu Giao Bằng (@c0038)."},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Thạch Hạo đá văng Tử Sơn Côn lên trời (@c0038)."},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Thạch Hạo trọng thương Lôi Minh Viễn (@c0038)."},{"ten":"Thạch Lâm Hổ","tag":"ho-hang","quanHe":"Trưởng bối trong thôn, ước hẹn nhóc tỳ săn Chân Hống cho mình khi trưởng thành","ghiChu":"@c0032"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Nhờ làm trọng tài quyết đấu","ghiChu":"Thạch Hạo nhờ ông lão cầm lông tuyết chủ trì công đạo @c0038"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Được nhóc tỳ mời làm trọng tài phân thắng bại vì còn giữ gìn công đạo","ghiChu":"Mời làm trọng tài trong quyết đấu Bảo Thuật (@c0038)"},{"ten":"Đôi tỷ muội sinh đôi","tag":"khac","quanHe":"Hai thiếu nữ thiên tài quan chiến, trầm trồ khi thấy nhóc tỳ lợi hại","ghiChu":"Quan chiến trận quyết đấu (@c0038)"},{"ten":"Thạch Lâm Hổ","tag":"khac","quanHe":"Người thôn Thạch thôn","ghiChu":"Đổ chân huyết vào đỉnh, hẹn nhóc tỳ lớn lên săn Chân Hống cho mình."},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Tộc trưởng chủ trì tẩy lễ cho nhóc tỳ","ghiChu":"Ngăn không cho can thiệp đỉnh, quyết định thêm chân huyết Thái cổ. @c0032"},{"ten":"Thạch Lâm Hổ","tag":"su-mon","quanHe":"Người thôn đổ chân huyết Thái cổ giúp nhóc tỳ lột xác","ghiChu":"Hét bảo nhóc tỳ tương lai phải săn Chân Hống cho lão. @c0032"},{"ten":"Thạch Phi Giao","tag":"khac","quanHe":"Người thôn, suýt bị nhóc tỳ đẩy ngã khi thử sức","ghiChu":"Kinh ngạc về thần lực nhóc tỳ dù tay hắn có lực năm sáu nghìn cân. @c0032"},{"ten":"Thạch Phúc","tag":"khac","quanHe":"Thúc thường hái quả mọng cho mình","ghiChu":"An ủi khi A Phúc bị thương @c0013"},{"ten":"Thạch Thủ Sơn","tag":"khac","quanHe":"Trưởng bối cùng thôn, đi thăm khi bị thương","ghiChu":"Mang rổ quả mọng đỏ đến thăm @c0013"},{"ten":"Bái Phong","tag":"doi-thu","quanHe":"Kẻ bị đá bay","ghiChu":"Đá Bái Phong bay tới trước người Thạch thôn @c0025"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Cường giả La Phù Đại Trạch trở mặt, định động thủ với người thôn và chim non","ghiChu":"@c0036"},{"ten":"Ông lão Vân Thiên Cung","tag":"an-nhan","quanHe":"Đứng ra can Giao Bằng khi cường giả muốn động thủ","ghiChu":"@c0036"},{"ten":"Giao Thương","tag":"doi-thu","quanHe":"Cường giả La Phù đòi bảo cốt","ghiChu":"Đòi Thạch Thôn giao bảo cốt Toan Nghê và ba chim non @c0039"},{"ten":"Ông lão Vân Thiên Cung","tag":"khac","quanHe":"Cường giả muốn chiêu mộ","ghiChu":"Nhiều lần tán thưởng thiên phú của nhóc tỳ @c0039"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Thần linh Thạch Thôn nhóc tỳ cầu khấn","ghiChu":"Hiển linh cành liễu non cứu làng, đâm chết Phi Giao @c0039"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn nhỏ cùng thôn, cùng bị Giao Bằng mắng ‘thùng rỗng kêu to’","ghiChu":"@c0036"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ giao chiến","ghiChu":"Đánh bay Giao Bằng làm vỡ nát gan bàn tay khi Giao Bằng săn ba con chim non (@c0037)."},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ trong quyết đấu bảo thuật, bị nhóc tỳ đánh bại","ghiChu":"@c0038"},{"ten":"Tử Sơn Côn","tag":"doi-thu","quanHe":"Đối thủ trong quyết đấu, Hỏa Lân bị Ma Cầm diệt","ghiChu":"@c0038"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đối thủ khai chiến bắn ba con chim non, bị Thạch Hạo đánh bay vỡ gan bàn tay","ghiChu":"@c0037"},{"ten":"Lôi Minh Viễn","tag":"doi-thu","quanHe":"Thiên tài Lôi Tộc cùng săn đuổi ba con chim non","ghiChu":"@c0037"},{"ten":"Giao Bằng","tag":"doi-thu","quanHe":"Đánh bay Giao Bằng một chưởng","ghiChu":""},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Người hướng dẫn Nhóc tỳ tu Cốt văn và chuẩn bị lột xác","ghiChu":"@c0028"},{"ten":"Thạch Vân Phong","tag":"su-mon","quanHe":"Lão tộc trưởng Thạch thôn, chỉ đạo toàn bộ tẩy lễ và quyết định thêm chân huyết ba Di chủng cho nhóc tỳ.","ghiChu":"@c0032"},{"ten":"Thạch Lâm Hổ","tag":"an-nhan","quanHe":"Đổ chân huyết sừng Bò ma Ly Hỏa và cánh tay Vượn Ác ma vào đỉnh giúp nhóc tỳ hoàn tất tẩy lễ; đùa nhóc tỳ sau này săn một con Chân Hống cho hắn.","ghiChu":"@c0032"},{"ten":"Thạch Phi Giao","tag":"khac","quanHe":"Suýt bị nhóc tỳ đẩy ngã khi thử thần lực sau lột xác, chấn động trước sức mạnh đứa nhỏ.","ghiChu":"@c0032"}],"tuiDo":{"congPhap":[{"ten":"Bí Cốt Bảo Thư","moTa":"Bảo phù nguyên thủy lĩnh ngộ từ phù văn của Thanh Lân Ưng, phóng được vầng trăng bạc chém đá","nguon":"@c0012"}]}},"nguon":["@c0012","@c0032","@c0005","@c0006","@c0007","@c0008","@c0009","@c0010","@c0014","@c0015","@c0016","@c0017","@c0018","@c0019","@c0020","@c0021","@c0022","@c0023","@c0024","@c0026","@c0027","@c0029","@c0030","@c0031","@c0033","@c0034","@c0035","@c0037","@c0038","@c0043","@c0047","@c0050","@c0051","@c0052","@c0053","@c0054","@c0025","@c0028","@c0036","@c0039","@c0055","@c0057","@c0058","@c0059","@c0062","@c0063","@c0064","@c0056","@c0061","@c0065","@c0066","@c0067","@c0068","@c0069","@c0070","@c0072","@c0073","@c0074","@c0075","@c0077","@c0078","@c0080","@c0081","@c0082","@c0083","@c0084","@c0085","@c0086","@c0087","@c0089","@c0090","@c0091","@c0092","@c0071","@c0088","@c0095","@c0096","@c0098","@c0099","@c0100","@c0097","@c0001","@c0002","@c0004","@c0013"],"aliases":["Nhóc tỳ","Tiểu Hạo Hạo","Tiểu Thạch Hạo","Hạo Hạo","Tiểu Thạch Hạo Hạo","bé Hạo","Hạo Nhi","Tiểu Hạo","chú nhóc","nhóc thò lò mũi xanh","nhóc thò lò","Thích Nhất Uống Sữa Thú","tiểu ca ca","đứa trẻ năm đó","Tên nhân loại","tiểu tử","Nhóc siêu quậy","Hạo Thiên","thằng nhóc quậy","thằng nhóc kỳ hoa","Thằng mập mặt trái táo","Tinh Bích đại gia","Thằng quỷ nhỏ","Hùng hài tử","Tiểu tặc","Nãi oa","Thằng nhóc siêu quậy","Chú nhóc (chưa đặt tên)","Nhị Mãnh","Nhị Mãnh (biệt danh của Thạch Mãnh)","Bì Hầu (biệt danh của Thạch Trung Hầu)","A Man","Tiêu Thiên (thiếu niên áo bào màu bạc)","Hoang","Tội","Hoang Thiên Đế","Thạch Hoàng","Đứa trẻ mồ côi","Đứa trẻ mồ côi Thạch Thôn","Chú nhóc Thạch Thôn","Tử Vân di cầm","Thạch Hạo","chú bé","Tiểu Hồng (gọi tước đỏ)","em bé sứ","Thạch Hạo lúc nhỏ","Bé Hồng","chim tước đỏ như Chu Tước","chim sẻ đỏ rực","#chu-nhoc-than-thon"],"vaiTro":"Nhân vật chính — thiên tài trời sinh Chí Tôn cốt của Thạch Thôn","tinhCach":"Ngoan cường bất khuất, khổ tu không sờn dù mất Chí Tôn cốt vẫn tái sinh vươn lên; thông tuệ nhạy bén, tinh thông cốt văn từ khi chưa đầy bốn tuổi; trọng tình nghĩa, liều nhục thân che chở người thân và bằng hữu; gan dạ hiếu chiến, dám đơn độc đối đầu cường địch và Thái Cổ di chủng","blurb":"Thạch Hạo là đứa trẻ trời sinh Nguyên thủy bảo cốt (Chí Tôn cốt) của Thạch Thôn, từ ba tuổi rưỡi đã có thần lực áp đảo và tinh thông cốt văn. Sau khi bị Lục tẩu cùng Thạch Nghị moi mất Chí Tôn cốt và rơi vào cửa tử, cậu dựa vào Nguyên Thủy Chân Giải tái sinh, khổ tu từ Bàn Huyết cảnh lên Động Thiên cảnh rồi rời Thạch Thôn vượt Đại Hoang tới Cổ quốc gia nhập Bổ Thiên các. Đến chương mới nhất, cậu đã mở tới Động Thiên thứ tám, khí tức Chí Tôn cốt tái sinh, một mình đại chiến nhiều Thái Cổ di chủng, thu phục Sư Tử chín đầu cùng Đại Hồng Điểu và giành được Bất Lão Tuyền."},{"id":"thanh-lan-ung","name":"Thanh Lân Ưng","cn":"","aliases":["Thanh đại thẩm","Thanh Lân Ưng đại thẩm","dì Thanh","Đại thẩm"],"gioiTinh":"nữ","theLuc":[],"trangThai":"song","blurb":"Thanh Lân Ưng là hung cầm màu xanh sải cánh mười lăm mét, hậu duệ Thái Cổ Ma Cầm và là chiến lực chủ lực mang Thạch Hạo lao vào dãy núi tranh đoạt di thể Toan Nghê. Sau khi trúng độc nặng và bị Bái Lý Thanh cho quân bắn trọng thương, nó nhờ ăn thịt Toan Nghê mà lột xác, cánh xanh hóa thành cánh bạc và khí tức cường thịnh hơn. Tính tới chương mới nhất trong hồ sơ, nó hồi phục hoàn toàn, rời đi bế quan chuẩn bị đột phá và tiếp tục chở Thạch Hạo dò xét cương thổ theo lệnh Thạch Lâm Hổ.","vaiTro":"Hung cầm đồng hành của Thạch Hạo — kẻ săn mồi đỉnh cấp khu ngoại vi","tabs":{"diem":[{"text":"Hậu duệ Thái Cổ Ma Cầm, thân dài bảy tám mét, sải cánh mười lăm mét, phủ vảy xanh kim loại","chuong":"@c0008"},{"text":"Chủ động diệt các con mạnh nhất trong loạn chiến, dùng vầng trăng xanh chém đôi hung thú","chuong":"@c0020"},{"text":"Trúng độc nặng rồi bị Bái Lý Thanh cho bắn hàng chục mũi tên máu để trói chân Thạch Hạo","chuong":"@c0023"},{"text":"Lột xác nhờ ăn thịt Toan Nghê: cánh xanh hóa thành cánh bạc, khí tức cường thịnh hơn","chuong":"@c0047"},{"text":"Hồi phục hoàn toàn, rời đi tìm chỗ bế quan chuẩn bị đột phá cảnh giới","chuong":"@c0033"},{"text":"Chở Thạch Hạo dò xét theo lệnh Thạch Lâm Hổ, phát hiện cương thổ trăm ngàn dặm bị hủy diệt","chuong":"@c0052"}],"kinhLich":[{"text":"Con hung cầm dài bảy tám mét, sải cánh mười lăm mét, toàn thân phủ vảy xanh kim loại, mỏ móc câu đen dài già nửa mét, móng vuốt gần mét, đầu có gai như sừng. Về tổ phát hiện mất ba quả trứng, nó nổi điên, kêu tiếng chói tai xuyên kim phá đá rồi lao xuống phá tan cả một khoảng rừng, đại thụ mười mấy người ôm đổ rạp; nhờ phiến đá núi cản trở lũ trẻ mới không mất mạng, nó bay lên lượn vòng chuẩn bị nhào xuống lần nữa.","anchor":"con Thanh Lân Ưng đó đã quay lại, chắc chắn đã phát hiện ra trứng bị mất, nó nổi điên rồi","bridge":true,"khoang":"@c0008"},{"text":"Khi Thạch Lâm Hổ tế Tổ Khí, mỏ Thanh Lân Ưng phát hào quang lộ ký hiệu huyệt mạch truyền thừa; luồng uy áp như vua vạn thú khiến nó chấn động bay lên xa.; Thanh Lân Ưng (thân dài 7-8 mét, sải cánh 15 mét) truy sát đám nhóc vào thạch động, cào xé nham thạch chui vào. Đá và tên cung sừng rồng chỉ tóe lửa trên vẩy nó, nhưng thiết mâu của Thạch Hạo làm bong một miếng vẩy khóe mắt khiến nó phát điên.; Thanh Lân Ưng truy sát đám nhóc Thạch Thôn vào tậ…","anchor":"như thể vua của vạn thú sống lại khiến cho con hung cầm ở trên không chấn động","bridge":true,"khoang":"@c0009"},{"text":"Hậu duệ Thái Cổ ma cầm Thanh Lân Ưng bị uy áp hai món Tổ Khí làm bụi gai dây leo đại thụ tan nát, kinh hãi không dám lao xuống. Nó bám theo đoàn Thạch Thôn tới gần thôn nhưng trông thấy gốc liễu già thì giật mình không dám xâm nhập, chỉ bay lượn phẫn nộ hú vang đứng canh trên đá.","anchor":"trông thấy gốc liễu già nó mới giật mình thảng thốt không dám xâm nhập","bridge":true,"khoang":"@c0010"},{"text":"Là hậu duệ Thái Cổ Ma Cầm, Thanh Lân Ưng quắp đuôi Xuyên Sơn Giáp thả từ trên trời cho vỡ thành bãi máu, nhổ vầng trăng xanh (Nguyên Thủy Bảo Thuật) chém đứt đầu Quỳ Thú, xé xác năm sáu con mãnh cầm bằng sức cơ thể.; Là hậu duệ Thái Cổ Ma Cầm, quắp giết Xuyên Sơn Giáp, nhổ vầng trăng xanh chém đứt đầu Quỳ Thú, nhưng bị Tử Kim Xà cắn nát vảy trúng độc và Huyết Điêu cào một lỗ dài ở cổ.; Bị Tử Kim Xà bắn tử quang cắn nát vảy làm trúng độc chảy máu…","anchor":"trực tiếp chặt đứt đầu của con Quỳ Thú đó, máu tươi bắn cao mười mấy mét","bridge":true,"khoang":"@c0019"},{"text":"Thanh Lân Ưng bay lên dùng vầng trăng xanh chém hung thú làm đôi, chủ động diệt các con mạnh nhất trong cuộc tranh đoạt xác Toan Nghê. Bị Thử Vương nhảy lên lưng cào ra mấy cân thịt, phá vảy xanh; sau đó phối hợp ký hiệu nguyên thủy giúp trọng thương Thử Vương. Khi Ác Ma Viên hàng lâm với hung uy ngập trời, Thanh Lân Ưng bỗng khiếp sợ mang Thạch Hạo bỏ chạy.","anchor":"giống như Cái Thế Ma Vương hàng lâm, phát ra hung uy ngập trời","bridge":true,"khoang":"@c0020"},{"text":"Trên tầng mây, Thanh Lân Ưng kinh hãi khi thấy Toan Nghê không chết mà sống lại, chứng kiến trận đại chiến ba con Thái Cổ Di Chủng rung động Đại Hoang.; Sau khi Toan Nghê chết thật, Thanh Lân Ưng xuống xác nhận rồi tha về cánh tay Ác Ma Viên chứa chân huyết hiếm. Nó lảo đảo suýt rơi vì trúng độc Tử Kim Xà từ trận trước, lại từng bị Huyết Điêu và Thử Vương đánh lén nên độc phát nhanh, phải gắng gượng quắp xác Toan Nghê cùng các bảo vật bay về Thạ…","anchor":"Trong tầng mây, Thanh Lân Ưng r","bridge":true,"khoang":"@c0021"},{"text":"Do trọng thương chảy máu đen không ngừng, Thanh Lân Ưng kiệt sức lướt xuống chứ không rơi thẳng, đụng gãy nhiều cổ mộc; Bảo thể Toan Nghê rơi trước đụng vỡ đá lớn.; Trọng thương chảy máu đen hôi thối không ngừng, kiệt sức lướt xuống đụng gãy nhiều cổ mộc, bảo thể Toan Nghê rơi trước. Sau được Thạch Hạo cho ăn bảo huyết, ánh mắt hung cầm lộ vẻ nhu hòa yên bình dù bị cắm mâu sắt và mấy mũi tên.; Được Thạch Hạo cho ăn thịt dính bảo huyết trong sừng…","anchor":"cuối cùng thì Thanh Lân Ưng cũng đã kiệt sức rồi","bridge":true,"khoang":"@c0022"},{"text":"Đang trúng độc nặng thì bị Bái Lý Thanh ra lệnh bắn trước để trói chân Thạch Hạo, trúng hàng chục mũi tên máu chảy như suối, gần chết; về sau được Thạch Vân Phong đổ đan giải độc cứu sống.; Đang trúng độc nặng, Thanh Lân Ưng bị Bái Thôn nhắm bắn để trói chân Thạch Hạo, dính hàng chục mũi tên máu chảy như suối, gần chết trước khi Thạch Vân Phong đổ đan giải độc cứu sống.","anchor":"Bắn tên, trước tiên giết con Thanh Lân Ưng kia đã!","bridge":true,"khoang":"@c0023"},{"importance":"major","chuong":"@c0047","tieuDe":"Lột xác cánh xanh hóa cánh bạc","text":"Sau khi ăn thịt Toan Nghê, Thanh Lân Ưng lột xác biến hóa, cánh xanh hóa thành cánh bạc, khí tức cường thịnh hơn nhiều; nó bay về Thạch thôn tránh đại họa, được ba con chim non Đại Bằng, Tiểu Thanh, Tử Vân mừng rỡ nhào tới cọ đầu, được người thôn và nhóc tỳ khuyên ở lại trong thôn tránh nạn.; Hậu duệ ma cầm Thái cổ, sau khi ăn thịt Toan Nghê thì lột xác — cánh xanh hóa thành cánh bạc, khí tức cường thịnh hơn nhiều; nó bay về Thạch thôn tránh họa…","anchor":"sau khi ăn thịt Toan Nghê nó đã được lột xác"},{"text":"Chở Thạch Hạo đi dò xét theo lệnh Thạch Lâm Hổ, phát hiện vùng cương thổ trăm ngàn dặm bị hủy diệt; cảm ngộ chiến ý từ vết tích chiến trường.","anchor":"Cương vực một trăm ngàn dặm đã thành một vùng tử địa","bridge":true,"khoang":"@c0052"}],"tuViMoc":[{"chuong":"@c0047","canhGioi":"Lột xác cánh bạc","text":"Nhờ ăn thịt Toan Nghê, Thanh Lân Ưng lột xác, cánh xanh hóa cánh bạc, thực lực tăng vọt.","importance":"major"},{"chuong":"@c0033","canhGioi":"Chuẩn bị đột phá","text":"Hồi phục hoàn toàn, rời đi tìm chỗ bế quan để đột phá cảnh giới mới.","importance":"normal"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Chở Thạch Hạo ra trận tranh đoạt, cùng nhau chiến đấu và che chở lẫn nhau","ghiChu":"Thạch Hạo dùng trăng bạc giữ lưng cho nó, gặp @c0019"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Mang Thạch Hạo trên lưng, cùng đối phó hung thú","ghiChu":"@c0020"},{"ten":"Thử Vương","tag":"doi-thu","quanHe":"Bị Thử Vương cào phá vảy xanh trên lưng","ghiChu":"@c0020"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Ân nhân cứu chữa, cho ăn bảo huyết giải độc","ghiChu":"@c0022"},{"ten":"Đại Bằng","tag":"dong-minh","quanHe":"Chim non trong Thạch thôn mừng rỡ nhào tới khi Thanh Lân Ưng bay về.","ghiChu":"@c0047"},{"ten":"Tiểu Thanh","tag":"dong-minh","quanHe":"Chim non trong Thạch thôn nhào tới cọ đầu khi Thanh Lân Ưng về thôn.","ghiChu":"@c0047"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Chim non trong Thạch thôn mừng rỡ đón Thanh Lân Ưng.","ghiChu":"@c0047"},{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Nhận ra Thanh Lân Ưng đã biến hóa cánh bạc, khuyên nó ở lại trốn trong thôn tránh nạn.","ghiChu":"@c0047"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Được Thạch Hạo cứu chữa","ghiChu":"Ánh mắt nhu hòa như đối con mình khi được nhóc tỳ đút bảo huyết. @c0022"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Được Thạch Hạo tử thủ bảo vệ khi trúng độc","ghiChu":"@c0023"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Được Thạch Vân Phong đổ đan giải độc cứu mạng","ghiChu":"@c0023"},{"ten":"Con Bái dữ","tag":"doi-thu","quanHe":"Phóng trăng xanh đánh nát chân sau con Bái","ghiChu":"@c0026"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo ném thiết mâu làm thương mắt","ghiChu":"@c0009"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Cưu mang nhóc tỳ, cùng thu hoạch bảo vật và bay về thôn","ghiChu":"@c0021"},{"ten":"Thạch Vân Phong","tag":"an-nhan","quanHe":"Đổ đan giải độc cứu Thanh Lân Ưng","ghiChu":"@c0023"},{"ten":"Đại Bằng","tag":"dong-minh","quanHe":"Chim non thân thiết","ghiChu":"Mừng rỡ nhào tới cọ đầu khi Thanh Lân Ưng về thôn"},{"ten":"Tiểu Thanh","tag":"dong-minh","quanHe":"Chim non thân thiết"},{"ten":"Tử Vân","tag":"dong-minh","quanHe":"Chim non thân thiết"},{"ten":"Đại Bằng","tag":"dong-hanh","quanHe":"Chim non thân cận","ghiChu":"Mừng rỡ nhào tới cọ đầu khi Thanh Lân Ưng về thôn (@c0047)"},{"ten":"Tiểu Thanh","tag":"dong-hanh","quanHe":"Chim non thân cận","ghiChu":"Mừng rỡ đón khi Thanh Lân Ưng về thôn (@c0047)"},{"ten":"Tử Vân","tag":"dong-hanh","quanHe":"Chim non thân cận","ghiChu":"Mừng rỡ đón khi Thanh Lân Ưng về thôn (@c0047)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Vầng trăng màu xanh","loai":"Nguyên Thủy Bảo Thuật","moTa":"Trăng xanh đường kính hơn hai mét do Thanh Lân Ưng nhổ ra, sắc bén chém đứt đầu Quỳ Thú và đuổi chém Tử Kim Xà.","nguon":"@c0019"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0019","@c0020","@c0021","@c0022","@c0033","@c0047","@c0008","@c0009","@c0023","@c0026","@c0010","@c0052"],"tinhCach":"Hung hãn, chủ động diệt kẻ mạnh nhất trong loạn chiến; kiên cường bám trụ dù trọng thương; trung thành phục tùng mệnh lệnh của tộc Thạch"},{"id":"ly-hoa-nguu-ma","name":"Ly Hỏa Ngưu Ma","gioiTinh":"khong-ro","aliases":["Bò ma Ly Hỏa","Ly Hoa Ngưu Ma"],"trangThai":"song","blurb":"Trâu đỏ khổng lồ cao mười mấy mét, dài ba mươi mét, bốn móng đạp lửa; từng được nhắc trong truyền thuyết của tộc trưởng Thạch Vân Phong.","vaiTro":"Hung thú cổ xưa xuất hiện giằng co với Vượn Ác Ma tranh đoạt xác Toan Nghê.","tabs":{"diem":[{"text":"Thần uy từng kinh động Đại Hoang, tồn tại lâu đời trong truyền thuyết","chuong":"@c0020"}],"kinhLich":[{"text":"Con trâu đỏ khổng lồ bốn móng đạp lửa xông đến giằng co với Vượn Ác Ma. Tộc trưởng Thạch Vân Phong từng nghe người già kể về Hỏa Ngưu sâu trong dãy núi. Trong trận, Ly Hỏa Ngưu Ma bị con Toan Nghê tưởng đã chết bật dậy đánh gãy sừng.","anchor":"Đây lẽ nào chính là Ly Hỏa Ngưu Ma mà tộc trưởng gia gia từng kể?","bridge":true,"khoang":"@c0020"},{"text":"Bị Toan Nghê bắn hai chùm ánh sáng phá vỡ ký hiệu trên người, Ly Hỏa Ngưu Ma phun hào quang đốt núi thành dung nham giết vô số hung cầm mãnh thú, nhưng đấu bất lợi nên toàn thân đầy máu, đành tông núi chạy trốn.","anchor":"xông về phía sâu trong dãy núi","bridge":true,"khoang":"@c0021"}],"nhanMach":[{"ten":"Vượn Ác Ma","tag":"doi-thu","quanHe":"Giằng co tranh đoạt bảo thể Toan Nghê","ghiChu":"@c0020"}]},"nguon":["@c0020","@c0021"]},{"id":"thu-vuong","name":"Thử Vương","gioiTinh":"khong-ro","trangThai":"song","blurb":"Con chuột tím to cỡ cối đá, xông vào tranh đoạt xác Toan Nghê.","vaiTro":"Hung thú lao lên lưng Thanh Lân Ưng, bị Thạch Hạo trọng thương.","tabs":{"kinhLich":[{"text":"Thử Vương nhảy lên lưng Thanh Lân Ưng, cào ra mấy cân thịt và phá vảy xanh. Bị Thạch Hạo dùng vầng trăng bạc truy kích kết hợp ký hiệu nguyên thủy của Thanh Lân Ưng đánh gãy một bộ phận xương, trọng thương rơi xuống.","anchor":"xương của Thử Vương gãy một bộ phận, bị thương trầm trọng","bridge":true,"khoang":"@c0020"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị Thạch Hạo truy kích đánh gãy xương","ghiChu":"@c0020"}]},"nguon":["@c0020"]},{"id":"a-van-thuc","name":"A Văn thúc","gioiTinh":"nam","trangThai":"tu-vong","blurb":"Người Thạch Thôn bị Bái Sơn bắn xuyên lồng ngực; ký ức về cái chết của thúc thôi thúc Thạch Hạo ra tay.","tabs":{"diem":[{"text":"Bị Bái Sơn bắn xuyên lồng ngực trong đại chiến; hồi tưởng về ông là động lực khiến Thạch Hạo lần đầu chém chết kẻ địch.","chuong":"@c0027"}],"nhanMach":[{"ten":"Bái Sơn","tag":"doi-thu","quanHe":"Kẻ giết mình","ghiChu":"Bái Sơn bắn xuyên lồng ngực A Văn thúc (@c0027)"}],"kinhLich":[],"tuViMoc":[]},"nguon":["@c0027"]},{"id":"tieu-hong","name":"Con chim đỏ nhỏ","aliases":["Chim tước đỏ","Con chim đỏ nhỏ","Tước đỏ","chim tước đỏ như lửa","chim nhỏ lửa đỏ","Nhoc Ty","Tước nhỏ hỏa hồng","Tiểu Hồng","Chim đỏ thẫm","chim Bé Hồng","Bé Hồng","#be-hong-chim"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Sinh linh chí cường (@c0051)","trangThai":"song","blurb":"Sinh linh chí cường thân đỏ như lửa, to bằng bàn tay; từng đại chiến ở Thương Mãng Sơn Mạch thiêu rụi nửa bầu trời suốt nửa tháng. (+) Sinh vật đỏ rực xuất hiện ở hướng khác trong dãy núi, đại chiến với một sinh vật kinh khủng khác được cho là vẫn còn sống. [CAN-SOAT-GOP]","vaiTro":"Cường giả ngoại lai","tinhCach":[{"text":"Trọng ân tình, biết đáp lễ","chuong":"@c0051"}],"tabs":{"diem":[{"text":"Thân đỏ như lửa, phun luồng ánh sáng có thể nung chảy đá thành dung nham","chuong":"@c0051"},{"text":"Thần uy ngập trời khiến Ngũ Sắc Kê, Độc Giác Thú quỳ lễ","chuong":"@c0051"},{"text":"Con chim đỏ nhỏ đỏ rực, đối thủ kinh ngạc vì nó vẫn còn sống","chuong":"@c0046"}],"kinhLich":[{"text":"Trong lời kể của Thạch Hạo với tộc trưởng, Tiểu Hồng là con chim sẻ toàn thân đỏ rực (gợi truyền thuyết Chu Tước/Thần Tước) mà Nhóc tỳ từng đuổi bắt; lũ trẻ không tin, riêng tộc trưởng thấy hay nên thưởng sữa thú.","anchor":"Tiểu Hồng chính là con chim sẻ toàn thân đỏ rực đó.","bridge":true,"khoang":"@c0010"},{"importance":"normal","chuong":"@c0047","tieuDe":"Chiến hung cầm giữa tứ đại sinh linh","text":"Là một trong tứ đại sinh linh chí cường huyết chiến sinh tử tranh đoạt khối Thánh vật trắng nơi sâu nhất dãy núi Thương Mãng; dù mang sẵn thương tích, tiểu Hồng vẫn kéo con hung cầm mắt đỏ ra tiêu hao sinh lực, há mỏ phun Bảo thuật hóa tiên kiếm đỏ thẫm chém đối thủ, hứng chịu ô quang phù văn từ đôi cánh hung cầm phản kích.; Tiểu Hồng dù mang thương tích sẵn vẫn kéo con hung cầm mắt đỏ ra khỏi đại chiến để tiêu hao sinh lực, phun Bảo thuật hóa t…","anchor":"ánh sáng hóa thành một thanh tiên kiếm đỏ thẫm rực rỡ sắc bén không gì sánh nổi"},{"importance":"normal","chuong":"@c0050","tieuDe":"Trọng thương rơi xuống trước cây liễu","text":"Một tia điện đỏ xẹt qua nhuộm đỏ bầu trời, Tiểu Hồng — con chim đỏ như lửa toàn thân trong suốt to bằng bàn tay — rơi xuống trước cây liễu; bụng ngực bị đâm xuyên gần đứt người, đầu có mấy lỗ suýt xuyên xương sọ, trong vết thương có ký hiệu đáng sợ lấp lóe đang phá hủy sinh cơ; đôi mắt trắng đen như bảo thạch lườm nhóc tỳ đầy u oán tức giận.; Con chim đỏ như lửa toàn thân trong suốt to bằng bàn tay của nhóc tỳ, một tia điện đỏ xẹt qua rồi nó rơi…","anchor":"một vết thương đáng sợ đâm xuyên bụng và ngực, gần như chém đứt người nó"},{"importance":"normal","chuong":"@c0051","tieuDe":"Tước đỏ tới Thạch Thôn nhờ trị thương","text":"Sinh linh chí cường thân đỏ như lửa từng đại chiến ở Thương Mãng Sơn Mạch, mang trọng thương rơi xuống Thạch Thôn; được cây liễu Liễu Thần tiết Tiên Châu chữa lành, khôi phục nguyên khí phát thần uy khiến muôn thú quỳ lễ, để lại một chiếc lông đỏ làm tín vật rồi thu lại thần tính trước khi bay đi.; Khôi phục nguyên khí, phát thần uy khiến muôn thú quỳ lễ; nói với Liễu Thần rằng nợ một ân tình rất lớn, rơi lại một chiếc lông đỏ làm tín vật cho th…","anchor":"từ xa một con chim nhỏ đỏ như lửa đại chiến ở trong Thương Mãng Sơn Mạch, thiêu rụi nửa bầu trời"},{"importance":"normal","chuong":"@c0046","tieuDe":"Đại chiến với sinh vật kinh khủng khác","text":"Ở hướng khác trong sâu sơn mạch, con chim đỏ nhỏ xuất hiện và phát động đại chiến với một sinh vật kinh khủng khác vốn tưởng đã chết; tổng cộng bốn sinh vật cực mạnh cùng quyết đấu tranh đoạt báu vật xuất thế.; Con chim đỏ nhỏ xuất hiện ở hướng khác trong sâu sơn mạch, phát động đại chiến với một sinh vật kinh khủng khác từng tưởng đã chết; là một trong bốn sinh vật cực mạnh quyết đấu tranh đoạt hỗn độn chí bảo.","anchor":"Thánh vật này là của ta"},{"importance":"normal","chuong":"@c0049","tieuDe":"Phun thần hỏa, cứu Tử Sơn Tộc bất thành","text":"Chí tôn phe chính diện, há mồm phun hào quang mang thần hỏa ngập trời thai nghén thành Tiên Kiếm màu đỏ giao đấu hung thú mắt xanh; định cứu Tử Sơn Tộc nhưng vừa chạm vào thì người trong phạm vi Bảo Thuật liền nổ tung thành sương máu, đành bất lực.; Chim tước đỏ nhỏ há mồm phun thần hỏa ngập trời thai nghén thành Tiên Kiếm màu đỏ, giao đấu với hung thú mắt xanh khổng lồ, hỏa quang và vuốt lớn va chạm rung động thiên địa. Nó cố lao vào cứu Tử Sơn…","anchor":"Đây là một trận chiến sinh tử, bọn chúng đã dồn hết sức mình"},{"chuong":"@c0028","importance":"normal","tieuDe":"Đại chiến sinh vật móng vàng kim","text":"Trong nơi sâu nhất dãy núi, Bé Hồng — chim đỏ thẫm nhỏ cỡ lòng bàn tay — dũng mãnh đấu một sinh vật khổng lồ móng vuốt vàng kim che trời đạp đất, đại chiến diễn ra trên vòm trời, núi non nóng chảy thành dung nham.","anchor":"mỗi một lần lao xuống đều cào nát bấy một cái dãy núi"}],"tuViMoc":[],"tuVi":"Sinh linh chí cường, đủ sức đại chiến ở Thương Mãng Sơn Mạch thiêu rụi nửa bầu trời suốt nửa tháng. (+) Chí cường giả, chưa rõ cảnh giới cụ thể. [CAN-SOAT-GOP]","nhanMach":[{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Được Liễu Thần cứu chữa toàn bộ thương thế; nợ một ân tình rất lớn","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Được nhóc tỳ dỗ bình tĩnh khi vừa rơi xuống","ghiChu":"@c0051"},{"ten":"Thạch Thôn","tag":"an-nhan","quanHe":"Để lại tín vật lông đỏ cho thôn nhân dùng khi có phiền toái","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Bị Thạch Hạo từng đuổi bắt và kể lại","ghiChu":"@c0010"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân (nhóc tỳ)","ghiChu":"Rơi xuống trước mặt nhóc tỳ khi trọng thương, lườm nhóc tỳ đầy u oán tức giận"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Ân nhân trị thương","ghiChu":"Liễu Thần chữa lành mọi thương thế cho tước đỏ; tước đỏ tự nhận nợ một ân tình rất lớn (@c0051)."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Đứa trẻ dỗ nó bình tĩnh","ghiChu":"Nhóc tỳ khẳng định tước đỏ không có sát khí và dỗ nó bình tĩnh lại (@c0051)."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Chim đỏ của nhóc tỳ, rơi xuống lườm nhóc u oán","ghiChu":"@c0050"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Được cây liễu trị thương, nợ một ân tình lớn","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được nhóc tỳ Thạch Hạo dỗ dành, cảm nhận nó không có địch ý","ghiChu":"@c0051"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Được Liễu Thần trị lành toàn bộ thương thế, tự nhận nợ một ân tình rất lớn","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được nhóc tỳ dỗ bình tĩnh, đặt tên Tiểu Hồng"},{"ten":"Liễu Thần","tag":"an-nhan","quanHe":"Được Liễu Thần trị thương, nợ một ân tình rất lớn"},{"ten":"Sinh vật mắt xanh biếc","tag":"khac","quanHe":"Cùng tham gia đại chiến bốn sinh vật cực mạnh tranh hỗn độn chí bảo trong Thương Mãng Sơn Mạch","ghiChu":"@c0046"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0051","@c0047","@c0010","@c0050","@c0046","@c0049","@c0028"]},{"id":"cha-me-nhoc-ty","name":"Cha mẹ nhóc tỳ","aliases":["Đôi vợ chồng trẻ","đôi vợ chồng trẻ"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Cổ quốc (bộ tộc của cha mẹ nhóc tỳ)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Đôi vợ chồng trẻ từ một cổ quốc hùng mạnh tìm về tổ địa Thạch Thôn, mang theo nhóc tỳ khi cơ thể nhóc tỳ thoái hóa nghiêm trọng.","vaiTro":"Người thân nhóc tỳ","tinhCach":[],"tabs":{"diem":[{"text":"Người phụ nữ xinh đẹp, người đàn ông anh tuấn nhưng có vẻ bệnh","chuong":"@c0051"}],"kinhLich":[{"text":"Theo lời tộc trưởng, đôi vợ chồng trẻ tới từ một cổ quốc mạnh mẽ khôn lường, nói Thạch Thôn là tổ địa bộ tộc của họ; người đàn ông có vẻ mang bệnh, họ mang theo nhóc tỳ khi cơ thể cậu thoái hóa nghiêm trọng.; Từ một cổ quốc mạnh mẽ tìm về tổ địa Thạch Thôn, mang theo nhóc tỳ cơ thể đang thoái hóa nghiêm trọng; do tổ huấn không được tùy ý quay lại tổ địa nên đã thất lạc đường về.; Người phụ nữ xinh đẹp, người đàn ông anh tuấn nhưng có vẻ bệnh; từ…","anchor":"Bọn họ tới từ một cổ quốc, nói Thạch Thôn là tổ địa của bộ tộc bọn họ","bridge":true,"khoang":"@c0051"}],"tuViMoc":[],"tuVi":"Xuất thân bộ tộc mạnh mẽ không thể tưởng tượng.","nhanMach":[{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Cha mẹ nhóc tỳ, mang con về tổ địa rồi rời đi","ghiChu":"@c0051"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Gặp tộc trưởng khi gửi nhóc tỳ về tổ địa","ghiChu":"@c0051"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Nghi là cha mẹ ruột của nhóc tỳ","ghiChu":"Chương nói có thể chính là cha mẹ của nhóc tỳ (@c0051)."},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Cha mẹ của nhóc tỳ, gửi lại cậu ở Thạch Thôn","ghiChu":"@c0051"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0051"]},{"id":"a-tu-chim","name":"A Tử","aliases":[],"gioiTinh":"khong-ro","trangThai":"song","vaiTro":"Một trong ba con chim non do Thanh Lân Ưng đẻ, được Thạch Hạo nuôi dưỡng","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0017","importance":"minor","tieuDe":"Muốn theo Thạch Hạo vào núi","text":"Cùng Đại Bằng và Tiểu Thanh dụi đầu vào tay Thạch Hạo tỏ vẻ thân thiết, muốn đi theo nhưng bị dặn ở lại thôn.","anchor":"Đại Bằng, Tiểu Thanh, A Tử tiến lại gần, dùng đầu cọ vào tay nhóc tỳ, tỏ vẻ vô cùng thân thiết, cũng muốn đi theo."}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người nuôi dưỡng, rất thân thiết","ghiChu":"@c0017"}],"tuiDo":{}},"nguon":["@c0017"]},{"id":"thu-linh-doi-san-thu-bai-thon","name":"Thủ lĩnh đội săn thú Bái Thôn","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Bái Thôn","trangThai":"gan-bo"}],"trangThai":"song","vaiTro":"Cầm đầu đội săn thú Bái Thôn phục kích Thạch Hạo","tabs":{"diem":[{"text":"Cao hai mét ba/tư, cơ bắp cuồn cuộn, coi thường lời thề trước bảo vật.","chuong":"@c0022"}],"kinhLich":[{"importance":"normal","chuong":"@c0022","tieuDe":"Cầm đầu phục kích Thạch Hạo","text":"Cao hai mét ba bốn, cơ bắp cuồn cuộn, thủ lĩnh dẫn hơn hai mươi người Bái Thôn phục kích Thạch Hạo bằng tên sắt và mâu sắt để cướp bảo thể Toan Nghê cùng sừng Thái Cổ Di Chủng; bị Bảo Nguyệt chém rách bụng suýt lòi ruột, sắc mặt tái nhợt ra lệnh rút lui.; Bắn mũi tên sắt lạnh lẽo sạt qua cổ họng Thạch Hạo, dẫn hơn hai mươi người Bái Thôn dùng tên sắt và mâu sắt vây nhóc tỳ để cướp bảo thể Toan Nghê và sừng Thái Cổ Di Chủng; bị vầng trăng bạc thứ…","anchor":"một mũi tên sắt lạnh lẽo bắn sạt qua cổ họng nó"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ phục kích","ghiChu":"Bị Bảo Nguyệt của Thạch Hạo chém rách bụng. @c0022"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ bị hắn phục kích nhưng lại đánh lui cả đội săn.","ghiChu":"@c0022"}],"tuiDo":{}},"nguon":["@c0022"]},{"id":"bai-gia","name":"Bái già","aliases":["Con Bái dữ","Con Bái già","con Bái","Bái già"],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Cự thú xảo trá điều động cả đàn thú tấn công Thạch Thôn, khao khát cướp bảo thể Toan Nghê, sừng quý và hai Tổ Khí.","vaiTro":"Phản diện — quái thú đầu sỏ tập kích Thạch Thôn.","theLuc":[],"tabs":{"diem":[{"text":"Xảo trá đánh du kích, tránh đối đầu trực diện để tiêu hao đối thủ dùng Tổ Khí.","chuong":"@c0026"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đánh du kích ép Thạch Lâm Hổ kiệt sức."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị nhóc tỳ triệu Bệ Ngạn cắn gãy chân, trọng thương."},{"ten":"Thanh Lân Ưng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thanh Lân Ưng hồi sinh phóng trăng xanh đánh nát chân sau."},{"ten":"Thạch Lâm Hổ","tag":"doi-thu","quanHe":"Đối thủ dùng Tổ Khí xương thú chống lại","ghiChu":"@c0026"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ dùng Tổ Khí da thú trọng thương","ghiChu":"@c0026"},{"ten":"Thanh Lân Ưng","tag":"doi-thu","quanHe":"Bị con chim hồi sinh phóng trăng xanh đánh nát chân sau","ghiChu":"@c0026"},{"ten":"Tế Linh","tag":"doi-thu","quanHe":"Bị Tế Linh hóa xích thần ráng xanh chặn lại khi liều mạng","ghiChu":"@c0026"}],"tuiDo":{}},"nguon":["@c0026"]},{"id":"te-linh","name":"Tế Linh","gioiTinh":"khong-ro","trangThai":"song","blurb":"Thực thể bảo hộ Thạch Thôn mang hình cây liễu lớn cháy đen chỉ còn một cành non.","vaiTro":"Thần linh bảo hộ thôn làng.","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Mang hình cây liễu cháy đen chỉ còn một cành non nhưng vẫn phát ánh sáng và uy lực bảo hộ.","chuong":"@c0026"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Bái già","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Ra tay hóa xích thần chặn con Bái dữ để bảo vệ tộc nhân."},{"ten":"Con Bái dữ","tag":"doi-thu","quanHe":"Ra tay chặn con Bái liều mạng trước thôn","ghiChu":"@c0026"}],"tuiDo":{}},"nguon":["@c0026"]},{"id":"hai-tieu-co-nuong-song-sinh","name":"Hai tiểu cô nương song sinh","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Hai bé gái tướng mạo giống hệt nhau, xinh đẹp, cưỡi Tuyết Vũ, chưa lộ tên.","vaiTro":"Đứng trên Tuyết Vũ cười đùa thích thú với nhóc tỳ khi ba thiên tài khai chiến.","tinhCach":[{"text":"Vô tư, thích thú","chuong":"@c0034"}],"tabs":{"diem":[{"text":"Song sinh tuyệt sắc giống hệt nhau, cưỡi Tuyết Vũ, chưa lộ tên","chuong":"@c0034"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Nhóc tỳ","tag":"khac","quanHe":"Thích thú theo dõi nhóc tỳ đánh bay Giao Bằng","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0034"]},{"id":"ac-ma-vien","name":"Vượn Ác Ma","cn":"","gioiTinh":"khong-ro","aliases":["Ác Ma Viên Vương","Vượn Ác Ma","Ác Ma Viên","Vược Ác Ma"],"theLuc":[],"canhGioiCaoNhat":"Dị thú huyết thống vương giả cực cao (@c0020)","trangThai":"song","blurb":"Con vượn dữ đen khổng lồ có cánh và sừng, huyết thống vương giả cực cao, uy áp khiến vạn thú im bặt khi hàng lâm. (+) Vượn dữ đen có cánh và sừng, huyết thống vương giả cực cao, hàng lâm khu ngoại vi khiến vạn thú run rẩy. [CAN-SOAT-GOP]","vaiTro":"Bá chủ hung thú xuất hiện tranh đoạt bảo thể Toan Nghê","tabs":{"diem":[{"text":"Huyết thống vương giả cực cao, uy áp khiến hung cầm mãnh thú im bặt ngã rạp","chuong":"@c0020"}],"kinhLich":[{"text":"Con vượn dữ đen có cánh và sừng từ sâu trong núi tới, uy áp khiến hung cầm mãnh thú run rẩy im bặt. Nó đè đầu con Điêu Hùng dài mười mét thưởng thức, giẫm chân dọn sạch đá quanh Toan Nghê, rồi giằng co với Ly Hỏa Ngưu Ma. Cuối cùng bị con Toan Nghê bật dậy xé đứt một cánh tay.; Từ sâu trong núi tới, Vượn Ác Ma — vượn dữ đen có cánh và sừng — phát ra hung uy ngập trời khiến vạn thú im bặt. Nó đè đầu con Điêu Hùng dài mười mét thưởng thức, giẫm ch…","anchor":"giống như Cái Thế Ma Vương hàng lâm, phát ra hung uy ngập trời","bridge":true,"khoang":"@c0020"},{"text":"Con Ác Ma Viên một tay dẫn đầu mười mấy Thái Cổ Di Chủng hoành hành, tấn công bộ lạc 20-30 vạn người: đập nát sọ cao thủ hút óc, xé đôi Tế Linh cá sấu bạc làm hai nửa, cùng thú triều nuốt sạch cư dân.","anchor":"đã bị Ác Ma Viên lấy tay và một bàn chân xé xác làm hai nửa","bridge":true,"khoang":"@c0049"},{"text":"Bị Toan Nghê xé đứt một cánh tay và dùng Bảo Thuật đánh thủng lưng một lỗ máu trước sau thông suốt, Ác Ma Viên vỡ tạng phủ, gãy xương, cuối cùng thoát khỏi mây khói của Toan Nghê rồi trốn vào sâu trong dãy núi dưỡng thương.","anchor":"xông về phía sâu trong dãy núi","bridge":true,"khoang":"@c0021"},{"text":"Hiện thân Vua vượn màu đen có cánh, đã mất một tay sau trận đại chiến với Toan Nghê; lùa cả thú triều đen nghịt đuổi giết đám cường giả liên hợp, hút não tủy từng người, không ai chạy thoát.; Hiện thân Vua vượn đen có cánh, mất một tay từ trận đại chiến với Toan Nghê, nay càng hung cuồng. Lùa cả thú triều đen nghịt đuổi giết đám cường giả liên hợp, hút não tủy từng người; không ai chạy thoát. Con Di chủng đang phụng mệnh dọn bãi cho Sơn bảo xuất…","anchor":"Sau cùng, không một ai có thể chạy thoát, tất cả đều bỏ mạng.","bridge":true,"khoang":"@c0042"}],"tuViMoc":[],"nhanMach":[{"ten":"Ly Hỏa Ngưu Ma","tag":"doi-thu","quanHe":"Giằng co tranh đoạt bảo thể Toan Nghê","ghiChu":"Hai bá chủ đánh nhau, đều bị Toan Nghê sống dậy trọng thương (@c0020)."},{"ten":"Ly Hỏa Ngưu Ma","tag":"doi-thu","quanHe":"Giằng co tranh đoạt bảo thể Toan Nghê","ghiChu":"@c0020"}],"tuiDo":{}},"nguon":["@c0020","@c0049","@c0021","@c0042"]},{"id":"thu-linh-kim-lang","name":"Thủ lĩnh bộ lạc Kim Lang","gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Kim Lang","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thủ lĩnh bộ lạc Kim Lang, tuổi gần Thạch Phi Giao, cưỡi Ngựa một sừng; bắt chuyện Thạch Phi Giao để dò hỏi Sơn bảo trên núi.","tabs":{"diem":[{"text":"Buộc Ngựa một sừng, tuổi gần Thạch Phi Giao, dò hỏi Sơn bảo","chuong":"@c0036"}],"kinhLich":[{"text":"Chủ động mời nhóc tỳ gia nhập bộ lạc Kim Lang, hứa dạy Cốt Văn mạnh nhất và Bảo Thuật chí cường — thực chất nhắm bảo cốt Toan Nghê và ba dị cầm; bị Thạch Hạo khéo léo từ chối.","anchor":"Bộ lạc Kim Lang của ta muốn thu đồ đệ, không biết cháu có muốn gia nhập không?","bridge":true,"khoang":"@c0039"},{"text":"Lão tộc trưởng cao to dũng mãnh, con ngươi bắn kim quang, lòng bàn tay có phù văn vàng kim chữa thương cho Ba Đồ, nghe xong quyết định đích thân tới Thạch thôn và mời Sói thần vàng kim đi theo cho ổn thỏa; xuất hiện cơn lốc xoáy vàng kim cuồn cuộn.","anchor":"Để ổn thỏa hơn sẽ đi mời Sói thần, để nó cũng theo ta một chuyến này.","bridge":true,"khoang":"@c0041"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Phi Giao","tag":"doi-thu","quanHe":"Dò hỏi Sơn bảo","ghiChu":"Bắt chuyện Thạch Phi Giao để dò hỏi (@c0036)"},{"ten":"Thạch Phi Giao","tag":"khac","quanHe":"Người dò hỏi","ghiChu":"Buộc Ngựa một sừng, tuổi gần Thạch Phi Giao, bắt chuyện dò hỏi về Sơn bảo trên núi (@c0036)."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[{"ten":"Ngựa một sừng","moTa":"Buộc bên cạnh","nguon":"@c0036"}],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0036","@c0039","@c0041"]},{"id":"toc-chu-la-phu-dai-trach","name":"Tộc chủ La Phù Đại Trạch","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"La Phù Đại Trạch","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chí cường giả","trangThai":"song","blurb":"Chí cường giả thống trị nhiều bộ tộc thuộc La Phù Đại Trạch; từng bị tàn phế thủ lĩnh đội Thương Giao nên muốn báo thù.","vaiTro":"Tộc chủ một trong bốn thế lực đại tộc vây đánh Thạch thôn.","tinhCach":[],"tabs":{"diem":[{"text":"Thống trị nhiều bộ tộc; từng bị tàn phế thủ lĩnh đội Thương Giao và tổn hại cao thủ.","chuong":"@c0042"}],"kinhLich":[{"text":"Muốn báo thù đòi bồi thường vì bị tàn phế thủ lĩnh đội Thương Giao và tổn hại cao thủ; cùng các đại tộc tiến về Thạch thôn.","anchor":"Mấy đại tộc vậy mà đều cùng đi một hướng, mục tiêu chính là: THẠCH THÔN.","bridge":true,"khoang":"@c0042"},{"importance":"major","chuong":"@c0044","tieuDe":"Tử vong dưới cành liễu","text":"Dùng Bảo thuật hóa hung giao dài hơn ba trăm mét công kích, bị cành liễu xuyên thủng trán, quấn cổ siết chặt hút khô tinh khí thần; đứng ở con sông phương Tây dùng khối xương thú làm thế thân vẫn bị cành liễu chém đứt làm hai, xác khô quắt như già mấy nghìn năm.; Dùng Bảo thuật hàm chứa tinh khí thần hóa hung giao dài hơn ba trăm mét công kích nhưng bị cây liễu hút khô, phải phun máu tươi; đứng bên con sông phương Tây dùng khối xương thú làm thế…","anchor":"đơn giản chét đứt hắn ra làm hai"}],"tuViMoc":[],"nhanMach":[{"ten":"Tử Sơn Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng vây công Thạch thôn @c0044"},{"ten":"Lôi Hầu","tag":"dong-minh","quanHe":"Đồng minh liên thủ","ghiChu":"Cùng vây công Thạch thôn @c0044"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"Đối thủ tử chiến","ghiChu":"Hung giao bị cây liễu hút khô; bản thân bị cành liễu chém đứt làm hai mà chết"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0042","@c0044"]},{"id":"than-lang","name":"Thần Lang","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Bộ lạc Kim Lang","trangThai":"da-roi"}],"canhGioiCaoNhat":"Đệ nhất Tế Linh trong phạm vi năm vạn dặm (@c0045)","trangThai":"song","blurb":"Thần Lang, đệ nhất Tế Linh trong phạm vi năm vạn dặm; phản ứng nhanh nhất trước cây liễu, cướp Tổ Khí Lang Nha Chủy rồi bỏ chạy vào rừng rậm nguyên thủy.","vaiTro":"Tế Linh của bộ lạc Kim Lang, vứt bỏ các tộc và cướp Tổ Khí khi cảm nhận đại họa.","tinhCach":[{"text":"Nhạy bén, cơ trí, biết tự bảo toàn — bỏ chủ nhân để thoát thân","chuong":"@c0045"}],"tabs":{"diem":[{"text":"Phản ứng nhanh nhất trong tứ đại thế lực, biến thành chùm sáng vàng chạy vào rừng khi da vàng đang tấn công nó","chuong":"@c0045"}],"kinhLich":[{"text":"Sau khi né được đợt tận diệt đầu tiên, Thần Lang vàng xông lại tát bay thiếu tộc trưởng Kim Lang rồi cắn lấy Lang Nha Chủy chạy mất; tộc lão kêu đây là điềm bất tường vì Tế Linh vứt bỏ họ và cướp Tổ Khí.","anchor":"cắn lấy cái Lang Nha Chủy đó rồi xoay người té thẳng","bridge":true,"khoang":"@c0045"}],"tuViMoc":[],"nhanMach":[{"ten":"Thiếu tộc trưởng bộ lạc Kim Lang","tag":"doi-thu","quanHe":"Tát bay hắn để cướp Tổ Khí (@c0045)"}],"tuiDo":{"phapBao":[{"ten":"Lang Nha Chủy","trangThai":"bi-cuop","moTa":"Cướp Tổ Khí của bộ lạc Kim Lang mang theo khi chạy trốn","nguon":"@c0045"}]}},"nguon":["@c0045"]},{"id":"doi-thu-dung-con-sat","name":"Đối thủ dùng côn sắt (chưa lộ tên)","gioiTinh":"khong-ro","trangThai":"khong-ro","canhGioiCaoNhat":"Không rõ (@c0046)","blurb":"Sinh vật khổng lồ dùng thanh côn sắt to như cột chống trời, giao chiến với sinh vật mắt xanh biếc để tranh thánh vật trong dãy núi nguyên thủy.","vaiTro":"Một trong bốn sinh vật cực mạnh quyết đấu tranh báu vật ở Thương Mãng Sơn Mạch.","tabs":{"kinhLich":[{"text":"Sinh vật khổng lồ dùng thanh côn sắt to như cột chống trời đánh trả sinh vật mắt xanh; thanh côn được ký hiệu nguyên thủy gia trì khiến thần uy tăng mạnh.","anchor":"Thánh vật này là của ta.","bridge":true,"khoang":"@c0046"},{"importance":"normal","chuong":"@c0049","tieuDe":"Chí tôn chính diện đối đầu Thôn Thiên Tước","text":"Sinh linh phe chính diện ẩn trong sương mù, vung côn sắt khổng lồ đánh về đầu Thôn Thiên Tước rồi mở mắt dọc giữa mi tâm phát kim quang hóa Tiên Kiếm chém Thiên Địa Hồng Lô đen; muốn ngăn cuộc huyết tẩy nhưng đánh với hai kẻ điên chỉ khiến tổn thất lớn hơn nên hiệu quả hạn chế.; Sinh linh cầm côn sắt ẩn trong sương mù vung côn khổng lồ quét sụp vòm trời đánh về đầu Thôn Thiên Tước, rồi mở mắt dọc giữa mi tâm phát kim quang hóa thành Tiên Kiếm ch…","anchor":"Đây là một trận chiến sinh tử, bọn chúng đã dồn hết sức mình"}],"nhanMach":[{"ten":"Sinh vật mắt xanh biếc","tag":"doi-thu","quanHe":"Đối thủ tranh thánh vật","ghiChu":"Giao chiến trực tiếp trong sâu dãy núi nguyên thủy."},{"ten":"Sinh vật mắt xanh biếc","tag":"doi-thu","quanHe":"Đối thủ giao chiến tranh thánh vật, dùng côn sắt được ký hiệu nguyên thủy gia trì đánh trả","ghiChu":"@c0046"},{"ten":"Sinh vật mắt xanh biếc","tag":"doi-thu","quanHe":"Đối chọi tranh thánh vật","ghiChu":"@c0046"}],"tuViMoc":[]},"nguon":["@c0046","@c0049"]},{"id":"thach-nghi","name":"Thạch Nghị","aliases":["Nghị Nhi","Nghị nhi","tiểu ca ca"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ quốc (hoàng thân)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0055)","trangThai":"song","blurb":"Đứa bé ba bốn tuổi trong ký ức Thạch Hạo, trời sinh có trọng đồng (bốn con ngươi) — dị tượng của Thượng Cổ Thánh Nhân; được cả tộc kỳ vọng trấn áp bát hoang.","vaiTro":"Anh cùng dòng họ với Thạch Hạo, thiên túng kỳ tài của dòng hoàng thân cổ quốc.","tinhCach":[{"text":"Chững chạc, uy nghiêm hơn tuổi","chuong":"@c0055"}],"tabs":{"diem":[{"text":"Trời sinh trọng đồng (bốn con ngươi) — dị tượng Thượng Cổ Thánh Nhân","chuong":"@c0055"},{"text":"Thiên túng kỳ tài, học nhanh hơn xa bọn trẻ cùng lứa","chuong":"@c0055"}],"kinhLich":[{"chuong":"@c0055","importance":"major","tieuDe":"Trọng đồng — dị tượng Thượng Cổ Thánh Nhân","text":"Trong ký ức tế trời của cổ quốc, Thạch Nghị là đứa bé ba bốn tuổi trời sinh có trọng đồng (bốn con ngươi), dị tượng của Thượng Cổ Thánh Nhân, thiên túng kỳ tài học gì cũng nhanh; cả tộc kỳ vọng nó tranh đoạt ngôi vị Nhân Hoàng.; Trong ký ức của Thạch Hạo, Thạch Nghị là đứa bé ba bốn tuổi trời sinh trọng đồng (bốn con ngươi) — dị tượng Thượng Cổ Thánh Nhân; chững chạc uy nghiêm, thiên túng kỳ tài học nhanh hơn xa bọn trẻ cùng lứa, được cả tộc kỳ…","anchor":"Nó trời sinh có trọng đồng, đây là dị tượng của Thượng Cổ Thánh Nhân."},{"chuong":"@c0056","importance":"major","tieuDe":"Dùng Trọng Đồng phát hiện Chí Tôn cốt của Hạo","text":"Chưa đủ bốn tuổi đã trầm ổn khác thường, tự tu hành Cốt văn; nhìn Hạo chằm chằm bằng Trọng Đồng, điềm tĩnh nói trong cơ thể Hạo có một khối xương ẩn chứa phù văn thâm ảo diệu kỳ khó lường; bị mẹ ra lệnh không được nói cho bất cứ ai.; Dùng Trọng Đồng phát hiện Chí Tôn cốt trong cơ thể Thạch Hạo; bị mẹ cấm không được nói cho ai; dửng dưng chứng kiến mẹ sai bóng u linh chiết xương Thạch Hạo; nằm trên giường ngọc bị rạch lồng ngực nhận cấy Chí Tôn c…","anchor":"thấy con trai mình đang nhìn đứa bé này chằm chằm, thần quang ẩn hiện trong khóe mắt"},{"importance":"major","chuong":"@c0057","tieuDe":"Nhận Chí Tôn Cốt, ép Tứ Thái Gia tha mẹ","text":"Cắn tấm gỗ mềm chịu đau khi được cấy Chí Tôn Cốt của Thạch Hạo vào lồng ngực; khi Tứ Thái Gia phá cửa định giết mẹ, cầm dao bạc đầu giường kề cổ tự thương cứa ra vết máu để ép ông tha; sau đó bình tĩnh khai nhận Chí Tôn Cốt đang ở trong người mình.; Vốn có trọng đồng bẩm sinh, chịu đau cắn tấm gỗ mềm khi được thiếu phụ và bóng đen cấy Chí Tôn Cốt vào lồng ngực; khi Tứ Thái Gia định giết mẹ, chộp con dao bạc ở đầu giường kề cổ tự cứa chảy máu ép…","anchor":"cầm lấy con dao bạc ở đầu giường kề lên cổ mình, lập tức xuất hiện một vết máu"},{"chuong":"@c0058","importance":"major","tieuDe":"Dung hợp Chí Tôn cốt thành một thể","text":"Chí Tôn cốt bị mẹ (độc phụ) móc từ Thạch Hạo, cấy vào Nghị nhi, được máu thịt bồi dưỡng như vốn sinh ra từ cơ thể; vài ngày sau dung luyện thành một lò, không cách nào tách trả — kết hợp với Trùng Đồng sẵn có khiến chư lão không dám tưởng tượng tương lai.; Được cấy Chí Tôn cốt móc từ Thạch Hạo; cốt hoà làm một thể với thân hắn, được máu thịt bồi dưỡng, sau vài ngày dung luyện thành một lò, không cách nào tách trả.; Chí Tôn cốt móc từ Thạch Hạo đ…","anchor":"Đã cùng Nghị nhi hòa làm một thể, được máu thịt của nó bồi dưỡng"},{"importance":"normal","chuong":"@c0059","tieuDe":"Xuất hiện chặn Thạch Tử Lăng","text":"Sau khi đoạt được Chí Tôn cốt (cướp từ nhóc tỳ Thạch Hạo) càng bất phàm, trời sinh Trùng Đồng, tư chất Thượng cổ Thánh nhân/Thần nhân; chớp mắt thần quang chuyển động, uy nghiêm đáng sợ như thần linh hiện thế, xuất hiện cạnh Lão Ngũ chặn Thạch Tử Lăng.; Sau khi đoạt Chí Tôn cốt từ nhóc tỳ, Thạch Nghị (trời sinh Trùng Đồng, tư chất Thượng cổ Thánh nhân) càng bất phàm uy nghiêm; xuất hiện cạnh Lão Ngũ chặn Thạch Tử Lăng.","anchor":"một đứa trẻ thông minh hoạt bát lại bị thoái hoá thành như bây giờ"},{"importance":"major","chuong":"@c0060","tieuDe":"Trùng đồng chỉ điểm và bị đánh gãy trăm xương","text":"Dùng trùng đồng nhìn thấu bổn nguyên, ba lần hét chỉ khe hở của Thạch Tử Lăng và hung thú cho ông nội Thạch Uyên tấn công nhưng không kịp tốc độ Bảo Thuật đối phương; bị vạch là kẻ tố giác Chí Tôn Cốt và dọa tự sát để bảo vệ mẹ; cuối chương bị ký hiệu Bảo Thuật lạ của Thạch Tử Lăng đánh bay tông vào giả sơn, toàn thân là máu, hơn trăm cây xương gãy lìa; Bị Thạch Tử Lăng vạch trần chính là kẻ tố giác chuyện Chí Tôn Cốt của Hạo Nhi cho mẹ và bày t…","anchor":"Thái gia, đánh vào sườn trái của hắn!"},{"importance":"major","chuong":"@c0061","tieuDe":"Trùng đồng + Chí Tôn Cốt tự chữa lành","text":"Chưa đủ bốn tuổi, gãy hơn trăm xương vẫn ngẩng đầu gào thét tàn ác; hào quang từ mắt tạo kén bao thân, xương gãy về vị trí cũ và ngồi dậy được, ngực phát thánh quang khép vết thương — Chí Tôn Cốt mới cấy chưa hai tháng đã phát huy uy lực nghịch thiên trên thân nó.; Đứa bé chưa đủ bốn tuổi, người trùng đồng mang đặc chất Thánh Nhân Thần Nhân Thượng Cổ, được cấy Chí Tôn Cốt của Hạo Nhi; gãy hơn trăm xương vẫn ngẩng đầu gào thét, rồi hào quang từ m…","anchor":"những cái xương bị gẫy đã về vị trí cũ."},{"chuong":"@c0062","importance":"major","tieuDe":"Cưỡng vận Chí Tôn cốt, phản phệ nứt xương","text":"Được Thạch Lạp cõng, hai người ngưng kết cưỡng ép thôi thúc khối Chí Tôn cốt (vốn của Hạo nhi) phát thần uy chấn động khiến người quan chiến muốn quỳ bái; bị phản phệ vì Chí Tôn cốt chưa trưởng thành, trăm xương rạn nứt nhưng tinh khí thần không yếu; Trùng Đồng hiện nhật nguyệt chuyển động, ngân hà vẫn lạc, phù văn quấy nhiễu thi pháp Thạch Tử Lăng; nhìn chằm chằm Thạch Tử Lăng lạnh lùng rồi liếc nhóc tỳ (Hạo nhi) bằng ánh mắt ngạo thị; Được Thạ…","anchor":"trong sâu thẳm Trùng Đồng, nó đang nhìn chằm chằm Thạch Tử Lăng một cách lạnh lùng"},{"text":"Được nhắc như đối thủ định mệnh của Thạch Hạo: Thượng Cổ Thánh Nhân người nhà Vương Hầu, đoạt được Chí Tôn Cốt, hơn chín tuổi sắp mười, được toàn tộc cổ quốc bồi dưỡng với tài nguyên vô hạn.","anchor":"Thạch Nghị - Thượng Cổ Thánh Nhân lại càng đoạt được Chí Tôn Cốt.","bridge":true,"khoang":"@c0065"},{"importance":"normal","chuong":"@c0090","tieuDe":"Kỷ lục chém chín Thú Vương tại Sơ Thủy Địa","text":"Bia đá kỷ lục Hư Thần Giới ghi Thạch Nghị ‘trùng đồng khai thiên’ trong một trận chém chín Thú Vương tại Sơ Thủy Địa, lập kỷ lục nhiều nhất; kỷ lục thứ hai là dùng sức mạnh cơ thể (không dùng Cốt Văn) nhảy một bước lên đỉnh núi; hiện đã lên động tiên tầng cao tìm khiêu chiến Tỳ Hưu và Đào Ngột con.","anchor":"trong một trận chiến giết chết chín con Thú Vương"},{"text":"Tới sơn môn Bổ Thiên các bằng con chim khổng lồ Thái Cổ di chủng vật cưỡi của Vũ Vương phủ; tuyên bố muốn gia nhập Bổ Thiên các với mục đích sánh vai Thượng Cổ Thánh Nhân, gây chấn động.","anchor":"Thạch Nghị muốn gia nhập Bổ Thiên các rồi, mục đích chỉ có một, muốn cùng Thượng Cổ Thánh Nhân sánh vai","bridge":true,"khoang":"@c0097"}],"tuViMoc":[{"chuong":"@c0057","canhGioi":"Phàm nhân (mang Chí Tôn Cốt)","text":"Được cấy Chí Tôn Cốt vào lồng ngực; nhờ trọng đồng nên có thể khám phá bổn nguyên bảo cốt.","importance":"major"},{"chuong":"@c0058","canhGioi":"Trùng Đồng + Chí Tôn cốt","text":"Vốn thiên sinh Trùng Đồng, nay thêm Chí Tôn cốt dung hợp thành một thể, tiềm năng tương lai không dám tưởng tượng.","importance":"major"},{"chuong":"@c0056","canhGioi":"Phàm nhân (Trọng Đồng + được cấy Chí Tôn cốt)","text":"Ba tuổi đã tự tu hành Cốt văn; mắt có Trọng Đồng — đặc thù Thượng cổ Thánh nhân/Thần nhân, nhìn ra ngọn nguồn thế giới; được cấy Chí Tôn cốt chiết từ Thạch Hạo.","importance":"major"},{"chuong":"@c0056","canhGioi":"Phàm nhân (chưa đủ bốn tuổi)","text":"Trời sinh Trọng Đồng — một mắt hai con ngươi, đặc thù Thượng cổ Thánh nhân Thần nhân nhìn ra ngọn nguồn thế giới; ba tuổi đã ngồi xếp bằng tu hành Cốt văn; cuối chương được cấy thêm Chí Tôn cốt cướp từ Hạo.","importance":"major"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Em cùng dòng họ (Hạo Nhi)","ghiChu":"Trưởng bối nói Hạo Nhi không kém Nghị Nhi là mấy. (@c0055)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Anh em họ; nạn nhân bị moi Chí Tôn Cốt để cấy cho Thạch Nghị","ghiChu":"@c0057"},{"ten":"Tứ Thái Gia","tag":"doi-thu","quanHe":"Bối phận cực cao trong Thạch Tộc; suýt giết mẹ Thạch Nghị, cảnh cáo sẽ tận diệt chi khi Tử Lăng về","ghiChu":"@c0057"},{"ten":"Lão Ngũ","tag":"an-nhan","quanHe":"Chủ sự chi ruột, viện Chí Tôn Cốt để cứu mạng mẹ Thạch Nghị và bản thân Thạch Nghị","ghiChu":"@c0057"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Trưởng lão thuộc chi trực tiếp của Nghị nhi, bảo vệ và báo tin dung hợp thành công.","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nạn nhân bị móc Chí Tôn cốt — cốt được cấy sang thân Nghị.","ghiChu":"@c0058"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Cha của Hạo, tuyên thề cắt một trăm khúc xương Nghị để báo thù.","ghiChu":"@c0058"},{"ten":"Lão Ngũ","tag":"dong-minh","quanHe":"Bề trên bảo hộ trực tiếp","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Kẻ phát điên tàn sát nhánh mình để đòi Chí Tôn cốt","ghiChu":"@c0059"},{"ten":"Thạch Uyên","tag":"ho-hang","quanHe":"Ông nội, tông lão chi thứ 5 đứng ra bảo vệ Chí Tôn Cốt ghép trên người mình; thất bại trước Thạch Tử Lăng.","ghiChu":"@c0060"},{"ten":"Mẹ Thạch Nghị","tag":"cha-me","quanHe":"Mẹ ruột, chị dâu Thạch Tử Lăng; được thông báo về Chí Tôn Cốt của Hạo Nhi qua chính hắn, bị áp giải tới phụ đệ và bị Thạch Tử Lăng phóng mâu ghim chết.","ghiChu":"@c0060"},{"ten":"Mẹ Thạch Nghị","tag":"cha-me","quanHe":"Mẹ ruột, bị Thạch Tử Lăng giết trước mặt nó","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"ho-hang","quanHe":"Cửu thái gia trong tộc, được nó cõng để gia trì trùng đồng cùng tham chiến","ghiChu":"@c0061"},{"ten":"Bốn vị lão tổ Thạch tộc","tag":"ho-hang","quanHe":"Bậc tối cao ẩn thân bảo vệ nó, coi là hi vọng xưng tôn của tộc","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"dong-minh","quanHe":"Người cõng Thạch Nghị, cưỡng ép thôi thúc Chí Tôn cốt phát thần uy.","ghiChu":"@c0062"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cùng dòng họ hoàng thân; được ví là huynh trưởng thiên tài của Hạo Nhi.","ghiChu":"@c0055"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ — cha của nhóc tỳ bị cướp cốt","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ bị hắn đoạt Chí Tôn cốt","ghiChu":"Tuyến đối đầu lâu dài"},{"ten":"Lão Ngũ","tag":"dong-minh","quanHe":"Người bảo hộ","ghiChu":"Đứng cạnh chặn Thạch Tử Lăng"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Trưởng bối trong dòng họ","ghiChu":"@c0055"},{"ten":"Lục tẩu","tag":"cha-me","quanHe":"Mẹ","ghiChu":"Chủ mưu chiết Chí Tôn cốt cho mình"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Huynh đệ trong tộc","ghiChu":"Nạn nhân bị chiết Chí Tôn cốt, dửng dưng chứng kiến"},{"ten":"Thập Nhất đệ","tag":"ho-hang","quanHe":"Thúc phụ","ghiChu":"Cha Thạch Hạo"},{"ten":"Thiếu phụ","tag":"cha-me","quanHe":"Mẹ ruột; chủ mưu cấy Chí Tôn Cốt cho con","ghiChu":""},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Anh em họ; nhận Chí Tôn Cốt bị moi từ Thạch Hạo","ghiChu":""},{"ten":"Tứ Thái Gia","tag":"khac","quanHe":"Chủ sự trong tộc, đe dọa xử tội chi của mẹ Thạch Nghị","ghiChu":""},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Chủ sự thuộc chi của Thạch Nghị, đứng ra bảo vệ vì Chí Tôn Cốt","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Người bị móc Chí Tôn cốt để cấy cho Thạch Nghị","ghiChu":"@c0058"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Cha Thạch Hạo, thề cắt một trăm cái xương để báo thù","ghiChu":"@c0058"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ nội tộc","ghiChu":"Cha nhóc tỳ bị Thạch Nghị đoạt Chí Tôn cốt"},{"ten":"Thạch Uyên","tag":"ho-hang","quanHe":"Ông nội, người che chở và được Thạch Nghị chỉ điểm trong trận","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Người đánh gãy hơn trăm xương của Thạch Nghị để trả thù cho con","ghiChu":"@c0060"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"Mẹ ruột, người được Thạch Nghị dọa tự sát để bảo vệ","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Người giết mẹ nó, đối đầu trong trận","ghiChu":"@c0061"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"Mẹ ruột, bị Thạch Tử Lăng giết trước mắt","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"an-nhan","quanHe":"Cửu thái gia cõng nó tham chiến, được nó gia trì trùng đồng","ghiChu":"@c0061"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân gốc của Chí Tôn Cốt được cấy vào thân nó","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"khac","quanHe":"Người cõng để vận Chí Tôn cốt","ghiChu":""},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Được cho là đoạt Chí Tôn cốt của Hạo nhi, liếc khinh","ghiChu":""},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Người cùng dòng họ hoàng thân cổ quốc"},{"ten":"Lục tẩu","tag":"cha-me","quanHe":"Mẹ ruột","ghiChu":"Kẻ chiết Chí Tôn cốt của Hạo cấy sang nó."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Em họ — kẻ bị nó cùng mẹ cướp Chí Tôn cốt","ghiChu":"Được mẹ hứa hai anh em bình bát hoang trấn vạn tộc, thực chất chiếm đoạt bảo cốt."},{"ten":"Bóng u linh","tag":"dong-minh","quanHe":"Kẻ phẫu thuật cấy cốt cho nó","ghiChu":"Rạch lồng ngực nó cấy Chí Tôn cốt."},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"mẹ ruột","ghiChu":"Cấy Chí Tôn Cốt cho con ruột, bị Tứ Thái Gia ném đập tường (@c0057)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"đường huynh đệ — nạn nhân","ghiChu":"Bị moi Chí Tôn Cốt cấy sang mình (@c0057)"},{"ten":"Tứ Thái Gia","tag":"ho-hang","quanHe":"tộc trưởng bối cao","ghiChu":"Bị Thạch Nghị dùng tính mạng ép tha mẹ (@c0057)"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"tổ tiên chi mình","ghiChu":"Bảo vệ vì Chí Tôn Cốt trong người Thạch Nghị (@c0057)"},{"ten":"Bóng đen (u linh)","tag":"dong-minh","quanHe":"thuật sĩ cấy cốt cho mẹ","ghiChu":"Thực hiện thủ thuật cấy Chí Tôn Cốt (@c0057)"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"Mẹ ruột — người ra tay cắt xương Thạch Hạo để đoạt cốt cho con","ghiChu":"Chư lão gọi là độc phụ/ác phụ, giao cho Thạch Tử Lăng xử trí. @c0058"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Cha của Thạch Hạo — kẻ thề cắt một trăm cái xương của Nghị nhi để trả thù","ghiChu":"@c0058"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Bề trên nhánh bảo hộ","ghiChu":"Cùng xuất hiện chặn Thạch Tử Lăng (@c0059)"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"Mẹ ruột, ngoại tộc gả vào","ghiChu":"Bị Thạch Tử Lăng ném mâu ghim xuống đất @c0060"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"cha-me","quanHe":"mẹ ruột — bị Thạch Tử Lăng giết trước mắt","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"kẻ đánh gãy hơn trăm xương, giết mẹ nó","ghiChu":"@c0061"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"chủ nhân gốc của Chí Tôn Cốt bị cấy vào thân nó","ghiChu":"@c0061"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối thủ định mệnh — người của chi cổ quốc so kè với người của tổ địa Thạch Thôn.","ghiChu":"Nhắc tên qua thôn nhân @c0065."},{"ten":"Thập Tam gia","tag":"khac","quanHe":"Nhân vật Vũ Vương phủ mất tích, khiến phủ dồn sức bồi dưỡng hắn.","ghiChu":"@c0098"},{"ten":"Thạch Tử Lăng","tag":"khac","quanHe":"Kỳ tài cùng biến mất nhiều năm, liên quan lý do Vũ Vương phủ dốc sức vào hắn.","ghiChu":"@c0098"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0055","@c0057","@c0058","@c0059","@c0060","@c0061","@c0062","@c0056","@c0065","@c0090","@c0098","@c0097"]},{"id":"thap-ngu-gia","name":"Thập Ngũ Gia","aliases":["Lão Thập Ngũ","Thập Ngũ gia","Ông nội Thạch Hạo"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ quốc (hoàng thân)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0055)","trangThai":"song","blurb":"Ông lão trưởng bối trong ký ức Thạch Hạo, gia gia của Hạo Nhi; tiễn pháp tinh diệu, hai tên hạ Loan Điểu ở Thánh Hồ, sau còn bắn chết Tỳ Hưu ở Bách Tộc Chiến Trường.","vaiTro":"Cường giả tiễn pháp của dòng hoàng thân cổ quốc; người trực tiếp nhỏ bảo huyết Thần Cầm cho Hạo Nhi lúc còn quấn tã.","tinhCach":[{"text":"Cương quyết, sủng ái cháu trai, đặt kỳ vọng lớn","chuong":"@c0055"}],"tabs":{"diem":[{"text":"Tiễn pháp tinh diệu — hai tên hạ Loan Điểu, làm đô thành chấn động","chuong":"@c0055"},{"text":"Đích thân nhỏ bảo huyết Thần Cầm cho Hạo Nhi bất chấp cha mẹ đứa bé khuyên can","chuong":"@c0055"}],"kinhLich":[{"chuong":"@c0055","importance":"normal","tieuDe":"Bắn hạ Loan Điểu, nuôi Thạch Hạo bằng bảo huyết","text":"Dùng cung thân đen dây gân Giao, hai tên bắn hạ Cầm Vương Loan Điểu dài mười bảy mười tám mét có dòng máu Thái Cổ Thần Cầm tại Thánh Hồ; xẻ lấy bảo huyết quý nhất nhỏ cho Hạo Nhi (Thạch Hạo sơ sinh) uống; về sau còn bắn chết một con Tỳ Hưu trên Bách Tộc Chiến Trường làm chấn động bát hoang.; Dùng cung đen dây gân Giao bắn hai tên hạ một Loan Điểu (hậu duệ Thái Cổ Thần Cầm) dài mười bảy mười tám mét ở Thánh Hồ, được khen tiễn pháp tinh diệu; tự x…","anchor":"Lão Thập Ngũ, không ngờ tiễn pháp của ông đã trở nên tinh diệu như vậy, hai tên đã bắn hạ một con Loan Điểu mạnh mẽ."},{"chuong":"@c0056","importance":"major","tieuDe":"Bắn chết con Tỳ Hưu, bị đuổi giết mất tích","text":"Tại Bách tộc chiến trường bắn chết con của một Tỳ Hưu huyết mạch cực kỳ tinh thuần chuốc đại họa; bị con Tỳ Hưu điên cuồng đuổi giết mấy chục vạn dặm, bị chém đứt một cánh tay, xương cốt toàn thân gần như gãy nát; cuối cùng sai người dùng mấy khối bảo cốt Thái cổ di chủng xếp thành Thần trận mới thoát mạng, tăm tích không rõ, sống chết khó nói.; Tại Bách tộc chiến trường, bắn chết con của Tỳ Hưu huyết mạch cực kỳ tinh thuần; bị Tỳ Hưu điên cuồng…","anchor":"lão bị chém đứt một cánh tay, xương cốt toàn thân gần như gãy nát"},{"importance":"normal","chuong":"@c0059","tieuDe":"Chiến tích Loan Điểu và Tỳ Hưu được nhắc lại","text":"Các bề trên nhắc lại: Thập Ngũ Gia nổi danh cường đại tại Hoàng Đô, hai mũi tên bắn chết Thái Cổ Di Chủng Loan Điểu, dám bắn chết thú con Tỳ Hưu huyết mạch tinh khiết để lấy máu chân chính gột rửa thân thể cho cháu trai Thạch Hạo.; Được các bề trên nhắc lại danh tiếng cường đại tại Hoàng Đô: hai mũi tên bắn chết Thái Cổ Di Chủng Loan Điểu, bắn chết thú con Tỳ Hưu huyết mạch tinh khiết để lấy máu gột rửa thân thể cho cháu trai Thạch Hạo.","anchor":"hai mũi tên bắn chết một con Thái Cổ Di Chủng -- Loan Điểu"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trai (Hạo Nhi)","ghiChu":"Gia gia của Hạo Nhi trong ký ức. (@c0055)"},{"ten":"Cha mẹ Thạch Hạo","tag":"ho-hang","quanHe":"Con trai và con dâu (đôi vợ chồng trẻ gọi ông là Cha)","ghiChu":"Đôi vợ chồng trẻ định khuyên can khi ông nhỏ bảo huyết cho Hạo Nhi. (@c0055)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trai (Hạo Nhi); ông đích thân cho uống bảo huyết Thần Cầm khi bé.","ghiChu":"@c0055"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Con trai","ghiChu":"Được khen sinh con trai giỏi"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trai","ghiChu":"Từng lấy máu Tỳ Hưu gột rửa thân thể cho cháu"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu (Hạo Nhi); đích thân nhỏ bảo huyết Thần Cầm cho uống, kỳ vọng tương lai vượt xa gia gia và cha","ghiChu":"@c0055"},{"ten":"Cha mẹ Thạch Hạo","tag":"ho-hang","quanHe":"Con và con dâu; đôi vợ chồng trẻ gọi ông là Cha, định khuyên can việc cho con uống bảo huyết","ghiChu":"@c0055"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trai (gọi Hạo Nhi)","ghiChu":"Nhỏ bảo huyết Thần Cầm cho Hạo uống, kỳ vọng tương lai vượt xa cha ông. @c0055"},{"ten":"Thập Nhất đệ","tag":"cha-me","quanHe":"Con trai","ghiChu":"Cha Thạch Hạo, đi tìm Thập Ngũ gia ở Nam Cương"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu nội","ghiChu":"Trời sinh Chí Tôn cốt"},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Con dâu","ghiChu":"Mẹ Thạch Nghị, vợ một huynh trưởng khác"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trong dòng họ, được lão nhỏ bảo huyết Thần Cầm bồi bổ từ sơ sinh","ghiChu":"@c0055"},{"ten":"Thập Nhất đệ","tag":"cha-me","quanHe":"Con trai (một trong nhiều con)","ghiChu":"Người quyết đi Nam Cương tìm cứu."},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Con dâu (vợ một huynh trưởng của Thập Nhất đệ)","ghiChu":"Ở lại chăm cháu, thực chất chiết xương cháu chồng."}],"tuiDo":{"phapBao":[{"ten":"Cung đen dây gân Giao","trangThai":"dang-co","moTa":"Cung thân màu đen, dây bằng gân Giao, phát sát khí mãnh liệt; bắn ra mũi tên như Giao Long hào quang ngập trời.","nguon":"@c0055"}],"danDuoc":[],"congPhap":[{"ten":"Tiễn pháp tinh diệu","moTa":"Kỹ xạ tiễn hai tên hạ Loan Điểu, đủ khiến đô thành chấn động.","nguon":"@c0055"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0055","@c0059","@c0056"]},{"id":"nhan-hoang-co-quoc","name":"Nhân Hoàng","aliases":["Nhân Hoàng cổ quốc","Nhân Hoàng của cổ quốc"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ quốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ — đứng trong vầng thái dương vàng như Thiên Đế (@c0055)","trangThai":"song","blurb":"Kẻ thống trị sơn hà hàng tỉ dặm của cổ quốc; đích thân chủ trì đại lễ cả nước tế trời trong ký ức thân thế của Thạch Hạo.","vaiTro":"Chí tôn cổ quốc, cùng huyết mạch hoàng tộc với dòng họ Thạch Hạo.","tabs":{"diem":[{"text":"Đứng trong vầng thái dương vàng chói, huyết khí vàng phóng ra như một vị Thiên Đế","chuong":"@c0055"}],"kinhLich":[{"chuong":"@c0055","importance":"normal","tieuDe":"Tự mình tế trời trong ký ức cổ quốc","text":"Trong ký ức của Thạch Hạo, Nhân Hoàng của cổ quốc — kẻ thống trị sơn hà hàng tỉ dặm — đứng trong vầng thái dương vàng, tự mình tế trời vô cùng trịnh trọng, sau lưng là cường giả hoàng tộc, đại chư hầu, thần tử và quân đội vô tận.","anchor":"Đây là Nhân Hoàng của cổ quốc, kẻ thống trị sơn hà hàng tỉ dặm, hiện tại đang tự mình tế trời, vô cùng trịnh trọng."},{"text":"Nghe tin tổ địa thứ hai của Thạch Tộc bị thiêu rụi, Nhân Hoàng đáp bốn chữ “Điều tra tới cùng”; thủ dụ hóa hào quang tận trời như bốn thanh Tiên Kiếm chém tan tầng mây trên Hoàng Đô, khiến cả kinh đô câm lặng.","anchor":"bốn chữ như bốn thanh Tiên Kiếm đánh tan tầng mây ở trên bầu trời Hoàng Đô","bridge":true,"khoang":"@c0076"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cùng dòng hoàng huyết (hoàng thân)","ghiChu":"Dòng họ Thạch Hạo có hoàng huyết, theo quy củ có thể tranh ngôi Nhân Hoàng. (@c0055)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Dòng họ Thạch Hạo là hoàng thân dưới cổ quốc do Nhân Hoàng thống trị, cùng mang hoàng huyết.","ghiChu":"@c0055"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Hoàng thân cùng cổ quốc","ghiChu":"Dòng họ Thạch Hạo là hoàng thân mang hoàng huyết trong cổ quốc do Nhân Hoàng thống trị @c0055"},{"ten":"Chiến Vương","tag":"khac","quanHe":"Tin tưởng và phái Chiến Vương cùng các Vương Hầu đi điều tra tới cùng","ghiChu":"@c0076"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0055","@c0076"]},{"id":"tu-thai-gia","name":"Tứ Thái Gia","aliases":["Tứ ca","Ông lão như Hoàng Kim Sư Tử","Ông lão như Hoàng Kim Thần Hỏa","Lão Tứ","ông lão như Hoàng Kim Sư Tử","Hoàng Kim Thần Hỏa","ông lão như Hoàng Kim Thần Hỏa"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một trong hai lão chủ sự bối phận cực cao của Thạch Tộc, được cha mẹ Thạch Hạo gửi trông cháu; phá cửa địa cung cứu Thạch Hạo khỏi âm mưu đoạt Chí Tôn Cốt.","vaiTro":"Trưởng bối bảo hộ Thạch Hạo","tinhCach":[{"text":"Cương liệt, dứt khoát; giận dữ có thể ném người đập tường","chuong":"@c0057"},{"text":"Trọng tình nghĩa với vợ chồng Tử Lăng: ôm cháu khóc xin lỗi","chuong":"@c0057"}],"tabs":{"diem":[{"text":"Bối phận cực cao, thực lực cực mạnh, thường ẩn tu trong cổ động tham ngộ diệu lý","chuong":"@c0057"},{"text":"Hào quang vạn trượng, oai vệ như Hoàng Kim Sư Tử/Hoàng Kim Thần Hỏa","chuong":"@c0057"}],"kinhLich":[{"importance":"normal","chuong":"@c0057","tieuDe":"Phá cửa địa cung cứu Thạch Hạo","text":"Được cha mẹ Thạch Hạo gửi nhờ trông cháu, hôm nay thiếu phụ dẫn hai đứa bé đi xem hậu duệ Thái Cổ Thần Cầm rồi vào địa cung không mở nổi cửa; ông phá hủy lối vào xông vào, nhấc cổ thiếu phụ như nhấc gà, gào mắng con tiện nhân độc ác, ném thiếu phụ đập tường vỡ đá; ôm Hạo Nhi vào lòng vận Bảo Phù phát thụy hà cứu chữa, khóc xin lỗi Tử Lăng; cảnh cáo khi Tử Lăng về sẽ chém tám phần mười chi thiếu phụ để đòi công đạo.; Cơn giận trút vào thiếu phụ…","anchor":"không chém tận giết tuyệt chi của ngươi cũng phải giết tám phần mười"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão Ngũ","tag":"dong-hanh","quanHe":"Cùng làm chủ sự trong Thạch Tộc; bất đồng vì Lão Ngũ bao che hậu nhân chi mình","ghiChu":"@c0057"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu được cha mẹ gửi trông nom; đích thân ôm cứu chữa bằng Bảo Phù","ghiChu":"@c0057"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Cháu bên chi Lão Ngũ mang Chí Tôn Cốt của Thạch Hạo; bị Tứ Thái Gia phẫn nộ nhưng không giết được","ghiChu":"@c0057"},{"ten":"Tử Lăng","tag":"dong-minh","quanHe":"Cha Thạch Hạo, thân tình cực sâu; Tứ Thái Gia khóc xin lỗi vợ chồng ông và tin ông sẽ trở về đòi công đạo","ghiChu":"@c0057"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Cháu được nhờ trông nom, ra tay cứu chữa","ghiChu":""},{"ten":"Lão Ngũ","tag":"dong-minh","quanHe":"Chủ sự thứ hai trong tộc, tranh cãi về việc xử thiếu phụ","ghiChu":""},{"ten":"Thiếu phụ","tag":"doi-thu","quanHe":"Kẻ hại cháu, bị ông nhấc cổ và ném đập tường","ghiChu":""},{"ten":"Thạch Tử Lăng","tag":"khac","quanHe":"Cha Thạch Hạo, được ông khóc xin lỗi và nhắc sẽ trở về đòi công đạo","ghiChu":""},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"cháu chắt — được bảo hộ","ghiChu":"Vận Bảo Phù cứu Hạo Nhi sau khi bị moi cốt (@c0057)"},{"ten":"Tử Lăng","tag":"khac","quanHe":"cha của cháu chắt được trông nom","ghiChu":"Khóc xin lỗi vì để cháu bị hại (@c0057)"},{"ten":"Lão Ngũ","tag":"dong-minh","quanHe":"đồng chủ sự Thạch Tộc","ghiChu":"Bị Lão Ngũ ngăn không cho giết thiếu phụ (@c0057)"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"doi-thu","quanHe":"hậu bối chi Lão Ngũ — kẻ hại","ghiChu":"Nhấc cổ, ném đập tường vì moi Chí Tôn Cốt Hạo Nhi (@c0057)"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"cháu chắt chi Lão Ngũ","ghiChu":"Bị Thạch Nghị dùng dao bạc kề cổ ép tha mẹ (@c0057)"}],"tuiDo":{"phapBao":[{"ten":"Bảo Phù","loai":"phap-bao","trangThai":"dang-co","moTa":"Pháp bảo cứu chữa của Tứ Thái Gia; vận chuyển phát ra thụy hà bọc lấy Thạch Hạo để cứu.","nguon":"@c0057"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0057"]},{"id":"lao-ngu","name":"Lão Ngũ","aliases":["Ngũ Thái Gia","Ông lão như Huyết Hoàng","ông lão như Huyết Hoàng"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Chủ sự thứ hai bối phận cực cao trong Thạch Tộc, toàn thân xích hà, hai mắt như kim đăng; ngăn Tứ Thái Gia giết thiếu phụ để bảo toàn Chí Tôn Cốt mới cấy sang Thạch Nghị (hậu nhân chi mình).","vaiTro":"Trưởng bối chi thiếu phụ; đối lập ngầm với Tứ Thái Gia","tinhCach":[{"text":"Thiên vị hậu nhân chi mình, viện Chí Tôn Cốt để can thiệp cứu người trong chi","chuong":"@c0057"}],"tabs":{"diem":[{"text":"Toàn thân tỏa xích hà như Huyết Hoàng, hai mắt như kim đăng","chuong":"@c0057"},{"text":"Cùng Tứ Thái Gia thường ẩn tu cổ động, tham ngộ diệu lý, bình thường không lộ diện","chuong":"@c0057"}],"kinhLich":[{"importance":"major","chuong":"@c0057","tieuDe":"Ngăn Tứ Thái Gia giết thiếu phụ, giữ Chí Tôn Cốt","text":"Đi vào địa cung ngay sau Tứ Thái Gia, tỏa xích hà, khuyên Tứ ca hạ thiếu phụ xuống; viện lý do Thạch Tộc vừa mất một vị Chí Tôn (Thạch Hạo) không thể để thêm một đứa trẻ trọng đồng (Thạch Nghị, giờ mang Chí Tôn Cốt) chết đi — đó là Thánh Nhân, Thần Nhân thời Thượng Cổ; bị Tứ Thái Gia mắng thiên vị hậu nhân chi mình.; Tỏa xích hà như Huyết Hoàng bước vào, ngăn Tứ ca giết thiếu phụ, viện lý do Thạch Tộc vừa mất một Chí Tôn nên không thể để đứa bé…","anchor":"chúng ta đã mất đi một vị Chí Tôn, lẽ nào còn phải mở to mình nhìn một thằng bé trọng đồng khác chết đi sao"},{"chuong":"@c0058","importance":"normal","tieuDe":"Chủ trương giữ Chí Tôn cốt cho Thạch Tộc","text":"Trong đại hội trưởng lão, khẳng định Chí Tôn phải thuộc về Thạch Tộc, không thể để tan biến; sau đó báo tin Chí Tôn cốt đã hoà làm một thể với Nghị nhi (thuộc chi của lão) được máu thịt bồi dưỡng, khiến cả điện chấn động.; Tại đại hội trưởng lão, khẳng định Chí Tôn phải thuộc về Thạch Tộc, không thể để tan biến; sau đó báo tin Chí Tôn cốt đã dung hợp thành công vào thân Thạch Nghị thuộc chi của hắn.; Trong đại hội trưởng lão, người đầy Xích Hà l…","anchor":"Chí tôn phải là của Thạch Tộc ta , quyết không thể vì vậy mà tan biến."},{"text":"Xuất hiện cuối chương chặn Thạch Tử Lăng, quanh người xích hà bao phủ như Huyết Hoàng Niết Bàn, con ngươi màu vàng như hai ngọn đèn bằng vàng; hỏi Thạch Tử Lăng đã giết đủ chưa, bớt giận chút nào chưa.; Cuối chương xuất hiện phía trước, quanh người xích hà bao phủ như Huyết Hoàng Niết Bàn, con ngươi màu vàng như hai ngọn đèn; hỏi Thạch Tử Lăng đã giết đủ chưa và ra mặt bảo hộ nhánh Thạch Nghị.","anchor":"cắt một cái Chí Tôn cốt của con ta thì trả đây một trăm cái xương đi","bridge":true,"khoang":"@c0059"}],"tuViMoc":[],"nhanMach":[{"ten":"Tứ Thái Gia","tag":"dong-hanh","quanHe":"Cùng làm chủ sự trong Thạch Tộc; đối lập vì bao che chi mình","ghiChu":"@c0057"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Hậu nhân chi Lão Ngũ; được ông cứu mạng gián tiếp bằng cách giữ mẹ","ghiChu":"@c0057"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Con cháu thuộc chi trực tiếp của hắn, được cấy Chí Tôn cốt.","ghiChu":"@c0058"},{"ten":"Thạch Nghị","tag":"dong-minh","quanHe":"Đứng cạnh bảo hộ","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Chặn tại cứ địa nhánh Thạch Nghị","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ chặn đường cuối chương","ghiChu":""},{"ten":"Thạch Nghị","tag":"dong-minh","quanHe":"Bảo hộ","ghiChu":"Đứng cạnh chặn Thạch Tử Lăng"},{"ten":"Thiếu phụ","tag":"ho-hang","quanHe":"Hậu nhân chi mình, ông đứng ra bảo vệ","ghiChu":""},{"ten":"Tứ Thái Gia","tag":"dong-minh","quanHe":"Chủ sự cùng tộc, tranh cãi về việc xử thiếu phụ","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Hậu nhân chi mình, mang Chí Tôn Cốt cần được bảo vệ","ghiChu":""},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cháu thuộc chi của Lão Ngũ","ghiChu":"@c0058"},{"ten":"Thạch Nghị","tag":"dong-minh","quanHe":"Người được bảo hộ","ghiChu":"Đứng cạnh chặn Thạch Tử Lăng"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Chặn khi Thạch Tử Lăng phát điên báo thù"},{"ten":"Tứ Thái Gia","tag":"dong-minh","quanHe":"đồng chủ sự Thạch Tộc","ghiChu":"Ngăn Tứ ca giết thiếu phụ (@c0057)"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"ho-hang","quanHe":"hậu nhân chi mình","ghiChu":"Bao che vì thuộc chi ông (@c0057)"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"hậu nhân chi mình — mang Chí Tôn Cốt","ghiChu":"Viện Chí Tôn Cốt để giữ mạng (@c0057)"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chí Tôn Cốt gốc bị moi","ghiChu":"Nhắc như vị Chí Tôn đã mất của tộc (@c0057)"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cháu thuộc chi của lão, người dung hợp Chí Tôn cốt","ghiChu":"@c0058"},{"ten":"Tứ Thái Gia","tag":"dong-hanh","quanHe":"Cùng dự đại hội trưởng lão, đối lập chủ trương xử trí (Lão Tứ đòi trả cốt cho Hạo)","ghiChu":"@c0058"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Chặn Thạch Tử Lăng cuối chương (@c0059)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0057","@c0058","@c0059"]},{"id":"thach-tu-lang","name":"Thạch Tử Lăng","aliases":["Lão thập nhất","Tử Lăng","Thập Nhất đệ","lão thập nhất","Trương Tử Lăng","Thiên Huyễn Tinh"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Cha ruột của Thạch Hạo, xếp thứ mười một trong thế hệ đương thời của Thạch Tộc; tu vi cực mạnh, sử dụng Hoàng Kim thần mâu.","vaiTro":"Cha Thạch Hạo, chiến lực trục của bổn tộc; trở về sau chuyến tìm cha thất bại thì phát hiện con bị đoạt Chí Tôn cốt, quyết đại khai sát giới báo thù.","tinhCach":[{"text":"Nóng nảy, cương liệt, thương con sâu sắc — vừa rơi lệ vừa muốn giết","chuong":"@c0058"},{"text":"Khinh sinh tử, không nể địa vị khi báo thù cho con","chuong":"@c0058"}],"tabs":{"diem":[{"text":"Xếp thứ 11 thế hệ trong Thạch Tộc, được gọi lão thập nhất","chuong":"@c0058"},{"text":"Uy lực áp đảo trưởng lão bản tộc, một mâu phá tan cung điện","chuong":"@c0058"}],"kinhLich":[{"text":"Cha Thạch Hạo, hiện đi xa; được Tứ Thái Gia gọi tên khi khóc xin lỗi và cảnh cáo rằng khi trở về sẽ tận diệt chi thiếu phụ để đòi công đạo cho con.","anchor":"Tử Lăng, ta thật có lỗi với vợ chồng hai ngươi","bridge":true,"khoang":"@c0057"},{"chuong":"@c0058","importance":"major","tieuDe":"Đại náo phủ đệ, thề cắt trăm xương báo thù","text":"Sau một tháng đi tìm Thập Tam gia không thấy, trở về gặp con trai suy kiệt vì bị đoạt Chí Tôn cốt; cầm Hoàng Kim thần mâu phá tan mảnh cung điện, xông về nhánh Thạch Nghị; đánh bay chư lão ngăn cản, giết chú ruột của Nghị nhi bằng một mâu xuyên ngực; tuyên thệ mụ ta cắt một xương của con hắn thì hắn cắt trăm xương của con mụ, vừa rơi lệ vừa quyết đại khai sát giới.; Trở về sau một tháng không tìm được Thập Tam gia, thấy con suy yếu liền phẫn nộ…","anchor":"Mụ ta cắt một cái xương của con ta, ta cắt một trăm cái xương của con mụ!"},{"importance":"major","chuong":"@c0059","tieuDe":"Phát điên đại khai sát giới","text":"Vì con bị cướp Chí Tôn cốt, Thạch Tử Lăng phát điên xông vào phủ mạch nhánh Thạch Nghị; tóc tung bay hoàng kim, cầm chiến mâu nguyên thủy phù văn, vận Bảo Thuật chư thiên thần linh đánh nát chuỗi cốt châu của lão bề trên, hạ liên tiếp lão quạt lông Phong Lôi và lão bảo cụ dây leo; phá sát trận bảo cốt, triệu hung thú Thái cổ tàn sát hơn trăm tử sĩ Vương tộc; cuối cùng bị Lão Ngũ và Thạch Nghị chặn lại, tuyên bố nợ máu trả máu — cắt một Chí Tôn c…","anchor":"cắt một cái Chí Tôn cốt của con ta thì trả đây một trăm cái xương đi"},{"importance":"major","chuong":"@c0060","tieuDe":"Đại chiến Thạch Uyên đòi Chí Tôn Cốt","text":"Đối đầu chi Thạch Uyên đòi trả Chí Tôn Cốt cho con; đại chiến Thạch Uyên bằng chiến mâu vàng phủ thần phù và bóng Thái Cổ Hung Thú, đâm chết Thái Cổ Hung Cầm rồi đâm xuyên vai Thạch Uyên phế nửa cánh tay; vạch mặt Thạch Nghị là kẻ tố giác Chí Tôn Cốt; công khai tuyên bố làm phản, dùng ký hiệu Bảo Thuật lạ xuyên qua phòng ngự tộc lão đánh trọng thương Thạch Nghị rồi phóng mâu ghim thiếu phụ mẹ Thạch Nghị xuống đất; Trước cả đám tông lão thiên hướ…","anchor":"Làm phản thì đã sao? Ta đã nói rồi, ai cũng không thể ngăn được!"},{"importance":"major","chuong":"@c0061","tieuDe":"Giết thiếu phụ mẹ Nghị Nhi","text":"Vẫy tay rút chiến mâu khiến thân thiếu phụ (mẹ Thạch Nghị) nổ tung gần nửa, chết ngay tại chỗ; sau đó vạch mặt bốn lão tổ ẩn thân, đâm chết một tộc lão chi thứ cáo mượn oai hùm và đánh trọng thương lão nhân hùng tráng ra bắt hắn; đòi trả Chí Tôn Cốt cho con.; Áp đảo cả đám tông lão như Hoàng Kim Chiến Thần, phẫn nộ vì con Hạo Nhi bị cướp Chí Tôn Cốt đến thoái hóa hấp hối; vẫy tay rút chiến mâu khiến thân thiếu phụ mẹ Thạch Nghị nổ tung gần nửa m…","anchor":"Cơ thể trực tiếp nổ tung gần một nửa."},{"chuong":"@c0062","importance":"major","tieuDe":"Đại chiến Thạch phủ, bị đày Man Hoang","text":"Cầm hoàng kim chiến mâu, thân hiện Thái cổ hung thú, một mình đơn đấu bốn vị lão tổ Thạch tộc trong Thạch phủ Hoàng Đô để đòi công đạo cho Hạo nhi, áp đảo khiến bốn đại cao thủ liên tục thổ huyết; bị bốn lão tổ ra tay trấn áp; sau đó cả nhà bị đày tới Man Hoang khổ địa (tổ địa thứ hai); được Tứ tổ lén trao tàn đồ dẫn tới tổ địa chính thức của Thạch tộc; thề nếu bất thành sẽ đi khắp Man Hoang tìm Thái Cổ Thần Sơn hái thánh dược cứu Hạo nhi, và nế…","anchor":"Thạch Tử Lăng như một vị thiên thần màu vàng, tung hoành xung kích giữa bốn đại cao thủ vây công mà vẫn chiếm cứ thượng phong"},{"chuong":"@c0076","importance":"normal","tieuDe":"Bị Vũ Tộc vu khống đẩy tội","text":"Cả Vũ Tộc lẫn Vũ Mông chọn Thạch Tử Lăng làm vật thế tội, bàn kế vu khống rằng đã phát hiện chính hắn phóng hỏa tổ địa để đẩy tội và tự bảo vệ; cùng lúc Chiến Vương lại được cho là rất thưởng thức kỳ tài trẻ tuổi này.","anchor":"Bảo Vũ Mông nhất định phải vu khống nói đã phát hiện được Thạch Tử Lăng"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai ruột, vốn là Chí Tôn nhưng bị đoạt cốt, khiến hắn nổi cơn thịnh nộ báo thù.","ghiChu":"@c0058"},{"ten":"Thập Tam gia","tag":"cha-me","quanHe":"Cha ruột, đang mất tích, hắn tìm cả tháng không thấy tung tích.","ghiChu":"@c0058"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đứa bé được cấy Chí Tôn cốt của con hắn, trở thành mục tiêu báo thù.","ghiChu":"@c0058"},{"ten":"Tứ thái gia","tag":"ho-hang","quanHe":"Trưởng lão bổn tộc, tự nhận lỗi với hắn về việc để Hạo bị hại.","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (nhóc tỳ) bị cướp Chí Tôn cốt — động cơ báo thù","ghiChu":"@c0059"},{"ten":"Thập Ngũ Gia","tag":"cha-me","quanHe":"Cha ruột — nổi danh Hoàng Đô","ghiChu":"@c0059"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối thủ trực tiếp trong nội tộc — kẻ đoạt Chí Tôn cốt của con hắn","ghiChu":"@c0059"},{"ten":"Lão Ngũ","tag":"doi-thu","quanHe":"Bề trên phe bảo hộ Thạch Nghị chặn hắn cuối chương","ghiChu":"@c0059"},{"ten":"Thạch Uyên","tag":"doi-thu","quanHe":"Tông lão chi thứ 5 của Thạch tộc, chủ mưu đoạt Chí Tôn Cốt; bị hắn đại chiến, đâm xuyên vai và phế một nửa cánh tay tại phụ đệ.","ghiChu":"@c0060"},{"ten":"Mẹ Thạch Nghị","tag":"doi-thu","quanHe":"Chị dâu, kẻ trực tiếp lấy Chí Tôn Cốt của Hạo Nhi ghép cho Thạch Nghị; bị hắn phóng mâu ghim xuống đất.","ghiChu":"@c0060"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ mang Chí Tôn Cốt bị cướp của con hắn; đứa bé trùng đồng phối hợp tứ đại tông lão quấy nhiễu Bảo Thuật của hắn","ghiChu":"@c0061"},{"ten":"Mẹ Thạch Nghị","tag":"doi-thu","quanHe":"Thiếu phụ bị hắn đích thân giết bằng chiến mâu để dứt tình dứt nợ với Thạch tộc","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"doi-thu","quanHe":"Cửu thái gia được Thạch Nghị cõng, xông vào chém suýt trúng đầu hắn, cắt rơi một sợi tóc","ghiChu":"@c0061"},{"ten":"Bốn vị lão tổ Thạch tộc","tag":"doi-thu","quanHe":"Bậc tối cao khóa thiên địa vây quanh hắn, dụ tiếp quản Thạch Phủ mười năm sau nhưng bị hắn cự tuyệt","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ (được cho là) đoạt Chí Tôn cốt của con trai Thạch Tử Lăng; bị Tử Lăng đối đầu để đòi công đạo.","ghiChu":"@c0062"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (nhóc tỳ bị đoạt Chí Tôn cốt)","ghiChu":"Ôm bảo bọc, phát điên báo thù vì con"},{"ten":"Mẹ Thạch Hạo","tag":"the-thiep","quanHe":"Thê tử","ghiChu":"Ôm con đi theo sau lưng hắn"},{"ten":"Thập Ngũ Gia","tag":"cha-me","quanHe":"Cha (Lão Thập Ngũ)","ghiChu":"Được bề trên khen sinh con trai giỏi"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối thủ — nhánh cướp Chí Tôn cốt","ghiChu":"Xuất hiện cuối chương chặn hắn"},{"ten":"Lão Ngũ","tag":"doi-thu","quanHe":"Đối thủ — phe bảo hộ Thạch Nghị","ghiChu":"Chặn hắn cuối chương"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột bị hại","ghiChu":""},{"ten":"Tứ Thái Gia","tag":"khac","quanHe":"Chủ sự trong tộc trông nom con giúp, hứa đòi công đạo","ghiChu":""},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đứa bé mang Chí Tôn cốt của con hắn, bị nhắm giết để báo thù","ghiChu":"@c0058"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"doi-thu","quanHe":"Ác phụ đã cắt xương con hắn, đối tượng thù hận","ghiChu":"@c0058"},{"ten":"Thập Ngũ Gia","tag":"cha-me","quanHe":"Cha","ghiChu":"Lão Thập Ngũ, cha Thạch Tử Lăng, nổi danh cường đại tại Hoàng Đô"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối thủ nội tộc","ghiChu":"Nhánh khác Thạch tộc, đoạt Chí Tôn cốt của con Thạch Tử Lăng"},{"ten":"Lão Ngũ","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Phe bảo hộ Thạch Nghị, chặn Thạch Tử Lăng cuối chương @c0059"},{"ten":"Thạch Uyên","tag":"doi-thu","quanHe":"Tông lão chi thứ 5 mà Thạch Tử Lăng đại chiến, đâm xuyên vai","ghiChu":"@c0060"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Cháu chi Thạch Uyên, kẻ tố giác Chí Tôn Cốt, bị hắn đánh gãy hơn trăm xương","ghiChu":"@c0060"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Con trai bị đoạt mất Chí Tôn Cốt, nguồn cơn cuộc chiến","ghiChu":"@c0060"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Kẻ được cấy Chí Tôn Cốt của con hắn, đối đầu trong trận","ghiChu":"Trùng đồng của Thạch Nghị quấy nhiễu Bảo Thuật khiến hắn suýt gặp nạn"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột, chủ nhân gốc Chí Tôn Cốt bị cướp","ghiChu":"Vì con bị thoái hóa hấp hối mà hắn phẫn nộ đòi trả bảo cốt"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"doi-thu","quanHe":"Bị hắn rút chiến mâu giết chết","ghiChu":"@c0061"},{"ten":"Thạch Lạp","tag":"doi-thu","quanHe":"Tông lão cõng Thạch Nghị xông vào đánh hắn","ghiChu":"Giao Long Đao suýt trúng đầu, chém rơi một sợi tóc"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (Hạo nhi), bị mất Chí Tôn cốt","ghiChu":"Thề tìm tổ địa / Thái Cổ Thần Sơn cứu con"},{"ten":"Thạch Lạp","tag":"khac","quanHe":"Người cõng Thạch Nghị cưỡng vận Chí Tôn cốt","ghiChu":""},{"ten":"Vợ Thạch Tử Lăng","tag":"the-thiep","quanHe":"Vợ, cùng ôm con tham chiến","ghiChu":""},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Đối tượng báo thù — kẻ được cấy cốt của con hắn","ghiChu":"@c0058"},{"ten":"Thiếu phụ (mẹ Thạch Nghị)","tag":"doi-thu","quanHe":"Ác phụ cắt xương con hắn, bị chư lão giao cho hắn xử trí","ghiChu":"@c0058"},{"ten":"Thập Tam gia","tag":"cha-me","quanHe":"Cha ruột, mất tích một tháng không tìm được","ghiChu":"@c0058"},{"ten":"Tứ Thái Gia","tag":"ho-hang","quanHe":"Bậc trưởng lão trong tộc, tự nhận lỗi với vợ chồng Tử Lăng vì để Hạo bị hại","ghiChu":"@c0058"},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Chú bác trong Thạch tộc chặn Thạch Tử Lăng","ghiChu":"Xuất hiện cuối chương ngăn cản (@c0059)"},{"ten":"Thạch Uyên","tag":"doi-thu","quanHe":"Tông lão chi thứ 5, bậc trên một thế hệ","ghiChu":"Đối đầu vì Chí Tôn Cốt, bị Thạch Tử Lăng đâm xuyên vai phế nửa cánh tay @c0060"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"Cháu Thạch Uyên, kẻ được ghép Chí Tôn Cốt của con hắn","ghiChu":"Bị Thạch Tử Lăng đánh gãy hơn trăm cây xương @c0060"},{"ten":"Thạch Nghị","tag":"doi-thu","quanHe":"kẻ mang Chí Tôn Cốt của con trai hắn","ghiChu":"Thạch Tử Lăng đánh trọng thương Nghị Nhi rồi giết mẹ nó, đòi trả Chí Tôn Cốt (@c0061)"},{"ten":"Thạch Lạp","tag":"doi-thu","quanHe":"Cửu thái gia cõng Thạch Nghị xông vào chém suýt trúng đầu hắn","ghiChu":"@c0061"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"cha ruột — con bị cướp Chí Tôn Cốt","ghiChu":"phẫn nộ vì Hạo Nhi bị cướp bảo cốt, thân thoái hóa hấp hối (@c0061)"},{"ten":"Tứ tổ","tag":"ho-hang","quanHe":"trưởng bối lén giúp","ghiChu":"lén trao tàn đồ dẫn tới tổ địa chính thức Thạch tộc @c0062"},{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Vũ Mông vu khống đổ tội phóng hỏa cho Thạch Tử Lăng","ghiChu":"@c0076"},{"ten":"Chiến Vương","tag":"khac","quanHe":"Được Chiến Vương thưởng thức như kỳ tài trẻ tuổi","ghiChu":"@c0076"}],"tuiDo":{"phapBao":[{"ten":"Hoàng Kim thần mâu","loai":"binh khí","moTa":"Chiến mâu vàng phù văn lượn quanh; khi đâm ra thần quang vạn trượng, phù văn kết thành cây mâu bằng ánh sáng, một mâu đánh bay cả mảnh cung điện.","nguon":"@c0058"}]}},"nguon":["@c0059","@c0060","@c0061","@c0062","@c0057","@c0058","@c0076"]},{"id":"a-man","name":"A Man","gioiTinh":"nu","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Bé gái thân thiết chăm sóc Thạch Hạo sau khi hắn bị đoạt Chí Tôn cốt và suy thoái mất trí nhớ.","vaiTro":"Người bạn/người hầu nhỏ giữ hồi ức cho Thạch Hạo, khắc ghi thân phận Chí Tôn để hắn đừng quên chính mình lẫn nàng.","tinhCach":[{"text":"Trọng tình, kiên trì — mỗi ngày khóc nhắc lại thân phận cho Hạo","chuong":"@c0058"}],"tabs":{"diem":[{"text":"Khóc nhắc đi nhắc lại cho Hạo hắn là Chí Tôn và nàng là A Man","chuong":"@c0058"},{"text":"Từng hứa dẫn Hạo đi xem Xích Vũ Hạc","chuong":"@c0058"}],"kinhLich":[{"chuong":"@c0056","importance":"normal","tieuDe":"Hạ nhân kể chuyện xưa cho Hạo nhi","text":"Tỷ tỷ hạ nhân trong Vương hầu phủ, hiền lành xinh đẹp, hay kể chuyện xưa cho tiểu Thạch Hạo, giới thiệu về Xích Vũ Hạc trong rừng cây khiến Hạo đòi ra xem.; Tỷ tỷ hạ nhân hiền lành xinh đẹp trong Vương hầu phủ, hay kể chuyện xưa cho tiểu Thạch Hạo nghe, giới thiệu về Xích Vũ Hạc; bị Lục tẩu coi là hạ nhân không đáng nghe.","anchor":"Nhóc tỳ xinh xắn khả ái lại hiền lành, chưa bao giờ bắt nạt con của hạ nhân trong nhà"},{"chuong":"@c0058","importance":"normal","tieuDe":"Khắc ghi thân phận Chí Tôn cho Hạo","text":"Ngày ngày chăm sóc nhóc tỳ đã suy thoái, khóc nhắc đi nhắc lại rằng hắn là Chí Tôn, dặn đừng quên nàng là A Man, nhắc chuyện định dẫn hắn đi xem Xích Vũ Hạc.; Chăm sóc Thạch Hạo đang suy thoái, khóc nhắc đi nhắc lại rằng hắn là Chí Tôn và đừng quên nàng là A Man; hứa dẫn hắn đi xem Xích Vũ Hạc.; Thấy Hạo dần quên mất mọi người, nàng khóc bên giường lặp đi lặp lại thân phận và tên mình để hắn đừng quên chính mình lẫn nàng.","anchor":"Ta nghe Tứ tổ nói, người là Chí Tôn, ai cũng không sánh được, thế nhưng lại bị người hại."},{"text":"Xuất hiện trong ký ức nhóc tỳ khi nghe cụm ‘Chí Tôn trời sinh’: một cô bé xinh đẹp mắt ngấn lệ đứng bên giường bệnh, căn dặn đứa bé gầy yếu vô thần, tự xưng nô tỳ và khẳng định thiếu gia là Chí Tôn trời sinh chân chính.","anchor":"Thiếu gia là Chí Tôn trời sinh chân chính, nô tỳ là A Man","bridge":true,"khoang":"@c0090"},{"importance":"normal","chuong":"@c0093","tieuDe":"Phá kỷ lục Song Tử Sơn","text":"Đến Sơ Thủy Địa trước ánh mắt đám đông chấn động hai giới, chọn tòa Song Tử Sơn cao hơn mấy trượng; giẫm chân khiến đại địa nứt nẻ tứ phương, không dùng Phù Văn bí lực mà chỉ bằng thân thể trùng thiên vượt qua đỉnh núi, phá kỷ lục hai năm chưa ai vượt của Thạch Nghị.","anchor":"chỉ cần thân thể đã trùng thiên mà lên như vậy rồi phá sương mù vượt lên tòa núi lớn kia"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Đối tượng nàng chăm sóc và cố khắc ghi trí nhớ; từng hứa dẫn hắn đi xem Xích Vũ Hạc.","ghiChu":"@c0058"},{"ten":"Tứ thái gia","tag":"khac","quanHe":"Bậc trên nàng nghe kể chuyện Hạo là Chí Tôn.","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Tiểu chủ nhân thân thiết","ghiChu":"Hay kể chuyện xưa cho Hạo nghe"},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Chăm sóc, thân thiết, nhắc hắn nhớ thân phận Chí Tôn","ghiChu":"@c0058"},{"ten":"Lục tẩu","tag":"cap-tren","quanHe":"Chủ nhân phủ","ghiChu":"Chê là hạ nhân đừng nghe lung tung, muốn dắt Hạo đi xem Loan Điểu, Ngũ Sắc Khổng Tước Vương."},{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Người nàng ngày đêm chăm sóc và tha thiết muốn hắn nhớ lại thân phận","ghiChu":"@c0058"},{"ten":"Tứ Thái Gia","tag":"an-nhan","quanHe":"Bậc trưởng bối mà nàng gọi là Tứ tổ, nghe từ ông chuyện Hạo là Chí Tôn","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Tự xưng là nô tỳ của thiếu gia (nhóc tỳ) trong ký ức mờ nhạt","ghiChu":"@c0090"}],"tuiDo":{}},"nguon":["@c0056","@c0058","@c0090","@c0093"],"aliases":["Nhóc tỳ","Thằng nhóc nhân thần cộng phẫn","Tiểu tử tham tài"]},{"id":"thap-tam-gia","name":"Thập Tam gia","gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"mat-tich","blurb":"Cha ruột của Thạch Tử Lăng, ông nội Thạch Hạo; mất tích đúng thời điểm Hạo bị đoạt Chí Tôn cốt.","vaiTro":"Trưởng bối bảo hộ Thạch Hạo trong bổn tộc, sự vắng mặt đột ngột gợi âm mưu có tổ chức tách người bảo hộ khỏi phủ đệ.","tabs":{"diem":[{"text":"Con của hắn là Thạch Tử Lăng (lão thập nhất)","chuong":"@c0058"}],"kinhLich":[{"chuong":"@c0058","importance":"major","tieuDe":"Mất tích trùng thời điểm cháu bị đoạt cốt","text":"Thạch Tử Lăng đi tìm cha suốt thời gian dài không hề tìm được, khi trở về mới hay Hạo (cháu ông) đã bị hại — gợi âm mưu có tổ chức tách người bảo hộ Hạo ra khỏi phủ.; Cha của Thạch Tử Lăng (ông nội Hạo) mất tích trùng thời điểm Thạch Hạo bị hại; Tử Lăng đi tìm một tháng không thấy.; Thạch Tử Lăng đi cả tháng vẫn không tìm được ông, đúng lúc Thạch Hạo bị móc Chí Tôn cốt tại phủ đệ.","anchor":"cũng không hề tìm được Thập Tam gia"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Con trai ruột, đi tìm ông một tháng không có kết quả.","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu nội, bị đoạt Chí Tôn cốt lúc ông mất tích.","ghiChu":"@c0058"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"Con trai — đi tìm ông suốt một tháng không thấy","ghiChu":"@c0058"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu nội","ghiChu":"@c0058"}],"tuiDo":{}},"nguon":["@c0058"]},{"id":"me-thach-hao","name":"Mẹ Thạch Hạo","gioiTinh":"nu","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"blurb":"Vợ Thạch Tử Lăng, mẹ nhóc tỳ Thạch Hạo — ôm con đi theo chồng khi hắn phát điên đòi lại Chí Tôn cốt.","nguon":["@c0059","@c0062","@c0056"],"tabs":{"diem":[{"text":"Nhu tình, đau lòng vì đứa con thông minh hoạt bát bị thoái hoá","chuong":"@c0059"}],"kinhLich":[{"chuong":"@c0056","importance":"major","tieuDe":"Rời phủ theo chồng đi Bách tộc chiến trường","text":"Ôm con hôn thắm thiết khẳng định dù có Chí Tôn cốt vẫn phải cho con tuổi thơ vui vẻ; sau khi cha chồng bị Tỳ Hưu đuổi giết mất tích, kiên quyết theo chồng đi cứu vì hai Bảo thuật liên thủ mới đạt cực điểm, giao Hạo nhi cho Lục tẩu chăm sóc.; Được chồng thông báo Thạch Hạo trời sinh Chí Tôn cốt; thuyết phục chồng cho đi cùng vì hai Bảo thuật liên thủ đạt cực điểm; giao Hạo nhi cho Lục tẩu rồi cùng chồng lên đường tới Bách tộc chiến trường tìm Thậ…","anchor":"Cuối cùng vợ chồng hai người rời khỏi quốc gia cổ, tới Bách tộc chiến trường"},{"text":"Ôm con nhỏ, trên người phát hào quang lấp lánh, đi theo phía sau chồng; mắt ngấn lệ đau lòng vì đứa trẻ thông minh hoạt bát bị thoái hoá.","anchor":"một đứa trẻ thông minh hoạt bát lại bị thoái hoá thành như bây giờ","bridge":true,"khoang":"@c0059"},{"text":"Mẹ nhóc tỳ ôm con giết vào chiến trường, hợp lực Thạch Tử Lăng tế bảo thuật Tâm hữu linh tê nhất điểm thông, chấn động cả Hoàng Đô; sau đó ôm con lo lắng ở tổ địa thứ hai.","anchor":"Cuối cùng, mẹ của nhóc tỳ cũng tham chiến, nàng ôm nó, giết vào chiến trường","bridge":true,"khoang":"@c0062"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"the-thiep","quanHe":"Chồng","ghiChu":"@c0059"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (nhóc tỳ)","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"the-thiep","quanHe":"Trượng phu","ghiChu":"Đi theo sau lưng chồng trong cơn phá giết"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai","ghiChu":"Trời sinh Chí Tôn cốt"},{"ten":"Thập Nhất đệ","tag":"the-thiep","quanHe":"Chồng","ghiChu":"Cùng đi Bách tộc chiến trường"},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Chị dâu / tẩu tẩu","ghiChu":"Giao Hạo nhi cho Lục tẩu chăm"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột","ghiChu":"Đứa con trời sinh Chí Tôn cốt bà thương yêu."},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Chị dâu","ghiChu":"Nhờ chăm Hạo nhi — không biết là kẻ chủ mưu."}],"tuiDo":{}},"trangThai":"song"},{"id":"lao-gia-chuoi-cot-chau","name":"Lão già chuỗi cốt châu","gioiTinh":"nam","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"blurb":"Bề trên Thạch tộc mở màn tấn công Thạch Tử Lăng bằng chuỗi cốt châu Bảo Cụ; bị đánh bại gãy xương.","nguon":["@c0059"],"tabs":{"diem":[{"text":"Bề trên nắm Bảo Cụ chuỗi cốt châu quý hiếm","chuong":"@c0059"}],"kinhLich":[{"importance":"normal","chuong":"@c0059","tieuDe":"Chuỗi cốt châu bị đánh nát","text":"Lấy chuỗi cốt châu (mỗi viên như trứng ngỗng, ánh sáng như sao Ngoại Vực) tạo hình chư tinh giáng xuống phủ Thạch Tử Lăng; bị Thạch Tử Lăng vận Bảo Thuật kinh thiên đánh nổ tung dải ngân hà cốt châu, bản thân bị đánh văng gãy nhiều xương, đập nát cung điện.; Bề trên Thạch tộc mở màn tấn công Thạch Tử Lăng bằng chuỗi cốt châu tạo hình dải ngân hà chư tinh giáng xuống; bị Thạch Tử Lăng đánh nổ tung Bảo Cụ, gãy nhiều xương, đập nát cung điện.; Mở m…","anchor":"Một chuỗi cốt châu - một Bảo Cụ mạnh mẽ như vậy lại bị đánh nát"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị Thạch Tử Lăng đánh bại","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Bề trên chú bác — đối đầu","ghiChu":"Bị Thạch Tử Lăng đánh bại đầu tiên"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Tử Lăng đánh bại đầu tiên"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị đánh bại"}],"tuiDo":{"phapBao":[{"ten":"Chuỗi cốt châu","trangThai":"hong","moTa":"Bảo Cụ chuỗi hạt xương tạo hình chư tinh dải ngân hà, bị đánh nát","nguon":"@c0059"}]}},"trangThai":"khong-ro"},{"id":"lao-gia-quat-long-phong-loi","name":"Lão già quạt lông Phong Lôi","gioiTinh":"nam","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"blurb":"Bề trên Thạch tộc quát Thạch Tử Lăng dám làm phản, bị sấm sét vàng đánh cháy đen.","nguon":["@c0059"],"tabs":{"diem":[{"text":"Viện dẫn quyết định của hơn mười bề trên, quát Thạch Tử Lăng làm phản","chuong":"@c0059"}],"kinhLich":[{"text":"Cầm quạt lông lượn lờ Phong Lôi phất ra quầng sáng tím như Lôi Thần, quát Thạch Tử Lăng làm phản; bị sấm sét vàng đánh cháy đen, khói xanh bốc đầu, không rõ sống chết, rồi bị tia kim quang đánh bay vào cung điện.","anchor":"trên đầu lão bốc lên khói xanh không rõ sống chết nữa","bridge":true,"khoang":"@c0059"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị đánh trọng thương","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Bề trên chú bác — đối đầu","ghiChu":"Quát làm phản, bị đánh trọng thương"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Tử Lăng trọng thương"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị đánh bại"}],"tuiDo":{"phapBao":[{"ten":"Quạt lông Phong Lôi","trangThai":"hong","moTa":"Quạt lông tạo quầng sáng tím như Lôi Thần hiện thế, bị vỡ","nguon":"@c0059"}]}},"trangThai":"khong-ro"},{"id":"lao-gia-day-leo","name":"Lão già dây leo","gioiTinh":"nam","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"blurb":"Bề trên Thạch tộc dùng bảo cụ dây leo trói buộc, bị Thạch Tử Lăng đánh bay phun máu.","nguon":["@c0059"],"tabs":{"diem":[{"text":"Sử dụng bảo cụ thực vật hóa (nhánh dây thân nâu đen)","chuong":"@c0059"}],"kinhLich":[{"text":"Hô Trói buộc, phóng nhánh dây thực vật hóa bảo cụ như Giao Long lao trói Thạch Tử Lăng; bị mái tóc hoàng kim cắn nát dây, bảo cụ nổ tung hóa tro, bản thân bị đánh bay đụng nát tòa núi giả phun máu.","anchor":"bảo cụ dây leo kia lập tức nổ tung rồi bị thiêu thành một mảnh tro tàn","bridge":true,"khoang":"@c0059"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị đánh trọng thương","ghiChu":"@c0059"},{"ten":"Thạch Tử Lăng","tag":"ho-hang","quanHe":"Bề trên chú bác — đối đầu","ghiChu":"Bị đánh bay phun máu"}],"tuiDo":{"phapBao":[{"ten":"Nhánh dây bảo cụ","trangThai":"hong","moTa":"Thực vật hóa bảo cụ, thân nâu đen sáng óng ánh khi kích hoạt, phóng dây trói như Giao Long","nguon":"@c0059"}]}},"trangThai":"khong-ro"},{"id":"thach-uyen","name":"Thạch Uyên","aliases":["Ngũ gia","Thái gia","Thiên Huyễn Tinh"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch tộc Hoàng Đô","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tông lão xếp hàng thứ năm của Thạch tộc Hoàng Đô, ông nội Thạch Nghị; cường giả tuyệt đỉnh với Bảo Thuật hóa cánh Phượng Hoàng và Thái Cổ Hung Cầm Huyết Hoàng, chủ mưu đoạt Chí Tôn Cốt của Thạch Hạo ghép cho cháu ruột.","vaiTro":"Phản diện chi phái mở màn nội chiến Thạch tộc quanh Chí Tôn Cốt.","tinhCach":[{"text":"Cứng rắn, lấy sự phồn thịnh của tộc làm cớ để duy trì việc đoạt bảo cốt.","chuong":"@c0060"},{"text":"Tự tin vào Bảo Thuật đỉnh cao nhưng tính toán sai tốc độ và bí thuật của Thạch Tử Lăng.","chuong":"@c0060"}],"tabs":{"diem":[{"text":"Tu vi không thể dò, được xưng cường giả tuyệt đỉnh nổi danh Hoàng Đô.","chuong":"@c0060"},{"text":"Sở hữu Bảo Thuật hóa cánh thần Phượng Hoàng và triệu Thái Cổ Hung Cầm Huyết Hoàng.","chuong":"@c0060"},{"text":"Vì cháu ruột Thạch Nghị mà chủ trương giữ Chí Tôn Cốt của Thạch Hạo trên người cháu.","chuong":"@c0060"}],"kinhLich":[{"importance":"major","chuong":"@c0060","tieuDe":"Bại trận trước Thạch Tử Lăng","text":"Từ chối trả Chí Tôn Cốt, đòi bồi thường thứ khác vì phồn thịnh của tộc; vận Bảo Thuật hóa cánh Phượng Hoàng lông đỏ rồi triệu Thái Cổ Hung Cầm Huyết Hoàng giao chiến Thạch Tử Lăng; cuối cùng hung cầm bị đâm chết, bản thân bị đâm xuyên vai phế nửa cánh tay, mất chiến lực như già đi mười tuổi; Thái Cổ Hung Cầm bị Thạch Tử Lăng đâm chết; vai ông ta bị mũi mâu phủ ký hiệu đâm xuyên trước sau thông suốt, gồng Bảo Thuật giữ vết thương không lan nên cá…","anchor":"Chí Tôn Cốt đã bị lấy ra rồi, khó mà nối lại"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cháu ruột, người được ghép Chí Tôn Cốt lấy từ Thạch Hạo; ông chủ mưu bảo vệ cháu và cùng cháu phối hợp trùng đồng trong trận.","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Cháu vai dưới một thế hệ, kỳ tài Hoàng Đô; đối đầu trong phụ đệ và đâm xuyên vai ông, phế nửa cánh tay.","ghiChu":"@c0060"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nạn nhân bị chi ông đoạt Chí Tôn Cốt, cháu vai dưới hai đời — nguồn cơn xung đột cả chương.","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Cường giả trẻ đã đâm xuyên vai, đánh bại ông","ghiChu":"@c0060"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cháu, được ghép Chí Tôn Cốt và chỉ điểm nhược điểm cho ông trong trận","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bậc dưới một thế hệ, kẻ đòi lại Chí Tôn Cốt","ghiChu":"Đâm xuyên vai Thạch Uyên trong trận đấu @c0060"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cháu, người được ghép Chí Tôn Cốt","ghiChu":"Chỉ điểm nhược điểm cho ông trong trận đấu @c0060"}],"tuiDo":{"phapBao":[{"ten":"Bảo cốt Thái Cổ Di Chủng","loai":"bảo cốt","trangThai":"dang-co","moTa":"Cùng các tông lão khác dùng để phong tỏa phụ đệ, cách âm ngoại giới trong lúc nội chiến.","nguon":"@c0060"}],"congPhap":[{"ten":"Bảo Thuật Phượng Hoàng · Thái Cổ Hung Cầm Huyết Hoàng","loai":"Bảo Thuật hóa hình + triệu thần thú","moTa":"Hai tay hóa cánh thần Phượng Hoàng lông đỏ, tiếng phượng kêu chấn động; triệu Thái Cổ Hung Cầm Huyết Hoàng toàn thân đỏ rực, hào quang tím dâng trào — Bảo Thuật chí cường của tông lão.","nguon":"@c0060"}],"linhThu":[{"ten":"Thái Cổ Hung Cầm Huyết Hoàng","loai":"thần thú Bảo Thuật","trangThai":"da-dung","moTa":"Được triệu ra đấu bóng Thái Cổ Hung Thú của Thạch Tử Lăng; cuối trận bị Thạch Tử Lăng đâm chết trước khi vai ông ta bị xuyên.","nguon":"@c0060"}],"danDuoc":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0060"]},{"id":"me-thach-nghi","name":"Mẹ Thạch Nghị","gioiTinh":"nu","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"tu-vong","blurb":"Thiếu phụ Thạch tộc, mẹ ruột của Thạch Nghị, bị Thạch Tử Lăng giết bằng chiến mâu ngay trong phủ đệ khi hắn đòi trả Chí Tôn Cốt.","vaiTro":"Nhân vật phụ, ngòi nổ cho quyết định cực đoan giữa Thạch Tử Lăng và cả tộc","tabs":{"diem":[],"kinhLich":[{"text":"Bị chiến mâu vàng của Thạch Tử Lăng ghim, khi hắn rút mâu thì thân thể nổ tung gần nửa, con là Nghị Nhi gào lên định chữa nhưng bà đã tắt thở tại chỗ.","anchor":"Cơ thể trực tiếp nổ tung gần một nửa.","bridge":true,"khoang":"@c0061"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con trai ruột, chưa đủ bốn tuổi","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Kẻ trực tiếp đâm mâu giết bà giữa phủ đệ","ghiChu":"@c0061"}],"tuiDo":{}},"nguon":["@c0061"]},{"id":"thach-lap","name":"Thạch Lạp","aliases":["Cửu thái gia"],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Tông lão Thạch tộc (@c0061)","trangThai":"song","blurb":"Cửu thái gia của Thạch tộc, được Thạch Nghị chỉ đích danh gọi cõng để dùng trùng đồng gia trì nhìn thấu khe hở đòn đánh, xông vào đánh Thạch Tử Lăng.","vaiTro":"Tông lão trực tiếp tham chiến trong vụ vây Thạch Tử Lăng ở phủ đệ","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0061","tieuDe":"Cõng Nghị Nhi xông vào chém Thạch Tử Lăng","text":"Được Nghị Nhi xin cõng để dùng sức trùng đồng gia trì, nhìn thấu hư không thấy khe hở đòn đánh của Thạch Tử Lăng chậm lại; xông vào chém một thanh Giao Long Đao suýt trúng đầu Thạch Tử Lăng, cắt rơi một sợi tóc.; Tông lão được Thạch Nghị gọi Cửu thái gia, cõng nó lên và nhờ sức trùng đồng gia trì mà nhìn thấu hư không, thấy khe hở đòn đánh của Thạch Tử Lăng chậm lại; xông vào chiến trường vung Giao Long Đao suýt trúng đầu đối phương, cắt rơi một…","anchor":"Cửu thái gia cõng cháu với!"},{"chuong":"@c0062","importance":"normal","tieuDe":"Cõng Thạch Nghị vận Chí Tôn cốt, tinh khí thần bị thôn phệ","text":"Cõng Thạch Nghị ngưng kết cưỡng ép thôi thúc Chí Tôn cốt phát thần uy trong đại chiến Thạch phủ; chỉ sau đòn đó tinh khí thần bị thôn phệ sạch sẽ, thổ huyết, thân nứt rách, nửa người nổ tung; được lão tổ Thạch tộc dùng cánh tay chặn hoàng kim chiến mâu của Thạch Tử Lăng cứu mạng; Cõng Thạch Nghị cưỡng ép thôi thúc khối Chí Tôn cốt phát ra thần uy chấn động khiến người quan chiến muốn quỳ bái, nhưng đòn này thôn phệ sạch tinh khí thần của hắn; hắ…","anchor":"Nhưng chỉ sau đòn đánh này tinh khí thần của Thạch Lạp bị thôn phệ sạch sẽ"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Cửu thái gia của Nghị Nhi, được nó xin cõng để tham chiến","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ mà ông suýt chém trúng đầu nhờ trùng đồng gia trì","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Được nó xin cõng và gia trì trùng đồng","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ bị ông xông vào chém suýt trúng đầu","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"khac","quanHe":"Người được cõng để vận Chí Tôn cốt","ghiChu":""},{"ten":"Thạch Nghị","tag":"khac","quanHe":"cháu — được nó nhờ cõng gia trì trùng đồng","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"đối thủ trận chiến, bị hắn suýt bị chém trúng đầu","ghiChu":"@c0061"}],"tuiDo":{}},"nguon":["@c0061","@c0062"]},{"id":"bon-lao-to-thach-toc","name":"Bốn vị lão tổ Thạch tộc","gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Bậc tối cao ẩn thân của Thạch tộc, ngồi bốn phương, dùng bảo cốt Thái Cổ Di Chủng khóa cả thiên địa quanh phủ đệ, dụ Thạch Tử Lăng tiếp quản gia tộc mười năm sau nhưng chưa trực tiếp ra tay.","vaiTro":"Nhóm nhân vật phụ tầm cao, hé lộ tầng nền quyền lực Thạch tộc","tabs":{"diem":[],"kinhLich":[{"text":"Bậc tối cao Thạch tộc ẩn thân từ sớm, dùng bảo cốt Thái Cổ Di Chủng khóa mảnh thiên địa ngăn tiếng chiến đấu truyền ra; khi Thạch Tử Lăng vạch mặt thì bốn lão nhân hiện ra ở bốn phương với uy áp khủng bố nhưng chưa ra tay, hứa cho hắn mười năm sau tiếp quản Thạch Phủ.; Bị Thạch Tử Lăng vạch mặt vì đã ẩn thân từ sớm dùng bảo cốt Thái Cổ Di Chủng khóa mảnh thiên địa, bốn lão nhân đồng loạt hiện thân ở bốn phương với uy áp khủng bố, ra điều kiện mư…","anchor":"Bốn vị lão nhân hiện ra, phân biệt xuất hiện ở bốn phương.","bridge":true,"khoang":"@c0061"},{"text":"Tu vi cực cao, ẩn ở Thạch phủ, trấn phong tứ phương ngay khi vợ chồng Thạch Tử Lăng bước vào; một lão dùng cánh tay chặn lưỡi mâu cứu Thạch Lạp và Thạch Nghị, khuyên Tử Lăng dừng tay, hứa bồi thường cho Hạo nhi rồi cùng ba lão kia hợp vây trấn áp.; Bốn lão tổ tu vi cực cao ẩn ở Thạch phủ Hoàng Đô, trấn phong tứ phương; một lão dùng cánh tay chặn lưỡi mâu cứu Thạch Lạp và Thạch Nghị, khuyên Tử Lăng dừng tay và hứa bồi thường cho Hạo nhi, rồi cùng…","anchor":"Tử Lăng, cháu nên dừng tay lại","bridge":true,"khoang":"@c0062"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Kẻ bị họ dụ tiếp quản gia tộc nhưng cự tuyệt, đòi trả Chí Tôn Cốt","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"ho-hang","quanHe":"Đứa bé trùng đồng mang Chí Tôn Cốt được họ ngầm bảo vệ như hi vọng xưng tôn của tộc","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Kẻ họ ẩn thân theo dõi và dụ dỗ tiếp quản gia tộc","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Trấn áp trong trận đòi công đạo","ghiChu":""}],"tuiDo":{"phapBao":[{"ten":"Bảo cốt Thái Cổ Di Chủng","trangThai":"dang-co","moTa":"Dùng khóa mảnh thiên địa quanh phủ đệ, chặn tiếng chiến đấu truyền ra ngoài","nguon":"@c0061"}]}},"nguon":["@c0061","@c0062"],"aliases":["Tổ lão Thạch tộc","Bốn lão tổ Hoàng Đô","bốn tông lão"]},{"id":"chu-yem","name":"Con khỉ ba tay","aliases":["Con khỉ ba tay dưới đáy hồ","Mao Cầu","Tiểu Chu","bóng lông","quả bóng lông vàng","con khỉ ba tay","quả cầu vàng","con thú lông vàng","bóng lông vàng","Tiểu mao cầu","ba con chim non","Tiểu sơn thú","sinh linh ba đầu sáu tay","chim tước","Chu Yếm"],"gioiTinh":"nam","trangThai":"song","canhGioiCaoNhat":"Không rõ","blurb":"Sinh linh dài một thước nằm bất động dưới đáy hồ khô cạn, bị đất cát phủ nhiều năm, có ba cái tay, còn một con mắt sáng cho thấy chưa chết. (+) Sinh linh hình khỉ dài một thước có ba cái tay, bị lấp dưới đáy hồ khô cạn nhiều năm, con mắt còn sáng cho thấy chưa chết. [CAN-SOAT-GOP]","vaiTro":"Sinh linh kỳ dị Thạch Hạo phát hiện dưới đáy hồ khô cạn.","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0052","tieuDe":"Con khỉ ba tay dưới đáy hồ","text":"Được đám chim của Thạch Hạo phát hiện nằm bất động dưới đáy hồ khô cạn, khắp người bị đất cát vùi lấp như đã nhiều năm, chỉ còn một con mắt sáng cho thấy chưa chết; Thạch Hạo giật mình nhận ra con khỉ dài chừng một thước này có tới ba cái tay.; Nằm bất động dưới đáy hồ khô cạn, khắp người bị đất cát phủ như bị lấp nhiều năm, chỉ còn một con mắt sáng cho thấy chưa chết; Thạch Hạo phát hiện đó là con khỉ dài một thước có tới ba cái tay.; Một sinh…","anchor":"Sao nó lại có đến ba cái tay vậy"},{"importance":"normal","chuong":"@c0053","tieuDe":"Lột xác dưới đáy hồ và được thu nuôi","text":"Bị trọng thương kẹt một chân trong bùn cứng dưới đáy hồ khô, ba đầu sáu tay đói khát; khi bị Cốt Văn dò xét lần hai thì tỏa kim quang, toàn thân rạn nứt bong hết da cũ, thu Bảo Thuật về còn một đầu hai tay và co lại thành quả cầu vàng hơn ba tấc; ăn sạch túi thịt khô của nhóc tỳ, được mang về Thạch Thôn; cuối cùng lộ ra hai cái sừng ẩn trong lông vàng khiến nhóc tỳ đau lòng.; Bị trọng thương, một chân kẹt trong bùn cứng dưới đáy hồ khô cạn, được…","anchor":"Sinh linh nhìn giống như khỉ này đột nhiên tỏa kim quang khắp người"},{"importance":"normal","chuong":"@c0054","tieuDe":"Mao Cầu quậy phá Thạch thôn","text":"Quả cầu vàng kim to bằng nắm tay, cao ba tấc, chuyên trộm đồ ăn khắp thôn để khôi phục nguyên khí sau một năm bị nhốt dưới đáy hồ; bị Hổ thẩm đuổi đánh nhưng thân cứng như thiết thạch không hề đau, được Thạch Hạo đặt tên Tiểu Chu / Mao Cầu; trộm hàng chục quả trứng dị cầm; đêm định gặm chồi non cây liễu thì bị Liễu Thần trói treo giữa không trung, sau được thả vì là Di Chủng Thái Cổ có phù văn bể nát, quên hết quá khứ.; Chu Yếm — quả cầu vàng ki…","anchor":"nó không phải là khỉ, nó là con Chu Yếm đó"},{"importance":"normal","chuong":"@c0063","tieuDe":"Phản ứng bất an trước Nguyên Thủy Chân Giải","text":"Nhìn cục xương trắng thì cực kỳ bất an, gào thét nhào tới muốn ôm lấy, như đang gắng sức nhớ lại điều gì đó liên quan tới bảo cốt.; Đáp xuống vai nhóc tỳ sau khi sương mù tan; khi thấy cục xương trắng thì cực bất an, sốt ruột như đang gắng nhớ lại điều gì đó, gào thét nhào tới muốn ôm đoạt lấy.; Quả bóng lông vàng đáp xuống vai nhóc tỳ; khi thấy cục xương trắng thì phản ứng cực bất an, sốt ruột như đang gắng nhớ lại điều gì đó, gào thét nhào tới…","anchor":"Nó nhào về phía cục xương trắng tinh, muốn ôm vào trong lòng."},{"importance":"normal","chuong":"@c0064","tieuDe":"Lộ tên thật, bị chọn làm nguồn chủ dược","text":"Chương này lộ tên thật Chu Yếm (trước gọi bóng lông); ôm chặt cục xương Nguyên Thủy Chân Giải coi như của mình, mỗi ngày ăn hơn nửa con Long Giác Tượng; bị Liễu Thần định làm nguồn chủ dược, cách ngày hiến một giọt máu vàng dù nổi giận phản đối; khi máu nhỏ vào đỉnh phát tiếng chư thần ngâm xướng, ám chỉ thân phận cực tôn quý.; Ôm chặt cục xương Nguyên Thủy Chân Giải không buông. Ăn hơn nửa con Long Giác Tượng mỗi ngày. Bị Liễu Thần chọn làm ngu…","anchor":"Bảo nó cứ cách mỗi ngày hiến ra một giọt máu làm chủ dược là được rồi"},{"importance":"normal","chuong":"@c0065","tieuDe":"Tự uống thuốc luyện từ máu mình","text":"Sau khi lô thuốc luyện xong, bóng lông giật bát múc uống dù đây là thuốc nấu từ chính máu vàng của nó, khiến Nhị Mãnh trêu chọc.; Máu vàng của Chu Yếm được dùng làm chủ dược khiến đỉnh cổ tổ truyền cộng minh, sống lại, vách hiện hình tiên dân tế thiên và Thái Cổ Hung Thú, sinh ra dược căn óng ánh.","anchor":"Đây đã coi là một lô thuốc quý rồi!"},{"chuong":"@c0068","importance":"normal","tieuDe":"Bám theo và cảnh giác trên đường","text":"Bóng lông vàng to bằng nắm đấm, mỗi ngày ăn hơn nửa con Long Giác Tượng; đuổi theo Thạch Hạo khi rời thôn, bám đuôi Độc Giác Thú; chạy tới trưa được ba bốn nghìn dặm thì đột nhiên thét lên, lông tóc dựng đứng, hai mắt trợn to sốt ruột bất an như báo hiệu nguy hiểm sắp tới.","anchor":"bóng lông màu vàng to bằng nắm đấm thét lên, cả người lông tóc dựng đứng"},{"text":"Cảm ứng nguy hiểm dẫn nhóc tỳ tránh vùng núi tử khí; tự cắn da nhỏ ba giọt máu vàng kim chữa lành thương cho nhóc tỳ không để lại sẹo; trộm về một quả trứng ngũ sắc to như cối đá tỏa hào quang khiến thần cầm mẹ gào rú truy đuổi.","anchor":"nó ôm một cái trứng to như cối đá tỏa ra hào quang kinh người","bridge":true,"khoang":"@c0069"},{"text":"Ôm chặt trứng cướp về, dùng đá đục không được bèn trực tiếp gặm vỡ vỏ trứng để hút thần tinh, bị nhóc tỳ mắng phá gia chi tử; sau khi cả nhóm thoát sông đen, tuy mạnh hơn Thái Cổ Hung Thú non vẫn suýt bị đông chết, cuối cùng miễn cưỡng nhỏ một giọt máu vàng cứu sống Độc Giác Thú; cuối chương biết giả ngu, đổi da lông từ vàng sang xám trắng, mắt mất linh động để cảnh báo có người vây tới.","anchor":"Bóng Lông cũng lấy ra một giọt máu vàng một cách vô cùng không tình nguyện để cứu sống Độc Giác Thú","bridge":true,"khoang":"@c0070"},{"importance":"major","chuong":"@c0072","tieuDe":"Bị nghi là hung thú Chu Yếm","text":"To bằng nắm tay, đổi lông xám sang vàng, chân có màu đỏ thẫm; nhóm bà lão cảm ứng thấy đã ăn khí tức trứng hậu duệ Thái cổ thần điểu và nghi chính là Chu Yếm trong truyền thuyết — hung thú xuất thế gây đại loạn binh đao.","anchor":"Lẽ lào là Chu Yếm trong truyền thuyết?"},{"text":"Cùng Thạch Hạo đứng xa quan sát tổ địa rách nát trong Thạch quốc, cẩn thận đề phòng có mai phục.","anchor":"Cuối cùng Thạch Hạo cũng tiến vào bên trong Thạch quốc, đi đến cái tổ địa rách nát kia","bridge":true,"khoang":"@c0073"},{"text":"Ra ngoài một chuyến, Mao Cầu (Chu Yếm màu vàng, to bằng nắm đấm, kim quang lấp lánh trên vai Thạch Hạo) thuần phục được một con Độc Giác Nhân Hùng cao ba trượng có sừng vàng và cánh; nửa đêm điều nó bay tới điền trang cũ nát, đập sập phòng gác cổng ngồi đè nghiền nát hai gác cổng độc ác — tàn khốc hơn cả giết.","anchor":"chỉ có nửa thân trên lộ ra bên ngoài, nửa thân dưới bị nát bét","bridge":true,"khoang":"@c0074"},{"text":"Con thú nhỏ trên vai Thạch Hạo, hẹp hòi không chịu giúp Thanh Phong; chập tối cùng đám trẻ đi trộm trứng chim quý Tiểu Loan Điểu bên hồ xanh lam đem nướng ăn.","anchor":"Bọn nó định đi trộm trứng chim, là trứng của chim quý hiếm","bridge":true,"khoang":"@c0077"},{"text":"Bóng Lông khống chế vật cưỡi của đám hung khấu, giả kêu thảm vì sợ bị lấy máu; tức tối vì hạt bảo đan quý luyện từ máu mình đã bị Thạch Hạo dùng cạn, rồi vâng lệnh gọi bầy Cự thú xử lý toàn bộ hung khấu không sót một tên.","anchor":"toàn bộ bọn hung khấu đều phải đền tội","bridge":true,"khoang":"@c0085"},{"text":"Là Thái Cổ Thần Viên hiểu bảy mươi hai biến hóa nhưng phù văn bị phá nát nên chỉ còn tiểu biến hóa; biến từ màu vàng thành lông xám trắng phổ thông để không bị nhận ra; Thạch Hạo định dùng nó trừ sâu hái thuốc ở vườn thuốc Bổ Thiên các.","anchor":"Nhanh biến thành bộ dạng phổ thông, đừng để người ta nhận ra","bridge":true,"khoang":"@c0097"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được Thạch Hạo phát hiện dưới đáy hồ khô cạn","ghiChu":"Tử Vân, Đại Bằng ra hiệu có sinh vật sống dưới đáy hồ."},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Ân nhân cứu mạng, người nuôi dưỡng","ghiChu":"Nhóc tỳ tìm thấy, cho ăn và mang về Thạch Thôn."},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Người nhận diện thân phận","ghiChu":"Tộc trưởng nhận ra nó là di chủng Chu Yếm."},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Được Thạch Hạo đặt tên và bênh vực","ghiChu":"@c0054"},{"ten":"Liễu Thần","tag":"khac","quanHe":"Bị Liễu Thần trói khi định gặm chồi non, sau được thả ra","ghiChu":"@c0054"},{"ten":"Hổ thẩm","tag":"doi-thu","quanHe":"Bị Hổ thẩm đuổi đánh vì trộm giò thú","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Được Thạch Hạo và đám linh thú phát hiện dưới đáy hồ khô cạn","ghiChu":"@c0052"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Ân nhân cứu mạng, chủ nhân thu nuôi","ghiChu":"Được Thạch Hạo cho ăn, cứu khỏi đáy hồ và mang về thôn."},{"ten":"Liễu Thần","tag":"khac","quanHe":"Bị Liễu Thần trói treo khi định gặm chồi liễu rồi được thả","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Thú cưng nhảy nhót trên vai Thạch Hạo","ghiChu":"@c0072"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"bạn đồng hành","ghiChu":"Đồng hành tới tổ địa rách nát (@c0073)"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Đi theo bám đuôi trên hành trình tới Cổ quốc","ghiChu":"@c0068"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Chủ nhân (Bóng Lông của Thạch Hạo)"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được Thạch Hạo phát hiện dưới đáy hồ","ghiChu":"@c0052"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Người phát hiện ra nó dưới đáy hồ","ghiChu":"Thạch Hạo cùng Tử Vân, Đại Bằng, Tiểu Thanh tìm thấy khi thám sát di tích chiến trường. @c0052"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Ân nhân","ghiChu":"Được Thạch Hạo phát hiện dưới đáy hồ, cho ăn, dùng Cốt Văn dò xét và mang về Thạch Thôn nuôi (@c0053)"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Người nhận diện","ghiChu":"Tộc trưởng Thạch Thôn nhận ra thân phận di chủng Chu Yếm (@c0053)"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Được Thạch Hạo đặt tên và bênh vực","ghiChu":"@c0054"},{"ten":"Liễu Thần","tag":"khac","quanHe":"Định gặm chồi non chí cường của Liễu Thần nên bị cành liễu trói treo, sau được thả","ghiChu":"@c0054"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Người phát hiện","ghiChu":"Thạch Hạo cùng đám chim phát hiện con khỉ ba tay còn sống dưới đáy hồ khô cạn."},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Ân nhân cứu mạng, người thu nhận và nuôi dưỡng","ghiChu":"Thạch Hạo cứu khỏi bùn, mang về Thạch Thôn (@c0053)"},{"ten":"Thạch Vân Phong","tag":"khac","quanHe":"Người nhận diện thân phận di chủng của nó","ghiChu":"@c0053"},{"ten":"Liễu Thần","tag":"khac","quanHe":"Bị cành liễu trói treo khi định gặm chồi non chí cường, sau được Liễu Thần thả ra"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"chủ nhân nuôi dưỡng, hứa đưa tới Thái Cổ Thần Sơn ăn bảo dược","ghiChu":"@c0064"},{"ten":"Liễu Thần","tag":"doi-thu","quanHe":"cây liễu chỉ định máu Chu Yếm làm chủ dược, khiến Chu Yếm nổi giận trợn mắt","ghiChu":"@c0064"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Chủ nhân nuôi dưỡng; dỗ dành khi nó bị lấy máu làm chủ dược, hứa đưa tới Thái Cổ Thần Sơn ăn bảo dược.","ghiChu":"@c0064"}],"tuiDo":{}},"nguon":["@c0052","@c0053","@c0054","@c0063","@c0064","@c0065","@c0068","@c0069","@c0070","@c0072","@c0073","@c0074","@c0077","@c0085","@c0097"]},{"id":"thap-nhat-de","name":"Thập Nhất đệ","cn":"十一弟","aliases":["Cha Thạch Hạo"],"gioiTinh":"nam","theLuc":[{"ten":"Vương hầu phủ (quốc gia cổ Nhân tộc)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ","trangThai":"song","blurb":"Cha của Thạch Hạo, con trai Thập Ngũ gia. Người đầu tiên tra xét và xác nhận Thạch Hạo trời sinh Chí Tôn cốt. Cùng vợ rời Vương hầu phủ đi Bách tộc chiến trường tìm phụ thân.","vaiTro":"Cha Thạch Hạo, con trai Thập Ngũ gia","tinhCach":[{"text":"Khí chất oai hùng, quyết đoán, hiếu thảo quyết đi tìm cha dù nguy hiểm","chuong":"@c0056"}],"tabs":{"diem":[{"text":"Tra xét xác nhận Thạch Hạo trời sinh Chí Tôn cốt, khiếp sợ đến run tay","chuong":"@c0056"},{"text":"Cùng vợ rời phủ đi Bách tộc chiến trường tìm phụ thân, giao con cho Lục tẩu","chuong":"@c0056"}],"kinhLich":[{"chuong":"@c0056","importance":"normal","tieuDe":"Xác nhận Chí Tôn cốt của con, rời phủ đi cứu cha","text":"Nhận tin cha bắn chết con Tỳ Hưu huyết mạch tinh thuần chuốc đại họa; cảm được khí tức phù văn trong người Hạo, tra xét kỹ, khiếp sợ đến run tay xác nhận con trời sinh Chí Tôn cốt; sau khi cha bị Tỳ Hưu đuổi giết mất tích, hắn cùng vợ giao Hạo cho Lục tẩu rồi lên đường tới Bách tộc chiến trường tìm cha.; Phát hiện trong cơ thể con trai có khí tức phù văn, tra xét xác nhận Thạch Hạo trời sinh Chí Tôn cốt, khiếp sợ run tay; bí mật bẩm báo hai vị l…","anchor":"Cuối cùng vợ chồng hai người rời khỏi quốc gia cổ, tới Bách tộc chiến trường"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới cụ thể, sở hữu một loại Bảo thuật liên thủ với vợ đạt cực điểm.","nhanMach":[{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai","ghiChu":"Trời sinh Chí Tôn cốt, giao cho Lục tẩu chăm"},{"ten":"Mẹ Thạch Hạo","tag":"the-thiep","quanHe":"Vợ","ghiChu":"Cùng đi Bách tộc chiến trường, hai Bảo thuật liên thủ đạt cực điểm"},{"ten":"Thập Ngũ Gia","tag":"cha-me","quanHe":"Phụ thân","ghiChu":"Bị Tỳ Hưu đuổi giết mất tích, đi tìm cứu"},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Tẩu tẩu (vợ huynh trưởng)","ghiChu":"Nhận chăm Hạo nhi khi vợ chồng rời phủ"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con ruột","ghiChu":"Đứa con trời sinh Chí Tôn cốt."},{"ten":"Thập Ngũ gia","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Bị Tỳ Hưu truy sát mất tích, hắn quyết đi tìm."},{"ten":"Lục tẩu","tag":"ho-hang","quanHe":"Chị dâu (vợ huynh trưởng)","ghiChu":"Giao con nhờ chăm — không biết đó là kẻ chủ mưu chiết xương."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0056"]},{"id":"luc-tau","name":"Lục tẩu","cn":"六嫂","aliases":["Mẹ Thạch Nghị","Đại nương"],"gioiTinh":"nu","theLuc":[{"ten":"Vương hầu phủ (quốc gia cổ Nhân tộc)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ","trangThai":"song","blurb":"Mẹ Thạch Nghị, vợ một huynh trưởng của Thập Nhất đệ. Dung mạo xuất chúng, địa vị cực cao trong tộc nhờ con mang Trọng Đồng. Ngoài mặt hiền hòa nhận nuôi Hạo nhi, thực chất lập kế chiết Chí Tôn cốt của Hạo cấy cho con mình.","vaiTro":"Mẹ Thạch Nghị, chủ mưu chiết Chí Tôn cốt","tinhCach":[{"text":"Hai mặt rõ rệt: ngoài mặt hiền hòa nhận nuôi cháu, bên trong tham lam tàn nhẫn, sẵn sàng chiết xương đứa bé để nâng con mình","chuong":"@c0056"},{"text":"Lạnh lùng với nhóc tỳ van xin, hiền từ nhu hòa với con ruột","chuong":"@c0056"}],"tabs":{"diem":[{"text":"Phát hiện Chí Tôn cốt của Thạch Hạo qua con trai (Trọng Đồng), lập tức nảy ý đoạt","chuong":"@c0056"},{"text":"Tra Cố thư chiết xương, lừa Hạo xuống mật thất, chỉ huy bóng u linh chiết Bảo cốt cấy sang Thạch Nghị","chuong":"@c0056"},{"text":"Tuyên bố Thạch Nghị là Chí tôn trời sinh, hứa mảnh đại vực tương lai đều thuộc về nó","chuong":"@c0056"}],"kinhLich":[{"chuong":"@c0056","importance":"major","tieuDe":"Nhận nuôi Hạo rồi chiết Chí Tôn cốt cấy cho con","text":"Nhận chăm Hạo nhi khi cha mẹ Hạo đi Bách tộc chiến trường, hứa hai anh em sẽ cùng bình bát hoang trấn vạn tộc; Thạch Nghị phát hiện Chí Tôn cốt trong người Hạo, ả ra lệnh không được nói cho ai; sau vài tháng nuôi dưỡng, lừa Hạo tới trang viên xem hậu duệ Thái cổ Thần cầm rồi dẫn xuống mật thất, phù văn điểm huyệt bị Bảo cốt hóa giải nên triệu bóng u linh cầm đao bạc chiết xương; đã tra Cố thư khẳng định thành công, tuyên bố con ruột sẽ là Chí tô…","anchor":"Không được nói cho bất cứ ai!"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới, biết sử dụng phù văn điểm huyệt.","nhanMach":[{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con trai","ghiChu":"Mang Trọng Đồng, được cấy Chí Tôn cốt"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu (con em chồng)","ghiChu":"Nạn nhân bị chiết Chí Tôn cốt"},{"ten":"Thập Nhất đệ","tag":"ho-hang","quanHe":"Em chồng","ghiChu":"Cha Thạch Hạo, giao Hạo nhi cho ả chăm"},{"ten":"Mẹ Thạch Hạo","tag":"ho-hang","quanHe":"Em dâu","ghiChu":"Mẹ Thạch Hạo"},{"ten":"Thập Ngũ Gia","tag":"ho-hang","quanHe":"Bố chồng","ghiChu":"Ông nội Thạch Hạo, mất tích"},{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con ruột","ghiChu":"Kẻ được cấy Chí Tôn cốt cướp từ Hạo."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Cháu chồng — nạn nhân bị chiết xương","ghiChu":"Ngoài mặt nhận nuôi, thực chất chiết Chí Tôn cốt."},{"ten":"Thập Nhất đệ","tag":"ho-hang","quanHe":"Em chồng (Thập Nhất đệ)","ghiChu":"Người giao Hạo cho ả chăm."},{"ten":"Bóng u linh","tag":"dong-minh","quanHe":"Sát thủ ả triệu","ghiChu":"Thực hiện ca chiết xương và cấy ghép."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0056"]},{"id":"bong-u-linh","name":"Bóng u linh","cn":"","aliases":["Bóng đen (kẻ phẫu thuật)"],"gioiTinh":"nam","theLuc":[{"ten":"Vương hầu phủ (quốc gia cổ Nhân tộc)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ","trangThai":"khong-ro","blurb":"Bóng đen được Lục tẩu triệu, di chuyển không tiếng động không hơi thở. Cầm đao bạc chiết Chí Tôn cốt khỏi lồng ngực Thạch Hạo rồi dùng ngân đao rạch ngực Thạch Nghị để cấy ghép.","vaiTro":"Sát thủ/phẫu thuật gia trong mật thất","tinhCach":[{"text":"Lặng lẽ tuân lệnh, gào lên như dã thú khi tách thành công Chí Tôn cốt","chuong":"@c0056"}],"tabs":{"diem":[{"text":"Di chuyển không tiếng động không hơi thở, xuất hiện khi Lục tẩu vỗ tay","chuong":"@c0056"}],"kinhLich":[{"chuong":"@c0056","importance":"major","tieuDe":"Chiết Chí Tôn cốt của Hạo cấy sang Nghị","text":"Được Lục tẩu triệu, xuất hiện không tiếng động không hơi thở; đặt Hạo lên giường lạnh băng, dùng đao bạc cứa lồng ngực Hạo chiết Chí Tôn cốt — sau nỗ lực dài rốt cuộc gào lên như dã thú vì tách được đoàn sáng chói lọi mang ma lực không thể cưỡng lại tỏa thần tính chói cả mật thất; tiếp đó dùng ngân đao lướt qua lồng ngực Nghị nhi rạch mở để cấy Chí Tôn cốt, bị thiếu phụ hung dữ cảnh cáo không được sai sót.; Được Lục tẩu triệu đến mật thất; dùng…","anchor":"gã đã phẫu thuật tách được ra từ trong lồng ngực nhóc tỳ một đoàn sáng chói lọi có ma lực không thể cưỡng lại"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Lục tẩu","tag":"cap-tren","quanHe":"Chủ nhân / người triệu","ghiChu":"Ra lệnh chiết và cấy Chí Tôn cốt"},{"ten":"Lục tẩu","tag":"cap-tren","quanHe":"Chủ triệu","ghiChu":"Nhận lệnh chiết Chí Tôn cốt và cấy ghép."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nạn nhân bị chiết xương","ghiChu":"Dùng đao bạc cứa lồng ngực chiết Chí Tôn cốt."},{"ten":"Thạch Nghị","tag":"dong-minh","quanHe":"Đối tượng cấy Chí Tôn cốt","ghiChu":"Rạch lồng ngực cấy bảo cốt."}],"tuiDo":{"phapBao":[{"ten":"Đao bạc","loai":"khí giới","trangThai":"dang-co","moTa":"Thanh đao bạc lóe ánh sáng lạnh lẽo, dùng để cứa lồng ngực chiết Chí Tôn cốt","nguon":"@c0056"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0056"]},{"id":"thieu-phu-me-thach-nghi","name":"Thiếu phụ (mẹ Thạch Nghị)","aliases":["Đại nương","bá thẩm Thạch Hạo","Chị dâu Thạch Tử Lăng"],"gioiTinh":"nu","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Mẹ ruột Thạch Nghị, thuộc chi Lão Ngũ; chủ mưu cấy Chí Tôn Cốt của Thạch Hạo sang con mình.","vaiTro":"Phản diện chi tộc","tinhCach":[{"text":"Dịu dàng dỗ con nhưng ánh mắt điên cuồng, tàn nhẫn tính bịt đầu mối","chuong":"@c0057"}],"tabs":{"kinhLich":[{"importance":"major","chuong":"@c0057","tieuDe":"Cấy Chí Tôn Cốt cho con, bị bắt quả tang","text":"Cùng bóng đen u linh moi Chí Tôn Cốt của Thạch Hạo cấy vào lồng ngực Thạch Nghị trong mật thất địa cung; ra lệnh rút cạn chân huyết Hạo Nhi để tẩm bổ; độc thoại mong cha mẹ Hạo Nhi chết dưới vuốt Tỳ Hưu để bịt đầu mối; bị Tứ Thái Gia phá cửa xông vào nhấc cổ như nhấc gà, ném đập tường vỡ đá; được Lão Ngũ can thiệp giữ mạng nhờ Chí Tôn Cốt trong người Thạch Nghị.; Cùng bóng đen cấy Chí Tôn Cốt đã moi từ Thạch Hạo vào lồng ngực Thạch Nghị; ra lệnh…","anchor":"Đôi vợ chồng đó nếu mất mạng dưới vuốt của Tỳ Hưu"},{"importance":"major","chuong":"@c0060","tieuDe":"Bị áp giải và ghim xuống đất","text":"Bị các tông lão trói áp giải tới, sắc mặt lạnh nhưng trong lòng sợ hãi; kêu thảm khi thấy Thạch Nghị trọng thương, quay lại đe dọa Thạch Tử Lăng bằng danh nghĩa cha ả, liền bị Thạch Tử Lăng ném chiến mâu xuyên người mang bay mấy chục trượng rồi ghim xuống đất; Bị các tông lão trói và áp giải tới sân chiến, tông lão đề nghị đổi mạng ả lấy mạng Thạch Nghị; ả quay lại đe dọa Thạch Tử Lăng nhân danh cha mình, liền bị hắn phóng chiến mâu hào quang và…","anchor":"mâu đâm xuyên người ả rồi mang theo ả bay những mấy chục trượng"},{"importance":"major","chuong":"@c0061","tieuDe":"Bị chiến mâu giết chết","text":"Bị Thạch Tử Lăng vẫy tay rút chiến mâu khiến thân thể nổ tung gần nửa; Nghị Nhi lao tới định chữa nhưng đã chết ngay tại chỗ.; Bị chiến mâu ghim xuống đất; khi Thạch Tử Lăng vẫy tay rút mâu thì thân thể nổ tung gần một nửa mà chết, Nghị Nhi gào Mẹ lao tới định chữa nhưng không kịp.","anchor":"Cơ thể trực tiếp nổ tung gần một nửa."}],"nhanMach":[{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con ruột; cấy Chí Tôn Cốt cho con","ghiChu":""},{"ten":"Lão Ngũ","tag":"ho-hang","quanHe":"Chủ sự chi của mình, đứng ra bảo vệ","ghiChu":""},{"ten":"Tứ Thái Gia","tag":"doi-thu","quanHe":"Chủ sự bắt quả tang, nhấc cổ và ném đập tường","ghiChu":""},{"ten":"Bóng đen","tag":"dong-minh","quanHe":"Thuật sĩ đồng lõa thực hiện cấy cốt và rút máu","ghiChu":""},{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con trai, người ả được biết tin Chí Tôn Cốt và bị dùng làm cớ bảo vệ","ghiChu":"@c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Em chồng, người phóng mâu ghim ả xuống đất","ghiChu":"@c0060"},{"ten":"Thạch Nghị","tag":"cha-me","quanHe":"Con ruột","ghiChu":"@c0061"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Người rút mâu giết ả","ghiChu":"@c0061"},{"ten":"Thạch Nghị","tag":"the-thiep","quanHe":"con ruột","ghiChu":"Cấy Chí Tôn Cốt cho con (@c0057)"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"cháu chồng — nạn nhân","ghiChu":"Moi Chí Tôn Cốt và rút chân huyết (@c0057)"},{"ten":"Bóng đen (u linh)","tag":"dong-minh","quanHe":"thuật sĩ đồng lõa","ghiChu":"Thực hiện thủ thuật (@c0057)"},{"ten":"Tứ Thái Gia","tag":"doi-thu","quanHe":"trưởng bối bắt quả tang","ghiChu":"Bị nhấc cổ và ném đập tường (@c0057)"},{"ten":"Lão Ngũ","tag":"an-nhan","quanHe":"tổ tiên chi mình","ghiChu":"Bao che giữ mạng (@c0057)"},{"ten":"Cha mẹ Thạch Hạo","tag":"doi-thu","quanHe":"vợ chồng bác chồng","ghiChu":"Mong chết dưới vuốt Tỳ Hưu để bịt đầu mối (@c0057)"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Em chồng, kẻ ghim ả xuống đất","ghiChu":"Bị Thạch Tử Lăng ném mâu xuyên người @c0060"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"kẻ giết mình","ghiChu":"@c0061"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0057","@c0060","@c0061"]},{"id":"bong-den-u-linh","name":"Bóng đen (u linh)","aliases":["u linh"],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Thuật sĩ đồng lõa của thiếu phụ, thực hiện thủ thuật cấy Chí Tôn Cốt và rút chân huyết bằng bí pháp và bình ngọc.","vaiTro":"Đồng lõa","tabs":{"kinhLich":[{"importance":"normal","chuong":"@c0057","tieuDe":"Cấy cốt, rút chân huyết Thạch Hạo","text":"Dùng ký hiệu chư thiên cấy Chí Tôn Cốt vào lồng ngực Thạch Nghị rồi khép vết thương cầm máu; dùng bình ngọc và bí pháp rút cạn chân huyết Thạch Hạo; cảnh báo lấy máu ra thì đứa bé không sống quá hai tuổi nhưng vẫn tuân lệnh; rời đi trước khi Tứ Thái Gia xông vào.","anchor":"ký hiệu ngưng tụ hóa thành một miếng Chí Tôn Cốt, ẩn vào trong lồng ngực của Thạch Nghị"}],"nhanMach":[{"ten":"Thiếu phụ","tag":"dong-minh","quanHe":"Chủ mưu ra lệnh, cùng thực hiện thủ thuật","ghiChu":""}],"tuiDo":{}},"nguon":["@c0057"]},{"id":"thach-ban","name":"Thạch Bân","gioiTinh":"nam","trangThai":"khong-ro","blurb":"Một đứa trẻ trong Thạch Tộc, bạn cùng chơi của Thạch Hạo; được nói là đã đi tu hành nên dần không còn lui tới.","tabs":{},"nguon":["@c0058"]},{"id":"vo-thach-tu-lang","name":"Vợ Thạch Tử Lăng","aliases":["Mẹ nhóc tỳ","Mẹ Thạch Hạo"],"gioiTinh":"nu","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0059","tieuDe":"Ôm con theo chồng vào cứ địa","text":"Ôm nhóc tỳ đi theo phía sau Thạch Tử Lăng trong cuộc tàn sát nhánh Thạch Nghị; trên người phát hào quang lấp lánh, mắt ngấn lệ vì con thông minh hoạt bát nay bị thoái hoá.; Ôm con nhỏ (Thạch Hạo) đi theo phía sau chồng khi Thạch Tử Lăng phát điên báo thù, trên người phát hào quang lấp lánh, mắt ngấn lệ đau lòng vì đứa trẻ bị thoái hoá.","anchor":"một đứa trẻ thông minh hoạt bát lại bị thoái hoá thành như bây giờ"},{"chuong":"@c0062","importance":"normal","tieuDe":"Ôm con tham chiến, cùng chồng bị đày","text":"Ôm nhóc tỳ (Hạo nhi) giết vào chiến trường Thạch phủ, hợp lực Thạch Tử Lăng tế bảo thuật Tâm hữu linh tê nhất điểm thông chấn động cả Hoàng Đô; sau khi bị bốn lão tổ trấn áp thì cùng chồng con bị đày tới Man Hoang khổ địa (tổ địa thứ hai); ôm con lo lắng, lâu không cười; về sau cùng chồng trải trăm cay nghìn đắng tìm được Thạch thôn, rung động trước cây liễu cháy đen nhưng thất vọng với phần còn lại; Ôm nhóc tỳ giết vào chiến trường, hợp lực Thạ…","anchor":"Cuối cùng, mẹ của nhóc tỳ cũng tham chiến, nàng ôm nó, giết vào chiến trường"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"the-thiep","quanHe":"Chồng","ghiChu":"Đi theo chồng khi phát điên báo thù"},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai","ghiChu":"Ôm con thoi thóp đi theo"},{"ten":"Thạch Tử Lăng","tag":"the-thiep","quanHe":"Chồng, cùng tham chiến","ghiChu":""},{"ten":"Thạch Hạo","tag":"cha-me","quanHe":"Con trai (nhóc tỳ), ôm vào chiến trường","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0059","@c0062"]},{"id":"lao-gia-bao-cu-day-leo","name":"Lão già bảo cụ dây leo","gioiTinh":"nam","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"importance":"normal","chuong":"@c0059","tieuDe":"Bảo cụ dây leo bị đốt thành tro","text":"Hét 'Trói buộc!', cầm nhánh dây bảo cụ (thân nâu đen giờ sáng óng ánh) khiến các nhánh vọt lên như Giao Long lao trói Thạch Tử Lăng; mái tóc hoàng kim của đối thủ cắn nát dây leo rồi đánh nổ bảo cụ hóa tro tàn, bản thân bị trường mâu quất bay đụng nát tòa núi giả, phun máu.; Cầm nhánh dây (thực vật hóa bảo cụ) hô Trói buộc, phóng dây như Giao Long lao trói Thạch Tử Lăng; mái tóc hoàng kim của Thạch Tử Lăng cắn nát dây leo rồi đánh nổ bảo cụ hóa…","anchor":"bảo cụ dây leo kia lập tức nổ tung rồi bị thiêu thành một mảnh tro tàn"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Thạch Tử Lăng đánh bại"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Bị đánh bại"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0059"]},{"id":"tong-lao-thien-vi-thach-uyen","name":"Tông lão thiên vị chi Thạch Uyên","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Tông lão Thạch tộc (@c0061)","trangThai":"song","tabs":{"kinhLich":[{"text":"Kẻ nghiêm khắc nhất trong đám tông lão, thiên vị nhánh chi Thạch Uyên; quát mắng và dọa trấn áp, đuổi Thạch Tử Lăng tới man hoang khổ địa, muốn gia nhập vây công.","anchor":"Bảo vệ Nghị Nhi cho tốt!","bridge":true,"khoang":"@c0061"}],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Kẻ ông quát mắng và dọa trấn áp","ghiChu":"@c0061"}]},"nguon":["@c0061"]},{"id":"bon-lao-gia-to-dia-thu-hai","name":"Bốn lão già tổ địa thứ hai","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thạch tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Địa vị cực cao (bị đày) (@c0062)","trangThai":"song","tabs":{"kinhLich":[{"text":"Bốn nhân vật từng uy danh hiển hách, địa vị cực cao, bị đày tới tổ địa thứ hai vì đại tội; phẫn nộ trước việc Thạch Tử Lăng bị đày, không tin ước định của đối phương về việc trả lại Chí Tôn cốt.","anchor":"Bốn vị lão tổ ở đây rồi thì s","bridge":true,"khoang":"@c0062"}],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"dong-minh","quanHe":"Người bị đày cùng nơi, đồng cảnh ngộ","ghiChu":""}]},"nguon":["@c0062"]},{"id":"lao-thap-ngu","name":"Lão Thập Ngũ","cn":"","aliases":["Thập Ngũ Gia"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ quốc (Nhân Hoàng)","trangThai":"gan-bo"}],"trangThai":"khong-ro","blurb":"Trưởng bối, gia gia của Thạch Hạo; tiễn pháp tinh diệu, hai tên hạ Loan Điểu ở Thánh Hồ và bắn chết Tỳ Hưu trên Bách Tộc Chiến Trường làm chấn động bát hoang.","vaiTro":"Ông nội (gia gia) của Thạch Hạo trong ký ức thân thế; cường giả xạ tiễn của dòng họ hoàng thân, đích thân cho Hạo Nhi uống bảo huyết Thần Cầm.","tinhCach":[{"text":"Xạ tiễn tinh diệu, sát phạt quyết đoán","chuong":"@c0055"},{"text":"Thương yêu, dốc lòng bồi dưỡng cháu trai","chuong":"@c0055"}],"tabs":{"diem":[{"text":"Tiễn pháp tinh diệu — hai mũi tên hạ một Loan Điểu mạnh","chuong":"@c0055"},{"text":"Bắn chết một con Tỳ Hưu trên Bách Tộc Chiến Trường, chấn động bát hoang","chuong":"@c0055"}],"kinhLich":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu trai (Hạo Nhi), đích thân cho uống bảo huyết Thần Cầm"},{"ten":"Cha mẹ Thạch Hạo","tag":"ho-hang","quanHe":"Con trai và con dâu, gọi ông là ‘Cha’"}],"tuiDo":{"phapBao":[{"ten":"Cung đen dây gân Giao","loai":"cung","trangThai":"dang-co","moTa":"Thân cung màu đen, dây cung làm bằng gân Giao, phát sát khí mãnh liệt; bắn ra mũi tên như Giao Long hào quang ngập trời — dùng hạ Loan Điểu và Tỳ Hưu.","nguon":"@c0055"}]}},"nguon":["@c0055"]},{"id":"bo-ma-ly-hoa","name":"Bò Ma Ly Hỏa","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ (hung thú Di chủng) @c0048","trangThai":"song","blurb":"Hung thú Di chủng khổng lồ đỏ như máu, cầm đầu thú triều tràn ra Đại Hoang.","vaiTro":"Hung thú thủ lĩnh trong họa loạn đại địa","tinhCach":[{"text":"Hung tàn, hủy diệt","chuong":"@c0048"}],"tabs":{"diem":[{"text":"Thân đỏ như máu, cao mười mấy mét, dài ba mươi mét, từng đại chiến Toan Nghê Hoàng Kim và bị đánh gãy một sừng lửa","chuong":"@c0048"}],"kinhLich":[{"text":"Bò Ma Ly Hỏa tông ra khỏi dãy núi Thương Mãng, kéo theo vô số hung thú Di chủng lao ra công phạt vùng ngoài, khiến bảy tám thôn xóm lân cận dãy núi bị san bằng không ai sống sót.","anchor":"cùng lao ra khỏi dãy núi Thương Mãng mà đi công phạt vùng núi sông bên ngoài","bridge":true,"khoang":"@c0048"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới, thuộc hàng hung thú Di chủng mạnh mẽ.","nhanMach":[],"tuiDo":{}},"nguon":["@c0048"]},{"id":"su-tu-kim-mao","name":"Sư Tử Kim Mao","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ (mãnh thú Di chủng) @c0048","trangThai":"song","blurb":"Mãnh thú lông vàng đứng thẳng cao hai mươi mét, sừng mi tâm lóe điện, diệt Tiểu Cô Sơn trấn.","vaiTro":"Hung thú tàn phá trong thú triều","tinhCach":[{"text":"Tàn bạo, hiếu sát","chuong":"@c0048"}],"tabs":{"diem":[{"text":"Đứng thẳng cao hai mươi mét, sừng mi tâm lóe điện, mắt đỏ máu; nuốt cả xác xương dân trấn vào bụng","chuong":"@c0048"}],"kinhLich":[{"text":"Sư Tử Kim Mao lao vào Tiểu Cô Sơn trấn, chém đôi đệ nhất cao thủ trung niên, đập nát Tế linh Tiểu Cô Sơn rồi nuốt ực; cả trấn thành phế tích, xác xương dân đều bị mai táng trong bụng nó.","anchor":"Sư Tử Kim Mao gầm to khiến cả trấn như đang run rẩy","bridge":true,"khoang":"@c0048"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới, thuộc mãnh thú Di chủng cực mạnh.","nhanMach":[],"tuiDo":{}},"nguon":["@c0048"]},{"id":"hoi-dong-be-tren-thach-toc","name":"Các tông lão Thạch tộc","gioiTinh":"khong-ro","theLuc":[{"ten":"Thạch tộc (Hoàng Đô)","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nhóm tiền bối ẩn cư nhiều năm của Thạch tộc, hơn Thạch Tử Lăng mấy thế hệ, mắt óng ánh như thái dương, là cường giả trong tộc.","vaiTro":"Tầng quyền lực tối cao Thạch tộc","tabs":{"kinhLich":[{"text":"Đã dùng bảo cốt Thái Cổ Di Chủng phong tỏa phụ đệ từ trước để cách âm ngoại giới; xuất hiện áp giải mẹ Thạch Nghị, đề nghị đổi tính mạng ả nhưng cấm Thạch Tử Lăng động vào Thạch Nghị; kinh hãi vì Bảo Thuật ký hiệu lạ chưa từng ghi chép xuyên qua phòng ngự của họ","anchor":"Con ác phụ này đang ở đây, muốn chém muốn giết tùy ngươi. Nhưng ngươi không thể động vào Nghị Nhi được","bridge":true,"khoang":"@c0060"}]},"nguon":["@c0060"]},{"id":"bon-vi-lao-to-thach-toc","name":"Bốn vị lão tổ Thạch tộc","gioiTinh":"khong-ro","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[{"text":"Bậc tối cao Thạch tộc, ẩn thân ở bốn phương khóa thiên địa nhưng chưa ra tay","chuong":"@c0061"}],"kinhLich":[{"importance":"normal","chuong":"@c0061","tieuDe":"Ẩn thân khóa thiên địa, dụ Thạch Tử Lăng","text":"Bốn lão tổ đã dùng bảo cốt Thái Cổ Di Chủng khóa mảnh thiên địa quanh phủ đệ từ trước; hiện thân ở bốn phương với uy áp khủng bố, dụ Thạch Tử Lăng mười năm sau tiếp quản Thạch Phủ nhưng bị hắn cự tuyệt và đòi trả Chí Tôn Cốt.","anchor":"Bốn vị lão nhân hiện ra, phân biệt xuất hiện ở bốn phương."},{"text":"Tu vi cực cao, ẩn sẵn ở Thạch phủ Hoàng Đô, trấn phong tứ phương ngay khi vợ chồng Thạch Tử Lăng bước vào; bị Thạch Tử Lăng cầm hoàng kim chiến mâu áp đảo, liên tục thổ huyết; một lão tổ dùng cánh tay chặn lưỡi mâu cứu Thạch Lạp và Thạch Nghị, khuyên Tử Lăng dừng tay, hứa sẽ bồi thường cho Hạo nhi; sau đó cùng ba lão còn lại hợp vây trấn áp Thạch Tử Lăng và đày cả nhà tới Man Hoang khổ địa","anchor":"Tử Lăng, cháu nên dừng tay lại","bridge":true,"khoang":"@c0062"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"hậu bối bị họ muốn trấn áp và dụ tiếp quản gia tộc","ghiChu":"@c0061"}],"tuiDo":{}},"nguon":["@c0061","@c0062"]},{"id":"tong-lao-thien-huong-chi-thach-uyen","name":"Tông lão thiên hướng chi Thạch Uyên","gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"},{"ten":"Chi Thạch Uyên (Thạch tộc Hoàng Đô)","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Kẻ nghiêm khắc nhất trong tông lão, cáo mượn oai hùm quát mắng Thạch Tử Lăng và dọa đuổi hắn về man hoang khổ địa, muốn gia nhập vây công.","anchor":"Người đó lập tức nổ tung, để lại một màn mưa máu.","bridge":true,"khoang":"@c0061"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"đối đầu — bị hắn đâm nổ tung","ghiChu":"@c0061"},{"ten":"Thạch Uyên","tag":"dong-minh","quanHe":"chi tộc được ông thiên vị","ghiChu":"@c0061"}],"tuiDo":{}},"nguon":["@c0061"]},{"id":"lao-nhan-hung-trang-thach-toc","name":"Lão nhân hùng tráng Thạch tộc","gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"}],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Xông ra định bắt Thạch Tử Lăng thì bị hắn đánh trọng thương, bay ra ngoài phun máu và suýt bị chia năm xẻ bảy.","anchor":"Ông ta bị đánh trọng thương, suýt nữa bị chia năm xẻ bảy.","bridge":true,"khoang":"@c0061"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"đối thủ đánh trọng thương mình","ghiChu":"@c0061"}],"tuiDo":{}},"nguon":["@c0061"]},{"id":"tieu-bach","name":"Tiểu Bạch","cn":"","aliases":["Độc Giác Thú của Thạch Hạo","Độc Giác Thú","Độc giác thú"],"gioiTinh":"duc","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Con Độc Giác Thú cao lớn thần tuấn bị Thạch Hạo bắt sống bên hồ Thạch Thôn, được đặt tên và thuần phục làm thú cưỡi.","vaiTro":"Thú cưỡi của Thạch Hạo trên hành trình tới Cổ quốc","tinhCach":[{"text":"Cứng đầu, mãi tới lúc mặt trời lặn mới chịu khuất phục; vẫn không cho người lạ lại gần","chuong":"@c0068"}],"tabs":{"diem":[{"text":"Hậu duệ Thái Cổ Thiên Mã, dòng dõi Thần Thú, toàn thân trắng tinh vảy bạc, trên trán mọc một sừng có ngân quang, tốc độ một ngày vạn dặm","chuong":"@c0068"}],"kinhLich":[{"chuong":"@c0068","importance":"normal","tieuDe":"Bị bắt và thuần phục, được đặt tên","text":"Là một con Độc Giác Thú cao lớn thần tuấn trong bầy bên hồ Thạch Thôn — hậu duệ Thái Cổ Thiên Mã, huyết mạch Thần Thú; bị Thạch Hạo dùng thân pháp Kim Bằng nhảy lên lưng tóm bờm vác ngược ra khỏi bầy, tới lúc mặt trời lặn mới khuất phục, được đặt tên Tiểu Bạch và hứa dạy Cốt Văn.","anchor":"Mãi tới lúc mặt trời lặn con Độc Giác Thú to lớn thần tuấn này mới khuất phục"},{"text":"Chở nhóc tỳ chạy trốn Khổng Tước rồi nhảy xuống sông đen, bị hàn khí cực lạnh làm trọng thương gần như đóng băng toàn diện; nhờ Thạch Hạo dùng thần hi tẩm bổ và một giọt máu vàng của Bóng Lông mới sống lại; qua hai ngày vết thương gần lành, lại nhờ uống chất lỏng trong trứng ngũ sắc và một giọt máu của Chu Yếm nên thêm thần tuấn, ký hiệu trong cơ thể ngưng thật, sắp in dấu vào khung xương.","anchor":"Độc Giác Thú đã bị trọng thương, gần như bị đóng băng toàn diện","bridge":true,"khoang":"@c0070"},{"text":"Chở Thạch Hạo lao nhanh mấy trăm dặm, chạy hóa thành đạo ngân quang xuyên núi vượt sông với tốc độ cực hạn suốt hành trình ba mươi vạn dặm ra khỏi Đại Hoang.","anchor":"hóa thành một đạo ngân quang","bridge":true,"khoang":"@c0072"},{"text":"Được Thạch Hạo từ biệt và để lại giữ Thạch thôn.","anchor":"chính nhóc tỳ muốn đưa nó đi Bổ Thiên Các","bridge":true,"khoang":"@c0095"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Chủ nhân, người bắt và thuần phục, hứa dạy Cốt Văn","ghiChu":"@c0068"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Chủ nhân — người bắt sống, thuần phục, đặt tên và cưỡi Tiểu Bạch tới Cổ quốc","ghiChu":"@c0068"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Chủ nhân / người thân","ghiChu":"Để lại giữ thôn"}],"tuViMoc":[]},"nguon":["@c0068","@c0070","@c0072","@c0095"]},{"id":"co-gai-ao-trang","name":"Cô gái áo trắng","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Đám săn trứng","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Cô gái áo trắng xinh đẹp xuất trần dẫn đầu đám tu sĩ đi đoạt trứng Ngũ Sắc Khổng Tước; chưa lộ tên thật.","vaiTro":"Thủ lĩnh đám săn trứng","tinhCach":[{"text":"Bình tĩnh, phán đoán sắc bén","chuong":"@c0070"}],"tabs":{"diem":[],"kinhLich":[{"text":"Xinh đẹp xuất trần, tóc dài da trắng như ngọc Dương Chi, dẫn đầu đám tu sĩ mạnh có bà lão và trung niên nhằm đoạt trứng Khổng Tước để tái hiện uy thế Thái Cổ Thần Vương; cuối chương cùng hơn mười mấy người vây bốn phía nhóc tỳ, hỏi han và tin có người lớn đi cùng đứa trẻ ở gần.","anchor":"nhóc tỳ cũng cảm ứng được từ bốn phía tổng coongjcos mười mấy người đang vây tới","bridge":true,"khoang":"@c0070"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Vây gặp nhóc tỳ đã cướp trứng mà chưa hay","ghiChu":"@c0070"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0070"]},{"id":"ba-lao-vo-trung-thai-co","name":"Bà lão cầm mảnh vỏ trứng","gioiTinh":"nu","trangThai":"song","blurb":"Cường giả trong nhóm truy tìm, con ngươi có phù văn màu bạc; cảm ứng ra Thạch Hạo trộm & ăn trứng thần điểu và là người đầu tiên nghi tiểu thú là Chu Yếm.","tabs":{"diem":[],"kinhLich":[{"text":"Lấy mảnh vỏ trứng ngũ sắc của Thái cổ di chủng, tỉ mỉ cảm ứng và nhận ra khí tức của trứng hậu duệ Thái cổ thần điểu trên tiểu thú của Thạch Hạo; thấy chân tiểu thú đỏ thẫm liền đổi sắc mặt, nghi là hung thú Chu Yếm.","anchor":"sau khi tỉ mỉ cám ứng thấy được khí tức hẳn là của trứng do hậu duệ Thái cổ thần điểu sinh","bridge":true,"khoang":"@c0072"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối tượng bị truy tìm sau vụ trộm trứng thần điểu","ghiChu":"@c0072"},{"ten":"Cô gái áo trắng","tag":"dong-hanh","quanHe":"Cùng nhóm truy tìm","ghiChu":"@c0072"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[{"ten":"Mảnh vỏ trứng thái cổ di chủng","moTa":"Mảnh vỏ trứng vỡ nhẵn như ngọc, óng ánh ngũ sắc, dùng để cảm ứng khí tức","nguon":"@c0072"}],"linhThao":[],"khac":[]}},"nguon":["@c0072"]},{"id":"co-gai-ao-trang-nhom-truy-tim","name":"Cô gái áo trắng (nhóm truy tìm)","gioiTinh":"nu","trangThai":"song","blurb":"Thành viên nhóm bà lão, tóc đen dài, da trắng; mong Thạch Hạo đi vào Bổ Thiên các để không bị thế lực khác cướp.","tabs":{"diem":[],"kinhLich":[{"text":"Sau khi cả nhóm kinh hãi vì đứa bé dám trộm trứng thần điểu, cô gái áo trắng bày tỏ mong muốn Thạch Hạo sẽ gia nhập Bổ Thiên các, tuyệt đối không bị các thế lực khác cướp đi.","anchor":"Mong là thằng nhóc có thể đi vào Bổ Thiên các, tuyệt đối không bị những thế lực khác cướp đi!","bridge":true,"khoang":"@c0072"}],"tuViMoc":[],"nhanMach":[{"ten":"Bà lão cầm mảnh vỏ trứng","tag":"dong-hanh","quanHe":"Cùng nhóm truy tìm","ghiChu":"@c0072"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Người mà cô gái muốn kết thiện duyên, hướng vào Bổ Thiên các","ghiChu":"@c0072"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0072"]},{"id":"trung-nien-vu-toc-xung-van","name":"Người trung niên Vũ tộc Xung Vân","gioiTinh":"nam","trangThai":"song","blurb":"Người đàn ông trung niên hơi mập, mặt trắng không râu, mắt lấp lóe tinh quang; bàn (rồi gạt) việc chiêu mộ tế linh Xung Vân, nhắc chờ Hạ U Vũ tiểu thư xin phù bài.","tabs":{"diem":[],"kinhLich":[{"text":"Trong thành Xung Vân, cùng một người trẻ tuổi bàn việc mời tế linh gia nhập Vũ tộc; lắc đầu cho là truyền ra không tốt, chính sự quan trọng hơn, và nhắc chờ Hạ U Vũ tiểu thư về xin một khối phù bài.","anchor":"Không biết Hạ U Vũ tiểu thư có về tới không, chúng ta cần xin một khối phù bài","bridge":true,"khoang":"@c0072"}],"tuViMoc":[],"nhanMach":[{"ten":"Hạ U Vũ","tag":"cap-tren","quanHe":"Người Vũ tộc mà ông chờ về để xin phù bài","ghiChu":"@c0072"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0072"]},{"id":"ha-u-vu","name":"Hạ U Vũ","gioiTinh":"nu","trangThai":"khong-ro","blurb":"Tiểu thư Vũ tộc; nhóm Vũ tộc ở Xung Vân trấn chờ cô về để xin một khối phù bài (chưa xuất hiện trực tiếp).","tabs":{"diem":[],"kinhLich":[{"text":"Dẫn nhóm tu sĩ đi Tây Cương phát phù bài, chạm mặt nhóc tỳ áo da rách; bất ngờ xuất thủ thử thực lực nhưng bị bắt hụt cánh tay, phải vận Thiên Thư ký hiệu trơn như cá mới thoát ra; kinh ngạc vì bị một đứa bé khống chế trong nhất thời, rồi tặng nó phù bài Bổ Thiên Các cuối cùng và dặn giao trưởng bối để dẫn tới Bổ Thiên Các","anchor":"đến lúc nào đó giao cho trưởng bối của đệ để họ dẫn đệ tới 'Bổ Thiên Các'","bridge":true,"khoang":"@c0071"},{"text":"Chưa xuất hiện; được người trung niên Vũ tộc ở Xung Vân trấn nhắc tên như đầu mối để xin một khối phù bài, gợi vai trò trọng yếu trong mạch tiếp theo.","anchor":"Không biết Hạ U Vũ tiểu thư có về tới không, chúng ta cần xin một khối phù bài","bridge":true,"khoang":"@c0072"}],"tuViMoc":[],"nhanMach":[{"ten":"Người trung niên Vũ tộc Xung Vân","tag":"cap-duoi","quanHe":"Thuộc hạ Vũ tộc chờ cô về để xin phù bài","ghiChu":"@c0072"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Nhóc tỳ nàng thử thực lực và tặng phù bài","ghiChu":"Xưng tên giả Hạo Thiên; phản đòn khống chế nàng trong nhất thời @c0071"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0072","@c0071"],"aliases":["Cô gái áo trắng"]},{"id":"te-linh-xung-van","name":"Tế linh Xung Vân","aliases":["Xung Vân đại nhân","Tế linh đại nhân"],"gioiTinh":"khong-ro","trangThai":"song","blurb":"Cây thực vật thành tinh cao bốn năm trượng, lá như quạt hương bồ, có ba đóa kỳ hoa (xích quang, trắng như ngọc, khói tím); trấn giữ Xung Vân trấn.","tabs":{"diem":[],"kinhLich":[{"text":"Trên thổ sơn gần cửa thành Xung Vân, đóa hoa đỏ của tế linh bắn ra một đạo xích quang — thực chất là thanh phi kiếm đỏ trong suốt như hỏa ngọc chính là nhị hoa — chém giết mấy chục mãnh thú trong thú triều; Thạch Hạo đánh giá tế linh mạnh hơn thần bái Bái thôn và Thanh Lân Ưng lúc chưa ăn huyết nhục Toan Nghê.","anchor":"kinh ngạc phát hiện đạo xích quang này lại là một thanh phi kiếm","bridge":true,"khoang":"@c0072"}],"tuViMoc":[],"nhanMach":[{"ten":"Vũ tộc","tag":"khac","quanHe":"Vũ tộc từng bàn việc chiêu mộ nhưng gác lại","ghiChu":"@c0072"}],"tuiDo":{"phapBao":[{"ten":"Xích kiếm nhị hoa","moTa":"Phi kiếm đỏ trong suốt như hỏa ngọc, chính là nhị của đóa hoa đỏ trên tế linh","nguon":"@c0072"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0072"]},{"id":"nguoi-trung-nien-vu-toc-map-map","name":"Người trung niên Vũ tộc mập mạp","gioiTinh":"nam","aliases":["Người trung niên mập mạp mặt trắng không râu"],"theLuc":[{"ten":"Vũ tộc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nhân vật quyền thế Vũ tộc ở thành Trùng Vân, sai bảo quản sự dò tin ‘thôn trang rách nát’, cảnh giác Thạch Tử Lăng.","vaiTro":"Thế lực Vũ tộc theo dõi tổ địa rách nát","tabs":{"diem":[{"text":"Mặt trắng không râu, thân hình mập mạp, quyền thế trong thành Trùng Vân","chuong":"@c0073"}],"kinhLich":[{"text":"Trong thành Trùng Vân, y trầm trồ ba phi kiếm của cây Tế linh là bảo cụ liên thành nhưng có thứ Vũ tộc không thể đụng vào; hỏi quản sự về ‘thôn trang rách nát’, dặn theo dõi Thạch Tử Lăng vì trong tộc không muốn hắn trở lại; khi quản sự gợi ý ám hại đứa bé, y cảnh cáo tổ địa ‘rách nát nhưng có ý nghĩa quan trọng’, đừng làm bậy.","anchor":"Thạch Tử Lăng rất đáng sợ, trong tộc lo lắng không muốn thấy hắn trở lại","bridge":true,"khoang":"@c0073"}],"tuViMoc":[],"nhanMach":[{"ten":"Quản sự Tây Cương","tag":"cap-tren","quanHe":"chủ nhân của quản sự","ghiChu":"Sai bảo quản sự theo dõi tổ địa (@c0073)"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"đề phòng","ghiChu":"Tộc không muốn Thạch Tử Lăng trở lại (@c0073)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0073"]},{"id":"quan-su-tay-cuong","name":"Quản sự Tây Cương","gioiTinh":"nam","aliases":["Người hơn bốn mươi tuổi sống ở Tây Cương","Quản gia (thuộc hạ Vũ Mông)","Quản gia Trùng Vân Trấn"],"theLuc":[{"ten":"Vũ tộc","trangThai":"danh-nghia"}],"trangThai":"song","blurb":"Quản sự hơn bốn mươi tuổi sống ở Tây Cương, thuộc hạ của người trung niên Vũ tộc; khom lưng trước chủ nhưng gợi ý ám hại đứa bé.","vaiTro":"Quản sự cai quản khu vực tổ địa rách nát","tabs":{"diem":[{"text":"Trước chủ khom lưng cúc cung; chủ đi khỏi thì lấy lại uy phong quát người hầu","chuong":"@c0073"}],"kinhLich":[{"text":"Trước mặt người trung niên Vũ tộc, quản sự bày kế cho đứa bé ‘tình cờ’ ngã giếng, rơi vách núi hoặc bị thú dữ ăn thịt để không lưu dấu vết; bị chủ cảnh cáo đừng làm bậy vì tổ địa có ý nghĩa quan trọng. Khi chủ đi khỏi, y lập tức lấy lại uy phong.","anchor":"đứa bé này có thể sẽ không may bị ngã xuống giếng, rơi xuống vách núi hoặc bị thú dữ ăn thịt","bridge":true,"khoang":"@c0073"},{"text":"Khi vắng Vũ Mông, vẻ khúm núm biến mất, triệu tập một đám cường giả, mắng chúng nhiều năm không tra ra tin Thạch Tử Lăng; vỗ tan bàn gỗ và nền đá kim cương lún hơn một xích, lộ tu vi đáng sợ; ra lệnh dù là giả cũng phải nghĩ cách giết đứa thế thân vì thể diện Vũ Tộc; sau khi tổ địa bị đốt, mặt trắng bệch, bị Vũ Mông tát rụng răng, quỳ chối tội, kinh hãi trước viễn cảnh Vương Hầu chân chính đích thân đến.","anchor":"Kể cả là giả thì cũng phải nghĩ cách giết chết đi","bridge":true,"khoang":"@c0075"}],"tuViMoc":[],"nhanMach":[{"ten":"Người trung niên Vũ tộc mập mạp","tag":"cap-tren","quanHe":"thuộc hạ","ghiChu":"Nhận lệnh dò tin, gợi kế ám hại (@c0073)"},{"ten":"Đứa bé tổ địa rách nát","tag":"doi-thu","quanHe":"gợi kế ám hại","ghiChu":"Bày cách hại đứa bé không để dấu vết (@c0073)"},{"ten":"Vũ Mông","tag":"cap-tren","quanHe":"Chủ nhân trong Vũ Tộc, bị chủ tát rụng răng khi lộ chuyện","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"doi-thu","quanHe":"Ra lệnh cho thuộc hạ dùng độc trùng/ác thú giết đứa thế thân","ghiChu":"@c0075"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0073","@c0075"]},{"id":"dua-be-to-dia-rach-nat","name":"Đứa bé tổ địa rách nát","gioiTinh":"nam","aliases":["Tiểu thiếu gia","‘Một mình khác’ của Thạch Hạo"],"theLuc":[{"ten":"Thạch Quốc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Bé trai gầy yếu, mặt trắng như tuyết, ho khan, chân tật; sống cô độc ở tổ địa rách nát trong Thạch quốc, bị đồn là thế thân của Thạch Hạo hoặc con cháu lão tổ tông sắp qua đời.","vaiTro":"‘Một mình khác’ của Thạch Hạo, mục tiêu bảo vệ trục cốt truyện","tinhCach":[{"text":"Yếu ớt nhưng cứng cỏi, nghẹn ngào cãi lại người hầu rằng ‘tổ gia gia sẽ không chết’","chuong":"@c0073"}],"tabs":{"diem":[{"text":"Gầy yếu, mặt trắng như tuyết, ho khan, chân tật phải vịn tường đi","chuong":"@c0073"},{"text":"Bị đồn là con cháu lão quái vật sắp chết, chỉ làm thế thân cho con Thạch Tử Lăng","chuong":"@c0073"}],"kinhLich":[{"importance":"normal","chuong":"@c0073","tieuDe":"Xuất hiện, bị người hầu ngược đãi","text":"Sống cô độc ở tổ địa rách nát, được ông lão Hải gia gia đưa đồ ăn thương xót; xin lần sau mang ‘đại hắc’ tới chơi. Sau đó bị người hầu trêu tức rằng vị lão tổ tông cuối cùng sắp qua đời và đồn nó chỉ là kẻ thế thân; mặt tái nhợt, đầy lệ vẫn cãi lại. Không biết Thạch Hạo đứng trong núi ngẩn ngơ nhận nó là ‘một mình khác’, thề đưa nó tới Bổ Thiên Các.","anchor":"một số người hầu bên trong cái thôn trang rách nát giống như lao tù này đã bị người bên ngoài mua chuộc"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"‘một mình khác’ — bản thân khác","ghiChu":"Thạch Hạo thề đưa đứa bé đến Bổ Thiên Các (@c0073)"},{"ten":"Hải gia gia","tag":"an-nhan","quanHe":"ông lão đưa đồ ăn thương xót","ghiChu":"Chăm sóc, than thở về số phận đứa bé (@c0073)"},{"ten":"Thạch Tử Lăng","tag":"cha-me","quanHe":"được đồn là cha (chưa xác nhận)","ghiChu":"Tin đồn trái chiều: có người bảo con Thạch Tử Lăng, có người bảo con cháu lão quái vật (@c0073)"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0073"]},{"id":"hai-gia-gia","name":"Hải gia gia","gioiTinh":"nam","aliases":["Ông lão đưa đồ ăn"],"theLuc":[{"ten":"Thạch Quốc","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Ông lão điều khiển xe thú đưa trái cây, thịt, đồ ăn cho tổ địa rách nát; thương xót đứa bé cô độc và hứa mang ‘đại hắc’ tới chơi.","vaiTro":"Người tốt bụng cấp tiếp tế cho đứa bé ở tổ địa","tabs":{"diem":[{"text":"Thương xót đứa bé bệnh tật, than thở về số phận nó","chuong":"@c0073"}],"kinhLich":[{"text":"Đưa trái cây, thịt, đồ ăn cho tổ địa rách nát; nghe đứa bé xin mang ‘đại hắc’ tới, ông ngoài mặt cười nhưng trong lòng than thở về số phận đáng thương của nó.","anchor":"một số người hầu bên trong cái thôn trang rách nát giống như lao tù này đã bị người bên ngoài mua chuộc","bridge":true,"khoang":"@c0073"},{"text":"Cùng con trai diệt sát thủ Vũ Tộc trong đêm, bắn ra phù tiễn phát sáng mang ký hiệu công lực thâm hậu; sau khi nhóc tỳ Thạch Hạo đốt tổ địa Thạch Tộc và cảnh báo Tây Cương sắp động đất lớn, giục cả nhóm nhanh chóng rời hiện trường, không dám nán lại lâu.","anchor":"“Đi thôi!” Cụ Hải ung thủ, không dám ở lâu","bridge":true,"khoang":"@c0075"}],"tuViMoc":[],"nhanMach":[{"ten":"Đứa bé tổ địa rách nát","tag":"an-nhan","quanHe":"chăm sóc, tiếp tế","ghiChu":"Thương xót và đối tốt với đứa bé (@c0073)"},{"ten":"Hải đại thúc","tag":"ho-hang","quanHe":"Con trai ruột, cùng ra tay diệt sát thủ","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"khac","quanHe":"Đứa bé thế thân được đưa đi khỏi thôn trang đổ nát","ghiChu":"@c0075"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Nhóc tỳ chính chủ cảnh báo trước Tây Cương sắp động đất lớn","ghiChu":"@c0075"},{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Kẻ Vũ Tộc ra lệnh bắt sống lấy máu nuôi hung thú","ghiChu":"@c0075"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0073","@c0075"]},{"id":"lao-nhan-to-gia-gia-dien-trang","name":"Lão nhân tổ gia gia điền trang","aliases":["tổ gia gia (đứa bé)","anh em ruột tổ gia gia Thạch Hạo"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","blurb":"Lão nhân hấp hối ở điền trang cũ nát Tây Cương, anh em ruột với tổ gia gia của Thạch Hạo, qua đời mãn nguyện sau khi trối gửi đứa cháu thế mạng cho Thạch Hạo.","vaiTro":"Người thân xa của Thạch Hạo phía Tây Cương; kẻ trối trăng gửi lại đứa bé thế mạng.","tabs":{"diem":[{"text":"Hồi quang phản chiếu, kinh mừng khi biết Thạch Hạo còn sống mạnh khỏe","chuong":"@c0074"}],"kinhLich":[{"text":"Nằm hấp hối trong sân điền trang cũ nát, được đứa bé nắm tay không chịu buông; khi Thạch Hạo lẻn vào xưng là “đứa trẻ năm đó”, lão nhân bừng tỉnh kinh mừng, nghe khoe một tay nhấc mười vạn tám ngàn cân thì hồi quang phản chiếu cười lớn; dùng chút sức cuối cùng đặt tay đứa bé vào tay Thạch Hạo, được hứa chiếu cố rồi mãn nguyện nhắm mắt qua đời. Hai hôm sau được chôn cất.","anchor":"Vị lão nhân này là anh em ruột với tổ gia gia của Thạch Hạo","bridge":true,"khoang":"@c0074"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Cháu (anh em ruột với tổ gia gia Thạch Hạo); Thạch Hạo lẻn vào thăm lúc hấp hối và hứa chiếu cố đứa bé thế mạng","ghiChu":"@c0074"},{"ten":"Đứa bé thế mạng","tag":"ho-hang","quanHe":"Cháu nhỏ được ông chăm sóc; trối gửi lại cho Thạch Hạo trước khi qua đời","ghiChu":"@c0074"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0074"]},{"id":"dua-be-the-mang","name":"Đứa bé thế mạng","aliases":["tiểu thiếu gia","đứa bé bệnh tật"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Đứa bé bệnh tật một chân bị què ở điền trang cũ nát Tây Cương, kẻ từng được mấy lão nhân bị trục xuất dùng để thế mạng cho Thạch Hạo; sau khi tổ gia gia qua đời được Thạch Hạo nhận chiếu cố.","vaiTro":"Kẻ thế mạng cho Thạch Hạo; đứa cháu duy nhất còn lại của lão nhân điền trang.","tabs":{"diem":[{"text":"Cô đơn, người thân lần lượt qua đời trong mấy năm","chuong":"@c0074"},{"text":"Bệnh tật, một chân bị què nhưng không chịu khuất phục hai gác cổng độc ác","chuong":"@c0074"}],"kinhLich":[{"text":"Bị hai gác cổng cợt nhả cái chết sắp tới của tổ gia gia, khập khiễng vào nhà nắm chặt tay lão nhân hấp hối không chịu buông; chứng kiến tổ gia gia trối trăng gửi lại tay mình vào tay Thạch Hạo và mãn nguyện nhắm mắt. Tang lễ khóc ngất trước mộ, được hai lão bộc bế đi; hoàng hôn bày tỏ tâm nguyện muốn thăm Đại Hắc của Hải lão gia tử và tiểu hổ, được Thạch Hạo hứa dẫn tới Bổ Thiên Các để không ai còn ức hiếp.","anchor":"cháu sẽ chiếu cố thật tốt cho nó","bridge":true,"khoang":"@c0074"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão nhân tổ gia gia điền trang","tag":"ho-hang","quanHe":"Tổ gia gia (ông) nuôi dưỡng; qua đời trong chương này","ghiChu":"@c0074"},{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Ân nhân nhận trách nhiệm chiếu cố sau khi tổ gia gia qua đời, hứa đưa tới Bổ Thiên Các","ghiChu":"@c0074"},{"ten":"Hải lão gia tử","tag":"khac","quanHe":"Người nuôi hắc hổ Đại Hắc mà đứa bé muốn thăm","ghiChu":"@c0074"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0074"]},{"id":"hai-lao-gia-tu","name":"Hải lão gia tử","aliases":["Hải gia gia"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Lão nhân nuôi hắc hổ Đại Hắc và tiểu hổ, hàng ngày cung cấp thú săn cho điền trang cũ nát ở Tây Cương; là đối tượng đứa bé thế mạng muốn tới thăm.","vaiTro":"Người quen thân thiết của đứa bé thế mạng ở Tây Cương, nuôi mãnh thú Đại Hắc.","tabs":{"diem":[],"kinhLich":[{"text":"Được nhắc là người nuôi hắc hổ Đại Hắc và tiểu hổ, hàng ngày cung cấp thú săn cho điền trang cũ nát; là đối tượng đứa bé thế mạng bày tỏ muốn tới thăm khi Thạch Hạo hỏi tâm nguyện.","anchor":"cháu sẽ chiếu cố thật tốt cho nó","bridge":true,"khoang":"@c0074"}],"tuViMoc":[],"nhanMach":[{"ten":"Đứa bé thế mạng","tag":"khac","quanHe":"Đứa bé bày tỏ tâm nguyện muốn tới thăm Hải lão gia tử và Đại Hắc","ghiChu":"@c0074"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0074"]},{"id":"vu-mong","name":"Vũ Mông","cn":"羽濛","aliases":["Vũ Mông (Vũ Tộc)"],"gioiTinh":"nam","theLuc":[{"ten":"Vũ Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cao thủ Vũ Tộc (tu vi cao thâm)","trangThai":"song","blurb":"Cao thủ Vũ Tộc trung niên hơi mập, mặt trắng không râu, mắt có ký hiệu lưu chuyển; phụng lệnh tông lão tuần tra Tây Cương, ra lệnh bắt sống cha con họ Hải.","vaiTro":"Phản diện phe Vũ Tộc tại Tây Cương","tinhCach":[{"text":"Kiêu ngạo, tàn nhẫn, coi trọng thể diện Vũ Tộc","chuong":"@c0075"},{"text":"Nóng nảy dữ tợn, tát rụng răng thuộc hạ khi tức giận","chuong":"@c0075"},{"text":"Có mưu tính, biết sợ hậu quả khi lộ mặt","chuong":"@c0075"}],"tabs":{"diem":[{"text":"Cao thủ Vũ Tộc phụng lệnh tông lão tuần tra Tây Cương, muốn xin phù bài Bổ Thiên Các cho thiên tài trong tộc","chuong":"@c0075"},{"text":"Nghi cha con họ Hải có lai lịch, muốn bắt sống lấy máu cường giả nuôi hung thú","chuong":"@c0075"}],"kinhLich":[{"chuong":"@c0075","importance":"normal","tieuDe":"Rống giận, tát rụng răng quản gia","text":"Nhận tin tổ địa Thạch Tộc bị một mồi lửa thiêu rụi, rống giận kinh thiên động địa; ý thức tai họa ngập trời sắp giáng do bản thân từng lộ mặt ở Tây Cương; tát bay quản gia tu vi cao thâm rụng cả hàm răng lẫn máu; khẳng định Thạch Quốc sẽ phái vài Vương Hầu truy xét đến cùng, hắn cũng bị liên lụy.; Phụng lệnh tông lão tuần tra Tây Cương, coi sóc sản nghiệp Vũ Tộc (khoáng hiếm, khu tiến cống trân cầm dị thú); muốn xin sứ giả Bổ Thiên Các một phù b…","anchor":"vung tay tát bay quản gia tu vi cao thâm, cả hàm răng hắn đều rụng ra"},{"text":"Hoảng loạn khi tổ địa Thạch Tộc bị thiêu, nổi giận đá gãy xương quản gia định diệt khẩu nhưng do dự vì sợ Thạch Tộc điều tra không bỏ sót; bị áp giải tới Cự Thành, bị ba Vương Hầu tra hỏi, chém cụt hai tay rồi hai chân nổ tung; tuyệt vọng khai hết, trước khi chết mới đoán ra một trong ba người là Chiến Vương nhưng đã muộn, bị chém đầu bỏ mạng nơi Tây Cương.","anchor":"Vũ Mông trực tiếp bị chém đầu, bỏ mạng nơi Tây Cương","bridge":true,"khoang":"@c0076"}],"tuViMoc":[],"nhanMach":[{"ten":"Quản sự Tây Cương","tag":"cap-tren","quanHe":"Thuộc hạ tu vi cao thâm dưới trướng, bị tát rụng răng vì lộ chuyện","ghiChu":"@c0075"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Mục tiêu truy sát (nhóc tỳ chính chủ)","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"doi-thu","quanHe":"Đứa thế thân bị hắn ra lệnh phải giết vì thể diện Vũ Tộc","ghiChu":"@c0075"},{"ten":"Hải gia gia","tag":"doi-thu","quanHe":"Cường giả ẩn cư ra lệnh bắt sống lấy máu nuôi hung thú","ghiChu":"@c0075"},{"ten":"Hải đại thúc","tag":"doi-thu","quanHe":"Cường giả ẩn cư ra lệnh bắt sống","ghiChu":"@c0075"},{"ten":"Chiến Vương","tag":"doi-thu","quanHe":"Vương Hầu Thạch Tộc trực tiếp ra lệnh tra tấn và chém đầu Vũ Mông tại Cự Thành","ghiChu":"@c0076"},{"ten":"Thạch Tử Lăng","tag":"doi-thu","quanHe":"Vũ Mông vu khống đổ tội phóng hỏa tổ địa cho Thạch Tử Lăng để tự cứu mình","ghiChu":"@c0076"}],"tuiDo":{}},"nguon":["@c0075","@c0076"]},{"id":"thach-thanh-phong","name":"Thạch Thanh Phong","cn":"石清风","aliases":["Thạch Hạo (thế thân)","Đứa thế thân","Thanh Phong","nhóc Thanh Phong","đứa thế thân của Thạch Hạo"],"gioiTinh":"nam","theLuc":[{"ten":"Thôn trang tổ địa thứ hai Thạch Tộc","trangThai":"da-roi"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Đứa bé thế thân từng bị nuôi làm Thạch Hạo giả trong thôn trang tổ địa thứ hai của Thạch Tộc; bị nô tài dùng Độc Giao cắn què chân, tự đổi tên thành Thạch Thanh Phong để nhường lại cái tên cũ và mong tự do như gió.","vaiTro":"Nhân vật phụ — đứa thế thân trùng tên với chính chủ Thạch Hạo","tinhCach":[{"text":"Lương thiện nhưng hèn yếu, sợ đau khổ hồi ức cũ","chuong":"@c0075"},{"text":"Khao khát tự do như cơn gió, muốn thoát khỏi lồng giam","chuong":"@c0075"}],"tabs":{"diem":[{"text":"Nguyên là đứa thế thân được nuôi đội tên Thạch Hạo, sau bị què chân do độc trùng","chuong":"@c0075"},{"text":"Thân thiết với Đại Hắc — con hổ đen là bạn tốt nhất","chuong":"@c0075"}],"kinhLich":[{"text":"Sau khi mấy ông lão đã chết, đứa bé thế thân vốn tên Thạch Hạo tự đặt cho mình cái tên Thạch Thanh Phong (mong tự do như gió, thoát khỏi lồng giam); muốn đi thăm Đại Hắc trước khi rời đi; được Hải đại thúc đến đón, chứng kiến cha con họ Hải diệt hơn hai mươi sát thủ Vũ Tộc trong một đêm rồi cùng nhóm rút lui khỏi thôn trang đổ nát.","anchor":"Nghĩ rất lâu, nó tự đặt cho mình cái tên Thạch Thanh Phong","bridge":true,"khoang":"@c0075"},{"text":"Được Thạch Hạo nhận làm đệ đệ và giới thiệu với cả thôn; chân trái bị Độc Giao cắn để lại bướu thịt, chờ dưỡng thương; vốn sợ nước không biết bơi, bị đám trẻ lớn kéo xuống hồ xanh lam, chỉ sau nửa canh giờ đã biết bơi và thấy nơi đây yên bình hạnh phúc.","anchor":"sau nửa canh giờ nó cũng biết bơi","bridge":true,"khoang":"@c0077"},{"chuong":"@c0078","importance":"normal","tieuDe":"Lành gân cốt, lộ thiên phú cốt văn","text":"Được bảo dược (máu Chu Yếm) bôi và uống cùng phù văn trị liệu mỗi ngày, chỉ mấy ngày gân cốt chân rách nát mọc lại và liền hẳn; hồi phục mặt hồng hào chạy nhảy bình thường, ra hồ luyện công và hiểu được cốt văn, được lão tộc trưởng gọi là thiên tài trước bị thân thể liên lụy.","anchor":"「Chỉ trong thời gian mấy ngày gân cốt trên chân Thanh Phong đã liền lại」"}],"tuViMoc":[],"nhanMach":[{"ten":"Hải đại thúc","tag":"an-nhan","quanHe":"Người đến đón khỏi thôn trang đổ nát","ghiChu":"@c0075"},{"ten":"Hải gia gia","tag":"an-nhan","quanHe":"Cường giả ẩn cư che chở, đưa đi","ghiChu":"@c0075"},{"ten":"Đại Hắc","tag":"ban-be","quanHe":"Con hổ đen là bạn tốt nhất","ghiChu":"@c0075"},{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Kẻ ra lệnh giết vì thể diện Vũ Tộc","ghiChu":"@c0075"},{"ten":"Quản sự Tây Cương","tag":"doi-thu","quanHe":"Kẻ trực tiếp ra lệnh sai thuộc hạ dùng độc trùng, ác thú giết","ghiChu":"@c0075"},{"ten":"Thạch Hạo","tag":"ho-hang","quanHe":"Được nhận làm ca ca, đưa về Thạch thôn","ghiChu":"Được Thạch Hạo hứa chữa lành chân","gap":"@c0077"}],"tuiDo":{}},"nguon":["@c0075","@c0077","@c0078"]},{"id":"hai-dai-thuc","name":"Hải đại thúc","aliases":["Con Hải gia gia"],"gioiTinh":"nam","theLuc":[{"ten":"Nhà họ Hải (cường giả ẩn cư Tây Cương)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cường giả ẩn cư (đủ giết cao thủ tu Cốt Văn)","trangThai":"song","blurb":"Con trai Hải gia gia, cao lớn với bộ râu quai nón thô lỗ; đến thôn trang đổ nát đón Thạch Thanh Phong và cùng cha ra tay diệt sạch hơn hai mươi sát thủ Vũ Tộc trong một đêm.","vaiTro":"Nhân vật phụ — hộ vệ họ Hải phe trợ giúp Thạch Hạo","tinhCach":[{"text":"Thô lỗ, thẳng thắn, dữ dằn khi ra tay","chuong":"@c0075"},{"text":"Coi trọng thằng bé thế thân, tố giác việc nô tài dùng độc trùng làm nó què chân","chuong":"@c0075"}],"tabs":{"diem":[{"text":"Cường giả ẩn cư có tu vi đủ sức diệt cao thủ tu Cốt Văn","chuong":"@c0075"},{"text":"Ngoại hình cao lớn, râu quai nón thô lỗ","chuong":"@c0075"}],"kinhLich":[{"text":"Đến thôn trang đổ nát đón Thạch Thanh Phong, tố cáo bọn nô tài dùng Độc Giao cắn què chân thằng bé; cùng cha nhanh như u linh diệt sạch hơn hai mươi sát thủ có tu Cốt Văn do quản gia Vũ Tộc phái tới, không tên nào chạy thoát; sau khi Vũ Mông ra lệnh bắt sống hai cha con, nghe nhóc tỳ Thạch Hạo cảnh báo rồi rút lui khỏi hiện trường.","anchor":"hai mươi mấy tên bị giết sạch sành sanh, không có tên nào có thể chạy thoát","bridge":true,"khoang":"@c0075"}],"tuViMoc":[],"nhanMach":[{"ten":"Hải gia gia","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"@c0075"},{"ten":"Thạch Thanh Phong","tag":"khac","quanHe":"Đứa bé thế thân được đến đón","ghiChu":"@c0075"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Nhóc tỳ chính chủ cảnh báo trước đại họa Tây Cương","ghiChu":"@c0075"},{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Kẻ Vũ Tộc ra lệnh bắt sống lấy máu nuôi hung thú","ghiChu":"@c0075"}],"tuiDo":{}},"nguon":["@c0075"]},{"id":"chien-vuong","name":"Chiến Vương","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thạch Tộc","trangThai":"gan-bo"},{"ten":"Thạch Quốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vương Hầu","trangThai":"song","blurb":"Vương Hầu Thạch Tộc trấn giữ Tây Cương, một trong những cường giả mạnh nhất dưới Nhân Hoàng; tính tình ngang tàng, không việc gì không dám làm.","vaiTro":"Vương Hầu Thạch Tộc phụ trách điều tra vụ thiêu tổ địa, trực tiếp xử tử Vũ Mông và tàn sát Vũ Tộc tại Tây Cương.","tinhCach":[{"text":"Ngang tàng cứng rắn, không việc gì không dám làm — chém Vũ Mông rồi tàn sát cả Vũ Tộc mà không cần áp giải về Hoàng Đô","chuong":"@c0076"},{"text":"Thưởng thức kỳ tài trẻ tuổi, nghe nói rất coi trọng Thạch Tử Lăng","chuong":"@c0076"}],"tabs":{"diem":[{"text":"Thân phát hào quang óng ánh như một vầng thái dương; đôi mắt xây bằng phù văn có cảnh khai thiên lập địa","chuong":"@c0076"},{"text":"Được Nhân Hoàng tin tưởng hoàn toàn, hành xử tuyệt đối theo ý mình","chuong":"@c0076"}],"kinhLich":[{"text":"Cùng ba vầng thái dương xuất hiện điều tra vụ thiêu tổ địa; ra lệnh tra tấn và chém đầu Vũ Mông ngay tại Cự Thành thay vì áp giải về Hoàng Đô; tàn sát người Vũ Tộc tại Tây Cương khiến đầu người chất như núi; sau đó ra lệnh tiếp tục điều tra Vũ Vương Phủ để cảnh cáo.","anchor":"người tại Tây Cương bị chém sạch, đầu người chất như núi","bridge":true,"khoang":"@c0076"}],"tuViMoc":[],"tuVi":"Vương Hầu Thạch Tộc, thực lực chỉ dưới Nhân Hoàng.","nhanMach":[{"ten":"Vũ Mông","tag":"doi-thu","quanHe":"Ra lệnh tra tấn và chém đầu Vũ Mông tại Cự Thành","ghiChu":"@c0076"},{"ten":"Thạch Tử Lăng","tag":"khac","quanHe":"Nghe nói rất thưởng thức kỳ tài trẻ tuổi Thạch Tử Lăng","ghiChu":"@c0076"},{"ten":"Nhân Hoàng","tag":"cap-tren","quanHe":"Được Nhân Hoàng tin tưởng phái đi điều tra tới cùng","ghiChu":"@c0076"}],"tuiDo":{}},"nguon":["@c0076"]},{"id":"tu-thai-gia-vu-vuong-phu","name":"Tứ thái gia","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vũ Vương Phủ","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tông lão Vũ Vương Phủ, khí thế như Hoàng Kim Sư Tử; tham gia bàn đối sách sau vụ thiêu thôn trang.","vaiTro":"Tông lão Vũ Vương Phủ.","tinhCach":[{"text":"Đa nghi — vội quy trách nhiệm cho thủ hạ của Nghị Nhi","chuong":"@c0076"}],"tabs":{"diem":[{"text":"Tông lão Vũ Vương Phủ khí thế như Hoàng Kim Sư Tử; nghi thủ hạ của Nghị Nhi phóng hỏa nhưng bị tông lão khác bác bỏ vì Nghị Nhi cơ trí","chuong":"@c0076"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0076"]},{"id":"ho-tu","name":"Hổ Tử","gioiTinh":"nam","theLuc":[{"ten":"Thạch thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (luyện cốt văn) @c0078","trangThai":"song","blurb":"Đứa trẻ Thạch thôn, con của Thạch Lâm Hổ, hăng hái cưỡi Độc Giác Thú đi mạo hiểm cùng đám nhóc.","vaiTro":"Nhân vật phụ — thiếu niên Thạch thôn trong nhóm đám trẻ của nhóc tỳ.","tinhCach":[{"text":"Gan dạ, thích mạo hiểm; tinh ý phán đoán khói lớn là cháy chứ không phải khói bếp","chuong":"@c0078"}],"tabs":{"diem":[{"text":"Con của Thạch Lâm Hổ, được cha giục thuần phục Độc Giác Thú","chuong":"@c0078"}],"kinhLich":[{"text":"Cùng Đại Tráng, Nhị Mãnh, Bì Hầu gật đầu đồng lòng cưỡi Độc Giác Thú vào núi đi săn; đề nghị đi săn và phán đoán khói to là cháy chứ không phải khói bếp, dẫn cả đám tới thôn hơn hai trăm hộ bị thảm sát; sau đó hỏi han về danh tính đám cướp.","anchor":"「Mấy đứa Đại Tráng, Nhị Mãnh, Hổ Tử, nhóc thò lò mũi xanh đều gật đầu」","bridge":true,"khoang":"@c0078"},{"text":"Cùng Bì Hầu cưỡi Độc Giác Thú tra xét quanh Thạch Thôn, mang về tin thôn xóm ngoài 600 dặm bị hung khấu tàn sát đẫm máu.","anchor":"Mấy ngày sau, Bì Hầu, Hổ Tử mang đến một tin tức không hay.","bridge":true,"khoang":"@c0079"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Lâm Hổ","tag":"cha-me","quanHe":"Cha","ghiChu":"Thạch Lâm Hổ giục con là Hổ Tử thuần phục Độc Giác Thú cho mình cưỡi. @c0078"},{"ten":"Nhị Mãnh","tag":"ban-be","quanHe":"Bạn cùng nhóm đám trẻ","ghiChu":"Cùng cưỡi Độc Giác Thú đi mạo hiểm. @c0078"},{"ten":"Thạch Đại Tráng","tag":"ban-be","quanHe":"Bạn cùng nhóm đám trẻ","ghiChu":"Cùng đi săn và phát hiện thôn bị diệt. @c0078"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Bạn cùng nhóm đám trẻ","ghiChu":"Cùng đua Độc Giác Thú và đi săn. @c0078"},{"ten":"Thạch Phi Giao","tag":"ban-be","quanHe":"Rủ nhóc tỳ dẫn đầu đi săn","ghiChu":"Cùng đội cưỡi Độc Giác Thú do nhóc tỳ dẫn. @c0078"},{"ten":"Bì Hầu","tag":"ban-be","quanHe":"Đồng đội trinh sát","ghiChu":"Cùng đi tra xét vùng ngoài @c0079"}],"tuiDo":{}},"nguon":["@c0078","@c0079"]},{"id":"tam-gia-thach-thon","name":"Tam gia","gioiTinh":"nam","theLuc":[{"ten":"Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tộc lão Thạch Thôn tuổi tác đã cao; bị đầu lĩnh hung khấu quất roi Phù Văn đánh bay trọng thương.","tabs":{"diem":[],"kinhLich":[{"text":"Vị tộc lão run run tiến lên hỏi yêu cầu của đám hung khấu thì lập tức bị đầu lĩnh vung roi Phù Văn đánh bay, một mảnh hoa máu túa ra, trọng thương.","anchor":"ngay lập tức tộc lão lập tức bị đánh bay, một mảnh hoa máu túa ra","bridge":true,"khoang":"@c0079"}],"tuViMoc":[],"nhanMach":[{"ten":"Đầu lĩnh hung khấu vết đao","tag":"doi-thu","quanHe":"Kẻ ra đòn đánh bay @c0079"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0079"]},{"id":"dau-linh-hung-khau-vet-dao","name":"Đầu lĩnh hung khấu vết đao","gioiTinh":"nam","theLuc":[{"ten":"Đám hung khấu áp sát Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thủ lĩnh đám hơn 100 hung khấu cưỡi mãnh thú, mặt có vết đao, dùng roi Phù Văn ra đòn và ép Thạch Thôn nộp 500 cân hắc kim.","tabs":{"diem":[{"text":"Có bí lực Cốt Văn mạnh, dùng roi Phù Văn đánh bay tộc lão và làm rách mặt thanh niên Thạch Thôn.","chuong":"@c0079"}],"kinhLich":[{"text":"Dẫn hơn 100 hung khấu cùng Tế Linh Xuyên Sơn Giáp (Chân Hống) áp sát Thạch Thôn, quất roi Phù Văn đánh bay Tam gia; ra hạn 20 ngày Thạch Thôn phải nộp 500 cân hắc kim, nếu không sẽ tàn sát diệt tộc; trước khi rời đi còn quất roi làm mặt Thạch Lâm Hổ và Thạch Phi Giao rách toác.","anchor":"Cho bọn ngươi thời hạn hai mươi ngày phải nộp lên năm trăm cân hắc kim","bridge":true,"khoang":"@c0079"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Vân Phong","tag":"doi-thu","quanHe":"Tộc trưởng thôn bị uy hiếp @c0079"},{"ten":"Tam gia","tag":"doi-thu","quanHe":"Nạn nhân roi Phù Văn @c0079"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0079"]},{"id":"chan-hong-te-linh","name":"Chân Hống","aliases":["Xuyên Sơn Giáp Tế Linh","Tê tê vàng kim"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Đám hung khấu áp sát Thạch Thôn","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Tế Linh Xuyên Sơn Giáp khổng lồ dài mấy chục mét, thân vàng kim, huyết quang trên vảy cho thấy từng ăn cả Tế Linh khác.","tabs":{"diem":[{"text":"Thân vàng kim, mắt như đèn lồng, vảy tỏa huyết quang — dấu hiệu giết chóc vô biên.","chuong":"@c0079"}],"kinhLich":[{"text":"Xuất hiện phía sau đám hung khấu — Xuyên Sơn Giáp (tê tê) dài mấy chục mét, thân vàng kim, mắt như đèn lồng, vảy tỏa huyết quang cho thấy từng ăn cả Tế Linh khác; đầu lĩnh gọi nó là 'Chân Hống'; gào chấn động rồi cùng hung khấu nghênh ngang rời Thạch Thôn.","anchor":"Đó là một con Xuyên Sơn Giáp toàn thân tỏa ra màu vàng kim nhàn nhạt","bridge":true,"khoang":"@c0079"}],"tuViMoc":[],"nhanMach":[{"ten":"Đầu lĩnh hung khấu vết đao","tag":"dong-minh","quanHe":"Tế Linh đi cùng đám hung khấu @c0079"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0079"]},{"id":"chi-ton-cai-the","name":"Chí Tôn cái thế","aliases":["Vị Chí Tôn"],"gioiTinh":"khong-ro","theLuc":[],"trangThai":"khong-ro","blurb":"Nhân vật truyền thuyết cái thế để lại đạo thống/truyền thừa trong động phủ cổ xưa; không xuất hiện trực tiếp.","tabs":{"diem":[],"kinhLich":[{"text":"Được nhắc tới qua lời kể Thạch Vân Phong: là vị Chí Tôn cái thế để lại đạo thống/truyền thừa trong một động phủ cổ xưa, sau bị sấm sét từ cửu thiên đánh xuống làm lộ một góc động phủ; nhiều thế lực tranh đoạt Cốt Thư của Ngài.","anchor":"Ta nghĩ nơi Chí Tôn địa kia hẳn là còn ở khu vực này","bridge":true,"khoang":"@c0079"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0079"]},{"id":"te-linh-xuyen-son-giap","name":"Xuyên Sơn Giáp (Tế Linh vàng kim)","aliases":["Tế Linh Xuyên Sơn Giáp","Tế Linh vàng kim","Tế Linh","Xuyên Sơn Giáp"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Tế Linh cỡ lớn @c0083","trangThai":"song","blurb":"Con Tế Linh Xuyên Sơn Giáp khổng lồ dài mấy chục thước, thân tỏa vàng kim, mang huyết mạch truyền thừa Cầu Long thời Thái Cổ; đối thủ chính của nhóc tỳ ở chương trận sinh tử.","vaiTro":"Đối thủ","tinhCach":[{"text":"Hung mãnh, sát khí ngút trời, chiến đấu linh hoạt như đại sư quyền thuật dù thân đồ sộ","chuong":"@c0083"}],"tabs":{"diem":[{"text":"Giáp da cực cứng khó phá, toàn bộ vảy giáp vàng kim là Bảo Cụ có thể lột ra tấn công","chuong":"@c0083"},{"text":"Có huyết mạch truyền thừa từ Cầu Long thời Thái Cổ, thân thể cực cường hãn; được ám chỉ đang mang bệnh trong người","chuong":"@c0083"}],"kinhLich":[{"text":"Lao tới như đại dương hoàng kim đánh gãy cổ thụ tung núi đá, đại chiến nhóc tỳ mấy trăm chiêu bất phân thắng bại; bị đạp nát một lớp vảy đầu phụt máu nhưng giáp da không thương tổn nặng, cuối cùng lột toàn bộ vảy giáp vàng kim thành mưa ánh sáng công kích, bắn ba vảy xuyên thủng cơ thể nhóc tỳ.","anchor":"Con Tế Linh lột vảy giáp vàng kim ra khỏi người trong nháy mắt để công kích một đòn khủng bố này","bridge":true,"khoang":"@c0083"},{"text":"Con di chủng ác linh màu vàng đối đầu nhóc tỳ: trút mưa ánh sáng vảy vàng, nhưng khi dồn hết vảy đi công kích thì thân trần mất bảo vệ, liên tiếp trúng chớp giật, Thái Cổ Ma Cầm và bảo kính khiến gãy xương, cháy đen, vỡ nội tạng; lộ cốt tiễn xương vàng cắt núi trăm mét rồi phát điên truy tìm nhóc tỳ trong sương mù. Do dã tâm tế luyện xương ngoại lai hòng làm nó sống lại nên tổn thương căn cơ, qua trận ác chiến thì cơ thể rạn nứt, phù văn vỡ nát, chia năm xẻ bảy chết thảm tại chỗ, cốt tiễn rơi từ trời xuống.","anchor":"Tế Linh chia năm xẻ bảy, chết thảm tại chỗ","bridge":true,"khoang":"@c0084"},{"importance":"major","chuong":"@c0085","tieuDe":"Xác bị chia, huyết nhục thành chiến lợi phẩm","text":"Sau khi bị hạ, xác Tế Linh vàng óng bị Thạch thôn chia năm xẻ bảy: cốt tiễn kim cốt bị Thạch Hạo đoạt, huyết nhục chứa tinh huyết quý giá được tộc lão đích thân thu gân mạch và bảo huyết, phần còn lại luyện chế với lão dược hoặc hầm ăn mừng; săn được một con Xuyên Sơn Giáp được ví như chiếm cả một bảo tàng.","anchor":"đang thu thập huyết nhục của Tế Linh"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ tử chiến","ghiChu":"Đại chiến mấy trăm chiêu với nhóc tỳ, gây trọng thương cho nó (@c0083)."},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ đối đầu sinh tử","ghiChu":"Bị Thạch Hạo dùng chuỗi bảo thuật của Toan Nghê trọng thương rồi tự bại @c0084"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0083","@c0084","@c0085"]},{"id":"dai-thu-linh-hung-khau-man-hoang","name":"Đại thủ lĩnh hung khấu vùng man hoang","gioiTinh":"nam","theLuc":[{"ten":"Đám hung khấu vùng man hoang","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Thủ lĩnh cầm đầu đám hung khấu vùng man hoang, đứng xa quan sát trận chiến và kinh hãi nghi nhóc tỳ là hậu đại hung thú Thái Cổ.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Lọc lõi, cảnh giác, choáng váng trước sức mạnh của nhóc tỳ","chuong":"@c0083"}],"tabs":{"diem":[],"kinhLich":[{"text":"Cùng đám hung khấu đứng xa xem trận chiến, bị sóng cương khí vàng kim thổi bay tán loạn; choáng váng nghi nhóc tỳ là đời sau của hung thú Thái Cổ như Nhai Tí, Thao Thiết.","anchor":"Nó là.. đời sau của hung thú Thái Cổ sao?","bridge":true,"khoang":"@c0083"},{"text":"Cùng đám cướp bị bốn mươi điểm sáng của vòng răng thú bay tới phế tinh khí và phù văn; riêng đại thủ lĩnh bị quấn xoắn cho phai mờ toàn bộ phù văn, khai ra thế lực Tiểu Tây Thiên và mục tiêu Chí Tôn Thần Tàng, sau đó bị bầy Cự thú xử lý.","anchor":"bốn mươi điểm sáng trắng muốt như ngọc bay về đám cướp","bridge":true,"khoang":"@c0085"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Kẻ theo dõi từ xa","ghiChu":"Quan sát trận chiến của nhóc tỳ, kinh sợ nghi lai lịch (@c0083)."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0083","@c0085"]},{"id":"nguoi-trung-nien-so-thuy-dia","name":"Người trung niên Sơ Thủy Địa","gioiTinh":"nam","aliases":["Người trung niên ~30 tuổi"],"theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Tu sĩ khoảng 30 tuổi ở Sơ Thủy Địa, kiên nhẫn giải thích cho nhóc tỳ quy tắc thông đạo phù văn.","vaiTro":"Nhân vật phụ thoáng qua","tinhCach":[{"text":"Điềm tĩnh, kiên nhẫn giảng giải","chuong":"@c0087"}],"tabs":{"diem":[],"kinhLich":[{"text":"Giảng cho nhóc tỳ rằng người mới tới Hư Thần Giới nhất định bị đưa vào Sơ Thủy Địa, tu hành viên mãn mới được dùng thông đạo phù văn lên khu vực cấp cao hơn.","anchor":"Mới tới Hư Thần giới, nhất định sẽ bị đưa vào 'Sơ Thủy Địa'","bridge":true,"khoang":"@c0087"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Giải thích quy tắc Sơ Thủy Địa cho nhóc tỳ ngây ngô","ghiChu":"@c0087"}],"tuiDo":{}},"nguon":["@c0087"]},{"id":"lao-gia-so-thuy-dia","name":"Lão già Sơ Thủy Địa","gioiTinh":"nam","aliases":[],"theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Tu sĩ già trong đám vây quanh ở Sơ Thủy Địa, ngỏ ý đổi nhiều tinh bích nếu nhóc tỳ đào được Phù Cốt.","vaiTro":"Nhân vật phụ thoáng qua","tinhCach":[{"text":"Tinh ranh, nhạy bén trước vật hiếm","chuong":"@c0087"}],"tabs":{"diem":[],"kinhLich":[{"text":"Cười hắc hắc đề nghị nếu nhóc tỳ đào được Phù Cốt cực hiếm quý thì sẽ đổi bằng rất nhiều tinh bích.","anchor":"Đây là Nguyên Thủy Bảo Cốt sao, xem ra rất hiếm thấy cùng quý giá","bridge":true,"khoang":"@c0087"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Ngỏ ý đổi tinh bích lấy Phù Cốt do nhóc tỳ đào","ghiChu":"@c0087"}],"tuiDo":{}},"nguon":["@c0087"]},{"id":"thai-loan","name":"Thải Loan","aliases":["thiếu nữ tốt bụng"],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiếu nữ hảo tâm ở Sơ Thủy Địa, chỉ Thạch Hạo cách khắc kỷ lục và nhiều lần cảnh báo có kẻ nhắm vào bảo cốt.","vaiTro":"Nhân vật phụ, ân nhân nhỏ của Thạch Hạo ở Hư Thần Giới.","tinhCach":[{"text":"Hảo tâm, chu đáo, hay nhắc nhở","chuong":"@c0089"}],"tabs":{"diem":[],"kinhLich":[{"text":"Thải Loan tự xưng tên với Thạch Hạo, chỉ nó cách khắc thông tin lên bia đá kỷ lục Sơ Thủy Địa và nhiều lần cảnh báo nó đề phòng những kẻ đang nhắm vào bảo cốt vừa đoạt được.","anchor":"một cái tên quen thuộc lập tức đập vào mắt nó, Thạch Nghị!","bridge":true,"khoang":"@c0089"},{"text":"Đi cùng đoàn, cùng Điểu gia bàn tán về danh xưng ‘Chí Tôn trời sinh’ của Thạch Nghị; kinh hãi trước kỷ lục chém chín Thú Vương trong một trận.","anchor":"trong một trận chiến giết chết chín con Thú Vương","bridge":true,"khoang":"@c0090"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"ban-be","quanHe":"Người nàng giúp đỡ và cảnh báo ở Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người đi cùng đoàn ở Sơ Thủy Địa","ghiChu":"@c0090"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089","@c0090"]},{"id":"tinh-bich-dai-gia","name":"Tinh Bích đại gia","aliases":["ông lão râu tóc hoa râm"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Cao thủ Hư Thần Giới (chưa rõ cảnh giới)","trangThai":"song","blurb":"Ông lão râu tóc hoa râm ở Sơ Thủy Địa, đòi dùng lượng lớn tinh bích đổi Nguyên Thủy Bảo Cốt của Thạch Hạo; bị Thạch Hạo cưỡng đặt biệt danh vì chuyện này.","vaiTro":"Nhân vật phụ, đối tác tranh đoạt bảo cốt của Thạch Hạo.","tinhCach":[{"text":"Nôn nóng đoạt bảo, chịu bám theo","chuong":"@c0089"}],"tabs":{"diem":[],"kinhLich":[{"text":"Ông lão viện “ước định” đòi dùng lượng lớn tinh bích đổi Nguyên Thủy Bảo Cốt của Thạch Hạo, bị chối vì nó “còn phải nghiên cứu”; sau đó cùng Chùy thúc, Điểu gia luân phiên thử phá thông đạo Sơ Thủy Địa nhưng mệt tới thổ huyết, đều thất bại.","anchor":"Ba người luân phiên ra trận, mệt tới thổ huyết nhưng cũng không có tác dụng gì.","bridge":true,"khoang":"@c0089"},{"text":"Bị nhóc tỳ gọi đùa là ‘Tinh Bích’ liền bực bội đính chính; kể Thạch Nghị đã tiến vào động tiên tầng cao tìm khiêu chiến Tỳ Hưu và Đào Ngột con, kỷ lục thứ hai là dùng sức mạnh cơ thể (không dùng Cốt Văn) nhảy một bước lên đỉnh núi.","anchor":"đang tìm tòi Tỳ Hưu và Đào Ngột con","bridge":true,"khoang":"@c0090"},{"text":"Sau khi Thạch Hạo hỏi, Tinh Bích đại gia đáp đã tìm được ngọn núi giữ kỷ lục đáng sợ của Thạch Nghị cách mấy dặm, khiến cả nơi bùng nổ khi nghe hai chữ Thạch Nghị.","anchor":"Ta đi phá kỷ lục, đạp đổ tất cả rồi làm lại","bridge":true,"khoang":"@c0092"},{"text":"Cùng ông già dẫn Nhóc tỳ tới ngọn núi giữ kỷ lục, chỉ vào tòa núi và kể lại năm xưa Thạch Nghị giậm chân xông thẳng lên đặt chân lên đỉnh trước mặt nhiều tộc chủ đại tộc mà không ai theo kịp.","anchor":"Chính là ngọn núi này, năm đó đột nhiên Thạch Nghị giậm chân một cái","bridge":true,"khoang":"@c0093"},{"text":"Nhanh nhẹn treo một tấm biển ở nơi đông người, rao đổi bí mật về nãi oa lấy một tinh bích","anchor":"Muốn biết bí mật về nãi oa, xin trả một tinh bích","bridge":true,"khoang":"@c0099"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Kẻ ông lão muốn đổi bảo cốt","ghiChu":"@c0089"},{"ten":"Chùy thúc","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Điểu gia","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người đi cùng, bị nhóc tỳ gọi đùa là ‘Tinh Bích’","ghiChu":"@c0090"},{"ten":"Thạch Hạo","tag":"dong-minh","quanHe":"Hỗ trợ Thạch Hạo ở Sơ Thủy Địa","ghiChu":"Báo tin ngọn núi giữ kỷ lục Thạch Nghị. @c0092"},{"ten":"Chuy thúc","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới bàn luận, chờ đợi Thạch Hạo.","ghiChu":"@c0098"},{"ten":"Điểu gia","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới, đều tin Thạch Hạo không lừa.","ghiChu":"@c0098"},{"ten":"Điểu gia","tag":"doi-thu","quanHe":"Đối thủ buôn tin","ghiChu":"Điểu gia bắt chước treo biển rao bán cạnh tranh"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089","@c0090","@c0092","@c0093","@c0098","@c0099"]},{"id":"chuy-thuc","name":"Chùy thúc","aliases":["người trung niên cho mượn búa"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Động Thiên Cảnh @c0089","trangThai":"song","blurb":"Đại cao thủ Động Thiên Cảnh, cho Thạch Hạo mượn một cây búa; bị nó cưỡng đặt biệt danh “Chùy thúc” vì cái búa, mượn danh vũ khí xin mua bảo cốt.","vaiTro":"Nhân vật phụ, cao thủ Hư Thần Giới muốn đoạt bảo cốt Sơ Thủy Địa.","tinhCach":[{"text":"Ranh mãnh, dùng cớ vũ khí đòi bảo, chịu mất mặt vì bảo cốt","chuong":"@c0089"}],"tabs":{"diem":[],"kinhLich":[{"text":"Chùy thúc mượn danh chuyện cho Thạch Hạo mượn búa để xin mua Nguyên Thủy Bảo Cốt, bị nó vặn lại ngây ngô; sau đó cùng Tinh Bích đại gia và Điểu gia luân phiên ra trận thử phá thông đạo Sơ Thủy Địa, dù là đại cao thủ Động Thiên Cảnh vẫn mệt tới thổ huyết, thất bại.","anchor":"Ba người luân phiên ra trận, mệt tới thổ huyết nhưng cũng không có tác dụng gì.","bridge":true,"khoang":"@c0089"},{"text":"Đi cùng nhóc tỳ đọc bia đá, giải thích Thú Vương là cường giả tuyệt đỉnh cùng cảnh giới thống trị một dãy núi, người thường gặp phải phải chạy trối chết; kỷ lục Thạch Nghị chém chín Thú Vương là chưa từng có.","anchor":"trong một trận chiến giết chết chín con Thú Vương","bridge":true,"khoang":"@c0090"},{"text":"Lau mồ hôi lạnh, nhận xét đứa nhóc đi tới đâu nơi đó không yên bình, may mà nó ở cách xa họ","anchor":"Nó đúng là một đứa gieo vạ, đi tới đâu là nơi đó không được yên bình","bridge":true,"khoang":"@c0099"}],"tuViMoc":[{"chuong":"@c0089","canhGioi":"Động Thiên Cảnh","text":"Được xác nhận là đại cao thủ Động Thiên Cảnh trong Hư Thần Giới.","importance":"minor"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"khac","quanHe":"Cho mượn búa, mượn cớ xin mua bảo cốt","ghiChu":"@c0089"},{"ten":"Tinh Bích đại gia","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Điểu gia","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người đi cùng, giảng giải kỷ lục Thạch Nghị cho nhóc tỳ","ghiChu":"@c0090"},{"ten":"Điểu gia","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới dõi theo Thạch Hạo.","ghiChu":"@c0098"},{"ten":"Tinh Bích đại gia","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới, được ông trấn an rằng Thạch Hạo sẽ tạo động tĩnh lớn.","ghiChu":"@c0098"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Đứa bé mà ông nghi ngờ đã lừa cả nhóm.","ghiChu":"@c0098"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Cái búa","trangThai":"dang-co","moTa":"Vũ khí Chùy thúc cho Thạch Hạo mượn để phá thông đạo Sơ Thủy Địa","nguon":"@c0089"}]}},"nguon":["@c0089","@c0090","@c0098","@c0099"]},{"id":"dieu-gia","name":"Điểu gia","aliases":["ông lão có chim ngũ sắc trên vai"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Cao thủ Hư Thần Giới (chưa rõ cảnh giới)","trangThai":"song","blurb":"Ông lão có con chim ngũ sắc đậu trên vai ở Sơ Thủy Địa, được Thạch Hạo cưỡng đặt biệt danh; nhắc nó khắc kỷ lục và cảnh báo bảo cốt bị nhắm.","vaiTro":"Nhân vật phụ, cao thủ Hư Thần Giới quanh Thạch Hạo.","tinhCach":[{"text":"Cởi mở, hay nhắc nhở, chịu chơi cùng nhóc tỳ","chuong":"@c0089"}],"tabs":{"diem":[],"kinhLich":[{"text":"Điểu gia hướng dẫn Thạch Hạo khắc thông tin lên bia đá kỷ lục và cảnh báo có kẻ đang nhắm vào Nguyên Thủy Bảo Cốt; sau đó cùng Chùy thúc và Tinh Bích đại gia luân phiên thử phá thông đạo Sơ Thủy Địa, mệt tới thổ huyết, đều thất bại.","anchor":"Ba người luân phiên ra trận, mệt tới thổ huyết nhưng cũng không có tác dụng gì.","bridge":true,"khoang":"@c0089"},{"text":"Cùng Thải Loan bàn tán chuyện Thạch Nghị được gọi ‘Chí Tôn trời sinh’; nhắc nhở nhóc tỳ coi chừng bọn muốn cướp bảo cốt trong tay.","anchor":"Thiếu gia là Chí Tôn trời sinh chân chính, nô tỳ là A Man","bridge":true,"khoang":"@c0090"},{"text":"Trước khi Nhóc tỳ ra tay phá kỷ lục ở Song Tử Sơn, lên tiếng hỏi han xem đã chuẩn bị chu toàn chưa.","anchor":"Nhóc con, ngươi chuẩn bị kỹ càng chưa đó?","bridge":true,"khoang":"@c0093"},{"text":"Lập tức bắt chước Tinh Bích đại gia, kéo một tấm vải rách treo bên cạnh với lời rao cạnh tranh","anchor":"Một tinh bích, bí mật độc nhất","bridge":true,"khoang":"@c0099"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"an-nhan","quanHe":"Hướng dẫn khắc kỷ lục và cảnh báo bảo cốt bị nhắm","ghiChu":"@c0089"},{"ten":"Thải Loan","tag":"dong-minh","quanHe":"Cùng cảnh báo Thạch Hạo có người nhắm bảo cốt","ghiChu":"@c0089"},{"ten":"Chùy thúc","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Tinh Bích đại gia","tag":"dong-minh","quanHe":"Cùng luân phiên thử phá thông đạo Sơ Thủy Địa","ghiChu":"@c0089"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người đi cùng, cảnh báo nhóc tỳ về bọn cướp bảo cốt","ghiChu":"@c0090"},{"ten":"Tinh Bích đại gia","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới chờ đợi Thạch Hạo.","ghiChu":"@c0098"},{"ten":"Chuy thúc","tag":"dong-minh","quanHe":"Cùng nhóm Hư Thần giới, phản biện nghi ngờ của Chuy thúc.","ghiChu":"@c0098"},{"ten":"Tinh Bích đại gia","tag":"doi-thu","quanHe":"Đối thủ buôn tin","ghiChu":"Bắt chước treo biển rao bán cạnh Tinh Bích đại gia"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089","@c0090","@c0093","@c0098","@c0099"]},{"id":"hoa-van-tien","name":"Hỏa Vân Tiên","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Ngự hỏa Cực Cảnh @c0089","trangThai":"khong-ro","blurb":"Chủ nhân kỷ lục ngự hỏa đạt Cực Cảnh trên bia đá Sơ Thủy Địa từ mấy vạn năm trước; danh chỉ nhắc qua bảng kỷ lục.","vaiTro":"Nhân vật kỷ lục thời cổ trên bia đá Sơ Thủy Địa.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Tên Hỏa Vân Tiên hiện trên bảng kỷ lục Sơ Thủy Địa với thành tích ngự hỏa đạt Cực Cảnh — kỷ lục lập từ mấy vạn năm trước, được Thạch Hạo đọc thấy.","anchor":"một cái tên quen thuộc lập tức đập vào mắt nó, Thạch Nghị!","bridge":true,"khoang":"@c0089"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089"]},{"id":"yeu-nguyet","name":"Yêu Nguyệt","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Bàn Huyết Cảnh (kỷ lục vô địch cùng cấp) @c0089","trangThai":"khong-ro","blurb":"Chủ nhân kỷ lục sinh mệnh lực mạnh vô địch Bàn Huyết Cảnh trên bia đá Sơ Thủy Địa, kỷ lục lập từ ngàn năm trước.","vaiTro":"Nhân vật kỷ lục cổ trên bia đá Sơ Thủy Địa.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Tên Yêu Nguyệt hiện trên bảng kỷ lục Sơ Thủy Địa với thần thông một niệm hoa nở, gỗ khô tái sinh, sinh mệnh lực mạnh, không ai vượt qua ở Bàn Huyết Cảnh — kỷ lục lập từ ngàn năm trước.","anchor":"một cái tên quen thuộc lập tức đập vào mắt nó, Thạch Nghị!","bridge":true,"khoang":"@c0089"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089"]},{"id":"than-nhan-thuong-co","name":"Thần Nhân Thượng Cổ","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ (bậc Thần Nhân Thượng Cổ)","trangThai":"khong-ro","blurb":"Bậc Thần Nhân Thượng Cổ được nhắc là đã từng tới Hư Thần Giới, có khả năng còn cư ngụ ở những động tiên tầng cao hơn.","vaiTro":"Bậc cường giả huyền thoại được cài cắm.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Thần Nhân Thượng Cổ được nhắc là đã từng đặt chân tới Hư Thần Giới; theo suy đoán, ông có thể vẫn còn cư ngụ ở những động tiên tầng cao hơn Sơ Thủy Địa.","anchor":"Thần Nhân Thượng Cổ quả nhiên cũng đã tới Hư Thần Giới","bridge":true,"khoang":"@c0089"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0089"]},{"id":"xich-van-cong-tu","name":"Xích Vân công tử","gioiTinh":"nam","trangThai":"song","tabs":{"diem":[{"text":"Cường giả thanh niên nổi tiếng khắp Hư Thần Giới, nhiều người kiêng kỵ","chuong":"@c0090"}],"kinhLich":[{"text":"Bảo Cụ Xích Vũ mười tám cái lông đỏ được nhận ra là binh khí của Xích Vân công tử; hắn được nhắc là cường giả thanh niên nổi tiếng khắp Hư Thần Giới; đệ đệ Xích Phong bị nhóc tỳ đánh trọng thương, mất Bảo Phiến; bản thân hắn chưa trực tiếp ra mặt.","anchor":"Nó là binh khí của Xích Vân công tử","bridge":true,"khoang":"@c0090"}],"tuViMoc":[],"nhanMach":[{"ten":"Xích Phong","tag":"ho-hang","quanHe":"Đệ đệ, bị nhóc tỳ một chưởng đánh nát phù văn, gãy xương nửa người","ghiChu":"@c0090"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Nhóc tỳ đoạt Bảo Phiến của hắn, đánh trọng thương đệ đệ","ghiChu":"@c0090"}],"tuiDo":{"phapBao":[{"ten":"Xích Vũ (Bảo Phiến)","loai":"bao-cu","trangThai":"mat","moTa":"Bảo Cụ hình quạt đỏ mười tám lông, nghi lông quý Thái Cổ Di Chủng; bị đệ đệ Xích Phong đem xuống Sơ Thủy Địa rồi bị nhóc tỳ đoạt","nguon":"@c0090"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0090"]},{"id":"xich-phong","name":"Xích Phong","gioiTinh":"nam","trangThai":"song","tabs":{"diem":[{"text":"Đệ đệ Xích Vân công tử; không đủ sức thúc giục Bảo Phiến, phải tách mười tám lông ra dùng","chuong":"@c0090"}],"kinhLich":[{"text":"Là thiếu niên trốn ở Sơ Thủy Địa, chủ nhân trực tiếp của Xích Vũ nhưng không đủ sức thúc giục nên phải tách ra dùng; bị nhóc tỳ đạp đất xông hơn trăm mét tung một chưởng đánh nát phù văn, phun máu, xương nửa người gãy lìa, thân mềm oặt; mười tám Thần Vũ rơi đất bị nhóc tỳ đoạt hết.","anchor":"Một chưởng rơi xuống liền đánh nát phù văn của thiếu niên này","bridge":true,"khoang":"@c0090"}],"tuViMoc":[],"nhanMach":[{"ten":"Xích Vân công tử","tag":"ho-hang","quanHe":"Anh ruột, chủ nhân thật của Bảo Phiến","ghiChu":"@c0090"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Bị nhóc tỳ một chưởng đánh nát phù văn, mất Bảo Phiến","ghiChu":"@c0090"}],"tuiDo":{"phapBao":[{"ten":"Xích Vũ (Bảo Phiến)","loai":"bao-cu","trangThai":"mat","moTa":"Mượn của anh Xích Vân, tách mười tám lông vì không đủ sức thúc giục cả cái quạt; bị nhóc tỳ đoạt sau khi trọng thương","nguon":"@c0090"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0090"]},{"id":"nu-chien-than-truc-loc","name":"Nữ Chiến Thần Trục Lộc Thư Viện","gioiTinh":"nu","theLuc":[{"ten":"Trục Lộc thư viện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Nữ tử của Trục Lộc Thư Viện cưỡi Ngũ Sắc Loan Điểu, mặc giáp trụ hoàng kim đến Sơ Thủy Địa xem Nhóc tỳ phá kỷ lục Thạch Nghị.","vaiTro":"Truyền nhân Trục Lộc Thư Viện đến quan sát kỳ tích phá kỷ lục","tinhCach":[{"text":"Uy nghi, ánh mắt sắc bén","chuong":"@c0093"}],"tabs":{"diem":[{"text":"Cưỡi Ngũ Sắc Loan Điểu, khoác giáp trụ hoàng kim toàn thân phát bảo huy","chuong":"@c0093"}],"kinhLich":[{"text":"Mặc giáp trụ hoàng kim, cưỡi chim Loan năm màu bay tới giữa đám đông, trực tiếp mời nhóc tỳ vừa phá kỷ lục nhảy của Thạch Nghị gia nhập Trục Lộc thư viện; khi nhóc tỳ xin suy nghĩ thêm để không đắc tội bên nào thì dứt khoát rút lui cùng các thế lực khác.","anchor":"Tỷ muốn mời tiểu đệ gia nhập Trục Lộc thư viện","bridge":true,"khoang":"@c0094"}],"tuViMoc":[],"nhanMach":[{"ten":"A Man","tag":"khac","quanHe":"Xa lạ","ghiChu":"Đến xem Nhóc tỳ phá kỷ lục Song Tử Sơn"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[{"ten":"Ngũ Sắc Loan Điểu","moTa":"Dị cầm năm sắc dùng làm thú cưỡi, ẩn trong sương mù rực rỡ","nguon":"@c0093"}],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Giáp trụ hoàng kim","moTa":"Bảo giáp phát sáng, toàn thân óng ánh bảo huy","nguon":"@c0093"}]}},"nguon":["@c0093","@c0094"]},{"id":"ba-lao-dong-tu-bac-nhom-ha-u-vu","name":"Bà lão đồng tử màu bạc","aliases":[],"gioiTinh":"nu","theLuc":[],"trangThai":"song","vaiTro":"Trưởng bối khí tức rất mạnh trong nhóm Hạ U Vũ, mắt bạc có ký hiệu chuyển động như nhật nguyệt.","tabs":{"diem":[],"kinhLich":[{"text":"Đi cùng nhóm Hạ U Vũ dò xét nhóc tỳ; đánh giá hai tay nó vung một cái có thần lực tám chín vạn cân, đã gần cửa ải Cực Cảnh lúc Thái Cổ Hung Thú khảo nghiệm con non, khiến cả nhóm chấn động; hứa sẽ đi xin thêm phù bài cho Vũ Tộc","anchor":"đã tiếp cận tới cửa ải Cực Cảnh lúc Thái Cổ Hung Thú khảo nghiệm con non rồi","bridge":true,"khoang":"@c0071"}],"tuViMoc":[],"nhanMach":[{"ten":"Hạ U Vũ","tag":"dong-hanh","quanHe":"Cùng nhóm đi Tây Cương phát phù bài","ghiChu":"Trưởng bối khí tức mạnh trong nhóm @c0071"}],"tuiDo":{}},"nguon":["@c0071"]},{"id":"nguoi-trung-nien-cho-muon-bua-hu-than-gioi","name":"Người trung niên cho mượn búa","gioiTinh":"nam","aliases":[],"blurb":"Kẻ trêu chọc trong Hư Thần Giới, ném cho nhóc tỳ cây búa hai ngàn cân và đau lòng khi búa bị đập gãy.","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Trêu chọc mời nhóc tỳ mượn dụng cụ, ném xuống cây búa hai ngàn cân to bằng cối xay khiến mặt đất lún hố, rồi đau lòng khi búa bị đập đến gãy đầu.","anchor":"cây búa biến hình, đầu búa gãy lìa khỏi chuôi bay ra ngoài","bridge":true,"khoang":"@c0088"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0088"]},{"id":"thieu-nu-giai-thich-so-thuy-dia","name":"Thiếu nữ giải thích quy tắc Sơ Thủy Địa","gioiTinh":"nu","aliases":[],"blurb":"Thiếu nữ tốt bụng trong Hư Thần Giới, giải thích cho nhóc tỳ quy tắc Sơ Thủy Địa và cơ chế phá cực cảnh.","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Giải thích Hư Thần Giới do Cổ Thần Minh xây dựng để bồi dưỡng hậu bối; nơi Sơ Thủy Địa giới hạn mọi người ở chiến lực Bàn Huyết cảnh, ai đánh vỡ được một loại cực cảnh sẽ nhận chỗ tốt, và Hư Thần Giới sẽ che giấu khí thế, bảo thuật của người thi pháp để giữ bí mật.","anchor":"bất luận tu vi của ai mạnh mẽ cơ nào cũng chỉ có thể phát huy ra chiến lực ở Bàn Huyết cảnh","bridge":true,"khoang":"@c0088"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0088"]},{"id":"thanh-phong","name":"Thanh Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thạch thôn","trangThai":"da-roi"}],"canhGioiCaoNhat":"Bàn Huyết Cảnh sắp trung kỳ","trangThai":"song","blurb":"Trẻ con Thạch thôn đồng hành cùng Thạch Hạo rời thôn hướng Bổ Thiên Các, giỏi phù văn, đã tiến vào Bàn Huyết Cảnh.","vaiTro":"Bạn đồng hành","tinhCach":[{"text":"Hào hứng với thế giới mới, chăm chỉ tu hành, giỏi phù văn","chuong":"@c0095"}],"tabs":{"diem":[{"text":"Được Thạch Hạo đưa đi Bổ Thiên Các, tiến bộ thần tốc nhờ chân huyết tẩy lễ","chuong":"@c0095"}],"kinhLich":[{"text":"Cùng Thạch Hạo rời Thạch thôn lên đường; nhờ chân huyết tẩy lễ và Linh Dược đã tiến vào Bàn Huyết Cảnh sắp trung kỳ; vượt Đại Hoang tới Thạch quốc; thay nhóc tỳ vào Hư Thần Giới dò hỏi Chùy thúc, Điểu gia, Tinh Bích đại gia về đường tới Bổ Thiên Các, mang tin về nhóc tỳ đã thành truyền thuyết.","anchor":"nó đã tiến vào Bàn Huyết Cảnh, mà cũng sắp đến trung kỳ rồi","bridge":true,"khoang":"@c0095"},{"text":"Cùng Thạch Hạo và Bóng Lông băng Đại Hoang tới gần Bổ Thiên Các; đề nghị bắt dã thú làm thú cưỡi, cười trộm khi Thạch Hạo bị gọi “kỳ hoa”, nài Thạch Hạo cùng vào Bổ Thiên Các, dọa bỏ đi nếu không.","anchor":"nhóc tỳ và Thanh Phong đã lại lên đường","bridge":true,"khoang":"@c0096"},{"text":"Nhận phù bài của Thạch Hạo, cầm phù bài thứ mười sáu vào thẳng sơn môn Bổ Thiên các không cần qua thử thách, trở thành đệ tử được coi trọng.","anchor":"đây cũng là miếng phù bài thứ mười sáu rồi","bridge":true,"khoang":"@c0097"}],"tuViMoc":[{"chuong":"@c0095","canhGioi":"Bàn Huyết Cảnh","text":"Tiến vào Bàn Huyết Cảnh sắp trung kỳ nhờ chân huyết hung thú tẩy lễ và nuốt Linh Dược trong hành trình vượt Đại Hoang.","importance":"minor"}],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Người dẫn đường và bảo hộ","ghiChu":"Muốn đưa Thanh Phong tới Bổ Thiên Các"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Bạn đồng hành, gọi là ca/tiểu ca ca"},{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":"Nhận phù bài từ Thạch Hạo"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0095","@c0096","@c0097"]},{"id":"mao-cau","name":"Mao Cầu","cn":"","aliases":[],"gioiTinh":"khac","theLuc":[{"ten":"Thạch thôn","trangThai":"da-roi"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Sinh vật nhỏ bằng nắm đấm, theo Thạch Hạo lên đường vì kích thước nhỏ dễ mang.","vaiTro":"Linh vật đồng hành","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Nhảy lên vai Thạch Hạo khi xuất phát, được mang theo vì nhỏ dễ mang.","anchor":"nhóc tỳ cùng Thanh Phong lên đường","bridge":true,"khoang":"@c0095"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Hạo","tag":"dong-hanh","quanHe":"Chủ nhân","ghiChu":"Theo cùng lên đường"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0095"]},{"id":"co-gai-ao-tim","name":"Cô gái áo tím","gioiTinh":"nu","theLuc":[{"ten":"Hoàng tộc một cổ quốc","trangThai":"danh-nghia"}],"trangThai":"song","blurb":"Thiếu nữ áo tím răng trắng mắt sáng, nghi thuộc hoàng tộc một cổ quốc, tới Sơ Thủy Địa nghe tin nhóc tỳ.","vaiTro":"Nhân vật phụ nghi hoàng tộc cổ quốc","tabs":{"kinhLich":[{"text":"Đứng trên thú cốt tỏa mây tía cùng đám cường giả tới sạp của Tinh Bích đại gia và Điểu gia, trả một viên tinh bích hỏi chỗ đặt chân của nhóc tỳ; hai lão không dám lừa, xác nhận nhóc tỳ tới Bổ Thiên Các hoặc Trục Lộc Thư Viện.","anchor":"Cô gái áo tím bước xuống khỏi thú cốt, sóng mắt lưu chuyển.","bridge":true,"khoang":"@c0096"}]},"nguon":["@c0096"]},{"id":"lao-nhan-canh-cua-bo-thien-cac","name":"Lão nhân canh cửa Bổ Thiên các","cn":"","aliases":["Lão nhân trước sơn môn Bổ Thiên các"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0098)","trangThai":"song","blurb":"Lão nhân ngồi xếp bằng trước sơn môn Bổ Thiên các, thân sáng, tiếng như sấm; điều phối khảo nghiệm vượt ải và cảnh cáo các thế lực ngoại lai.","vaiTro":"Người canh cửa Bổ Thiên các, điều phối khảo nghiệm nhập môn.","tinhCach":[{"text":"Uy nghiêm, cứng rắn, giữ luật lệ chặt chẽ.","chuong":"@c0098"}],"tabs":{"diem":[{"text":"Ngồi xếp bằng trên tảng đá trước sơn môn, thân sáng, tiếng như sấm.","chuong":"@c0098"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Nữ Chiến Thần Trục Lộc thư viện","tag":"doi-thu","quanHe":"Bị ông cảnh cáo quá giới hạn khi đến Bổ Thiên các đoạt người.","ghiChu":"@c0098"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0098"]},{"id":"nu-chien-than-truc-loc-thu-vien","name":"Nữ Chiến Thần Trục Lộc thư viện","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Trục Lộc thư viện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (@c0098)","trangThai":"song","blurb":"Cô gái mặc chiến y hoàng kim cưỡi chim Loan năm màu, được xưng “Nữ Chiến Thần của Trục Lộc thư viện”; đến tận Bổ Thiên các để đoạt người.","vaiTro":"Thiên tài Trục Lộc thư viện, người đi đầu vụ đoạt người trước sơn môn Bổ Thiên các.","tinhCach":[{"text":"Kiêu ngạo, táo bạo, trực tiếp không kiêng dè.","chuong":"@c0098"}],"tabs":{"diem":[{"text":"Dung mạo trong sáng kiêu ngạo, chiến y hoàng kim, cưỡi chim Loan năm màu.","chuong":"@c0098"}],"kinhLich":[{"text":"Nữ tử tỏa ánh sáng vàng, mỹ lệ yêu kiều, giữa lúc trưởng lão Bổ Thiên Các phẫn nộ đã công khai chiêu mộ nhóc tỳ, tuyên bố cửa Trục Lộc thư viện luôn mở rộng với tiểu huynh đệ","anchor":"Cánh cửa Trục Lộc thư viên sẽ mãi mở rộng với đệ","bridge":true,"khoang":"@c0099"},{"text":"Cùng chiến tướng các thế lực đứng ngoài quan sát cục diện Bổ Thiên các, thực ra đến để tìm nhóc tỳ.","anchor":"có tới tám chín ngàn người vượt ải thành công!","bridge":true,"khoang":"@c0100"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão nhân canh cửa Bổ Thiên các","tag":"doi-thu","quanHe":"Bị lão nhân cảnh cáo quá giới hạn.","ghiChu":"@c0098"},{"ten":"Thạch Hạo","tag":"su-mon","quanHe":"Người muốn chiêu mộ","ghiChu":"Mời gọi nhóc tỳ gia nhập Trục Lộc thư viện"},{"ten":"Thạch Hạo","tag":"khac","quanHe":"Đến chiến trường tìm nhóc tỳ","ghiChu":"@c0100"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[{"ten":"Chim Loan năm màu","trangThai":"dang-co","moTa":"Toạ kỵ ngũ sắc, bao quanh mây mù thần hi.","nguon":"@c0098"}],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0098","@c0099","@c0100"]},{"id":"hung-phi-truong-lao","name":"Hùng Phi","aliases":["Hùng Phi trưởng lão"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Trưởng lão Bổ Thiên Các dẫn đoàn chờ ở lối ra cổ chiến trường, đếm số người vượt ải.","vaiTro":"Trưởng lão Bổ Thiên Các phụ trách lối ra khu thí luyện.","tinhCach":[{"text":"Sốt ruột, dễ hoảng loạn khi biến cố xảy ra","chuong":"@c0099"}],"tabs":{"diem":[],"kinhLich":[{"text":"Dẫn đoàn chờ ở lối ra tám khu vực và đếm số người vượt ải; hoảng loạn sốt ruột khi con số bùng nổ tới 8927; khẳng định thủ phạm phá trận là Hùng hài tử, rơi lệ đầy mặt","anchor":"nó trộm cắp bảo cốt bên trong khu vực thứ tám, phá hỏng nơi thí luyện","bridge":true,"khoang":"@c0099"},{"text":"Than quá nhiều người khi đối mặt tám chín ngàn người vượt ải thành công nhưng bị tộc lão bộ lạc cắt lời, bị ép giữ lời hứa thu nhận đệ tử.","anchor":"có tới tám chín ngàn người vượt ải thành công!","bridge":true,"khoang":"@c0100"}],"tuViMoc":[],"nhanMach":[{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Đồng liêu trưởng lão","ghiChu":"Cùng chờ lối ra, cùng lo lắng vì trận bị phá"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Thủ phạm truy tìm","ghiChu":"Xác định nhóc tỳ Hùng hài tử là kẻ phá trận"},{"ten":"Trác Vân","tag":"dong-minh","quanHe":"Cùng làm trưởng lão Bổ Thiên các, cùng bế tắc chuyện thu nhận đệ tử","ghiChu":"@c0100"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0099","@c0100"]},{"id":"trac-van-truong-lao","name":"Trác Vân","aliases":["Trác Vân trưởng lão"],"gioiTinh":"nam","theLuc":[{"ten":"Bổ Thiên Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Trưởng lão Bổ Thiên Các, an ủi mọi người rồi cứng họng khi số người vượt ải bùng nổ.","vaiTro":"Trưởng lão Bổ Thiên Các tại lối ra khu thí luyện.","tinhCach":[{"text":"Tự tin ban đầu, dễ bối rối và đổ mồ hôi khi tình thế vượt tầm kiểm soát","chuong":"@c0099"}],"tabs":{"diem":[],"kinhLich":[{"text":"An ủi mọi người rồi cứng họng vì quá đông người vượt ải; dọa sẽ đánh mông nhóc tỳ nở hoa; đổ mồ hôi trán và đảo mắt nhìn quanh khi nữ chiến thần Trục Lộc thư viện công khai chiêu mộ nhóc tỳ","anchor":"Cánh cửa Trục Lộc thư viên sẽ mãi mở rộng với đệ","bridge":true,"khoang":"@c0099"},{"text":"Vẻ mặt đắng chát xin các tộc lão bộ lạc châm chước về số lượng đệ tử phải thu nhận sau khi tám chín ngàn người vượt ải.","anchor":"có tới tám chín ngàn người vượt ải thành công!","bridge":true,"khoang":"@c0100"}],"tuViMoc":[],"nhanMach":[{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Đồng liêu trưởng lão","ghiChu":"Cùng chờ lối ra, cùng ứng phó trận bị phá"},{"ten":"Thạch Hạo","tag":"doi-thu","quanHe":"Đối tượng truy phạt","ghiChu":"Dọa đánh mông nhóc tỳ vì phá hỏng nơi thí luyện"},{"ten":"Nữ Chiến Thần Trục Lộc thư viện","tag":"doi-thu","quanHe":"Đối thủ tranh người","ghiChu":"Nàng chiêu mộ nhóc tỳ khiến Trác Vân đổ mồ hôi trán"},{"ten":"Hùng Phi","tag":"dong-minh","quanHe":"Cùng làm trưởng lão Bổ Thiên các, cùng bế tắc chuyện thu nhận đệ tử","ghiChu":"@c0100"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0099","@c0100"]},{"id":"vu-vuong","name":"Vũ Vương","gioiTinh":"nam","trangThai":"song","blurb":"Vương của Vũ tộc ở Thạch quốc (chữ \"Vũ\" chỉ lông vũ loài chim); sinh linh hình người sừng vàng, cánh ngũ sắc, dùng hung đao. Cùng liên minh công chúa Hỏa quốc đi Thần Quật đoạt chí bảo, bị nhóc tỳ đá hộc máu và chặt đứt một cánh tay.","tabs":{"kinhLich":[{"text":"Được nhắc là chủ nhân con chim khổng lồ Thái Cổ di chủng làm vật cưỡi của Vũ Vương phủ, chở Thạch Nghị tới sơn môn Bổ Thiên các.","anchor":"Thạch Nghị muốn gia nhập Bổ Thiên các rồi, mục đích chỉ có một, muốn cùng Thượng Cổ Thánh Nhân sánh vai","bridge":true,"khoang":"@c0097"}],"nhanMach":[]},"nguon":["@c0097"],"aliases":[]}]};