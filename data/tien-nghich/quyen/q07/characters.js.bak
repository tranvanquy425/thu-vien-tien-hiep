/* characters q07 (91 mục) — cân xếp hạng toàn cảnh Lão già tóc bạc trong Lôi Tiên Giới */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["tien-nghich"]=window.__LIBQ["tien-nghich"]||{};window.__LIBQ["tien-nghich"]["q07"]=window.__LIBQ["tien-nghich"]["q07"]||{};window.__LIBQ["tien-nghich"]["q07"]["characters"]={"updatedAt":"2026-07-06","count":91,"chars":[{"id":"vuong-lam","name":"Vương Lâm","aliases":["Hứa Mộc","chủ nhân Hoành Vân Phong","lão tổ Thanh Linh Tinh","Tôn Chủ","Tôn Chủ của Thân Công Hổ","Vân Hà Tinh"],"canhGioiCaoNhat":"Vấn Đỉnh viên mãn @c0689","trangThai":"song @c0694","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0635","importance":"normal","tieuDe":"Nhận con oán ảnh","text":"Vương Lâm nhận ra oán ảnh trong sương đen có quan hệ huyết mạch với mình, lập tức thu chiêu và dùng Tiên vệ khôi lỗi bao phủ màn sương để ngăn nó hành động; sau khi biết Liễu Mi đã luyện đứa nhỏ trăm năm thành oán ảnh, hắn quyết tâm cứu hồi đứa nhỏ dù mất ngàn năm, rồi bùng sát ý hiếm thấy với Liễu Mi, dùng nhiều thần thông ép nàng tới tuyệt cảnh; khi Huyễn gia Lão Tổ cứu Liễu Mi, hắn tuyên bố Huyễn gia sẽ bị diệt tộc và phóng kiếm khí Lăng Thiên Hầu truy kích vào lốc xoáy.","anchor":"Loại cảm giác máu huyết tương dung bỗng nhiên mạnh mẽ xuất hiện toàn thân"},{"text":"Sau khi kiếm khí truy sát Huyễn gia Lão Tổ, Vương Lâm trở lại Nhiễm Vân Tinh đối diện oán anh trong màn sương đen; hắn nhận ra đây là huyết mạch của mình, để đứa bé cắn hút máu mà vẫn dịu dàng đổi tên Lệ Nhi thành Vương Bình, mong con được bình an.","anchor":"Từ nay về sau tên của ngươi là Vương Bình… Ta hy vọng cả đời này ngươi sẽ bình an, không giống như ta…","bridge":true,"khoang":"@c0636"},{"chuong":"@c0637","importance":"normal","tieuDe":"Giữ đạo nghĩa ba ngọc","text":"Vương Lâm phong ấn oán anh Bình nhi, đưa vào Thiên nghịch và hứa sẽ bế quan xua oán khí cho con; sau đó hắn thu hồi đệ tử hồn cho Tôn Hồn Phiên, bỏ qua chuyện Tôn Tích từng giấu giếm, giữ lời vì ba Tiên ngọc để bảo vệ hậu nhân ba nhà, dùng Đạo hóa Hoàng Tuyền cùng Bát phẩm đan dược giúp Tôn Tích khôi phục tu vi rồi rời Nhiễm Vân Tinh, lao tới Thiên Huyễn Tinh với ý định diệt Huyễn gia nếu họ bảo vệ Liễu Mi.","anchor":"những hậu nhân của họ ta sẽ bảo đảm được bình yên trong trăm năm"},{"text":"Vương Lâm cưỡi Tinh La bàn tới Thiên Huyễn Tinh với sát ý, dùng Tiên vệ khôi lỗi và Xạ Thần xa hóa Lôi Thú khiến Thiên Quỳ Tử rút lui, sau đó tiến tới Nhà Tổ Huyễn gia đòi giao Liễu Mi và mở phong ấn Lôi Thú công kích đại trận.","anchor":"Hắn đến với mục đích giết người.","bridge":true,"khoang":"@c0638"},{"text":"Vương Lâm thúc Lôi Thú và Tiên vệ khôi lỗi liên thủ công kích Huyễn gia đại trận; khi trận pháp bị ép đến cực hạn, hắn lấy Vũ Kiếm tiên do Chu Dật phân ly truyền thừa và thi triển Trảm La Quyết, khiến Huyễn gia Lão Tổ nhận ra khí tức quy tắc.","anchor":"Kiếm này chính là Vũ Kiếm tiên, nó được Chu Dật tiền bối phân ly, truyền thừa muôn đời cho Vương Lâm.","bridge":true,"khoang":"@c0639"},{"text":"Vương Lâm thi triển Trảm La Quyết, một kiếm chứa quy tắc khiến Huyễn gia đại trận sụp đổ trước khi va chạm trực tiếp; sau đó hắn chịu hao tổn lớn, đối diện Phúc Trạch ngọc giản và gọi tồn tại trong nguyên thần với lời hứa thả tự do sau trận.","anchor":"Trong phút chốc, Huyễn gia đại trận chưa thực sự tiếp xúc và bị công kích nhưng cũng đã sụp đổ.","bridge":true,"khoang":"@c0640"},{"chuong":"@c0641","importance":"normal","tieuDe":"Mượn lực Tán Ma","text":"Trong thế không thể giết Liễu Mi bằng thủ đoạn thông thường khi nàng được Huyễn gia Lão Tổ bảo hộ, Vương Lâm chủ động gọi Tán Ma, chấp nhận giao dịch thả tự do sau trận để đổi lấy sức chiến đấu; khi Tán Ma nhập thể, thân thể hắn bị ma khí khống chế, ma giáp bao phủ, tiên lực chuyển thành ma lực; dù mất quyền chủ động thân thể, hắn vẫn cảm nhận quá trình Cổ Ma rút tinh hồn Thiên Huyễn Tinh và sinh ra cảm ngộ.","anchor":"Sau khi trận chiến này chấm dứt, ta sẽ thả tự do cho ngươi !"},{"text":"Trong lúc thân thể bị Tán Ma khống chế, Vương Lâm trực tiếp cảm nhận Trừu hồn và va chạm cấp bước thứ hai, nhờ đó nhận rõ khoảng cách giữa bản thân với tầng thứ này và khát vọng đột phá càng mạnh.","anchor":"Một trận chiến này, Tán Ma khống chế thân thể hắn, mang đến cho hắn lợi ích lớn không thể tưởng tượng được.","bridge":true,"khoang":"@c0642"},{"chuong":"@c0643","importance":"major","tieuDe":"Nhận di vật quy ẩn","text":"Thân thể bị Tán Ma khống chế phá lớp bảo hộ cuối cùng của Huyễn gia; sau khi Tán Ma nuốt Huyễn Vô Tình và rời đi, hắn nhận túi trữ vật Liễu Mi để lại, biết trong đó có đan dược cùng ngọc giản; hắn không diệt toàn tộc Huyễn gia, buông bỏ việc truy xét Liễu Mi thật sự chết hay chưa rồi đưa đứa nhỏ tới Lạc Nguyệt thôn sống ẩn như thợ mộc.","anchor":"Bên trong có một viên đan dược và một khối ngọc giản, ngoài ra không có thêm vật nào nữa."},{"chuong":"@c0644","importance":"major","tieuDe":"Ẩn cư nuôi con","text":"Vương Lâm xác lập Vương Bình là con, dùng đan dược và thần thông Lôi hệ âm thầm khu trừ oán khí cho đứa trẻ; hắn hủy ký ức cũ của Vương Bình để cho con một đời mới, chọn sống như phàm nhân tại thôn Lạc Nguyệt bằng nghề thợ mộc, rồi kiên quyết không để Vương Bình tu đạo và muốn bầu bạn với con trọn một kiếp luân hồi.","anchor":"Trí nhớ của Vương Bình đã bị Vương Lâm huỷ đi, cho nó một cuộc đời mới."},{"chuong":"@c0645","importance":"normal","tieuDe":"Đạo tâm thăng hoa","text":"Sống ở thôn Lạc Nguyệt như một phàm nhân, Vương Lâm từ chối chuyện tái hôn, chăm sóc Vương Bình và nhiều năm gần như không dùng thần thông ngoài việc xua oán khí cho con; trong quá trình nhìn con trưởng thành, hắn cảm ngộ sâu hơn về sinh tử luân hồi, đạo tâm thoát dần mệt mỏi và bước vào giai đoạn then chốt hướng tới nhân quả tuần hoàn.","anchor":"Chỉ có điều, trong khi quên hết mọi việc, một cỗ cảm ngộ về sinh tử luân hồi sinh ra"},{"chuong":"@c0646","importance":"major","tieuDe":"Cấm con tu đạo","text":"Sau khi Tôn Thái qua đời, Vương Lâm giữ tro cốt của lão trong túi trữ vật; hắn dạy Vương Bình điêu khắc bằng tâm ý, biết rõ Tôn Thái từng âm thầm truyền khẩu quyết cho con mình, nhưng vẫn dứt khoát cấm Vương Bình bước vào con đường tu đạo và sau mười chín năm sống ở Lạc Nguyệt thôn thì thu dọn nhà cửa dẫn con rời đi.","anchor":"Cuộc sống tu đạo, không thích hợp với con! Việc này, không nên nói nữa!"},{"chuong":"@c0647","importance":"normal","tieuDe":"Tám năm rèn tâm","text":"Vương Lâm không truyền đạo thuật cho Vương Bình mà dẫn con đi qua danh sơn, sông ngòi và biển rộng trên Nhiễm Vân tinh để dùng thiên địa rèn tâm linh; khi trở về gần Lạc Nguyệt thôn, hắn nhận ra oán khí trong linh hồn con chỉ còn chút cuối nhưng pháp thuật và đan dược đều không thể khu trừ, chỉ có thể chờ luân hồi hủy diệt; tại Kỳ Liên phong, sau khi Vương Bình thấy tu sĩ cưỡi phi kiếm và xin được tu đạo, hắn bi thương nhưng vẫn lắc đầu khước từ.","anchor":"Vương Lâm không truyền thụ đạo thuật cho Vương Bình nhưng với phương thức của hắn"},{"text":"Trên xe ngựa tới Kỳ Thủy thành, Vương Bình lần thứ hai xin tu đạo nhưng Vương Lâm vẫn từ chối, giữ kín căn nguyên thật sự liên quan đến bản thân Vương Bình và cái chết của Liễu Mi; sau đó tại Tĩnh Nhã Hiên, hắn chỉ bằng một ánh mắt làm lão nhân Kết Đan nứt kim đan vì dám ra tay phế hai tay con trai, rồi công khai tuyên bố không ai được giáo huấn Vương Bình thay mình.","anchor":"Không ai biết, nguyên nhân chân chính hắn không cho Vương Bình tu đạo, Tôn Thái không biết, Vương Bình cũng không biết.","bridge":true,"khoang":"@c0648"},{"text":"Tại tửu lâu Kỳ Thủy thành, Vương Lâm áp chế lão nhân Kết Đan và thanh niên tử y, rồi dùng một bước khiến ba lão nhân Tôn gia chấn động tâm thần; sau đó hắn chỉ tha Tôn gia đúng một lần vì từng có uyên nguyên và lời hứa che chở một trăm năm.","anchor":"Từng có một chút uyên nguyên, phụ thân đã từng đáp ứng","bridge":true,"khoang":"@c0649"},{"chuong":"@c0650","importance":"major","tieuDe":"Trao ba mươi năm","text":"Tại Vương Phủ ở Kỳ Thủy thành, Vương Lâm nói với Vương Bình rằng sau những năm bình thường và mạo hiểm, hắn sẽ cho con ba mươi năm phú quý; khi Vương Bình muốn tự mình trở thành chí tôn phàm nhân, Vương Lâm chấp thuận và trao hư ảnh bảo hộ cho con, đồng thời âm thầm đau xót vì con không thể tu đạo.","anchor":"tiếp đó, ta cho con ba mươi năm phú quý"},{"text":"Tại Vương phủ ở Kỳ Thủy Thành, uy thế của Vương Lâm khiến Tôn gia nhận ra người trong phủ là Hứa Mộc và lập tức lui tránh; sau đó ông xuất hiện trong phòng Vân Vô Phong, đánh ngã hắn, chọn Thanh Nghi theo giúp Vương Bình và hứa đưa nàng tới đạo hạnh Nguyên Anh; ba ngày sau Vương Bình rời đi, Vương Lâm giữ lời không dùng thần thức truy tìm, trải qua đêm say đầu tiên sau tám trăm năm và càng thêm già nua sau mười năm.","anchor":"Đây là lần đầu sau tám trăm năm hắn say","bridge":true,"khoang":"@c0651"},{"chuong":"@c0652","importance":"normal","tieuDe":"Lặng nhìn năm tháng","text":"Ở Kỳ Thủy thành, Vương Lâm già nua vẫn sống như một phàm nhân bình thường, thường tới tửu quán uống rượu và nghe chuyện Thiên Hành phái, chiến sự ba nước; về phủ, hắn nghĩ Vương Bình đã bốn mươi bảy tuổi và có lẽ đã nhận ra vài manh mối về bản thân.","anchor":"Bình nhi đã được bốn mươi bảy tuổi rồi"},{"chuong":"@c0653","importance":"normal","tieuDe":"Kể rõ nguồn gốc Vương Bình","text":"Vương Lâm chờ Vương Bình ba mươi lăm năm, chuẩn bị bữa cơm bình dị để đón con trở về rồi kể lại quá khứ từ Chu Tước Tinh, Liễu Mi tới việc mang đứa nhỏ tới Nhiễm Vân Tinh. Sau khi Vương Bình rời đi không nói lời nào, hắn tiếp tục sống bình lặng thêm mười năm và trong vô tâm hiểu sâu hơn về sinh tử, cân bằng và nhân quả.","anchor":"Ta kể cho các con nghe một chuyện xưa"},{"text":"Vương Lâm ở một mình trong căn phòng lớn của Vương phủ, lặng lẽ nhìn trẻ nhỏ chung quanh tới chơi; hắn cho rằng những điều cần làm và cần nói với Vương Bình đều đã làm, phần còn lại phải do Vương Bình tự nghĩ thông.","anchor":"Dần dần, căn phòng lớn của Vương phủ này, liền trở thành chỗ chơi đùa cho hài đồng","bridge":true,"khoang":"@c0654"},{"chuong":"@c0655","importance":"normal","tieuDe":"Cảm ứng nguy cơ","text":"Trong Vương gia đại viện ở Kỳ Thủy thành, Vương Lâm vốn đang uống rượu lặng lẽ như một lão nhân; khi Vương Bình bị Lôi Đạo Tử nhìn ra bất thường và rơi vào nguy hiểm, hắn lập tức ngẩng đầu, làm bầu rượu tan biến và ánh mắt bùng hàn quang sau nhiều năm bình lặng.","anchor":"Vương Lâm nguyên vốn bình tĩnh ngồi trên ghế cầm bầu rượu uống xong một ngụm, cũng mạnh mẽ ngẩng đầu"},{"chuong":"@c0656","importance":"normal","tieuDe":"Cứu con phô tu vi","text":"Vương Lâm hiện thân bằng thần thông Định, cứu Vương Bình khỏi lôi quang của Lôi Đạo Tử; đưa Vương Bình và Thanh Nghi rời thôn sang bình nguyên phía tây Nhiễm Vân tinh; tuyên bố bất kể thân phận Lôi Đạo Tử ra sao cũng phải chết vì đã suýt giết con trai; sau đó nuốt lôi quang, tạo lôi cầu áp đảo pháp bảo thu lôi và phô bày tiên lực cùng ý cảnh tăng tới Vấn Đỉnh hậu kỳ.","anchor":"Thanh âm kia chỉ mang theo có một chữ: \"Định!\""},{"text":"Trong trận đối đầu Lôi Đạo Tử, Vương Lâm phóng ý cảnh luân hồi tới mức Vấn Đỉnh hậu kỳ đỉnh, gọi Xạ Thần Xa hóa thành Ngân Giác lôi thú, dùng tiên bút vẽ bảy phù văn lôi phá Lôi tiên kiếp và khiến đối phương lần đầu thua về lôi điện thần thông; cuối chương, khi Lôi Đạo Tử nhắc Vương Bình là người chết, hắn bùng sát ý, rút đại kiếm chuẩn bị đối đầu nguyên lực thần thông của Âm Hư tu sĩ.","anchor":"Im mồm!~ Vương Lâm ngẩng đầu, trong mắt một rực một màu đỏ, kiếm trong tay chậm rãi nâng lên, lạnh lùng nói.","bridge":true,"khoang":"@c0657"},{"text":"Vương Lâm đỏ mắt truy kích khi Lôi Đạo Tử bỏ chạy, dùng đại kiếm thi triển Trảm La quyết bằng nguyên thần phối hợp nguyên lực; trong lôi đỉnh, hắn chịu đạo niệm thần lôi liên tục oanh kích, đồng thời một kiếm chém vào quy tắc thiên địa khiến cấu trúc đại đỉnh sụp đổ.","anchor":"nguyên thần kết hợp với nguyên lực, lập tức phân ra một phần dung nhập vào trong kiếm","bridge":true,"khoang":"@c0658"},{"chuong":"@c0659","importance":"normal","tieuDe":"Khép đời luân hồi","text":"Trong trận với Lôi Đạo Tử, Vương Lâm mở đạo phong ấn thứ ba cho lôi thú, hợp cùng Tiên vệ và Trảm La phá đại đỉnh, khiến đối phương trọng thương bỏ chạy; sau đó hắn chứng kiến Vương Bình nhận ra chân tướng, xóa sạch tia oán khí cuối cùng của con, đưa dải sáng hồn tức vào Thiên Nghịch bên cạnh Lý Mộ Uyển và rời đi cùng linh hồn Thanh Nghi, khép lại một đời luân hồi bảy mươi năm.","anchor":"Vương Lâm nắm chặt dải sáng, đặt tại mi tâm, dung nhập trong thiên nghịch, đặt ở bên cạnh nguyên anh Lý Mộ Uyển"},{"chuong":"@c0660","importance":"major","tieuDe":"Đột phá sau luân hồi","text":"Sau một đời luân hồi gắn với Vương Bình và chính bản thân mình, Vương Lâm đạt Vấn Đỉnh trung kỳ, ý cảnh đạt Vấn Đỉnh hậu kỳ; sau đó truy sát Lôi Đạo Tử, hạ cấm chế vào nguyên thần đối phương và lộ mục đích luyện hắn thành tiên vệ thứ hai.","anchor":"Tu vi đột phá Vấn Đỉnh sơ kỳ, đạt tới Vấn Đỉnh trung kỳ, ý cảnh theo một đời luân hồi bình thản và cảm ngộ, đạt tới Vấn Đỉnh hậu kỳ."},{"text":"Vương Lâm dùng tiên vệ khôi lỗi, lôi thú, ba chung cực chủ hồn, Thất Tinh kiếm trận và cấm chế điện quang khóa nguyên thần Lôi Đạo Tử; sau đó tế luyện thân thể đối phương, dùng Hoàng Tuyền lực luyện khoáng thạch thành dịch cầu màu vàng để đẩy thân thể khôi lỗi lên ngân cấp; cuối cùng ép Lôi Đạo Tử lựa chọn làm khôi lỗi ba ngàn năm đổi lấy tự do.","anchor":"Thật là một cơ hội tốt cho Vương Lâm luyện chế một tiên vệ khôi lỗi","bridge":true,"khoang":"@c0661"},{"chuong":"@c0662","importance":"normal","tieuDe":"Thu Lôi Nguyên Thuật","text":"Tại động phủ trên tinh cầu bỏ hoang, Vương Lâm tế luyện tiên vệ thứ hai từ Lôi Đạo Tử và đầu lôi thú nhưng thất bại ở bước cuối, chỉ giữ được thân thể ngân cực đỉnh phong; sau đó hắn ổn định đạo tâm, quyết định ưu tiên đề cao tu vi, mở túi trữ vật vô chủ của Lôi Đạo Tử, phá lôi uy trong ngọc giản và phát hiện Đỉnh Hóa Thiên Địa cùng Lôi Nguyên Thuật; thuật thiếu này trở thành cơ duyên then chốt vì phù hợp nguyên thần lôi của hắn, đồng thời giúp thân phận giả sứ giả Lôi Tiên Điện càng khó bị phân biệt.","anchor":"trong ngọc giản này, chỉ ghi chép hai đạo thần thông"},{"chuong":"@c0663","importance":"normal","tieuDe":"Bản tôn lộ diện","text":"Phân thân kiểm kê túi trữ vật của Lôi Đạo Tử, nhận ra nội tình Lôi Tiên Điện cực mạnh rồi bố trí tiên ngọc, Tôn Hồn Phiên, ba chủ hồn và tiên vệ khôi lỗi để bế quan thôn phệ tiên khí; cùng chương, bản tôn xuất hiện từ tinh cầu sụp đổ với tóc đỏ và bốn tinh điểm, thử Trừu Hồn chưa thành thục rồi tiếp tục tìm nơi có lôi quang tu luyện.","anchor":"Hắn, đúng là bản tôn của Vương Lâm"},{"importance":"major","chuong":"@c0664","tieuDe":"Đột phá Vấn Đỉnh hậu kỳ","text":"Sau gần một năm hấp thu lượng tiên ngọc khổng lồ, Vương Lâm đột phá từ Vấn Đỉnh trung kỳ lên Vấn Đỉnh hậu kỳ; sau đó cưỡi lôi thú tới Thiên Huyễn Tinh, suy ngẫm về ba bước tu đạo và câu hỏi bước thứ tư, ép Huyễn Gia giao Thăng Tiên quả rồi nảy ý mượn danh Lôi Tiên Điện cướp đoạt thêm ở La Thiên Bắc Vực.","anchor":"Trải qua một năm hấp thu tiên lực, Vương Lâm rốt cuộc cũng đạt tới đỉnh cao này"},{"text":"Sau khi lấy Thăng Tiên quả của Huyễn gia, Vương Lâm cưỡi Lôi Thú tới Thiên gia, xuất trình Lôi Tiên lệnh bài đoạt từ Lôi Đạo Tử để củng cố thân phận Sứ giả Lôi Tiên Điện, nhận một nửa Thăng Tiên quả rồi tiếp tục quét La Thiên bắc vực tìm thêm linh quả.","anchor":"Lấy được Thăng Tiên quả của Huyễn gia, Vương Lâm ngồi trên lưng Lôi Thú, thẳng hướng Thiên gia mà đi.","bridge":true,"khoang":"@c0665"},{"text":"Vương Lâm tiếp tục thu gom Thăng Tiên quả, tới Vân Hà Tinh để hoàn thiện thuộc tính kim loại của Thiên Nghịch Châu; tại đây hắn mất Thất Tinh kiếm trận, dùng hồng vụ Thăng Tiên quả gây tê xúc tu, cấy lạc ấn vào phần lớn gốc xúc tu, cứu Lôi Thú rồi quyết định xuống lòng đất thăm dò trước khi hấp thu xương Vọng Nguyệt.","anchor":"Điểm hưng phấn của Vọng Nguyệt này, chính là gốc xúc tu của nó","bridge":true,"khoang":"@c0666"},{"text":"Vương Lâm men theo xương Vọng Nguyệt, phát hiện khe lớn và pháp bảo sơn thạch của Tham Lang, dùng kiếm khí của Lăng Thiên Hậu cắt lấy rồi bị một con Vọng Nguyệt nhỏ phục kích; sau khi thoát thân, hắn suy đoán Tham Lang có thể đã động tới Nguyệt Hoa và chuyển hướng tới nơi bài tiết hấp thu.","anchor":"Một sơn thạch rất lớn mắc kẹt ở chỗ sâu trong cái khe này!","bridge":true,"khoang":"@c0667"},{"chuong":"@c0668","importance":"normal","tieuDe":"Thi triển rút cốt","text":"Vương Lâm tới gần nơi bài tiết, nhận ra Tham Lang bị nhốt nhưng quyết định không cứu; sau đó quay lại chỗ xương bị sơn thạch kẹt, kích hoạt đồng loạt lạc ấn Thăng Tiên quả trong xúc tu và thi triển Đạo hóa Hoàng Tuyền đệ tam thức để rút xương Vọng Nguyệt.","anchor":"Đạo hóa Hoàng Tuyền đệ tam thức, Hoàng Tuyền lực!"},{"text":"Vương Lâm dùng Hoàng Tuyền lực kích động bộ xương Vọng Nguyệt, liều mạng kéo nửa đoạn xương sống khổng lồ, gọi Tiên Vệ kéo nửa còn lại, rồi khi xúc tu quấn vào xương thì lấy Cấm Phiên ra để tranh thủ đường thoát.","anchor":"Vương Lâm không chút do dự vỗ túi trữ vật, lập tức lấy ra Cấm Phiên","bridge":true,"khoang":"@c0669"},{"text":"Khi Vọng Nguyệt thức tỉnh và Vân Hà Tinh rung chuyển, Vương Lâm dùng Cấm Phiên tự hủy mở đường, hy sinh Thất Tinh Kiếm Trận để đổi một nhịp, rồi dùng tiếng nói Cổ Thần kế thừa từ Đồ Ti khiến thần thông phá nát tạm ngừng, tiếp tục cùng Tiên Vệ khiêng xương cốt bỏ chạy ra ngoài bầu trời.","anchor":"Âm thanh hắn phát ra cũng là tiếng nói của Cổ Thần được truyền thừa từ Đồ Ti.","bridge":true,"khoang":"@c0670"},{"chuong":"@c0671","importance":"normal","tieuDe":"Hi sinh kiếm trận","text":"Trong lúc mang xương cốt Vọng Nguyệt bỏ chạy, Vương Lâm để Cấm Phiên tự hủy mở đường, sau đó cảm ứng Thất Tinh Kiếm Trận trong khe nứt và ra lệnh cho Tử Thử kiếm cùng sáu kiếm thể còn lại tự bạo; khi Vọng Nguyệt phát ra tiếng nói Cổ Thần và thi triển dấu hiệu phá nát cấp Bát Tinh Cổ Thần, hắn dùng tiếng nói Cổ Thần từ truyền thừa Đồ Ti đáp lại để tạm ngăn không gian sụp vỡ rồi tiếp tục trốn.","anchor":"Thất Tinh Kiếm Trận không chỉ có kiếm thể tự bạo mà trong khoảnh khắc này ngay cả những tà hồn ở bên trên cũng hóa thành những lực lượng vô tận"},{"text":"Trước cơn phẫn nộ của Vọng Nguyệt, Vương Lâm ném trả một nửa xương để trì hoãn rồi cùng Tiên Vệ mang nửa còn lại lao ra tinh không bằng Tinh La Bàn; trên đường bị truy sát, hắn uống hết hai giọt tiên tửu để thi triển Định Thân Thuật, tạm khóa đàn Vọng Nguyệt nhỏ và ngăn Tham Lang đổi vị trí với mình.","anchor":"Vương Lâm phóng lên Tinh La Bàn cả người hóa thành ngân quang, hắn mang theo xương cốt của Vọng Nguyệt rất dài phóng thẳng đi như tên bắn","bridge":true,"khoang":"@c0672"},{"chuong":"@c0673","importance":"normal","tieuDe":"Mất thân đoạt bảo","text":"Trong tinh không nơi Vọng Nguyệt thức tỉnh, Vương Lâm đoạt bình phong Sơn Hà Đồ, dùng Định Thân Thuật kéo Cổ Thần Chỉ về phía Tham Lang; sau đó bị Cổ Thần Chỉ phá hủy nhục thân, nguyên thần hóa thái cổ Lôi Long, cuốn túi trữ vật, Tiên Vệ, xương Vọng Nguyệt, thu thêm vương miện của Tham Lang rồi dung hợp Tinh La Bàn bỏ chạy.","anchor":"Trong quá trình bỏ chạy nguyên thần Vương Lâm lại càng dung hợp vào bên trong Tinh La Bàn, nó mang theo Tiên Vệ và một nửa đoạn xương Vọng Nguyệt điên cuồng bỏ chạy."},{"text":"Sau khi dùng Tinh La Bàn thoát khỏi Vọng Nguyệt ở ranh giới La Thiên Nam-Bắc Vực, Vương Lâm phát hiện tinh cầu lôi quang trong tầng đá Nam Vực. Hắn ở Lôi Ngục mười năm để khôi phục nguyên thần, rồi mượn Cổ Thần Quyết và lôi lực tiên thiên ngưng tụ khung xương, bắt đầu tái tạo thân thể mới.","anchor":"Việc quan trọng nhất bây giờ là phải khôi phục lại thân thể!","bridge":true,"khoang":"@c0674"},{"chuong":"@c0675","importance":"major","tieuDe":"Thiên Nghịch ngũ hành viên mãn","text":"Sau một giáp hấp thu lôi quang và sinh cơ trên tinh cầu lôi quang, Vương Lâm tạo ra thân thể mới chứa sức mạnh sấm sét; hắn bố trí Tôn Hồn Phiên và Đệ Tứ Hồn hộ pháp rồi đưa Thiên Nghịch hấp thu Kim Viên Quáng trong xương Vọng Nguyệt; trong thời gian chờ đợi, hắn kiểm tra bảo vật của Tham Lang, cảm ngộ rút Sơn Hồn, tế luyện Sơn Hà Đồ bình phong, nghiên cứu Vương Miện và khiến đóa hồng lam dung nhập vào đó; sau ba tháng, thuộc tính kim của Thiên Nghịch viên mãn, hắn nhỏ máu lạc ấn khiến phù văn cổ xưa hiện ra trong tâm thần.","anchor":"Sau khi trải qua một giáp hấp thu một số lượng lớn lôi quang và sinh cơ, Vương Lâm đã tạo ra một thân thể mới."},{"chuong":"@c0676","importance":"normal","tieuDe":"Đối mặt Thiên Nghịch","text":"Vương Lâm đưa phù văn vào Hạt Châu Thiên Nghịch khiến tử quang mục nát bùng phát, kịp thu hồi Tiên Vệ và chủ hồn khỏi bị hủy hoại; khi cánh cửa tím xuất hiện, hắn chống lại nỗi sợ bản năng bằng đạo niệm bất khuất, tuyên bố nếu Thiên Nghịch phản lại sẽ đập vỡ nó, rồi dùng xương Vọng Nguyệt thử uy lực cánh tay tử quang thay vì trực tiếp bước vào.","anchor":"Ngươi nếu muốn phản lại ta, ta sẽ đập vỡ cái nghịch của ngươi"},{"chuong":"@c0677","importance":"normal","tieuDe":"Vào Lôi Trì tu luyện","text":"Sau khi Thiên Nghịch Châu trở lại tay và mất ngũ hành lực bên ngoài, Vương Lâm kiểm tra những tồn tại bên trong, suy đoán về chủ nhân trước của Thiên Nghịch rồi rời Lôi Quang tinh cầu đã phế bỏ. Hắn triệu Xạ Thần Xa hóa thành Lôi Thú, đi sâu qua tầng đá vụn, phát hiện không gian Lôi Trì khổng lồ và bắt đầu tu luyện Lôi Nguyên Thuật tại đó.","anchor":"Nơi này cũng là địa phương tốt nhất để tu luyện Lôi Nguyên Thuật"},{"chuong":"@c0678","importance":"normal","tieuDe":"Thiên Nghịch kinh biến","text":"Trong Lôi Trì, Vương Lâm vận chuyển Lôi Nguyên Thuật để chuyển hóa Lôi Đình thành một tia nguyên lực pha tạp; khi định luyện hóa, tia nguyên lực lại bị Thiên Nghịch trong nguyên thần hút lấy, khiến hạt châu tự bay khỏi mi tâm, làm Lôi Trì bạo loạn, hút vô số Lôi Long và khiến cấm chế cùng cánh cửa lớn tái hiện.","anchor":"Hạt châu Thiên Nghịch bên trong nguyên thần hiếm thấy trường hợp không đợi Vương Lâm triệu tập, đã tự động từ bên trong nguyên thần biến ảo xuất ra, từ mi tâm của cơ thể Vương Lâm bay ra."},{"chuong":"@c0679","importance":"major","tieuDe":"Thiên Nghịch nhập đạo","text":"Sau khi Thiên Nghịch nhận chủ và dung nhập nguyên thần, Vương Lâm mạo hiểm tiếp cận cánh cửa Thiên Địa trong Lôi Trì, tâm thần bị hút vào không gian Thiên Nghịch. Hắn chứng kiến vật sáng sinh diệt thành tinh cầu, rơi vào trạng thái truy tìm Đạo, rồi sau khi ba tinh cầu ấm áp hóa thành hào quang nhập đầu, bản thân vô thức hóa thành vật sáng và bành trướng thành một tinh cầu có núi sông, biển cả cùng sinh hoạt phàm tục.","anchor":"Vương Lâm, tại nơi xa xôi này đang truy tìm dấu chân của Đạo"},{"chuong":"@c0680","importance":"major","tieuDe":"Thấy bước thứ ba","text":"Trong không gian Thiên Nghịch, Vương Lâm lĩnh hội sinh tử luân hồi và nhân quả qua các hình ảnh Lý Mộ Uyển, Vương Bình, Thanh Nghi; sau đó bị đẩy khỏi cảnh giới cánh cửa, chứng kiến Thiên Nghịch biến hóa âm dương và xác nhận cơ duyên hiểu Đạo cực quý. Tuy tu vi không tăng trực tiếp, tâm cảnh của hắn thăng hoa, thấy được khí tức bước thứ ba; khi mở mắt bên trên Lôi Trì, ánh mắt còn lưu tàn ảnh cảm ngộ khiến tu sĩ Dương Thực tóc đen bị chấn nhiếp dữ dội.","anchor":"Hắn thấy được bước thứ ba."},{"chuong":"@c0681","importance":"normal","tieuDe":"Cơ duyên bước thứ ba","text":"Tỉnh khỏi cảnh mộng tầm đạo do Thiên Nghịch mở khe hở, Vương Lâm nhận ra mình đã nhìn thấy con đường dẫn tới bước thứ ba Tu Đạo; dư uy trong ánh mắt còn khiến Thân Công Hổ và tọa kỵ Lôi Thú bị áp chế gần như tan rã.","anchor":"Cảnh tượng chân thật như trong mơ kia đã mở ra cho hắn một con đường đi tới cánh cửa lớn của bước thứ ba."},{"chuong":"@c0681","importance":"major","tieuDe":"Thu nhận Đạo Hồn","text":"Sau khi Thân Công Hổ quỳ xin nương tựa và dâng Đạo Hồn làm bảo chứng ngàn năm, Vương Lâm hỏi lại ý chí của hắn rồi thu Đạo Hồn vào nguyên thần; từ đó có người đầu tiên dựa vào mình tại La Thiên.","anchor":"Vương Lâm không hề dài dòng, tay phải phất một cái đạo hồn của Thân Công Hổ lập tức rơi vào trong tay, một hơi nuốt vào rồi dung nhập vào bên trong nguyên thần của hắn."},{"chuong":"@c0681","importance":"normal","tieuDe":"Hỏi chuyện Lôi Tiên Giới","text":"Vương Lâm hỏi Thân Công Hổ về thời điểm mở Lôi Tiên Giới, Lôi Đỉnh, giới hạn tu vi và bí pháp Lôi Tiên Điện; hắn cũng nói rõ mình không phải người La Thiên Tinh Vực rồi cho Thân Công Hổ lưu lại Lôi Trì tu luyện nhưng không được quấy rầy.","anchor":"Lão phu cũng không phải là người ở La Thiên Tinh Vực này!"},{"text":"Được Thân Công Hổ cảm kích vì cho ở lại, Vương Lâm đi sâu khoảng trăm bước vào Lôi Trì rồi dùng Lôi Nguyên Thuật hấp thụ lôi đình để khôi phục nguyên lực đã hao tổn sau trận với Lôi Đạo Tử; qua hai năm, hắn tăng mức hấp thụ lên gấp mười hai lần, ghi nhớ cảm ngộ bước thứ ba, nhận ra càng gần trung tâm Lôi Trì thì nguyên lực càng dày, rồi quyết định tiến sâu hơn.","anchor":"Một trận chiến với Lôi Đạo Tử đã khiến nguyên lực của hắn tiêu hao quá nhiều, hiển nhiên đã xuống tới gần ranh giới thấp nhất của tu vi.","bridge":true,"khoang":"@c0682"},{"text":"Vương Lâm dùng lôi thể và lôi uy nguyên thần thử tiến vào Lôi Trì nhưng bị chặn ở vùng rìa; sau đó hắn quên ngoại giới, nhìn ra quy luật vận hành trong lôi đình, từng bước đạp lên lôi quang và tỉnh lại với nhận thức rằng cảm ngộ sấm sét này liên hệ tới bước thứ ba, có giá trị vượt xa tiên thuật hay pháp bảo thông thường đối với đạo của hắn.","anchor":"tất cả chuyện này nhất định có liên hệ tới bước thứ ba","bridge":true,"khoang":"@c0683"},{"text":"Vương Lâm tỉnh lại ở vòng trong Lôi Trì, thử thổ nạp lôi đình dày đặc để tu luyện nhưng thân thể và nguyên thần đều chịu áp lực nặng; khi Chiến Không Liệt tới và thế cục có nguy cơ bại lộ, hắn tuyên bố không ra tay, biến trận giao chiến thành khảo nghiệm dành cho Thân Công Hổ và tiếp tục duy trì vẻ thần bí trước người ngoài.","anchor":"Nếu ngươi thất bại, đạo hồn trả lại ngươi!","bridge":true,"khoang":"@c0684"},{"text":"Trong Lôi Trì, Vương Lâm quan sát Thân Công Hổ giao thủ với Chiến Không Liệt, nhìn ra Dẫn lôi thuật có lôi uy nhưng thiếu lôi hồn và sức mạnh căn nguyên của sấm sét. Hắn thu một đạo lôi quang vào lòng bàn tay, làm nó tiêu tán chỉ còn ánh sáng thoáng qua để gợi ý cho Thân Công Hổ về đường trở về căn nguyên, khiến hai tu sĩ bước thứ hai càng kính sợ.","anchor":"Nguyên lực thần thông này của ngươi, tuy có lôi uy, nhưng không có lôi hồn","bridge":true,"khoang":"@c0685"},{"text":"Vương Lâm quan sát Thân Công Hổ giao thủ Chiến Không Liệt, nhìn ra Dẫn lôi thuật có lôi uy nhưng thiếu lôi hồn; hắn biểu diễn lôi quang quy về căn nguyên, khiến Thân Công Hổ ngộ ra tầng then chốt, Chiến Không Liệt cũng cúi đầu nhận hắn là tiền bối; sau mười năm tu luyện ở Lôi Trì, hắn đạt mức nguyên lực và nguyên thần bão hòa, rời đi để chuẩn bị cho Lôi Tiên Giới, tìm hiểu Thiên Nghịch Châu, chỉnh lý thần thông và chọn Thanh Linh Tinh làm nơi dừng chân.","anchor":"Nguyên lực thần thông này của ngươi, tuy có lôi uy, nhưng không có lôi hồn","bridge":true,"khoang":"@c0686"},{"chuong":"@c0687","importance":"normal","tieuDe":"Chiếm Thanh Linh Tinh","text":"Vương Lâm hiện thân tại Hoành Vân Sơn Phong, xua tan tử khí, ban thêm mười năm thọ nguyên cho Trương Tân Hải, giao Trương gia thu oán khí phàm nhân, dùng Tôn Hồn Phiên lập cấm địa rồi truyền thần niệm tuyên bố Thanh Linh Tinh là tu chân tinh của mình; trong năm năm sau, hắn ở trên đỉnh núi tế luyện nhiều pháp bảo và đặc biệt nhận ra Côn Cực Tiên liên quan đến phương hướng bước thứ ba.","anchor":"Từ hôm nay trở đi, nơi này sẽ là tu chân tinh của ta!"},{"chuong":"@c0688","importance":"normal","tieuDe":"Tế luyện nhân quả","text":"Trên Hoành Vân Phong, Vương Lâm suy diễn đạo nhân quả, quyết định dùng Côn Cực Tiên thay thế sự ngưng hóa sau cùng của nhân quả ý cảnh để chuẩn bị cho Lôi Chi Tiên Giới; sau ba năm tế luyện, hắn dùng pháp bảo này tạo vòng tròn nhân quả, áp chế hình thái đại kiếm của Hứa Lập Quốc và phân định rằng viễn cổ kiếm ý kia có nhân từ mình nên quả phải thuộc về mình.","anchor":"Lấy Côn Cực Tiên để thay thế cho ngưng hóa sau cùng của nhân quả ý cảnh, chắc là có thể thành công!"},{"chuong":"@c0689","importance":"normal","tieuDe":"Thần thông đại chỉnh","text":"Tại Hoành Vân Phong, Vương Lâm cho Hứa Lập Quốc tạm hoạt động ngoài túi trữ vật, thả Văn Thú, Lôi Oa và Xạ Thần Xa, rồi chuyển trọng tâm sang điều chỉnh hệ thống thần thông theo cảm nhận về bước thứ ba; sau khi nhận ra ba chỉ pháp Tịch Diệt, Hóa Ma, Hoàng Tuyền còn bất toàn, hắn hấp thu oán khí vào Hoàng Tuyền, khiến sinh tử luân hồi ý cảnh viên mãn, tiếp đó bày trận tiên ngọc, uống tiên dịch, đạt Vấn Đỉnh viên mãn và dùng tiên bút vẽ được tám nét ký hiệu.","anchor":"Đến khi Vương Lâm ở trên Thanh Linh Tinh được mười chín năm tám tháng, hắn đã đạt tới Vấn Đỉnh viên mãn!"},{"text":"Rời Thanh Linh Tinh sau hai mươi năm, mang theo tài nguyên đã chuẩn bị và quyết định tự đoạt Lôi Đỉnh để vào Lôi Tiên Giới; tại Thánh Đàn Tinh, hắn chặn đội tu sĩ trở về, gọi khôi lỗi Tiên Vệ, dùng Tiên Sơn thi triển Trừu Linh Chi Lai và ngưng tụ lôi điện thực chất hóa uy hiếp lão già Trương gia.","anchor":"Nếu không có Lôi Đỉnh, vậy thì hãy đi đoạt về!","bridge":true,"khoang":"@c0690"},{"chuong":"@c0691","importance":"normal","tieuDe":"Đổi lấy Đệ Tam Nhãn","text":"Đoạt được Lôi Đỉnh từ lão già Âm Hư, rồi dùng Tịch Diệt Chỉ, Hóa Ma Chỉ và Sát Lục Tiên Quyết để đổi lấy Đệ Tam Nhãn; sau đó nhận ra thuật này ẩn chứa phương hướng bước thứ ba, trở về Hoành Vân Phong tu chỉnh hơn nửa tháng và cố ý nuốt hai đạo Tiên Lôi để hấp thụ nguyên lực.","anchor":"Lấy ba pháp thuật có chút vấn đề này đổi lấy một thần thông có ẩn chứa một chút phương hướng của bước thứ ba, đúng là có chút quá đáng…"},{"chuong":"@c0692","importance":"normal","tieuDe":"Lôi Đỉnh tan vỡ","text":"Đối mặt đạo Tiên Lôi thứ ba trên Thanh Linh Tinh, hắn dùng nguyên thần mang Lôi Đỉnh bay lên, hóa hình giống Thái Cổ Lôi Long nuốt một nửa lôi đình; phần còn lại khiến Lôi Đỉnh quá tải, nứt vỡ hoàn toàn và cuồng lôi cuốn hắn phá nát hư không lao tới Lôi Tiên Giới với tốc độ dị thường.","anchor":"vĩnh viễn mất đi một Lôi Đỉnh, vĩnh viễn mất đi một chỉ tiêu tiến vào Lôi Tiên Giới"},{"chuong":"@c0693","importance":"major","tieuDe":"Vào cửa trước hạn","text":"Dưới hình thái sao băng lôi đình, hắn lao tới cửa Lôi Tiên Giới với tốc độ khiến thần thức các tu sĩ không kịp khóa lại, va thẳng vào sấm sét đỏ sậm và biến mất vào bên trong trước khi cửa chính thức mở.","anchor":"đạo sao băng lôi đình này bỗng nhiên va chạm với đám sấm sét đỏ sậm to lớn kia."},{"text":"Bị lưu tinh lôi đình khóa thân thể và nguyên thần rồi nện xuống đại lục Lôi Tiên Giới trọng thương; sau khi tỉnh lại trong thạch thất dưới lòng đất, hắn khu trừ lôi lực, phát hiện bùn đất bị thần thông giam cầm và buộc phải đi theo thông đạo có các cửa ra liên tục biến mất.","anchor":"Cũng không phải là thiên địa nguyên lực tự nhiên sinh ra mà có người thi triển thần thông, không muốn cho ta ra ngoài!","bridge":true,"khoang":"@c0694"}],"tuViMoc":[{"chuong":"@c0656","canhGioi":"Vấn Đỉnh hậu kỳ","text":"Ý cảnh của Vương Lâm tiếp tục tăng sau khi tiên lực dừng ở Vấn Đỉnh trung kỳ, bao trùm Nhiễm Vân tinh và đạt mức Vấn Đỉnh hậu kỳ; đây là mốc ý cảnh, đồng thời thể hiện cảnh giới cao nhất được bộc lộ trong chương.","importance":"major"},{"chuong":"@c0660","canhGioi":"Vấn Đỉnh trung kỳ; ý cảnh Vấn Đỉnh hậu kỳ","text":"Sau một đời luân hồi, tu vi của Vương Lâm từ Vấn Đỉnh sơ kỳ lên Vấn Đỉnh trung kỳ, ý cảnh đạt tới Vấn Đỉnh hậu kỳ; đây là biến hóa cảnh giới và ý cảnh, còn muốn chân chính có tu vi Vấn Đỉnh hậu kỳ vẫn cần đủ tiên ngọc.","importance":"major"},{"chuong":"@c0663","canhGioi":"Cổ Thần bốn tinh điểm chưa hoàn chỉnh","text":"Bản tôn Vương Lâm hiện ra sau khi tinh cầu vỡ, mi tâm có bốn tinh điểm nhưng một điểm còn ảm đạm; đây là mốc thể chất Cổ Thần, không phải tu vi chính của phân thân.","importance":"major"},{"chuong":"@c0680","canhGioi":"Đạo cảnh chạm tới khí tức bước thứ ba","text":"Đây là mốc cảm ngộ thuộc hệ Đạo cảnh, không phải tu vi chính; Vương Lâm chưa bước vào cảnh giới ấy nhưng đã quan sát được khí tức bước thứ ba, khiến tâm cảnh thăng hoa.","importance":"major"},{"chuong":"@c0689","canhGioi":"Vấn Đỉnh viên mãn","text":"Sau mười chín năm tám tháng ở Thanh Linh Tinh, khi sinh tử luân hồi ý cảnh viên mãn và tiên lực được bổ sung bằng tiên ngọc, tiên dịch, Vương Lâm đạt Vấn Đỉnh viên mãn.","importance":"major"}],"nhanMach":[{"ten":"Vương Bình","tag":"ho-hang","quanHe":"con","ghiChu":"Đứa nhỏ của Vương Lâm và Liễu Mi bị luyện hóa thành oán ảnh; Vương Lâm nhận ra quan hệ huyết mạch và quyết tâm cứu hồi."},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"đại thù","ghiChu":"Liễu Mi dùng oán ảnh đứa nhỏ để trả thù, khiến Vương Lâm nổi sát ý hiếm thấy."},{"ten":"Huyễn gia Lão Tổ","tag":"doi-thu","quanHe":"đối địch","ghiChu":"Huyễn gia Lão Tổ cứu Liễu Mi khỏi tay Vương Lâm, khiến Vương Lâm chuyển ân oán sang cả Huyễn gia."},{"ten":"Vương Bình","tag":"cha-me","quanHe":"cha con","ghiChu":"Nhận oán anh là huyết mạch của mình và đặt tên là Vương Bình.","gap":"@c0636"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Người từng kéo Vương Lâm vào Hồn thủy nhưng được Vương Lâm bỏ qua chuyện cũ và giao phó hậu nhân ba nhà.","ghiChu":"Quan hệ chuyển sang giữ đạo nghĩa sau khi Tôn Tích thú nhận chuyện năm xưa."},{"ten":"Thiên Quỳ Tử","tag":"doi-thu","quanHe":"bị chặn đường ngoài tinh không Thiên Huyễn Tinh","ghiChu":"Thiên Quỳ Tử ban đầu muốn đoạt Tiên vệ khôi lỗi, về sau vì sợ Lôi Tiên Điện nên rút lui và bồi thường."},{"ten":"Huyễn Phong Thần","tag":"khac","quanHe":"người trong Huyễn gia phản đối việc kết tử thù với Vương Lâm","ghiChu":"Huyễn Phong Thần công khai cho rằng Huyễn gia nên cân nhắc kết giao thay vì đối đầu Vương Lâm."},{"ten":"Tán Ma","tag":"khac","quanHe":"ma hồn bị khắc lạc ấn, được gọi ra giao dịch chiến đấu","ghiChu":"Vương Lâm dùng lời hứa thả tự do sau trận để đổi lấy việc Tán Ma nhập thể đối chiến."},{"ten":"Liễu Mi","tag":"khac","quanHe":"nhận di vật","ghiChu":"Vương Lâm nhận túi trữ vật Liễu Mi để lại sau khi nàng tiêu tán."},{"ten":"Chu thúc thúc","tag":"khac","quanHe":"người trong thôn nhờ làm đồ","ghiChu":"Đại hán họ Chu tới nhà nhờ Vương Lâm làm đồ đạc cho phòng cưới con trai."},{"ten":"Trương thẩm thẩm","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Thường tới nhà Vương Lâm trong đời sống thôn xóm ở thôn Lạc Nguyệt."},{"ten":"Chu gia nhị nha đầu","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Cô bé trong thôn có liên hệ sinh hoạt với Vương Bình, được nhắc trong cảnh Tôn Thái trêu Vương Bình."},{"ten":"Tu sĩ Nguyên Anh hậu kỳ Tôn gia","tag":"doi-thu","quanHe":"người từng bị uy hiếp","ghiChu":"Lời cảnh cáo tại tửu lâu được người này báo lại cho Tôn gia."},{"ten":"Vân Vô Phong","tag":"doi-thu","quanHe":"Người bị ông đánh ngã sau khi trêu chọc Vương Bình và Thanh Nghi.","ghiChu":"Vân Vô Phong hoảng sợ khi biết người mình đụng tới là Hứa Mộc."},{"ten":"Thanh Nghi","tag":"dong-minh","quanHe":"Được ông chọn đi theo giúp Vương Bình vài năm.","ghiChu":"Vương Lâm nhìn trúng tư chất của Thanh Nghi và hứa đưa nàng tới đạo hạnh Nguyên Anh."},{"ten":"Thanh Nghi","tag":"khac","quanHe":"người xin đi theo Vương Bình bằng linh hồn","ghiChu":"Sau khi Vương Bình tan đi, Thanh Nghi cầu xin Vương Lâm dẫn nàng đi cùng để tiếp tục làm bạn với Vương Bình."},{"ten":"Tôn Thái","tag":"ban-be","quanHe":"cố nhân","ghiChu":"Giữ tro cốt Tôn Thái trong túi trữ vật theo lời hứa sau khi lão qua đời."},{"ten":"Chu gia đại hán","tag":"ban-be","quanHe":"hàng xóm","ghiChu":"Được Chu gia đại hán cùng dân thôn tiễn khi rời Lạc Nguyệt thôn."},{"ten":"Tôn Khải Minh","tag":"khac","quanHe":"Người từng lập công lớn vì việc của Vương Lâm, nay đến Kỳ Thủy thành truy xét người uy hiếp Tôn gia.","ghiChu":"Tôn Khải Minh chưa biết người khiến chi nhánh Tôn gia chấn động là Vương Lâm."},{"ten":"Đại hán họ Chu","tag":"khac","quanHe":"người trong thôn nhờ làm đồ mộc","ghiChu":"Đại hán họ Chu đem chương lộc làm tiền đặt cọc để nhờ Vương Lâm đóng đồ cho phòng cưới của con trai."},{"ten":"Vọng Nguyệt","tag":"doi-thu","quanHe":"bị truy sát rồi thoát khỏi","ghiChu":"Vọng Nguyệt dừng lại ở ranh giới La Thiên Nam-Bắc Vực, giúp Vương Lâm thoát khỏi cuộc truy sát trong tình trạng nguyên thần trọng thương."},{"ten":"Tiên Vệ","tag":"dong-minh","quanHe":"hộ pháp","ghiChu":"Tiên Vệ được điều khiển dò đường qua tầng đá, sau đó ở ngoài tinh cầu lôi quang hộ pháp trong thời gian Vương Lâm chữa thương."},{"ten":"Đồ Ti","tag":"khac","quanHe":"nguồn ký ức Cổ Thần Quyết","ghiChu":"Vương Lâm mượn bí thuật Cổ Thần Quyết từ ký ức Đồ Ti để ngưng tụ lại thân thể."},{"ten":"Uyển Nhi","tag":"the-thiep","quanHe":"người được bảo vệ trong Thiên Nghịch","ghiChu":"Hồn phách của nàng là một trong các nguyên nhân khiến Vương Lâm không chịu khuất phục trước dị biến Thiên Nghịch."},{"ten":"Cô gái áo trắng","tag":"khac","quanHe":"người xuất hiện trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Nàng cảm thấy nơi này quen thuộc và muốn tìm đáp án."},{"ten":"Người nam trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"người tồn tại trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Cùng một nữ nhân ở phía bắc trở thành hai trong ba người không biến mất qua năm tháng."},{"ten":"Người nữ trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"người tồn tại trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Cùng một nam nhân ở phía bắc trở thành hai trong ba người không biến mất qua năm tháng."},{"ten":"Thân Công Hổ","tag":"dong-minh","quanHe":"Người dựa vào ngàn năm","ghiChu":"Thân Công Hổ tự dâng Đạo Hồn để cầu được nương tựa và đổi lấy cơ hội được chỉ điểm khi đột phá."},{"ten":"Chiến Không Liệt","tag":"doi-thu","quanHe":"Bị Chiến Không Liệt nghi ngờ thân phận, thực lực và khả năng liên quan tới Lôi Tiên Điện khi đang ở sâu trong Lôi Trì.","ghiChu":"Lần đầu đối diện gián tiếp trong Lôi Trì."},{"ten":"Trương Tân Hải","tag":"khac","quanHe":"người bản địa nhìn thấy Vương Lâm trên Hoành Vân Phong","ghiChu":"Trương Tân Hải kinh sợ vì thần thức không phát hiện được Vương Lâm dù mắt thường thấy rõ."},{"ten":"Trương Tân Hải","tag":"dong-minh","quanHe":"gia chủ Trương gia nhận lệnh làm việc cho Vương Lâm","ghiChu":"Được Vương Lâm ban thêm mười năm thọ nguyên và giao nhiệm vụ thu oán khí phàm nhân trên Thanh Linh Tinh."},{"ten":"Lão già Trương gia","tag":"doi-thu","quanHe":"đối thủ tranh đoạt Lôi Đỉnh","ghiChu":"Chạm mặt tại Thánh Đàn Tinh khi Vương Lâm yêu cầu giao Lôi Đỉnh."},{"ten":"Lão già tóc bạc trong Lôi Tiên Giới","tag":"khac","quanHe":"người bí ẩn can thiệp địa hình","ghiChu":"Lão xuất hiện sau khi Vương Lâm rơi xuống và dùng thần thông tác động vào mặt đất."}],"tuiDo":{"phapBao":[{"ten":"Oán ảnh","loai":"pháp bảo đặc thù","trangThai":"dang-co","moTa":"Đứa nhỏ bị Liễu Mi luyện hóa thành oán ảnh, được Vương Lâm nhận ra quan hệ huyết mạch và xem là mục tiêu phải cứu hồi.","nguon":"@c0635"}],"danDuoc":[],"congPhap":[{"ten":"Nguyên thần lôi uy chỉ","loai":"thần thông","trangThai":"dang-co","moTa":"Một chỉ do Vương Lâm phân ra nguyên thần lôi uy ngưng tụ ở đầu ngón tay, định dùng để lấy mạng Liễu Mi.","nguon":"@c0635"},{"ten":"Kiếm khí của Lăng Thiên Hầu","loai":"kiếm khí","trangThai":"dang-co","moTa":"Đạo kiếm khí được Vương Lâm phóng vào lốc xoáy để truy kích Huyễn gia Lão Tổ.","nguon":"@c0635"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635","@c0636","@c0637","@c0638","@c0639","@c0640","@c0641","@c0642","@c0643","@c0644","@c0645","@c0646","@c0647","@c0648","@c0649","@c0650","@c0651","@c0652","@c0653","@c0654","@c0655","@c0656","@c0657","@c0658","@c0659","@c0660","@c0661","@c0662","@c0663","@c0664","@c0665","@c0666","@c0667","@c0668","@c0669","@c0670","@c0671","@c0672","@c0673","@c0674","@c0675","@c0676","@c0677","@c0678","@c0679","@c0680","@c0681","@c0682","@c0683","@c0684","@c0685","@c0686","@c0687","@c0688","@c0689","@c0690","@c0691","@c0692","@c0693","@c0694"],"gioiTinh":"nam","theLuc":[{"ten":"Liên Minh Tinh Vực","trangThai":"danh-nghia"}],"tinhCach":[]},{"id":"lieu-mi","name":"Liễu Mi","aliases":["Huyễn Mi"],"gioiTinh":"nữ","canhGioiCaoNhat":"Không rõ @c0653","trangThai":"tu-vong","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0635","importance":"normal","tieuDe":"Luyện con thành oán ảnh","text":"Liễu Mi tiết lộ đã luyện hóa đứa nhỏ trăm năm thành oán ảnh, gieo vào ý thức nó rằng phụ thân vứt bỏ nó để trả thù Vương Lâm; trong trận chiến sau đó, nàng dùng Cổ kính Hạ phẩm Tiên bảo và hắc châm Hồn thứ tư chống đỡ nhưng bị Vương Lâm đánh trọng thương, sau cùng gọi Lệ nhi lay động tâm thần hắn và được Huyễn gia Lão Tổ cứu đi.","anchor":"Ta đem đứa nhỏ này luyện hoá trăm năm, rốt cuộc luyện thành oán ảnh"},{"chuong":"@c0636","importance":"normal","tieuDe":"Được Lão Tổ giữ lại","text":"Được Huyễn gia Lão Tổ cứu khỏi Vương Lâm và kéo chạy khi kiếm khí truy sát; dù lão từng nghĩ giao nàng cho Vương Lâm là lựa chọn tốt nhất, kế hoạch tu vi trên người nàng khiến lão quyết định không từ bỏ.","anchor":"Ánh mắt của Huyễn gia Lão Tổ dừng lại trên người Liễu Mi đang có vẻ mặt mất mát, lập tức cắn răng một cái, từ bỏ suy nghĩ này."},{"chuong":"@c0637","importance":"normal","tieuDe":"Mục tiêu truy sát","text":"Liễu Mi được nhắc là nguyên nhân trực tiếp khiến Vương Lâm quyết giết mọi kẻ ngăn cản; nếu Huyễn gia Lão Tổ bảo vệ nàng, Vương Lâm sẽ đối đầu cả thế lực Huyễn gia.","anchor":"Nếu là Huyễn gia Lão Tổ quyết bảo vệ Liễu Mi thì nhất định sẽ mời người tương trợ."},{"text":"Liễu Mi đứng bên Huyễn Vô Tình trong Nhà Tổ Huyễn gia; khi Vương Lâm yêu cầu giao nàng ra, nàng né tránh ánh mắt, còn Huyễn Vô Tình xác nhận nàng và Vương Lâm đều đến từ Liên Minh Tinh Vực.","anchor":"Ánh mắt của Liễu Mi lộ ra vẻ phức tạp, quay đầu đi, như không muốn đối mặt với Vương Lâm.","bridge":true,"khoang":"@c0638"},{"chuong":"@c0639","importance":"normal","tieuDe":"Tâm điểm bất mãn","text":"Liễu Mi trở thành nguyên nhân khiến nội bộ Huyễn gia bùng phát bất mãn, vì nhiều tộc nhân cho rằng việc bảo hộ một ngoại nhân đã kéo tai họa đến gia tộc; Huyễn Phong Thần còn nêu việc tu vi của nàng do Lão Tổ cưỡng ép nâng lên.","anchor":"Lão Tổ, chỉ vì một ngoại nhân mà dẫn đến hạo kiếp này cho Huyễn gia."},{"text":"Khi Phúc Trạch ngọc giản hóa thành bóng người áp sát Vương Lâm, Liễu Mi nhìn hắn với ánh mắt phức tạp, chạm vào túi trữ vật rồi lập tức buông tay, chưa thực hiện hành động rõ ràng.","anchor":"Liễu Mi ở một bên lúc này ngẩng đầu nhìn Vương Lâm, trong ánh mắt vẫn rất phức tạp","bridge":true,"khoang":"@c0640"},{"chuong":"@c0642","importance":"normal","tieuDe":"Bị ép giao ý cảnh","text":"Liễu Mi bị Huyễn gia xem như điều kiện đổi mạng trước Tán Ma; nàng biết ra ngoài là chết, rồi bị Huyễn Vô Tình ép giao ý cảnh, đồng thời bị lộ rõ rằng mình vốn được thu nhận để ngày sau bị cắn nuốt Vạn Huyễn Thiên Ma đạo.","anchor":"Bởi vì Vạn Huyễn Thiên Ma đạo của Liễu Mi nên Huyễn Vô Tình mới có tâm tư chủ động thu nàng làm đệ tử, để ngày sau cắn nuốt."},{"chuong":"@c0643","importance":"major","tieuDe":"Tiêu tán để lại giải dược","text":"Nàng biết Huyễn Vô Tình có mưu đồ với mình từ khi bị đưa tới La Thiên Tinh Vực; trước lúc bị cắn nuốt ý cảnh, nàng yêu cầu Huyễn Vô Tình giết Vương Lâm, nếu không làm được thì giao túi trữ vật cho hắn; sau khi ý cảnh và nguyên thần bị cắn nuốt, thân thể nàng tan thành mảnh vụn theo gió, để lại đan dược cùng ngọc giản cho đứa nhỏ.","anchor":"Nếu ngươi không giết được Vương Lâm thì hãy đem túi trữ vật này giao cho hắn !"},{"text":"Liễu Mi được nhắc qua số đan dược đã lưu lại, hiện trở thành một phần trong quá trình Vương Lâm điều trị oán khí cho Vương Bình sau khi đứa trẻ vốn là Oán Anh.","anchor":"Vương Bình chính là Oán Anh kia, sau khi ăn vào đan dược do Liễu Mi lưu lại và","bridge":true,"khoang":"@c0644"},{"text":"Liễu Mi được nhắc lại qua dung mạo ngày càng giống nàng của Vương Bình và qua việc từng được Huyễn Gia Lão Tổ coi trọng vì có dấu hiệu thăng hoa ý cảnh, khiến lão đưa nàng về Huyễn gia.","anchor":"Liễu Mi sở dĩ bị Huyễn Gia Lão Tổ nhìn trúng, bởi vì có dấu hiệu thăng hoa về ý cảnh","bridge":true,"khoang":"@c0645"},{"text":"Liễu Mi được Vương Lâm nhắc lại khi kể cho Vương Bình và Thanh Nghi nghe câu chuyện gần chín trăm năm nhân sinh của mình. Nàng là đầu mối trong chân tướng về mẫu thân và nguồn gốc của Vương Bình.","anchor":"Ta kể cho các con nghe một chuyện xưa","bridge":true,"khoang":"@c0653"},{"chuong":"@c0659","importance":"normal","tieuDe":"Hồn phách Vương Bình","text":"Chân tướng năm xưa được làm rõ: thứ Liễu Mi giao cho Vương Lâm không phải một đứa trẻ sống hoàn chỉnh mà chỉ là một tia hồn phách oán anh, về sau được kiếm khí và pháp thuật duy trì thành Vương Bình.","anchor":"Liễu Mi đưa cho Vương Lâm, đó chỉ là một tia hồn phách!"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Bình","tag":"ho-hang","quanHe":"con","ghiChu":"Đứa nhỏ của Liễu Mi và Vương Lâm bị nàng luyện hóa thành oán ảnh để trả thù."},{"ten":"Huyễn gia Lão Tổ","tag":"dong-minh","quanHe":"người cứu viện","ghiChu":"Huyễn gia Lão Tổ mở lốc xoáy cứu Liễu Mi khỏi sát chiêu của Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ truy sát Liễu Mi và sẵn sàng diệt mọi thế lực bảo vệ nàng.","ghiChu":"Mâu thuẫn dẫn tới hướng đi Thiên Huyễn Tinh."},{"ten":"Huyễn Phong Thần","tag":"khac","quanHe":"người trong Huyễn gia phản đối việc mạo hiểm vì nàng","ghiChu":"Huyễn Phong Thần dùng thân phận ngoại nhân và việc tu vi của Liễu Mi được cưỡng ép nâng lên để chất vấn Lão Tổ."},{"ten":"Vương Lâm","tag":"khac","quanHe":"người nhận di vật","ghiChu":"Trước khi tiêu tán, Liễu Mi dặn nếu Huyễn Vô Tình không giết được Vương Lâm thì phải giao túi trữ vật của nàng cho hắn."},{"ten":"Huyễn Vô Tình","tag":"doi-thu","quanHe":"kẻ cắn nuốt ý cảnh","ghiChu":"Huyễn Vô Tình dùng Liễu Mi làm vật dẫn để cưỡng ép sinh ra một tia Vô Tướng Thiên Ma."},{"ten":"Vương Bình","tag":"cha-me","quanHe":"mẫu thân","ghiChu":"Vương Bình khi lớn lên được nhắc là càng giống Liễu Mi về dung mạo."}],"tuiDo":{"phapBao":[{"ten":"Cổ kính","loai":"Hạ phẩm Tiên bảo","trangThai":"dang-co","moTa":"Pháp bảo do Huyễn gia Lão Tổ tặng, được Liễu Mi lấy ra chắn Hoàng tuyền chỉ.","nguon":"@c0635"},{"ten":"Hắc châm","loai":"pháp bảo","trangThai":"dang-co","moTa":"Cây châm đen còn gọi là Hồn thứ tư, được Liễu Mi phóng ra bằng máu để ngăn kiếm trận và chỉ phong.","nguon":"@c0635"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635","@c0636","@c0637","@c0638","@c0639","@c0640","@c0642","@c0643","@c0644","@c0645","@c0646","@c0653","@c0659"],"theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"tinhCach":[]},{"id":"vuong-binh","name":"Vương Bình","aliases":["Lệ nhi","Bình nhi"],"gioiTinh":"nam","theLuc":[{"ten":"Lạc Nguyệt thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Oán anh @c0658","trangThai":"khong-ro","blurb":"Đứa nhỏ của Vương Lâm và Liễu Mi, bị Liễu Mi luyện hóa trăm năm thành oán ảnh. Sự xuất hiện của Vương Bình khiến Vương Lâm chịu đả kích nặng và mở ra mục tiêu cứu hồi đứa nhỏ.","vaiTro":"con của Vương Lâm và Liễu Mi","tinhCach":[{"text":"bị luyện hóa thành oán ảnh, ý thức bị gieo oán niệm","chuong":"@c0635"},{"text":"tiếng kêu thê lương có thể lay động tâm thần Vương Lâm","chuong":"@c0635"}],"tabs":{"diem":[{"text":"Có quan hệ huyết mạch trực tiếp với Vương Lâm, khiến hắn nhận ra ngay khi nhìn vào ánh mắt trong sương đen.","chuong":"@c0635"},{"text":"Bị Liễu Mi luyện hóa trăm năm thành oán ảnh và dùng như pháp bảo đặc thù để trả thù.","chuong":"@c0635"},{"text":"Khi Liễu Mi gọi Lệ nhi, tiếng kêu trong sương đen khiến tâm can Vương Lâm như bị xé nát.","chuong":"@c0635"},{"text":"Xuất hiện trong màn sương đen được Tiên vệ vây quanh, phát ra tiếng non nớt và nhìn Vương Lâm bằng oán khí.","chuong":"@c0636"},{"text":"Cắn hút máu Vương Lâm và truyền oán khí âm hàn vào cơ thể hắn.","chuong":"@c0636"},{"text":"Được Vương Lâm đổi tên từ Lệ Nhi thành Vương Bình, gửi gắm nguyện vọng bình an.","chuong":"@c0636"},{"text":"Thân thể yếu nhược, sắc mặt tái nhợt và kém khỏe hơn những đứa trẻ cùng tuổi.","chuong":"@c0643"},{"text":"Sống cùng Vương Lâm trong căn nhà nhỏ ở Lạc Nguyệt thôn.","chuong":"@c0643"},{"text":"Thể chất yếu bệnh, được mô tả sắc mặt tái nhợt và thân mình nhu nhược.","chuong":"@c0643"},{"text":"Gọi Vương Lâm là cha và sống cùng hắn trong căn nhà nhỏ ở phía Bắc thôn.","chuong":"@c0643"},{"text":"Thể chất yếu bệnh, sắc mặt tái nhợt, thân mình nhu nhược so với trẻ cùng tuổi.","chuong":"@c0643"},{"text":"Sống cùng Vương Lâm trong ngôi nhà nhỏ ở phía Bắc Lạc Nguyệt thôn.","chuong":"@c0643"}],"kinhLich":[{"chuong":"@c0635","importance":"normal","tieuDe":"Thành oán ảnh","text":"Vương Bình xuất hiện trong màn sương đen dưới dạng oán ảnh, bị Liễu Mi luyện hóa trăm năm và gieo ý thức rằng phụ thân đã vứt bỏ mình; khi Liễu Mi gọi Lệ nhi, oán ảnh phát ra tiếng thê lương khiến Vương Lâm đau đớn nhưng không thể ngăn hắn ra tay với Liễu Mi.","anchor":"Ta đem đứa nhỏ này luyện hoá trăm năm, rốt cuộc luyện thành oán ảnh"},{"text":"Trong màn sương đen trên Nhiễm Vân Tinh, oán anh cắn hút máu Vương Lâm nhưng được hắn nhận là huyết mạch ruột thịt; Vương Lâm đổi tên đứa bé từ Lệ Nhi thành Vương Bình, mong con không phải chịu đời bất an như mình.","anchor":"Từ nay về sau tên của ngươi là Vương Bình… Ta hy vọng cả đời này ngươi sẽ bình an, không giống như ta…","bridge":true,"khoang":"@c0636"},{"text":"Trong trạng thái oán anh, Vương Bình vẫn cắn ngón tay Vương Lâm và truyền oán khí vào người cha; Vương Lâm dùng cấm chế phong ấn, đưa con vào Thiên nghịch không gian và để lại lời hứa sau khi xử lý xong việc vặt sẽ bế quan xua oán khí cho con.","anchor":"Đợi vi phụ đen những viêc vặt hoàn toàn xử lý sẽ bế quan xua đi oán khí cho con.","bridge":true,"khoang":"@c0637"},{"chuong":"@c0643","importance":"normal","tieuDe":"Sống tại Lạc Nguyệt thôn","text":"Vương Bình được giới thiệu là đứa bé khoảng năm sáu tuổi, sắc mặt tái nhợt và thân thể yếu nhược; cậu sống cùng Vương Lâm tại Lạc Nguyệt thôn dưới Kỳ Liên Phong, nghe thiếu niên họ Chu kể chuyện sương mù trên núi có thể cường thân kiện thể rồi về nhà gặp cha.","anchor":"Đứa bé trai này khoảng năm sáu tuổi, sắc mặt tái nhợt, thân mình nhu nhược."},{"chuong":"@c0644","importance":"major","tieuDe":"Được ban đời mới","text":"Vương Bình được xác nhận vốn là Oán Anh, nay được Vương Lâm nuôi như con trong thôn Lạc Nguyệt; cậu uống đan dược do Liễu Mi lưu lại và được thần thông Lôi hệ khu trừ oán khí, ký ức cũ bị hủy để bắt đầu một đời sống phàm tục, về sau mười tuổi nhưng vẫn nhỏ yếu và được dân làng yêu mến.","anchor":"Cha con hai người này chính là Vương Lâm và Vương Bình."},{"text":"Từ năm mười tuổi, Vương Bình lo sợ phụ thân cưới mẹ kế nên được Vương Lâm trấn an; hắn uống thuốc, nói muốn ở bên phụ thân đến già, nhớ lại việc từng hỏi về mẫu thân rồi không hỏi nữa vì hiểu nỗi suy sụp của cha; về sau hắn là nghĩa tôn của Tôn Thái và khắc mộ bia cho lão.","anchor":"Cha, có Bình nhi với người, người sẽ không cô độc","bridge":true,"khoang":"@c0645"},{"chuong":"@c0646","importance":"major","tieuDe":"Bị cấm tu đạo","text":"Từ mười sáu đến mười chín tuổi, Vương Bình học điêu khắc bên Vương Lâm, từng được Tôn Thái âm thầm truyền khẩu quyết tu đạo nhưng nói mình chưa từng tu luyện; khi hỏi về tu đạo, hắn bị cha dứt khoát ngăn cấm, sau đó cùng Vương Lâm rời Lạc Nguyệt thôn và khiến Chu Nhược Đồng đau lòng trong buổi tiễn biệt.","anchor":"nương theo chuyện thu Vương Bình làm nghĩ tôn đã âm thầm truyền thụ pháp thuật"},{"chuong":"@c0647","importance":"normal","tieuDe":"Phàm tâm thăng hoa","text":"Vương Bình theo phụ thân trải qua tám năm leo núi, vượt sông và ra biển, dung hợp trong tâm cảnh sự sắc bén của núi, liên miên của sông cùng bao la của biển, trở về đại lục khi vẫn là phàm nhân nhưng tâm linh đã đủ chứa thiên địa; phần oán khí cuối trong linh hồn hắn được Vương Lâm nhận định chỉ còn có thể hủy diệt trong luân hồi; trên Kỳ Liên phong, lần đầu thấy tu sĩ cưỡi phi kiếm khiến hắn chấn động và lại xin tu đạo, nhưng bị phụ thân lắc đầu từ chối nên trầm mặc suốt đường xuống núi.","anchor":"Hắn tuy rằng là một phàm nhân, nhưng tâm linh của hắn cũng có thể cất chứa được thiên địa"},{"chuong":"@c0648","importance":"normal","tieuDe":"Xin tu đạo lần hai","text":"Vương Bình trên xe ngựa lại xin phụ thân cho mình tu đạo nhưng bị từ chối; khi vào Kỳ Thủy thành, hắn vui thích trước cảnh phồn hoa, rồi tại Tĩnh Nhã Hiên bị thanh niên tử y nhục mạ dung mạo và bình tĩnh đáp trả trước khi suýt bị lão nhân Kết Đan phế hai tay.","anchor":"-Phụ thân, con muốn tu đạo… Đây là lần thứ hai, hắn nói muốn tu đạo."},{"chuong":"@c0649","importance":"normal","tieuDe":"Nhận ra uy thế phụ thân","text":"Vương Bình chứng kiến Vương Lâm chỉ bằng ánh mắt và động tác đã áp chế tu sĩ, từ đó nhận ra phụ thân không phải tu sĩ bình thường; hắn trò chuyện thân thiện với Thanh Nghi rồi theo cha tới đại viện mới ở Kỳ Thủy thành.","anchor":"dường như phụ thân mình, cũng không phải là một tu sĩ bình thường"},{"chuong":"@c0650","importance":"major","tieuDe":"Cầu chí tôn phàm nhân","text":"Trong thư phòng Vương Phủ, Vương Bình hỏi phụ thân có phải đang bù đắp việc không cho mình tu đạo hay không; hắn nói nếu không được tu đạo thì muốn tự mình trở thành chí tôn trong phàm nhân, được Vương Lâm trao hư ảnh bảo hộ, rồi âm thầm nghĩ mình muốn tu đạo để giữ lời hứa mãi ở bên phụ thân.","anchor":"Con đây liền muốn thành chí tôn trong phàm nhân"},{"chuong":"@c0651","importance":"normal","tieuDe":"Rời Kỳ Thủy Thành","text":"Sau khi sự việc với Tôn gia và Vân Vô Phong lắng xuống, Vương Bình rời Kỳ Thủy Thành cùng Thanh Nghi để theo đuổi lý tưởng không muốn sống bình thản. Ba năm sau, Bắc bộ Nhiễm Vân tinh xuất hiện Thiên Hành phái trong phàm nhân, thủ lĩnh được đồn như tiên nhân và luôn có một nữ nhân bên cạnh.","anchor":"Vương Bình mang theo lý tưởng của hắn đi khỏi Kỳ Thủy thành"},{"chuong":"@c0652","importance":"major","tieuDe":"Lập Thiên Hành đế quốc","text":"Vương Bình từ thủ lĩnh Thiên Hành phái trở thành quân chủ Thiên Hành đế quốc sau khi Đế Sơn quốc bị thay thế; về sau Đại Tần và Trần Vân xé minh ước, hắn ngự giá thân chinh khiến tu sĩ can dự chiến tranh đều bại lui, nhưng bản thân lại không thấy khoái hoạt, mệt mỏi vì việc đời và nhớ thời thơ ấu ở sơn thôn.","anchor":"Đế Sơn quốc bị mất, thay vào đó là Thiên Hành đế quốc"},{"chuong":"@c0653","importance":"normal","tieuDe":"Biết chân tướng mẫu thân","text":"Vương Bình trở lại thôn Lạc Nguyệt, gặp lại Chu Nhược Đồng và biết con gái nàng tên Hứa Niệm Bình; sau nhiều năm chinh chiến, hắn hoàn thành chí nguyện thống nhất thế tục khi Thiên Hành trở thành quốc gia duy nhất trên Nhiễm Vân Tinh. Về Vương phủ sau ba mươi lăm năm, hắn nghe Vương Lâm kể quá khứ về Liễu Mi và nguồn gốc của mình, đau đớn nhận ra bản thân là oán anh bị mẫu thân luyện hóa, rồi rời cha không nói lời nào và quy ẩn cùng Thanh Nghi.","anchor":"Hóa ra, ta là một oán anh bị mẫu thân luyện hóa"},{"importance":"major","chuong":"@c0654","tieuDe":"Cuối đời tha thứ","text":"Vương Bình đến tuổi già, tiếp tục khắc tượng phụ thân và thừa nhận nếu có kiếp sau chỉ muốn cùng Vương Lâm sống bình thường trong một sơn thôn nhỏ; hắn cũng nói còn một nghi vấn sâu kín về nguyên nhân phụ thân không cho mình tu đạo, cảm nhận sinh mệnh sắp hết, dặn sau khi mình chết hãy đốt các pho tượng, rồi nói bản thân đã sớm tha thứ cho Vương Lâm.","anchor":"nếu có kiếp sau, ta hy vọng có thể ở cùng với phụ thân trong một sơn thôn nhỏ"},{"text":"Khi Lôi Đạo Tử tập trung thần thức vào thôn nhỏ trong núi, Vương Bình không hôn mê như phàm nhân khác; hắn bình tĩnh buông bức tượng điêu khắc, đứng trước Thanh Nghi hỏi thân phận đối phương, rồi khi lôi quang lan tới vẫn tin chắc phụ thân mình nhất định sẽ đến.","anchor":"Vương Bình buông bức tượng điêu khắc trong tay, đứng lên, đi tới trước mặt Thanh Nghi","bridge":true,"khoang":"@c0655"},{"text":"Vương Bình trầm ổn đối diện lôi quang của Lôi Đạo Tử, được Vương Lâm hiện thân dùng Định cứu khỏi nguy cơ; sau đó cùng Thanh Nghi được Vương Lâm dùng ánh sáng dịu dàng bảo hộ và đưa rời khỏi thôn tới bình nguyên phía tây Nhiễm Vân tinh.","anchor":"Hắn vung tay phải lên, một đạo ánh sáng dịu dàng bao vây lấy Vương Bình và Thanh Nghi","bridge":true,"khoang":"@c0656"},{"text":"Khi Vương Lâm nâng tu vi trong trận chiến trên Nhiễm Vân tinh, thân hình Vương Bình xuất hiện dao động từ linh hồn, khiến phán đoán trước đó của hắn về bản thân càng thêm nặng nề; Thanh Nghi nắm tay và trấn an rằng nàng sẽ ở cạnh hắn bất luận ra sao.","anchor":"Không sao cả, bất luận chàng như thế nào, ta điều ở bên cạnh chàng.","bridge":true,"khoang":"@c0657"},{"text":"Vương Bình đứng sau Vương Lâm và bị Lôi Đạo Tử dùng thần thông hai mắt nhìn thấu là oán anh; hai đạo kiếm khí trong thân thể hắn khiến Lôi Đạo Tử sợ hãi đến mức lập tức bỏ chạy.","anchor":"Hai đạo kiếm khí bên trong Vương Bình, làm cho hắn hoàn toàn sợ hãi.","bridge":true,"khoang":"@c0658"},{"chuong":"@c0659","importance":"major","tieuDe":"Tan thành hồn tức","text":"Vương Bình hỏi cha về lời Lôi Đạo Tử, tự xâu chuỗi việc mình không thể tu đạo, không có con nối dòng, không bệnh tật và không mỏi mệt để nhận ra mình đã chết từ sớm; chân tướng lộ rõ rằng hắn chỉ là một tia hồn phách oán anh được hai đạo kiếm khí và pháp thuật của Vương Lâm duy trì, rồi từ biệt cha cùng Thanh Nghi trước khi tan thành dải sáng.","anchor":"Cha, Thanh Nghi, ta đi rồi…"},{"text":"Vương Bình được nhắc trong nhận thức của Vương Lâm rằng một đời luân hồi vừa thuộc về Vương Bình, vừa là luân hồi của chính Vương Lâm, trở thành phần cảm ngộ giúp Vương Lâm tăng tiến tu vi và ý cảnh.","anchor":"Tu vi đột phá Vấn Đỉnh sơ kỳ, đạt tới Vấn Đỉnh trung kỳ, ý cảnh theo một đời luân hồi bình thản và cảm ngộ, đạt tới Vấn Đỉnh hậu kỳ.","bridge":true,"khoang":"@c0660"},{"chuong":"@c0677","importance":"normal","tieuDe":"Vẫn ở Thiên Nghịch","text":"Sau khi Thiên Nghịch Châu trở lại trạng thái bình thường, Vương Lâm kiểm tra và xác nhận Vương Bình vẫn còn ở bên trong hạt châu.","anchor":"Thần thức Vương Lâm lập tức thâm nhập, nguyên anh Lý Mộ Uyển, Vương Bình cùng với hồn phách Thanh Nghi vẫn còn bên trong"}],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Vương Bình xuất hiện như một đứa trẻ phàm tục yếu bệnh tại Lạc Nguyệt thôn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"cha-me","quanHe":"phụ thân","ghiChu":"Vương Lâm nhận ra quan hệ huyết mạch và quyết tâm cứu hồi Vương Bình."},{"ten":"Liễu Mi","tag":"cha-me","quanHe":"mẫu thân","ghiChu":"Liễu Mi luyện hóa Vương Bình thành oán ảnh để trả thù Vương Lâm."},{"ten":"Chu đại ca","tag":"ban-be","quanHe":"người kể chuyện trong nhóm trẻ","ghiChu":"Vương Bình nghe thiếu niên họ Chu kể về Kỳ Liên Phong và chuyện võ lâm."},{"ten":"Chu thúc thúc","tag":"khac","quanHe":"người trong thôn","ghiChu":"Chu thúc thúc khen Vương Bình lễ phép khi gặp cậu."},{"ten":"Trương thẩm thẩm","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Việc Trương thẩm thẩm nhiều lần tới nhà khiến Vương Bình lo lắng chuyện cha mình có thể hợp ý một cô gái trong thôn."},{"ten":"Chu gia nhị nha đầu","tag":"ban-be","quanHe":"bạn nhỏ trong thôn","ghiChu":"Cô bé tới tìm Vương Bình giữa trời tuyết và gọi cậu là Vương ca ca."},{"ten":"Chu Nhược Đồng","tag":"khac","quanHe":"thiếu nữ trong thôn có tình ý với Vương Bình khi hắn rời Lạc Nguyệt thôn","ghiChu":"Nàng hỏi hắn có trở về hay không, rồi khóc bỏ chạy sau khi nghe câu trả lời có lẽ không."},{"ten":"Tôn Thái","tag":"an-nhan","quanHe":"người từng âm thầm truyền khẩu quyết tu đạo","ghiChu":"Tôn Thái truyền pháp môn tu đạo cho Vương Bình trước khi qua đời, nhưng Vương Bình nói mình chưa từng tu luyện."},{"ten":"Người đàn ông trung niên cưỡi phi kiếm màu xanh","tag":"khac","quanHe":"tu sĩ bay ngang khiến Vương Bình lần đầu tận mắt thấy cảnh tượng tu tiên","ghiChu":"Gặp trên Kỳ Liên phong @c0647"},{"ten":"Thanh niên tử y","tag":"doi-thu","quanHe":"bị khiêu khích và nhục mạ tại Tĩnh Nhã Hiên","ghiChu":"Thanh niên tử y ghen tức vì Thanh nhi chú ý tới Vương Bình nên liên tục châm chọc."},{"ten":"Lão nhân cẩm y","tag":"doi-thu","quanHe":"bị lão nhân ra tay định phế hai tay","ghiChu":"Lão nhân lấy cớ giáo huấn thay gia trưởng, phóng đôi đũa vào hai vai Vương Bình."},{"ten":"Thanh nhi sư muội","tag":"khac","quanHe":"người chứng kiến xung đột","ghiChu":"Thanh nhi từng nhìn Vương Bình khi hắn vào tửu quán, khiến thanh niên tử y ghen tức."},{"ten":"Thanh Nghi","tag":"ban-be","quanHe":"quen biết qua biến cố tửu lâu","ghiChu":"Thanh Nghi trò chuyện với Vương Bình và tỏ thiện cảm sau khi xin lỗi phía Vương Lâm."},{"ten":"Thanh Nghi","tag":"dong-hanh","quanHe":"Đồng hành khi rời Kỳ Thủy Thành.","ghiChu":"Thanh Nghi được Vương Lâm sắp xếp đi theo giúp Vương Bình vài năm."},{"ten":"Thanh Nghi","tag":"the-thiep","quanHe":"người bên cạnh lâu năm","ghiChu":"Thanh Nghi chăm sóc Vương Bình trong điện phủ và doanh trướng, cùng hắn nhắc tới Vương Lâm như phụ thân chung."},{"ten":"Hứa Niệm Bình","tag":"khac","quanHe":"con gái cố nhân","ghiChu":"Con gái Chu Nhược Đồng tự nói tên mình, khiến Vương Bình xúc động vì cái tên gợi nhớ đến hắn."},{"ten":"Lôi Đạo Tử","tag":"doi-thu","quanHe":"Bị Lôi Đạo Tử phát hiện không giống phàm nhân và nhắm tới.","ghiChu":"Vương Bình vẫn bình tĩnh đối diện đối phương."},{"ten":"Lý Mộ Uyển","tag":"cha-me","quanHe":"mẫu thân được Vương Lâm nhận định","ghiChu":"Sau khi thu hồn tức Vương Bình vào Thiên Nghịch, Vương Lâm đặt bên cạnh nguyên anh Lý Mộ Uyển và nhận nàng là mẫu thân của Vương Bình."},{"ten":"Thiếu niên họ Chu","tag":"ban-be","quanHe":"người trong thôn kể chuyện Kỳ Liên Phong cho cậu","ghiChu":"Thiếu niên họ Chu kể chuyện sương mù trên núi có thể cường thân kiện thể khiến Vương Bình muốn nhờ cha đưa đi xem."},{"ten":"Đại hán họ Chu","tag":"khac","quanHe":"người lớn trong thôn quen biết nhà cậu","ghiChu":"Đại hán họ Chu tới nhà Vương Lâm đặt cọc chương lộc, Vương Bình chứng kiến việc này."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635","@c0636","@c0637","@c0643","@c0644","@c0645","@c0646","@c0647","@c0648","@c0649","@c0650","@c0651","@c0652","@c0653","@c0654","@c0655","@c0656","@c0657","@c0658","@c0659","@c0660","@c0677"]},{"id":"huyen-gia-lao-to","name":"Huyễn gia Lão Tổ","aliases":["Huyễn gia Lão Tổ","Huyễn Vô Tình"],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Bước thứ hai tu đạo @c0642","trangThai":"tu-vong","blurb":"Lão tổ của Huyễn gia trên Thiên Huyễn Tinh. Lão mở lốc xoáy cứu Liễu Mi khỏi Vương Lâm, nhưng bị kiếm khí Lăng Thiên Hầu truy kích tới Nhà Tổ Huyễn gia.","vaiTro":"lão tổ Huyễn gia","tinhCach":[{"text":"ra tay cứu người trong thời khắc nguy cấp","chuong":"@c0635"},{"text":"có thủ đoạn cách không qua lốc xoáy","chuong":"@c0635"}],"tabs":{"diem":[{"text":"Từ trong lốc xoáy đưa cánh tay khô héo ra va chạm với song chỉ của Vương Lâm.","chuong":"@c0635"},{"text":"Cứu Liễu Mi khỏi sát chiêu của Vương Lâm và kéo nàng vào lốc xoáy.","chuong":"@c0635"},{"text":"Bị kiếm khí Lăng Thiên Hầu truy kích khiến lốc xoáy sụp đổ và truyền ra tiếng kêu đau.","chuong":"@c0635"}],"kinhLich":[{"text":"Huyễn gia Lão Tổ mở lốc xoáy tối đen, đưa cánh tay khô héo ra đối chưởng với Vương Lâm và kéo Liễu Mi đi; khi Vương Lâm phóng kiếm khí Lăng Thiên Hầu vào lốc xoáy, lão bị truy kích tới nơi bế quan tại Nhà Tổ Huyễn gia trên Thiên Huyễn Tinh, lốc xoáy sụp đổ và lão phát ra tiếng kêu đau.","anchor":"Một cánh tay khô héo từ bên trong lốc xoáy lao ra","bridge":true,"khoang":"@c0635"},{"chuong":"@c0636","importance":"normal","tieuDe":"Kiếm khí truy sát","text":"Dùng nguyên thần vượt tinh không cứu Liễu Mi nhưng bị kiếm khí của Lăng Thiên Hầu truy kích về mật thất; lão vận Vạn Huyễn Vô Tướng đạo chống đỡ, bị kim mang xâm nhập thân thể, nhận ra Vương Lâm có uy hiếp diệt Huyễn gia và cuối cùng vẫn giữ Liễu Mi vì kế hoạch tu vi, đồng thời cầu viện Thiên gia và Hứa gia.","anchor":"Điều này làm cho đáy lòng lão càng hoảng sợ, không dám đối kháng, mà chỉ hoảng hốt bỏ chạy."},{"text":"Huyễn gia Lão Tổ được Vương Lâm suy đoán là người nếu quyết bảo vệ Liễu Mi thì nhất định sẽ mời kẻ khác tương trợ, vì Huyễn gia tuy thế lực phức tạp nhưng khó có nhiều tu sĩ bước thứ hai.","anchor":"Nếu là Huyễn gia Lão Tổ quyết bảo vệ Liễu Mi thì nhất định sẽ mời người tương trợ.","bridge":true,"khoang":"@c0637"},{"text":"Huyễn Vô Tình triệu hồi tộc nhân, mở hộ tộc đại trận ở phía Nam Thiên Huyễn Tinh, nhờ Thiên Quỳ Tử chặn Vương Lâm; sau khi Thiên Quỳ Tử rút lui, lão ở Nhà Tổ cùng Liễu Mi đối mặt Vương Lâm và thách hắn phá đại trận.","anchor":"Tiểu bối, ngươi nếu có thể phá được Huyễn gia đại trận của lão phu thì hãy nói câu này !","bridge":true,"khoang":"@c0638"},{"chuong":"@c0639","importance":"normal","tieuDe":"Cố thủ bảo hộ Liễu Mi","text":"Huyễn Vô Tình trấn áp tộc nhân phản đối việc bảo hộ Liễu Mi, đồng thời muốn buộc Vương Lâm tiêu hao kiếm khí trước khi ra tay; khi Vương Lâm thi triển Trảm La Quyết, lão chấn động vì nhận ra khí tức quy tắc trong một kiếm ấy.","anchor":"Chỉ có không ngừng tiêu hao kiếm khí của ngươi thì lão phu mới có thể ra tay giết ngươi được !"},{"chuong":"@c0640","importance":"normal","tieuDe":"Mời Phúc Trạch ngọc giản","text":"Huyễn Vô Tình thừa nhận đã xem thường Vương Lâm nhưng vẫn tin khoảng cách giữa bước thứ nhất và bước thứ hai rất lớn; sau khi đại trận bị phá, hắn mời Phúc Trạch ngọc giản của Huyễn gia và ra lệnh cho bóng người do ngọc giản hóa thành giết Vương Lâm.","anchor":"Huyễn gia Lão Tổ hét lớn một tiếng lập tức từ bên trong Nhà Tổ của Huyễn gia bỗng nhiên dâng lên một đạo lực lượng mênh mông"},{"text":"Khi Tán Ma hiện thân từ Vương Lâm, Huyễn gia Lão Tổ lần đầu sắc mặt tái nhợt, nhận ra đây mới là tuyệt chiêu đáng sợ của đối phương trong trận chiến tại Thiên Huyễn Tinh.","anchor":"Nháy mắt khi Tán Ma xuất hiện, lần đầu tiên sắc mặt của Huyễn gia Lão Tổ tái nhợt không chút huyết sắc.","bridge":true,"khoang":"@c0641"},{"chuong":"@c0642","importance":"normal","tieuDe":"Lộ ý đồ cắn nuốt","text":"Trước áp lực Tán Ma phá phòng ngự, Huyễn Vô Tình cân nhắc giao Liễu Mi nhưng sau đó yêu cầu nàng giao ý cảnh để mình chạm tới Vô Tướng Thiên Ma đạo; chương xác nhận việc thu nàng làm đệ tử vốn nhằm ngày sau cắn nuốt Vạn Huyễn Thiên Ma đạo.","anchor":"Bởi vì Vạn Huyễn Thiên Ma đạo của Liễu Mi nên Huyễn Vô Tình mới có tâm tư chủ động thu nàng làm đệ tử, để ngày sau cắn nuốt."},{"chuong":"@c0643","importance":"major","tieuDe":"Bị Tán Ma nuốt chết","text":"Kế hoạch chờ Liễu Mi đại thành rồi mới dung hợp bị Vương Lâm phá hỏng, nên lão cắn nuốt ý cảnh nàng sớm và thi triển Vô Tướng Thiên Ma đạo chưa hoàn chỉnh; thần thông vừa sinh ra vô số hư ảnh đã bị Tán Ma nuốt, bản thân lão cũng bị ma khí khóa chặt rồi tiêu tán trong bụng Tán Ma.","anchor":"Huyễn gia Lão Tổ đồng dạng cũng bị khoá chặt bên trong, bị Tán Ma nuốt vào trong bụng, tiêu tan !"},{"chuong":"@c0645","importance":"normal","tieuDe":"Coi trọng Liễu Mi","text":"Huyễn Gia Lão Tổ được nhắc là người từng nhìn trúng Liễu Mi vì dấu hiệu thăng hoa ý cảnh, đến mức tạm bỏ việc tìm hạt châu Thiên Nghịch ở Liên Minh Tu Chân để đưa nàng về Huyễn gia.","anchor":"Liễu Mi sở dĩ bị Huyễn Gia Lão Tổ nhìn trúng, bởi vì có dấu hiệu thăng hoa về ý cảnh"}],"tuViMoc":[],"nhanMach":[{"ten":"Liễu Mi","tag":"dong-minh","quanHe":"người được cứu","ghiChu":"Huyễn gia Lão Tổ cứu Liễu Mi khỏi tay Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đối địch","ghiChu":"Vì cứu Liễu Mi, Huyễn gia Lão Tổ bị Vương Lâm uy hiếp diệt Huyễn gia và dùng kiếm khí truy kích."},{"ten":"Thiên gia lão hữu","tag":"dong-minh","quanHe":"đối tượng cầu viện","ghiChu":"Được Huyễn gia Lão Tổ truyền thần thức nhờ hỗ trợ khi quyết giữ Liễu Mi.","gap":"@c0636"},{"ten":"Hứa gia huynh đệ","tag":"dong-minh","quanHe":"đối tượng cầu viện","ghiChu":"Được Huyễn gia Lão Tổ truyền thần thức nhờ hỗ trợ cùng Thiên gia.","gap":"@c0636"},{"ten":"Thiên Quỳ Tử","tag":"dong-minh","quanHe":"bạn cũ được nhờ chặn Vương Lâm","ghiChu":"Quan hệ rạn nứt khi Thiên Quỳ Tử tưởng Vương Lâm thuộc Lôi Tiên Điện và trách Huyễn Vô Tình khiến mình trêu chọc đại họa."},{"ten":"Huyễn Phong Thần","tag":"khac","quanHe":"tộc trưởng công khai trái ý","ghiChu":"Huyễn Phong Thần chất vấn quyết định của Huyễn Vô Tình và tuyên bố sẽ thối lui nếu đại trận bị phá."},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"cắn nuốt ý cảnh","ghiChu":"Lão dùng ý cảnh và nguyên thần của Liễu Mi để sinh ra một tia Vô Tướng Thiên Ma."},{"ten":"Tán Ma","tag":"doi-thu","quanHe":"bị nuốt diệt","ghiChu":"Thần thông và bản thể của Huyễn Vô Tình đều bị Tán Ma nuốt."}],"tuiDo":{"phapBao":[{"ten":"Cổ kính","loai":"Hạ phẩm Tiên bảo","trangThai":"da-trao","moTa":"Pháp bảo Hạ phẩm Tiên bảo từng được Huyễn gia Lão Tổ tặng cho Liễu Mi.","nguon":"@c0635"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635","@c0636","@c0637","@c0638","@c0639","@c0640","@c0641","@c0642","@c0643","@c0645"]},{"id":"dang-hoa-nguyen","name":"Đằng Hoá Nguyên","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ @c0635","trangThai":"khong-ro","blurb":"Nhân vật được nhắc khi đối chiếu mức sát khí của Vương Lâm. Việc tên Đằng Hoá Nguyên được nêu cho thấy sát ý của Vương Lâm với Liễu Mi đã đạt mức hiếm thấy.","vaiTro":"đại thù cũ của Vương Lâm","tinhCach":[{"text":"gắn với sát khí sâu nặng trong ký ức Vương Lâm","chuong":"@c0635"},{"text":"được dùng làm mốc so sánh cho đại thù","chuong":"@c0635"}],"tabs":{"diem":[{"text":"Được nêu trong lúc mô tả sát khí hiếm thấy của Vương Lâm đối với Liễu Mi.","chuong":"@c0635"}],"kinhLich":[{"text":"Đằng Hoá Nguyên được nhắc như người hiếm hoi từng khiến Vương Lâm có sát khí nồng đậm tương tự, qua đó làm nổi bật mức thù hận của Vương Lâm với Liễu Mi sau chuyện oán ảnh.","anchor":"Ngoại trừ Đằng Hoá Nguyên, Vương Lâm chưa bao giờ từng có sát khí nồng đậm như vậy đối với một ai khác","bridge":true,"khoang":"@c0635"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đại thù cũ","ghiChu":"Tên Đằng Hoá Nguyên được dùng để so sánh với sát khí Vương Lâm dành cho Liễu Mi."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635"]},{"id":"lang-thien-hau","name":"Lăng Thiên Hầu","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ @c0635","trangThai":"song @c0673","blurb":"Cường giả được nhắc qua đạo kiếm khí mà Vương Lâm sử dụng. Kiếm khí của Lăng Thiên Hầu có uy lực truy kích xuyên lốc xoáy và làm Huyễn gia Lão Tổ bị chấn động.","vaiTro":"chủ nhân nguồn kiếm khí","tinhCach":[{"text":"kiếm khí để lại có uy lực rất lớn","chuong":"@c0635"},{"text":"tên tuổi gắn với thủ đoạn kiếm khí sắc bén","chuong":"@c0635"}],"tabs":{"diem":[{"text":"Đạo kiếm khí của Lăng Thiên Hầu được Vương Lâm phóng vào lốc xoáy để truy kích Huyễn gia Lão Tổ.","chuong":"@c0635"},{"text":"Kiếm khí khiến lốc xoáy sụp đổ và truyền ra tiếng kêu đau từ phía Huyễn gia Lão Tổ.","chuong":"@c0635"}],"kinhLich":[{"text":"Lăng Thiên Hầu được nhắc qua đạo kiếm khí mà Vương Lâm ngưng tụ và phóng vào lốc xoáy, truy kích Huyễn gia Lão Tổ tới Nhà Tổ Huyễn gia trên Thiên Huyễn Tinh.","anchor":"Nháy mắt khi kiếm khí công kích, lốc xoáy nháy mắt đã sụp đổ","bridge":true,"khoang":"@c0635"},{"text":"Lăng Thiên Hậu không trực tiếp xuất hiện, nhưng kiếm khí của ông trong cơ thể Vương Lâm được phóng ra để ngăn Cổ Thần Chỉ, chỉ khiến ngón tay hơi khựng lại trước khi tiếp tục ấn xuống.","anchor":"Kiếm khí của Lăng Thiên Hậu có một uy lực nhất định, ngón tay Cổ Thần hơi ngừng lại nhưng lại vội vàng ấn xuống không chút do dự.","bridge":true,"khoang":"@c0673"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"nguồn kiếm khí đang được sử dụng","ghiChu":"Vương Lâm dùng kiếm khí của Lăng Thiên Hầu để truy kích Huyễn gia Lão Tổ."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Kiếm khí của Lăng Thiên Hầu","loai":"kiếm khí","trangThai":"khong-ro","moTa":"Đạo kiếm khí được Vương Lâm dùng để đánh vào lốc xoáy cứu viện của Huyễn gia Lão Tổ.","nguon":"@c0635"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0635","@c0673"]},{"id":"tien-ve-ao-den","name":"Tiên vệ","cn":"","aliases":["Tiên vệ khôi lỗi"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Vương Lâm","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Âm Dương hư thật @c0636","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0636","importance":"normal","tieuDe":"Vây màn sương đen","text":"Cảnh giới Âm Dương hư thật của Tiên vệ khiến Huyễn gia Lão Tổ e dè khi còn suy yếu; sau đó Tiên vệ vây quanh màn sương đen chứa oán anh trên Nhiễm Vân Tinh.","anchor":"Điều này làm cho lão không khỏi kinh ngạc."},{"chuong":"@c0640","importance":"normal","tieuDe":"Hộ bên Vương Lâm","text":"Khi bóng người do Phúc Trạch ngọc giản hóa thành bước về phía Vương Lâm, Tiên vệ khôi lỗi xuất hiện bên cạnh hắn cùng Lôi Thú để hộ vệ trước tiên lực đang áp xuống.","anchor":"Bóng người do ngọc giản hoá thành nghe vậy liền bước lên một bước hướng về phía Vương Lâm."},{"chuong":"@c0655","importance":"normal","tieuDe":"Hiện thân hộ chủ","text":"Tiên vệ khôi lỗi ẩn trong bóng Vương Bình hiện thân đúng lúc Lôi Đạo Tử nói Vương Bình không phải người, lập tức tung quyền đánh xuyên lôi quang, khiến Lôi Đạo Tử phải lùi một bước và nhận ra phẩm cấp cực cao của khôi lỗi.","anchor":"Tiên vệ khôi lỗi cơ hồ vừa hiện thân, liền đánh ra một quyền"},{"text":"Tiên vệ khôi lỗi xuất hiện cạnh Vương Lâm, thân phát kim quang lao vào Lôi Đạo Tử; sau đó bị lôi võng vây khốn, rồi thoát ra khi thiết côn thu lôi của Lôi Đạo Tử sụp đổ khiến lôi võng tan rã.","anchor":"Phía trên lôi võng có vô số hoa văn lá bùa chợt lóe","bridge":true,"khoang":"@c0656"},{"text":"Tiên vệ bộc phát kim quang pha hồng quang, dùng quyền đánh nứt đại đỉnh, phối hợp với lôi thú và Trảm La của Vương Lâm làm đại đỉnh sụp đổ, rồi tiếp tục truy kích Lôi Đạo Tử.","anchor":"Trong nháy mắt, đại đỉnh sụp đổ, hóa thành vô số những mảnh vỡ","bridge":true,"khoang":"@c0659"},{"text":"Tiên vệ khôi lỗi theo Vương Lâm rời động phủ, đứng trên không trung cảnh giới và được giao nhiệm vụ diệt sát mọi vật tiếp cận trong lúc hắn bế quan thôn phệ tiên khí.","anchor":"Tiên khí khổng lồ lập tức tràn ngập, hình thành một cỗ lốc xoáy","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[{"ten":"Lôi Đạo Tử","tag":"doi-thu","quanHe":"Giao thủ để bảo vệ Vương Bình khỏi Lôi Đạo Tử.","ghiChu":"Một quyền đánh xuyên lôi quang quanh thân đối phương."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0636","@c0640","@c0655","@c0656","@c0659","@c0663"]},{"id":"ton-tich","name":"Tôn Tích","gioiTinh":"nam","canhGioiCaoNhat":"Anh Biến trung kỳ @c0637","trangThai":"song","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0637","importance":"normal","tieuDe":"Khôi phục Anh Biến","text":"Tôn Tích từ trong thành bay ra, thú nhận ba người từng giấu giếm để kéo Vương Lâm vào Hồn thủy, cung cấp tin tức về Nhiễm gia Lão Tổ và Triệu Truyền Văn; hắn chọn dùng Bát phẩm linh đan để khôi phục thay vì trải lại cửa sinh tử Vấn Đỉnh, được Vương Lâm dùng Đạo hóa Hoàng Tuyền trợ giúp tới Anh Biến trung kỳ, rồi nhận việc dàn xếp hậu nhân ba nhà và chờ Vương Lâm trở lại.","anchor":"Tu vi của ngươi đã khôi phục tới Anh Biến trung kỳ nhưng cũng là cực hạn của ngươi."},{"importance":"normal","chuong":"@c0654","tieuDe":"Rời bế quan quan sát","text":"Tôn Tích đang bế quan nhiều năm nhưng bị lôi uy từ trời cao kinh động, lập tức bay lên không trung quan sát; trước tiên lực và lôi uy của người giáng lâm, lão tổ Tôn gia tỏ ra kinh hãi, phía sau là tám tu sĩ Anh Biến hậu kỳ trong gia tộc.","anchor":"Lão tổ, xem ra người này không có ý tốt"}],"tuViMoc":[{"chuong":"@c0637","canhGioi":"Anh Biến trung kỳ","text":"Sau ba ngày trong Hoàng Tuyền cùng dược lực Bát phẩm đan dược, Tôn Tích khôi phục tới Anh Biến trung kỳ nhưng đây là cực hạn về sau.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người được Tôn Tích thú nhận chuyện cũ, sau đó giúp hắn khôi phục tu vi và giao việc hậu nhân ba nhà.","ghiChu":"Quan hệ chịu ràng buộc bởi đạo nghĩa ba Tiên ngọc và lời hứa bảo vệ hậu nhân."},{"ten":"Triệu Truyền Văn","tag":"khac","quanHe":"Một trong ba người liên quan chuyện Hồn thủy năm xưa.","ghiChu":"Tôn Tích nói Triệu Truyền Văn không luyện ra phân thân nhưng có thần thông tách nguyên thần, có thể đã rời Nhiễm Vân Tinh."},{"ten":"Nhiễm gia Lão Tổ","tag":"khac","quanHe":"Một trong ba người liên quan chuyện Hồn thủy năm xưa.","ghiChu":"Tôn Tích cho biết Nhiễm gia Lão Tổ đã rời Nhiễm Vân Tinh từ mấy trăm năm trước."},{"ten":"Lôi Đạo Tử","tag":"khac","quanHe":"người giáng lâm khiến Tôn gia cảnh giác","ghiChu":"Lôi uy của Lôi Đạo Tử khiến Tôn Tích rời bế quan và quan sát trên không trung.","gap":"@c0654"}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm của Tôn Tích","trangThai":"dang-co","moTa":"Kiếm quang dưới chân không ổn khi hắn sợ hãi đối diện Vương Lâm.","nguon":"@c0637"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Ngọc giản của Tôn Tích","trangThai":"da-giao","moTa":"Ghi vị trí Thiên Huyễn Tinh để Vương Lâm dùng trên đường truy sát Liễu Mi.","nguon":"@c0637"}]}},"nguon":["@c0637","@c0654"]},{"id":"don-thien","name":"Độn Thiên","gioiTinh":"nam","canhGioiCaoNhat":"Không đổi trong chương này","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Độn Thiên được Vương Lâm nhắc tới khi đệ tử hồn của Tôn Hồn Phiên được thu hồi và đưa lại vào phiên, hàm ý uy lực pháp bảo cũ sẽ tái hiện.","anchor":"Độn Thiên sư phụ, đệ tử hồn đã được đệ tử thu hồi.","bridge":true,"khoang":"@c0637"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Được Vương Lâm gọi là sư phụ khi khôi phục đệ tử hồn cho Tôn Hồn Phiên.","ghiChu":"Lời nhắc gắn với việc phục hồi uy lực Tôn Hồn Phiên."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0637"]},{"id":"trieu-truyen-van-lao-to-630","name":"Triệu Truyền Văn","aliases":["Tiêu Dao"],"gioiTinh":"nam","canhGioiCaoNhat":"Không đổi trong chương này","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Triệu Truyền Văn được Tôn Tích nhắc là người không luyện được phân thân nhưng có thần thông tách nguyên thần, vì vậy được đoán đã rời Nhiễm Vân Tinh.","anchor":"trước đó ba người chúng ta dấu diếm chính là vi muốn kéo ngươi tiến vào bên trong Hồn thuỷ","bridge":true,"khoang":"@c0637"}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn Tích","tag":"khac","quanHe":"Cùng liên quan chuyện giấu giếm để kéo Vương Lâm vào Hồn thủy năm xưa.","ghiChu":"Tôn Tích thuật lại tình hình của Triệu Truyền Văn cho Vương Lâm."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Từng cùng Tôn Tích và Nhiễm gia Lão Tổ liên quan việc kéo Vương Lâm vào Hồn thủy.","ghiChu":"Chương này chỉ được nhắc qua lời Tôn Tích."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Thần thông tách nguyên thần của Triệu Truyền Văn","trangThai":"dang-co","moTa":"Năng lực giúp Triệu Truyền Văn có thể tách nguyên thần và rời Nhiễm Vân Tinh.","nguon":"@c0637"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0637"]},{"id":"nhiem-gia-lao-to","name":"Nhiễm gia Lão Tổ","gioiTinh":"khong-ro","theLuc":[{"ten":"Nhiễm gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Nhiễm gia Lão Tổ là một trong ba người từng liên quan chuyện Hồn thủy với Tôn Tích và Triệu Truyền Văn. Đến chương này, Tôn Tích cho biết người này đã rời Nhiễm Vân Tinh từ mấy trăm năm trước.","vaiTro":"Người cũ liên quan Hồn thủy","tinhCach":"Không rõ; hành tung khó nắm; có liên hệ với Nhiễm gia","tabs":{"diem":[{"text":"Là một trong ba người từng giấu giếm chuyện Hồn thủy với Vương Lâm.","chuong":"@c0637"},{"text":"Đã rời Nhiễm Vân Tinh từ mấy trăm năm trước theo lời Tôn Tích.","chuong":"@c0637"}],"kinhLich":[{"text":"Nhiễm gia Lão Tổ được Tôn Tích nhắc là đã rời Nhiễm Vân Tinh từ mấy trăm năm trước, không rõ đi đâu nhưng có lẽ không gặp biến cố nghiêm trọng.","anchor":"trước đó ba người chúng ta dấu diếm chính là vi muốn kéo ngươi tiến vào bên trong Hồn thuỷ","bridge":true,"khoang":"@c0637"}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn Tích","tag":"khac","quanHe":"Cùng liên quan chuyện Hồn thủy năm xưa.","ghiChu":"Tôn Tích thuật lại hành tung của Nhiễm gia Lão Tổ cho Vương Lâm."},{"ten":"Triệu Truyền Văn","tag":"khac","quanHe":"Cùng nhóm ba người liên quan chuyện Hồn thủy.","ghiChu":"Cả hai đều được Vương Lâm hỏi tung tích qua Tôn Tích."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Từng liên quan việc kéo Vương Lâm vào Hồn thủy làm người thế tội.","ghiChu":"Vương Lâm bỏ qua chuyện cũ vì đạo nghĩa ba Tiên ngọc."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0637"]},{"id":"hong-diep","name":"Hồng Điệp","gioiTinh":"nu","canhGioiCaoNhat":"Không đổi trong chương này","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Hồng Điệp được nhắc trong ví dụ cũ ở Chu Tước Tinh, khi Chu Tước quốc nhìn trúng nàng và Tuyết Vực quốc muốn thăng cấp nên tông chủ dùng cách cưỡng ép nâng Hóa Thần lên Anh Biến.","anchor":"Hứa huynh, Tôn mỗ lựa chọn cách phía sau.","bridge":true,"khoang":"@c0637"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0637"]},{"id":"tong-chu-tuyet-vuc-quoc","name":"Tông chủ Tuyết Vực quốc","gioiTinh":"khong-ro","theLuc":[{"ten":"Tuyết Vực quốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Tông chủ Tuyết Vực quốc được nhắc như tiền lệ về việc cưỡng ép nâng tu vi từ Hóa Thần lên Anh Biến. Cách này giúp đạt mục tiêu trước mắt nhưng khiến người dùng khó tiến thêm.","vaiTro":"Tông chủ Tuyết Vực quốc","tinhCach":"Quyết đoán; chấp nhận hy sinh tiềm lực; vì lợi ích tu chân quốc","tabs":{"diem":[{"text":"Từng dùng phương pháp cưỡng ép nâng tu vi để phục vụ việc Tuyết Vực quốc thăng cấp.","chuong":"@c0637"},{"text":"Là ví dụ khiến Tôn Tích hiểu hậu quả của cách khôi phục bằng linh đan.","chuong":"@c0637"}],"kinhLich":[{"text":"Tông chủ Tuyết Vực quốc được nhắc trong lời Vương Lâm về phương pháp cưỡng ép nâng Hóa Thần lên Anh Biến, một con đường có thể đạt kết quả nhanh nhưng khiến người dùng dừng bước cả đời.","anchor":"Hứa huynh, Tôn mỗ lựa chọn cách phía sau.","bridge":true,"khoang":"@c0637"}],"tuViMoc":[],"nhanMach":[{"ten":"Hồng Điệp","tag":"khac","quanHe":"Cùng xuất hiện trong bối cảnh Tuyết Vực quốc muốn thăng cấp vì Hồng Điệp được Chu Tước quốc nhìn trúng.","ghiChu":"Chỉ được nhắc trong ví dụ cũ."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0637"]},{"id":"thien-quy-tu","name":"Thiên Quỳ Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"cao hơn Vương Lâm, chưa nêu rõ cảnh giới @c0665","trangThai":"song","blurb":"Thiên Quỳ Tử là một trong ba lão tổ Thiên gia trên Thiên Huyễn Tinh. Lão ra mặt chặn Vương Lâm vì giao dịch với Huyễn gia, nhưng lập tức rút lui khi lầm tưởng Vương Lâm thuộc Lôi Tiên Điện.","vaiTro":"Lão tổ Thiên gia chặn đường Vương Lâm","tinhCach":[{"text":"thận trọng trước thế lực lớn","chuong":"@c0638"},{"text":"tham lợi khi thấy khôi lỗi Âm Hư","chuong":"@c0638"},{"text":"quyết đoán rút lui khi nhận ra nguy cơ","chuong":"@c0638"}],"tabs":{"diem":[{"text":"Là một trong ba lão tổ Thiên gia và có tu vi Âm Hư.","chuong":"@c0638"},{"text":"Ra tay giúp Huyễn gia bằng tư cách cá nhân để đổi lấy bảo vật.","chuong":"@c0638"},{"text":"Vì thấy Lôi Thú nên nhận định Vương Lâm là người Lôi Tiên Điện, từ đó cắt quan hệ với Huyễn gia.","chuong":"@c0638"}],"kinhLich":[{"text":"Thiên Quỳ Tử chặn Vương Lâm ngoài tinh không Thiên Huyễn Tinh, ban đầu muốn đoạt Tiên vệ khôi lỗi; sau khi Xạ Thần xa hóa Lôi Thú, lão tin Vương Lâm là người Lôi Tiên Điện, lập tức xin lỗi, bồi thường Tiên ngọc, tuyên bố Thiên gia không tham dự và quay lại trách Huyễn Vô Tình.","anchor":"Thiên gia ta tuyệt không tham dự vào việc này, chặt đứt tất cả quan hệ đối với Huyễn gia !","bridge":true,"khoang":"@c0638"},{"text":"Thiên Quỳ Tử dùng thần thức quan sát trận chiến tại Huyễn gia, nhận ra một kiếm của Vương Lâm có quy tắc và nghi ngờ hắn liên quan Lôi Tiên Điện; sau đó tiếp tục chú ý Phúc Trạch ngọc giản và di bảo tổ tiên Huyễn gia.","anchor":"Quy tắc ! Một kiếm này ẩn chứa quy tắc !","bridge":true,"khoang":"@c0640"},{"text":"Thiên Quỳ Tử run sợ trước ma uy của Tán Ma, đồng thời dựa vào các thủ đoạn như Lôi Thú, khôi lỗi, quy tắc kiếm thức và Ma để suy đoán Vương Lâm có địa vị trọng yếu trong Lôi Tiên Điện.","anchor":"Nháy mắt khi Tán Ma xuất hiện, lần đầu tiên sắc mặt của Huyễn gia Lão Tổ tái nhợt không chút huyết sắc.","bridge":true,"khoang":"@c0641"},{"text":"Thiên Quỳ Tử đại diện Thiên gia nghênh đón Vương Lâm, kiểm tra Lôi Tiên lệnh bài, giao một nửa Thăng Tiên quả và chỉ hứa Thiên gia sẽ phụ thuộc khi Vương Lâm đạt Âm Dương Hư Thực.","anchor":"Khi tu vi của ngài đạt tới Âm Dương Hư Thực chi cảnh, Thiên gia trở thành gia tộc tu chân phụ thuộc của ngài.","bridge":true,"khoang":"@c0665"}],"tuViMoc":[{"chuong":"@c0638","canhGioi":"Âm Hư trong Âm Dương hư thật cảnh giới","text":"Vương Lâm nhờ dung hợp cảm nhận với Tiên vệ khôi lỗi mà nhận ra Thiên Quỳ Tử đã đạt Âm Hư.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"chặn đường rồi rút lui","ghiChu":"Ban đầu muốn đoạt Tiên vệ khôi lỗi của Vương Lâm, sau vì sợ Lôi Tiên Điện nên bồi thường và rời khỏi."},{"ten":"Huyễn Vô Tình","tag":"dong-minh","quanHe":"giúp theo giao dịch rồi trở mặt","ghiChu":"Ra tay giúp Huyễn gia bằng tư cách cá nhân, nhưng sau khi sợ đắc tội Lôi Tiên Điện thì cắt quan hệ và oán trách Huyễn Vô Tình."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Phù văn lôi pháp của Thiên Quỳ Tử","trangThai":"dang-co","moTa":"Tạo lượng lớn phù văn, hóa thành lôi quang và Thiên lôi công kích Tiên vệ khôi lỗi.","nguon":"@c0638"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Túi trữ vật chứa Tiên ngọc","trangThai":"da-dung","moTa":"Đưa cho Vương Lâm để bồi thường sau khi nhận định đối phương là người Lôi Tiên Điện.","nguon":"@c0638"}]}},"nguon":["@c0638","@c0640","@c0641","@c0665"]},{"id":"huyen-phong-than","name":"Huyễn Phong Thần","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ trong chương này","trangThai":"song","blurb":"Huyễn Phong Thần là Tộc trưởng Huyễn gia trên Thiên Huyễn Tinh. Trong lúc Huyễn gia đại trận bị Vương Lâm công kích, hắn công khai chất vấn Lão Tổ và chọn phương án bảo toàn gia tộc.","vaiTro":"Tộc trưởng Huyễn gia","tinhCach":[{"text":"Thực tế, đặt an nguy gia tộc lên trên ý chí của Lão Tổ","chuong":"@c0639"},{"text":"Dám công khai phản đối quyết định gây nguy hiểm cho Huyễn gia","chuong":"@c0639"}],"tabs":{"diem":[{"text":"Là Tộc trưởng Huyễn gia và đứng ra chất vấn lựa chọn của Lão Tổ giữa lúc đại trận bị công kích.","chuong":"@c0639"},{"text":"Nhận định người có Lôi Thú và khôi lỗi chiến lực cao như Vương Lâm nên được cân nhắc kết giao thay vì kết tử thù.","chuong":"@c0639"},{"text":"Tuyên bố sẽ thối lui nếu trận pháp bị phá, thể hiện sự phân liệt trong tầng lãnh đạo Huyễn gia.","chuong":"@c0639"}],"kinhLich":[{"chuong":"@c0639","importance":"normal","tieuDe":"Công khai trái ý Lão Tổ","text":"Huyễn Phong Thần xuất hiện với thân phận Tộc trưởng Huyễn gia, chất vấn việc vì Liễu Mi mà kết tử thù với Vương Lâm; hắn cho rằng người sở hữu Lôi Thú và khôi lỗi mạnh như Vương Lâm đáng được cân nhắc kết giao, rồi tuyên bố nếu đại trận bị phá sẽ lập tức thối lui để đề phòng vạn nhất.","anchor":"Một người như thế thì xin hỏi Lão Tổ, Huyễn gia chúng ta có nên kết giao hay là nên kết tử cừu !?"},{"text":"Huyễn Phong Thần bị kiếm thức của Vương Lâm làm chấn động, rồi dùng thân phận Tộc trưởng tuyên bố Huyễn gia không tham dự ân oán giữa Vương Lâm và Huyễn Vô Tình; các trực hệ Huyễn gia lần lượt đứng về phía hắn.","anchor":"Ta thân là Tộc trưởng của Huyễn gia, có quyền đặt Huyễn gia ra ngoài chuyện này.","bridge":true,"khoang":"@c0640"},{"text":"Huyễn Phong Thần cùng tộc nhân trực hệ Huyễn gia bị ma uy của Tán Ma chấn nhiếp, thầm thấy may mắn vì lựa chọn trước đó khi đối diện Vương Lâm.","anchor":"Nháy mắt khi Tán Ma xuất hiện, lần đầu tiên sắc mặt của Huyễn gia Lão Tổ tái nhợt không chút huyết sắc.","bridge":true,"khoang":"@c0641"},{"text":"Khi phòng ngự cuối của Huyễn gia bị Tán Ma đánh nứt, Huyễn Phong Thần khuyên Lão Tổ giao Liễu Mi để tránh họa diệt tộc, cho rằng đối thủ tuy chỉ hiện cảnh giới Vấn Đỉnh nhưng pháp bảo và thần thông quá mạnh.","anchor":"Lão Tổ, giao Liễu Mi ra đi thôi… Huyễn Phong Thần trầm giọng nói.","bridge":true,"khoang":"@c0642"},{"chuong":"@c0643","importance":"normal","tieuDe":"Báo lời dặn Liễu Mi","text":"Sau khi Huyễn Vô Tình bị Tán Ma nuốt và túi trữ vật rơi xuống, Huyễn Phong Thần nói cho Vương Lâm biết Liễu Mi từng dặn nếu Huyễn Vô Tình không giết được hắn thì phải giao túi trữ vật cho hắn.","anchor":"Nếu ngươi không giết được Vương Lâm thì hãy đem túi trữ vật này giao cho hắn !"},{"text":"Huyễn Phong Thần dẫn tu sĩ Huyễn Gia ra nghênh tiếp Vương Lâm, nhận đối phương là sứ giả Lôi Tiên Điện và quyết định giao toàn bộ Thăng Tiên quả, chấp nhận bỏ cơ hội tiến vào Lôi Chi tiên giới sau trăm năm.","anchor":"Thôi vậy, Huyễn Gia ta buông tha cơ hội trăm năm sau tiến vào Lôi Chi tiên giới","bridge":true,"khoang":"@c0664"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Vô Tình","tag":"khac","quanHe":"Lão Tổ bị hắn công khai chất vấn","ghiChu":"Huyễn Phong Thần trái ý Huyễn Vô Tình trong quyết định bảo hộ Liễu Mi và đối đầu Vương Lâm."},{"ten":"Vương Lâm","tag":"khac","quanHe":"đối tượng được hắn đề nghị cân nhắc kết giao","ghiChu":"Huyễn Phong Thần nhìn nhận uy hiếp từ Lôi Thú và Tiên vệ của Vương Lâm là lý do không nên kết tử thù."},{"ten":"Liễu Mi","tag":"khac","quanHe":"ngoại nhân khiến hắn phản đối quyết định của Lão Tổ","ghiChu":"Hắn chỉ ra việc Huyễn gia mạo hiểm vì Liễu Mi là không đáng."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0639","@c0640","@c0641","@c0642","@c0643","@c0664"]},{"id":"chu-dat","name":"Chu Dật","cn":"","aliases":["Chu Dật tiền bối"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Chu Dật được nhắc lại là người đã phân ly và truyền thừa Vũ Kiếm tiên cho Vương Lâm, làm rõ lai lịch cự kiếm mà Vương Lâm dùng để thi triển Trảm La Quyết.","anchor":"Kiếm này chính là Vũ Kiếm tiên, nó được Chu Dật tiền bối phân ly, truyền thừa","bridge":true,"khoang":"@c0639"},{"text":"Chu Dật được nhắc qua Vấn Đỉnh chi tinh trong cơ thể Vương Lâm; căn nguyên này khiến nguyên khí của Vương Lâm vượt tu sĩ Vấn Đỉnh bình thường, giúp giảm phần nào rủi ro khi thi triển Trảm La Quyết.","anchor":"Thi triển một thức này cần nguyên khí của thân thể và nguyên thần dung hợp thật chặt chẽ.","bridge":true,"khoang":"@c0640"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0639","@c0640"]},{"id":"lao-gia-hua-gia","name":"Lão già Hứa gia","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Hứa gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không đổi trong chương này","trangThai":"song","blurb":"Lão giả thuộc Hứa gia trên Thiên Huyễn Tinh, dùng thần thức theo dõi biến cố tại Huyễn gia. Ông từng có ước định với Huyễn gia Lão Tổ nhưng kiêng dè hậu thủ của Vương Lâm nên tạm dừng ra tay.","vaiTro":"Lão giả Hứa gia quan sát Huyễn gia","tinhCach":[{"text":"thận trọng trước đối thủ còn giấu hậu thủ","chuong":"@c0640"},{"text":"biết cân nhắc lợi hại trong ước định giữa các nhà","chuong":"@c0640"}],"tabs":{"diem":[{"text":"Định tương trợ Huyễn gia theo ước định nhưng dừng lại khi nhận ra kiếm thức và hậu thủ của Vương Lâm đáng kiêng dè.","chuong":"@c0640"},{"text":"Suy đoán Tiên bảo Huyễn gia có thể đã bị trưởng bối Huyễn gia mang đi.","chuong":"@c0640"}],"kinhLich":[{"text":"Lão già Hứa gia đang định bước ra tương trợ Huyễn gia theo ước định với Huyễn gia Lão Tổ, nhưng đặt chân xuống vì cho rằng Vương Lâm dám khiêu chiến Huyễn gia ắt còn chuẩn bị hậu thủ; về sau ông cũng suy đoán về tung tích Tiên bảo Huyễn gia.","anchor":"Ta dù không sợ hãi nhưng kẻ này dám khiêu chiến Huyễn gia nhất định còn chuẩn bị hậu thủ !","bridge":true,"khoang":"@c0640"},{"text":"Lão già Hứa gia động dung, thần thức kích động khi nhận ra thứ xuất hiện từ Vương Lâm là Tán Ma do Cổ Ma hạ xuống.","anchor":"Nháy mắt khi Tán Ma xuất hiện, lần đầu tiên sắc mặt của Huyễn gia Lão Tổ tái nhợt không chút huyết sắc.","bridge":true,"khoang":"@c0641"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Vô Tình","tag":"dong-minh","quanHe":"có ước định tương trợ","ghiChu":"Từng có ước định với Huyễn gia Lão Tổ nhưng trong chương này tạm không ra tay."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đối tượng kiêng dè","ghiChu":"Kiêng dè kiếm thức và hậu thủ của Vương Lâm nên dừng ý định can thiệp."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0640","@c0641"]},{"id":"huyen-vo-tuong","name":"Huyễn Vô Tướng","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"mat-tich","blurb":"Người Huyễn gia được nhắc là đã mất tích nhiều ngàn năm trước cùng di bảo của tổ tiên. Sự mất tích này khiến Huyễn Vô Tình không thể dùng di bảo tổ tiên trong trận với Vương Lâm.","vaiTro":"Người Huyễn gia mất tích cùng di bảo","tinhCach":[{"text":"chưa rõ tính cách, chỉ được nhắc qua biến cố mất tích","chuong":"@c0640"},{"text":"gắn với bí mật di bảo tổ tiên Huyễn gia","chuong":"@c0640"}],"tabs":{"diem":[{"text":"Mất tích cùng di bảo của Tổ tiên Huyễn gia nhiều ngàn năm trước.","chuong":"@c0640"},{"text":"Sự vắng mặt của di bảo khiến Huyễn Vô Tình phải mời Phúc Trạch ngọc giản.","chuong":"@c0640"}],"kinhLich":[{"text":"Huyễn Vô Tướng được Huyễn Vô Tình nhắc là đã mất tích cùng di bảo của Tổ tiên Huyễn gia mấy ngàn năm trước, khiến món Tiên bảo này không thể được đem ra dùng trong trận hiện tại.","anchor":"Đáng tiếc di bảo của Tổ tiên đã mất tích cùng với Huyễn Vô Tướng mấy ngàn năm trước.","bridge":true,"khoang":"@c0640"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Vô Tình","tag":"ho-hang","quanHe":"người cùng Huyễn gia","ghiChu":"Được Huyễn Vô Tình nhắc khi nghĩ tới di bảo tổ tiên đã mất tích."}],"tuiDo":{"phapBao":[{"ten":"Di bảo của Tổ tiên Huyễn gia","loai":"Tiên bảo mất tích","trangThai":"mat","moTa":"Mất tích cùng Huyễn Vô Tướng nhiều ngàn năm trước.","nguon":"@c0640"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0640"]},{"id":"tan-ma","name":"Tán Ma","cn":"","aliases":["Ma Ảnh một sừng"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Bước thứ hai tu đạo @c0642","trangThai":"song","blurb":"Tán Ma là ma hồn bị Vương Lâm khắc lạc ấn hơn trăm năm, từng được Vương Lâm định luyện thành nguyên thần thứ hai nhưng chưa hoàn toàn luyện hóa. Trong trận tại Thiên Huyễn Tinh, nó hiện thân thành Ma Ảnh một sừng và giao dịch tự do để đổi lấy việc nhập thể chiến đấu.","vaiTro":"Ma hồn nhập thể trợ chiến","tinhCach":[{"text":"hung lệ, coi tự do là điều kiện tối trọng","chuong":"@c0641"},{"text":"tính toán lâu dài, chấp nhận giao dịch để tìm cơ hội thoát khỏi lạc ấn","chuong":"@c0641"}],"tabs":{"diem":[{"text":"Bị lạc ấn của Vương Lâm trói buộc sâu trong ma hồn, lại có thần thông của Cổ Yêu Bối La khiến nó khó phá bỏ nhanh chóng.","chuong":"@c0641"},{"text":"Có thể hóa sương mù nhập thất khiếu Vương Lâm, khống chế thân thể hắn và chuyển tiên lực thành ma lực.","chuong":"@c0641"},{"text":"Nhận ra Hoá Tiên Thuật và dùng thủ đoạn Cổ Ma rút tinh hồn Thiên Huyễn Tinh để đối lại.","chuong":"@c0641"}],"kinhLich":[{"chuong":"@c0641","importance":"major","tieuDe":"Nhập thể chiến đấu","text":"Tán Ma từ thiên linh cái Vương Lâm thoát ra thành Ma Ảnh một sừng, đòi sau trận phải được thả tự do rồi mới chịu giúp hắn đánh giết; sau khi giao ước thành lập, nó hóa sương mù nhập thất khiếu Vương Lâm, khống chế thân thể, phối hợp ma giáp tung quyền hóa hắc long; khi hư ảnh Tiên nhân thi triển Hoá Tiên Thuật rút linh lực tinh cầu, Tán Ma dùng ngôn ngữ Cổ Tộc gọi Cổ Ma và rút tinh hồn Thiên Huyễn Tinh để đối kháng.","anchor":"Ma khí chia làm bảy đạo chui vào thất khiếu của Vương Lâm."},{"text":"Tán Ma khống chế thân thể Vương Lâm thi triển Trừu hồn, rút tinh hồn Thiên Huyễn Tinh để đối kháng Tiên nhân hư ảnh; sau khi hư ảnh sụp đổ, hắn tiếp tục công kích quầng sáng phòng ngự cuối của Huyễn gia.","anchor":"Ma trảo này đem tinh hồn của Thiên Huyễn Tinh rút ra, thanh thế này phải gấp ngàn vạn lần so với Tham Lang năm đó.","bridge":true,"khoang":"@c0642"},{"chuong":"@c0643","importance":"normal","tieuDe":"Nuốt thần thông Huyễn gia","text":"Tán Ma khống chế thân thể Vương Lâm phá vỡ lớp bảo hộ tiên lực cuối cùng của Huyễn gia; khi thấy Huyễn Vô Tình thi triển Vô Tướng Thiên Ma đạo, hắn rời thân thể Vương Lâm, nuốt phần lớn hư ảnh rồi nuốt luôn Huyễn Vô Tình, sau đó tuyên bố hoàn thành hứa hẹn và rời đi.","anchor":"Có hơn phân nửa số này nháy mắt đã bị Tán Ma nuốt vào trong bụng."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"bị khắc lạc ấn và nhập thể trợ chiến theo giao ước","ghiChu":"Muốn được Vương Lâm thả tự do sau trận chiến."},{"ten":"Cổ Yêu Bối La","tag":"doi-thu","quanHe":"người để lại thần thông gia cố lạc ấn trong ma hồn","ghiChu":"Thần thông của Bối La khiến Tán Ma phải tính chuyện mất vài trăm năm mới có hy vọng khu trừ."},{"ten":"hư ảnh Tiên nhân","tag":"doi-thu","quanHe":"đối thủ trực tiếp trong trận tại Thiên Huyễn Tinh","ghiChu":"Dùng thủ đoạn Cổ Ma rút tinh hồn để đối lại Hoá Tiên Thuật của hư ảnh Tiên nhân."},{"ten":"Huyễn Vô Tình","tag":"doi-thu","quanHe":"nuốt diệt","ghiChu":"Tán Ma xem tia Vô Tướng Thiên Ma là vật đại bổ và nuốt cả thần thông lẫn bản thể Huyễn Vô Tình."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"tạm mượn thân thể theo giao ước","ghiChu":"Khống chế thân thể Vương Lâm trong biến cố Huyễn gia rồi rời đi sau khi hoàn thành lời hứa."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Cổ Ma rút ra tinh hồn","loai":"thần thông Cổ Ma","trangThai":"da-dung","moTa":"Tán Ma dùng ngôn ngữ Cổ Tộc phát động, hóa ma trảo rút tinh hồn Thiên Huyễn Tinh để chống lại việc hư ảnh Tiên nhân rút linh lực tinh cầu.","nguon":"@c0641"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0641","@c0642","@c0643"]},{"id":"co-yeu-lao-to-tong","name":"Cổ Yêu Bối La","aliases":["Cổ Yêu"],"canhGioiCaoNhat":"Không đổi trong chương này","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Cổ Yêu Bối La được nhắc đến vì thần thông của hắn gia cố lạc ấn trong ma hồn Tán Ma, khiến Tán Ma không thể nhanh chóng phá bỏ hay hoàn toàn rời khỏi nguyên thần Vương Lâm.","anchor":"Lạc ấn này vốn tuyệt không đơn giản, lại có thêm thần thông của Bối La nên ấn thật sâu vào trong ma hồn của Tán Ma.","bridge":true,"khoang":"@c0641"}],"tuViMoc":[],"nhanMach":[{"ten":"Tán Ma","tag":"doi-thu","quanHe":"thần thông của hắn gia cố lạc ấn trói Tán Ma","ghiChu":"Tán Ma xem việc khu trừ thần thông này là mục tiêu sau khi được tự do."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0641"]},{"id":"hu-anh-tien-nhan","name":"hư ảnh Tiên nhân","cn":"","aliases":["Tiên nhân hư ảnh"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong @c0642","blurb":"hư ảnh Tiên nhân là đối thủ trực tiếp của Tán Ma nhập thể Vương Lâm trong trận tại Thiên Huyễn Tinh. Hư ảnh này dùng tiên lực hóa giải hắc long ma lực rồi thi triển Hoá Tiên Thuật, rút linh lực toàn tinh cầu chuyển thành tiên lực.","vaiTro":"Hư ảnh đối chiến Tán Ma","tinhCach":[{"text":"ra tay bằng tiên lực, áp chế trực diện ma lực của Tán Ma","chuong":"@c0641"},{"text":"sử dụng thủ đoạn quy mô tinh cầu để gom linh lực thành tiên lực","chuong":"@c0641"}],"tabs":{"diem":[{"text":"Dùng tiên lực ngưng tụ thành lốc xoáy, khiến hắc long do Tán Ma nhập thể tung ra hóa thành hư vô.","chuong":"@c0641"},{"text":"Thi triển Hoá Tiên Thuật, rút linh khí toàn Thiên Huyễn Tinh chuyển hóa thành tiên lực và ngưng tụ thành vụ cầu màu trắng ngà.","chuong":"@c0641"}],"kinhLich":[{"text":"hư ảnh Tiên nhân đối đầu Tán Ma nhập thể Vương Lâm, dùng tiên lực hóa giải một quyền hóa hắc long; sau đó thi triển thủ đoạn rút linh lực toàn bộ Thiên Huyễn Tinh, chuyển hóa thành tiên lực và ngưng tụ thành vụ cầu màu trắng ngà trong tay.","anchor":"Nháy mắt này, Thiên Huyễn Tinh đã không có chút linh lực nào !","bridge":true,"khoang":"@c0641"},{"text":"Hư ảnh Tiên nhân dùng tiên lực chuyển hóa từ linh lực Thiên Huyễn Tinh nghênh chiến Tán Ma, nhưng sau va chạm thì sụp đổ; Phúc Trạch ngọc giản hiện ra rồi vỡ vụn, mở lớp phòng ngự cuối.","anchor":"Lúc này đây, Tiên nhân hư ảnh trên bầu trời bỗng nhiên sụp đổ, hoá thành từng làn khói nhẹ, tiêu tan.","bridge":true,"khoang":"@c0642"}],"tuViMoc":[],"nhanMach":[{"ten":"Tán Ma","tag":"doi-thu","quanHe":"đối thủ trực tiếp","ghiChu":"Hai bên đối nhau bằng Hoá Tiên Thuật và Cổ Ma rút tinh hồn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đối thủ trong trận khi thân thể Vương Lâm bị Tán Ma nhập thể","ghiChu":"Hư ảnh Tiên nhân hóa giải hắc long ma lực từ thân thể Vương Lâm."}],"tuiDo":{"phapBao":[{"ten":"Vụ cầu màu trắng ngà","loai":"vật tạo bởi tiên lực","trangThai":"da-dung","moTa":"Được ngưng tụ từ linh lực toàn Thiên Huyễn Tinh sau khi chuyển hóa thành tiên lực.","nguon":"@c0641"}],"danDuoc":[],"congPhap":[{"ten":"Hoá Tiên Thuật","loai":"thần thông","trangThai":"da-dung","moTa":"Rút linh khí toàn tinh cầu, chuyển hóa thành tiên lực và ngưng tụ trong tay.","nguon":"@c0641"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0641","@c0642"]},{"id":"tham-lang","name":"Tham Lang","aliases":[],"trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Vương Lâm nhớ lại Tham Lang từng dùng Tiên sơn pháp bảo rút Sơn hồn ở Yêu Linh chi địa, lấy đó đối chiếu với Trừu hồn quy mô lớn của Tán Ma.","anchor":"Ma trảo này đem tinh hồn của Thiên Huyễn Tinh rút ra, thanh thế này phải gấp ngàn vạn lần so với Tham Lang năm đó.","bridge":true,"khoang":"@c0642"},{"chuong":"@c0643","importance":"normal","tieuDe":"Bị lạc ấn uy hiếp","text":"Trong tinh không La Thiên Tinh Vực, Tham Lang mang rất nhiều lạc ấn trên người, sợ bất cứ lạc ấn nào phát tác cũng khiến mình chết không chỗ chôn, nên tiếp tục đi tìm Vương Lâm.","anchor":"Trên thân thể hắn có rất nhiều lạc ấn, nhiều đến nỗi mỗi khi nhớ tới đều khiến da đầu hắn run lên, đáy lòng phát lạnh."},{"text":"Tham Lang vừa tiến vào La Thiên Bắc Vực đã cảm ứng được bảo vật trên một tinh cầu bị sương mù và mây tía che phủ. Hắn nhớ tới cảm giác từng đoạt đại đỉnh năm xưa, lấy đại đỉnh màu đen ra rồi tiến vào màn sương để tìm kiếm.","anchor":"Lão phu muốn nhìn xem, rốt cuộc là bảo vật gì","bridge":true,"khoang":"@c0653"},{"text":"Tham Lang mắc kẹt ở Vân Hà tinh thuộc La Thiên Tinh Vực; lần thứ tám trong bảy mươi năm hắn chật vật lao ra khỏi sương mù cùng một cái đỉnh lớn nhưng lại bị xúc tu từ trong tinh cầu kéo trở xuống, tuyệt vọng oán trách Vương Lâm khiến mình rơi vào nơi này.","anchor":"đây là lần thứ tám hắn chạy trốn trong vòng bảy mươi năm qua","bridge":true,"khoang":"@c0661"},{"chuong":"@c0666","importance":"normal","tieuDe":"Kẹt nơi bài tiết","text":"Tham Lang lộ diện trong hang động rộng bên trong Vân Hà Tinh, ngồi trong đại đỉnh bị xúc tu quấn quanh và chịu hồng vụ, chất bẩn cùng điện quang phun ra tại nơi bài tiết của Vọng Nguyệt.","anchor":"Lão giả này, đúng là Tham Lang."},{"chuong":"@c0668","importance":"normal","tieuDe":"Bị bỏ mặc","text":"Tham Lang được hé lộ đã tham bảo vào Vân Hà Tinh, đào Kim Viêm quáng mạch và chạm tới Nguyệt Hoa nên bị nuốt vào nơi bài tiết; dù cầu cứu và hứa giao pháp bảo, hắn bị Vương Lâm bỏ mặc vì cứu người quá nguy hiểm.","anchor":"Vương Lâm từ đầu đến cuối không nói câu nào mà xoay người rời đi."},{"text":"Nhân biến động khi Vọng Nguyệt thức tỉnh, Tham Lang mang theo Cự Đỉnh phóng ra khỏi chỗ bài tiết và hấp thu, vừa kinh sợ bản thể Vọng Nguyệt vừa hưng phấn vì nhìn thấy cơ hội thoát khỏi cảnh sống trăm năm trong khí tức tanh tưởi.","anchor":"Tham Lang phóng ra từ trong khe nứt này, tất nhiên hắn sẽ không quên Cự Đỉnh.","bridge":true,"khoang":"@c0670"},{"text":"Biến động trong cơ thể Vọng Nguyệt tạo ra vết nứt ở khu vực bài tiết và hấp thu, Tham Lang nhân cơ hội phóng ra, không quên mang theo Cự Đỉnh và hưng phấn khi nhìn thấy cơ hội rời khỏi nơi tanh tưởi đã giam hắn suốt thời gian dài.","anchor":"Tham Lang phóng ra từ trong khe nứt này, tất nhiên hắn sẽ không quên Cự Đỉnh","bridge":true,"khoang":"@c0671"},{"text":"Tham Lang nhiều lần suýt thoát khỏi khe nứt nhưng bị nửa xương, Định Thân Thuật và Vọng Nguyệt cản lại; hắn kích phát cự đỉnh đổi vị trí, hi sinh thọ nguyên để phóng lớn cự đỉnh rồi đau lòng bỏ đỉnh, sau đó lấy bình phong Sơn Hà Đồ chống một chỉ Cổ Thần nhưng bị trọng thương.","anchor":"Trong nháy mắt sơn hà trong tinh không đột nhiên biến mất, Tham Lang phun ra một ngụm máu nguyên thần lớn rồi cơ thể nhanh chóng lui về phía sau","bridge":true,"khoang":"@c0672"},{"text":"Tham Lang bị Vương Lâm dùng Định Thân Thuật làm khựng lại, phải đội Tôn Tiên Đế Quan để chống Cổ Thần Chỉ; pháp bảo chịu được một chỉ nhưng linh hồn đế vương tan hết, hắn bị đánh bay, biến mất trong tinh không và để rơi vương miện.","anchor":"Tham Lang lúc này đã không biết sống chết, biến mất bên trong tinh không.","bridge":true,"khoang":"@c0673"},{"chuong":"@c0674","importance":"major","tieuDe":"Thoát lạc ấn","text":"Tham Lang rơi xuống một tinh cầu nguyên thủy ở La Thiên Bắc Vực trong tình trạng thân thể vỡ nát, nguyên thần hao tổn nặng nhưng vẫn sống sót. Một chỉ Cổ Thần phá tan phần lớn lạc ấn cường giả trong cơ thể hắn, chỉ còn lạc ấn Thiên Vận Tử; hắn chìm xuống lòng đất để chờ khôi phục.","anchor":"Chỉ còn tồn tại duy nhất đạo lạc ấn của Thiên Vận Tử."},{"chuong":"@c0675","importance":"normal","tieuDe":"Bảo vật bị kiểm tra","text":"Sau khi đoạt được nhiều bảo vật của Tham Lang từ một giáp trước, Vương Lâm lần lượt kiểm tra núi đá tiên giới, Sơn Hà Đồ bình phong, Vương Miện và các vật liên quan, qua đó nhận ra giá trị bất thường của kho bảo vật này.","anchor":"Tham Lang đoạt được cũng không phải là Sơn Hà Thiên Đạo Đồ chân chính, mà chỉ"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"bị ép tìm kiếm","ghiChu":"Tham Lang phải tìm Vương Lâm vì những lạc ấn trên thân đe dọa tính mạng."},{"ten":"Vương Lâm","tag":"khac","quanHe":"mục tiêu phải tìm","ghiChu":"Tham Lang lo sợ lạc ấn trên thân phát tác nên tiếp tục bôn tẩu tìm Vương Lâm."},{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"bị lạc ấn khống chế","ghiChu":"Sau biến cố một chỉ Cổ Thần, trong cơ thể Tham Lang chỉ còn lạc ấn của Thiên Vận Tử tồn tại."}],"tuiDo":{"phapBao":[{"ten":"Tiên sơn pháp bảo","loai":"pháp bảo","trangThai":"dang-co","moTa":"Từng được dùng ở Yêu Linh chi địa để rút Sơn hồn, được Vương Lâm nhớ lại khi chứng kiến Trừu hồn của Tán Ma.","nguon":"@c0642"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0642","@c0643","@c0653","@c0661","@c0666","@c0668","@c0670","@c0671","@c0672","@c0673","@c0674","@c0675"],"canhGioiCaoNhat":"không rõ @c0673","gioiTinh":"nam","tinhCach":[]},{"id":"chu-thuc-thuc","name":"Chu thúc thúc","aliases":["đại hán họ Chu","Chu thúc thúc"],"gioiTinh":"nam","theLuc":[{"ten":"Lạc Nguyệt thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0643","trangThai":"song","blurb":"Chu thúc thúc là thợ săn ở Lạc Nguyệt thôn. Ông săn được chương lộc rồi mang tới nhà Vương Lâm làm tiền đặt cọc để nhờ làm đồ đạc cho phòng cưới của con trai.","vaiTro":"thợ săn trong Lạc Nguyệt thôn","tinhCach":[{"text":"chất phác, gần gũi với hàng xóm","chuong":"@c0643"},{"text":"quan tâm việc cưới hỏi của con trai","chuong":"@c0643"}],"tabs":{"diem":[{"text":"Săn được chương lộc và dùng làm tiền đặt cọc nhờ Vương Lâm làm đồ.","chuong":"@c0643"},{"text":"Có quan hệ quen biết với Vương Lâm và Vương Bình trong thôn.","chuong":"@c0643"},{"text":"Là thợ săn trong Lạc Nguyệt thôn, trở về với con chương lộc săn được.","chuong":"@c0643"},{"text":"Đến nhà Vương Lâm nhờ làm đồ đạc cho phòng cưới của con trai.","chuong":"@c0643"}],"kinhLich":[{"chuong":"@c0643","importance":"normal","tieuDe":"Nhờ làm phòng cưới","text":"Chu thúc thúc săn được chương lộc, gặp Vương Bình ở thôn khẩu rồi đến nhà Vương Lâm, dùng con mồi làm tiền đặt cọc để nhờ làm đồ đạc cho phòng cưới của con trai.","anchor":"Con chương lộc này làm tiền đặt cọc trước vậy !"},{"chuong":"@c0646","importance":"normal","tieuDe":"Tiễn biệt Vương gia","text":"Chu gia đại hán cùng người trong thôn tới tiễn hai cha con Vương gia rời Lạc Nguyệt thôn, cảm khái gần hai mươi năm trôi qua từ khi Vương Lâm ôm Vương Bình tới đây và nhắc con gái mình không có duyên với Vương Bình.","anchor":"năm đó ta còn nhớ rõ cảnh tượng ngươi ôm Bình nhi tới nơi này"}],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Chu thúc thúc xuất hiện như một thợ săn phàm tục tại Lạc Nguyệt thôn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người nhờ làm đồ","ghiChu":"Chu thúc thúc nhờ Vương Lâm làm đồ đạc cho phòng cưới con trai."},{"ten":"Vương Bình","tag":"khac","quanHe":"người trong thôn","ghiChu":"Ông khen Vương Bình lễ phép khi gặp cậu."},{"ten":"Chu đại ca","tag":"cha-me","quanHe":"cha","ghiChu":"Chu thúc thúc là cha của thiếu niên họ Chu."},{"ten":"Vương Lâm","tag":"ban-be","quanHe":"hàng xóm","ghiChu":"Hàng xóm thân thiện, đến tiễn Vương Lâm khi hắn rời Lạc Nguyệt thôn."},{"ten":"Chu Nhược Đồng","tag":"cha-me","quanHe":"phụ thân","ghiChu":"Là cha của Chu Nhược Đồng."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[{"ten":"Chương lộc","trangThai":"da-dung","moTa":"Con mồi săn được, được Chu thúc thúc dùng làm tiền đặt cọc nhờ Vương Lâm làm đồ đạc.","nguon":"@c0643"}],"linhThao":[],"khac":[]}},"nguon":["@c0643","@c0646"]},{"id":"ton-thai","name":"Tôn Thái","aliases":["Tôn gia gia"],"canhGioiCaoNhat":"Không rõ @c0653","trangThai":"tu-vong","tabs":{"diem":[],"kinhLich":[{"text":"Tôn Thái đến sống gần Vương Lâm từ năm thứ ba sau khi Vương Lâm định cư ở thôn Lạc Nguyệt; lão đã già nua, tử khí dày đặc, yêu quý Vương Bình, từng có ý truyền sở học nhưng tôn trọng quyết định của Vương Lâm không cho đứa trẻ tu đạo.","anchor":"Vương Lâm định cư ở đây đến năm thứ ba thì Tôn Thái tới","bridge":true,"khoang":"@c0644"},{"chuong":"@c0645","importance":"major","tieuDe":"Đại nạn qua đời","text":"Khi đại nạn đến, Tôn Thái nằm trên giường nghe Vương Lâm nhắc lại lời hứa năm xưa, nhớ chuyện ở Vũ Chi Tiên Giới rồi an tường mất; sau đó lão được chôn ở sau núi cạnh thôn Lạc Nguyệt, mộ bia do Vương Bình khắc với thân phận nghĩa tôn.","anchor":"Tôn Thái mỉm cười, nhắm hai mắt lại."},{"chuong":"@c0646","importance":"major","tieuDe":"Tro cốt được giữ","text":"Tôn Thái đã qua đời; thi thể hóa thành tro cốt và được Vương Lâm đặt trong túi trữ vật theo lời hứa. Chương cũng nhắc việc lão từng mượn danh nghĩa nhận Vương Bình làm cháu nuôi để âm thầm truyền pháp thuật cho hắn, khiến bản thân chết sớm hơn.","anchor":"thi thể của lão đã trở thành một vò tro cốt, đặt trong túi trữ vật của Vương Lâm"},{"text":"Mộ Tôn Thái ở hậu sơn thôn Lạc Nguyệt được chăm sóc sạch cỏ. Vương Bình đến trước mộ im lặng tế bái hồi lâu, rồi nhắc với Thanh Nghi rằng đã lâu chưa gặp phụ thân và còn chuyện cần hỏi rõ.","anchor":"Đã hai mươi năm rồi, không gặp phụ thân","bridge":true,"khoang":"@c0653"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Bình","tag":"an-nhan","quanHe":"người truyền khẩu quyết tu đạo","ghiChu":"Tôn Thái từng nương danh nhận Vương Bình làm cháu nuôi để âm thầm truyền pháp thuật cho hắn."},{"ten":"Vương Lâm","tag":"ban-be","quanHe":"cố nhân","ghiChu":"Sau khi Tôn Thái chết, Vương Lâm giữ tro cốt của lão trong túi trữ vật theo lời hứa."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0644","@c0645","@c0646","@c0653"],"gioiTinh":"nam","tinhCach":[]},{"id":"truong-tham-tham","name":"Trương thẩm thẩm","cn":"","aliases":["bà mối","Trương thẩm thẩm"],"gioiTinh":"nu","theLuc":[{"ten":"Thôn Lạc Nguyệt","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0645","trangThai":"song","blurb":"Trương thẩm thẩm là người trong thôn Lạc Nguyệt, thường qua lại nhà Vương Lâm trong những năm cha con hắn sống đời phàm tục. Sự xuất hiện của bà làm nổi bật không khí sinh hoạt thôn quê quanh Vương Lâm và Vương Bình.","vaiTro":"người dân thôn Lạc Nguyệt","tinhCach":[{"text":"Nhiệt tình qua lại nhà Vương Lâm","chuong":"@c0644"},{"text":"Gắn với đời sống phàm tục trong thôn","chuong":"@c0644"}],"tabs":{"diem":[{"text":"Thường tới nhà Vương Lâm trong ba năm, khiến Vương Bình chú ý tới chuyện cha mình có thể hợp ý người trong thôn.","chuong":"@c0644"},{"text":"Đại diện cho quan hệ thôn xóm đã hình thành quanh cha con Vương Lâm.","chuong":"@c0644"},{"text":"Khuyên Vương Lâm nghĩ tới Vương Bình khi cân nhắc tái hôn.","chuong":"@c0645"},{"text":"Là người đưa chuyện nữ nhi Triệu gia vào đời sống phụ tử Vương Lâm.","chuong":"@c0645"}],"kinhLich":[{"text":"Trương thẩm thẩm nhiều lần tới nhà Vương Lâm trong ba năm, trở thành một trong các mối quan hệ phàm tục của cha con Vương Lâm tại thôn Lạc Nguyệt.","anchor":"ba năm qua, Trương Thẩm Thẩm đã tới đây vài lần","bridge":true,"khoang":"@c0644"},{"text":"Trương thẩm thẩm đến khuyên Vương Lâm cưới nữ nhi Triệu gia, nhấn mạnh Vương Bình thiếu mẫu thân và cô gái kia cam tâm tình nguyện, nhưng Vương Lâm quyết định coi như không có chuyện này.","anchor":"Ngươi không vì bản thân cũng phải vì đứa nhỏ mà ngẫm lại.","bridge":true,"khoang":"@c0645"}],"tuViMoc":[{"chuong":"@c0644","canhGioi":"Phàm nhân","text":"Trương thẩm thẩm xuất hiện như một người dân bình thường trong thôn Lạc Nguyệt.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Thường tới nhà Vương Lâm trong những năm hắn sống ở thôn Lạc Nguyệt."},{"ten":"Vương Bình","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Sự lui tới của bà khiến Vương Bình lo lắng chuyện cha mình."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0644","@c0645","@c0646"]},{"id":"chu-gia-nhi-nha-dau","name":"Chu gia nhị nha đầu","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Chu gia","trangThai":"gan-bo"},{"ten":"Thôn Lạc Nguyệt","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0644","trangThai":"song @c0644","blurb":"Chu gia nhị nha đầu là cô bé trong thôn Lạc Nguyệt, khoảng tám tuổi, tới tìm Vương Bình giữa trời tuyết. Cô thuộc mảng sinh hoạt trẻ nhỏ quanh Vương Bình trong những năm cậu được nuôi như phàm nhân.","vaiTro":"bạn nhỏ trong thôn","tinhCach":[{"text":"Hồn nhiên trong sinh hoạt thôn xóm","chuong":"@c0644"},{"text":"Thân quen với Vương Bình","chuong":"@c0644"}],"tabs":{"diem":[{"text":"Tới tìm Vương Bình giữa trời tuyết và gọi cậu là Vương ca ca.","chuong":"@c0644"},{"text":"Làm rõ Vương Bình đã hòa vào đời sống trẻ nhỏ trong thôn Lạc Nguyệt.","chuong":"@c0644"}],"kinhLich":[{"text":"Chu gia nhị nha đầu được nhắc là cô bé trong thôn tới tìm Vương Bình, khiến Tôn Thái trêu chọc và Vương Bình phản ứng như một đứa trẻ bình thường.","anchor":"ba năm qua, Trương Thẩm Thẩm đã tới đây vài lần","bridge":true,"khoang":"@c0644"}],"tuViMoc":[{"chuong":"@c0644","canhGioi":"Phàm nhân","text":"Chu gia nhị nha đầu xuất hiện như một đứa trẻ phàm tục ở thôn Lạc Nguyệt.","importance":"minor"}],"nhanMach":[{"ten":"Vương Bình","tag":"ban-be","quanHe":"bạn nhỏ trong thôn","ghiChu":"Tới tìm Vương Bình giữa trời tuyết."},{"ten":"Vương Lâm","tag":"khac","quanHe":"người trong thôn quen biết","ghiChu":"Liên quan tới sinh hoạt thôn xóm quanh nhà Vương Lâm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0644"]},{"id":"chu-nhuoc-dong","name":"Chu Nhược Đồng","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Chu gia","trangThai":"gan-bo"},{"ten":"Lạc Nguyệt thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0653","trangThai":"song","blurb":"Chu Nhược Đồng là thiếu nữ Chu gia ở Lạc Nguyệt thôn, có tình cảm với Vương Bình khi hắn trưởng thành. Trong ngày Vương Bình rời thôn, nàng hỏi hắn có trở về hay không rồi bật khóc khi nhận câu trả lời phủ định.","vaiTro":"thiếu nữ thôn lưu luyến Vương Bình","tinhCach":[{"text":"thẳng thắn bộc lộ tình cảm khi ly biệt","chuong":"@c0646"},{"text":"dễ tổn thương trước sự lạnh nhạt của Vương Bình","chuong":"@c0646"}],"tabs":{"diem":[{"text":"Là thiếu nữ trong thôn có tình ý rõ rệt với Vương Bình khi hắn rời Lạc Nguyệt thôn.","chuong":"@c0646"},{"text":"Trực tiếp hỏi Vương Bình liệu sau này hắn có trở về không, rồi khóc bỏ chạy khi nghe hắn nói có lẽ sẽ không.","chuong":"@c0646"},{"text":"Là khuê nữ Chu gia ở Lạc Nguyệt thôn, xuất hiện trong nhóm thiếu nữ tới tiễn Vương Bình.","chuong":"@c0646"},{"text":"Hỏi Vương Bình sau này có trở về không, rồi khóc khi nhận câu trả lời phủ định.","chuong":"@c0646"}],"kinhLich":[{"text":"Chu Nhược Đồng nhận ra Vương Bình khi hắn trở lại thôn Lạc Nguyệt sau nhiều năm xa cách. Nàng nay đã là phụ nhân trung niên có chồng con, vẫn vui mừng vì gặp lại cố nhân và có con gái tên Hứa Niệm Bình.","anchor":"Vừa rồi nhìn thấy ca, ta liền nhận ra rồi","bridge":true,"khoang":"@c0653"}],"tuViMoc":[{"chuong":"@c0646","canhGioi":"Phàm nhân","text":"Chu Nhược Đồng xuất hiện như thiếu nữ phàm tục trong Lạc Nguyệt thôn, không có dấu hiệu tu luyện.","importance":"minor"}],"nhanMach":[{"ten":"Vương Bình","tag":"khac","quanHe":"người nàng lưu luyến","ghiChu":"Nàng hỏi Vương Bình có trở về thôn hay không và đau lòng khi hắn nói có lẽ sẽ không."},{"ten":"Chu gia đại hán","tag":"cha-me","quanHe":"người thân Chu gia","ghiChu":"Nàng là khuê nữ Chu gia trong Lạc Nguyệt thôn."},{"ten":"Hứa Niệm Bình","tag":"cha-me","quanHe":"mẹ con","ghiChu":"Chu Nhược Đồng là mẫu thân của Hứa Niệm Bình."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0646","@c0653"]},{"id":"nguoi-dan-ong-trung-nien-cuoi-phi-kiem-mau-xanh","name":"Người đàn ông trung niên cưỡi phi kiếm màu xanh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"tu sĩ @c0647","trangThai":"song","blurb":"Một tu sĩ tiên phong đạo cốt cưỡi phi kiếm xanh bay qua Kỳ Liên phong sau cơn dông. Sự xuất hiện thoáng qua của ông khiến Vương Bình lần đầu chứng kiến cảnh tượng tu tiên.","vaiTro":"tu sĩ bay ngang Kỳ Liên phong","tinhCach":"tiên phong đạo cốt; có lời tán thưởng nghị lực của phàm nhân leo núi","tabs":{"diem":[{"text":"Cưỡi phi kiếm màu xanh bay qua cầu vồng gần Kỳ Liên phong.","chuong":"@c0647"},{"text":"Nhìn thấy phụ tử Vương Lâm và tán thưởng nghị lực của phàm nhân leo tới đỉnh núi.","chuong":"@c0647"}],"kinhLich":[{"text":"Sau cơn dông trên Kỳ Liên phong, người đàn ông trung niên cưỡi phi kiếm màu xanh bay qua gần cầu vồng, nhìn thấy phụ tử Vương Lâm rồi tán thưởng nghị lực leo núi của phàm nhân trước khi rời đi; cảnh tượng này khiến Vương Bình lần đầu trong đời chứng kiến tu sĩ phi hành.","anchor":"đây là lần đầu tiên trong cuộc đời hắn nhìn thấy một cảnh tượng như vậy","bridge":true,"khoang":"@c0647"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Bình","tag":"khac","quanHe":"người khiến Vương Bình lần đầu thấy cảnh tượng tu tiên","ghiChu":"Bay qua Kỳ Liên phong @c0647"},{"ten":"Vương Lâm","tag":"khac","quanHe":"gặp thoáng qua trên Kỳ Liên phong","ghiChu":"Tán thưởng nghị lực leo núi của phàm nhân @c0647"}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm màu xanh","loai":"pháp bảo","trangThai":"dang-co","moTa":"Phi kiếm xanh tỏa hàn quang, dùng để phi hành qua Kỳ Liên phong.","nguon":"@c0647"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0647"]},{"id":"lao-nhan-cam-y","name":"Lão nhân cẩm y","cn":"","aliases":["lão già tóc trắng"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Kết Đan @c0648","trangThai":"song","blurb":"Tu sĩ Kết Đan xuất hiện tại Tĩnh Nhã Hiên, đi cùng thanh niên tử y và Thanh nhi sư muội. Lão ra tay độc ác với Vương Bình nhưng lập tức bị ánh mắt của Vương Lâm trọng thương.","vaiTro":"Tu sĩ gây xung đột tại Tĩnh Nhã Hiên","tinhCach":[{"text":"uy nghiêm và tự phụ khi lấy danh giáo huấn thay gia trưởng","chuong":"@c0648"},{"text":"ra tay tàn độc với phàm nhân, nhắm thẳng hai vai Vương Bình","chuong":"@c0648"},{"text":"biết cầu viện sau khi bị trọng thương","chuong":"@c0648"}],"tabs":{"diem":[{"text":"Là tu sĩ Kết Đan, cao hơn thanh niên tử y và Thanh nhi trong nhóm đi cùng.","chuong":"@c0648"},{"text":"Dùng đôi đũa làm ám khí nhắm vào hai vai Vương Bình, nếu trúng sẽ khiến hắn tàn phế.","chuong":"@c0648"},{"text":"Bị Vương Lâm liếc một cái khiến kim đan nứt, phải nuốt đan dược và bóp nát ngọc giản đưa tin.","chuong":"@c0648"}],"kinhLich":[{"text":"Tại Tĩnh Nhã Hiên, lão nhân cẩm y lấy cớ giáo huấn thay gia trưởng, phóng đôi đũa vào hai vai Vương Bình; Vương Lâm can thiệp bằng một ánh mắt khiến kim đan của lão nứt ra, sau đó lão nuốt đan dược và bóp nát ngọc giản đưa tin.","anchor":"Một ngụm máu tươi từ khóe miệng chảy xuống, trong máu tươi còn mang theo ánh vàng, đó là kim đan, lúc này, kim đan nứt ra, đan khí nhập vào máu huyết tuôn ra.","bridge":true,"khoang":"@c0648"}],"tuViMoc":[{"chuong":"@c0648","canhGioi":"Kết Đan","text":"Chương xác nhận lão nhân là một tu sĩ Kết Đan.","importance":"minor"}],"nhanMach":[{"ten":"Vương Bình","tag":"doi-thu","quanHe":"ra tay định phế hai tay","ghiChu":"Lão nhắm đôi đũa vào hai vai Vương Bình sau khi thanh niên tử y bị đáp trả."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"bị Vương Lâm dùng ánh mắt trọng thương","ghiChu":"Vương Lâm ra tay vì lão động tới con trai mình."},{"ten":"Thanh niên tử y","tag":"dong-minh","quanHe":"đi cùng bàn tại Tĩnh Nhã Hiên","ghiChu":"Lão can dự sau khi thanh niên tử y xung đột với Vương Bình."},{"ten":"Thanh nhi sư muội","tag":"dong-minh","quanHe":"đi cùng bàn tại Tĩnh Nhã Hiên","ghiChu":"Thanh nhi kinh hô và muốn chặn đôi đũa khi lão ra tay."}],"tuiDo":{"phapBao":[{"ten":"Ngọc giản đưa tin","loai":"vật phẩm truyền tin","trangThai":"da-dung","moTa":"Bị lão bóp nát sau khi trọng thương để truyền tin hoặc cầu viện.","nguon":"@c0648"}],"danDuoc":[{"ten":"Đan dược trong túi trữ vật","loai":"đan dược","trangThai":"da-dung","moTa":"Lão lấy ra nuốt sau khi kim đan nứt và ngã xuống.","nguon":"@c0648"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Đôi đũa","loai":"vật tùy thân","trangThai":"mat","moTa":"Được lão dùng như ám khí nhắm vào hai vai Vương Bình nhưng mất lực bên người Vương Bình.","nguon":"@c0648"},{"ten":"Túi trữ vật","loai":"vật chứa đồ","trangThai":"dang-co","moTa":"Chứa đan dược mà lão lấy ra sau khi bị thương.","nguon":"@c0648"}]}},"nguon":["@c0648"]},{"id":"thanh-nien-tu-y","name":"Thanh niên tử y","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Luyện Khí @c0648","trangThai":"song","blurb":"Nam tử trẻ mặc tử y thêu kim tuyến, đi cùng lão nhân cẩm y và Thanh nhi tại Tĩnh Nhã Hiên. Vì ghen tức khi Thanh nhi chú ý tới Vương Bình, hắn liên tục chế nhạo và nhục mạ Vương Bình.","vaiTro":"Người khơi mào xung đột tại Tĩnh Nhã Hiên","tinhCach":[{"text":"dễ ghen tức trước phản ứng của Thanh nhi","chuong":"@c0648"},{"text":"kiêu ngạo, dùng lời nhục mạ dung mạo người khác","chuong":"@c0648"}],"tabs":{"diem":[{"text":"Có tu vi Luyện Khí, thấp hơn lão nhân cẩm y đi cùng.","chuong":"@c0648"},{"text":"Vì Thanh nhi nhìn Vương Bình mà sinh lòng ghen ghét, nhiều lần châm chọc Vương Bình.","chuong":"@c0648"},{"text":"Sau khi lão nhân bị trọng thương, hắn vẫn âm trầm nhìn phụ tử Vương Lâm.","chuong":"@c0648"},{"text":"Lấy danh Tôn gia để uy hiếp Vương Lâm trong tửu lâu.","chuong":"@c0649"},{"text":"Bị Vương Lâm phất tay đánh ngã nhưng không bị giết.","chuong":"@c0649"}],"kinhLich":[{"text":"Tại Tĩnh Nhã Hiên, thanh niên tử y thấy Thanh nhi chú ý tới Vương Bình nên sinh ghen tức, liên tục nhạo báng và nhục mạ dung mạo Vương Bình, khiến xung đột với phụ tử Vương Lâm bùng lên.","anchor":"Thanh niên hừ lạnh một tiếng, sở dĩ vừa rồi hắn nhạo báng Vương Bình, bởi vì khi Vương Bình tiến vào, nữ nhân trước mắt vốn luôn luôn lãnh đạm này, không ngờ ngẩng đầu nhìn thoáng qua.","bridge":true,"khoang":"@c0648"},{"text":"Thanh niên tử y định lấy Tôn gia ra uy hiếp Vương Lâm, nhưng chưa nói hết đã bị Vương Lâm phất tay đánh ngã; do linh khí trong cơ thể ít và gần như phàm nhân, hắn được tha mạng.","anchor":"Không chờ hắn nói hết, Vương Lâm vung tay phải lên","bridge":true,"khoang":"@c0649"}],"tuViMoc":[{"chuong":"@c0648","canhGioi":"Luyện Khí","text":"Chương xác nhận thanh niên tử y chỉ có tu vi Luyện Khí.","importance":"minor"}],"nhanMach":[{"ten":"Vương Bình","tag":"doi-thu","quanHe":"chủ động nhục mạ và khiêu khích","ghiChu":"Hắn châm chọc Vương Bình vì ghen tức với phản ứng của Thanh nhi."},{"ten":"Thanh nhi sư muội","tag":"su-mon","quanHe":"đồng môn hoặc cùng sư môn chưa rõ tên","ghiChu":"Hắn gọi nàng là Thanh nhi sư muội."},{"ten":"Lão nhân cẩm y","tag":"dong-minh","quanHe":"đi cùng bàn tại Tĩnh Nhã Hiên","ghiChu":"Lão nhân ra tay sau khi hắn bị Vương Bình đáp trả."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"gây hấn rồi bị áp chế","ghiChu":"Dùng danh Tôn gia uy hiếp Vương Lâm nhưng bị đánh ngã."},{"ten":"Tôn sư tổ","tag":"ho-hang","quanHe":"cùng tộc","ghiChu":"Đều thuộc Tôn gia tại Kỳ Thủy thành."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0648","@c0649"]},{"id":"thanh-nhi-su-muoi","name":"Thanh nhi sư muội","cn":"","aliases":["Thanh nhi","nữ nhân hiên ngang"],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Chưa tới Trúc Cơ @c0648","trangThai":"song","blurb":"Nữ nhân trẻ đi cùng thanh niên tử y và lão nhân cẩm y tại Tĩnh Nhã Hiên. Nàng chú ý tới Vương Bình, tỏ vẻ phiền chán trước lời chế nhạo và kinh hô khi lão nhân ra tay độc ác.","vaiTro":"Nữ tu đồng môn của thanh niên tử y","tinhCach":[{"text":"lãnh đạm với thanh niên tử y nhưng có phản ứng khi thấy Vương Bình","chuong":"@c0648"},{"text":"không tán đồng hành vi quá đáng của người đi cùng","chuong":"@c0648"}],"tabs":{"diem":[{"text":"Được thanh niên tử y gọi là sư muội, cho thấy hai người có quan hệ đồng môn hoặc cùng sư môn.","chuong":"@c0648"},{"text":"Từng ngẩng đầu nhìn Vương Bình khi hắn bước vào, trở thành nguyên nhân khiến thanh niên tử y ghen tức.","chuong":"@c0648"},{"text":"Tu vi chưa tới Trúc Cơ trong nhóm ba người tại bàn bên cạnh.","chuong":"@c0648"}],"kinhLich":[{"text":"Tại Tĩnh Nhã Hiên, Thanh nhi sư muội đi cùng thanh niên tử y và lão nhân cẩm y; việc nàng chú ý tới Vương Bình khiến thanh niên tử y ghen ghét, còn khi lão nhân ra tay bằng đôi đũa, nàng kinh hô và muốn ngăn lại.","anchor":"Thanh niên hừ lạnh một tiếng, sở dĩ vừa rồi hắn nhạo báng Vương Bình, bởi vì khi Vương Bình tiến vào, nữ nhân trước mắt vốn luôn luôn lãnh đạm này, không ngờ ngẩng đầu nhìn thoáng qua.","bridge":true,"khoang":"@c0648"}],"tuViMoc":[{"chuong":"@c0648","canhGioi":"Chưa tới Trúc Cơ","text":"Chương cho biết nàng chưa đạt Trúc Cơ.","importance":"minor"}],"nhanMach":[{"ten":"Thanh niên tử y","tag":"su-mon","quanHe":"được gọi là sư muội","ghiChu":"Hai người đi cùng nhau tại Tĩnh Nhã Hiên, nhưng tên sư môn chưa được nêu."},{"ten":"Lão nhân cẩm y","tag":"dong-minh","quanHe":"đi cùng bàn tại Tĩnh Nhã Hiên","ghiChu":"Nàng kinh hô khi lão nhân ra tay với Vương Bình."},{"ten":"Vương Bình","tag":"khac","quanHe":"người nàng chú ý trong tửu quán","ghiChu":"Cái nhìn của nàng với Vương Bình khiến thanh niên tử y ghen tức."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0648"]},{"id":"phu-xe","name":"Phu xe","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Phàm nhân @c0648","trangThai":"song","blurb":"Người điều khiển xe ngựa chở phụ tử Vương Lâm tới Kỳ Thủy thành. Chương chỉ nhắc ông ở ngoài xe, không nêu thêm thân phận.","vaiTro":"Người đánh xe chở phụ tử Vương Lâm","tinhCach":[{"text":"làm phận sự điều khiển xe ngựa","chuong":"@c0648"}],"tabs":{"diem":[{"text":"Có mặt bên ngoài xe ngựa khi phụ tử Vương Lâm nói chuyện trên đường tới Kỳ Thủy thành.","chuong":"@c0648"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0648","canhGioi":"Phàm nhân","text":"Chương không nêu dấu hiệu tu vi của phu xe.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"chở Vương Lâm tới Kỳ Thủy thành","ghiChu":"Phu xe ở ngoài xe ngựa trong đoạn phụ tử Vương Lâm lên đường."},{"ten":"Vương Bình","tag":"khac","quanHe":"chở Vương Bình tới Kỳ Thủy thành","ghiChu":"Phu xe điều khiển xe ngựa có Vương Bình ngồi bên trong."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0648"]},{"id":"tieu-nhi-tuu-lau","name":"Tiểu nhị tửu lâu","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tĩnh Nhã Hiên","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0648","trangThai":"song","blurb":"Tiểu nhị tại tửu lâu Tĩnh Nhã Hiên ở Kỳ Thủy thành. Hắn tiếp đón phụ tử Vương Lâm vào đại sảnh và bưng rượu thức ăn.","vaiTro":"Tiểu nhị phục vụ tại Tĩnh Nhã Hiên","tinhCach":[{"text":"làm việc tiếp khách và phục vụ trong tửu lâu","chuong":"@c0648"}],"tabs":{"diem":[{"text":"Xuất hiện tại Tĩnh Nhã Hiên khi phụ tử Vương Lâm vào tửu lâu dùng bữa.","chuong":"@c0648"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0648","canhGioi":"Phàm nhân","text":"Chương không nêu dấu hiệu tu vi của tiểu nhị.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"tiếp đón tại tửu lâu","ghiChu":"Tiểu nhị dẫn phụ tử Vương Lâm vào đại sảnh và phục vụ rượu thức ăn."},{"ten":"Vương Bình","tag":"khac","quanHe":"tiếp đón tại tửu lâu","ghiChu":"Tiểu nhị phục vụ khi Vương Bình cùng Vương Lâm vào Tĩnh Nhã Hiên."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0648","@c0652"]},{"id":"thanh-nghi","name":"Thanh Nghi","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Tôn gia","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ đại viên mãn @c0654","trangThai":"khong-ro","blurb":"Thanh Nghi là nữ đệ tử đi cùng lão nhân Kết Đan trong vụ tửu lâu Kỳ Thủy thành. Nàng xin lỗi Vương Lâm, trò chuyện với Vương Bình và hé lộ việc sư tôn đã gọi viện binh Tôn gia.","vaiTro":"đệ tử liên hệ Tôn gia","tinhCach":[{"text":"biết nhận lỗi khi phía mình gây chuyện","chuong":"@c0649"},{"text":"dịu dàng và có thiện cảm với Vương Bình","chuong":"@c0649"}],"tabs":{"diem":[{"text":"Chủ động thừa nhận phía mình có lỗi và báo cho Vương Bình biết Tôn gia sắp tới.","chuong":"@c0649"},{"text":"Có thiện cảm rõ với Vương Bình qua cuộc trò chuyện trong tửu lâu.","chuong":"@c0649"}],"kinhLich":[{"text":"Sau biến cố trong tửu lâu, Thanh Nghi xin lỗi Vương Lâm, trò chuyện với Vương Bình và tiết lộ sư tôn đã bóp nát ngọc giản đưa tin để gọi người Tôn gia tới.","anchor":"sư tôn đã bóp nát ngọc giản đưa tin","bridge":true,"khoang":"@c0649"},{"chuong":"@c0650","importance":"normal","tieuDe":"Che giấu họ Vương","text":"Bị đưa tới đại điện chi nhánh Tôn gia sau vụ tửu lâu, Thanh Nghi run sợ khi bị hỏi về họ của người kia nhưng vẫn phủ nhận để che giấu cho Vương Lâm; lão nhân mặt đỏ nhìn ra nàng nói dối.","anchor":"với lịch duyệt của hắn, tự nhiên liếc một cái liền biết nữ nhân này đang nói dối"},{"chuong":"@c0651","importance":"major","tieuDe":"Theo giúp Vương Bình","text":"Sau khi bị đuổi khỏi Tôn gia, Thanh Nghi bị phong tỏa tu vi và đưa tới phòng Vân Vô Phong. Vương Lâm xuất hiện, nhìn ra tư chất của nàng không tồi, bảo nàng theo giúp Vương Bình vài năm và hứa đưa nàng tới đạo hạnh Nguyên Anh; ba ngày sau nàng rời Kỳ Thủy Thành cùng Vương Bình.","anchor":"theo nhi tử ta giúp nó mấy năm, ta đưa ngươi tới đạo hạnh Nguyên Anh"},{"chuong":"@c0652","importance":"normal","tieuDe":"Ở bên Vương Bình","text":"Thanh Nghi ở bên chăm sóc Vương Bình nhiều năm, khoác áo choàng và khuyên hắn nghỉ ngơi; nàng cùng hắn gọi Vương Lâm là phụ thân, rồi khi Vương Bình mệt mỏi nhìn về Kỳ Liên Sơn, nàng gợi ý hắn trở lại nơi thơ ấu.","anchor":"Phụ thân ta là phụ thân nàng"},{"text":"Thanh Nghi theo Vương Bình trở lại thôn Lạc Nguyệt, viếng mộ Tôn Thái, về Vương phủ gặp Vương Lâm và nghe chuyện xưa về mẫu thân Vương Bình. Sau khi Vương Bình không thể đối diện ngay với chân tướng, nàng cùng hắn rời Kỳ Thủy Thành, chọn một sơn thôn biên thùy để sống bình thản.","anchor":"Từ đầu tới cuối hắn không nói với phụ thân một câu nào","bridge":true,"khoang":"@c0653"},{"importance":"normal","chuong":"@c0654","tieuDe":"Chọn tình phàm nhân","text":"Thanh Nghi ở bên Vương Bình tới cuối đời; dù từng được Vương Lâm nâng tu vi tới Nguyên Anh hậu kỳ đại viên mãn và cảm ngộ ý cảnh tình yêu không hối hận, nàng vẫn xem tu vi như bụi bặm và chọn làm người thường có tình.","anchor":"ta không muốn làm thần tiên vô tình, chỉ muốn làm người thường có tình mà thôi"},{"chuong":"@c0655","importance":"normal","tieuDe":"Chắn trước Vương Bình","text":"Thanh Nghi vừa hình thành nguyên thần không lâu nên bị thần thức Lôi Đạo Tử làm sắc mặt tái nhợt và phun máu; dù vậy nàng vẫn cưỡng ép vận linh lực, bước lên chắn trước Vương Bình, sau đó nắm tay hắn khi lôi quang lan tới.","anchor":"vẫn tiến lên được một bước, đứng chắn trước mặt Vương Bình"},{"text":"Thanh Nghi đi cùng Vương Bình trong lúc Lôi Đạo Tử ra tay; khi Vương Lâm chuyển chiến trường, nàng được ánh sáng dịu dàng bảo hộ và đưa khỏi thôn tới bình nguyên phía tây Nhiễm Vân tinh.","anchor":"Hắn vung tay phải lên, một đạo ánh sáng dịu dàng bao vây lấy Vương Bình và Thanh Nghi","bridge":true,"khoang":"@c0656"},{"text":"Thanh Nghi ở bên cạnh Vương Bình khi thân hình hắn dao động từ linh hồn, nắm tay hắn và dùng lời dịu dàng khẳng định dù hắn thế nào nàng cũng sẽ không rời.","anchor":"Không sao cả, bất luận chàng như thế nào, ta điều ở bên cạnh chàng.","bridge":true,"khoang":"@c0657"},{"chuong":"@c0659","importance":"major","tieuDe":"Theo Vương Bình","text":"Thanh Nghi chứng kiến Vương Bình tan đi, quỳ xin Vương Lâm dẫn mình theo; nàng khẳng định không hối hận dù phải hóa thành hồn phách, chỉ muốn tiếp tục làm bạn với Vương Bình dưới hoàng tuyền.","anchor":"Vương Lâm đi rồi, còn mang theo một linh hồn không hối hận của Thanh Nghi"},{"text":"Vương Lâm dùng thần thức dò Thiên Nghịch Châu và xác nhận hồn phách Thanh Nghi vẫn còn bên trong sau khi cánh cửa và cánh tay biến mất.","anchor":"Thần thức Vương Lâm lập tức thâm nhập, nguyên anh Lý Mộ Uyển, Vương Bình cùng với hồn phách Thanh Nghi vẫn còn bên trong","bridge":true,"khoang":"@c0677"}],"tuViMoc":[{"chuong":"@c0654","canhGioi":"Nguyên Anh hậu kỳ đại viên mãn","text":"Thanh Nghi được nhắc là đã từng được Vương Lâm nâng tu vi tới Nguyên Anh hậu kỳ đại viên mãn.","importance":"minor"},{"chuong":"@c0654","canhGioi":"Ý cảnh tình yêu không hối hận","text":"Thanh Nghi ở bên Vương Bình hai mươi năm trước mà cảm ngộ thiên đạo, đạt ý cảnh gắn với tình yêu không hối hận; đây là mốc ý cảnh, không phải tu vi chính.","importance":"major"}],"nhanMach":[{"ten":"Vương Bình","tag":"ban-be","quanHe":"quen biết qua biến cố tửu lâu","ghiChu":"Hai người trò chuyện thân thiện, Thanh Nghi đỏ mặt và có thiện cảm với Vương Bình."},{"ten":"Lão nhân Kết Đan","tag":"su-mon","quanHe":"sư đồ","ghiChu":"Thanh Nghi là đệ tử của lão nhân Kết Đan."},{"ten":"Lão nhân mặt đỏ","tag":"doi-thu","quanHe":"người thẩm vấn","ghiChu":"Bị lão nhân mặt đỏ nhìn ra đang nói dối khi che giấu thân phận Vương Lâm."},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Người giải thế bị khống chế và mở đường tu đạo cho nàng.","ghiChu":"Vương Lâm hứa đưa Thanh Nghi tới đạo hạnh Nguyên Anh nếu nàng theo giúp Vương Bình."},{"ten":"Vương Bình","tag":"dong-hanh","quanHe":"Người nàng đi theo sau khi rời Kỳ Thủy Thành.","ghiChu":"Nàng được sắp xếp đồng hành và giúp Vương Bình vài năm."},{"ten":"Vân Vô Phong","tag":"khac","quanHe":"Người muốn giữ nàng bên cạnh.","ghiChu":"Nàng bị đưa tới phòng Vân Vô Phong khi tu vi bị phong tỏa."},{"ten":"Vương Bình","tag":"the-thiep","quanHe":"người gắn bó lâu năm","ghiChu":"Ở bên chăm sóc Vương Bình và cùng hắn đối diện những năm tháng quyền lực phàm nhân."},{"ten":"Vương Lâm","tag":"khac","quanHe":"gọi như phụ thân","ghiChu":"Qua lời Vương Bình, nàng xem Vương Lâm như phụ thân chung."},{"ten":"Lôi Đạo Tử","tag":"doi-thu","quanHe":"Bị uy áp thần thức và lôi quang của Lôi Đạo Tử đe dọa khi bảo vệ Vương Bình.","ghiChu":"Nàng phun máu nhưng vẫn chắn trước Vương Bình."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0649","@c0650","@c0651","@c0652","@c0653","@c0654","@c0655","@c0656","@c0657","@c0659","@c0677"]},{"id":"lao-nhan-ket-dan","name":"Lão nhân Kết Đan","cn":"","aliases":["sư tôn Thanh Nghi","Sư tôn của Thanh Nghi"],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Trúc Cơ hậu kỳ @c0650","trangThai":"song","blurb":"Lão nhân Kết Đan là sư tôn của Thanh Nghi và thuộc nhánh Tôn gia ở Kỳ Thủy thành. Ông bị Vương Lâm làm đan khí tán loạn, phải cầu cứu tộc thúc khi Tôn sư tổ tới.","vaiTro":"tu sĩ Tôn gia bị áp chế","tinhCach":[{"text":"dựa vào thế lực Tôn gia khi gặp nguy","chuong":"@c0649"},{"text":"khiếp sợ trước uy áp của Vương Lâm","chuong":"@c0649"}],"tabs":{"diem":[{"text":"Bị Vương Lâm khiến đan khí tán loạn, phải dùng dược hoàn cố ổn định tu vi.","chuong":"@c0649"},{"text":"Cầu cứu tộc thúc Tôn gia và được tạm khóa đan khí bằng linh quyết.","chuong":"@c0649"}],"kinhLich":[{"text":"Trong tửu lâu, lão nhân Kết Đan bị Vương Lâm áp chế đến đan khí tán loạn, phải nuốt dược hoàn rồi cầu cứu tộc thúc; Tôn sư tổ dùng linh quyết tạo lưới tạm khóa đan khí cho ông.","anchor":"hình thành một tấm lưới, gắt gao bao lấy bên ngoài đan khí","bridge":true,"khoang":"@c0649"}],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Trúc Cơ hậu kỳ","text":"Tu vi bị hạ xuống Trúc Cơ hậu kỳ sau vụ tửu lâu.","importance":"minor"}],"nhanMach":[{"ten":"Thanh Nghi","tag":"su-mon","quanHe":"sư đồ","ghiChu":"Ông là sư tôn của Thanh Nghi."},{"ten":"Tôn sư tổ","tag":"ho-hang","quanHe":"tộc thúc","ghiChu":"Ông cầu cứu Tôn sư tổ sau khi đan khí tán loạn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"bị áp chế","ghiChu":"Bị Vương Lâm làm đan khí tán loạn trong tửu lâu."}],"tuiDo":{"phapBao":[],"danDuoc":[{"ten":"Dược hoàn ổn định đan khí","loai":"đan dược","trangThai":"da-dung","moTa":"Dùng để cố ổn định đan khí đang tràn ra ngoài, hiệu quả không cao trong tình thế bị Vương Lâm áp chế.","nguon":"@c0649"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Ngọc giản đưa tin","loai":"vật phẩm truyền tin","trangThai":"da-dung","moTa":"Bị bóp nát để gọi viện binh Tôn gia tới tửu lâu.","nguon":"@c0649"}]}},"nguon":["@c0649","@c0650"]},{"id":"ton-su-to","name":"Tôn sư tổ","cn":"","aliases":["tộc thúc của lão nhân Kết Đan"],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh viên mãn, nửa bước Hóa Thần","trangThai":"song","blurb":"Tôn sư tổ là lão nhân Tôn gia dẫn người tới tửu lâu sau khi nhận tín hiệu cầu viện. Ông tạm cứu lão nhân Kết Đan, nhìn ra tư chất đặc biệt của Vương Bình nhưng bị uy thế một bước của Vương Lâm áp đảo.","vaiTro":"cao thủ Tôn gia Kỳ Thủy thành","tinhCach":[{"text":"thận trọng quan sát đối phương trước khi ra tay","chuong":"@c0649"},{"text":"có nhãn lực nhận ra thiên tư của Vương Bình","chuong":"@c0649"}],"tabs":{"diem":[{"text":"Nhận ra Vương Bình có thiên tư và tâm tính hiếm thấy dù là phàm thai tục cốt.","chuong":"@c0649"},{"text":"Dùng linh quyết tạm khóa đan khí cho lão nhân Kết Đan.","chuong":"@c0649"},{"text":"Bị một bước của Vương Lâm ép đến tái mặt và lùi lại.","chuong":"@c0649"}],"kinhLich":[{"text":"Tôn sư tổ dẫn hai lão nhân Tôn gia tới tửu lâu, đánh giá Vương Bình có thiên tư hiếm có, tạm khóa đan khí cho tộc nhân rồi ngăn đường phụ tử Vương Lâm; khi Vương Lâm tiến một bước, ông chấn động tâm thần và phải lui lại.","anchor":"bước này thoạt nhìn như đơn giản, nhưng lại như có tiếng sấm đánh ầm ầm","bridge":true,"khoang":"@c0649"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão nhân Kết Đan","tag":"ho-hang","quanHe":"tộc thúc","ghiChu":"Được lão nhân Kết Đan cầu cứu và ra tay tạm khóa đan khí cho ông."},{"ten":"Hai lão nhân đi cùng Tôn sư tổ","tag":"dong-minh","quanHe":"đồng hành trong Tôn gia","ghiChu":"Cùng tới tửu lâu để xử lý biến cố."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"bị uy thế áp đảo","ghiChu":"Ngăn đường Vương Lâm nhưng bị một bước ép lui."},{"ten":"Vương Bình","tag":"khac","quanHe":"người được chú ý","ghiChu":"Nhìn ra Vương Bình có thiên tư và tâm tính đặc biệt."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Linh quyết khóa đan khí","loai":"pháp thuật","trangThai":"dang-co","moTa":"Bấm quyết đánh vào mi tâm lão nhân Kết Đan, tạo thành tấm lưới tạm khóa đan khí tán loạn.","nguon":"@c0649"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0649"]},{"id":"hai-lao-nhan-di-cung-ton-su-to","name":"Hai lão nhân đi cùng Tôn sư tổ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh trung kỳ","trangThai":"song","blurb":"Hai lão nhân đi cùng Tôn sư tổ là tu sĩ Tôn gia tới tửu lâu Kỳ Thủy thành sau tín hiệu cầu viện. Họ cùng ngăn đường phụ tử Vương Lâm nhưng bị một bước của Vương Lâm làm biến sắc và lùi lại.","vaiTro":"tu sĩ Tôn gia đi cùng Tôn sư tổ","tinhCach":[{"text":"hành động theo Tôn sư tổ","chuong":"@c0649"},{"text":"khiếp sợ trước uy áp của Vương Lâm","chuong":"@c0649"}],"tabs":{"diem":[{"text":"Cùng Tôn sư tổ tới tửu lâu để xử lý biến cố của Tôn gia.","chuong":"@c0649"},{"text":"Bị khí thế một bước của Vương Lâm ép lùi.","chuong":"@c0649"}],"kinhLich":[{"text":"Hai lão nhân theo Tôn sư tổ vào tửu lâu, cùng ngăn phụ tử Vương Lâm rời đi; khi Vương Lâm bước tới, cả hai chấn động tâm thần, biến sắc và lùi lại.","anchor":"bước này thoạt nhìn như đơn giản, nhưng lại như có tiếng sấm đánh ầm ầm","bridge":true,"khoang":"@c0649"}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn sư tổ","tag":"dong-minh","quanHe":"đồng hành trong Tôn gia","ghiChu":"Cùng Tôn sư tổ tới tửu lâu."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"bị uy thế áp đảo","ghiChu":"Ngăn đường Vương Lâm nhưng bị một bước ép lui."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0649"]},{"id":"lao-nhan-mat-do","name":"Lão nhân mặt đỏ","aliases":["lão nhân mặc đỏ"],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"},{"ten":"Chi nhánh Tôn gia Kỳ Thủy thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần @c0651","trangThai":"song","blurb":"Một trong ba trưởng lão Hóa Thần của chi nhánh Tôn gia tại Kỳ Thủy thành. Ông thẩm vấn người liên quan vụ tửu lâu, nhìn ra Thanh Nghi nói dối và tuyên bố đã báo về dòng họ.","vaiTro":"Trưởng lão Tôn gia tại Kỳ Thủy","tinhCach":[{"text":"Già dặn, dễ nhận ra lời nói dối","chuong":"@c0650"},{"text":"Cứng rắn trong việc giữ uy thế Tôn gia","chuong":"@c0650"}],"tabs":{"diem":[{"text":"Là một trong ba trưởng lão Hóa Thần chủ trì việc truy xét biến cố tửu lâu.","chuong":"@c0650"},{"text":"Nhìn ra Thanh Nghi đang nói dối nhưng vẫn tiếp tục xử lý vụ việc theo hướng báo về dòng họ.","chuong":"@c0650"},{"text":"Nhìn ra Thanh Nghi nói dối nhưng trọng tâm của ông là báo về dòng họ và chờ tu sĩ Anh Biến tới.","chuong":"@c0650"}],"kinhLich":[{"chuong":"@c0650","importance":"normal","tieuDe":"Điều Anh Biến tới","text":"Trong đại điện chi nhánh Tôn gia, lão nhân mặt đỏ thẩm vấn người liên quan vụ tửu lâu, nhận ra Thanh Nghi nói dối và tuyên bố đã bẩm báo gia tộc để tu sĩ Anh Biến tới Kỳ Thủy thành trong thời gian ngắn nhất.","anchor":"sẽ có tu sĩ Anh Biến kì của gia tộc tới trong thời gian ngắn nhất"},{"text":"Lão nhân mặt đỏ chế giễu người hầu Vương phủ rồi bước vào, lập tức bị lực lượng vô hình từ trong phủ chấn thương, nguyên thần gần như sụp đổ. Sự việc khiến Tôn Khải Tinh nhận ra khí tức Vấn Đỉnh và vội đưa Tôn gia rời đi.","anchor":"cảm thấy một lực lượng vô hình truyền từ trong phủ ra","bridge":true,"khoang":"@c0651"}],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Hóa Thần","text":"Được nêu là trưởng lão Hóa Thần của chi nhánh Tôn gia tại Kỳ Thủy thành.","importance":"major"}],"nhanMach":[{"ten":"Thanh Nghi","tag":"doi-thu","quanHe":"người bị thẩm vấn","ghiChu":"Nhìn ra Thanh Nghi nói dối khi che giấu thân phận Vương Lâm."},{"ten":"Tôn Khải Minh","tag":"cap-tren","quanHe":"phó gia chủ được nghênh đón","ghiChu":"Thuộc chi nhánh Tôn gia đón Tôn Khải Minh đến xử lý vụ việc."},{"ten":"Tôn Khải Tinh","tag":"dong-minh","quanHe":"Cùng thuộc đoàn Tôn gia tới Vương phủ.","ghiChu":"Việc ông bị chấn thương khiến Tôn Khải Tinh nhận ra trong phủ có cường giả không thể đắc tội."},{"ten":"Trưởng lão áo xanh","tag":"dong-minh","quanHe":"Đồng trưởng lão chi nhánh Tôn gia.","ghiChu":"Cùng tham gia xét đoán vụ tửu lâu tại Kỳ Thủy thành."},{"ten":"Trưởng lão Tôn gia thứ ba","tag":"dong-minh","quanHe":"Đồng trưởng lão chi nhánh Tôn gia.","ghiChu":"Cùng ngồi trong đại điện xử lý vụ tộc nhân bị uy hiếp."},{"ten":"Tu sĩ Nguyên Anh hậu kỳ Tôn gia","tag":"cap-tren","quanHe":"Trưởng lão nghe người này báo cáo.","ghiChu":"Tu sĩ Nguyên Anh hậu kỳ thuật lại câu nói của Vương Lâm cho ba trưởng lão."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0650","@c0651"]},{"id":"truong-lao-ao-xanh","name":"Trưởng lão áo xanh","gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"},{"ten":"Chi nhánh Tôn gia Kỳ Thủy thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần @c0650","trangThai":"song","blurb":"Một trưởng lão Hóa Thần của chi nhánh Tôn gia tại Kỳ Thủy thành. Ông đánh giá người gây chuyện ở tửu lâu có tu vi rất cao, thậm chí có thể đạt Anh Biến kỳ.","vaiTro":"Trưởng lão Tôn gia tại Kỳ Thủy","tinhCach":[{"text":"Lạnh lùng khi phân tích kẻ khiêu khích Tôn gia","chuong":"@c0650"},{"text":"Thận trọng trước thủ đoạn vượt xa tu sĩ thường","chuong":"@c0650"}],"tabs":{"diem":[{"text":"Tổng hợp các biểu hiện như liếc mắt làm vỡ đan và một bước ép lui Nguyên Anh để phán đoán tu vi đối phương.","chuong":"@c0650"},{"text":"Cho rằng người kia có thể đã đạt tới Anh Biến kỳ.","chuong":"@c0650"},{"text":"Tổng hợp các dấu hiệu trong vụ tửu lâu để nhận định đối phương có thể là tu sĩ Anh Biến kỳ.","chuong":"@c0650"}],"kinhLich":[{"chuong":"@c0650","importance":"normal","tieuDe":"Phán đoán Anh Biến","text":"Tại chi nhánh Tôn gia Kỳ Thủy thành, trưởng lão áo xanh cho rằng người kia khiêu khích Tôn gia và dựa vào các thủ đoạn không thấy thần thông rõ ràng để phán đoán tu vi đối phương có thể đạt Anh Biến kỳ.","anchor":"tu vi này, chỉ sợ đã đạt tới Anh Biến kì"},{"text":"Trưởng lão áo xanh oán trách người trong Vương phủ cuồng vọng, nhưng bị gia chủ Tôn gia quát im miệng và phê bình vì không biết tốt xấu. Sau khi Tôn gia rút về, ông hỏi thân phận người trong phủ và nhớ tới nhân vật Hứa Mộc khi được gợi ý.","anchor":"người này đã hạ thủ lưu tình, các ngươi còn không biết tốt xấu","bridge":true,"khoang":"@c0651"}],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Hóa Thần","text":"Được nêu là trưởng lão Hóa Thần của chi nhánh Tôn gia.","importance":"major"}],"nhanMach":[{"ten":"Lão nhân mặt đỏ","tag":"dong-minh","quanHe":"đồng trưởng lão","ghiChu":"Cùng tham gia xử lý vụ tửu lâu tại chi nhánh Tôn gia."},{"ten":"Trưởng lão Tôn gia thứ ba","tag":"dong-minh","quanHe":"Đồng trưởng lão chi nhánh Tôn gia.","ghiChu":"Cùng tham gia cuộc bàn định trong đại điện chi nhánh."},{"ten":"Tu sĩ Nguyên Anh hậu kỳ Tôn gia","tag":"cap-tren","quanHe":"Trưởng lão nghe người này báo cáo.","ghiChu":"Nhận thông tin về câu nói và thủ đoạn của Vương Lâm qua báo cáo của tu sĩ Nguyên Anh hậu kỳ."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0650","@c0651"]},{"id":"truong-lao-ton-gia-thu-ba","name":"Trưởng lão Tôn gia thứ ba","gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"},{"ten":"Chi nhánh Tôn gia Kỳ Thủy thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần @c0650","trangThai":"song","blurb":"Một trong ba trưởng lão Hóa Thần tại chi nhánh Tôn gia Kỳ Thủy thành. Ông dựa vào lão tổ Tôn gia và vị tiền bối che chở trăm năm để trấn an rằng Tôn gia không thể sụp đổ.","vaiTro":"Trưởng lão Tôn gia tại Kỳ Thủy","tinhCach":[{"text":"Tin tưởng vào chỗ dựa của Tôn gia","chuong":"@c0650"},{"text":"Bình thản trước nguy cơ từ vụ tửu lâu","chuong":"@c0650"}],"tabs":{"diem":[{"text":"Nhắc tới lão tổ Tôn gia và vị tiền bối che chở trăm năm như nền tảng khiến Tôn gia không dễ sụp đổ.","chuong":"@c0650"},{"text":"Cùng hai trưởng lão còn lại xử lý vụ người lạ uy hiếp Tôn gia.","chuong":"@c0650"},{"text":"Đại diện cho thái độ tự tin của Tôn gia sau nhiều năm độc tôn ở Nhiễm Vân tinh.","chuong":"@c0650"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Hóa Thần","text":"Được nêu là một trong ba trưởng lão Hóa Thần của chi nhánh Tôn gia.","importance":"major"}],"nhanMach":[{"ten":"Lão nhân mặt đỏ","tag":"dong-minh","quanHe":"đồng trưởng lão","ghiChu":"Cùng chủ trì việc thẩm vấn và xử lý vụ tửu lâu."},{"ten":"Trưởng lão áo xanh","tag":"dong-minh","quanHe":"Đồng trưởng lão chi nhánh Tôn gia.","ghiChu":"Cùng bàn định về tu vi và ý đồ của người uy hiếp Tôn gia."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0650"]},{"id":"tu-si-nguyen-anh-hau-ky-ton-gia","name":"Tu sĩ Nguyên Anh hậu kỳ Tôn gia","gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"},{"ten":"Chi nhánh Tôn gia Kỳ Thủy thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ @c0650","trangThai":"song","blurb":"Tu sĩ Tôn gia từng ngăn cản Vương Lâm tại tửu lâu. Sau đó hắn báo lại câu nói của Vương Lâm cho ba trưởng lão nhưng không biết họ tên của đối phương.","vaiTro":"Tu sĩ Tôn gia dự vụ tửu lâu","tinhCach":[{"text":"Tuân lệnh trưởng lão trong việc báo cáo sự việc","chuong":"@c0650"},{"text":"Bị chấn nhiếp trước người lạ có tu vi khó lường","chuong":"@c0650"}],"tabs":{"diem":[{"text":"Là người thuật lại câu nói cảnh cáo của Vương Lâm trước ba trưởng lão Tôn gia.","chuong":"@c0650"},{"text":"Không biết họ tên của người đã uy hiếp Tôn gia tại tửu lâu.","chuong":"@c0650"}],"kinhLich":[{"chuong":"@c0650","importance":"normal","tieuDe":"Báo câu cảnh cáo","text":"Sau vụ tửu lâu, tu sĩ Nguyên Anh hậu kỳ Tôn gia báo lại với ba trưởng lão rằng người kia từng nói chỉ có lần này; hắn không biết họ của Vương Lâm.","anchor":"người này quả thật đã nói: Chỉ lần này thôi, chỉ một lần thôi"}],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Nguyên Anh hậu kỳ","text":"Được nêu là tu sĩ Nguyên Anh hậu kỳ của chi nhánh Tôn gia.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"người từng ngăn cản","ghiChu":"Từng ngăn Vương Lâm tại tửu lâu rồi báo lại lời cảnh cáo của hắn."},{"ten":"Lão nhân mặt đỏ","tag":"cap-tren","quanHe":"Trưởng lão tiếp nhận báo cáo.","ghiChu":"Ông cùng hai trưởng lão khác nghe tu sĩ này thuật lại câu nói của Vương Lâm."},{"ten":"Trưởng lão áo xanh","tag":"cap-tren","quanHe":"Trưởng lão tiếp nhận báo cáo.","ghiChu":"Dựa trên báo cáo của tu sĩ này, trưởng lão áo xanh phán đoán người kia có thể là Anh Biến kỳ."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0650"]},{"id":"ton-khai-minh-621","name":"Tôn Khải Minh","nguon":["@c0650","@c0651"],"canhGioiCaoNhat":"Anh Biến hậu kỳ @c0650","trangThai":"song","tabs":{"kinhLich":[{"chuong":"@c0650","importance":"normal","tieuDe":"Đến Kỳ Thủy thành","text":"Ba ngày sau vụ tửu lâu, Tôn Khải Minh mặc hắc y tiến vào Kỳ Thủy thành, được toàn bộ chi nhánh Tôn gia nghênh đón; với thân phận phó gia chủ và tu vi Anh Biến hậu kỳ, hắn lập tức hỏi người kia ở đâu và cân nhắc khả năng đối phương là Vấn Đỉnh lão quái.","anchor":"Người này, là Tôn Khải Minh, năm đó bởi vì việc của Vương Lâm"},{"text":"Khi dẫn người Tôn gia tới nơi ở của phụ tử Vương Lâm, Tôn Khải Minh quát trưởng lão áo xanh câm miệng, cho rằng đối phương đã hạ thủ lưu tình mà tộc nhân còn không biết tốt xấu. Ông cảnh cáo sự ngạo mạn của Tôn gia có thể dẫn đại địch tới cho gia tộc.","anchor":"người này đã hạ thủ lưu tình, các ngươi còn không biết tốt xấu","bridge":true,"khoang":"@c0651"}],"tuViMoc":[{"chuong":"@c0650","canhGioi":"Anh Biến hậu kỳ","text":"Được nêu rõ có tu vi Anh Biến hậu kỳ khi đến Kỳ Thủy thành xử lý sự việc.","importance":"minor"}],"nhanMach":[{"ten":"Lão nhân mặt đỏ","tag":"cap-tren","quanHe":"phó gia chủ","ghiChu":"Được chi nhánh Tôn gia tại Kỳ Thủy thành nghênh đón để xử lý vụ việc."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người từng liên quan tới công lao lớn của hắn.","ghiChu":"Chương nhắc Tôn Khải Minh năm đó lập công lớn vì việc của Vương Lâm; hiện hắn đến Kỳ Thủy thành truy xét vụ việc nhưng chưa biết đối phương chính là Vương Lâm."},{"ten":"Tôn Tích","tag":"cap-tren","quanHe":"Người từng đề bạt hắn làm đại gia chủ tiếp theo.","ghiChu":"Tôn Tích được nhắc là nguyên do giúp Tôn gia hưng thịnh và từng đề bạt Tôn Khải Minh."}]},"vaiTro":"Phó gia chủ Tôn gia, được chi nhánh Kỳ Thủy thành nghênh đón khi tới truy xét vụ người uy hiếp Tôn gia ở tửu lâu.","tinhCach":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}]},{"id":"ton-khai-tinh","name":"Tôn Khải Tinh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Gia chủ hoặc nhân vật cầm đầu đoàn Tôn gia khi tới Vương phủ ở Kỳ Thủy Thành. Ông nhận ra khí tức Vấn Đỉnh trong phủ và lập tức thay đổi thái độ, nghiêm cấm tộc nhân đến gần nơi ở của vị tiền bối.","vaiTro":"Người cầm đầu Tôn gia tại Kỳ Thủy Thành","tinhCach":[{"text":"Biết tiến lui khi nhận ra cường giả không thể trêu chọc","chuong":"@c0651"},{"text":"Nghiêm khắc với tộc nhân để tránh tai họa cho gia tộc","chuong":"@c0651"}],"tabs":{"diem":[{"text":"Cảm nhận khí tức Vấn Đỉnh sau khi lão nhân mặt đỏ bị chấn thương và lập tức cung kính xin rời.","chuong":"@c0651"},{"text":"Ra lệnh toàn tộc không được bước vào phạm vi một ngàn trượng quanh nơi ở của tiền bối.","chuong":"@c0651"}],"kinhLich":[{"text":"Tôn Khải Tinh đưa người Tôn gia tới ngoài Vương phủ bái kiến, nhưng sau khi lão nhân mặt đỏ bị lực lượng vô hình trong phủ chấn thương, ông nhận ra khí tức Vấn Đỉnh và vội rút lui. Trở về đại điện chi nhánh Tôn gia, ông ra lệnh ai bước vào phạm vi một ngàn trượng quanh nơi ở của tiền bối sẽ bị phế tu vi và trục xuất khỏi gia môn.","anchor":"không được bước vào phạm vi một ngàn trượng nơi ở của tiền bối kia","bridge":true,"khoang":"@c0651"},{"importance":"normal","chuong":"@c0654","tieuDe":"Nhận định nguy cơ","text":"Tôn Khải Tinh đứng đầu nhóm tám tu sĩ Anh Biến hậu kỳ của Tôn gia phía sau Tôn Tích khi lôi uy giáng lâm; hắn nhận định người đến không có thiện ý.","anchor":"Lão tổ, xem ra người này không có ý tốt"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Cường giả khiến ông phải kính sợ và tránh xa.","ghiChu":"Ông nhận ra người trong Vương phủ có địa vị khiến lão tổ Tôn gia cũng phải tôn kính."},{"ten":"Lão nhân mặt đỏ","tag":"dong-minh","quanHe":"Tộc nhân đi cùng trong đoàn tới Vương phủ.","ghiChu":"Lão nhân mặt đỏ xông vào phủ và bị trọng thương, khiến Tôn Khải Tinh nhận ra nguy hiểm."},{"ten":"Lôi Đạo Tử","tag":"khac","quanHe":"người bị hắn cảnh giác","ghiChu":"Tôn Khải Tinh nhận định Lôi Đạo Tử giáng lâm không có ý tốt.","gap":"@c0654"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0651","@c0654"]},{"id":"van-vo-phong","name":"Vân Vô Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không thể tu đạo do tư chất kém @c0651","trangThai":"song","blurb":"Tộc nhân ngoại tộc Vân gia trên Vân Hải tinh, từng xung đột với Vương Bình ở tửu lâu. Hắn không thể tu đạo vì tư chất kém nhưng dựa vào thân phận Vân gia để được các gia tộc tu chân ở Nhiễm Vân tinh nể mặt.","vaiTro":"Tộc nhân Vân gia đụng độ Vương Bình","tinhCach":[{"text":"Ỷ vào thân phận Vân gia dù bản thân không có tu vi","chuong":"@c0651"},{"text":"Hoảng sợ khi biết đã trêu vào Hứa Mộc","chuong":"@c0651"},{"text":"Đổ lỗi cho Thanh Nghi khi bản thân gặp nguy","chuong":"@c0651"}],"tabs":{"diem":[{"text":"Là tộc nhân Vân gia trên Vân Hải tinh, một đại gia tộc khiến các gia tộc tu chân ở Nhiễm Vân tinh phải nể mặt.","chuong":"@c0651"},{"text":"Ở lại Nhiễm Vân tinh vì nhìn thấy Thanh Nghi khi thương đội tới đây.","chuong":"@c0651"},{"text":"Nhớ lời trưởng lão thương đội cảnh báo không được trêu chọc Hứa Mộc, người từng quét sạch Huyễn gia.","chuong":"@c0651"}],"kinhLich":[{"chuong":"@c0651","importance":"normal","tieuDe":"Đụng phải Hứa Mộc","text":"Vân Vô Phong được xác lập là tộc nhân Vân gia trên Vân Hải tinh, tư chất kém nên không thể tu đạo nhưng được nể vì thân phận gia tộc; hắn ở lại Nhiễm Vân tinh vì Thanh Nghi. Khi biết người mình trêu chọc là Hứa Mộc, hắn hoảng sợ, rồi trong phòng nơi Thanh Nghi bị phong tu vi, hắn bị Vương Lâm xuất hiện từ bóng đêm đánh ngã.","anchor":"Thanh niên áo tím này tên là Vân Vô Phong, là tộc nhân Vân gia trên Vân Hải tinh"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Cường giả đánh ngã hắn sau khi hắn trêu chọc Vương Bình và Thanh Nghi.","ghiChu":"Vân Vô Phong từng được cảnh báo tuyệt đối không trêu chọc Hứa Mộc."},{"ten":"Thanh Nghi","tag":"khac","quanHe":"Người khiến hắn ở lại Nhiễm Vân tinh.","ghiChu":"Thanh Nghi bị đưa tới phòng hắn trong tình trạng tu vi bị phong tỏa."},{"ten":"Vương Bình","tag":"doi-thu","quanHe":"Người từng xung đột với hắn ở tửu lâu.","ghiChu":"Vân Vô Phong về sau biết Vương Bình là nhi tử của Hứa Mộc."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0651"]},{"id":"truong-nhi","name":"Trương Nhị","gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Hành phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân hoặc không rõ","trangThai":"khong-ro","blurb":"Trương Nhị là người được khách tửu quán ở Kỳ Thủy thành nhắc tới như một giáo chúng Thiên Hành phái. Việc người này hằng tháng được phát lương thực cho thấy Thiên Hành phái đã cắm rễ trong dân gian.","vaiTro":"giáo chúng dân gian","tinhCach":[{"text":"không rõ tính cách riêng","chuong":"@c0652"}],"tabs":{"diem":[{"text":"Được nhắc như ví dụ về dân chúng Kỳ Thủy thành gia nhập Thiên Hành phái.","chuong":"@c0652"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0652"]},{"id":"tieu-nhi-moi","name":"Tiểu nhị mới","gioiTinh":"nam","theLuc":[{"ten":"Tửu quán Kỳ Thủy thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Tiểu nhị mới của tửu quán Kỳ Thủy thành đã quen mặt Vương Lâm khi ông thường xuyên tới uống rượu. Hắn khuyên Vương Lâm uống ít vì tuổi cao và thương cảm vì tưởng ông không có con cái kề bên.","vaiTro":"tiểu nhị tửu quán","tinhCach":[{"text":"biết quan tâm khách quen","chuong":"@c0652"},{"text":"nhìn Vương Lâm bằng sự thương cảm phàm nhân","chuong":"@c0652"}],"tabs":{"diem":[{"text":"Quen mặt Vương Lâm vì ông thường tới tửu quán uống rượu.","chuong":"@c0652"},{"text":"Khuyên Vương Lâm uống ít hơn do thấy ông tuổi đã cao.","chuong":"@c0652"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0652","canhGioi":"Phàm nhân","text":"Xuất hiện như tiểu nhị mới của tửu quán Kỳ Thủy thành.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"khách quen","ghiChu":"Quen mặt và khuyên Vương Lâm uống ít rượu."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0652"]},{"id":"lao-boc-trong-phu-vuong-lam","name":"Lão bộc trong phủ Vương Lâm","gioiTinh":"nam","theLuc":[{"ten":"Vương phủ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Lão bộc trong Vương phủ theo Vương Lâm lúc hoàng hôn để đưa ông về phủ. Sự xuất hiện của ông cho thấy đời sống phàm nhân quanh Vương Lâm tại Kỳ Thủy thành đã thành nếp lâu dài.","vaiTro":"lão bộc Vương phủ","tinhCach":[{"text":"cẩn thận chăm nom chủ nhân già yếu","chuong":"@c0652"},{"text":"âm thầm làm tròn bổn phận trong phủ","chuong":"@c0652"}],"tabs":{"diem":[{"text":"Theo Vương Lâm sau buổi uống rượu để đưa ông về phủ.","chuong":"@c0652"},{"text":"Lo cho tuổi già của Vương Lâm trong mắt người phàm.","chuong":"@c0652"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0652","canhGioi":"Phàm nhân","text":"Xuất hiện trong Vương phủ tại Kỳ Thủy thành với thân phận lão bộc.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"chủ nhân","ghiChu":"Theo hầu và đưa Vương Lâm trở về phủ khi hoàng hôn."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0652"]},{"id":"hua-niem-binh","name":"Hứa Niệm Bình","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"thôn Lạc Nguyệt","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân @c0653","trangThai":"song","blurb":"Hứa Niệm Bình là con gái của Chu Nhược Đồng ở thôn Lạc Nguyệt. Cái tên của cô bé khiến Vương Bình chấn động khi nghe thấy trong lần trở về quê cũ.","vaiTro":"Con gái Chu Nhược Đồng","tinhCach":[{"text":"rụt rè trước người lạ","chuong":"@c0653"},{"text":"hồn nhiên nói rõ tên mình","chuong":"@c0653"}],"tabs":{"diem":[{"text":"Xuất hiện bên cạnh Chu Nhược Đồng khi Vương Bình trở lại thôn Lạc Nguyệt.","chuong":"@c0653"},{"text":"Tự nói tên mình là Hứa Niệm Bình, làm Vương Bình xúc động vì tên gọi ấy.","chuong":"@c0653"}],"kinhLich":[{"text":"Hứa Niệm Bình được Chu Nhược Đồng bảo gọi Vương Bình là thúc thúc. Ban đầu cô bé sợ người lạ, sau đó tự nói tên mình, khiến Vương Bình dừng lại và thầm chấn động.","anchor":"Thúc thúc, ta tên là Hứa Niệm Bình","bridge":true,"khoang":"@c0653"}],"tuViMoc":[{"chuong":"@c0653","canhGioi":"Phàm nhân","text":"Hứa Niệm Bình xuất hiện như một cô bé hơn mười tuổi ở thôn Lạc Nguyệt.","importance":"minor"}],"nhanMach":[{"ten":"Chu Nhược Đồng","tag":"cha-me","quanHe":"mẹ con","ghiChu":"Chu Nhược Đồng là mẫu thân của Hứa Niệm Bình."},{"ten":"Vương Bình","tag":"khac","quanHe":"cố nhân của mẫu thân","ghiChu":"Hứa Niệm Bình gặp Vương Bình khi hắn trở lại thôn Lạc Nguyệt."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0653"]},{"id":"loi-dao-tu","name":"Lôi Đạo Tử","cn":"","aliases":["sứ giả Lôi Tiên Điện"],"gioiTinh":"nam","theLuc":[{"ten":"Lôi Tiên Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Âm Hư @c0662","trangThai":"tu-vong","blurb":"Lôi Đạo Tử là trung niên văn sĩ tu vi Âm Hư, tự xưng sứ giả Lôi Tiên Điện chân chính. Hắn cưỡi Lôi Thú tới Nhiễm Vân tinh để điều tra kẻ bị nghi giả mạo sứ giả Lôi Tiên Điện.","vaiTro":"Sứ giả Lôi Tiên Điện điều tra Nhiễm Vân tinh","tinhCach":[{"text":"Tự tin vào thân phận và uy thế Lôi Tiên Điện","chuong":"@c0654"},{"text":"Hành động quyết liệt, trực tiếp giáng lâm bằng lôi uy","chuong":"@c0654"}],"tabs":{"diem":[{"text":"Tu vi đã siêu thoát đệ nhất bộ, đạt Âm Hư.","chuong":"@c0654"},{"text":"Cưỡi Lôi Thú, coi đây là dấu hiệu của sứ giả Lôi Tiên Điện chân chính.","chuong":"@c0654"},{"text":"Được phái tới truy xét biến cố Thiên Huyễn Tinh và nghi án giả mạo sứ giả Lôi Tiên Điện.","chuong":"@c0654"}],"kinhLich":[{"importance":"normal","chuong":"@c0654","tieuDe":"Sứ giả chân chính","text":"Lôi Đạo Tử cưỡi Lôi Thú từ tinh không tiến vào La Thiên Bắc Vực, hướng tới Nhiễm Vân tinh; với tu vi Âm Hư và thân phận sứ giả Lôi Tiên Điện chân chính, hắn tới điều tra kẻ bị nghi giả mạo sứ giả Lôi Tiên Điện sau biến cố Thiên Huyễn Tinh bảy mươi năm trước, rồi giáng lôi uy kinh động toàn bộ tu sĩ Nhiễm Vân tinh.","anchor":"Có thể khiến cho ta Lôi Đạo Tử, chân chính sứ giả Lôi Tiền Điện tới tìm"},{"text":"Lôi Đạo Tử cưỡi lôi thú đến Nhiễm Vân tinh, thả thần thức mang lôi uy bao trùm toàn tinh khiến tu sĩ chấn động, yêu vật run rẩy và phàm nhân hôn mê; sau khi định rời đi, hắn phát hiện Vương Bình không hôn mê, vào tận phòng, nhìn ra Vương Bình bất thường, giao thủ với tiên vệ khôi lỗi rồi dùng lôi quang phá tan căn phòng.","anchor":"thần thức không chút cố kỵ, quét ngang hết thảy, trong nháy mắt bao trùm toàn bộ Nhiễm Vân tinh","bridge":true,"khoang":"@c0655"},{"text":"Lôi Đạo Tử tấn công Vương Bình bằng lôi quang rồi đuổi theo Vương Lâm tới bình nguyên phía tây Nhiễm Vân tinh; hắn đòi tiên vệ khôi lỗi, dùng lôi võng vây khốn khôi lỗi và lấy thiết côn khắc phù thu lôi, nhưng bị lôi lực của Vương Lâm áp đảo khiến pháp bảo sụp đổ; cuối chương hắn nhận ra đối phương là Hứa Mộc từng giả mạo sứ giả Lôi Tiên Điện và kinh nghi trước tu vi đang bộc lộ.","anchor":"Ngươi, ngươi chính là tên giả mạo Lôi Tiên điện sứ giả Hứa Mộc!","bridge":true,"khoang":"@c0656"},{"text":"Lôi Đạo Tử nghi Vương Lâm giả mạo sứ giả Lôi Tiên Điện, triệu lôi thú và thi triển Lôi tiên kiếp để áp chế đối thủ; sau khi bị Ngân Giác lôi thú làm chấn động và bị bảy phù văn lôi đánh lui, hắn nổi tham muốn đoạt lôi thú cùng khôi lỗi rồi tuyên bố sẽ dùng nguyên lực pháp thuật bước thứ hai.","anchor":"Đây là lần đầu tiên trong cuộc đời hắn, thua ở trên phương diện lôi điện thần thông.","bridge":true,"khoang":"@c0657"},{"text":"Lôi Đạo Tử dùng thần thông hai mắt soi Vương Bình, phát hiện đối phương là oán anh và trong thân có hai đạo kiếm khí đáng sợ nên lập tức bỏ ý định giao chiến trực diện; sau khi bị Trảm La quyết do Vương Lâm dùng nguyên thần phối hợp nguyên lực chém tới, hắn cảm nhận nguy cơ sinh tử và triển khai Nguyên lực lôi đỉnh để luyện hóa đối thủ.","anchor":"Thiên địa, hóa thành cự đỉnh! Thiên làm miệng đỉnh, địa làm thân đỉnh!","bridge":true,"khoang":"@c0658"},{"text":"Lôi Đạo Tử dùng đại đỉnh lôi hỏa áp chế Vương Lâm nhưng bị lôi thú mở phong ấn, Tiên vệ và Trảm La hợp kích phá cục; khi đại đỉnh sụp đổ, hắn trọng thương, phun máu và bỏ chạy trong sợ hãi.","anchor":"Giữa trời đất, bóng dáng Lôi Đạo Tử biến ảo mà hiện, hắn phun ra đầy máu tươi, quay đầu bỏ chạy","bridge":true,"khoang":"@c0659"},{"text":"Lôi Đạo Tử bị tiên vệ khôi lỗi, lôi thú và Vương Lâm vây ép đến nguyên lực gần cạn; hắn xin tha, chấp nhận để Vương Lâm lưu dấu vết nhưng thầm định phá cấm sau khi khôi phục, rồi bị đưa tới tinh cầu xám và bị Côn Cực Tiên rút nguyên thần khỏi thân thể để bắt đầu luyện thành tiên vệ.","anchor":"Trong lúc này, nguyên thần bị rút ra, thoát ly khỏi thân thể bảy xích.","bridge":true,"khoang":"@c0660"},{"chuong":"@c0661","importance":"normal","tieuDe":"Bị ép thành khôi lỗi","text":"Lôi Đạo Tử định phản kháng nhưng nguyên thần bị nhiều tầng thủ đoạn của Vương Lâm khóa chặt; hắn chứng kiến thân thể mình bị tế luyện thành khôi lỗi, kinh hãi khi hiểu ý đồ của Hứa Mộc, rồi bị ép cân nhắc điều kiện làm khôi lỗi ba ngàn năm để đổi tự do.","anchor":"Hứa Mộc này, là muốn luyện mình thành khôi lỗi"},{"chuong":"@c0662","importance":"major","tieuDe":"Dung Nhập Tiên Vệ","text":"Nguyên thần Lôi Đạo Tử mất thần trí và bị Vương Lâm dùng trong quá trình tế luyện tiên vệ thứ hai; sau khi nguyên thần tiêu tán, túi trữ vật của y mất lạc ấn thần thức, trở thành vật vô chủ để Vương Lâm kiểm kê.","anchor":"cái túi trữ vật này trở thành vô chủ, không còn lạc ấn thần thức nữa."},{"text":"Sau khi chết, túi trữ vật của Lôi Đạo Tử bị Vương Lâm kiểm kê; lượng tiên ngọc trong đó khiến Vương Lâm nhận ra một sứ giả Lôi Tiên Điện đã có tài nguyên vượt xa tu chân gia tộc bình thường.","anchor":"một lôi tiên điện sứ giả mà có nhiều tiên ngọc như vậy","bridge":true,"khoang":"@c0663"}],"tuViMoc":[{"chuong":"@c0654","canhGioi":"Âm Hư","text":"Lôi Đạo Tử xuất hiện với tu vi Âm Hư, đã vượt qua đệ nhất bộ.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"mục tiêu điều tra gián tiếp","ghiChu":"Hắn tới Nhiễm Vân tinh truy xét kẻ bị nghi giả mạo sứ giả Lôi Tiên Điện, nguy cơ hướng về Vương Lâm.","gap":"@c0654"},{"ten":"Tôn Tích","tag":"khac","quanHe":"kẻ bị khí tức kinh động","ghiChu":"Lôi uy khi hắn giáng lâm khiến Tôn Tích rời bế quan quan sát.","gap":"@c0654"},{"ten":"Tôn Khải Tinh","tag":"khac","quanHe":"kẻ nhận định nguy cơ","ghiChu":"Tôn Khải Tinh nhìn lôi uy giáng lâm và cho rằng người đến không có ý tốt.","gap":"@c0654"},{"ten":"Vương Bình","tag":"doi-thu","quanHe":"Nhắm vào vì phát hiện Vương Bình không giống phàm nhân.","ghiChu":"Lần đầu trực tiếp đối diện trong thôn nhỏ trên Nhiễm Vân tinh."},{"ten":"Thanh Nghi","tag":"doi-thu","quanHe":"Uy áp thần thức và lôi quang khiến Thanh Nghi bị thương khi nàng chắn trước Vương Bình.","ghiChu":"Thanh Nghi chống đỡ để bảo vệ Vương Bình."},{"ten":"Tiên vệ","tag":"doi-thu","quanHe":"Giao thủ trực diện với khôi lỗi bảo vệ Vương Bình.","ghiChu":"Lôi Đạo Tử nhận ra đây là cực phẩm khôi lỗi."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Thần thông lôi hệ","loai":"thần thông","trangThai":"dang-co","moTa":"Lôi Đạo Tử nhắc đến thần thông lôi hệ khi khẳng định không phải cứ thi triển được lôi pháp là có thể giả mạo người Lôi Tiên Điện.","nguon":"@c0654"}],"linhThu":[{"ten":"Xạ Thần xa","tenCu":"Lôi Thú","loai":"linh thú vật cưỡi","trangThai":"dang-co","moTa":"Mãnh thú khổng lồ giống kỳ lân nhưng không sừng, toàn thân lấp lóe lôi quang, được Lôi Đạo Tử cưỡi và coi là dấu hiệu của người Lôi Tiên Điện chân chính.","nguon":"@c0654"}],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0654","@c0655","@c0656","@c0657","@c0658","@c0659","@c0660","@c0661","@c0662","@c0663"]},{"id":"ly-mo-uyen","name":"Lý Mộ Uyển","aliases":["Uyển Nhi"],"gioiTinh":"nu","trangThai":"khong-ro","tabs":{"diem":[],"kinhLich":[{"text":"Nguyên anh Lý Mộ Uyển ở trong Thiên Nghịch; Vương Lâm đặt dải sáng hồn tức Vương Bình bên cạnh nàng và nói từ nay nàng là mẫu thân của Vương Bình.","anchor":"Vương Lâm nắm chặt dải sáng, đặt tại mi tâm, dung nhập trong thiên nghịch, đặt ở bên cạnh nguyên anh Lý Mộ Uyển","bridge":true,"khoang":"@c0659"},{"text":"Khi ký ức phong ấn của Chu Như được cởi bỏ, đoạn liên quan tới Uyển nhi hiện lên, khiến Chu Như hiểu thêm tâm ý của Vương Lâm và bật khóc.","anchor":"trong đầu nàng dường như một chút trí nhớ bị phong ấn chậm rãi cởi bỏ","bridge":true,"khoang":"@c0663"},{"text":"Vương Lâm dùng thần thức kiểm tra Thiên Nghịch Châu sau biến cố, xác nhận nguyên anh Lý Mộ Uyển vẫn ở bên trong và so với trước càng linh động, ngưng luyện hơn.","anchor":"Thần thức Vương Lâm lập tức thâm nhập, nguyên anh Lý Mộ Uyển, Vương Bình cùng với hồn phách Thanh Nghi vẫn còn bên trong","bridge":true,"khoang":"@c0677"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Bình","tag":"cha-me","quanHe":"mẫu thân được Vương Lâm nhận định","ghiChu":"Vương Lâm đặt hồn tức Vương Bình bên cạnh nguyên anh Lý Mộ Uyển trong Thiên Nghịch."},{"ten":"Chu Như","tag":"khac","quanHe":"người trong ký ức","ghiChu":"Xuất hiện trong ký ức được giải phong của Chu Như."},{"ten":"Vương Lâm","tag":"the-thiep","quanHe":"người trong ký ức cũ","ghiChu":"Được nhắc trong hồi tưởng của Liễu Mi về nhu tình của thiếu niên Vương Lâm năm xưa tại Hằng Nhạc Phái."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0659","@c0663","@c0643","@c0677"]},{"id":"tu-tam","name":"Tử Tâm","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Huyết Tổ thế lực","trangThai":"gan-bo"},{"ten":"Liên Minh Tinh Vực","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Không rõ @c0663","trangThai":"song","blurb":"Tử Tâm là thị thiếp của Huyết Tổ, hoạt động trong phạm vi Liên Minh Tinh Vực. Nàng từng được Huyết Tổ cứu khỏi Thiên Thủy Cung và trong chương này dẫn huyết nô điều tra một tinh cầu đang chết dần.","vaiTro":"Thị thiếp Huyết Tổ","tinhCach":"thận trọng trước cường giả; biết nhận lỗi để giữ mạng; quyết đoán khi lâm nguy","tabs":{"diem":[{"text":"Từng được Huyết Tổ cứu khỏi Thiên Thủy Cung và trở thành thị thiếp của hắn.","chuong":"@c0663"},{"text":"Dẫn hai huyết nô Vấn Đỉnh đi điều tra tinh cầu hoang dã trong phạm vi Huyết Tổ.","chuong":"@c0663"},{"text":"Bị uy áp trong lòng tinh cầu chấn nhiếp liền nhận lỗi, rút lui và tìm cách truyền tống về Huyết Tinh.","chuong":"@c0663"}],"kinhLich":[{"text":"Tử Tâm dẫn hai huyết nô tới điều tra một tiểu tinh cầu đang chết dần trong phạm vi Huyết Tổ; khi thần thức xâm nhập lòng tinh cầu, nàng bị tiếng quát uy nghiêm đẩy lui, phải nhận lỗi rút đi rồi dùng huyết nô tự bạo để tranh thủ kích hoạt ngọc giản huyết sắc truyền tống.","anchor":"Vãn bối không biết đây là nơi tiền bối tới bế quan","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyết Tổ","tag":"khac","quanHe":"chủ nhân và người cứu mạng","ghiChu":"Huyết Tổ từng cứu nàng khỏi Thiên Thủy Cung và biến nàng thành thị thiếp."},{"ten":"Hai huyết nô của Huyết Tổ","tag":"dong-minh","quanHe":"thuộc hạ hộ vệ","ghiChu":"Hai huyết nô đi theo nàng điều tra tinh cầu và tự bạo để mở đường thoát."},{"ten":"Vương Lâm","tag":"khac","quanHe":"bị bản tôn chấn nhiếp","ghiChu":"Nàng không biết trước thân phận người trong lòng tinh cầu, chỉ nhận ra đó là nơi một tiền bối bế quan."}],"tuiDo":{"phapBao":[{"ten":"Ngọc giản huyết sắc","trangThai":"da-dung","moTa":"Vật Huyết Tổ tặng, có thể truyền tống một lần về Huyết Tinh nhưng cần thời gian mở ra.","nguon":"@c0663"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"huyet-to","name":"Huyết Tổ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyết Tổ thế lực","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ @c0663","trangThai":"mat-tich","blurb":"Huyết Tổ là cường giả gắn với Huyết Tinh và một vùng thế lực trong Liên Minh Tinh Vực. Sau khi từ Yêu Linh Chi Địa trở về, tung tích của hắn không rõ nhưng ảnh hưởng vẫn thể hiện qua Tử Tâm, huyết nô và ngọc giản huyết sắc.","vaiTro":"Cường giả Huyết Tinh","tinhCach":"thế lực sâu; thủ đoạn luyện huyết nô; hành tung khó đoán","tabs":{"diem":[{"text":"Từng cứu Tử Tâm khỏi truy sát của Thiên Thủy Cung và biến nàng thành thị thiếp.","chuong":"@c0663"},{"text":"Có huyết nô Vấn Đỉnh và ngọc giản huyết sắc truyền tống về Huyết Tinh.","chuong":"@c0663"}],"kinhLich":[{"text":"Huyết Tổ được nhắc qua vùng thế lực nơi Tử Tâm điều tra tinh cầu chết dần, qua hai huyết nô Vấn Đỉnh và ngọc giản huyết sắc có thể truyền tống về Huyết Tinh; sau khi từ Yêu Linh Chi Địa trở về, hắn đã rời đi không rõ tung tích.","anchor":"giống như tinh cầu này sống ngắn ngủi bốn trăm năm rồi xong đời vậy","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[{"ten":"Tử Tâm","tag":"khac","quanHe":"thị thiếp","ghiChu":"Hắn từng cứu Tử Tâm khỏi Thiên Thủy Cung."},{"ten":"Diêu Tích Tuyết","tag":"cha-me","quanHe":"cha con","ghiChu":"Huyết Tổ là cha của Diêu Tích Tuyết."},{"ten":"Hai huyết nô của Huyết Tổ","tag":"khac","quanHe":"chủ nhân","ghiChu":"Hai lão nhân bị luyện hóa thành huyết nô phục vụ thế lực của hắn."}],"tuiDo":{"phapBao":[{"ten":"Ngọc giản huyết sắc","trangThai":"dang-co","moTa":"Vật từng được hắn ban cho Tử Tâm để truyền tống về Huyết Tinh khi nguy cấp.","nguon":"@c0663"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"hai-huyet-no-cua-huyet-to","name":"Hai huyết nô của Huyết Tổ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyết Tổ thế lực","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh @c0663","trangThai":"tu-vong","blurb":"Hai huyết nô là hai lão nhân bị Huyết Tổ luyện hóa, có tu vi Vấn Đỉnh và đi theo Tử Tâm. Họ tự bạo nguyên thần để ngăn sóng gợn khi tinh cầu hoang dã sụp đổ.","vaiTro":"Huyết nô hộ vệ Tử Tâm","tinhCach":"phục tùng mệnh lệnh; liều chết hộ chủ; ít tự chủ","tabs":{"diem":[{"text":"Có tu vi Vấn Đỉnh và đi theo Tử Tâm điều tra tinh cầu chết dần.","chuong":"@c0663"},{"text":"Tự bạo nguyên thần để chặn sóng gợn từ tinh cầu tan vỡ.","chuong":"@c0663"}],"kinhLich":[{"text":"Hai huyết nô đi theo Tử Tâm tới tinh cầu hoang dã đang chết dần; khi tinh cầu tan vỡ, họ tự bạo nguyên thần để ngăn sóng gợn, giúp Tử Tâm có thời gian kích hoạt ngọc giản huyết sắc truyền tống.","anchor":"Hắn, đúng là bản tôn của Vương Lâm","bridge":true,"khoang":"@c0663"}],"tuViMoc":[{"chuong":"@c0663","canhGioi":"Vấn Đỉnh","text":"Hai huyết nô được xác nhận có tu vi Vấn Đỉnh khi đi theo Tử Tâm điều tra tinh cầu thuộc phạm vi Huyết Tổ.","importance":"major"}],"nhanMach":[{"ten":"Tử Tâm","tag":"dong-minh","quanHe":"hộ vệ phục tùng","ghiChu":"Đi theo Tử Tâm và tự bạo để giúp nàng thoát khỏi tinh cầu sụp đổ."},{"ten":"Huyết Tổ","tag":"khac","quanHe":"huyết nô","ghiChu":"Bị Huyết Tổ luyện hóa thành huyết nô."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"vuong-lam-ban-ton","name":"Vương Lâm bản tôn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Cổ Thần","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cổ Thần bốn tinh điểm chưa hoàn chỉnh @c0663","trangThai":"song","blurb":"Vương Lâm bản tôn là Cổ Thần thể của Vương Lâm, xuất hiện từ trung tâm một tinh cầu sụp đổ. Hắn có tóc đỏ, mi tâm hiện bốn tinh điểm nhưng một điểm còn ảm đạm, đang tìm cổ thần chi khí để trưởng thành.","vaiTro":"Cổ Thần bản tôn của Vương Lâm","tinhCach":"lạnh lùng; chuyên chú tu luyện; tính toán đường trưởng thành Cổ Thần","tabs":{"diem":[{"text":"Hiện ra từ trung tâm tinh cầu vỡ với tóc đỏ và bốn tinh điểm trên mi tâm.","chuong":"@c0663"},{"text":"Tự nhận Trừu Hồn chưa thành thục và cần cổ thần chi khí để tiếp tục trưởng thành.","chuong":"@c0663"},{"text":"Cân nhắc Chu Tước Tinh, Thác Sâm và chọn một tinh cầu có lôi quang để tiếp tục tu luyện.","chuong":"@c0663"}],"kinhLich":[{"chuong":"@c0663","importance":"normal","tieuDe":"Cổ Thần lộ diện","text":"Bản tôn Vương Lâm xuất hiện từ trung tâm tinh cầu tan vỡ, khiến Tử Tâm phải bỏ chạy; hắn thử Trừu Hồn nhưng chưa thành thục, nhận ra bản thân thiếu cổ thần chi khí rồi vài tháng sau dung nhập vào một tinh cầu hoang dã có tầng lôi quang để tiếp tục tu luyện.","anchor":"Hắn, đúng là bản tôn của Vương Lâm"}],"tuViMoc":[{"chuong":"@c0663","canhGioi":"Cổ Thần bốn tinh điểm chưa hoàn chỉnh","text":"Mi tâm bản tôn hiện bốn tinh điểm, nhưng một điểm còn ảm đạm; đây là mốc trưởng thành của Cổ Thần thể, không phải tu vi chính theo hệ tu sĩ.","importance":"major"}],"nhanMach":[{"ten":"Tử Tâm","tag":"khac","quanHe":"chấn nhiếp","ghiChu":"Tiếng quát và uy áp từ lòng tinh cầu khiến Tử Tâm phải nhận lỗi rút lui."},{"ten":"Thác Sâm","tag":"doi-thu","quanHe":"mối đe dọa Cổ Thần","ghiChu":"Bản tôn cân nhắc chuyện Thác Sâm khi nghĩ tới Chu Tước Tinh và cổ thần chi khí."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Trừu Hồn","trangThai":"dang-co","moTa":"Thần thông bản tôn thử dùng trên mảnh vỡ tinh cầu nhưng chưa thành thục.","nguon":"@c0663"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"thac-sam","name":"Thác Sâm","trangThai":"song","tabs":{"kinhLich":[{"text":"Trong Cổ Thần Chi Địa, Thác Sâm ngồi trên cột đá lớn nhất giữa Huyết Hải, liên tục khắc tên Vương Lâm và tuyên bố mình sắp thoát khỏi nơi giam giữ; ba tháng sau, hắn phái sứ giả rời Cổ Thần Chi Địa.","anchor":"Vương Lâm, ta sắp thoát khỏi đây rồi","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Ma Tán Nhân","tag":"dong-minh","quanHe":"sứ giả","ghiChu":"Thiên Ma Tán Nhân rời Cổ Thần Chi Địa với thân phận sứ giả do Thác Sâm phái ra."}],"tuiDo":{"phapBao":[{"ten":"Thiết kiếm rỉ sét","trangThai":"dang-co","moTa":"Thanh kiếm cắm bên cạnh Thác Sâm trên cột đá trong Huyết Hải.","nguon":"@c0663"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"thien-ma-tan-nhan","name":"Thiên Ma Tán Nhân","trangThai":"song","tabs":{"kinhLich":[{"text":"Ba tháng sau lời tuyên bố của Thác Sâm, một người rời Cổ Thần Chi Địa; người này không phải Thác Sâm mà là sứ giả của hắn, được nhận ra là Thiên Ma Tán Nhân vốn đã chết từ lâu và vẫn ôm hận Vương Lâm vì kế hoạch truyền thừa năm xưa bị phá.","anchor":"người này đúng là Thiên Ma Tán Nhân đã chết từ lâu","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[{"ten":"Thác Sâm","tag":"dong-minh","quanHe":"sứ giả","ghiChu":"Được Thác Sâm phái rời Cổ Thần Chi Địa."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"mang hận","ghiChu":"Hận Vương Lâm vì ký ức truyền thừa và kế hoạch nhiều năm bị phá."},{"ten":"Lục Dục Ma Quân","tag":"su-mon","quanHe":"sư phụ","ghiChu":"Được nhắc qua thân phận sư phụ của Lục Dục Ma Quân."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"chu-nhu","name":"Chu Như","trangThai":"song","tabs":{"kinhLich":[{"chuong":"@c0663","importance":"normal","tieuDe":"Ký ức giải phong","text":"Trên đỉnh Chu Tước Sơn, Chu Như mở túi trữ vật Vương Lâm lưu lại nhiều năm trước; bạch quang trong túi nhập vào mi tâm, giải khai ký ức bị phong ấn, khiến nàng nhớ tới Uyển nhi và hiểu Vương Lâm vẫn không muốn nàng đi tìm hắn.","anchor":"trong đầu nàng dường như một chút trí nhớ bị phong ấn chậm rãi cởi bỏ"}],"tuViMoc":[],"nhanMach":[{"ten":"Lý Mộ Uyển","tag":"khac","quanHe":"người trong ký ức","ghiChu":"Ký ức được giải phong hiện lên đoạn liên quan tới Uyển nhi."}],"tuiDo":{"phapBao":[{"ten":"Túi trữ vật Vương Lâm lưu lại cho Chu Như","trangThai":"da-dung","moTa":"Túi cổ xưa mở ra bạch quang giải phong ký ức trong đầu Chu Như.","nguon":"@c0663"},{"ten":"Bạch quang trong túi trữ vật","trangThai":"da-dung","moTa":"Nhập vào mi tâm Chu Như và cởi bỏ ký ức bị phong ấn.","nguon":"@c0663"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"tieu-bach","name":"Tiểu Bạch","trangThai":"song","tabs":{"kinhLich":[{"text":"Tiểu Bạch nằm lười sau lưng Chu Như trên đỉnh Chu Tước Sơn; khi bạch quang từ túi trữ vật nhập vào mi tâm nàng, nó lập tức rít gào đứng dậy chứng kiến biến cố giải phong ký ức.","anchor":"trong đầu nàng dường như một chút trí nhớ bị phong ấn chậm rãi cởi bỏ","bridge":true,"khoang":"@c0663"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0663"]},{"id":"chu-dai-ca","name":"Chu đại ca","cn":"","aliases":["thiếu niên họ Chu"],"gioiTinh":"nam","theLuc":[{"ten":"Lạc Nguyệt thôn","trangThai":"gan-bo"},{"ten":"Võ lâm đại hội của nhóm trẻ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Thiếu niên họ Chu ở Lạc Nguyệt thôn, con của Chu thúc thúc. Cậu kể cho đám trẻ về Kỳ Liên Phong, luyện kiếm và trò võ lâm đại hội.","vaiTro":"Thiếu niên dẫn dắt đám trẻ trong sinh hoạt phàm tục ở Lạc Nguyệt thôn.","tinhCach":[{"text":"Hoạt bát, thích kể chuyện và bày trò luyện kiếm với nhóm trẻ.","chuong":"@c0643"}],"tabs":{"diem":[{"text":"Kể cho nhóm trẻ nghe về sương mù Kỳ Liên Phong và khuyên luyện kiếm để cường thân kiện thể.","chuong":"@c0643"},{"text":"Là con của Chu thúc thúc, gia đình đang chuẩn bị việc cưới vợ cho cậu.","chuong":"@c0643"},{"text":"Kể chuyện Kỳ Liên Phong và sương mù từng giúp cường thân kiện thể cho nhóm trẻ nghe.","chuong":"@c0643"},{"text":"Nhắc tới luyện kiếm và võ lâm đại hội như trò chơi giang hồ của trẻ trong thôn.","chuong":"@c0643"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Chu đại ca xuất hiện như thiếu niên phàm tục trong sơn thôn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Bình","tag":"ban-be","quanHe":"người quen trong thôn","ghiChu":"Cậu kể chuyện Kỳ Liên Phong và võ lâm đại hội cho Vương Bình cùng nhóm trẻ."},{"ten":"Chu thúc thúc","tag":"cha-me","quanHe":"cha","ghiChu":"Chu thúc thúc là cha của thiếu niên họ Chu."},{"ten":"Vương Lâm","tag":"khac","quanHe":"người trong thôn được nhờ làm đồ","ghiChu":"Cha cậu tới nhờ Vương Lâm làm đồ đạc cho phòng cưới của cậu."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0643"]},{"id":"chu-thuc-thuc-lac-nguyet","name":"Chu thúc thúc","cn":"","aliases":["đại hán họ Chu"],"gioiTinh":"nam","theLuc":[{"ten":"Lạc Nguyệt thôn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Thợ săn họ Chu ở Lạc Nguyệt thôn, cha của thiếu niên họ Chu. Ông săn được chương lộc và đem làm tiền đặt cọc để nhờ Vương Lâm làm đồ đạc cho phòng cưới của con trai.","vaiTro":"Người dân phàm tục trong tuyến ẩn cư Lạc Nguyệt thôn, qua lại với Vương Lâm như hàng xóm cùng thôn.","tinhCach":[{"text":"Chân chất, hào sảng, dùng con mồi săn được để đặt cọc nhờ làm đồ.","chuong":"@c0643"},{"text":"Thân thiện với Vương Bình, khen cậu lễ phép.","chuong":"@c0643"}],"tabs":{"diem":[{"text":"Là thợ săn trong thôn, trở về với con chương lộc săn được.","chuong":"@c0643"},{"text":"Tới nhà Vương Lâm nhờ làm đồ đạc cho phòng cưới của con trai.","chuong":"@c0643"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Chu thúc thúc xuất hiện như một thợ săn phàm tục ở Lạc Nguyệt thôn.","importance":"minor"}],"nhanMach":[{"ten":"Chu đại ca","tag":"cha-me","quanHe":"con trai","ghiChu":"Ông chuẩn bị phòng cưới cho con trai."},{"ten":"Vương Lâm","tag":"khac","quanHe":"người cùng thôn","ghiChu":"Ông nhờ Vương Lâm làm đồ đạc và đem chương lộc làm tiền đặt cọc."},{"ten":"Vương Bình","tag":"khac","quanHe":"đứa trẻ cùng thôn","ghiChu":"Ông gặp và khen Vương Bình lễ phép."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Cương xoa tiễn","loai":"vũ khí săn bắn","trangThai":"dang-co","moTa":"Vũ khí săn bắn Chu thúc thúc cầm khi từ thôn khẩu trở về sau chuyến săn.","nguon":"@c0643"},{"ten":"Chương lộc","loai":"con mồi","trangThai":"da-dung","moTa":"Con mồi Chu thúc thúc săn được và dùng làm tiền đặt cọc nhờ Vương Lâm làm đồ đạc.","nguon":"@c0643"}]}},"nguon":["@c0643"]},{"id":"thieu-nien-ho-chu-643","name":"Thiếu niên họ Chu","aliases":["Chu đại ca"],"gioiTinh":"nam","theLuc":[{"ten":"Sơn thôn dưới Kỳ Liên Phong","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Thiếu niên trong sơn thôn dưới Kỳ Liên Phong, khoảng mười bốn mười lăm tuổi, kể cho nhóm trẻ nghe chuyện sương mù trên núi có thể cường thân kiện thể.","vaiTro":"Thiếu niên thôn quê kết nối Vương Bình với truyền thuyết về Kỳ Liên Phong.","tinhCach":[{"text":"Hoạt bát, thích kể chuyện và khuyên đám trẻ luyện kiếm để cường thân kiện thể.","chuong":"@c0643"}],"tabs":{"diem":[{"text":"Kể chuyện sương mù Kỳ Liên Phong từng giúp người cường thân kiện thể, khiến Vương Bình chú ý.","chuong":"@c0643"}],"kinhLich":[{"chuong":"@c0643","importance":"normal","tieuDe":"Kể chuyện Kỳ Liên Phong","text":"Thiếu niên họ Chu tụ tập cùng nhóm trẻ trong thôn, kể chuyện sương mù Kỳ Liên Phong và khuyên bọn trẻ luyện kiếm để cường thân kiện thể.","anchor":"Đứa bé trai này khoảng năm sáu tuổi, sắc mặt tái nhợt, thân mình nhu nhược."}],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Thiếu niên họ Chu xuất hiện như một thiếu niên thôn quê, không có biểu hiện tu vi.","importance":"major"}],"nhanMach":[{"ten":"Vương Bình","tag":"ban-be","quanHe":"đứa trẻ trong thôn nghe hắn kể chuyện","ghiChu":"Vương Bình nghe thiếu niên họ Chu kể chuyện sương mù Kỳ Liên Phong."},{"ten":"Đại hán họ Chu","tag":"cha-me","quanHe":"cha","ghiChu":"Đại hán họ Chu là cha của thiếu niên họ Chu và chuẩn bị phòng cưới cho con trai."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0643"]},{"id":"dai-han-ho-chu-643","name":"Đại hán họ Chu","aliases":["Chu thúc thúc"],"gioiTinh":"nam","theLuc":[{"ten":"Sơn thôn dưới Kỳ Liên Phong","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","blurb":"Thợ săn vạm vỡ trong sơn thôn dưới Kỳ Liên Phong, cha của thiếu niên họ Chu. Ông đem chương lộc tới nhà Vương Lâm làm tiền đặt cọc để nhờ đóng đồ cho phòng cưới của con trai.","vaiTro":"Người dân trong thôn giao tiếp với Vương Lâm khi hắn sống ẩn như thợ mộc.","tinhCach":[{"text":"Chất phác, thực tế, dùng con mồi săn được để đặt cọc việc mộc.","chuong":"@c0643"}],"tabs":{"diem":[{"text":"Săn được chương lộc và đem tới nhờ Vương Lâm làm đồ dùng cho phòng cưới của con trai.","chuong":"@c0643"}],"kinhLich":[{"chuong":"@c0643","importance":"normal","tieuDe":"Đặt cọc chương lộc","text":"Đại hán họ Chu từ thôn khẩu trở về với chương lộc trên vai và cương xoa tiễn săn bắn, đem con mồi làm tiền đặt cọc để nhờ Vương Lâm đóng đồ đạc cho phòng cưới của con trai.","anchor":"Con chương lộc này làm tiền đặt cọc trước vậy !"}],"tuViMoc":[{"chuong":"@c0643","canhGioi":"Phàm nhân","text":"Đại hán họ Chu xuất hiện như một thợ săn phàm tục trong sơn thôn, không có biểu hiện tu vi.","importance":"major"}],"nhanMach":[{"ten":"Thiếu niên họ Chu","tag":"cha-me","quanHe":"cha","ghiChu":"Ông nhờ Vương Lâm làm đồ cho phòng cưới của con trai."},{"ten":"Vương Lâm","tag":"khac","quanHe":"người thợ mộc được ông nhờ làm đồ","ghiChu":"Ông đem chương lộc tới đặt cọc cho việc mộc."},{"ten":"Vương Bình","tag":"khac","quanHe":"đứa trẻ trong nhà Vương Lâm","ghiChu":"Vương Bình chứng kiến ông đem chương lộc đến nhà."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Cương xoa tiễn săn bắn","loai":"vũ khí phàm tục","trangThai":"dang-co","moTa":"Vật săn bắn đại hán họ Chu mang theo khi trở về thôn.","nguon":"@c0643"},{"ten":"Chương lộc","loai":"con mồi","trangThai":"da-dung","moTa":"Con thú ông săn được và đem làm tiền đặt cọc cho Vương Lâm.","nguon":"@c0643"}]}},"nguon":["@c0643"]},{"id":"vong-nguyet","name":"Vọng Nguyệt","aliases":["Vân Hà Tinh"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"hung thú cổ dị khổng lồ @c0667","trangThai":"khong-ro","blurb":"Hung thú cổ dị khổng lồ hóa thành Vân Hà Tinh, thân thể chứa xương, xúc tu, Kim Viêm thạch và Nguyệt Hoa. Trong đợt này nó bị tổn thương, xuất hiện dấu hiệu chuyển sang hình thái công kích.","vaiTro":"Hung thú cổ dị Vân Hà Tinh","tinhCach":[{"text":"Bản năng hung hiểm, phản ứng mạnh khi bị tổn thương","chuong":"@c0667"},{"text":"Cơ thể chứa nhiều trọng bảo nhưng cực kỳ nguy hiểm","chuong":"@c0667"}],"tabs":{"diem":[{"text":"Bộ xương có khe lớn gần như chặt đứt, đủ khiến thân thể đau đớn và chuyển trạng thái.","chuong":"@c0667"},{"text":"Trong cơ thể có Nguyệt Hoa mang kịch độc và nguy cơ tự bạo trên phạm vi rất rộng.","chuong":"@c0667"}],"kinhLich":[{"text":"Trong thân thể Vọng Nguyệt, Vương Lâm phát hiện khe lớn gần chặt đứt xương, sơn thạch của Tham Lang bị kẹt và đồng hóa với Kim Viêm thạch; sự xuất hiện của con Vọng Nguyệt nhỏ cùng nguy cơ Nguyệt Hoa cho thấy tình trạng bên trong đã biến hóa nghiêm trọng.","anchor":"Cái khe này rất sâu gần như chặt đứt xương của Vọng Nguyệt.","bridge":true,"khoang":"@c0667"},{"chuong":"@c0668","importance":"normal","tieuDe":"Bị kích thích rút cốt","text":"Thân thể Vọng Nguyệt bị chất lỏng Thăng Tiên quả lan khắp, xúc tu mất tính công kích trong trạng thái hưng phấn; ngay sau đó Vương Lâm dùng Hoàng Tuyền lực bám theo xương cốt để rút cốt, khiến toàn bộ Vân Hà Tinh chấn động và phát tiếng rống.","anchor":"Một tiếng rống tràn đầy tang thương buồn bực ở trong chấn động của đại địa chậm rãi truyền ra rất xa."},{"chuong":"@c0669","importance":"normal","tieuDe":"Bắt đầu thức tỉnh","text":"Vọng Nguyệt bị Hoàng Tuyền lực và việc rút xương sống kích động, thân thể hóa thành Vân Hà Tinh chấn động, xúc tu phun hồng vụ và kéo dài, bùn đất bong tróc như vỏ trứng, dần thức tỉnh trong trạng thái bị Thăng Tiên quả làm mê loạn cảm giác.","anchor":"Giống như một con hung thú đã ngủ say qua vô số năm tháng đang dần dần thức tỉnh"},{"chuong":"@c0670","importance":"major","tieuDe":"Thức tỉnh truy sát","text":"Vọng Nguyệt thức tỉnh, xoay mình khiến lục địa trên thân thể vỡ vụn, làm sương mù Vân Hà Tinh tiêu tán; nó cảm nhận xương cốt quen thuộc mà truy đuổi Vương Lâm và Tiên Vệ, đồng thời phát ra tiếng nói Cổ Thần cùng kỹ thuật phá nát khiến bầu trời nứt vỡ.","anchor":"Trên thực tế thì mặt đất chính là thân thể Vọng Nguyệt, cái phóng lên không chẳng qua chỉ do Vọng Nguyệt xoay người ngẩng đầu lên mà thôi."},{"chuong":"@c0671","importance":"normal","tieuDe":"Thức tỉnh truy đuổi","text":"Vọng Nguyệt thức tỉnh, khiến mặt đất Vân Hà Tinh lộ bản chất là thân thể của nó, lục địa bám trên thân vỡ vụn và sương mù tiêu tán; nó truy đuổi xương cốt quen thuộc, phát ra tiếng nói Cổ Thần bất thường và tạo ra nguy cơ phá nát không gian.","anchor":"Trên thực tế thì mặt đất chính là thân thể Vọng Nguyệt"},{"chuong":"@c0672","importance":"normal","tieuDe":"Phẫn nộ hóa chỉ","text":"Vọng Nguyệt dần thoát khỏi ảnh hưởng Thăng Tiên Quả, nhận ra xương bị nuốt là xương của chính mình nên hoàn toàn nổi giận; nó truy sát Vương Lâm và Tham Lang, phun ra đàn Vọng Nguyệt nhỏ, chú ý khí tức cự đỉnh rồi huyễn hóa một chỉ Cổ Thần phá bình phong Sơn Hà Đồ.","anchor":"Vọng Nguyệt một khi phẫn nộ thì sẽ đạt đến hình thái thứ ba, lúc này sẽ có uy lực tương đương với một chỉ của Cổ Thần"},{"text":"Vọng Nguyệt dùng thần thông huyễn hóa Cổ Thần Chỉ đánh Tham Lang rồi phá hủy nhục thân Vương Lâm; sau khi ngón tay tiêu tán, nó nhìn cự đỉnh trên xúc tua, hơi do dự rồi tiếp tục đuổi theo nguyên thần Vương Lâm.","anchor":"Nó nhìn thoáng qua cự đỉnh khổng lồ trên những xúc tua rồi hơi chút do dự, sau đó thân thể khổng lồ lại phóng thẳng về phía trước đuổi theo.","bridge":true,"khoang":"@c0673"},{"text":"Vọng Nguyệt truy sát Vương Lâm từ La Thiên Bắc Vực tới ranh giới Nam-Bắc Vực nhưng vì ký ức cảnh cáo mơ hồ và cảm giác khủng hoảng nên không dám vượt qua. Sau đó nó lui về gần Ngũ Đại Chủ Tinh, cuốn cự đỉnh vào cơ thể, thu xúc tua, tỏa sương mù và bước vào trạng thái ngủ thứ hai.","anchor":"Vọng Nguyệt lại bắt đầu trạng thái thứ hai, bắt đầu ngủ.","bridge":true,"khoang":"@c0674"},{"text":"Vọng Nguyệt không trực tiếp xuất hiện, nhưng đoạn xương khổng lồ còn lại của nó được Vương Lâm ném về phía cánh cửa màu tím để thăm dò; cánh tay tử quang chỉ sờ nhẹ đã khiến đoạn xương tan vỡ.","anchor":"Dãy núi do xương của Vọng Nguyệt tạo thành nhằm thẳng cánh cửa to lớn kia phóng đến","bridge":true,"khoang":"@c0676"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"truy sát","ghiChu":"Truy sát Vương Lâm nhưng dừng lại ở ranh giới La Thiên Nam-Bắc Vực, không tiếp tục vượt qua."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[{"ten":"Kim Viêm thạch","trangThai":"trong-co-the","moTa":"Mọc trong xương Vọng Nguyệt và đồng hóa với sơn thạch của Tham Lang.","nguon":"@c0667"},{"ten":"Nguyệt Hoa","trangThai":"trong-co-the","moTa":"Vật mang kịch độc và nguy cơ tự bạo nếu bị uy hiếp hoặc lấy ra.","nguon":"@c0667"}],"linhThao":[],"khac":[]}},"nguon":["@c0667","@c0668","@c0669","@c0670","@c0671","@c0672","@c0673","@c0674","@c0676"]},{"id":"con-vong-nguyet-nho","name":"Con Vọng Nguyệt nhỏ","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"hung thú cổ dị nhỏ @c0667","trangThai":"song","blurb":"Một cá thể Vọng Nguyệt nhỏ ẩn trong bùn đất gần khe xương của Vọng Nguyệt khổng lồ. Nó bất ngờ phục kích Vương Lâm khi hắn lấy sơn thạch.","vaiTro":"Hung thú phục kích trong bùn đất","tinhCach":[{"text":"Ẩn nấp kín đáo trong bùn đất","chuong":"@c0667"},{"text":"Tấn công bất ngờ khi con mồi đoạt bảo vật","chuong":"@c0667"}],"tabs":{"diem":[{"text":"Thân thể lộ ra dài khoảng mười trượng, xuất hiện sau lưng Vương Lâm trong lúc hắn lấy sơn thạch.","chuong":"@c0667"},{"text":"Bị Định thân thuật làm khựng lại trong khoảnh khắc rồi rút vào bùn đất.","chuong":"@c0667"}],"kinhLich":[{"text":"Con Vọng Nguyệt nhỏ bất ngờ xuất hiện phía sau Vương Lâm khi hắn vừa đoạt sơn thạch, bị Định thân thuật chặn lại trong chớp mắt, tạo cơ hội cho hắn trốn vào bùn đất.","anchor":"Vật ở phía sau là một con Vọng Nguyệt nhỏ hơn nữa thân thể ở trong bùn đất, phần lộ ra dài ước chừng mười trượng!","bridge":true,"khoang":"@c0667"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0667"]},{"id":"tien-ve","name":"Tiên Vệ","aliases":["Con rối Tiên Vệ"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Vương Lâm","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ @c0682","trangThai":"song","blurb":"Khôi lỗi hộ vệ của Vương Lâm, được luyện hóa theo cách mô phỏng Cổ Thần. Trong chương này nó thể hiện lực lượng Âm Hư khi kéo nửa đoạn xương sống Vọng Nguyệt.","vaiTro":"Khôi lỗi hộ vệ của Vương Lâm","tinhCach":[{"text":"Tuy là khôi lỗi nhưng chấp hành mệnh lệnh quyết liệt","chuong":"@c0669"},{"text":"Thân thể mạnh mẽ, lực lượng vượt xa Vương Lâm lúc này","chuong":"@c0669"}],"tabs":{"diem":[{"text":"Đạt cảnh giới Âm Hư và có lực lượng lớn nhờ phương thức luyện hóa mô phỏng Cổ Thần.","chuong":"@c0669"},{"text":"Được triệu ra kéo nửa đoạn xương sống còn lại của Vọng Nguyệt.","chuong":"@c0669"}],"kinhLich":[{"text":"Tiên Vệ được Vương Lâm gọi ra, lao tới ôm lấy nửa đoạn xương sống bên phải của Vọng Nguyệt và kéo theo sau hắn để hai nửa xương cùng được rút khỏi lòng đất.","anchor":"con rối Tiên Vệ biến ảo ra lao thẳng tới nửa thanh xương cốt của Vọng Nguyệt ở bên phải","bridge":true,"khoang":"@c0669"},{"text":"Tiên Vệ bị tiếng rống của Vọng Nguyệt làm kim quang tán loạn nhưng vẫn theo sát Vương Lâm, cùng khiêng đoạn xương cốt của Vọng Nguyệt và lao lên tầng sương mù để thoát ra ngoài bầu trời.","anchor":"Vương Lâm thân thể run lên, ở dưới tiếng rống này tiên lực nháy mắt tán loạn.","bridge":true,"khoang":"@c0670"},{"text":"Tiên Vệ mang một đoạn xương Vọng Nguyệt theo sau Vương Lâm, bị tiếng rống làm kim quang tán loạn nhưng vẫn tiếp tục lao lên tầng sương mù để thoát ra ngoài.","anchor":"Một người một con rối đột nhiên lao ra, mắt thấy sắp tiến vào trong sương mù","bridge":true,"khoang":"@c0671"},{"text":"Tiên Vệ được Vương Lâm giao xương Vọng Nguyệt mang đi; khi nhục thân Vương Lâm bị hủy, nguyên thần hắn cuốn theo Tiên Vệ và nửa đoạn xương Vọng Nguyệt để bỏ chạy.","anchor":"Trong quá trình bỏ chạy nguyên thần Vương Lâm lại càng dung hợp vào bên trong Tinh La Bàn, nó mang theo Tiên Vệ và một nửa đoạn xương Vọng Nguyệt điên cuồng bỏ chạy.","bridge":true,"khoang":"@c0673"},{"text":"Tiên Vệ được Vương Lâm điều khiển dò qua tầng đá tới tinh cầu lôi quang nhưng tỏ ra do dự trước lôi tiên thiên. Vương Lâm nhận ra lôi nơi này tự nhiên sinh thành nên để Tiên Vệ ở ngoài tinh cầu hộ pháp trong mười năm hắn chữa thương.","anchor":"Lôi quang ở đây là tự nhiên, không phải do bất kỳ pháp thuật thần thông nào huyễn hóa ra","bridge":true,"khoang":"@c0674"},{"text":"Khi lôi quang trên tinh cầu suy yếu sau một giáp, Tiên Vệ có thể tiến vào gần Vương Lâm để hộ pháp trong lúc hắn tái tạo thân thể và xử lý Thiên Nghịch.","anchor":"Làm xong những công việc bảo vệ, Vương Lâm lại quét thần thức qua một lượt.","bridge":true,"khoang":"@c0675"},{"text":"Khi Thiên Nghịch tự bay ra và hút lôi điện khiến Lôi Trì bạo loạn, Tiên Vệ ở gần Vương Lâm lập tức rút lui khỏi vùng dao động nguy hiểm.","anchor":"Vô số Lôi Long trong Lôi Trì gào thét kéo đến, từ bốn phương tám hướng một mạch chui vào trong Thiên Nghịch.","bridge":true,"khoang":"@c0678"},{"text":"Trong lúc Vương Lâm tu luyện, Tiên Vệ khoanh chân trên đá vụn gần đó, hai mắt lóe tinh quang và thỉnh thoảng nhìn chăm chú Thân Công Hổ, tạo thế giám sát để bảo đảm an toàn cho chủ nhân.","anchor":"Ở trên đá vụn cách đó không xa, con rối Tiên Vệ khoanh chân ngồi, hai mắt lộ ra tinh quang, thỉnh thoảng nhìn về phía Thân Công Hổ.","bridge":true,"khoang":"@c0682"},{"text":"Tiên Vệ con rối khoanh chân trên đá vụn gần Vương Lâm, không để ý Chiến Không Liệt xuất hiện; sự hiện diện của nó cùng Lôi Thú sừng bạc khiến Chiến Không Liệt cho rằng cục diện quanh Vương Lâm rất quỷ dị.","anchor":"Chuyện này thật sự rất quỷ dị, nếu không phải đối phương có pháp bảo hung mạnh không thể tưởng tượng, thì chính là đã ẩn giấu tu vi thực sự.","bridge":true,"khoang":"@c0684"}],"tuViMoc":[{"chuong":"@c0669","canhGioi":"Âm Hư","text":"Chương nêu Tiên Vệ đã đạt cảnh giới Âm Hư khi được triệu ra kéo xương sống Vọng Nguyệt.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"chủ nhân","ghiChu":"Được Vương Lâm triệu ra hỗ trợ kéo xương sống Vọng Nguyệt."},{"ten":"Chiến Không Liệt","tag":"khac","quanHe":"Bị Chiến Không Liệt chú ý như một trong những tồn tại quanh Vương Lâm làm tăng nghi ngờ về thân phận của chủ nhân.","ghiChu":"Chưa trực tiếp giao chiến."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0669","@c0670","@c0671","@c0673","@c0674","@c0675","@c0678","@c0682","@c0684"]},{"id":"do-ti","name":"Đồ Ti","aliases":["Cổ Thần Đồ Ti"],"gioiTinh":"nam","theLuc":[{"ten":"Cổ Thần","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cổ Thần","trangThai":"khong-ro","blurb":"Đồ Ti là Cổ Thần hiện diện qua ký ức truyền thừa của Vương Lâm. Trong chương này, tiếng nói Cổ Thần mà Vương Lâm sử dụng bắt nguồn từ truyền thừa của Đồ Ti.","vaiTro":"Nguồn truyền thừa Cổ Thần","tinhCach":[{"text":"Uy thế Cổ Thần để lại ảnh hưởng sâu trong truyền thừa","chuong":"@c0670"},{"text":"Ký ức truyền thừa trở thành căn cứ để Vương Lâm nhận biết dị thường của Vọng Nguyệt","chuong":"@c0670"}],"tabs":{"diem":[{"text":"Ký ức của Đồ Ti không từng ghi nhận việc Vọng Nguyệt có thể phát ra tiếng nói Cổ Thần.","chuong":"@c0670"},{"text":"Tiếng nói Cổ Thần Vương Lâm dùng để ngăn nguy cơ sinh tử được truyền thừa từ Đồ Ti.","chuong":"@c0670"}],"kinhLich":[{"text":"Đồ Ti được nhắc qua ký ức Cổ Thần của Vương Lâm; chính ký ức ấy khiến Vương Lâm nghi hoặc khi thấy Vọng Nguyệt phát tiếng nói Cổ Thần, và tiếng nói Vương Lâm dùng để đáp lại cũng là truyền thừa từ Đồ Ti.","anchor":"Trong ký ức của Đồ Ti chưa từng đề cập đến chuyện Vọng Nguyệt sẽ phát ra tiếng nói của Cổ Thần, đây rốt cuộc là Vọng Nguyệt gì?","bridge":true,"khoang":"@c0670"},{"text":"Ký ức và truyền thừa của Đồ Ti được Vương Lâm dùng để nhận ra điểm bất thường khi Vọng Nguyệt phát ra tiếng nói Cổ Thần; tiếng nói Cổ Thần mà Vương Lâm dùng đáp trả cũng bắt nguồn từ truyền thừa này.","anchor":"Trong ký ức của Đồ Ti chưa từng đề cập đến chuyện Vọng Nguyệt sẽ phát ra tiếng nói của Cổ Thần","bridge":true,"khoang":"@c0671"},{"text":"Ký ức Cổ Thần của Đồ Ti giúp Vương Lâm hiểu quy luật khi Vọng Nguyệt phẫn nộ và nhận ra uy thế tương đương một chỉ Cổ Thần.","anchor":"Vọng Nguyệt một khi phẫn nộ thì sẽ đạt đến hình thái thứ ba, lúc này sẽ có uy lực tương đương với một chỉ của Cổ Thần","bridge":true,"khoang":"@c0672"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người kế thừa ký ức Cổ Thần","ghiChu":"Vương Lâm sử dụng tiếng nói Cổ Thần được truyền thừa từ Đồ Ti."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Tiếng nói Cổ Thần","trangThai":"dang-co","moTa":"Nguồn truyền thừa giúp Vương Lâm phát ra tiếng nói Cổ Thần trong lúc sinh tử.","nguon":"@c0670"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0670","@c0671","@c0672"]},{"id":"ly-nguy-du","name":"Lý Nguy Dữ","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Tu sĩ từng truy đuổi Tham Lang, được nhắc trong hồi tưởng của Tham Lang khi so sánh hiểm cảnh trước một chỉ của Vọng Nguyệt.","vaiTro":"Tu sĩ từng truy đuổi Tham Lang","tinhCach":[{"text":"Không rõ","chuong":"@c0672"}],"tabs":{"diem":[{"text":"Được Tham Lang nhớ tới như một trong những người từng khiến hắn rơi vào nguy cơ.","chuong":"@c0672"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Từng truy đuổi","ghiChu":"Được nhắc trong hồi tưởng của Tham Lang."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0672"]},{"id":"doi-van-tien","name":"Đối Vân Tiên","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Tu sĩ từng truy đuổi Tham Lang, chỉ được nhắc trong hồi tưởng về những nguy cơ sinh tử cũ.","vaiTro":"Tu sĩ từng truy đuổi Tham Lang","tinhCach":[{"text":"Không rõ","chuong":"@c0672"}],"tabs":{"diem":[{"text":"Nằm trong nhóm từng truy đuổi Tham Lang trước đây.","chuong":"@c0672"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Từng truy đuổi","ghiChu":"Được nhắc trong hồi tưởng của Tham Lang."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0672"]},{"id":"tri-nhat-chau","name":"Tri Nhất Châu","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Tu sĩ từng truy đuổi Tham Lang, được nhắc như một phần trong các hiểm cảnh trước đây của Tham Lang.","vaiTro":"Tu sĩ từng truy đuổi Tham Lang","tinhCach":[{"text":"Không rõ","chuong":"@c0672"}],"tabs":{"diem":[{"text":"Được nhắc cùng nhóm truy đuổi Tham Lang trong quá khứ.","chuong":"@c0672"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Từng truy đuổi","ghiChu":"Được nhắc trong hồi tưởng của Tham Lang."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0672"]},{"id":"de-nhi-tien-ve","name":"Đệ Nhị Tiên Vệ","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Vương Lâm","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ @c0673","trangThai":"tu-vong @c0673","blurb":"Con rối Tiên Vệ thứ hai được Vương Lâm lấy ra từ túi trữ vật trong lúc đối mặt Cổ Thần Chỉ. Nó bị dùng làm lá chắn và nhanh chóng tan rã dưới uy lực một chỉ.","vaiTro":"con rối chắn đòn","tinhCach":[{"text":"không có ý thức riêng rõ rệt","chuong":"@c0673"},{"text":"được dùng để giảm nguy cơ cho chủ nhân","chuong":"@c0673"}],"tabs":{"diem":[{"text":"Được Vương Lâm gọi ra từ túi trữ vật để chắn trước người khi Cổ Thần Chỉ ép tới.","chuong":"@c0673"},{"text":"Bị Cổ Thần Chỉ đánh trúng và tan rã, chỉ giảm bớt một phần nguy cơ cho Vương Lâm.","chuong":"@c0673"}],"kinhLich":[{"text":"Vương Lâm lấy Đệ Nhị Tiên Vệ ra chắn trước người, nhưng Cổ Thần Chỉ đánh vào khiến con rối nhanh chóng sụp đổ, chỉ làm giảm bớt một phần nguy cơ.","anchor":"Ngón tay Cổ Thần vỗ lên trên người Đệ Nhị tiên vệ, toàn thân Tiên Vệ lập tức run lên","bridge":true,"khoang":"@c0673"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"chủ nhân","ghiChu":"Được Vương Lâm lấy ra làm lá chắn trước Cổ Thần Chỉ."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0673"]},{"id":"thien-van-tu","name":"Thiên Vận Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"","vaiTro":"","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Thiên Vận Tử được nhắc tới vì lạc ấn của hắn là đạo lạc ấn duy nhất còn tồn tại trong cơ thể Tham Lang sau khi một chỉ Cổ Thần phá tan các lạc ấn cường giả khác.","anchor":"Chỉ còn tồn tại duy nhất đạo lạc ấn của Thiên Vận Tử.","bridge":true,"khoang":"@c0674"}],"tuViMoc":[],"nhanMach":[{"ten":"Tham Lang","tag":"doi-thu","quanHe":"để lại lạc ấn","ghiChu":"Lạc ấn của Thiên Vận Tử vẫn còn trong cơ thể Tham Lang sau biến cố một chỉ Cổ Thần."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0674"]},{"id":"uyen-nhi","name":"Uyển Nhi","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Uyển Nhi là người có hồn phách được Vương Lâm đặt trong Hạt Châu Thiên Nghịch. Khi Thiên Nghịch viên mãn sinh dị biến, sự an nguy của hồn phách nàng trở thành lý do khiến Vương Lâm quyết không khuất phục.","vaiTro":"hồn phách trong Thiên Nghịch","tinhCach":[{"text":"là điểm yếu và động lực bảo vệ của Vương Lâm","chuong":"@c0676"},{"text":"gắn chặt với bí mật bên trong Thiên Nghịch","chuong":"@c0676"}],"tabs":{"diem":[{"text":"Hồn phách của nàng nằm trong Hạt Châu Thiên Nghịch, khiến dị biến của pháp bảo này trực tiếp đe dọa điều Vương Lâm muốn bảo vệ.","chuong":"@c0676"},{"text":"Tên nàng được Vương Lâm nhắc đến khi hắn chống lại nỗi sợ bản năng trước cánh cửa tím.","chuong":"@c0676"}],"kinhLich":[{"chuong":"@c0676","importance":"normal","tieuDe":"Được Vương Lâm bảo vệ","text":"Trong lúc Thiên Nghịch mở ra cánh cửa tím và khiến Vương Lâm rung động từ linh hồn, hồn phách Uyển Nhi trong pháp bảo trở thành điều hắn quyết phải bảo vệ, khiến hắn không chấp nhận khuất phục trước dị biến.","anchor":"Hắn quyết không để cho bất kỳ ai làm tổn hại đến hai cái linh hồn kia"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"the-thiep","quanHe":"người bảo vệ hồn phách nàng","ghiChu":"Vương Lâm xem hồn phách của nàng trong Thiên Nghịch là điều không thể để bị tổn hại."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0676"]},{"id":"nguoi-dan-ong-toc-den-cuoi-loi-thu","name":"Người đàn ông tóc đen cưỡi Lôi Thú","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Dương Thực, gần viên mãn @c0680","trangThai":"song","blurb":"Một tu sĩ tóc đen xuất hiện trong tinh không ngoài tầng đá vụn Nam Vực La Thiên, cưỡi Lôi Thú khoác giáp đen tiến về Lôi Ngục. Hắn biết truyền thuyết Thiên Nghịch từng lần đầu xuất hiện tại nơi này và nhắc tới việc Lôi Tiên Giới sắp mở.","vaiTro":"Tu sĩ tiến vào Lôi Ngục","tinhCach":[{"text":"Hiểu biết truyền thuyết liên quan Thiên Nghịch và Lôi Ngục","chuong":"@c0678"},{"text":"Hành động có mục tiêu rõ ràng trước khi Lôi Tiên Giới mở ra","chuong":"@c0678"}],"tabs":{"diem":[{"text":"Cưỡi một Lôi Thú mặc giáp đen bay về tầng đá vụn Nam Vực La Thiên.","chuong":"@c0678"},{"text":"Dự định vào Lôi Ngục hấp thụ nguyên lực trước thời điểm Lôi Tiên Giới mở ra.","chuong":"@c0678"},{"text":"Nhắc truyền thuyết hạt châu Thiên Nghịch lần đầu xuất hiện tại tầng đá vụn này.","chuong":"@c0678"}],"kinhLich":[{"text":"Người đàn ông tóc đen cưỡi Lôi Thú mặc giáp đen trong tinh không, hướng tới tầng đá vụn Nam Vực La Thiên để vào Lôi Ngục hấp thụ nguyên lực; hắn đồng thời nhắc Lôi Tiên Giới sắp mở, có thể xuất hiện pháp bảo, tiên thuật và khiến sứ giả Lôi Tiên Điện tranh đoạt.","anchor":"Lôi Tiên Giới đã sắp mở ra, vào lúc này phải vào trong Lôi Ngục hấp thụ một ít nguyên lực.","bridge":true,"khoang":"@c0678"},{"text":"Người đàn ông tóc đen cưỡi Lôi Thú mặc áo giáp tiến vào tầng đá vụn, nhận ra lôi quang dao động dữ dội và khí tức hùng mạnh khác thường. Hắn lộ tu vi Dương Thực, từng quen đến nơi này tu luyện Lôi Nguyên Thuật; khi xuyên qua lớp đá vụn cuối, hắn thấy Vương Lâm lơ lửng bên trên Lôi Trì đã rút nhỏ gần một nửa, rồi bị ánh mắt còn mang khí tức bước thứ ba của Vương Lâm làm tâm thần, tim máu và nguyên lực chấn động.","anchor":"Sắc mặt người đàn ông tóc đen âm trầm, tu vi của hắn đã đạt tới cảnh giới Dương Thực","bridge":true,"khoang":"@c0680"}],"tuViMoc":[{"chuong":"@c0680","canhGioi":"Dương Thực","text":"Tu vi của người đàn ông tóc đen được nêu rõ là đã đạt cảnh giới Dương Thực và gần viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người bị chấn nhiếp","ghiChu":"Gặp Vương Lâm tại Lôi Trì trong lúc Vương Lâm vừa trải qua cảm ngộ khí tức bước thứ ba."}],"tuiDo":{"phapBao":[{"ten":"Áo giáp màu đen của Lôi Thú","loai":"giáp","trangThai":"dang-co","moTa":"Bộ giáp khoác trên Lôi Thú mà người đàn ông tóc đen cưỡi, khiến con thú trông dữ tợn.","nguon":"@c0678"}],"danDuoc":[],"congPhap":[],"linhThu":[{"ten":"Lôi Thú","loai":"tọa kỵ","trangThai":"dang-co","moTa":"Con Lôi Thú mặc giáp đen chở người đàn ông tóc đen tiến về tầng đá vụn Nam Vực La Thiên.","nguon":"@c0678"}],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0678","@c0680"]},{"id":"co-gai-ao-trang","name":"Cô gái áo trắng","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một nữ tử áo trắng xuất hiện ở phía nam tinh cầu do trạng thái của Vương Lâm hóa thành. Nàng cảm thấy nơi này quen thuộc một cách khó hiểu và muốn tìm ra đáp án.","vaiTro":"người bí ẩn trên tinh cầu tâm tượng","tinhCach":[{"text":"nhạy cảm với cảm giác quen thuộc kỳ lạ","chuong":"@c0679"},{"text":"quyết tâm truy tìm lời giải","chuong":"@c0679"}],"tabs":{"diem":[{"text":"Xuất hiện ở phía nam tinh cầu mới hình thành từ trạng thái của Vương Lâm.","chuong":"@c0679"},{"text":"Cảm nhận sự quen thuộc khó giải thích và chủ động muốn tìm đáp án.","chuong":"@c0679"}],"kinhLich":[{"text":"Trên tinh cầu do trạng thái của Vương Lâm hóa thành, cô gái áo trắng bay qua phía nam, cảm thấy nơi này có sự quen thuộc khó hiểu và khẳng định muốn tìm ra đáp án. Qua vô số năm tháng, nàng là một trong ba người duy nhất không biến mất.","anchor":"Ta muốn tìm đến đáp án!","bridge":true,"khoang":"@c0679"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"xuất hiện trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Mối liên hệ cụ thể chưa được nói rõ trong chương."},{"ten":"Người nam trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"cùng là người không biến mất trên tinh cầu","ghiChu":"Cùng tồn tại bền vững qua năm tháng."},{"ten":"Người nữ trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"cùng là người không biến mất trên tinh cầu","ghiChu":"Cùng tồn tại bền vững qua năm tháng."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0679"]},{"id":"nguoi-nam-trong-ho-gia-dinh-phia-bac-tinh-cau","name":"Người nam trong hộ gia đình phía bắc tinh cầu","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một nam nhân không nêu tên sống bình lặng trong hộ gia đình duy nhất ở phía bắc tinh cầu do trạng thái của Vương Lâm hóa thành. Hắn cùng một nữ nhân và cô gái áo trắng là ba người không biến mất qua năm tháng.","vaiTro":"người bất biến phía bắc tinh cầu","tinhCach":[{"text":"bình lặng trong sinh hoạt phàm tục","chuong":"@c0679"},{"text":"thân phận chưa được hé lộ","chuong":"@c0679"}],"tabs":{"diem":[{"text":"Sống trong hộ gia đình duy nhất ở phía bắc tinh cầu mới.","chuong":"@c0679"},{"text":"Là một trong ba người không biến mất dù tinh cầu biến hóa qua năm tháng.","chuong":"@c0679"}],"kinhLich":[{"text":"Trên tinh cầu do trạng thái của Vương Lâm hóa thành, một nam nhân sống cùng một nữ nhân trong hộ gia đình duy nhất ở phía bắc. Khi tinh cầu trải qua vô số năm tháng biến hóa, hắn vẫn là một trong ba người duy nhất không biến mất.","anchor":"duy nhất không biến mất chỉ có ba người.","bridge":true,"khoang":"@c0679"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"xuất hiện trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Mối liên hệ cụ thể chưa được nói rõ trong chương."},{"ten":"Người nữ trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"cùng sống trong hộ gia đình phía bắc","ghiChu":"Hai người cùng xuất hiện trong hộ gia đình duy nhất phía bắc tinh cầu."},{"ten":"Cô gái áo trắng","tag":"khac","quanHe":"cùng là người không biến mất trên tinh cầu","ghiChu":"Cùng tồn tại bền vững qua năm tháng."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0679"]},{"id":"nguoi-nu-trong-ho-gia-dinh-phia-bac-tinh-cau","name":"Người nữ trong hộ gia đình phía bắc tinh cầu","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một nữ nhân không nêu tên sống bình lặng cùng một nam nhân trong hộ gia đình duy nhất ở phía bắc tinh cầu do trạng thái của Vương Lâm hóa thành. Nàng là một trong ba người không biến mất qua vô số năm tháng.","vaiTro":"người bất biến phía bắc tinh cầu","tinhCach":[{"text":"bình lặng trong sinh hoạt phàm tục","chuong":"@c0679"},{"text":"thân phận chưa được hé lộ","chuong":"@c0679"}],"tabs":{"diem":[{"text":"Sống cùng nam nhân trong hộ gia đình duy nhất phía bắc tinh cầu mới.","chuong":"@c0679"},{"text":"Là một trong ba người duy nhất không biến mất dù tinh cầu biến hóa qua năm tháng.","chuong":"@c0679"}],"kinhLich":[{"text":"Trên tinh cầu do trạng thái của Vương Lâm hóa thành, một nữ nhân sống cùng một nam nhân trong hộ gia đình duy nhất ở phía bắc. Qua vô số năm tháng, nàng vẫn là một trong ba người duy nhất không biến mất.","anchor":"duy nhất không biến mất chỉ có ba người.","bridge":true,"khoang":"@c0679"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"xuất hiện trên tinh cầu do trạng thái của Vương Lâm hóa thành","ghiChu":"Mối liên hệ cụ thể chưa được nói rõ trong chương."},{"ten":"Người nam trong hộ gia đình phía bắc tinh cầu","tag":"khac","quanHe":"cùng sống trong hộ gia đình phía bắc","ghiChu":"Hai người cùng xuất hiện trong hộ gia đình duy nhất phía bắc tinh cầu."},{"ten":"Cô gái áo trắng","tag":"khac","quanHe":"cùng là người không biến mất trên tinh cầu","ghiChu":"Cùng tồn tại bền vững qua năm tháng."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0679"]},{"id":"than-cong-ho","name":"Thân Công Hổ","cn":"","aliases":["người đàn ông tóc đen cưỡi Lôi Thú"],"gioiTinh":"nam","theLuc":[{"ten":"Thân Công tộc","trangThai":"gan-bo"},{"ten":"Lôi Tiên Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Dương Thật @c0686","trangThai":"song @c0693","blurb":"Thân Công Hổ là người Thân Công tộc ở nam vực La Thiên, giữ thân phận Nhị cấp sứ giả Lôi Tiên Điện. Sau khi bị dư uy tầm đạo của Vương Lâm áp chế, hắn nhận định Vương Lâm có uy năng giống Đạo Yểm và chủ động dâng Đạo Hồn xin dựa vào ngàn năm.","vaiTro":"Người đầu tiên dựa vào Vương Lâm tại La Thiên","tinhCach":[{"text":"Biết sợ trước uy thế vượt xa nhận thức và nhanh chóng đổi thái độ thành cung kính","chuong":"@c0681"},{"text":"Quyết đoán, dám rút Đạo Hồn làm bảo chứng để đổi lấy cơ hội tu đạo","chuong":"@c0681"},{"text":"Có tham vọng đột phá và rất coi trọng cơ duyên được chỉ điểm","chuong":"@c0681"}],"tabs":{"diem":[{"text":"Là Nhị cấp sứ giả Lôi Tiên Điện, xuất thân Thân Công tộc nam vực La Thiên và có tu vi Dương Thật.","chuong":"@c0681"},{"text":"Sau khi chứng kiến ánh mắt của Vương Lâm, hắn liên hệ hiện tượng ấy với Đạo Yểm trong truyền thuyết.","chuong":"@c0681"},{"text":"Tự rút Đạo Hồn chứa ý cảnh và đạo niệm để xin dựa vào Vương Lâm trong một ngàn năm.","chuong":"@c0681"}],"kinhLich":[{"text":"Thân Công Hổ tới Lôi Trì để tu luyện nguyên lực trước kỳ Lôi Tiên Giới mở ra, nhưng bị ánh mắt còn lưu dư uy tầm đạo của Vương Lâm khóa chặt khiến nguyên lực mất khống chế, nguyên thần như bị thiêu đốt và gần như không thể phản kháng.","anchor":"Ánh mắt của đối phương ẩn chứa lực lượng đáng sợ khiến cho hắn căn bản không sinh nổi tâm tư gì để chống cự.","bridge":true,"khoang":"@c0681"},{"chuong":"@c0681","importance":"normal","tieuDe":"Nhận định Đạo Yểm","text":"Thoát khỏi áp lực tử vong, Thân Công Hổ nhớ tới truyền thuyết Đạo Yểm từng đánh bại tu sĩ bước thứ hai ở La Thiên, từ sợ hãi chuyển sang sùng kính cuồng nhiệt đối với Vương Lâm.","anchor":"Đạo Yểm, cảnh tượng vừa rồi kia tuyệt đối là Đạo Yểm kia trong truyền thuyết nhắc đến."},{"chuong":"@c0681","importance":"major","tieuDe":"Quỳ xin nương tựa","text":"Hắn chính thức tự xưng là Thân Công Hổ, Nhị cấp sứ giả Lôi Tiên Điện, người Thân Công tộc nam vực La Thiên, tu sĩ Dương Thật, rồi quỳ bái xin được dựa vào Vương Lâm.","anchor":"Tiền bối, vãn bối, Thân Công Hổ, người của Thân Công tộc ở nam vực của La Thiên, sứ giả cấp hai Lôi Tiên Điện, tu sĩ cảnh giới Dương Thật khẩn cầu được dựa vào tiền bối!"},{"chuong":"@c0681","importance":"major","tieuDe":"Dâng Đạo Hồn","text":"Khi bị Vương Lâm từ chối, Thân Công Hổ tự rút Đạo Hồn chứa ý cảnh và đạo niệm, xin dựa vào ngàn năm để đổi lấy một lần chỉ điểm khi đột phá; Vương Lâm cuối cùng thu nhận Đạo Hồn của hắn.","anchor":"Hắn nói xong, hai tay bấm tay bắt quyết, áp lên phía trên Thiên Linh cái, lập tức một luồng sáng màu đen từ nơi đỉnh đầu này bay ra, bên trong này ẩn chứa ý cảnh và đạo niệm của hắn."},{"chuong":"@c0681","importance":"normal","tieuDe":"Giải thích Lôi Tiên Giới","text":"Sau khi được thu nhận, Thân Công Hổ nói rõ mình tới Lôi Trì vì Lôi Tiên Giới sắp mở ra; hắn cung cấp tin về mốc mười năm, Lôi Đỉnh, giới hạn Vấn Đỉnh hậu kỳ đại viên mãn và bí pháp Lôi Tiên Điện cho tu sĩ bước thứ hai vào giới.","anchor":"Mười năm nữa, Lôi Tiên Giới sẽ lại mở ra."},{"text":"Sau khi được Vương Lâm cho ở lại, Thân Công Hổ vừa cảm kích vừa bị khuất phục trong đạo tâm vì đã giao đạo hồn và từng bị ánh mắt Vương Lâm làm khiếp sợ; hắn tu luyện trong Lôi Trì để chữa thương, quan sát cách Vương Lâm hấp thụ lôi đình, càng thêm kính phục và chờ cơ hội nhìn thấy thần thông của đối phương.","anchor":"Lúc này nghe Vương Lâm đồng ý cho hắn ở lại, Thân Công Hổ lập tức dâng lên mối cảm kích.","bridge":true,"khoang":"@c0682"},{"text":"Thân Công Hổ chứng kiến Vương Lâm ban đầu chỉ đi được một đoạn ở rìa Lôi Trì nên thất vọng và dao động sùng kính; khi thấy Vương Lâm bước tiếp với lôi quang hiện dưới chân, hắn kinh hãi, cho rằng đây mới là lôi thần thông mình chờ đợi và sự cuồng nhiệt với Vương Lâm lại tăng mạnh.","anchor":"Cái hắn đợi hai năm để xem chính là thần thông như thế này","bridge":true,"khoang":"@c0683"},{"text":"Thân Công Hổ đối đầu Chiến Không Liệt trong khi thương thế chưa hồi phục, dựa vào sự hiện diện của Vương Lâm để uy hiếp đối phương; sau khi Vương Lâm tuyên bố đây là khảo nghiệm, hắn công khai gọi Vương Lâm là Tôn chủ trước mặt Chiến Không Liệt, xác nhận quan hệ thần phục bằng lời nói.","anchor":"Tôn chủ yên tâm, Thân Công Hổ sẽ không thua đâu!","bridge":true,"khoang":"@c0684"},{"text":"Thân Công Hổ nuốt đan dược phát hồng quang để áp chế thương thế và cưỡng ép khí tức tăng lên, rồi thi triển Dẫn lôi thuật đấu với Chiến Không Liệt. Sau khi được Vương Lâm thị phạm lôi quang, hắn cảm thấy tầng ngăn cách trong nhận thức bị xuyên thủng, càng sùng bái Vương Lâm và tiếp tục muốn giao chiến.","anchor":"Trong đầu hắn sáng tỏ thông suốt, như thể một tầng giấy ngăn cách mỏng manh đã bị xuyên thủng.","bridge":true,"khoang":"@c0685"},{"chuong":"@c0686","importance":"normal","tieuDe":"Ngộ căn nguyên lôi","text":"Thân Công Hổ vẫn xưng Vương Lâm là Tôn Chủ, nuốt đan dược để tạm áp chế thương thế rồi dùng Dẫn lôi thuật quyết chiến Chiến Không Liệt; sau khi được Vương Lâm chỉ ra thiếu lôi hồn và biểu diễn ánh sáng căn nguyên, hắn hiểu ra phương hướng trở về căn nguyên, lòng sùng bái đối với Vương Lâm càng sâu.","anchor":"Trong đầu hắn sáng tỏ thông suốt, như thể một tầng giấy ngăn cách mỏng manh đã bị xuyên thủng."},{"chuong":"@c0690","importance":"normal","tieuDe":"Ngọc giản chỉ đường","text":"Không trực tiếp xuất hiện, nhưng ngọc giản của hắn giúp Vương Lâm tìm được tu chân tinh có hai gia tộc thường nhận nhiều Lôi Đỉnh; Vương Lâm cũng cân nhắc không tìm hắn quá nhiều để tránh lộ sơ hở.","anchor":"Trong ngọc giản của Thân Công Hổ có nói, tu chân tinh này có hai gia tộc tu chân, mỗi một lần Lôi Tiên Giới mở ra, hai gia tộc này đều giành được nhiều Lôi Đỉnh nhất."},{"text":"Có mặt trước cửa Lôi Tiên Giới, bị Đường Ngôn Phong mỉa mai vì phụ thuộc Vương Lâm và đạo hồn không đầy đủ; dù chịu áp lực từ gia tộc và Lôi Tiên Điện suốt hai mươi năm, hắn không hối hận và nhờ đạo hồn cảm nhận khí tức Tôn Chủ trong sao băng lôi đình.","anchor":"Bên trong đạo sao băng lôi đình kia, nhờ có đạo hồn, nên hăn cảm nhận được một tia khí tức của Tôn Chủ.","bridge":true,"khoang":"@c0693"}],"tuViMoc":[{"chuong":"@c0681","canhGioi":"Dương Thật","text":"Thân Công Hổ tự xưng là tu sĩ cảnh giới Dương Thật khi cầu dựa vào Vương Lâm.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người được hắn dựa vào","ghiChu":"Thân Công Hổ dâng Đạo Hồn và xin nương tựa Vương Lâm trong ngàn năm."},{"ten":"Lôi Thú của Thân Công Hổ","tag":"khac","quanHe":"Tọa kỵ","ghiChu":"Tọa kỵ Lôi Thú đi cùng hắn tới Lôi Trì và cũng bị dư uy ánh mắt của Vương Lâm áp chế."},{"ten":"Điện chủ Lôi Tiên Điện","tag":"cap-tren","quanHe":"Người đứng đầu thế lực","ghiChu":"Thân Công Hổ nhắc Điện chủ Lôi Tiên Điện như mốc so sánh áp lực và người từng đánh giá thiên tư của hắn."},{"ten":"Chiến Không Liệt","tag":"doi-thu","quanHe":"Đối thủ trong Lôi Trì, bị Thân Công Hổ uy hiếp rời đi rồi chuẩn bị giao chiến bằng lôi pháp.","ghiChu":"Hai bên có thế đối đầu rõ rệt."},{"ten":"Đường Ngôn Phong","tag":"doi-thu","quanHe":"người mỉa mai trước cửa Lôi Tiên Giới","ghiChu":"Đường Ngôn Phong chế giễu chuyện Thân Công Hổ có Tôn Chủ và đạo hồn không đầy đủ."}],"tuiDo":{"phapBao":[{"ten":"Đạo Hồn của Thân Công Hổ","loai":"vật bảo chứng tu đạo","trangThai":"mat","moTa":"Hắn tự rút Đạo Hồn chứa ý cảnh và đạo niệm để giao cho Vương Lâm làm bảo chứng nương tựa ngàn năm.","nguon":"@c0681"}],"danDuoc":[],"congPhap":[],"linhThu":[{"ten":"Lôi Thú của Thân Công Hổ","loai":"tọa kỵ","trangThai":"dang-co","moTa":"Lôi Thú của hắn cùng chịu uy áp từ ánh mắt Vương Lâm, thân thể gần như tan rã rồi cúi đầu mất hết cao ngạo.","nguon":"@c0681"}],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0681","@c0682","@c0683","@c0684","@c0685","@c0686","@c0690","@c0693"]},{"id":"loi-thu-cua-than-cong-ho","name":"Lôi Thú của Thân Công Hổ","cn":"","aliases":["Lôi Thú mặc giáp"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thân Công Hổ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ @c0682","trangThai":"song","blurb":"Lôi Thú của Thân Công Hổ là tọa kỵ đưa hắn tới Lôi Trì. Nó chịu dư uy ánh mắt của Vương Lâm nặng nề, thân thể gần như tan rã rồi cúi đầu mất hết vẻ cao ngạo.","vaiTro":"Tọa kỵ của Thân Công Hổ","tinhCach":[{"text":"Vốn cao ngạo nhưng bị áp chế đến khuất phục trước uy áp của Vương Lâm","chuong":"@c0681"}],"tabs":{"diem":[{"text":"Cùng Thân Công Hổ xuất hiện tại Lôi Trì trước khi Lôi Tiên Giới mở ra.","chuong":"@c0681"},{"text":"Chịu tác động trực tiếp từ dư uy ánh mắt của Vương Lâm, thân thể tan rã nhanh chóng như trở về bụi đất.","chuong":"@c0681"}],"kinhLich":[{"text":"Khi Thân Công Hổ bị ánh mắt của Vương Lâm áp chế, tọa kỵ Lôi Thú cũng chịu áp lực sâu hơn, thân thể tan rã nhanh bằng mắt thường có thể thấy, sau đó cúi đầu không còn cao ngạo.","anchor":"Thân thể của nó dùng mắt thường cũng có thể thấy được tốc độ, tan rã một cách nhanh chóng, giống như trở lại bụi đất.","bridge":true,"khoang":"@c0681"},{"text":"Con Lôi Thú mặc giáp của Thân Công Hổ vốn sắp mọc Lôi Giác nhưng đã bị ánh mắt Vương Lâm phá vỡ kiêu ngạo; khi Lôi Thú sừng bạc của Vương Lâm trừng mắt, nó lập tức lùi lại, không dám tới gần, rồi cũng nhìn Vương Lâm với vẻ kính sợ.","anchor":"Lôi Thú của Thân Công Hổ lập tức lui ra sau vài bước, không dám tới gần.","bridge":true,"khoang":"@c0682"},{"text":"Lôi Thú mặc giáp của Thân Công Hổ cảm nhận sâu hơn chủ nhân rằng hiện tượng trong Lôi Trì không phải nghênh đón đơn thuần, mà là Vương Lâm đang đạp lên Lôi Trì; bản năng Lôi Thú khiến nó sinh ra kính sợ và thần phục sâu với Vương Lâm.","anchor":"mỗi bước chân của Vương Lâm rõ ràng đều đang đạp lên trên Lôi Trì này","bridge":true,"khoang":"@c0683"},{"text":"Lôi Thú đi bên cạnh Thân Công Hổ, gầm gừ với Chiến Không Liệt và ngưng tụ sấm sét để phối hợp giao chiến; nhưng ánh mắt kính sợ của nó khi nhìn Vương Lâm khiến Chiến Không Liệt càng thêm nghi ngờ thân phận của Vương Lâm.","anchor":"Ánh mắt Lôi Thú này để lộ ra manh mối, không thể suy nghĩ sâu xa","bridge":true,"khoang":"@c0684"}],"tuViMoc":[],"nhanMach":[{"ten":"Thân Công Hổ","tag":"khac","quanHe":"Chủ nhân","ghiChu":"Là tọa kỵ của Thân Công Hổ."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị uy áp áp chế","ghiChu":"Dư uy ánh mắt của Vương Lâm khiến nó gần như tan rã."},{"ten":"Chiến Không Liệt","tag":"doi-thu","quanHe":"Gầm gừ và chuẩn bị phối hợp với Thân Công Hổ đối đầu Chiến Không Liệt.","ghiChu":"Lần đầu đối diện trong Lôi Trì."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0681","@c0682","@c0683","@c0684"]},{"id":"dien-chu-loi-tien-dien","name":"Điện chủ Lôi Tiên Điện","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Lôi Tiên Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Điện chủ Lôi Tiên Điện là người đứng đầu Lôi Tiên Điện tại La Thiên Tinh Vực. Trong lời Thân Công Hổ, nhân vật này được dùng làm mốc so sánh áp lực và từng đánh giá thiên tư của Thân Công Hổ thuộc nhóm nổi bật của La Thiên.","vaiTro":"Người đứng đầu Lôi Tiên Điện","tinhCach":[{"text":"Được nhắc qua đánh giá thiên tư và uy áp, chưa trực tiếp xuất hiện","chuong":"@c0681"}],"tabs":{"diem":[{"text":"Được Thân Công Hổ lấy làm mốc so sánh áp lực khi kinh sợ trước ánh mắt của Vương Lâm.","chuong":"@c0681"},{"text":"Từng đánh giá thiên tư Thân Công Hổ thuộc nhóm ba mươi người đứng đầu La Thiên.","chuong":"@c0681"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Thân Công Hổ","tag":"cap-tren","quanHe":"Cấp trên trong Lôi Tiên Điện","ghiChu":"Thân Công Hổ là Nhị cấp sứ giả Lôi Tiên Điện và nhắc tới Điện chủ trong chương này."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0681"]},{"id":"chien-khong-liet","name":"Chiến Không Liệt","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Chiến gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Dương Thật @c0686","trangThai":"song","blurb":"Chiến Không Liệt là nam tử âm nhu thuộc Chiến gia, cưỡi kiếm gỗ màu tím tiến vào Lôi Trì. Hắn có tu vi Dương Thực viên mãn, thận trọng trước vị trí của Vương Lâm và thái độ bất thường của Thân Công Hổ cùng Lôi Thú.","vaiTro":"Đối thủ của Thân Công Hổ trong Lôi Trì","tinhCach":[{"text":"Thận trọng, không tùy tiện ra tay khi gặp tình huống quỷ dị.","chuong":"@c0684"},{"text":"Giỏi dò xét qua lời nói và phản ứng của linh thú.","chuong":"@c0684"},{"text":"Tự tin vào tu vi nhưng vẫn kiêng dè thân phận chưa rõ của Vương Lâm.","chuong":"@c0684"}],"tabs":{"diem":[{"text":"Cưỡi kiếm gỗ màu tím tiến vào khu vực Lôi Trì và được Thân Công Hổ gọi đích danh.","chuong":"@c0684"},{"text":"Nhận ra vị trí sâu bất thường của Vương Lâm trong Lôi Trì nên nghi ngờ đối phương có pháp bảo mạnh, ẩn giấu tu vi hoặc liên quan tới Lôi Tiên Điện.","chuong":"@c0684"},{"text":"Bị hai chữ Tôn chủ của Thân Công Hổ làm chấn động, càng kiêng dè quan hệ giữa Thân Công Hổ và Vương Lâm.","chuong":"@c0684"}],"kinhLich":[{"text":"Chiến Không Liệt cưỡi kiếm gỗ màu tím tới Lôi Trì, nhận ra Thân Công Hổ và nhanh chóng chú ý tới Vương Lâm ở vòng trong; hắn suy đoán Vương Lâm có pháp bảo cực mạnh, ẩn giấu tu vi hoặc là sứ giả Lôi Tiên Điện, sau đó chuẩn bị giao chiến với Thân Công Hổ nhưng chấn động khi nghe Thân Công Hổ gọi Vương Lâm là Tôn chủ.","anchor":"Chuyện này thật sự rất quỷ dị, nếu không phải đối phương có pháp bảo hung mạnh không thể tưởng tượng, thì chính là đã ẩn giấu tu vi thực sự.","bridge":true,"khoang":"@c0684"},{"text":"Chiến Không Liệt nghi ngờ Vương Lâm là tiền bối ẩn tu sau khi thấy Thân Công Hổ gọi hắn là Tôn Chủ, rồi dùng kiếm gỗ và kiếm khí đối kháng Dẫn lôi thuật. Chứng kiến Vương Lâm chỉ điểm căn nguyên lôi quang, hắn cung kính nhận lỗi, tiết lộ mình đã nhận thư triệu tập và sẽ cùng Thân Công Hổ làm sứ giả Lôi Tiên Điện, sau đó rời khỏi Lôi Trì.","anchor":"vừa rồi có mạo phạm, mong tiền bối bỏ qua, vãn bối lập tức rời khỏi!","bridge":true,"khoang":"@c0685"},{"text":"Chiến Không Liệt từ thái độ của Thân Công Hổ suy đoán Vương Lâm có thể là tiền bối ẩn tu, dùng kiếm gỗ giao thủ một chiêu với Thân Công Hổ; sau khi thấy Vương Lâm chỉ điểm căn nguyên lôi đình, hắn cúi đầu tự xưng vãn bối, nhận lỗi rồi rời đi, đồng thời nói mình đã nhận thư triệu tập của Lôi Tiên Điện.","anchor":"Vãn bối Chiến Không Liệt, không biết tiền bối ở trong này, vừa rồi có mạo phạm","bridge":true,"khoang":"@c0686"}],"tuViMoc":[{"chuong":"@c0684","canhGioi":"Dương Thực viên mãn","text":"Tu vi của Chiến Không Liệt được nêu là Dương Thực viên mãn khi hắn tiến vào Lôi Trì và đánh giá vị trí của Vương Lâm.","importance":"minor"}],"tuVi":"","nhanMach":[{"ten":"Thân Công Hổ","tag":"doi-thu","quanHe":"Đối đầu trong Lôi Trì, bị Thân Công Hổ uy hiếp rời đi trong ba nhịp thở.","ghiChu":"Hai bên chuẩn bị giao chiến bằng lôi pháp."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Nghi ngờ thân phận và thực lực của Vương Lâm khi thấy hắn ở sâu trong vòng trong Lôi Trì.","ghiChu":"Chưa trực tiếp giao chiến."}],"tuiDo":{"phapBao":[{"ten":"Kiếm gỗ màu tím","loai":"pháp bảo","trangThai":"dang-co","moTa":"Pháp bảo phi hành và chiến đấu, phát tử quang, có hàn khí sắc bén và phối hợp với lôi quang màu tím khi Chiến Không Liệt thi triển thần thông.","nguon":"@c0684"}],"danDuoc":[],"congPhap":[{"ten":"Nguyên lực thần thông của Chiến Không Liệt","loai":"thần thông","trangThai":"dang-co","moTa":"Bấm quyết tạo lôi quang màu tím, phối hợp kiếm khí từ kiếm gỗ, trong uy phong ẩn chứa thiên địa nguyên khí.","nguon":"@c0684"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0684","@c0685","@c0686"]},{"id":"hua-lap-quoc","name":"Hứa Lập Quốc","gioiTinh":"nam","canhGioiCaoNhat":"Kiếm linh trong tiên kiếm @c0686","trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Hứa Lập Quốc tuyên bố đã nuốt kiếm ý viễn cổ, sắp thành kiếm linh chân chính và tự khoe mình rất lợi hại; chưa nói hết, hắn đã bị Vương Lâm vỗ túi trữ vật, bấm quyết áp chế kiếm ý cùng tiếng la hét trở lại.","anchor":"Không chờ hắn nói xong, tay phải Vương Lâm bấm quyết, đặt lên túi trữ vật.","bridge":true,"khoang":"@c0686"},{"text":"Hứa Lập Quốc phá được phong ấn túi trữ vật, kêu gào đòi đảo ngược thân phận chủ tớ với Vương Lâm; khi được gọi ra, hắn hóa thành đại kiếm mang viễn cổ kiếm ý lao tới nhưng bị Côn Cực Tiên cuốn vào vòng nhân quả làm tan rã, cuối cùng hoảng sợ cầu xin và cố dùng nhân quả phản biện lại chủ nhân.","anchor":"Điều ta muốn là từ nay về sau ngươi phải đi theo lão tử, thân phận chúng ta đổi lại cho nhau","bridge":true,"khoang":"@c0688"},{"text":"Hứa Lập Quốc bị Côn Cực Tiên dung nhập ý cảnh dọa cho khuất phục, vội nịnh nọt Vương Lâm; sau khi được tạm thả trong phạm vi quanh núi để lĩnh ngộ viễn cổ kiếm ý, hắn lén dùng ảo thuật lừa tu sĩ qua đường, rồi nhắm tới thân thể con trai Trương Tân Hải nên bị Vương Lâm cấm túc trong trăm trượng.","anchor":"Ta cũng chỉ muốn tạm thời dung nhập vào trong thân thể đó, sau khi chiếm cứ cảm thụ một chút cảm giác có thân thể ra sao, thật là nhiều chuyện…","bridge":true,"khoang":"@c0689"}],"tuViMoc":[],"nhanMach":[{"ten":"Con trai Trương Tân Hải","tag":"khac","quanHe":"nhắm tới thân thể","ghiChu":"Hứa Lập Quốc muốn tạm dung nhập thân thể người này để cảm nhận cảm giác có thân xác."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0686","@c0688","@c0689"]},{"id":"truong-tan-hai","name":"Trương Tân Hải","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Trương gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không nêu rõ trong @c0687","trangThai":"song","blurb":"Trương Tân Hải là gia chủ đời này của Trương gia trên Thanh Linh Tinh. Hắn đình trệ ở Nguyên Anh hậu kỳ lâu năm, mang tử khí lên Hoành Vân Phong chuẩn bị tọa hóa thì gặp Vương Lâm.","vaiTro":"Gia chủ Trương gia","tinhCach":[{"text":"Trầm ổn trước lúc tọa hóa nhưng bị chấn động khi gặp tồn tại vượt ngoài thần thức","chuong":"@c0686"},{"text":"Gắn bó với truyền thống tọa hóa của Trương gia trên Hoành Vân Phong","chuong":"@c0686"}],"tabs":{"diem":[{"text":"Là gia chủ đời này của Trương gia, gia tộc tu chân mạnh trên Thanh Linh Tinh.","chuong":"@c0686"},{"text":"Đình trệ Nguyên Anh hậu kỳ, lên Hoành Vân Phong trong tử khí để chuẩn bị tọa hóa.","chuong":"@c0686"},{"text":"Nhìn thấy Vương Lâm bằng mắt thường nhưng thần thức lại không phát hiện được, vì vậy sinh kinh sợ.","chuong":"@c0686"},{"text":"Tuổi thọ sắp cạn, đến Hoành Vân Sơn Phong định quy tiên trước khi gặp Vương Lâm.","chuong":"@c0687"},{"text":"Được Vương Lâm dùng linh quyết thiêu đốt linh lực để tăng thêm mười năm tuổi thọ.","chuong":"@c0687"},{"text":"Đại diện Trương gia truyền đạt mệnh lệnh thu oán khí phàm nhân, để gia tộc xuất hiện với thân phận sứ giả của Vương Lâm.","chuong":"@c0687"}],"kinhLich":[{"text":"Trương Tân Hải mang tử khí lên Hoành Vân Phong, nơi tộc nhân Trương gia thường bế quan tọa hóa trước khi hết thọ nguyên; hắn phát hiện Vương Lâm đứng trên thạch đài dù thần thức không thấy gì, nên kinh sợ lùi lại.","anchor":"Thần thức hắn xem xét nơi đó không hề có bóng người, nhưng mắt thường lại nhìn thấy cực kỳ rõ ràng.","bridge":true,"khoang":"@c0686"},{"chuong":"@c0687","importance":"major","tieuDe":"Nhận lệnh thu oán khí","text":"Trương Tân Hải vốn đến Hoành Vân Sơn Phong chờ quy tiên, bị khí tức của Vương Lâm áp chế và được ban thêm mười năm thọ nguyên; hắn nhận nhiệm vụ tích góp oán khí phàm nhân trong thiên hạ, đưa Trương gia ra làm sứ giả của Vương Lâm, nhưng sau năm năm tiến độ vẫn chưa đến bốn phần.","anchor":"Thay đổi vận mệnh của ngươi thì ta không làm được, nhưng lấy linh lực của ngươi thiêu đốt, tăng tuổi thọ thêm mười năm thì có thể làm được."},{"text":"Trương Tân Hải tuổi thọ gần hết, dẫn con trai tới Hoành Vân Phong, giao ngọc giản chứa oán khí phàm nhân toàn Thanh Linh Tinh cho Vương Lâm và xin để con kế nhiệm việc làm sứ giả bên ngoài núi; ông nhận đan dược cùng hạt giống Thăng Tiên Quả để đưa về Trương gia thực hiện nhiệm vụ lâu dài.","anchor":"Vãn bối Trương Tân Hải, đã hoàn thành việc của tiền bối, xin được cầu kiến!","bridge":true,"khoang":"@c0689"}],"tuViMoc":[{"chuong":"@c0686","canhGioi":"Nguyên Anh hậu kỳ","text":"Trương Tân Hải đã đình trệ ở Nguyên Anh hậu kỳ lâu nhất trong đời, tới lúc thọ nguyên gần hết vẫn chưa đột phá.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người bí ẩn xuất hiện trên Hoành Vân Phong","ghiChu":"Trương Tân Hải nhìn thấy Vương Lâm trên thạch đài nhưng thần thức không phát hiện được."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"người ban thọ nguyên và giao nhiệm vụ","ghiChu":"Trương Tân Hải nhận lệnh thu oán khí phàm nhân cho Vương Lâm để đổi lấy sự bảo đảm hương hỏa Trương gia khi Vương Lâm còn ở Thanh Linh Tinh."},{"ten":"Con trai Trương Tân Hải","tag":"cha-me","quanHe":"cha con","ghiChu":"Ông đưa con trai tới gặp Vương Lâm để kế nhiệm việc phụng sự bên ngoài Hoành Vân Phong."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0686","@c0687","@c0689"]},{"id":"van-thu","name":"Văn Thú","canhGioiCaoNhat":"khong-ro","trangThai":"song","tabs":{"kinhLich":[{"text":"Văn Thú được Vương Lâm thả ra cùng Lôi Oa và Xạ Thần Xa; ban đầu nó không muốn rời Lôi Oa, sau lại chuyển hứng thú sang Lôi Thú do Xạ Thần Xa hóa thành.","anchor":"Ngay sau đó, Xạ Thần Xa bay ra, ầm một cái ở giữa không trung hóa thành Lôi Thú.","bridge":true,"khoang":"@c0689"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0689"]},{"id":"loi-oa","name":"Lôi Oa","canhGioiCaoNhat":"khong-ro","trangThai":"song","tabs":{"kinhLich":[{"text":"Lôi Oa được Vương Lâm thả ra từ túi trữ vật, lập tức đối địch với Lôi Thú do Xạ Thần Xa hóa thành, nhưng vì tu vi chưa đủ nên không chủ động tấn công.","anchor":"Ngay sau đó, Xạ Thần Xa bay ra, ầm một cái ở giữa không trung hóa thành Lôi Thú.","bridge":true,"khoang":"@c0689"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0689"]},{"id":"con-trai-truong-tan-hai","name":"Con trai Trương Tân Hải","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Trương gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh đại viên mãn @c0689","trangThai":"song","blurb":"Con trai Trương Tân Hải là tu sĩ Trương gia trên Thanh Linh Tinh, được cha đưa tới Hoành Vân Phong để kế nhiệm việc làm sứ giả bên ngoài núi. Trong lần đầu ra mắt, ông bị Hứa Lập Quốc nhắm tới vì thân thể.","vaiTro":"sứ giả kế nhiệm của Trương gia","tinhCach":[{"text":"kính sợ Vương Lâm và Hoành Vân Phong","chuong":"@c0689"},{"text":"hoảng hốt sau khi bị Hứa Lập Quốc trêu chọc","chuong":"@c0689"}],"tabs":{"diem":[{"text":"Được Trương Tân Hải dẫn tới để thay cha tiếp tục phụng sự bên ngoài Hoành Vân Phong.","chuong":"@c0689"},{"text":"Có tu vi Nguyên Anh đại viên mãn nhưng vẫn bị Hứa Lập Quốc nhắm tới và khiến hoảng hốt.","chuong":"@c0689"}],"kinhLich":[{"chuong":"@c0689","importance":"normal","tieuDe":"Kế nhiệm sứ giả Trương gia","text":"Con trai Trương Tân Hải được cha đưa tới gặp Vương Lâm để sau này thay cha phụng sự bên ngoài Hoành Vân Phong; trong lần này, ông bị Hứa Lập Quốc dụ vào sương đen với ý định tạm chiếm thân thể, rồi rời núi trong trạng thái hoảng hốt kỳ dị.","anchor":"Ta cũng chỉ muốn tạm thời dung nhập vào trong thân thể đó, sau khi chiếm cứ cảm thụ một chút cảm giác có thân thể ra sao, thật là nhiều chuyện…"}],"tuViMoc":[{"chuong":"@c0689","canhGioi":"Nguyên Anh đại viên mãn","text":"Khi được Trương Tân Hải dẫn tới Hoành Vân Phong, ông được ghi nhận là tu sĩ Nguyên Anh đại viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Trương Tân Hải","tag":"cha-me","quanHe":"cha con","ghiChu":"Được cha đưa tới để kế nhiệm việc làm sứ giả bên ngoài Hoành Vân Phong."},{"ten":"Hứa Lập Quốc","tag":"khac","quanHe":"bị nhắm tới","ghiChu":"Bị Hứa Lập Quốc muốn tạm dung nhập thân thể để cảm nhận thân xác."},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"phụng sự","ghiChu":"Được Vương Lâm chấp nhận làm sứ giả bên ngoài Hoành Vân Phong thay cha."}],"tuiDo":{"phapBao":[],"danDuoc":[{"ten":"Đan dược Vương Lâm ban cho Trương gia","trangThai":"dang-co","moTa":"Được Vương Lâm ban đan dược nhằm tăng chút cơ hội Hóa Thần.","nguon":"@c0689"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0689"]},{"id":"lao-gia-truong-gia","name":"Lão già Trương gia","aliases":["lão già Âm Hư","đạo hữu giữ Lôi Đỉnh"],"gioiTinh":"nam","theLuc":[{"ten":"Trương gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Âm Hư @c0691","trangThai":"song @c0691","blurb":"Tu sĩ Trương gia ở Thánh Đàn Tinh, vừa đạt Âm Hư khi dẫn đội tu sĩ trở về từ Lôi Tiên Điện. Lão nghi Vương Lâm giả mạo sứ giả và giao chiến vì Lôi Đỉnh.","vaiTro":"đối thủ giữ Lôi Đỉnh","tinhCach":"cẩn trọng; sĩ diện; đa nghi","tabs":{"diem":[{"text":"Vừa bước vào Âm Hư nhưng đã đủ khiến đội tu sĩ Thánh Đàn Tinh lấy lão làm trung tâm.","chuong":"@c0690"},{"text":"Nghi Vương Lâm là kẻ giả mạo sứ giả Lôi Tiên Điện vì thời điểm các sứ giả thật đều tụ tập ở Lôi Tiên Điện.","chuong":"@c0690"}],"kinhLich":[{"text":"Dẫn hơn mười tu sĩ trở về trước khi Lôi Tiên Giới mở, nghi Vương Lâm giả mạo sứ giả Lôi Tiên Điện và cự tuyệt giao Lôi Đỉnh; sau đó dùng hắc hỏa, khiên lửa chống khôi lỗi Tiên Vệ nhưng bị phá phòng ngự, rồi kinh hãi khi thấy Trừu Linh Chi Lai.","anchor":"Vốn tưởng rằng chỉ là tin đồn vớ vẩn, hôm nay nhìn thấy ngươi, lão phu dĩ nhiên đã xác định ngươi chính là người giả mạo kia!","bridge":true,"khoang":"@c0690"},{"chuong":"@c0691","importance":"normal","tieuDe":"Trao đổi Đệ Tam Nhãn","text":"Dùng Đệ Tam Nhãn chống Vương Lâm nhưng mất Lôi Đỉnh; sau đó bị Sát Lục Tiên Quyết làm động tâm, đồng ý đổi truyền thừa gia tộc lấy ba thần thông của Vương Lâm, đồng thời cố ý ghi sai vài chỗ trong ngọc giản.","anchor":"Đạo hữu dừng lại. Sát Lục Tiên Quyết này, cùng với Tịch Diệt Chỉ và Hóa Ma Chỉ lúc trước, ta trao đổi với ngươi!"}],"tuViMoc":[{"chuong":"@c0690","canhGioi":"Âm Hư","text":"Xuất hiện trong đội tu sĩ trở về với thân phận lão già vừa đạt Âm Hư.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đối thủ tranh đoạt Lôi Đỉnh","ghiChu":"Giao chiến khi bị Vương Lâm yêu cầu giao một chiếc Lôi Đỉnh."}],"tuiDo":{"phapBao":[{"ten":"Lôi Đỉnh","trangThai":"dang-co","moTa":"Trương gia có ba chiếc, lão do dự không muốn giao ra vì thể diện.","nguon":"@c0690"}],"danDuoc":[],"congPhap":[{"ten":"Hắc hỏa thần thông","trangThai":"thi-trien","moTa":"Tạo hắc hỏa bao phủ bốn phía để đối phó khôi lỗi Tiên Vệ.","nguon":"@c0690"},{"ten":"Khiên lửa","trangThai":"thi-trien","moTa":"Tạo khiên lửa phòng ngự nhưng bị Tiên Vệ đánh vỡ.","nguon":"@c0690"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0690","@c0691"]},{"id":"loi-thu-xa-than-xa-c0604","name":"Lôi Thú","trangThai":"song @c0691","tabs":{"kinhLich":[{"text":"Chở Vương Lâm rời khỏi chỗ lão già, phun tia chớp và tỏ vẻ khinh thường khi quay lại sau khi lão già đồng ý giao dịch.","anchor":"Đạo hữu dừng lại. Sát Lục Tiên Quyết này, cùng với Tịch Diệt Chỉ và Hóa Ma Chỉ lúc trước, ta trao đổi với ngươi!","bridge":true,"khoang":"@c0691"}],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0691"]},{"id":"khoi-loi-tien-ve","name":"Khôi lỗi Tiên Vệ","trangThai":"khong-ro @c0694","tabs":{"kinhLich":[{"text":"Được Vương Lâm điều đi bắt một con mãnh thú để làm vật thử Sát Lục Tiên Quyết trước mặt lão già Âm Hư.","anchor":"Kiếm khí nhập vào cơ thể, mãnh thú lập tức kêu thảm, trong nháy mắt thân mình lập tức ở trước lão già hai mắt đang trợn tròn, nhanh chóng héo rũ.","bridge":true,"khoang":"@c0691"},{"text":"Từ hư ảnh sau lưng Vương Lâm đi ra hộ pháp khi hắn thổ nạp trong thạch thất; sau đó được điều khiển đánh thử các vị trí để xác định các hướng đều bị ngăn, chỉ phía trước có thể mở.","anchor":"Con rối tiên vệ đi ra, ngồi đối diện với Vương Lâm, hai mắt cảnh giác, làm hộ pháp cho hắn.","bridge":true,"khoang":"@c0694"}],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0691","@c0694"],"aliases":["Con rối tiên vệ"]},{"id":"duong-ngon-phong","name":"Đường Ngôn Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"La Thiên Tinh Vực","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"bước thứ hai @c0693","trangThai":"song @c0693","blurb":"Tu sĩ trung niên áo lam họ Đường, ngồi gần Thân Công Hổ trước cửa Lôi Tiên Giới. Hắn dùng giọng âm dương quái lạ mỉa mai việc Thân Công Hổ phụ thuộc Tôn Chủ.","vaiTro":"tu sĩ khiêu khích Thân Công Hổ","tinhCach":"châm chọc; tự phụ; quan sát nhanh","tabs":{"diem":[{"text":"Biết lời đồn Thân Công Hổ có Tôn Chủ và đạo hồn không đầy đủ, rồi dùng chuyện này để công kích.","chuong":"@c0693"},{"text":"Khi sao băng lôi đình lao vào cửa trước thời hạn, hắn kinh ngạc tự hỏi đó là gì.","chuong":"@c0693"}],"kinhLich":[{"text":"Ngồi trước cửa Lôi Tiên Giới cạnh Thân Công Hổ, hắn nhắc lời đồn về Tôn Chủ và đạo hồn không đầy đủ để chế giễu; sau đó chứng kiến sao băng lôi đình xông thẳng vào cửa.","anchor":"Đường mỗ vốn không tin. Nhưng lúc này nhìn thấy đạo hồn của Thân Công huynh không được đầy đủ, xem ra lời đồn này là thật!","bridge":true,"khoang":"@c0693"}],"tuViMoc":[],"nhanMach":[{"ten":"Thân Công Hổ","tag":"doi-thu","quanHe":"người bị hắn mỉa mai","ghiChu":"Châm chọc Thân Công Hổ trước cửa Lôi Tiên Giới."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0693"]},{"id":"tu-si-am-hu-tha-phan-than","name":"Tu sĩ Âm Hư thả phân thân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"La Thiên Tinh Vực","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Âm Hư @c0693","trangThai":"tu-vong @c0693","blurb":"Tu sĩ vô danh trước cửa Lôi Tiên Giới, bị kích thích bởi việc sao băng lôi đình vào trước thời hạn. Hắn dùng phân thân thử cửa nhưng bị lôi điện đỏ sậm truy diệt cả bản thể.","vaiTro":"người thử cửa thất bại","tinhCach":"liều lĩnh; tò mò; đánh giá sai nguy hiểm","tabs":{"diem":[{"text":"Đạt Âm Hư nhưng vẫn không chống nổi tia chớp đỏ sậm từ cửa Lôi Tiên Giới.","chuong":"@c0693"},{"text":"Cái chết của hắn chứng minh sao băng lôi đình vào được là ngoại lệ, không phải quy tắc phổ thông.","chuong":"@c0693"}],"kinhLich":[{"text":"Sau khi thấy sao băng lôi đình vào được, hắn dùng phân thân tiếp xúc cửa Lôi Tiên Giới; phân thân tan vỡ, bản thể bị tia chớp đỏ sậm truy kích và chết cùng nguyên thần, túi trữ vật.","anchor":"Thân mình tu sĩ kia run lên, cả người cùng với nguyên thần và túi trữ vật, toàn bộ đều tan vỡ.","bridge":true,"khoang":"@c0693"}],"tuViMoc":[{"chuong":"@c0693","canhGioi":"Âm Hư","text":"Xuất hiện trước cửa Lôi Tiên Giới với tu vi Âm Hư rồi bị diệt sát.","importance":"major"}],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Phân thân thử cửa","trangThai":"da-dung","moTa":"Tách phân thân tiếp xúc sấm sét đỏ sậm, dẫn tới bản thể bị truy diệt.","nguon":"@c0693"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Túi trữ vật","trangThai":"hong","moTa":"Cùng thân thể và nguyên thần tan vỡ dưới tia chớp đỏ sậm.","nguon":"@c0693"}]}},"nguon":["@c0693"]},{"id":"lao-gia-toc-bac-trong-loi-tien-gioi","name":"Lão già tóc bạc trong Lôi Tiên Giới","cn":"","aliases":["Lão giả tóc bạc"],"gioiTinh":"nam","theLuc":[{"ten":"Lôi Tiên Giới","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"không rõ, có khí tức quay về căn nguyên @c0693","trangThai":"song @c0694","blurb":"Nhân vật vô danh đứng trên lôi sơn đen bên trong Lôi Tiên Giới chưa mở. Lão cảm ứng dị biến từ xa, tỏ vẻ hứng thú rồi hóa thành vô số tinh điểm biến mất.","vaiTro":"người bí ẩn trong Lôi Tiên Giới","tinhCach":"bí ẩn; ung dung; hứng thú với dị biến","tabs":{"diem":[{"text":"Xuất hiện bên trong Lôi Tiên Giới trước khi nơi này mở ra cho tu sĩ bên ngoài.","chuong":"@c0693"},{"text":"Khi biến mất để lộ một tia khí tức quay về căn nguyên, gợi thân phận hoặc thần thông không tầm thường.","chuong":"@c0693"}],"kinhLich":[{"text":"Đứng trên lôi sơn đen trong Lôi Tiên Giới chưa mở, lão cảm ứng được dị biến từ xa, nói thú vị rồi hóa thành vô số tinh điểm biến mất với khí tức quay về căn nguyên.","anchor":"Cả người hắn hóa thành vô số tinh điểm, biến mất khỏi ngọn lôi sơn này.","bridge":true,"khoang":"@c0693"},{"text":"Xuất hiện bên hố sau khi Vương Lâm rơi xuống, nhận xét cách vào Lôi Tiên Giới của hắn là tham lam, nhìn ra nguyên thần và thân thể đều liên quan lôi điện, rồi xem vị trí hạ xuống là có duyên và dùng thần thông tác động vào mặt đất trước khi biến mất.","anchor":"Chẳng qua vị trí hắn hạ xuống đúng là có chút thú vị! Thôi, để lão phu nhìn thấy thì xem như có duyên!","bridge":true,"khoang":"@c0694"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"người được lão xem là hữu duyên","ghiChu":"Lão can thiệp mặt đất sau khi đánh giá tình trạng lôi điện trong nguyên thần và thân thể Vương Lâm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Hóa thành vô số tinh điểm","trangThai":"thi-trien","moTa":"Biến mất khỏi lôi sơn bằng vô số tinh điểm, để lộ khí tức quay về căn nguyên.","nguon":"@c0693"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0693","@c0694"]}]};
