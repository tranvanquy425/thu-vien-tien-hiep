/* characters q03 (21 mục) — sinh tự động bởi migrate_split.js 2026-06-14T14:19:50.417Z - gop theo danh sach 2026-06-25 */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["tien-nghich"]=window.__LIBQ["tien-nghich"]||{};window.__LIBQ["tien-nghich"]["q03"]=window.__LIBQ["tien-nghich"]["q03"]||{};window.__LIBQ["tien-nghich"]["q03"]["characters"]={"updatedAt":"2026-06-14","count":21,"chars":[{"id":"tien-khon","name":"Tiễn Khôn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan trung kỳ (@c0127)","trangThai":"tu-vong","vaiTro":"Phản diện (Đại trưởng lão)","tinhCach":"Kiêu ngạo khi thắng thế, hèn nhát và xảo trá khi thất thế.","blurb":"Đại trưởng lão Đấu Tà phái, Kết Đan trung kỳ, sở hữu pháp bảo Đại Duyệt Tuyệt Phù. Cầm đầu mười Kết Đan kỳ truy sát Vương Lâm; là kẻ chạy đầu tiên khi Vương Lâm kết đan thành công. Cùng đường lấy Vạn Ma Bách Nhật Tru Sát Lệnh ra dọa rồi bị Vương Lâm niệm Tử Chú thuật giết.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0127","importance":"normal","text":"Dẫn đầu mười Kết Đan kỳ Đấu Tà phái truy sát Vương Lâm vì Bách Thú Linh Lô; khi Vương Lâm kết đan thành công thì khiếp sợ bỏ chạy đầu tiên."},{"chuong":"@c0128","importance":"normal","text":"Chạy về phân bộ Ngũ Đinh phong cầu cứu; cùng đường lấy Vạn Ma Bách Nhật Tru Sát Lệnh ra dọa và cầu hòa, hứa dẫn tiến Vương Lâm làm Đại trưởng lão."},{"chuong":"@c0129","importance":"major","text":"Bị Vương Lâm niệm một chữ 'Tử' giết chết (thất khiếu chảy máu, thần thức phá liệt); lệnh bài vỡ kết thành chữ 'Diệt' treo trên đầu Vương Lâm."}],"tuVi":"Kết Đan trung kỳ (@c0127).","tuViMoc":[{"chuong":"@c0127","canhGioi":"Kết Đan trung kỳ","text":"Đại trưởng lão Đấu Tà phái, Kết Đan trung kỳ."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Kẻ truy sát rồi bị giết bởi","ghiChu":"Truy sát Vương Lâm; bị Tử Chú thuật giết.","tag":"doi-thu"}],"tuiDo":{"phapBao":[{"ten":"Đại Duyệt Tuyệt Phù","moTa":"Pháp bảo của Tiễn Khôn dùng trong truy sát.","nguon":"@c0127"},{"ten":"Vạn Ma Bách Nhật Tru Sát Lệnh","moTa":"Lệnh bài thượng cổ Tiễn Khôn tế luyện; khi hắn chết, lệnh bài vỡ kích hoạt chữ 'Diệt' truy sát Vương Lâm.","trangThai":"hong","nguon":"@c0128, @c0129"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0127","@c0128","@c0129"]},{"id":"con-tang","name":"Côn Tang","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan kỳ (@c0127)","trangThai":"tu-vong","vaiTro":"Phản diện phụ (trưởng lão)","tinhCach":"Tham lam, liều lĩnh vì pháp bảo.","blurb":"Trưởng lão Kết Đan kỳ Đấu Tà phái, sở hữu Cổ Kính (định vị) và Hắc Thạch Ấn. Cùng truy sát Vương Lâm vì Bách Thú Linh Lô; bị Vương Lâm phóng tinh quang xuyên ngực giết, Kim đan bị thu.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0127","importance":"minor","text":"Dùng Cổ Kính định vị và Hắc Thạch Ấn công phá Cửu Ly Thi Cốt trận; cùng Phác Lâm đoạt Bách Thú Linh Lô."},{"chuong":"@c0128","importance":"normal","text":"Bỏ chạy, dùng bí thuật tự tổn thân tăng tốc nhưng vẫn bị Vương Lâm phóng tinh quang xuyên ngực giết — người thứ ba bị giết; Kim đan bị thu."}],"tuVi":"Kết Đan kỳ (@c0127).","tuViMoc":[{"chuong":"@c0127","canhGioi":"Kết Đan kỳ","text":"Trưởng lão Kết Đan kỳ Đấu Tà phái."}],"nhanMach":[],"tuiDo":{"phapBao":[{"ten":"Cổ Kính","moTa":"Pháp bảo định vị mục tiêu.","nguon":"@c0127"},{"ten":"Hắc Thạch Ấn (Vạn Phong Ấn)","moTa":"Pháp bảo hóa cự phong, dùng công phá trận pháp.","nguon":"@c0127"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0127","@c0128"]},{"id":"tran-hai","name":"Trần Hải","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan kỳ (@c0128)","trangThai":"tu-vong","vaiTro":"Phản diện phụ (trưởng lão)","tinhCach":"Lão luyện, giỏi ẩn nấp.","blurb":"Trưởng lão Kết Đan kỳ Đấu Tà phái. Khi bị truy sát đã đào hố tự chôn ẩn tức để trốn (cách từng dùng thời Trúc Cơ kỳ) nhưng vẫn bị Vương Lâm giết — người thứ tư.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0128","importance":"minor","text":"Đào hố tự chôn, thu liễm hơi thở để trốn Vương Lâm nhưng vẫn bị giết, thất khiếu chảy máu, kim tuyến lôi xác lên."}],"tuVi":"Kết Đan kỳ (@c0128).","tuViMoc":[{"chuong":"@c0128","canhGioi":"Kết Đan kỳ","text":"Trưởng lão Kết Đan kỳ Đấu Tà phái."}],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0128"]},{"id":"moc-nam","name":"Mộc Nam","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan kỳ (@c0128)","trangThai":"song","vaiTro":"Nhân vật phụ (trưởng lão phân bộ)","tinhCach":"Khôn ngoan biết sợ — gặp kẻ mạnh thì khúm núm để giữ mạng.","blurb":"Trưởng lão Kết Đan kỳ tọa trấn phân bộ Đấu Tà phái tại Ngũ Đinh phong, huynh đệ với Mộc Bắc. Nhận ra Vương Lâm áp đảo nên cung kính không dám cản, bị ép dẫn đường tới Tổng bộ Đấu Tà phái.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0128","importance":"minor","text":"Cùng Mộc Bắc tọa trấn Ngũ Đinh phong; nhận ra chín thi thể Vương Lâm kéo theo là chín trưởng lão Tổng bộ nên khúm núm tham kiến, không dám ngăn."},{"chuong":"@c0129","importance":"minor","text":"Bị Vương Lâm ép dẫn đường tới Tổng bộ Đấu Tà phái; cung cấp tin tức về tu vi chưởng môn và việc không có Nguyên Anh kỳ trong vùng."}],"tuVi":"Kết Đan kỳ (@c0128).","tuViMoc":[{"chuong":"@c0128","canhGioi":"Kết Đan kỳ","text":"Trưởng lão Kết Đan kỳ tọa trấn Ngũ Đinh phong."}],"nhanMach":[{"ten":"Mộc Bắc","quanHe":"Huynh đệ","ghiChu":"Cùng tọa trấn phân bộ Ngũ Đinh phong.","tag":"ho-hang"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0128","@c0129","@c0130"]},{"id":"moc-bac","name":"Mộc Bắc","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan kỳ (@c0128)","trangThai":"song","vaiTro":"Nhân vật phụ (trưởng lão phân bộ)","tinhCach":"Khôn ngoan biết sợ, tương tự Mộc Nam.","blurb":"Trưởng lão Kết Đan kỳ tọa trấn phân bộ Đấu Tà phái tại Ngũ Đinh phong, huynh đệ với Mộc Nam. Cùng bị ép dẫn đường tới Tổng bộ; cung cấp thông tin tu vi chưởng môn Đấu Tà phái.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0128","importance":"minor","text":"Cùng Mộc Nam khúm núm tham kiến Vương Lâm khi thấy uy thế của hắn, không dám cản."},{"chuong":"@c0129","importance":"minor","text":"Cho biết chưởng môn Đấu Tà phái đạt Kết Đan trung kỳ đỉnh; bị ép dẫn đường tới Tổng bộ."}],"tuVi":"Kết Đan kỳ (@c0128).","tuViMoc":[{"chuong":"@c0128","canhGioi":"Kết Đan kỳ","text":"Trưởng lão Kết Đan kỳ tọa trấn Ngũ Đinh phong."}],"nhanMach":[{"ten":"Mộc Nam","quanHe":"Huynh đệ","ghiChu":"Cùng tọa trấn phân bộ Ngũ Đinh phong.","tag":"ho-hang"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0128","@c0129","@c0130"]},{"id":"thuong-quan-mac","name":"Thượng Quan Mặc","cn":"","aliases":["Hắc y Ma quân"],"gioiTinh":"nam","theLuc":["Hắc y Ma quân (tán tu ngoại vi Tu Ma Hải)","Đấu Tà phái (chưởng giáo @c0133)"],"canhGioiCaoNhat":"Kết Đan trung kỳ đỉnh (@c0129)","trangThai":"song (chưởng giáo Đấu Tà phái; bản mệnh tinh huyết bị lão nhân thanh bào bức bách @c0136)","vaiTro":"Thuộc hạ (bị thu phục)","tinhCach":"Ngạo mạn khi thị uy, hèn và biết thời thế khi gặp kẻ mạnh hơn; thực dụng, chịu khuất phục để bảo mạng.","blurb":"Tu sĩ trung tuổi danh hiệu Hắc y Ma quân, Kết Đan trung kỳ đỉnh, hoạt động ngoại vi Tu Ma Hải, mạnh hơn Đại trưởng lão Đấu Tà phái. Định giết Vương Lâm để đoạt Vạn Ma Bách Nhật Tru Sát Lệnh nhưng bị áp đảo; dâng bản mệnh tinh huyết để bảo mạng, từ đó bị Vương Lâm ràng buộc sống-chết và theo hầu. Sau khi Giải Đông Lai chết, được Vương Lâm bổ nhiệm làm chưởng giáo Đấu Tà phái.","tabs":{"diem":[{"text":"Biết thời thế để sống — từ ngạo mạn 'dạy' Vương Lâm chuyển sang quỳ xin tha, xin bái sư, rồi dâng bản mệnh tinh huyết khi nhận ra không thể địch lại.","chuong":"@c0129"},{"text":"Thừa lệnh Vương Lâm thị uy toàn bộ Nam Đẩu thành, giết Âu Dương lão nhân trước mắt chúng tu sĩ.","chuong":"@c0131"}],"kinhLich":[{"chuong":"@c0129","importance":"normal","text":"Xuất hiện định giết Vương Lâm đoạt lệnh bài; bị Tử Chú thuật áp đảo (ngọc phù di vật sư phụ chống được một kích Nguyên Anh kỳ phải tự vỡ); quỳ xin tha, cuối chương dâng bản mệnh tinh huyết để liều mạng."},{"chuong":"@c0130","importance":"normal","text":"Bị Vương Lâm nuốt bản mệnh tinh huyết tạo ràng buộc sống-chết hai chiều; theo hầu Vương Lâm, thị uy đám tu sĩ cản đường."},{"chuong":"@c0131","importance":"normal","text":"Thừa lệnh giết Âu Dương lão nhân — hành động thị uy cùng Mộc Nam/Mộc Bắc trước hàng nghìn tu sĩ quy tụ vì chữ 'Tru'."},{"chuong":"@c0132","importance":"minor","text":"Theo hộ vệ Vương Lâm tiến về đại bản doanh Đấu Tà phái, đối diện Đấu Long Đại Trận hơn 13.000 đệ tử."},{"chuong":"@c0133","importance":"major","text":"Sau khi Giải Đông Lai chết, được Vương Lâm bổ nhiệm làm chưởng giáo Đấu Tà phái — nắm quyền thay thế chưởng môn cũ."},{"chuong":"@c0136","importance":"major","text":"Lão nhân thanh bào (Nguyên Anh kỳ) tìm tới, bức một giọt bản mệnh tinh huyết từ mi tâm để dò ra dấu Vương Lâm — bị xâm phạm thân thể cực kỳ nguy hiểm."}],"tuVi":"Kết Đan trung kỳ đỉnh (@c0129).","tuViMoc":[{"chuong":"@c0129","canhGioi":"Kết Đan trung kỳ đỉnh","text":"Mạnh hơn Đại trưởng lão Đấu Tà phái, được chưởng môn kính ba phần."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Chủ (ràng buộc tinh huyết)","ghiChu":"Áp đảo và nuốt bản mệnh tinh huyết của hắn, khiến hắn theo hầu.","tag":"su-mon"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[{"ten":"Bản mệnh tinh huyết (đã dâng)","moTa":"Màu kim hoàng, dâng cho Vương Lâm để bảo mạng; bị Vương Lâm nuốt, tu vi tổn hại, từ đó bị ràng buộc sống-chết.","trangThai":"mat","nguon":"@c0129, @c0130"}]}},"nguon":["@c0129","@c0130","@c0131","@c0132","@c0133","@c0136"]},{"id":"giai-dong-lai","name":"Giải Đông Lai","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đấu Tà phái"],"canhGioiCaoNhat":"Kết Đan trung kỳ (@c0133)","trangThai":"tu (chết @c0133 — hóa tro khi kiếm hoàn phản bị phá)","vaiTro":"Chưởng môn Đấu Tà phái","tinhCach":"Bình tĩnh, kiên định, sẵn sàng hy sinh bản thân vì môn phái; dùng kế hiến thân dụ địch — đây là lựa chọn chủ động, không phải liều mạng thất vọng.","blurb":"Chưởng môn Đấu Tà phái, Kết Đan trung kỳ, kiếm tu. Khi Vương Lâm dẫn quân diệt môn phái, Giải Đông Lai dùng Đấu Long Đại Trận tập hợp sức mạnh 13.562 đệ tử để đàm phán; thất bại, bèn giả thua dâng chưởng giáo lệnh để dẫn dụ Vương Lâm vào tầm sát của kiếm hoàn và kiếm đan — kế không thành, hóa tro chết.","tabs":{"diem":[{"text":"Kiếm tu Kết Đan trung kỳ — kiếm hoàn và kiếm đan là chiêu tử thương dụ địch cuối cùng, thể hiện bản lĩnh kiếm tu thuần túy.","chuong":"@c0133"}],"kinhLich":[{"chuong":"@c0132","importance":"major","text":"Khi Vương Lâm dẫn quân tiến tới đại bản doanh, triển khai Đấu Long Đại Trận — dồn thần thức toàn bộ 13.562 đệ tử, tu vi tạm thời gần sơ Nguyên Anh. Ra điều kiện: nếu phá được trận thì toàn phái quy phục."},{"chuong":"@c0133","importance":"major","text":"Giả thua, trao chưởng giáo lệnh để dụ Vương Lâm vào gần — bất ngờ tung kiếm hoàn và kiếm đan đánh sát tử. Kiếm hoàn bị phá, kiếm đan phản bật; Giải Đông Lai hóa tro chết. Đấu Tà phái đầu hàng, Thượng Quan Mặc được bổ nhiệm chưởng giáo mới."}],"tuVi":"Kết Đan trung kỳ, kiếm tu (@c0133).","tuViMoc":[{"chuong":"@c0132","canhGioi":"Kết Đan trung kỳ (gần sơ Nguyên Anh tạm thời qua Đấu Long Đại Trận)","text":"Khi Đấu Long Đại Trận kích hoạt, tu vi tạm thời nâng lên gần sơ Nguyên Anh nhờ hội tụ thần thức 13.562 đệ tử."}],"nhanMach":[{"ten":"Thượng Quan Mặc","quanHe":"Người kế nhiệm","ghiChu":"Được Vương Lâm chỉ định thay thế Giải Đông Lai làm chưởng giáo Đấu Tà phái sau khi lão chết.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0132","@c0133"]},{"id":"bat-cuc-ma-quan","name":"Bát Cực Ma Quân","cn":"","aliases":["Lão nhân thanh bào","Thanh sam lão giả","Đoan Mộc Cực"],"gioiTinh":"nam","theLuc":["Thất Mai thành"],"canhGioiCaoNhat":"Hóa Thần kỳ (@c0143)","trangThai":"song","vaiTro":"Kẻ truy sát / đồng minh cưỡng ép","tinhCach":"Lạnh lùng, quyết đoán; không giết bừa bãi để tránh can thiệp từ tứ cấp tu chân quốc; thực dụng — chuyển sang đàm phán ngay khi thấy dùng vũ lực không hiệu quả.","blurb":"Cường giả tu vi Nguyên Anh hậu kỳ đại viên mãn, nghi đã tiến vào Hóa Thần kỳ, từ Tu Ma Hải nội hải. Truy sát Vương Lâm suốt ba năm để chiếm Tử Chú thuật nhằm phục vụ một kế hoạch lớn liên quan tới địa phương bí ẩn sắp mở. Sau khi Tử Chú thuật hấp thu bởi Bát Trảo Thần Thức trong ý thức hải khiến lão khựng người, đề nghị đàm phán và đạt hiệp nghị với Vương Lâm.","tabs":{"diem":[{"text":"Phá hộ sơn đại trận của Hỏa Phần Minh chỉ bằng một cái ấn tay; trấn áp Nguyên Anh kỳ Tà Ma tông bằng một chữ 'Biến!'.","chuong":"@c0138"},{"text":"Bát Trảo Thần Thức trong ý thức hải hấp thu tia chớp Tử Chú — cơ chế phòng thủ đặc biệt khiến lão chỉ khựng người chứ không chết.","chuong":"@c0139"}],"kinhLich":[{"chuong":"@c0135","importance":"minor","text":"Xuất hiện tại trà lâu Nam Đẩu thành (bào xanh, mũi ưng, bảy đóa mai vàng trên vạt áo), tra hỏi về Vương Lâm và Tử Chú thuật."},{"chuong":"@c0136","importance":"major","text":"Chính thức truy sát: bức một giọt bản mệnh tinh huyết từ mi tâm Thượng Quan Mặc để lần dấu Vương Lâm. Đuổi sát nhưng VL lặn biển thoát."},{"chuong":"@c0137","importance":"normal","text":"Kẹp được phi kiếm VL bằng hai ngón tay, bị một đạo công kích sượt qua mặt gây thương nhỏ; nếm máu của mình. Quét tay đẩy bay Phượng Loan – Dương Sâm – Trâu Bân ngàn trượng. Sau khi VL biến vào Mộng Cảnh, triển khai thần thức không tìm ra dấu."},{"chuong":"@c0138","importance":"major","text":"Lộ danh xưng Bát Cực Ma Quân; tuyên bố sẽ luyện hóa toàn Tuyên Vũ quốc nếu trong ba năm không bắt được VL. Phá hộ sơn đại trận Hỏa Phần Minh bằng một ấn tay; phân bốn thân lùng sục toàn quốc — không tìm ra."},{"chuong":"@c0139","importance":"major","text":"Dùng Thổ Hành Chu đuổi VL dưới lòng đất; thả Thanh Ban Mãng thử Tử Chú thuật. Bị VL tấn công bằng Tử Chú — Bát Trảo Thần Thức hấp thu nhưng vẫn run rẩy khựng người. Sau khi VL bị thương, lão đề nghị đàm phán."},{"chuong":"@c0140","importance":"major","text":"Đạt hiệp nghị với Vương Lâm: VL hộ tống vào địa phương bí ẩn sắp mở, đổi lấy Lập Anh đan + bảo vật. Đặt phù văn phòng đào tẩu vào người VL. Dùng khí thế ép Chiến Thần Điện mở thạch phủ Thần Đạo thuật cho VL xem."},{"chuong":"@c0143","importance":"normal","text":"Lộ thân phận thành chủ Thất Mai Thành (Tu Ma nội hải); bóp nát Truyền Tống trận của Thi Âm tông, giết đám Kết Đan kỳ, ép Triệu Truyện Lương cùng năm Nguyên Anh kỳ rút lui để bảo vệ Vương Lâm. Phân tích toàn diện phẩm chất VL, nảy một ý niệm."},{"chuong":"@c0144","importance":"major","text":"Cùng sứ giả Âm Dương Tông Uông Thanh Việt dẫn Vương Lâm qua Cổ Truyền Tống Trận tới Toái Tinh Loạn — hé lộ kế hoạch trở lại 'địa phương kia' (nơi ngàn năm trước lão lấy được hồ lô + ba khối cực phẩm linh thạch). Trong bụng vẫn toan tính để VL chết khi qua hồng vụ."},{"chuong":"@c0146","importance":"normal","text":"Hội cùng Cổ Đế, Lục Dục Ma Quân, Mạnh Đà Tử — bốn đại cao thủ sống sót ngàn năm trước — phá phong ấn vào Cổ Thần Chi Địa săn Anh Biến đan. Bị Vương Lâm ép giữ lời hứa, trao hai viên đan trợ Kết Anh (hóa anh + lập anh)."}],"tuVi":"Hóa Thần kỳ (giả thần cảnh giới); thành chủ Thất Mai Thành nội hải Tu Ma (@c0137, @c0143).","tuViMoc":[{"chuong":"@c0135","canhGioi":"Nguyên Anh kỳ","text":"Tu vi ước đoán ban đầu là Nguyên Anh kỳ."},{"chuong":"@c0137","canhGioi":"Nguyên Anh hậu kỳ (nghi Hóa Thần)","text":"Trâu Bân (Chiến Thần Điện lão tổ từng du ngoạn nội hải) xác nhận lão là người Thất Mai chi địa, nghi đã đạt Hóa Thần kỳ."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Mục tiêu truy sát / đồng minh cưỡng ép","ghiChu":"Truy ba năm để chiếm Tử Chú thuật; cuối cùng ký hiệp nghị đồng hành vào địa phương bí ẩn.","tag":"doi-thu"}],"tuiDo":{"phapBao":[{"ten":"Thổ Hành Chu","moTa":"Thuyền gỗ đen di chuyển dưới lòng đất theo Độn Thổ thuật đẳng cấp cao; lão đi mượn để truy đuổi Vương Lâm trong chương 139.","nguon":"@c0138, @c0139"},{"ten":"Trùy tử bảy màu (hình con thoi trong suốt)","moTa":"Pháp bảo tấn công phóng dưới lòng đất, quang mang bảy màu; chặn được ngọc phù cấp Nguyên Anh của Dương Sâm và gây nổ trăm trượng.","nguon":"@c0139"},{"ten":"Thanh Ban Mãng","moTa":"Mãng xà dài ba trượng, thả ra làm mục tiêu thử Tử Chú thuật và lập xà trận; bị phi kiếm Vương Lâm chém đứt.","nguon":"@c0139"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0135","@c0136","@c0137","@c0138","@c0139","@c0140","@c0142","@c0143","@c0144","@c0145","@c0146","@c0147","@c0148"]},{"id":"au-duong","name":"Âu Dương lão nhân","cn":"","aliases":["#au-duong-lao-nhan"],"gioiTinh":"nam","theLuc":["Tán tu (ngoại vi Tu Ma Hải)"],"canhGioiCaoNhat":"Kết Đan kỳ (@c0131)","trangThai":"tu (chết @c0131 — bị Thượng Quan Mặc giết)","vaiTro":"Nhân vật phụ","tinhCach":"Không rõ tính cách chi tiết; xuất hiện ngắn.","blurb":"Tán tu Kết Đan kỳ hoạt động ngoại vi Tu Ma Hải. Bị Thượng Quan Mặc giết theo lệnh Vương Lâm trong cuộc thị uy tại Nam Đẩu thành.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0131","importance":"minor","text":"Bị Thượng Quan Mặc hạ sát trước mắt hàng nghìn tu sĩ quy tụ vì chữ 'Tru', trong khuôn khổ cuộc thị uy của Vương Lâm tại Nam Đẩu thành."}],"tuVi":"Kết Đan kỳ (@c0131).","tuViMoc":[{"chuong":"@c0131","canhGioi":"Kết Đan kỳ","text":"Tu vi Kết Đan kỳ khi bị giết."}],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0131"]},{"id":"lao-gia-mat-do","name":"Lão giả mặt đỏ","cn":"","aliases":["Trâu Bân"],"gioiTinh":"nam","theLuc":["Chiến Thần Điện"],"canhGioiCaoNhat":"Nguyên Anh kỳ (@c0137)","trangThai":"song","vaiTro":"Nhân vật phụ (Chiến Thần Điện)","tinhCach":"Thực tế, bảo vệ lợi ích tông môn; chịu nhún khi gặp kẻ mạnh hơn (Bát Cực Ma Quân), nhưng đặt điều kiện rõ ràng với Vương Lâm.","blurb":"Lão tổ Chiến Thần Điện, tên Trâu Bân, tu vi Nguyên Anh kỳ, mắt to với ngọn lửa trong đồng tử. Ba trăm năm trước từng du ngoạn Tu Ma Hải nên nhận ra dấu hiệu bảy đóa mai vàng của Thất Mai chi địa. Canh giữ thạch phủ chứa Thần Đạo thuật; ra điều kiện cho Vương Lâm xem công pháp phải thề không lôi Chiến Thần Điện vào rắc rối.","tabs":{"diem":[{"text":"Người duy nhất trong nhóm nhận ra dấu hiệu bảy đóa mai vàng — ám chỉ Thất Mai chi địa nội hải Tu Ma Hải, thế lực cực mạnh.","chuong":"@c0137"}],"kinhLich":[{"chuong":"@c0137","importance":"normal","text":"Cùng Phượng Loan và Dương Sâm tới Hỏa Phần quốc truy tìm Vương Lâm; nhận ra bảy đóa mai vàng của lão nhân thanh bào là dấu Thất Mai chi địa. Bị lão nhân quét tay đẩy bay ngàn trượng, Nguyên Anh suýt ly thể."},{"chuong":"@c0140","importance":"normal","text":"Canh giữ thạch phủ Thần Đạo thuật; dẫn Vương Lâm tới trước cửa và yêu cầu VL phát lời thề không kéo Chiến Thần Điện vào phiền toái mới chịu mở thạch phủ."}],"tuVi":"Nguyên Anh kỳ (@c0137).","tuViMoc":[{"chuong":"@c0137","canhGioi":"Nguyên Anh kỳ","text":"Tu vi Nguyên Anh kỳ, tương đương Dương Sâm; bị lão nhân thanh bào đẩy bay ngàn trượng."}],"nhanMach":[{"ten":"Phượng Loan","quanHe":"Đồng môn (Chiến Thần Điện)","ghiChu":"Cùng thực hiện nhiệm vụ truy tìm Vương Lâm.","tag":"khac"},{"ten":"Vương Lâm","quanHe":"Người xin học Thần Đạo thuật","ghiChu":"Ra điều kiện VL thề bảo vệ lợi ích Chiến Thần Điện trước khi mở thạch phủ.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0137","@c0140"]},{"id":"luc-duc-ma-quan","name":"Lục Dục Ma Quân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Hóa Thần đại viên mãn (@c0165, đỉnh cao trước khi chết); tử vong @c0165","trangThai":"tu-vong","vaiTro":"Đại cao thủ Tu Ma nội hải (đối thủ)","tinhCach":[{"text":"Lãnh khốc vô tình — toàn thân toát hàn khí thấu xương như băng vĩnh cửu, ra tay tàn nhẫn.","chuong":"@c0145"},{"text":"Thực dụng, biết dùng người — hứa bảo đảm an toàn cho Vương Lâm để đổi lấy việc mở 'cửa thứ ba'.","chuong":"@c0145"}],"blurb":"Một trong bốn đại cao thủ sống sót sau chuyến thâm nhập Cổ Thần Chi Địa ngàn năm trước. Nam tử mặc cẩm y đỏ điểm hoa văn vàng, tướng mạo tuấn tú, lạnh lùng vô tình; cưỡi Long chu, sở trường ma công Thụ Thuật Giả rút khí người sống làm vũ khí. Cầm đầu đội thâm nhập Cổ Thần Chi Địa lần này để săn Anh Biến đan. Bị vây khốn trên Cấm Sơn, sau đó lập thề Tâm Ma cùng Cổ Đế và tụt xuống một cảnh giới.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0145","importance":"normal","text":"Đến Toái Tinh Loạn trên Long chu cùng một thanh niên mắt đỏ; sau khi nghe Đoan Mộc Cực truyền âm, hứa bảo đảm an toàn cho Vương Lâm nếu hắn mở được 'cửa thứ ba'."},{"chuong":"@c0146","importance":"normal","text":"Chủ trì mở Cổ Truyền Tống trận, phân chia bảo vật (mỗi người một kiện, Anh Biến đan tùy bản lãnh); dẫn cả đoàn vào không gian Cổ Thần Chi Địa."},{"chuong":"@c0147","importance":"normal","text":"Trong trận vây đánh cự xà, thi triển ma công khẩu quyết 'Khiếp hãi / Nộ' rút khí từ thất khiếu một người sống làm hai lợi kiếm đâm vào mắt cự xà."},{"chuong":"@c0157","importance":"normal","text":"Dẫn một thanh niên trẻ lên sườn Cấm Sơn sau khi vượt Bất Quy lộ; bị đám mây mù dày đặc xuất hiện ba ngày chặn lại, kinh ngạc vì lần trước không có."},{"chuong":"@c0159","importance":"major","text":"Bị vây khốn trên Cấm Sơn năm năm; cùng Cổ Đế lập thề Tâm Ma để hợp tác vào dòng xoáy đỉnh. Mất cánh tay của thi thể thanh niên đang dùng, tụt xuống một cảnh giới."},{"chuong":"@c0161","importance":"normal","text":"Vào đệ tam quan (Tịch Diệt giới), tụt còn Hóa Thần sơ kỳ do thiên lôi cửa hai; dò tìm cửa ra hướng Tây Bắc, cầm thi thể thanh niên để hút diệt du hồn."},{"chuong":"@c0162","importance":"normal","text":"Bị Vương Lâm dùng mưu mượn đao lao tới làm mồi nhử; cho VL 'ba nhịp hô hấp biến đi'. Khi Mạnh Đà Tử (yêu thần Đồ Ti) đuổi tới, được thả cho một thân ảnh huyết sắc — chính là sư phụ hắn (Thiên Tán ma / Thiên Ma Tán Nhân) — hắn ngơ ngác gọi 'Sư phụ'."},{"chuong":"@c0165","importance":"major","text":"Hấp thu trọn sáu dục niệm Cổ Thần, Huyền Thiên Ma Dục Quyết đạt đại viên mãn (Hóa Thần đại viên mãn). Ngay sau đó bị chính sư phụ Thiên Ma Tán Nhân dùng 'Dĩ dục vi kiếm' ép tự nổ tung — TỬ VONG, thân xác trở thành chìa khóa mở thần thức Cổ Thần."}],"tuVi":"Hóa Thần trung kỳ (@c0157) → tụt Hóa Thần sơ kỳ (@c0161) → hấp thu sáu dục đạt Hóa Thần đại viên mãn rồi tử vong (@c0165).","tuViMoc":[{"chuong":"@c0146","canhGioi":"Hóa Thần kỳ","text":"Một trong bốn đại cao thủ (cùng Cổ Đế, Đoan Mộc Cực, Mạnh Đà Tử) sống sót trở về từ đệ tam quan Cổ Thần Chi Địa ngàn năm trước."},{"chuong":"@c0157","canhGioi":"Hóa Thần trung kỳ","text":"Tu vi xác nhận Hóa Thần trung kỳ; Lục Dục ma công đạt hóa cảnh sau ngàn năm tu luyện."},{"chuong":"@c0161","canhGioi":"Hóa Thần sơ kỳ","text":"Tụt một cảnh giới do thiên lôi cửa hai khi vào đệ tam quan."},{"chuong":"@c0165","canhGioi":"Hóa Thần đại viên mãn → tử vong","text":"Hấp thu sáu dục niệm Cổ Thần đạt đại viên mãn, rồi bị sư phụ Thiên Ma Tán Nhân ép tự nổ — chết."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Quân cờ mở cửa thứ ba","ghiChu":"Hứa bảo đảm an toàn cho VL nếu hắn mở được cửa thứ ba; VL về sau thoát ly đội ngũ vì sợ bị thanh trừ.","tag":"doi-thu"},{"ten":"Mạnh Đà Tử","quanHe":"Cao thủ ngang hàng","ghiChu":"Ngàn năm trước từng bất phân thắng bại; nay cùng đoàn vào Cổ Thần Chi Địa.","tag":"khac"},{"ten":"Cổ Đế","quanHe":"Đồng hành trên Cấm Sơn","ghiChu":"Cùng lập thề Tâm Ma để hợp tác vào dòng xoáy đỉnh Cấm Sơn.","tag":"khac"}],"tuiDo":{"phapBao":[{"ten":"Long chu","moTa":"Pháp bảo bay hình thuyền rồng mà Lục Dục Ma Quân cưỡi tới Toái Tinh Loạn.","nguon":"@c0145"}],"congPhap":[{"ten":"Thụ Thuật Giả","moTa":"Ma công cần một người sống làm vật hy sinh: hô khẩu quyết 'Khiếp hãi / Nộ' để rút hắc khí / khí tím đỏ từ thất khiếu nạn nhân, ngưng thành lợi kiếm; cũng có thể khiến nạn nhân hai mắt thất thần, mất hồn.","nguon":"@c0147, @c0148"},{"ten":"Lục Dục ma công","moTa":"Công pháp ma đạo Lục Dục Ma Quân tu luyện; đạt hóa cảnh sau ngàn năm, giúp miễn nhiễm dao động tinh thần của Bất Quy lộ (@c0157).","nguon":"@c0157"}],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0145","@c0146","@c0147","@c0148","@c0150","@c0157","@c0159"]},{"id":"co-de","name":"Cổ Đế","cn":"","aliases":["Cổ Lam"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Hóa Thần trung kỳ (@c0158) → bị du hồn bào mòn còn Nguyên Anh trung kỳ rồi tử vong (@c0161–@c0162)","trangThai":"tu-vong","vaiTro":"Đại ma đầu Tu Ma nội hải (đối thủ nguy hiểm)","tinhCach":[{"text":"Ngoài hiền từ tiên phong đạo cốt, trong lòng lang dạ sói — một đại ma đầu / kẻ điên khét tiếng nội hải.","chuong":"@c0145"},{"text":"Tàn nhẫn, ra tay đột ngột — đang giảng giải bỗng vung phất trần định giết Vương Lâm.","chuong":"@c0145"}],"blurb":"Tên thật Cổ Lam, lão nhân mặc y phục đen, thân cao gầy râu bạc, cầm phất trần; một trong bốn đại cao thủ sống sót ngàn năm trước, được xem là đại ma đầu mạnh nhất nhóm. Đoạt được Băng Phong Tráo từ tứ cấp tu chân quốc, nhận phá đệ nhất quan Cổ Thần Chi Địa. Mất hơn nửa pháp bảo khi vượt Hành Hỏa chi địa; lập thề Tâm Ma với Lục Dục Ma Quân và mất 4 lá cờ khi kích phát cấm chế đỉnh Cấm Sơn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0145","importance":"normal","text":"Xuất hiện ở Toái Tinh Loạn, đang giảng về Cổ thần thì bất ngờ vung phất trần định giết Vương Lâm; bị Đoan Mộc Cực ngăn vì VL biết Tử Chú thuật, đành thu tay lui ra."},{"chuong":"@c0146","importance":"normal","text":"Nhận phá đệ nhất quan; dùng hắc ti ngưng thành hắc long phá phong ấn quang quyển, là người đầu tiên bước vào không gian Cổ Thần."},{"chuong":"@c0147","importance":"minor","text":"Dùng cự chung (chuông cổ) phát sóng âm đánh cự xà, nhưng bị đầu rắn nhỏ trong miệng cự xà nuốt mất chuông — mất cảm ứng pháp bảo."},{"chuong":"@c0158","importance":"normal","text":"Tốn bảy năm vượt Hành Hỏa chi địa, mất hơn nửa pháp bảo; sau đó vào Cấm Sơn, bị vây năm năm cùng Lục Dục Ma Quân. Tu vi Hóa Thần trung kỳ được xác nhận."},{"chuong":"@c0159","importance":"major","text":"Cùng Lục Dục Ma Quân lập thề Tâm Ma hợp tác; mất 4 lá cờ (ban đầu 8 lá, còn 4 lá) khi đoạn xương vàng bạo phát gần đỉnh Cấm Sơn, vào dòng xoáy đỉnh."},{"chuong":"@c0161","importance":"normal","text":"Vào đệ tam quan, bị Vương Lâm điều khiển đại quân du hồn vây khốn (phải dùng bảo tháp che chắn); tu vi bị bào mòn dần xuống Nguyên Anh trung kỳ."},{"chuong":"@c0162","importance":"major","text":"Ghi pháp quyết truyền tống ra khỏi Cổ Thần chi địa vào ngọc giản trao cho Vương Lâm để đổi mạng — nhưng VL thu ngọc giản xong vẫn ra lệnh du hồn diệt hắn, đoạt thêm túi trữ vật. TỬ VONG; xác bị Mạnh Đà Tử ném vào Yêu Thần huyết hải, nơi nhận ra Xích Hỏa ma quân, Nam Cuồng ngô bại, Thiên Tán ma — những kẻ chết ngàn năm trước."}],"tuVi":"Hóa Thần trung kỳ (@c0158) → bào mòn còn Nguyên Anh trung kỳ (@c0161) → tử vong (@c0162).","tuViMoc":[{"chuong":"@c0145","canhGioi":"Hóa Thần kỳ","text":"Tu vi rất cao, Đoan Mộc Cực thừa nhận khó thắng dễ dàng; một trong bốn đại cao thủ sống sót."},{"chuong":"@c0161","canhGioi":"Nguyên Anh trung kỳ (bị bào mòn)","text":"Bị đại quân du hồn của Vương Lâm vây khốn bào mòn từ Hóa Thần trung kỳ xuống Nguyên Anh trung kỳ."},{"chuong":"@c0162","canhGioi":"Tử vong","text":"Bị du hồn của Vương Lâm diệt sau khi trao ngọc giản pháp quyết truyền tống."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Mục tiêu từng định giết","ghiChu":"Định giết VL ở Toái Tinh Loạn, bị Đoan Mộc Cực ngăn vì VL biết Tử Chú thuật.","tag":"doi-thu"},{"ten":"Lục Dục Ma Quân","quanHe":"Đồng hành trên Cấm Sơn","ghiChu":"Cùng bị vây khốn, lập thề Tâm Ma để hợp tác vào dòng xoáy đỉnh.","tag":"khac"}],"tuiDo":{"phapBao":[{"ten":"Băng Phong Tráo","moTa":"Bảo vật Cổ Đế đoạt từ tứ cấp tu chân quốc, dùng phá / chống đệ nhất quan của Cổ Thần Chi Địa.","nguon":"@c0146"},{"ten":"Cự chung (chuông cổ)","trangThai":"mat","moTa":"Chuông cổ hóa lớn, rung phát sóng không khí điên cuồng; bị đầu rắn nhỏ trong miệng cự xà cắn nuốt mất.","nguon":"@c0147"},{"ten":"8 lá cờ (mất 4 khi kích cấm chế)","moTa":"Bộ tám lá cờ pháp bảo của Cổ Đế; mất bốn lá khi đoạn xương vàng bạo phát gần đỉnh Cấm Sơn (@c0159), còn bốn lá.","nguon":"@c0159"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0145","@c0146","@c0147","@c0158","@c0159"]},{"id":"manh-da-tu","name":"Mạnh Đà Tử","cn":"","aliases":["Lão đà tử","Lục bào đà tử","Yêu thần Đồ Ti (sau khi bị ma hóa)"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Hóa Thần trung kỳ (@c0153, lúc sống); xác bị ma hóa thành yêu ma Hóa Thần hậu kỳ (@c0162)","trangThai":"tu-vong","vaiTro":"Cao thủ dùng độc (đối thủ ngầm của Vương Lâm)","tinhCach":[{"text":"Gian xảo, giả nhân nghĩa — rủ Vương Lâm cùng chạy với cớ tốt bụng, thực chất để phân tán mục tiêu truy kích của giao long.","chuong":"@c0148"},{"text":"Tàn độc nhưng kiên cường — từng bị Cự Ma tộc truy sát ba trăm năm, độc sát toàn bộ kẻ đuổi giết.","chuong":"@c0146"}],"blurb":"Lão giả gù mặc lục bào, mặt đầy mụn mủ, cao thủ dùng độc bậc nhất; cưỡi một con bích thiềm thử (cóc xanh) khổng lồ. Một trong bốn đại cao thủ sống sót ngàn năm trước, từng bất phân thắng bại với Lục Dục Ma Quân; từng bị Cự Ma tộc truy sát ba trăm năm. Tử vong trong cửa thứ nhất Cổ Thần Chi Địa.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0146","importance":"normal","text":"Đến muộn nhập đoàn, nhận phá đệ nhị quan; phát đan chống độc cho mọi người khi con thú thân rắn tỏa khí tanh."},{"chuong":"@c0147","importance":"normal","text":"Trong trận vây cự xà, hút trọn cỗ hắc vụ của nó vào bướu sau lưng phình to như núi nhỏ; lao vào miệng cự xà nhắm con rắn nhỏ thứ hai."},{"chuong":"@c0148","importance":"normal","text":"Giả lòng tốt rủ Vương Lâm cùng chạy để phân tán mục tiêu giao long; bị VL nhìn thấu, đẩy cho hồng giao long đuổi theo (sống chết chưa rõ ngay)."},{"chuong":"@c0150","importance":"normal","text":"Cùng nhóm bị giao long đỏ truy kích, lạc vào Hành Thổ chi địa; bị bầy sinh vật âm-ba vây khốn, kiệt linh lực, trốn trong một hắc tháp nghìn trượng. Vương Lâm định bám theo mượn sức vượt nạn."},{"chuong":"@c0153","importance":"major","text":"Dốc toàn lực đốt Ly Thiên thiềm thử — pháp bảo bản mệnh — và thượng cổ ma công để đột phá tạm thời lên Hóa Thần đại viên mãn, đánh thú vương giải vây. Tu vi thật sự chỉ Hóa Thần trung kỳ; khi VL quay lại thì chỉ thấy đống xương. Vương Lâm nhân đó ném Long cân đoạt túi trữ vật."},{"chuong":"@c0154","importance":"major","text":"Bị thú vương thủ lĩnh bắt sống (thú vương đốt xương ngón tay vàng điểm vào mi tâm); sống chết chưa rõ."},{"chuong":"@c0155","importance":"normal","text":"Xác nhận tử vong. Túi trữ vật của hắn — chứa ~30 vạn thượng phẩm linh thạch, 2 viên cực phẩm linh thạch, ngọc giản Minh quyết, và Độc Vương đỉnh vỡ đôi — rơi vào tay Vương Lâm."},{"chuong":"@c0162","importance":"major","text":"Xác bị truyền thừa Yêu Thần chi địa ma hóa, tái xuất ở cửa thứ ba dưới hình dạng yêu ma cao hơn mười trượng, tự xưng KHÔNG còn là Mạnh Đà Tử mà là 'yêu thần Đồ Ti' — phụng mệnh 'chủ nhân' huyết hải giết sạch người tiến vào và cấm ai vào cửa thứ tư; tu vi yêu ma đạt Hóa Thần hậu kỳ, miễn nhiễm du hồn. Lôi Đoan Mộc Cực và Uông Thanh Việt vào Yêu Thần huyết hải, truy đuổi Vương Lâm."}],"tuVi":"Hóa Thần trung kỳ (tu vi thật); tạm đạt Hóa Thần đại viên mãn nhờ đốt pháp bảo + ma công (@c0153).","tuViMoc":[{"chuong":"@c0153","canhGioi":"Hóa Thần đại viên mãn (tạm thời)","text":"Đốt Ly Thiên thiềm thử và thượng cổ ma công đột phá tạm thời; tu vi thật chỉ Hóa Thần trung kỳ."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Đối thủ ngầm","ghiChu":"Lừa VL cùng chạy để làm mồi nhử giao long; VL sau đó đoạt túi trữ vật sau khi hắn tử vong.","tag":"doi-thu"},{"ten":"Cự Ma tộc","quanHe":"Thù địch cũ","ghiChu":"Truy sát hắn ba trăm năm; bị hắn độc sát.","tag":"doi-thu"}],"tuiDo":{"linhThu":[{"ten":"Bích thiềm thử (cóc xanh)","moTa":"Linh thú cóc khổng lồ hơn mười trượng (thu nhỏ đậu trên vai), lưng đầy mụn ẩn hiện linh lực; có thể phun cực phẩm linh thạch từ trong bụng.","nguon":"@c0146, @c0150"},{"ten":"Ly Thiên thiềm thử (bản mệnh pháp bảo, đã đốt)","trangThai":"da-dung","moTa":"Pháp bảo bản mệnh của Mạnh Đà Tử; bị đốt cùng thượng cổ ma công để đột phá tạm thời Hóa Thần đại viên mãn (@c0153).","nguon":"@c0153"}],"congPhap":[{"ten":"Độc công","moTa":"Sở trường dùng độc: bóp vỡ mụn trên mặt phun chất lỏng / khí đen, hút hắc vụ; độc sát hàng vạn sinh vật âm-ba để lại bãi xác đen sì.","nguon":"@c0147, @c0150"},{"ten":"Thượng cổ ma công (đã đốt)","trangThai":"da-dung","moTa":"Công pháp ma đạo thượng cổ, bị đốt cùng Ly Thiên thiềm thử để đột phá tạm thời Hóa Thần đại viên mãn (@c0153).","nguon":"@c0153"}],"phapBao":[{"ten":"Độc Vương đỉnh (bản mệnh pháp bảo, đã vỡ)","trangThai":"da-dung","moTa":"Đỉnh linh bản mệnh phỏng theo Dược Vương đỉnh; vỡ đôi khi Mạnh Đà Tử tử vong. Vương Lâm nung chảy phần còn lại luyện thành phi kiếm độc có gai (@c0155).","nguon":"@c0155"}],"danDuoc":[],"khac":[{"ten":"Ngọc giản Minh quyết","moTa":"Ngọc giản ghi công pháp 9 tầng lấy độc nhập đạo; thu từ túi trữ vật Mạnh Đà Tử và rơi vào tay Vương Lâm (@c0155).","nguon":"@c0155"}]}},"nguon":["@c0146","@c0147","@c0148","@c0150","@c0153","@c0154","@c0155","@c0162"]},{"id":"thien-ma-tan-nhan","name":"Thiên Ma Tán Nhân","cn":"","aliases":["Thiên Tán ma"],"gioiTinh":"nam","theLuc":[{"ten":"Yêu Thần huyết hải","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Yêu ma thượng cổ (chủ mưu — tu vi cao thâm khó lường, @c0165)","trangThai":"song","vaiTro":"Chủ mưu thật của ván cờ Cổ Thần chi địa","tinhCach":[{"text":"Thâm trầm, gian xảo bậc nhất — già đời gian xảo, dù gặp đại biến sắc mặt vẫn bình tĩnh như cũ.","chuong":"@c0170"},{"text":"Tàn nhẫn vô tình với cả người thân — sẵn sàng tế sát chính đồ đệ (Lục Dục Ma Quân) để mở thần thức Cổ Thần.","chuong":"@c0165"}],"blurb":"Sư phụ của Lục Dục Ma Quân; một trong những kẻ chết trong Cổ Thần (Yêu Thần) chi địa ngàn năm trước, bị truyền thừa ma hóa thành yêu ma huyết hải. Chính là chủ mưu giăng cả ván cờ ngàn năm: âm thầm lấy trộm một phần ba truyền thừa Cổ Thần, rồi tế sát đồ đệ để mở thần thức Cổ Thần. Cùng Đóa Mục truy bắt Vương Lâm (kẻ thôn hồn).","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0162","importance":"normal","text":"Xuất hiện lần đầu dưới dạng một thân ảnh huyết sắc cao mười trượng do Mạnh Đà Tử (yêu thần Đồ Ti) thả ra giao cho Lục Dục Ma Quân; Lục Dục ngơ ngác nhận ra và gọi 'Sư phụ'."},{"chuong":"@c0165","importance":"major","text":"Lộ diện chủ mưu thật: để đồ đệ Lục Dục Ma Quân hấp thu trọn sáu dục niệm Cổ Thần đạt đại viên mãn, rồi dùng 'Dĩ dục vi kiếm' ép Lục Dục tự nổ tung — dùng cái chết của đồ đệ làm chìa khóa mở thần thức Cổ Thần. Thủ cốt của hắn thiếu một đốt ngón (đốt ngón Cổ Thần đang nằm trong túi Vương Lâm)."},{"chuong":"@c0166","importance":"normal","text":"Bị Đóa Mục đại nhân kéo đi truy lùng kẻ thôn hồn (Vương Lâm) sau khi băng tinh lam bị cướp."},{"chuong":"@c0170","importance":"normal","text":"Có mặt trong nhóm vận hành phong ấn; bắt đầu tính toán riêng vì biết truyền thừa Cổ Thần mà mình lấy trộm một phần ba sắp bị lộ khi phong ấn Thác Sâm được mở."}],"tuVi":"Yêu ma thượng cổ, tu vi cao thâm khó lường; là chủ mưu đứng sau cả nhóm (@c0165).","tuViMoc":[{"chuong":"@c0165","canhGioi":"Yêu ma thượng cổ (chủ mưu)","text":"Tu vi đủ để tế sát một Hóa Thần đại viên mãn (Lục Dục Ma Quân) và giăng ván cờ ngàn năm."}],"nhanMach":[{"ten":"Lục Dục Ma Quân","quanHe":"Đồ đệ (đã tế sát)","ghiChu":"Đồ đệ ruột; bị chính hắn dùng 'Dĩ dục vi kiếm' ép tự nổ để mở thần thức Cổ Thần (@c0165).","tag":"su-mon"},{"ten":"Vương Lâm","quanHe":"Mục tiêu truy bắt","ghiChu":"Cùng Đóa Mục truy lùng VL (kẻ thôn hồn) sau khi VL cướp băng tinh lam (@c0166).","tag":"doi-thu"},{"ten":"Đóa Mục","quanHe":"Đồng hành (huyết hải)","ghiChu":"Cùng truy bắt kẻ thôn hồn.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[{"ten":"Dĩ dục vi kiếm","moTa":"Thủ đoạn ép một kẻ đã hấp thu trọn dục niệm Cổ Thần tự nổ tung; dùng để hiến tế Lục Dục Ma Quân mở thần thức Cổ Thần (@c0165).","nguon":"@c0165"}],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0162","@c0165","@c0166","@c0170"]},{"id":"doa-muc","name":"Đóa Mục","cn":"","aliases":["Đóa Mục đại nhân"],"gioiTinh":"nam","theLuc":[{"ten":"Yêu Thần huyết hải","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Thượng cổ tu sĩ — tu vi vượt thang Chu Tước tinh (@c0166)","trangThai":"song","vaiTro":"Thủ lĩnh thật nhóm du hồn huyết hải","tinhCach":[{"text":"Quyền uy, quyết đoán — địa vị dưới thập đại chiến tướng huyết hải, ra lệnh điều động cả nhóm.","chuong":"@c0166"},{"text":"Nóng nảy, thiếu kiên nhẫn — sốt ruột với cách Vương Lâm cò kè, doạ 'tiễn ngươi một đoạn'.","chuong":"@c0170"}],"blurb":"Thượng cổ tu sĩ trong Yêu Thần huyết hải, địa vị chỉ dưới thập đại chiến tướng huyết hải, tu vi vượt thang Chu Tước tinh. Là thủ lĩnh thật của nhóm du hồn cầu Vương Lâm phá rồi tái phong ấn Thác Sâm (Cổ Ma Đồ Ti); dẫn VL qua khe nứt vào không gian bí mật để vận hành phong ấn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0166","importance":"major","text":"Lộ danh xưng Đóa Mục đại nhân; bóp nát băng tinh lam rồi kéo Thiên Ma Tán Nhân đi truy lùng kẻ thôn hồn (Vương Lâm)."},{"chuong":"@c0168","importance":"normal","text":"Lộ diện là thủ lĩnh thật của nhóm; dẫn Vương Lâm qua khe nứt vào không gian bí mật vận hành phong ấn Thác Sâm."},{"chuong":"@c0170","importance":"normal","text":"Cùng lão giả (đại ca) thương lượng, giao Hỗn Nguyên khu thú quyển + 20 cực phẩm linh thạch cho Vương Lâm; sốt ruột định ra tay nhưng bị lão giả ngăn, cuối cùng để VL giữ mười pháp khí bổn mạng làm con tin."}],"tuVi":"Thượng cổ tu sĩ huyết hải, tu vi vượt thang Chu Tước tinh (@c0166).","tuViMoc":[{"chuong":"@c0166","canhGioi":"Thượng cổ tu sĩ (vượt thang Chu Tước tinh)","text":"Địa vị dưới thập đại chiến tướng huyết hải; tu vi rất cao."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Người được nhờ phá phong ấn","ghiChu":"Cầu VL (thôn hồn) vào huyết hải phá rồi tái phong ấn Thác Sâm, đổi Hỗn Khu Thú Quyển; bị VL ép giữ mười pháp khí bổn mạng làm con tin (@c0168–@c0170).","tag":"khac"},{"ten":"Thác Sâm","quanHe":"Đối tượng cần phong ấn","ghiChu":"Cổ Ma Đồ Ti bị phong ấn mấy vạn năm; nhóm Đóa Mục muốn tái phong ấn.","tag":"doi-thu"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0166","@c0168","@c0169","@c0170"]},{"id":"thac-sam","name":"Thác Sâm","cn":"","aliases":["Hồng phát nam tử","Cổ Ma Đồ Ti","Kẻ đứng đầu huyết hải"],"gioiTinh":"nam","theLuc":[{"ten":"Yêu Thần huyết hải","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Ma vật chủ huyết hải — bị phong ấn (@c0163, @c0169)","trangThai":"song","vaiTro":"Kẻ đứng đầu Yêu Thần huyết hải (bị phong ấn)","tinhCach":[{"text":"Cuồng ngạo, áp chế — khí tức cuồng ngạo mạnh mẽ khiến người nhìn vào hít thở không thông.","chuong":"@c0170"},{"text":"Thao túng, ép buộc — buộc Vương Lâm hấp thu phân thức mở phong ấn, nếu không thì giết.","chuong":"@c0170"}],"blurb":"Nam tử tóc đỏ như máu, kẻ đứng đầu Yêu Thần huyết hải, bị phong ấn trên cây cột đá thông thiên mấy vạn năm. Theo lời nhóm du hồn, thực chất là ma vật do oán niệm của cổ thần Đồ Ti khi chết ngưng tụ thành — tức Cổ Ma Đồ Ti. Cầm Hỗn Nguyên khu thú quyển làm vật trao đổi; ép Vương Lâm (thôn hồn) hấp thu 'Đồ Ti phân thức' để giải phong ấn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0163","importance":"major","text":"Lộ diện là kẻ đứng đầu huyết hải bị phong ấn mấy vạn năm; phát hiện Vương Lâm là thôn hồn nên lệnh toàn bộ 'yêu thần Đồ Ti' đi bắt VL."},{"chuong":"@c0169","importance":"normal","text":"Nhóm du hồn tiết lộ Thác Sâm thực chất là ma vật do oán niệm cổ thần Đồ Ti chết ngưng tụ (Cổ Ma Đồ Ti); cần một thôn hồn vào huyết hải tái phong ấn hắn."},{"chuong":"@c0170","importance":"major","text":"Trao Hỗn Nguyên khu thú quyển + 20 cực phẩm linh thạch cho Vương Lâm, nhờ phá phong ấn; ép VL hấp thu 'Đồ Ti phân thức' (nếu không thì chết). Sau khi phong ấn dần được giải, nhóm du hồn cảm thấy Thác Sâm có một biến đổi khó nói rõ là ở chỗ nào."},{"chuong":"@c0318","importance":"major","text":"Tuyên bố sắp thoát thể xác Cổ Thần (tiến trình giải phong ấn tiếp tục). (@c0318)"}],"tuVi":"Ma vật chủ huyết hải, khí tức cuồng ngạo áp chế; bị phong ấn mấy vạn năm (@c0163, @c0170).","tuViMoc":[{"chuong":"@c0170","canhGioi":"Ma vật chủ huyết hải (bị phong ấn)","text":"Khí tức mạnh tới mức Vương Lâm nhìn vào hít thở không thông; đang được giải phong ấn dần."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Người phá phong ấn (bị ép)","ghiChu":"Ép VL (thôn hồn) hấp thu Đồ Ti phân thức để giải phong ấn, đổi lại Hỗn Nguyên khu thú quyển (@c0170).","tag":"khac"},{"ten":"Đồ Ti (Cổ Thần)","quanHe":"Bản thể oán niệm","ghiChu":"Theo lời nhóm du hồn, Thác Sâm là oán niệm của cổ thần Đồ Ti chết ngưng tụ (@c0169).","tag":"khac"}],"tuiDo":{"phapBao":[{"ten":"Hỗn Nguyên khu thú quyển","moTa":"Đồng quyển cổ phác lớn như thủ trạc, bên ngoài khắc nhiều tiên thú dữ tợn sống động; bên trong vang tiếng rít gào; bảo vật cấp một trong truyền thuyết. Thác Sâm dùng làm vật trao đổi với Vương Lâm (@c0170).","nguon":"@c0170"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0163","@c0169","@c0170","@c0318"]},{"id":"uong-thanh-viet","name":"Uông Thanh Việt","cn":"","aliases":["Bạch y văn sỹ"],"gioiTinh":"nam","theLuc":[{"ten":"Âm Dương Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần kỳ (nghi; ngang Bát Cực Ma Quân @c0144)","trangThai":"song","vaiTro":"Sứ giả Âm Dương Tông (đồng hành)","tinhCach":[{"text":"Ngông cuồng, hiếu kỳ — không do dự xông vào Toái Tinh Loạn để khám phá bí mật, lập tức bị phân thân của chính mình tấn công.","chuong":"@c0145"},{"text":"Tham vọng, đa nghi — tham lam nhìn cực phẩm linh thạch; thần thức để ý đề phòng Vương Lâm.","chuong":"@c0144"}],"blurb":"Trung niên văn sỹ mặc bố sam, đầu đội khăn vuông, mặt trắng như ngọc; sứ giả Âm Dương Tông của tứ cấp tu chân quốc, tu vi cao thâm 'nhìn không thấu' ngang Đoan Mộc Cực, tinh thông ngũ hành (độn) thuật. Cùng đoàn thâm nhập Cổ Thần Chi Địa; là người Đoan Mộc Cực cần để vượt năm ngũ hành chi địa.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0144","importance":"normal","text":"Xuất hiện trả lại Hành Thổ Chu cho Đoan Mộc Cực rồi gia nhập chuyến đi; ngạc nhiên khi biết Vương Lâm hữu dụng nhờ Tử Chú thuật. Tốc độ không cần pháp bảo vẫn ngang hồ lô."},{"chuong":"@c0146","importance":"minor","text":"Trợ giúp Đoan Mộc Cực bằng ngũ hành độn thuật; đang đấu với phân thân của chính mình trên Toái Tinh Loạn, bị ép vào thế hạ phong."},{"chuong":"@c0147","importance":"minor","text":"Trong trận vây cự xà, chắp hai tay triệu phù chú kim-mộc-thủy-hỏa-thổ tạo trận pháp ngũ hành oanh kích thân cự xà."}],"tuVi":"Tu vi cao thâm 'nhìn không thấu', ngang Bát Cực Ma Quân (nghi Hóa Thần kỳ); tinh thông ngũ hành độn thuật (@c0144).","tuViMoc":[{"chuong":"@c0144","canhGioi":"Hóa Thần kỳ (nghi)","text":"Tu vi ngang Đoan Mộc Cực; Uông Thanh Việt nói nếu VL là Nguyên Anh kỳ thì muốn lãnh giáo — gián tiếp cho thấy ở tầm trên Nguyên Anh."}],"nhanMach":[{"ten":"Bát Cực Ma Quân (Đoan Mộc Cực)","quanHe":"Đồng hành / ngang hàng","ghiChu":"Đoan Mộc Cực cần ngũ hành thuật của Uông Thanh Việt để vượt ngũ hành chi địa; hai bên ngang tài, cảnh giác lẫn nhau.","tag":"dong-minh"}],"tuiDo":{"congPhap":[{"ten":"Ngũ hành (độn) thuật","moTa":"Công pháp cho phép di chuyển dạng nửa trong suốt, dịch chuyển tức thời khi gặp vật cản, và vượt qua năm thế giới ngũ hành (sông băng, biển lửa, sa mạc, núi đao, rừng cây) — lý do Đoan Mộc Cực đi tìm hắn.","nguon":"@c0144, @c0147, @c0150"}],"phapBao":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0144","@c0145","@c0146","@c0147","@c0150"]},{"id":"trieu-truyen-luong","name":"Triệu Truyện Lương","cn":"","aliases":["Triệu Truyền Lương"],"gioiTinh":"nam","theLuc":[{"ten":"Thi Âm Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh kỳ (@c0142)","trangThai":"song","vaiTro":"Tông chủ chi nhánh Thi Âm tông (thù địch)","tinhCach":"Cung kính sợ hãi trước 'thượng tông'; quyết liệt truy sát kẻ thù của tông môn; chịu áp lực vì em ruột từng bị tuyển thân thể.","blurb":"Tông chủ đương thời của chi nhánh Thi Âm tông tại Hỏa Phần quốc, tu vi Nguyên Anh kỳ; trong người chứa hồn Dạ Tự Tại (cựu tông chủ Thi Âm tông Triệu quốc). Bị 'thượng tông' đe dọa hủy thân thể nếu không tìm ra kẻ đoạt xá mất tích; dẫn năm Nguyên Anh kỳ truy sát Vương Lâm (hóa danh Mã Lương) tới Tu Ma hải.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0142","importance":"normal","text":"Bị 'thượng tông' hiện trong quầng sáng đe dọa: cho mười ngày tìm kẻ đoạt xá mất tích (Mã Lương bị nghi), không thì báo ngũ cấp phân bộ hủy thân thể. Ra lệnh toàn bộ tu sĩ Thi Âm tông trên Kết Đan kỳ theo hắn tới Hỏa Phần Minh, mở Truyền Tống trận tập kích Vương Lâm."},{"chuong":"@c0143","importance":"normal","text":"Công khai tội của Mã Lương (giết đệ tử Thi Âm tông + đoạt xá Hứa Lập Quốc, tin mua từ Thiên Địa lão nhân); bị Bát Cực Ma Quân bóp nát Truyền Tống trận, đành cùng bốn Nguyên Anh kỳ rút lui sau khi cảnh cáo."}],"tuVi":"Nguyên Anh kỳ; bốn trăm năm trước cùng em vào Thi Âm tông (@c0142).","tuViMoc":[{"chuong":"@c0142","canhGioi":"Nguyên Anh kỳ","text":"Một trong năm Nguyên Anh kỳ Thi Âm tông tập kích Vương Lâm; trong người chứa hồn Dạ Tự Tại."}],"nhanMach":[{"ten":"Dạ Tự Tại","quanHe":"Hồn cộng sinh trong thân","ghiChu":"Cựu tông chủ Thi Âm tông Triệu quốc; thân thể tuyệt hảo từng bị ngũ cấp tông cưỡng đoạt nên chưa khôi phục được.","tag":"khac"},{"ten":"Vương Lâm","quanHe":"Mục tiêu truy sát","ghiChu":"Truy 'Mã Lương' vì giết đệ tử Thi Âm tông và đoạt xá Hứa Lập Quốc.","tag":"doi-thu"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0142","@c0143"]},{"id":"cung-mac","name":"Cung Mặc","cn":"","aliases":["Cung lão tổ"],"gioiTinh":"nam","theLuc":[{"ten":"Chiến Thần Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (lão tổ khai sáng Chiến Thần Điện)","trangThai":"mat-tich","vaiTro":"Lão tổ khai sáng (nhân vật lịch sử)","tinhCach":"Không rõ tính cách chi tiết; chỉ được nhắc qua lời kể và linh bài.","blurb":"Lão tổ khai sáng Chiến Thần Điện và là người phát hiện ra Thần Đạo thuật. Sau khi tứ cấp tu chân quốc Thiên Cương quốc tới luận đàm rồi mang Thần Đạo thuật nguyên thủy đi, Cung Mặc đi vân du và từ đó không trở về. Chỉ xuất hiện gián tiếp qua linh bài và lời kể.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0141","importance":"minor","text":"Được nhắc qua linh bài tầng cao nhất trong thạch phủ Chiến Thần Điện và lời kể của lão giả mặt đỏ: khai sáng tông môn, phát hiện Thần Đạo thuật, rồi vân du mất tích sau khi Thiên Cương quốc mang bản nguyên thủy đi."}],"tuVi":"Không rõ (@c0141).","tuViMoc":[],"nhanMach":[{"ten":"Trần Trùng","quanHe":"Đệ tử","ghiChu":"Đệ tử tư chất kém nhất, người dùng trí nhớ khắc lại một thành Thần Đạo thuật.","tag":"su-mon"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0141"]},{"id":"tran-trung","name":"Trần Trùng","cn":"","aliases":["Trần Trùng lão tổ"],"gioiTinh":"nam","theLuc":[{"ten":"Chiến Thần Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (đệ tử Cung Mặc)","trangThai":"tu-vong","vaiTro":"Lão tổ khắc lại Thần Đạo thuật (nhân vật lịch sử)","tinhCach":"Kiên trì, hy sinh — tư chất tầm thường nhưng dồn hết tuổi thọ để khắc lại bộ thuật cho hậu nhân.","blurb":"Lão tổ Chiến Thần Điện, đệ tử có tư chất kém nhất của Cung Mặc. Bằng trí nhớ, ông khắc lại được 'một thành' Thần Đạo thuật lên thạch bích thanh ngọc — điều không ai làm được — rồi tuyệt khí qua đời, dặn hậu nhân tu luyện phải cẩn thận.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0141","importance":"minor","text":"Được nhắc qua lời kể: dùng trí nhớ khắc lại một thành Thần Đạo thuật lên thạch bích thanh ngọc; vì đại hạn đã đến nên chỉ khắc xong một phần rồi tuyệt khí qua đời."}],"tuVi":"Không rõ (@c0141).","tuViMoc":[],"nhanMach":[{"ten":"Cung Mặc","quanHe":"Sư phụ","ghiChu":"Lão tổ khai sáng Chiến Thần Điện.","tag":"su-mon"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0141"]},{"id":"co-than-do-ti","name":"Cổ thần Đồ Ti","cn":"","aliases":["Đồ Ti"],"gioiTinh":"nam","theLuc":[{"ten":"Chủ nhân Cấm Sơn (Cổ Thần Chi Địa)","trangThai":"hien-tai"}],"canhGioiCaoNhat":"Cổ Thần (vượt Hóa Thần, không rõ cảnh giới cụ thể @c0160)","trangThai":"khong-ro","vaiTro":"Cổ thần chủ Cấm Sơn; người giao nhiệm vụ chế Cấm Phiên","tinhCach":"Thận trọng, chọn lọc — chỉ công nhận người lĩnh ngộ thực sự; sau khi chờ đủ điều kiện mới xuất hiện giao nhiệm vụ.","blurb":"Phân thân của Cổ thần Đồ Ti, cai quản Cấm Sơn trong Cổ Thần Chi Địa. Sau khi Vương Lâm dành mười ba năm vượt ba trăm trượng cuối Cấm Sơn, phân thân Đồ Ti xuất hiện, công nhận VL là người lĩnh ngộ thứ tư, và giao nhiệm vụ chế Cấm Phiên (cần 999.999 cấm chế + Mặc Gian thạch từ thiên thạch ngoài không gian).","tabs":{"diem":[{"text":"Giữ một viên Mặc Gian thạch trong thức hải bản thể — vật liệu thiết yếu chế Cấm Phiên, trao cho người lĩnh ngộ khi đủ điều kiện.","chuong":"@c0160"}],"kinhLich":[{"chuong":"@c0160","importance":"major","text":"Phân thân xuất hiện sau khi Vương Lâm vượt ba trăm trượng cuối (tổng mười ba năm); công nhận VL là người lĩnh ngộ thứ tư, giao ngọc giản chế Cấm Phiên và thông báo bản thể giữ một viên Mặc Gian thạch."}],"tuVi":"Cổ Thần, vượt ra ngoài hệ thống Hóa Thần kỳ (@c0160).","tuViMoc":[{"chuong":"@c0160","canhGioi":"Cổ Thần","text":"Danh hiệu Cổ thần, chủ nhân Cấm Sơn trong Cổ Thần Chi Địa; cảnh giới cụ thể không rõ."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Người lĩnh ngộ thứ tư","ghiChu":"Công nhận VL sau mười ba năm trên Cấm Sơn; giao nhiệm vụ chế Cấm Phiên.","tag":"dong-hanh"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"nguyenLieu":[{"ten":"Mặc Gian thạch (trong thức hải bản thể)","moTa":"Đá thiên thạch từ ngoài không gian; một viên lưu giữ trong thức hải bản thể Đồ Ti. Vật liệu thiết yếu chế Cấm Phiên, sẽ cấp cho Vương Lâm khi chế tác (@c0160).","nguon":"@c0160"}],"khac":[]}},"nguon":["@c0160"]}]};