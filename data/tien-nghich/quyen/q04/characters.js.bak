/* characters q04 (118 mục) — cân xếp hạng toàn cảnh Thiên Vận Tử - gop trung 2026-06-24 - gop theo danh sach 2026-06-25 - sua the 2026-06-27 - gop theo danh sach 2026-06-27 - gop theo danh sach 2026-06-27 - bo sung noi dung 2026-06-27 - bo sung noi dung 2026-06-27 - bo sung noi dung 2026-06-27 - sua field 2026-06-27 - bo sung noi dung 2026-06-27 */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["tien-nghich"]=window.__LIBQ["tien-nghich"]||{};window.__LIBQ["tien-nghich"]["q04"]=window.__LIBQ["tien-nghich"]["q04"]||{};window.__LIBQ["tien-nghich"]["q04"]["characters"]={"updatedAt":"2026-06-24","count":116,"chars":[{"id":"am-duong-lao-nhan","name":"Âm Dương lão nhân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Hợp Hoan Tông"],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ (@c0213)","trangThai":"song (@c0213 — bị thương khi trận vỡ, đầu hàng mở trận)","vaiTro":"Thủy tổ Hợp Hoan Tông","tinhCach":"Thận trọng khi đối mặt kẻ mạnh hơn; thực dụng — ưu tiên bảo toàn tông môn hơn giữ nghĩa với Đằng gia.","blurb":"Đệ nhất thủy tổ Hợp Hoan Tông, tu vi Nguyên Anh hậu kỳ. Chủ trì hộ sơn đại trận khi Vương Lâm tấn công; bị ép buộc phải mở trận sau khi VL giết dần hàng nghìn đệ tử hộ trận và ngưng lôi cầu Cực Cảnh đỏ. Cung kính gọi VL là 'Tiền bối' và chỉ nơi Đằng gia ẩn náu trong đại điện (@c0213).","tabs":{"diem":[{"text":"Nguyên Anh hậu kỳ nhưng tự nhận động thủ với Đằng Hóa Nguyên (cũng Nguyên Anh hậu kỳ) vẫn phải 'lượng sức' — xác nhận thực lực ngang hàng.","chuong":"@c0213"}],"kinhLich":[{"chuong":"@c0213","importance":"major","text":"Họp cùng 3 Nguyên Anh tu sĩ Hợp Hoan Tông bàn về 'ma tu' (đồn Hóa Thần kỳ) đang tàn sát Đằng gia. Quyết định giữ Đằng gia làm con tin và khởi động hộ sơn đại trận nghênh chiến. Khi VL giết dần đệ tử hộ trận (gần nghìn người) và ngưng lôi cầu đỏ Cực Cảnh, hắn khiếp sợ đầu hàng, cung kính gọi VL là 'Tiền bối', mở trận và chỉ nơi Đằng gia. Bị thương khi trận vỡ. (@c0213)"}],"tuVi":"Nguyên Anh hậu kỳ (@c0213).","tuViMoc":[{"chuong":"@c0213","canhGioi":"Nguyên Anh hậu kỳ","text":"Tự xác nhận khi so sánh với Đằng Hóa Nguyên (cũng hậu kỳ) @c0213."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Cường địch (ép mở trận)","ghiChu":"Bị VL ép mở hộ sơn đại trận; đầu hàng và cung kính gọi 'Tiền bối' @c0213.","tag":"doi-thu"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0213"]},{"id":"cao-khai-minh","name":"Cao Khải Minh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Phiêu Miểu Tông","trangThai":"da-roi"}],"canhGioiCaoNhat":"Không rõ (chưởng môn tông phái; tu vi không được nêu trong nguyên tác)","trangThai":"tu-vong","vaiTro":"Nhân vật phụ — chưởng môn Phiêu Miểu Tông, người bói ra vị trí gia đình Vương Lâm","tinhCach":"Đặt sự tồn vong của môn phái lên trên tính mạng bản thân; tự sát để cắt đứt dây liên quan khi biết bại cục đã định.","blurb":"Chưởng môn Phiêu Miểu Tông, chuyên thuật bói toán. Theo lệnh Đằng Hóa Nguyên, dùng bói toán dò ra vị trí gia đình Vương Lâm — nguyên nhân gốc rễ khiến Đằng gia có thể đe dọa tính mạng thân nhân VL. Khi Đằng gia sụp đổ và VL biết rõ danh tính, Cao Khải Minh tự sát để tránh liên lụy môn phái, hy sinh bản thân bảo toàn đệ tử.","tabs":{"diem":[{"text":"Tự sát vì môn phái — khi biết Vương Lâm biết rõ danh tính mình, chọn chết ngay để cắt đứt dây liên quan, bảo toàn Phiêu Miểu Tông.","chuong":"@c0223"}],"kinhLich":[{"chuong":"@c0222","importance":"normal","text":"Đằng Hóa Nguyên trước khi chết khai tên Cao Khải Minh — chưởng môn Phiêu Miểu Tông, người dùng thuật bói toán tìm ra vị trí gia đình Vương Lâm theo lệnh Đằng gia. (@c0222)"},{"chuong":"@c0223","importance":"major","tieuDe":"Tự sát bảo toàn môn phái","text":"Khi biết mình bị điểm danh và Vương Lâm đang diệt sạch thế lực liên quan, Cao Khải Minh tự sát ngay tại chỗ — hy sinh bản thân để cắt đứt dây liên quan, tránh để Phiêu Miểu Tông bị vạ lây. (@c0223)"}],"tuVi":"chưa xác nhận.","tuViMoc":[],"nhanMach":[{"ten":"Đằng Hóa Nguyên","quanHe":"Người thuê dịch vụ bói toán","ghiChu":"Thực hiện bói toán theo yêu cầu Đằng gia, tìm ra vị trí gia đình Vương Lâm.","tag":"dong-minh"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0222","@c0223"]},{"id":"nap-da","name":"Nạp Đa","cn":"","aliases":["thanh niên tà dị"],"gioiTinh":"nam","theLuc":[{"ten":"Ngũ Hành tinh","trangThai":"da-roi"}],"canhGioiCaoNhat":"Anh Biến sơ kỳ (3/10 sức mạnh khi gặp VL @c0223–@c0224)","trangThai":"song","vaiTro":"Nhân vật phụ — người ngoài tinh cầu, tiết lộ bí quyết đột phá Cực Cảnh","tinhCach":"Bộc trực, dễ nổi giận; biết lùi đúng lúc khi gặp đối thủ vượt tầm. Từng có bạn thân quan trọng (đã mất) để lại di vật.","blurb":"Thanh niên xuất thân Ngũ Hành tinh, tu vi Anh Biến sơ kỳ (chỉ đạt 3/10 sức mạnh khi gặp Vương Lâm). Đuổi theo Vương Lâm đòi lại túi trữ vật bị thất lạc. Tiết lộ bí quyết đột phá Cực Cảnh: cần trấn quốc chi bảo của lục cấp Tu Chân Quốc. Sở hữu Cực Cảnh Ngũ Sắc — di vật từ người bạn thân đã chết. Dùng la bàn đen mở hắc động rời khỏi tinh cầu.","tabs":{"diem":[{"text":"Biết người biết ta — dù tức giận muốn trả đũa nhưng nhận ra Cấm Phiên (gây Thiên Kiếp) của Vương Lâm vượt quá tầm xử lý, lập tức lùi bước.","chuong":"@c0224"}],"kinhLich":[{"chuong":"@c0223","importance":"normal","text":"Xuất hiện với danh nghĩa 'thanh niên tà dị' đuổi theo Vương Lâm đòi lại túi trữ vật bị mất. VL nhận ra từ ảo cảnh ở @c0220. (@c0223)"},{"chuong":"@c0224","importance":"major","tieuDe":"Tiết lộ bí quyết Cực Cảnh — rời tinh cầu bằng la bàn đen","text":"VL trả túi trữ vật; Nạp Đa nổi giận muốn trả đũa nhưng VL thị uy Cấm Phiên (phát sinh Thiên Kiếp), Nạp Đa đành lùi. Tiết lộ: đột phá Cực Cảnh cần trấn quốc chi bảo lục cấp Tu Chân Quốc. Tự giới thiệu tên Nạp Đa, xuất thân Ngũ Hành tinh; khoe Cực Cảnh Ngũ Sắc — di vật người bạn thân đã mất. Dùng la bàn đen mở hắc động rời khỏi tinh cầu. (@c0224)"}],"tuVi":"Anh Biến sơ kỳ, chỉ đạt 3/10 sức mạnh thật khi gặp VL @c0224.","tuViMoc":[{"chuong":"@c0224","canhGioi":"Anh Biến sơ kỳ","text":"Tự tiết lộ: chỉ đạt khoảng 3/10 sức mạnh thật khi đang ở Triệu quốc @c0224."}],"nhanMach":[{"ten":"Vương Lâm","quanHe":"Tình cờ gặp — tranh chấp túi trữ vật","ghiChu":"Đuổi theo VL đòi túi trữ vật; bị VL thị uy Cấm Phiên đành lùi; tình cờ tiết lộ bí quyết quan trọng cho VL trước khi rời đi @c0224.","tag":"xa-la"}],"tuiDo":{"phapBao":[{"ten":"La bàn đen (Tinh La Bàn)","loai":"phap-bao","trangThai":"hien-tai","moTa":"Pháp bảo hình la bàn màu đen dùng để mở hắc động — lối vào không gian hư vô liên tinh cầu. Nạp Đa dùng để rời Triệu quốc (Chu Tước tinh) về Ngũ Hành tinh @c0224.","nguon":"@c0224"},{"ten":"Cực Cảnh Ngũ Sắc","loai":"phap-bao","trangThai":"hien-tai","moTa":"Pháp bảo di vật từ người bạn thân đã mất của Nạp Đa. Chi tiết tác dụng chưa được nêu trong nguyên tác tới chương 230.","nguon":"@c0224"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0223","@c0224"]},{"id":"lieu-phi","name":"Liễu Phỉ","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"dang-o"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ — đại trưởng lão VTT @c0306; 143 năm ở NA hậu kỳ, thần thức đi vào 100 trượng trong bài tập ma luyện @c0307","trangThai":"song","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Chấp nhận thất bại không do dự — khi Vương Lâm chiến thắng hoàn toàn, lập tức đề nghị đầu hàng giúp tông môn bảo toàn còn lại.","chuong":"@c0201"},{"text":"Quyết đoán và tàn nhẫn khi cần thiết — dẫn 2 trưởng lão Nguyên Anh sơ kỳ đã thề ra ngoài và biến họ thành rối (diệt khẩu) để bảo vệ bí mật thân phận Tằng Ngưu của VL.","chuong":"@c0306"},{"text":"Kiên định theo đuổi Hóa Thần — bỏ chức đại trưởng lão đi theo VL dù biết con đường gian nan, vì đây là cơ hội duy nhất.","chuong":"@c0306"}],"blurb":"Đại trưởng lão Nguyên Anh hậu kỳ của Vân Thiên Tông; bị Vương Lâm bắt sống năm xưa. Sau khi VL trở về, nàng bỏ chức vụ đi theo VL với hy vọng đạt Hóa Thần, đã 143 năm mắc kẹt ở Nguyên Anh hậu kỳ.","tabs":{"diem":[{"text":"Tu vi Nguyên Anh trung kỳ đỉnh — cao nhất còn lại trong Vân Thiên Tông sau khi lão nhân áo xám chết; bị Thanh Đồng Cổ Kính bắt sống.","chuong":"@c0201"},{"text":"Đại trưởng lão Nguyên Anh hậu kỳ VTT; báo cáo với VL về tình trạng LMU (3 lần Kết Anh thất bại, suýt chết lần cuối 30 năm trước).","chuong":"@c0306"},{"text":"143 năm ở Nguyên Anh hậu kỳ; theo VL cầu Hóa Thần. Thần thức đi vào 100 trượng trong bài tập ma luyện bảo tháp.","chuong":"@c0307"}],"kinhLich":[{"chuong":"@c0201","importance":"major","tieuDe":"Bị Vương Lâm bắt sống trong trận diệt Vân Thiên Tông","text":"Là tu sĩ mạnh nhất VTT còn lại sau khi lão nhân áo xám bị giết. Bị Vương Lâm dùng Thanh Đồng Cổ Kính bắt sống, trao huyết hồn làm đòn bẩy buộc bốn lão tổ nộp huyết hồn; lập tức đề nghị đầu hàng bảo toàn tông môn. (@c0201)"},{"chuong":"@c0306","importance":"major","tieuDe":"Bỏ chức vụ — theo Vương Lâm cầu Hóa Thần","text":"Báo cáo với VL về tình trạng LMU (3 lần Kết Anh thất bại, lần gần nhất 30 năm trước suýt chết). Sau khi VL lệnh bảo mật, tự nguyện dẫn 2 trưởng lão Nguyên Anh sơ kỳ mới ra ngoài diệt khẩu (biến họ thành rối). Bỏ chức đại trưởng lão đi theo VL — 143 năm mắc kẹt ở Nguyên Anh hậu kỳ, hy vọng đây là cơ hội cuối cầu Hóa Thần. (@c0306)"},{"bridge":true,"khoang":"@c0307–@c0310","text":"Hộ vệ VL và LMU trên đường về Tu Ma Hải; thần thức đi vào 100 trượng trong bài tập ma luyện uy áp bảo tháp. Tham dự đấu giá Luyện Khí Các, được VL giao bảo vệ LMU khi VL đi tìm Chu Ngạn Hoành. (@c0307–@c0310)"}],"tuViMoc":[{"chuong":"@c0201","canhGioi":"Nguyên Anh trung kỳ đỉnh","text":"Tu vi xác nhận khi Vương Lâm dùng Thanh Đồng Cổ Kính bắt sống trong trận phá Vân Thiên Tông."},{"chuong":"@c0306","canhGioi":"Nguyên Anh hậu kỳ (143 năm bế tắc)","text":"Đại trưởng lão Nguyên Anh hậu kỳ VTT; 143 năm mắc kẹt ở cảnh giới này, không thể đột phá Hóa Thần. Theo VL với hy vọng đây là cơ hội duy nhất. VL chỉ dẫn: linh lực bề bộn cần đồng nhất mới cảm ngộ Hóa Thần."}],"nhanMach":[{"ten":"Vân Thiên Tông","gap":"@c0201","quanHe":"Môn phái (đại trưởng lão)","ghiChu":"Đại trưởng lão cao cấp nhất; sau khi VL rời, ở lại cùng Tống Thanh quản lý tông, mở rộng thành đứng đầu Sở quốc.","tag":"the-luc","uuTien":60},{"ten":"Vương Lâm","gap":"@c0201","quanHe":"Chủ nhân — người dẫn đường đến Hóa Thần","ghiChu":"Ban đầu bị bắt sống, trao huyết hồn. Sau khi VL trở về, tự nguyện theo VL cầu Hóa Thần; bỏ chức đại trưởng lão.","tag":"thuoc-ha","uuTien":85},{"ten":"Lý Mộ Uyển","gap":"@c0302","quanHe":"Tông chủ (bảo vệ)","ghiChu":"Hộ vệ LMU theo lệnh VL từ @c0306 đến @c0310.","tag":"cap-tren","uuTien":70}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0201","@c0306","@c0307","@c0308","@c0309","@c0310"]},{"id":"tong-thanh","name":"Tống Thanh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"dang-o"}],"canhGioiCaoNhat":"Nguyên Anh kỳ (cụ thể chưa rõ) @c0201","trangThai":"song","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Tỉnh táo và linh hoạt trong khủng hoảng — là nội tông tông chủ vẫn sống sót khi tông môn bị diệt.","chuong":"@c0201"},{"text":"Thực tế và biết phân tích — bổ sung thông tin cho VL: tuổi thọ LMU đã kéo dài quá giới hạn Kết Đan bằng đan dược, không thể nghịch thiên trừ phi kết anh.","chuong":"@c0306"}],"blurb":"Nội tông tông chủ Vân Thiên Tông. Sống sót sau khi Vương Lâm tấn công tông môn; sau đó cùng Liễu Phỉ quản lý tông, mở rộng Vân Thiên Tông thành môn phái đứng đầu Sở quốc.","tabs":{"diem":[{"text":"Nội tông tông chủ — lãnh đạo nội bộ Vân Thiên Tông; sống sót qua trận Vương Lâm tấn công.","chuong":"@c0201"},{"text":"Bổ sung thông tin với VL về tình trạng LMU — tuổi thọ kéo dài nhờ đan dược nhưng sắp cạn, chỉ Kết Anh mới cứu được.","chuong":"@c0306"}],"kinhLich":[{"chuong":"@c0201","importance":"normal","tieuDe":"Sống sót sau trận Vương Lâm phá Vân Thiên Tông","text":"Nội tông tông chủ sống sót khi 5/9 trưởng lão tử vong. Chứng kiến VL dùng Thanh Đồng Cổ Kính bắt sống Liễu Phỉ, tông môn đầu hàng. (@c0201)"},{"chuong":"@c0306","importance":"normal","tieuDe":"Báo cáo VL tình trạng Lý Mộ Uyển — ở lại quản lý tông","text":"Bổ sung cho Lữ Phi: tuổi thọ LMU vượt giới hạn Kết Đan bằng đan dược, không thể nghịch thiên — trừ phi kết anh thành công. Sau đó ở lại cùng Liễu Phỉ quản lý Vân Thiên Tông, nhân cơ hội nhiều môn phái bị diệt, mở rộng thành đứng đầu Sở quốc. (@c0306)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vân Thiên Tông","gap":"@c0201","quanHe":"Môn phái (tông chủ nội tông)","ghiChu":"Nội tông tông chủ; sống sót sau trận VL tấn công, 5/9 trưởng lão chết. Sau đó cùng Liễu Phỉ mở rộng thành đứng đầu Sở quốc.","tag":"the-luc","uuTien":60},{"ten":"Vương Lâm","gap":"@c0201","quanHe":"Chủ nhân (qua Lý Mộ Uyển)","ghiChu":"VL là ân nhân của LMU — Tống Thanh và Liễu Phỉ phục vụ trực tiếp cho LMU.","tag":"cap-tren","uuTien":70}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0201","@c0303","@c0306"]},{"id":"ton-tran-vi","name":"Tôn Trấn Vĩ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Vân Thiên Tông"],"canhGioiCaoNhat":"Kết Đan kỳ @c0200","trangThai":"tu-vong","vaiTro":"Phản diện","tinhCach":[{"text":"Kiêu ngạo dựa vào thế lực — ép hôn Lý Mộ Uyển vì ỷ vào thế lực cha (Nguyên Anh trung kỳ) và Vân Thiên Tông.","chuong":"@c0200"}],"blurb":"Trưởng lão Kết Đan kỳ Vân Thiên Tông, con trai lão nhân áo xám (Nguyên Anh trung kỳ). Ép hôn Lý Mộ Uyển tại điển lễ song tu, khiến Vương Lâm ra tay. Bị VL giết trong trận phá Vân Thiên Tông; Thanh Đồng Cổ Kính bắt Nguyên Anh không để thoát.","tabs":{"diem":[{"text":"Kết Đan kỳ — trưởng lão Vân Thiên Tông; ép hôn Lý Mộ Uyển nhờ thế lực cha và tông môn.","chuong":"@c0200"},{"text":"Bị giết trong trận Vương Lâm phá tông — Thanh Đồng Cổ Kính bắt Nguyên Anh tại chỗ.","chuong":"@c0201"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0200","canhGioi":"Kết Đan kỳ","importance":"normal","text":"Xác nhận là Kết Đan kỳ — trưởng lão Vân Thiên Tông; ép hôn Lý Mộ Uyển."}],"nhanMach":[{"ten":"Lão nhân áo xám","gap":"@c0201","quanHe":"Phụ thân","ghiChu":"Cha là Nguyên Anh trung kỳ, tử chiến với VL để bảo vệ con.","tag":"gia-dinh","uuTien":70},{"ten":"Vân Thiên Tông","gap":"@c0200","quanHe":"Môn phái","ghiChu":"Trưởng lão; dựa thế lực tông môn ép hôn.","tag":"the-luc","uuTien":60},{"ten":"Lý Mộ Uyển","gap":"@c0200","quanHe":"Người bị ép hôn","ghiChu":"Nhân vật gây ra mâu thuẫn VL vs Vân Thiên Tông.","tag":"tinh-cam","uuTien":65}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0200","@c0201"]},{"id":"lao-nhan-ao-xam-cha-ton-tran-vi","name":"Lão nhân áo xám","cn":"","aliases":["cha Tôn Trấn Vĩ"],"gioiTinh":"nam","theLuc":["Vân Thiên Tông"],"canhGioiCaoNhat":"Nguyên Anh trung kỳ @c0201","trangThai":"tu-vong","vaiTro":"Phản diện","tinhCach":[{"text":"Phụ thân bảo vệ con — tự xung ra tử chiến với Vương Lâm khi con trai sắp bị giết.","chuong":"@c0201"}],"blurb":"Lão tổ Nguyên Anh trung kỳ của Vân Thiên Tông, cha Tôn Trấn Vĩ. Xung ra bảo vệ con khi VL tấn công tông môn; bị VL giết — Nguyên Anh bị Thanh Đồng Cổ Kính bắt không thể xuất thể.","tabs":{"diem":[{"text":"Nguyên Anh trung kỳ — lão tổ mạnh nhất Vân Thiên Tông ra mặt bảo vệ con trai trong trận VL tấn công.","chuong":"@c0201"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0201","canhGioi":"Nguyên Anh trung kỳ","importance":"normal","text":"Xác nhận tu vi trong trận chiến — tử vong khi Thanh Đồng Cổ Kính khóa Nguyên Anh."}],"nhanMach":[{"ten":"Tôn Trấn Vĩ","gap":"@c0201","quanHe":"Con trai","ghiChu":"Xung ra chết vì bảo vệ con.","tag":"gia-dinh","uuTien":70},{"ten":"Vân Thiên Tông","gap":"@c0201","quanHe":"Môn phái (lão tổ)","ghiChu":"Lão tổ cấp Nguyên Anh duy nhất ra mặt chống VL.","tag":"the-luc","uuTien":60}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0201"]},{"id":"tran-bach-luong","name":"Trần Bách Lương","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Vân Thiên Tông"],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ @c0202","trangThai":"tu-vong","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Ngạnh kháng tới cùng — là lão tổ duy nhất dám chống Vương Lâm tới chết thay vì quy hàng.","chuong":"@c0202"}],"blurb":"Lão tổ Nguyên Anh hậu kỳ của Vân Thiên Tông, người duy nhất dám chống Vương Lâm tới cùng. Tế Tử Mặc Trùng cùng Huyết thuẫn phá giải Cực cảnh thần thức của VL một lần, nhưng cuối cùng ngạnh kháng tới mức phun tiên huyết ngã chết tại trận — lão tổ duy nhất bỏ mình. Bốn lão tổ còn lại quy hàng giao huyết hồn. Vương Lâm thu Tử Mặc Trùng từ túi trữ vật của ông.","tabs":{"diem":[{"text":"Lão tổ duy nhất bỏ mình trong trận — ngạnh kháng tới chết, không quy hàng như bốn lão tổ còn lại.","chuong":"@c0202"}],"kinhLich":[],"tuViMoc":[],"nhanMach":[{"ten":"Vân Thiên Tông","gap":"@c0202","quanHe":"Môn phái (lão tổ)","ghiChu":"Lão tổ Nguyên Anh hậu kỳ; ngạnh kháng tới chết.","tag":"the-luc","uuTien":50}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0202"]},{"id":"chu-vu-duc","name":"Chu Vũ Đức","cn":"","aliases":["lão nhân mũi ưng"],"gioiTinh":"nam","theLuc":["Bí thị"],"canhGioiCaoNhat":"Nguyên Anh trung kỳ @c0207","trangThai":"tu-vong","vaiTro":"Phản diện","tinhCach":[{"text":"Mưu mô che giấu — tự xưng giúp đỡ nhưng thực chất bố trí người vây giết VL để cướp pháp bảo.","chuong":"@c0207"}],"blurb":"Lão nhân mũi ưng, Nguyên Anh trung kỳ, thành viên Bí thị. Tiếp cận VL tại chợ bí mật và giả vờ thân thiện, thực chất bố trí Diệt Độn tru sát trận (cần 6 Nguyên Anh) để cướp pháp bảo. Bị VL nhận ra bẫy và phản giết; túi trữ vật có bản đồ 4 đại lục + Tu Ma Hải.","tabs":{"diem":[{"text":"Nguyên Anh trung kỳ — thành viên Bí thị; bày bẫy Diệt Độn tru sát trận cần 6 Nguyên Anh để giết VL cướp pháp bảo.","chuong":"@c0207"},{"text":"Bị VL nhận ra bẫy và phản giết — túi trữ vật mang bản đồ 4 đại lục giá trị.","chuong":"@c0208"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0207","canhGioi":"Nguyên Anh trung kỳ","importance":"normal","text":"Tu vi xác nhận khi bày bẫy tại Bí thị; chết trong phản đòn của VL."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0207","quanHe":"Mục tiêu ám sát (thất bại)","ghiChu":"Mượn danh nghĩa Bí thị (chợ kín ba thành ở Tu Ma hải) tiếp cận VL để bày bẫy; VL nhận ra mưu kế và phản giết, thu được bản đồ quan trọng.","tag":"doi-thu","uuTien":75}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0207","@c0208"]},{"id":"thanh-nien-chien-than-dien-chu-vo-kiem","name":"Thanh niên Chiến Thần Điện","cn":"","aliases":["chủ vỏ kiếm cổ thứ hai","thanh niên Hỏa Phần quốc"],"gioiTinh":"nam","theLuc":["Hỏa Phần quốc"],"canhGioiCaoNhat":"Anh Biến kỳ (~3 thành) — thi khô @c0208","trangThai":"da-mat","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Kiên định đến cùng — ba nghìn năm nằm chờ chữa trị trong trạng thái thi khô để gìn giữ vỏ kiếm bí ẩn.","chuong":"@c0208"}],"blurb":"Tu sĩ Hỏa Phần quốc, chủ nhân vỏ kiếm cổ thứ hai. Ở trạng thái thi khô ba nghìn năm do bệnh nặng; trước khi hoàn toàn mất ý thức còn phóng Thiên Quỷ Sưu thần thuật tấn công VL. Vỏ kiếm của hắn phong ấn luồng sát khí kinh thiên — phi kiếm VL vỡ vụn khi thử rút một chút.","tabs":{"diem":[{"text":"Anh Biến kỳ ~3 thành — Hỏa Phần quốc; ba nghìn năm nằm thi khô chờ chữa bệnh; phóng Thiên Quỷ Sưu thần thuật trong hơi tàn.","chuong":"@c0208"}],"kinhLich":[],"tuViMoc":[{"chuong":"@c0208","canhGioi":"Anh Biến kỳ (~3 thành, thi khô)","importance":"normal","text":"Trạng thái thi khô ba nghìn năm; tu vi còn khoảng 3 thành; phóng Thiên Quỷ Sưu thần thuật trong hơi cuối."}],"nhanMach":[{"ten":"Hỏa Phần quốc","gap":"@c0208","quanHe":"Xuất thân","ghiChu":"Tu sĩ Hỏa Phần quốc; mang vỏ kiếm bí ẩn phong ấn sát khí.","tag":"the-luc","uuTien":50}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0208"]},{"id":"dang-tu-tu","name":"Đằng Tú Tú","cn":"","aliases":[],"gioiTinh":"nu","theLuc":["Đằng gia","Triệu quốc"],"canhGioiCaoNhat":"Kết Đan kỳ @c0210","trangThai":"da-chet (@c0217 — bị Vương Trác kết liễu)","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Thuận theo địa vị gia tộc — kết hôn với Vương Trác theo sắp xếp của Đằng gia nhằm củng cố liên minh.","chuong":"@c0210"}],"blurb":"Con gái của Đằng Tam (Đằng Hải) — hạch tâm tộc nhân Đằng gia; kết hôn với Vương Trác (Kết Đan hậu kỳ) theo sắp xếp của Đằng gia tại Triệu quốc. Khi Vương Lâm diệt Đằng gia, được cha hy sinh tu vi truyền tống cứu thoát (@c0216), nhưng cuối cùng bị chính chồng Vương Trác tự tay kết liễu để hắn không phản bội huyết hận Vương gia (@c0217).","tabs":{"diem":[{"text":"Vợ Vương Trác — liên hôn Đằng gia, củng cố quyền lực Đằng Hóa Nguyên ở Triệu quốc.","chuong":"@c0210"}],"kinhLich":[{"chuong":"@c0210","importance":"normal","tieuDe":"Khuyên chồng buông thù, bị cảnh cáo","text":"Cùng Vương Trác bay về Đằng gia thành thăm muội muội. Khuyên Vương Trác buông bỏ thù xưa, nói 'nên hận Vương Lâm chứ không nên hận lão tổ' — bị Vương Trác cảnh cáo gay gắt, bị cấm nhắc tên Vương Lâm. (@c0210)"},{"chuong":"@c0216","importance":"normal","tieuDe":"Cha Đằng Tam hy sinh tu vi truyền tống cứu","text":"Cha Đằng Tam hy sinh nguyên anh tinh huyết kích hoạt trận truyền tống, ném nàng và Vương Trác vào quầng sáng thoát khỏi màn sương thôn hồn của Vương Lâm. Cha dặn: nếu ta chết thì rời ngay Triệu quốc, đừng tìm muội muội. (@c0216)"},{"chuong":"@c0217","importance":"major","tieuDe":"Lộ thù hận VL; bị chồng kết liễu lần đầu gọi 'Tú Tú'","text":"Khi Vương Lâm xuất hiện truy theo, nàng lộ 'tia thù hận thật sâu lẩn khuất' với hắn — kẻ vừa giết cha nàng. Vương Lâm quyết không giết nàng, lệnh hai vợ chồng rời Triệu quốc. Nhưng Vương Trác chọn tự tay đặt lên thiên linh cái nàng kết liễu — đó là lần đầu tiên hắn gọi tên 'Tú Tú'. Nàng chết trong lòng hắn. (@c0217)"}],"tuViMoc":[],"nhanMach":[{"ten":"Đằng Hóa Nguyên","gap":"@c0210","quanHe":"Thân quyến Đằng gia","ghiChu":"Liên hôn theo sắp xếp của Đằng gia để tăng quyền lực.","tag":"gia-dinh","uuTien":60},{"ten":"Vương Trác","gap":"@c0210","quanHe":"Phu quân","ghiChu":"Vương Trác Kết Đan hậu kỳ là rể Đằng gia qua cuộc hôn nhân này; cuối cùng tự tay kết liễu nàng @c0217.","tag":"gia-dinh","uuTien":65},{"ten":"Đằng Tam (Đằng Hải)","gap":"@c0216","quanHe":"Phụ thân","ghiChu":"Hy sinh tu vi truyền tống cứu nàng thoát; dặn rời Triệu quốc nếu cha chết.","tag":"gia-dinh","uuTien":70}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0210","@c0216","@c0217"]},{"id":"dang-nhat","name":"Đằng Nhất","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia","Triệu quốc"],"canhGioiCaoNhat":"Nguyên Anh kỳ (tẩu hỏa nhập ma @c0219)","trangThai":"bat-minh (@c0219 — biến mất quỷ dị sau khi trúng Thông thiên thuật Cự Ma tộc)","vaiTro":"Phản diện — hạch tâm đệ tử số 1 Đằng gia, em ruột Đằng Hóa Nguyên","tinhCach":[{"text":"Gần như mất hết nhân tính sau khi tẩu hỏa nhập ma; chỉ đánh thuần bằng thân thể, mô phỏng cổ thần.","chuong":"@c0219"}],"blurb":"Hạch tâm tộc nhân số 1 của Đằng gia, em ruột Đằng Hóa Nguyên — kẻ ngay cả các hạch tâm khác cũng sợ nhất. Tu thần thông luyện thể cổ xưa do sứ giả Thông Thiên tháp truyền cho, thần thức dung vào khắp xương cốt nên miễn nhiễm đòn thần thức (khiến Cực Cảnh thần thức của Vương Lâm vô hiệu). Đã tẩu hỏa nhập ma, tu luyện hàng trăm năm trong quan tài hắc tinh dưới đáy Hắc Nê Đàm. Biến mất quỷ dị sau khi Vương Lâm thi triển Thông thiên thuật Cự Ma tộc @c0219.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0218","importance":"major","tieuDe":"Hy sinh cánh tay phải hóa giải Cực Cảnh thần thức","text":"Vương Lâm phóng Cực Cảnh thần thức (vô số tia chớp đỏ) vào bùn Hắc Nê Đàm. Đằng Nhất hy sinh cánh tay phải tiêu diệt sạch toàn bộ tia chớp — thần thức đã dung vào xương cốt khiến đòn thần thức hoàn toàn vô hiệu. Vương Lâm bung hơn 90 đạo cấm khí từ Cấm Phiên oanh tạc; thân Đằng Nhất nứt toác nhưng không vỡ rã, miệng hô bí thuật 'Ngưng!' — kim quang lóe, thân thể khôi phục tức thì. Trận chiến ở Hắc Nê Đàm ngoài kinh nghiệm của Vương Lâm, vẫn đang giằng co. (@c0218)"},{"chuong":"@c0219","importance":"major","tieuDe":"Bị ép phun huyết cổ thần vàng; VL Thông thiên thuật Cự Ma; biến mất để lại 1 giọt máu vàng","text":"Vương Lâm nổ Thanh Đồng cổ kính ép Đằng Nhất phun ngụm máu vàng (chứa tia máu cổ thần). Cả hai giành nhau cục máu, máu tách đôi. Vương Lâm dùng nửa cục máu vàng làm chất dẫn cổ thần lực, thi triển Thông thiên thuật Cự Ma tộc — hút 3/5 linh mạch Triệu quốc, triệu hư ảnh khổng lồ vung tay. Đằng Nhất biến mất quỷ dị từ xa, điểm sáng thần thức tối sầm; chỉ còn lại 1 giọt máu vàng trên nền bùn — Vương Lâm thu về. (@c0219)"}],"tuViMoc":[{"chuong":"@c0218","canhGioi":"Nguyên Anh kỳ + thần thông luyện thể","text":"Tu pháp thần thông luyện thể cổ xưa do sứ giả Thông Thiên tháp truyền — thần thức dung vào xương cốt toàn thân, miễn nhiễm mọi đòn thần thức. Bế quan trong quan tài hắc tinh dưới đáy Hắc Nê Đàm hàng trăm năm."}],"nhanMach":[{"ten":"Đằng Hóa Nguyên","gap":"@c0218","quanHe":"Huynh trưởng","ghiChu":"Đằng Nhất là em ruột lão tổ Đằng Hóa Nguyên.","tag":"gia-dinh","uuTien":70}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0215","@c0218","@c0219"]},{"id":"dang-tam","name":"Đằng Tam","cn":"","aliases":["Đằng Hải"],"gioiTinh":"nam","theLuc":["Đằng gia","Triệu quốc"],"canhGioiCaoNhat":"Nguyên Anh kỳ @c0216","trangThai":"da-chet (@c0216 — liều chết lao vào Vương Lâm sau khi cứu con)","vaiTro":"Nhân vật phụ — hạch tâm tộc nhân số 3 Đằng gia","tinhCach":[{"text":"Yêu vợ sâu nặng — đặt tên phi kiếm Điệu Vân theo tên vong thê phàm nhân, không bao giờ dùng kiếm đánh người.","chuong":"@c0216"},{"text":"Xả thân vì con — hy sinh tu vi truyền tống con gái thoát, rồi một mình liều chết cản Vương Lâm.","chuong":"@c0216"}],"blurb":"Hạch tâm tộc nhân số 3 Đằng gia, tên thật Đằng Hải, cha của Đằng Tú Tú. Bị lão tổ ép chia lìa người vợ phàm nhân (luật Đằng gia cấm kết hôn phàm nhân); tự luyện phi kiếm Điệu Vân đặt theo tên vợ, trong kiếm có giọt máu phàm của nàng. Khi Vương Lâm diệt Đằng gia, hy sinh tu vi truyền tống con gái Đằng Tú Tú và rể Vương Trác thoát, rồi hóa sao băng lao vào màn sương thôn hồn. Vương Lâm tha hồn phách hắn vì tình nghĩa biểu lộ lúc chết @c0216.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0216","importance":"major","tieuDe":"Hy sinh tu vi truyền tống con; triệu Điệu Vân lau lần cuối; hóa sao băng lao VL; VL tha hồn phách","text":"Vừa ngừng bế quan đưa con gái Đằng Tú Tú về Đằng gia thành thì bị màn sương thôn hồn (Vương Lâm) vây tứ phía. Hy sinh lượng lớn nguyên anh tinh huyết kích hoạt trận truyền tống, ném Đằng Tú Tú và Vương Trác vào quầng sáng cứu thoát. Dặn con: nếu ta chết thì rời Triệu quốc, đừng tìm muội muội. Sau đó triệu phi kiếm Điệu Vân — đặt theo tên vong thê Vận — lau kiếm lần cuối trước khi thân người hòa vào kiếm hóa sao băng cam lao vào màn sương; trong sao băng mơ hồ thấy vong thê vẫy gọi. Thi thể rơi ngoài trăm dặm, mắt mở, không một vết thương; phi kiếm Điệu Vân gãy theo. Vương Lâm tha hồn phách hắn vì cảm tia ý niệm thương nhớ thể hiện lúc chết — nhưng hắn vẫn phải chết vì mang họ Đằng. (@c0216)"}],"tuViMoc":[{"chuong":"@c0216","canhGioi":"Nguyên Anh kỳ","text":"Xác nhận khi hy sinh nguyên anh tinh huyết kích hoạt trận truyền tống cứu con gái @c0216."}],"nhanMach":[{"ten":"Đằng Tú Tú","gap":"@c0216","quanHe":"Con gái","ghiChu":"Hy sinh tu vi truyền tống cứu con thoát khỏi Vương Lâm. Mẹ của Đằng Tú Tú là vợ phàm nhân của Đằng Tam (tên có chữ 'Vận'), bị lão tổ ép chia lìa, hết tuổi thọ mà mất; Đằng Tam đặt tên phi kiếm Điệu Vân theo tên nàng.","tag":"gia-dinh","uuTien":70}],"tuiDo":{"phapBao":[{"ten":"Điệu Vân (phi kiếm)","loai":"phap-bao","trangThai":"da-gay (@c0216)","moTa":"Phi kiếm tự luyện, đặt theo chữ 'Vận' trong tên vong thê phàm nhân; trong kiếm có giọt máu phàm của nàng. Không bao giờ dùng khi đấu với người khác; gãy khi Đằng Tam tử chiến.","nguon":"@c0216"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0216"]},{"id":"dang-cuu","name":"Đằng Cửu","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"Nguyên Anh kỳ @c0215","trangThai":"da-chet (@c0215 — bị Vương Lâm bóp cổ, hồn phách bị thu vào hồn kỳ)","vaiTro":"Hạch tâm tộc nhân số 9 Đằng gia","tinhCach":[{"text":"Sát khí cực dày, lạnh như băng; tuổi thơ bị khinh rẻ trong chi thứ — giết ca ca ruột để đoạt quyền tham gia khiêu chiến; tu bí thuật thôn phệ linh lực người khác.","chuong":"@c0214"}],"blurb":"Hạch tâm tộc nhân số 9 Đằng gia, gốc chi thứ; đã đổi chủ 6 lần. Sát khí cực dày, tu bí thuật thôn phệ linh lực người khác giảm thọ nguyên để đoạt danh 'Đằng Cửu'. Bị Vương Lâm bóp gãy cổ @c0215; hồn phách thượng đẳng bị thu vào hồn kỳ để luyện thành ma đầu.","tabs":{"diem":[{"text":"Sát khí tự nhiên cực dày — Vương Lâm đánh giá có thể luyện thành đại ma đầu uy lực vô cùng trong tương lai.","chuong":"@c0215"}],"kinhLich":[{"chuong":"@c0214","importance":"normal","tieuDe":"Lai lịch tàn độc, cố thủ trong mật thất","text":"Hé lộ xuất thân: gốc chi thứ, bị khinh rẻ từ nhỏ; tự tay giết ca ca ruột để đoạt suất tham gia khiêu chiến 50 năm; tu bí thuật thôn phệ giảm thọ nguyên để đủ lực đoạt danh 'Đằng Cửu' (chủ cũ Kết Đan hậu kỳ). Bế quan trong mật thất dưới cồn cát có linh mạch ngầm; bị Vương Lâm đánh sụp mật thất, thoát kịp hiện giữa không trung, sát khí cực hạn đối đầu Vương Lâm. (@c0214)"},{"chuong":"@c0215","importance":"major","tieuDe":"Bóp cổ chết, hồn phách thượng đẳng bị VL thu","text":"Bỏ chạy ngàn dặm, ném hạt châu xám nổ bất thành; dùng hàng loạt pháp bảo bị lưới chớp đỏ hủy thần thức. Quỳ xin làm chủ nhân dâng hồn huyết bảo đảm — Vương Lâm từ chối. Bị Vương Lâm nhảy vào lưới tử thần, tay phải bóp gãy cổ; Vương Lâm đánh pháp quyết 'thôn hồn' thu hồn phách hồng quang thượng đẳng — hồn phách ma đầu thứ 4 Vương Lâm thu được (thứ 400 năm chỉ có 3). (@c0215)"}],"tuViMoc":[{"chuong":"@c0215","canhGioi":"Nguyên Anh kỳ","text":"Xác nhận khi đối đầu Vương Lâm @c0215 — Đằng Bát (Nguyên Anh trung kỳ) đứng thứ 1 Đằng gia sau ĐHN; Đằng Cửu tu vi đứng thứ 2 (sau ĐHN, hơn Đằng Bát trong bảng xếp)."}],"nhanMach":[{"ten":"Đằng Hóa Nguyên","gap":"@c0215","quanHe":"Lão tổ Đằng gia","ghiChu":"Đằng Hóa Nguyên chuẩn bị cực phẩm đan dược cho hắn — vô dụng vì hắn đã chết.","tag":"gia-dinh","uuTien":60}],"tuiDo":{"phapBao":[],"congPhap":[{"ten":"Bí thuật thôn phệ","moTa":"Tu công pháp ác độc thôn phệ linh lực người khác, tăng tu vi cực nhanh đổi lấy giảm thọ nguyên nghiêm trọng.","nguon":"@c0214"}],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0214","@c0215","@c0216"]},{"id":"dang-bat","name":"Đằng Bát","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"Nguyên Anh trung kỳ @c0215","trangThai":"da-chet (@c0215 — thần thức thôn hồn xâm nhập, Nguyên Anh bị nuốt)","vaiTro":"Hạch tâm tộc nhân số 8 Đằng gia","tinhCach":[{"text":"Bình tĩnh tự tin; người thứ năm mang danh 'Đằng Bát' — mọi kẻ khiêu chiến hắn đều bị giết.","chuong":"@c0215"}],"blurb":"Hạch tâm tộc nhân số 8 Đằng gia, Nguyên Anh trung kỳ. Người thứ năm mang danh 'Đằng Bát'; chuyên dùng chuỗi phi kiếm đen. Kẻ hắn sợ nhất trong Đằng gia là Đằng Nhất. Bị thần thức thôn hồn (màn sương đen) của Vương Lâm nuốt gọn, Nguyên Anh bị rút, hồn phách bị thu @c0215.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0215","importance":"major","tieuDe":"Thôn hồn sương đen xâm nhập, Nguyên Anh bị nuốt, hồn phách bị thu","text":"Bình tĩnh dùng chuỗi phi kiếm đen nghênh chiến — bị màn sương đen thôn hồn của Vương Lâm nuốt gọn xâm nhập toàn thân. Cơ thể lưu chuyển sương đen + máu, gào thảm thiết; Nguyên Anh bị nuốt, hồn phách bị rút ra nhập hồn kỳ; thân bị long cân xuyên qua. (@c0215)"}],"tuViMoc":[{"chuong":"@c0215","canhGioi":"Nguyên Anh trung kỳ","text":"Xác nhận khi xuất chiến với Vương Lâm @c0215."}],"nhanMach":[{"ten":"Đằng Nhất","gap":"@c0215","quanHe":"Huynh đệ hạch tâm","ghiChu":"Người Đằng Bát sợ nhất trong Đằng gia — hơn cả Đằng Hóa Nguyên, 'như cơn ác mộng, nghĩ tới là dâng hàn ý'.","tag":"gia-dinh","uuTien":60}],"tuiDo":{"phapBao":[{"ten":"Chuỗi phi kiếm đen","loai":"phap-bao","trangThai":"mat (@c0215)","moTa":"Pháp bảo chủ lực, số lượng lớn (túi trữ vật như động không đáy); bị màn sương đen thôn hồn dập tắt rơi xuống.","nguon":"@c0215"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0215","@c0216"]},{"id":"dang-ngu","name":"Đằng Ngũ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"Nguyên Anh kỳ @c0215","trangThai":"da-chet (@c0215 — sương đen thôn hồn bao trọn, Nguyên Anh + hồn phách bị rút)","vaiTro":"Hạch tâm tộc nhân số 5 Đằng gia","tinhCach":[{"text":"Ngoại hình ~80% giống Đằng Lệ — người Đằng Hóa Nguyên yêu quý nhất trong các hạch tâm tộc nhân sau Đằng Nhất.","chuong":"@c0216"}],"blurb":"Hạch tâm tộc nhân số 5 Đằng gia. Ngoại hình ~80% giống Đằng Lệ nên được Đằng Hóa Nguyên yêu quý đặc biệt. Bị sương đen thôn hồn của Vương Lâm bao trọn khi chỉ còn dưới 1000 dặm Đằng gia thành @c0215; cái chết của hắn khiến ĐHN lần đầu lao ra đối mặt Vương Lâm.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0215","importance":"major","tieuDe":"Sương đen thôn hồn bao trọn gần về tới thành","text":"Đang trên đường về Đằng gia thành cùng 2 nữ tu, chỉ còn dưới 1000 dặm — bị màn sương đen thôn hồn của Vương Lâm bất ngờ bao trọn; Nguyên Anh và hồn phách bị rút ra. Đằng Hóa Nguyên cảm hơi thở hắn tắt liền lao tới đối mặt Vương Lâm lần đầu tiên. (@c0215)"}],"tuViMoc":[{"chuong":"@c0215","canhGioi":"Nguyên Anh kỳ","text":"Xác nhận khi bị giết @c0215."}],"nhanMach":[{"ten":"Đằng Hóa Nguyên","gap":"@c0215","quanHe":"Lão tổ Đằng gia","ghiChu":"ĐHN yêu quý Đằng Ngũ vì ngoại hình giống Đằng Lệ ~80%; cái chết của hắn khiến ĐHN lần đầu lao ra đối mặt VL.","tag":"gia-dinh","uuTien":65}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0215","@c0216"]},{"id":"dang-luc","name":"Đằng Lục","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"Nguyên Anh kỳ @c0215","trangThai":"da-chet (@c0215 — bị thôn hồn giết; ngọc giản hạch tâm vỡ, xác nhận qua @c0216/@c0218)","vaiTro":"Hạch tâm tộc nhân số 6 Đằng gia","tinhCach":[{"text":"Linh cảm nguy hiểm nhạy bén, ẩn giấu sát khí giỏi; từng tự tay giết chủ cũ của danh 'Đằng Lục' để cướp lại danh xưng.","chuong":"@c0215"}],"blurb":"Hạch tâm tộc nhân số 6 Đằng gia. Linh cảm nguy hiểm cực nhạy; ~200 năm trước bị đoạt danh, sau bế quan rồi tự tay giết chủ cũ đoạt lại danh 'Đằng Lục' (bị lão tổ nghiêm trị nhưng cho giữ danh). Dùng bí thuật thiêu đốt linh hồn/tế hiến thân thể tăng tốc bỏ chạy @c0215; Vương Lâm bủa Cấm Phiên ngàn dặm và thả thôn hồn ly thể để săn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0215","importance":"normal","tieuDe":"Bí thuật thiêu linh hồn tăng tốc bỏ chạy khỏi Cấm Phiên","text":"Linh cảm nguy hiểm kịp thời — dùng bí thuật thiêu đốt linh hồn/tế hiến thân thể (nổ 'bang bang' huyết nhục dưới chân) tăng tốc gấp mấy lần, hóa sao băng đỏ bỏ chạy dù đã trong phạm vi ngàn dặm Cấm Phiên. Vương Lâm không đuổi mà thiền tọa thả thôn hồn ly thể thành mây đen trùm cả Triệu quốc để săn. (@c0215)"}],"tuViMoc":[{"chuong":"@c0215","canhGioi":"Nguyên Anh kỳ","text":"Xác nhận khi chiến đấu với Vương Lâm @c0215."}],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[{"ten":"Bí thuật thiêu linh hồn / tế hiến thân thể","moTa":"Bí thuật hy sinh linh hồn và huyết nhục dưới chân đổi lấy tốc độ gấp bội; hóa sao băng đỏ bỏ chạy.","nguon":"@c0215"}],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0215"]},{"id":"dang-tu","name":"Đằng Tứ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"Nguyên Anh sơ kỳ @c0215","trangThai":"da-chet (@c0215 — bị thôn hồn giết; ngọc giản hạch tâm vỡ, xác nhận qua @c0216/@c0218)","vaiTro":"Hạch tâm tộc nhân số 4 Đằng gia","tinhCach":[{"text":"Thiên phú cao — đạt tư cách hạch tâm tộc nhân không cần 20 năm; bi phẫn khi đệ đệ và tộc nhân liên tục tử vong, rời bế quan đi báo thù.","chuong":"@c0215"}],"blurb":"Hạch tâm tộc nhân số 4 Đằng gia, Nguyên Anh sơ kỳ. Thiên phú cao, đạt danh hạch tâm nhanh hơn quy định. Rời bế quan vì bi phẫn khi đệ đệ và tộc nhân liên tục chết — đang trên đường tìm hung thủ báo thù thì bị mây đen thôn hồn của Vương Lâm rình phía trên mà không hay @c0215.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0215","importance":"normal","tieuDe":"Rời bế quan báo thù cho đệ đệ, bị thôn hồn rình","text":"Bi phẫn vì tộc nhân liên tiếp tử vong — bỏ bế quan cưỡi phi kiếm bay đi tìm hung thủ báo thù cho đệ đệ. Không hay đám mây đen (thôn hồn ly thể của Vương Lâm) đang dày đặc rình phía trên; kết cục chưa được hiển thị trong phần text đọc được. (@c0215)"}],"tuViMoc":[{"chuong":"@c0215","canhGioi":"Nguyên Anh sơ kỳ","text":"Xác nhận khi xuất hiện @c0215."}],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0215"]},{"id":"dang-tan","name":"Đằng Tấn","cn":"","aliases":["Tấn nhi"],"gioiTinh":"nam","theLuc":["Đằng gia"],"canhGioiCaoNhat":"chưa rõ (dưới Nguyên Anh kỳ — không phải hạch tâm tộc nhân)","trangThai":"song (@c0212)","vaiTro":"Con cháu Đằng gia — trợ lý điều tra của Đằng Hóa Nguyên","tinhCach":[{"text":"Lạnh lùng âm trầm, mặt trắng như ngọc; được Đằng Hóa Nguyên tin tưởng giao việc điều tra.","chuong":"@c0212"}],"blurb":"Con cháu Đằng gia (không phải hạch tâm tộc nhân), thanh niên mặt trắng lạnh lùng. Được Đằng Hóa Nguyên giao điều tra vụ tàn sát. Báo cáo chính xác lộ trình 4 ngày / 961 nạn nhân và dâng bức họa vẽ kẻ địch — khiến ĐHN nhận ra Vương Lâm.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0212","importance":"normal","tieuDe":"Báo cáo 961 nạn nhân, dâng bức họa vẽ VL","text":"Được Đằng Hóa Nguyên giao điều tra. Báo cáo đầy đủ lộ trình 4 ngày: Thiên Đạo Môn 7 người → Vô Phong Cốc 93 → Đằng gia ngoại trang 174 → Thiên Âm Thành 104 → kinh thành 211 → Nguyên Khuê phái 27 → Tịch Diệt Tông 345, tổng 961 nhân mạng. Dâng bức họa đơn giản vẽ người tóc bạc, mi tâm tinh điểm, cưỡi yêu thú miệng dài kéo dải thi thể hình quạt — vật khiến ĐHN nhận ra Vương Lâm. (@c0212)"}],"tuViMoc":[],"nhanMach":[{"ten":"Đằng Hóa Nguyên","gap":"@c0212","quanHe":"Lão tổ Đằng gia","ghiChu":"Được ĐHN tin tưởng giao điều tra vụ tàn sát, gọi là 'Tấn nhi'.","tag":"gia-dinh","uuTien":65}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0212"]},{"id":"phuc-nhi","name":"Phúc Nhi","cn":"","aliases":["tiểu đạo sĩ"],"gioiTinh":"nam","theLuc":[{"ten":"Liên minh bốn phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Trúc Cơ kỳ @c0238","trangThai":"song","vaiTro":"Đệ tử cuối của Chu Võ Thái","tinhCach":[{"text":"Kiêu ngạo vì là đệ tử được Chu Võ Thái cưng chiều; tình cảm thật với sư phụ (giữ đồ chơi đường không ăn vì muốn giữ làm kỷ niệm).","chuong":"@c0239"}],"blurb":"Tiểu đạo sĩ Trúc Cơ kỳ, đệ tử duy nhất còn lại của Chu Võ Thái. Mồ côi được CVT cứu và nuôi dưỡng. Tính kiêu ngạo vì sư phụ cưng chiều. Bị Vương Lâm đánh vì truy đuổi Từ Đào; sau đó nghe VL vạch trần số phận — sư phụ cuối cùng phải tự tay giết mình để Hóa Thần.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0238","importance":"normal","tieuDe":"Truy đuổi Từ Đào — bị VL áp chế","text":"Truy đuổi Từ Đào đang bị thương nặng đến cửa hàng VL; bị VL dùng ma đầu Hứa Lập Quốc áp chế. Tính kiêu ngạo nhưng biết sợ thực lực. (@c0238)"},{"chuong":"@c0239","importance":"normal","tieuDe":"Nghe VL vạch trần số phận — bị gieo mầm nghi ngờ","text":"Có mặt khi VL vạch trần rằng CVT cuối cùng phải tự tay giết mình để Hóa Thần. Có chút run sợ khi nghe câu 'trăm năm hẳn phải chết', nhìn sư phụ ôn hòa thì yên lòng. Giữ đồ chơi đường không ăn — thể hiện tình cảm với sư phụ. (@c0239)"}],"tuViMoc":[],"nhanMach":[{"ten":"Chu Võ Thái","gap":"@c0238","quanHe":"Sư phụ","ghiChu":"Được CVT cứu và nuôi dưỡng từ nhỏ; CVT cuối cùng phải giết mình để Hóa Thần.","tag":"su-mon"},{"ten":"Vương Lâm","gap":"@c0238","quanHe":"Kẻ áp chế — gieo tâm chướng","ghiChu":"Đánh Phúc Nhi, vạch trần số phận bị sư phụ giết trước mặt mình.","tag":"doi-thu"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0238","@c0239"]},{"id":"lao-nhan-anh-bien","name":"Lão nhân Anh Biến kỳ","cn":"","aliases":["lão nhân bí ẩn","sư phụ bí ẩn"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Anh Biến kỳ @c0234","trangThai":"song","vaiTro":"Ân nhân dẫn dắt VL lĩnh ngộ ý cảnh","tinhCach":[{"text":"Ngoại hình gầy gò bẩn thỉu như ăn mày; lúc bình thường hài hước thích được khen, tự xưng 'lão tử'; lúc nghiêm túc uy nghiêm cương trực. Có mưu lược cao thâm — làm giả Tổ linh bài đến mức Bạch Vân Tông không phát hiện ra.","chuong":"@c0236"}],"blurb":"Lão nhân bí ẩn ngoại hình như ăn mày, tu vi Anh Biến kỳ. Chủ động tiếp cận VL tại kinh đô gợi ý về ý cảnh; sau đó tự nguyện đưa VL xâm nhập Bạch Vân Tông, dùng Tổ linh bài (thực ra đồ giả tự chế) ép 3 Hóa Thần thi triển ý cảnh cho VL lĩnh ngộ. Đổi lấy 100 pho tượng gỗ VL điêu khắc.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0227","importance":"normal","tieuDe":"Lần đầu gặp VL tại kinh đô — gợi ý ý cảnh","text":"Đọc thấu cảnh giới VL và mọi tu sĩ trên phố; lẩm bẩm 'Nguyên Anh trung kỳ, có nên giúp không?'; khuyên VL muốn Hóa Thần phải đạt ý cảnh. Tái xuất @c0233 sau 6 năm VL hóa phàm. (@c0227)"},{"chuong":"@c0234","importance":"normal","tieuDe":"Giải thích ý cảnh — giao ước 100 pho tượng","text":"Giải thích cơ chế ý cảnh và con đường đột phá Hóa Thần. VL đồng ý tạc 100 pho tượng đổi lấy cơ hội lĩnh ngộ ý cảnh từ Hóa Thần tu sĩ Bạch Vân Tông. Lão tức thì dịch chuyển 10 vạn dặm tới Bạch Vân Tông. (@c0234)"},{"chuong":"@c0236","importance":"normal","tieuDe":"Dùng Tổ linh bài ép Bạch Vân Tông — VL lĩnh ngộ 3 ý cảnh","text":"Xuất Tổ linh bài ép Bạch Vân Tông phục tùng; dàn xếp cho VL lĩnh ngộ lần lượt ba ý cảnh Hóa Thần (tuyệt tình, ấm áp/hư vô, tuế nguyệt). Trả lại Tổ linh bài sau đó, đưa VL về kinh đô. Bộc lộ tính cách thích được khen khi VL không nịnh. (@c0236)"},{"bridge":true,"khoang":"@c0237","text":"Thừa nhận Tổ linh bài là đồ giả do chính lão làm. VL đã tạc được 2/3 số tượng đã hứa."},{"bridge":true,"khoang":"@c0244–@c0245","text":"Xuất hiện lần cuối trước khi rời đi: tiết lộ nguyên nhân chiến tranh là Vũ Đỉnh + bí mật Cổ Tiên Giới (đã phá tan; khí tiên giới trong mảnh vỡ là điều kiện bắt buộc Hóa Thần → Anh Biến). Yêu cầu VL khắc 2 tượng gỗ cho Tiểu Thúy ở Hồng Phấn Lâu (bức giống thật bị từ chối vì 'giống con khỉ'; bức đẹp trai được nhận). Để lại pháp bảo mũ rơm cho VL, hẹn 99 tượng nữa khi VL đạt Hóa Thần. (@c0244–@c0245)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0227","quanHe":"Người được dẫn dắt","ghiChu":"Chủ động giúp VL lĩnh ngộ ý cảnh đổi lấy 100 pho tượng gỗ; cuối cùng tiết lộ bí mật Vũ Đỉnh và Cổ Tiên Giới, hẹn 99 tượng nữa sau khi VL Hóa Thần.","tag":"su-mon"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0227","@c0233","@c0234","@c0235","@c0236","@c0237","@c0244","@c0245"]},{"id":"dai-nguu","name":"Đại Ngưu","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Phàm nhân","trangThai":"song","vaiTro":"Hàng xóm phàm nhân của Vương Lâm trong giai đoạn hóa phàm","tinhCach":[{"text":"Thật thà, thân thiện; con người bình dị của phố thị — ngày nào cũng mang rượu trái cây sang xem VL điêu khắc khi còn là thiếu niên.","chuong":"@c0229"}],"blurb":"Hàng xóm đối diện Vương Lâm trong suốt hơn 30 năm hóa phàm; con trai thợ rèn, kế thừa cửa hàng dụng cụ sắt của cha. Thiếu niên 12 tuổi khi VL đến ở @c0229; lớn lên lấy vợ sinh con, trưởng thành thành trụ cột gia đình. Cha Đại Ngưu qua đời @c0240. Bị bắt đi dọn tuyết @c0245, VL cứu và đưa sang nước láng giềng @c0249 — lần chia tay vĩnh viễn.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0229","text":"Thiếu niên 12 tuổi con thợ rèn hàng xóm; ngày nào cũng mang rượu trái cây sang xem VL điêu khắc. VL kết thân."},{"bridge":true,"khoang":"@c0237","text":"Đã trưởng thành, lấy vợ, có con trai 4 tuổi. Cha bắt đầu đau ốm."},{"chuong":"@c0240","importance":"normal","tieuDe":"Cha qua đời — VL cảm ngộ thiên đạo luân hồi","text":"Cha Đại Ngưu qua đời vì già yếu. VL đến linh đường, dùng đóa hoa đen trợ giúp hồn phách cha ông trước khi đầu thai. Con trai Đại Ngưu 9 tuổi nhìn thấy hồn phách ông nội trên không trung — có thể là dấu hiệu tố chất tu luyện. (@c0240)"},{"bridge":true,"khoang":"@c0241","text":"Đại Ngưu nay là trung niên — sang thăm VL, kể chuyện tu sĩ tập trận không xa thành làm dân tình hoảng loạn."},{"bridge":true,"khoang":"@c0245","text":"Bị bắt cưỡng bức đi phương Nam dọn tuyết cùng toàn bộ dân thường, kể cả phụ nữ trẻ em. VL tặng 2 tấm gỗ điêu khắc tỏa hơi ấm bảo hộ Đại Ngưu và vợ."},{"bridge":true,"khoang":"@c0248","text":"Bỏ trốn từ đội dọn tuyết, dẫn vợ lén lút chạy về kinh thành."},{"chuong":"@c0249","importance":"normal","tieuDe":"VL cứu — chia tay vĩnh viễn tại biên giới","text":"VL tìm gặp vợ chồng Đại Ngưu đang lẩn trốn, đưa hai người vượt biên giới sang nước láng giềng an toàn. Đây là lần chia tay vĩnh viễn — VL sắp rời Tứ Phái, không bao giờ gặp lại. (@c0249)"},{"bridge":true,"khoang":"@c0258","text":"Định cư ở nước láng giềng, mở cửa hàng rèn. Vợ có bầu — sinh con gái (VL từ xa bơm linh lực bảo hộ mẹ con). Đại Ngưu suốt đời không bao giờ gặp lại VL; điều tiếc nuối nhất khi chết không phải không gặp Tiểu Ngưu mà là không gặp lại Vương thúc thúc. Hai bức tượng điêu khắc VL tặng được con cháu giữ làm gia bảo truyền đời."},{"chuong":"@c0301","importance":"minor","tieuDe":"Nhận ra tên Tằng Ngưu giống cha mình","text":"Ở một môn phái nhỏ tại tu chân quốc cấp bốn thuộc Chu Tước tinh, thì thào khi nghe tin Tằng Ngưu nổi danh: 'Tằng Ngưu và cha ta tên giống nhau. Cha ta từng kêu là Đại Ngưu…' — vô tình nói trúng sự thật về VL đã lấy tên giả từ họ của cha mình. (@c0301)"},{"chuong":"@c0248","importance":"normal","text":"Bị cưỡng bức đưa tới thành trì phía nam Tứ Phái dọn tuyết, sống chen chúc hơn 30 người một phòng. Nhờ tượng gỗ VL tặng tỏa hơi ấm mà thoát chết rét; tin rằng vợ giữ tượng cũng sống được. Chứng kiến con trai thứ hai nhà họ Chu cùng phòng chết cóng trong đêm, đau đớn khóc rống, nhớ vợ con và Vương thúc. Con trai Tằng Tiểu Ngưu đã vào Bạch Vân Tông (Ngưng Khí kỳ) nhưng quá yếu, không thể tìm cha mẹ. Cắn răng quyết bỏ trốn tìm vợ, băng qua cánh đồng đầy thi thể đông cứng.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0229","quanHe":"Hàng xóm thân quen","ghiChu":"Bạn bình dị duy nhất trong hơn 30 năm VL hóa phàm; sinh lão bệnh tử gia đình Đại Ngưu là tấm gương thiên đạo luân hồi; VL cứu và đưa ra khỏi vùng chiến sự @c0249.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0229","@c0237","@c0240","@c0241","@c0245","@c0248","@c0249","@c0258","@c0301"]},{"id":"thien-van-tu","name":"Thiên Vận Tử","cn":"","aliases":["lão đạo cưỡi đá sao băng","Cực Tôn"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"chưởng môn"}],"canhGioiCaoNhat":"Vượt Hóa Thần (ước lượng) @c0241; sở hữu huyết tinh sát khí cực mạnh @c0299","trangThai":"song","vaiTro":"Sư phụ (ký danh đệ tử) của Vương Lâm","tinhCach":[{"text":"Phóng túng, qua lại vũ trụ trên tảng đá sao băng; cứu VL khỏi lạc vào luân hồi một cách tình cờ, thu làm ký danh đệ tử theo hứng. Coi Chu Tước tinh là 'tu chân tinh vứt đi'.","chuong":"@c0241"},{"text":"Mưu tính cục đại — phái đệ tử vào tiên giới ngăn Đại La Kiếm Tông đoạt Vũ Chi Kiếm Tiên để giữ cân bằng thực lực Thiên Vận tinh.","chuong":"@c0297"}],"blurb":"Chưởng môn Thiên Vận Tông, tu vi cực cao. Tình cờ cứu VL khỏi luân hồi @c0241, thu làm ký danh đệ tử. Sở hữu huyết tinh sát khí — cũng là người đàn ông trung niên xuất hiện trong tiên giới; bắt VL + Sất Hổ đưa ra khỏi tiên giới @c0299.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0241","importance":"normal","tieuDe":"Cứu VL khỏi luân hồi — thu làm ký danh đệ tử","text":"Cưỡi tảng đá khổng lồ đi qua, phát hiện VL sắp lạc vào luân hồi, dùng pháp lực ép VL quay về. Khen VL 'sắp tới Hóa Thần kỳ rồi'. Thu VL làm ký danh đệ tử, lưu tinh đồ Thiên Vận Tinh vào đầu VL, dặn đến Thiên Vận Tinh tìm hắn. (@c0241)"},{"bridge":true,"khoang":"@c0297","text":"Phái đệ tử (Hóa Thần hậu kỳ, sở hữu huyết tinh sát khí) vào tiên giới ngăn Đại La Kiếm Tông đoạt Vũ Chi Kiếm Tiên — lo mất cân bằng thực lực Thiên Vận tinh. Đệ tử tự tin: 'Chỉ cần sư tôn Thiên Vận Tử ra tay, Đại La Kiếm Tông không đáng kể.' (@c0297)"},{"text":"Xuất hiện dưới dạng bàn tay to ảo hóa (lốc xoáy), dùng 3 huyết tinh + 'Huyết tinh sát khí, Bạo!' tấn công Lăng Thiên Hậu. Không ngăn lão đoạt kiếm tiên, chỉ bắt VL + Sất Hổ đưa vào lốc xoáy biến mất. Tuyên bố: 'Lăng Thiên Hậu, ngươi đoạt được kiếm tiên chính là thiên ý, lão phu không ngăn trở ngươi.' (@c0299)","bridge":true,"khoang":"@c0299"},{"chuong":"@c0613","importance":"normal","tieuDe":"Dẫn đầu tiến vào cánh cửa Yêu Linh","text":"Mười năm trước cảm thấy hãi hùng do lạc ấn để trên Vương Lâm bị khu trừ (như Tôn Vân từng làm), nay cùng Lăng Thiên Hậu, Huyết Tổ và bảy tám lão giả tiến vào cánh cửa Yêu Linh ngoài Đông Hải sớm hơn dự định mười năm."},{"chuong":"@c0614","importance":"normal","tieuDe":"Bấm độn dò ra Vương Lâm","text":"Vào vùng đất Yêu Linh, thuật bói không còn bị Đông Hải cản trở, bấm độn dò được vị trí Vương Lâm xuyên vực sâu triều tịch. Thấy trên người Vương Lâm không có lạc ấn Sát Lục Tiên Quyết nhưng không kịp ngăn. Cuối chương nhìn dòng xoáy với ánh mắt tỏa ánh sáng kỳ dị, tâm tư khó dò."},{"chuong":"@c0241","importance":"major","text":"Lão đạo cưỡi tảng đá khổng lồ như sao băng đi qua Chu Tước tinh. Thấy VL cảm ngộ thiên đạo luân hồi suýt lạc vào luân hồi, dùng pháp lực đẩy VL về cứu mạng; tự xưng tên, thu VL làm đệ tử ký danh, hẹn tới Thiên Vận Tinh, lưu lại tinh đồ trong đầu VL.","nguonNblm":true},{"chuong":"@c0455","importance":"major","text":"Đại cường giả, sư tôn các đệ tử Tử hệ Thiên Vận Tông; xuất hiện cứu Triệu Tinh Sát. Thi triển tiên thuật khôi phục toàn bộ Tử Lâm Các và núi non, một lời làm tan vỡ nguyên thần ngũ sư tỷ áo tím. Chính thức thu VL bái sư tu đại đạo ở Tử hệ; xác nhận đã gặp VL ở Chu Tước tinh năm xưa.","nguonNblm":true},{"chuong":"@c0460","importance":"normal","text":"Tổ chức đại thọ ngàn năm có một trên Thiên Vận Tinh; uy vọng cực lớn (huyền trấn liên minh phái sứ giả tặng quà). Tử vụ đại trận tạm ngừng, tu sĩ bốn phương cùng lão quái độc chiếm tiểu tinh đổ về chúc thọ.","nguonNblm":true},{"chuong":"@c0466","importance":"major","text":"Ngồi trên tường vân giảng đạo, phân tu đạo làm ba bước: bước một là chữ 'tu' (bảy cảnh tới Vấn Đỉnh), bước hai là hư thực nhị ý / toái niết tam cảnh, bước ba là chữ 'đạo' cầu thiên vận. Phân biệt tu tiên / tu chân / tu đạo. Tiết lộ ba ngàn năm trước gặp 'hắn' mới tin có bước thứ ba.","nguonNblm":true},{"chuong":"@c0467","importance":"major","text":"Tiết lộ 'hắn' là kẻ duy nhất lão biết đạt bước thứ ba, từng khiến Tu Chân Liên Minh nếm khổ rồi biệt tích. Thi triển trung phẩm Tiên thuật tên Dẫn Tiên thuật (vốn là thuật người Tiên giới dùng đưa tu sĩ thăng tiên), lấy Kiếm Tôn Lăng Thiên Hầu làm đối tượng.","nguonNblm":true},{"chuong":"@c0468","importance":"major","text":"Thi triển Dẫn Tiên thuật cuốn hơn vạn đệ tử Đại La Kiếm Tông đi (hẹn ba ngày trở về), làm nhục Lăng Thiên Hầu; thừa nhận không biết người bị dẫn sẽ tới đâu. Tuyên bố hôm nay Hoàng hệ và Tử hệ sẽ xuất hiện người mang phong hiệu Thiên Vận Thất tử.","nguonNblm":true},{"chuong":"@c0472","importance":"major","text":"Trao phong hiệu Thiên Vận Thất tử cho Trần Đào (kẻ thắng VL); kết thúc đại thọ. Nhận VL làm đệ tử chân chính, hứa truyền Cấm pháp thần thông và pháp bảo bản mạng, đưa về Tổng tông ba ngọn núi. Sắp đặt khảo nghiệm Toái Tiên chi địa cho VL.","nguonNblm":true},{"chuong":"@c0474","importance":"major","text":"Mở tâm thần thành thế giới bảy màu chứa 3600 phân thân cho VL tự chọn Cấm pháp thần thông; sở hữu thần thông bảy màu (Tối hỷ khẩu thất thải). Trong đó còn 'hơn một người' — phân thân áo xám bí ẩn nắm Sát Lục Tiên quyết, có hứa hẹn với lão.","nguonNblm":true},{"chuong":"@c0475","importance":"major","text":"Tiết lộ người áo xám chính là nguyên thần thứ hai của lão tu luyện khi còn trẻ, năm xưa phân hóa Âm Dương hư thật nhị ý không tách ra được; truyền Sát Lục Tiên quyết cho VL. Ban giới chỉ tím bảo mệnh (chống một kích toàn lực Vấn Đỉnh hậu kỳ hai lần), lệnh VL đi nhậm sứ giả, hẹn ở Độc Sơn giác ngoài Đông Hải. Là một thế hệ Cực Tôn, có địa vị Nội Tịch trong Tu Chân Liên Minh.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0241","quanHe":"Ký danh đệ tử","ghiChu":"Cứu VL khỏi luân hồi tình cờ, thu làm đệ tử, lưu tinh đồ; bắt VL ra khỏi tiên giới @c0299.","tag":"su-mon","uuTien":80},{"ten":"Tôn Vân","tag":"su-mon","quanHe":"Đệ tử cũ","ghiChu":"Đệ tử ngày trước từng khu trừ được lạc ấn của Thiên Vận Tử, giống điều Vương Lâm nay làm."}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0241","@c0297","@c0299","@c0613","@c0614"],"detail":"Tông chủ kiêm Thủy Tổ Thiên Vận Tông trên Thiên Vận Tinh (thất cấp tu chân quốc), một thế hệ Cực Tôn có địa vị Nội Tịch trong Tu Chân Liên Minh. Tu vi cực cao, tinh thông Tiên thuật. Gặp VL từ Chu Tước tinh, sau thu làm đệ tử Tử hệ, truyền Sát Lục Tiên quyết. Nắm bí mật chưa lộ về 'hắn' (kẻ đạt bước thứ ba) và nguyên thần thứ hai áo xám."},{"id":"tang-van-trac","name":"Tằng Văn Trác","cn":"","aliases":["Tiểu Ngưu"],"gioiTinh":"nam","theLuc":[{"ten":"Bạch Vân Tông","trangThai":"hien-tai"}],"canhGioiCaoNhat":"Ngưng Khí kỳ @c0248","trangThai":"song","vaiTro":"Con trai Đại Ngưu, đệ tử Bạch Vân Tông","tinhCach":[],"blurb":"Con trai Đại Ngưu — Tiểu Ngưu. Được VL bí mật dùng đan dược cải biến thể chất từ nhỏ (linh căn tốt hơn VL xưa gấp mấy lần). 3 năm trước được tu sĩ Kết Đan kỳ Bạch Vân Tông nhìn trúng, thu làm đệ tử, ban tên Tằng Văn Trác. Tách cha mẹ trong chiến tranh @c0248, bất lực không thể tìm phàm nhân phân tán.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0241","text":"Được VL cải biến thể chất từ nhỏ (đan dược bí mật); 3 năm trước vừa gia nhập Bạch Vân Tông (tu sĩ Kết Đan kỳ nhìn trúng), được ban tên Tằng Văn Trác."},{"bridge":true,"khoang":"@c0248","text":"Ngưng Khí kỳ; muốn tìm cha mẹ Đại Ngưu bị bắt dọn tuyết nhưng phàm nhân phân tán khắp cả nước — bất lực không biết nơi đâu."}],"tuViMoc":[],"nhanMach":[{"ten":"Đại Ngưu","gap":"@c0241","quanHe":"Cha","ghiChu":"Bị tách trong chiến tranh Tuyết Vực.","tag":"khac"},{"ten":"Vương Lâm","gap":"@c0241","quanHe":"Ân nhân bí mật","ghiChu":"VL dùng đan dược cải biến thể chất Tiểu Ngưu từ nhỏ — giải Nhân Quả đời phàm.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0241","@c0248"]},{"id":"hong-diep","name":"Hồng Điệp","cn":"","aliases":["Tuyệt Tình","Hồng Diệp"],"gioiTinh":"nu","theLuc":[{"ten":"Tuyết Vực Quốc","trangThai":"xuat-than"},{"ten":"Chu Tước Quốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần hậu kỳ (trước khi bị hao tổn tiên giới); Hóa Thần trung kỳ sau khi kích hoạt Nguyên Khai Thái @c0291; thua VL trong đại chiến @c0340; bị Kiền Phong hạ thủ cướp ý cảnh + tứ linh @c0340","trangThai":"bi-ha-thu — bị Kiền Phong đoạt tuyệt tình ý cảnh + tứ linh @c0340; trở thành con rối Kiền Phong kiểm soát @c0341; mắt trống rỗng, tên đổi 'Tuyệt Tình'; còn tia nguyên thần sót @c0345","vaiTro":"Thiên chi kiêu nữ Tuyết Vực — nguyên nhân trực tiếp của cuộc chiến diệt quốc","tinhCach":[],"blurb":"Nữ tử thiên tài nghìn vạn năm mới xuất hiện một lần của Tuyết Vực, sở hữu Thiên Tiên Ngũ Linh thể. Kiếp nạn đã tận nhờ Thủ Đồ thế mạng. Chu Tước Quốc chiêu mộ — nàng đặt điều kiện nâng Tuyết Vực lên ngũ cấp và lấy đất Tứ Phái, khởi phát cuộc chiến diệt quốc. Sau khi kiếp nạn qua, theo sứ giả Âu Chí đi Chu Tước Quốc dự Quán Đỉnh đại lễ. (+) Sư muội của Kiền Phong, mặc áo hồng, xinh đẹp tuyệt trần nhưng hai mắt mờ mịt đờ đẫn như con rối không hồn vì bị Kiền Phong khống chế. Được sư tôn phái đi thu thập đạo tâm của Vương Lâm. [CAN-SOAT-GOP]","tabs":{"diem":[{"text":"Xinh đẹp tuyệt trần nhưng bị Kiền Phong khống chế thành con rối không hồn — mắt mờ mịt đờ đẫn, bị hút sinh mệnh lực để chữa thương cho hắn.","chuong":"@c0392"},{"text":"Từng là người hầu/sư muội gắn bó với Vương Lâm, được Kiền Phong nhắc là người nhớ mãi không quên Vương Lâm; được sư tôn phái đi thu thập đạo tâm Vương Lâm.","chuong":"@c0391"}],"kinhLich":[{"bridge":true,"khoang":"@c0246","text":"Nữ tử thiên tài Tuyết Vực — Thiên Tiên Ngũ Linh thể, tiềm năng Hóa Thần hậu kỳ đỉnh phong 100 năm không đan dược. Chu Tước Quốc chiêu mộ; điều kiện của nàng: nâng Tuyết Vực lên ngũ cấp + chọn lãnh thổ Tứ Phái làm nơi mới. Nguyên nhân trực tiếp của chiến tranh diệt quốc."},{"chuong":"@c0253","importance":"normal","tieuDe":"Xuất hiện — kiếp nạn đã tận","text":"Hồng Điệp thật xuất hiện sau khi Thủ Đồ thế mạng trong sát trận. Kiếp nạn đã tận. Theo sứ giả Âu Chí rời Tuyết Vực đi Chu Tước Quốc. (@c0253)"},{"bridge":true,"khoang":"@c0256","text":"Đã đến Chu Tước Quốc. Sắp tham gia Quán Đỉnh đại lễ — nghi lễ một đời, lập tức nhận Anh Biến sơ kỳ nhưng tu vi bị phong ấn, thọ mệnh giới hạn còn 100 năm."},{"bridge":true,"khoang":"@c0268–@c0269","text":"Đứng trước tế đàn lớn tại Tuyết Vực quốc, tuyên bố 'Ta đi đây' rồi bay lên tiên giới — 1 trong 6 tu sĩ cầm Vũ Đỉnh hình thành đồ án lục giác. Ngồi trên đài cao trước cánh cửa tiên giới; tu sĩ khác nhận ra bản lãnh Hóa Thần Hậu Kỳ đều tự rời đi. Liên tục cảm giác VL (người thư sinh) rất quen thuộc nhưng không nhớ ra. (@c0268–@c0269)"},{"chuong":"@c0273","importance":"normal","tieuDe":"Đánh lén Vương Lâm — hỏi tung tích","text":"Bất ngờ xuất hiện trên mảnh vỡ sa mạc, đánh lén VL bằng ngân quang trong lúc hắn đắm chìm trong ảo ảnh — nếu thần thức VL không đạt Hóa Thần hậu kỳ thì hẳn đã chết ngay. VL gọi đúng tên 'Hồng Điệp', nàng kinh ngạc hỏi 'Ngươi là ai?' (xác nhận chưa nhận ra VL). VL đáp lấp liếm. Nàng tuyên bố giữ VL lại, lóe ngân quang trên tay phải. (@c0273)"},{"chuong":"@c0274","importance":"major","tieuDe":"Bị gieo hạt giống phá đạo tâm — trúng chưởng ấn tiên giới","text":"Giao chiến VL (Hóa Thần sơ kỳ): vung ngân quang, phóng phi kiếm mang ý cảnh vô tình (bông tuyết rơi), phóng 5 đạo khí băng hàn hóa 5 ngọn núi tuyết. Ý cảnh vô tình xâm nhập cơ thể VL suýt xóa ký ức — nhưng bị sinh tử ý cảnh chặn lại. VL khiêu khích 'dù tiến vào luân hồi cha mẹ vẫn theo ngươi' → đạo tâm chấn động nhẹ; VL gieo hạt giống nghi ngờ trong lòng — chừng nào hạt giống còn, nàng không thể Anh Biến. Nhận ra mục đích VL phá đạo tâm, xuất nguyên thần đông cứng cấm khí ác long; đuổi theo VL bỏ chạy. Bất ngờ bị chưởng ấn cự đại xuyên thẳng qua thân thể — lần đầu sắc mặt đại biến. (@c0274)"},{"chuong":"@c0275","importance":"normal","tieuDe":"VL trốn — nhận xét sai thân phận","text":"Nhận ra VL đã dùng truyền tống trận biến mất. Nhận xét VL 'đạo pháp phi phàm, vừa tỉ mỉ lại vừa lớn mật, pháp bảo nhiều vô số'; đoán sai hắn là tinh anh đệ tử được ngũ cấp tu chân quốc ở Chu Tước tinh toàn lực bồi dưỡng. Ánh mắt lạnh lẽo rồi bay đi tìm khí tiên giới. (@c0275)"},{"chuong":"@c0284","importance":"major","tieuDe":"Đấu VL — xuất bản mệnh pháp bảo","text":"Xuất hiện qua truyền tống trận, tấn công VL ngay. Dùng tượng băng (đầu người mình rắn) đông cứng Lôi Oa và cấm khí VL; bị phá đạo tâm bởi lời quát bất hiếu–bất nhân–bất nghĩa–bất trung của VL, đạo tâm dao động không kháng cự. Cuối cùng phun tiên huyết mi tâm xuất bản mệnh pháp bảo: đóa hoa hồng kiều diễm — phá vỡ trường thương VL, rụng cánh hoa. VL là người đầu tiên buộc nàng dùng bản mệnh pháp bảo. (@c0284)"},{"chuong":"@c0285","importance":"normal","tieuDe":"Hòa giải — thách đấu lại Chu Tước tinh","text":"Trước uy hiếp Sất Hổ (hư ảnh cự nhân) + Cấm Phiên VL, thu đóa hoa về mi tâm. Thách đấu VL khi về Chu Tước tinh. Vô tình ý cảnh sắp đại thành; VL nhận định đạo tâm nàng chưa đạt tách rời ý cảnh khỏi pháp quyết. (@c0285)"},{"bridge":true,"khoang":"@c0286–@c0287","text":"Dẫn đầu vượt sông băng 30 vạn dặm: dùng Tuyết Tiên băng điêu (ba chiếc liên tiếp bị phá) và bản mệnh pháp bảo đóa hoa hồng để chống sương Cực Băng khí + sương tím. Linh lực hao tổn nghiêm trọng. Trên Tinh La Bàn ngồi phía tây khôi phục tu vi; dùng đóa hoa hồng chống luồng khí đỏ của sinh vật Hư — mất 2 cánh hoa + 1 nhị hoa (chỉ có 3 nhị, không thể bù lại). (@c0286–@c0287)"},{"chuong":"@c0288","importance":"normal","tieuDe":"Đáy động trống — biến sắc khi nghe tên Chu Dật","text":"Xuống đáy động tầng hai thất vọng vì bảo vật đã bị lấy sạch; phẫn nộ cáo buộc Sất Hổ lừa gạt. Khi Chu Dật xuất hiện, nghe tên liền biến sắc, lộ sự ghê tởm sâu đậm — có tiền sử hiềm khích. (@c0288)"},{"bridge":true,"khoang":"@c0289–@c0290","text":"Bị lão đầu Thi Âm Tông dùng thuật phụ thể khống chế thân thể: mặt tím đen, mắt phóng u quang đỏ. Dùng vòng ngọc Nguyên Khai Thái đe dọa — lão đầu cam kết không giết. Thân thể xuất Tứ Linh (thiếu Thổ Linh) + đóa hoa hồng đen; lão đầu dùng thân nàng đánh Sất Hổ. Sau trận khôi phục thần trí, mặt tái nhợt. (@c0289–@c0290)"},{"chuong":"@c0291","importance":"major","tieuDe":"Bị VL tấn công — mất cánh tay phải","text":"Suy yếu nghiêm trọng (tu vi hạ, pháp bảo tổn thất, nội thương). Bị VL dùng Cấm Khí Trường Thương + Tuế Nguyệt Ý Cảnh + lông chim quạt sư tỷ tấn công. Dùng phi kiếm trắng (vỡ) và vòng ngọc Nguyên Khai Thái chống đỡ. Kích hoạt Nguyên Khai Thái mở hắc động về Chu Tước quốc — cái giá: tu vi tụt từ Hóa Thần hậu kỳ xuống Hóa Thần trung kỳ. Bị VL Nguyên Thần xuất thể cắt đứt cánh tay phải ngay trước khi trốn thoát. (@c0291)"},{"chuong":"@c0301","importance":"normal","tieuDe":"Phát thông điệp thách đấu Tằng Ngưu","text":"5 tháng sau khi trở về Chu Tước quốc cụt tay, nghiến răng nói tên 'Tằng Ngưu' rồi hôn mê. Tên này lập tức nổi danh cả Chu Tước tinh, áp chế cả Hồng Điệp. Thương thế chuyển biến tốt, nàng thông qua Chu Tước quốc phát thông điệp: 'Tằng Ngưu, cuộc chiến của chúng ta vẫn chưa kết thúc. Ta chờ ngươi đến tìm ta.' (@c0301)"},{"bridge":true,"khoang":"@c0335","text":"Đệ tử Thiên Ngọc tông — tu vi Hóa Thần hậu kỳ không tiến nửa bước (đạo tâm tổn thương vì VL phế tay lúc suy yếu nhất). Xuất hiện từ xa nhìn VL đến Chu Tước quốc. Vào không gian chiến đấu quyết đấu 10 năm hẹn. (@c0335)"},{"chuong":"@c0336","importance":"major","tieuDe":"Đại chiến VL — triệu Băng Thần + bản mệnh pháp bảo","text":"Tốc chiến tốc thắng: triệu Băng Thần (tượng người băng khổng lồ, pháp bảo Tuyết Vực 500 năm chế tác) + bản mệnh pháp bảo đóa hoa hồng (lưới tơ + 9 phi kiếm đỏ từ cắn đầu lưỡi phun máu). Bọc kín VL bằng cánh hoa nhưng bị kiếm quang 'khai thiên' phá vây. Rút 6 cánh hoa hóa 6 nữ tử áo đỏ khi VL mang Cấm Phiên ra. (@c0336)"},{"chuong":"@c0337","importance":"normal","tieuDe":"Thu 6 hư ảnh chống Thiên Kiếp — dùng Côn Cực Tiên","text":"Thu 6 nữ tử nhập thân (lục nguyên hợp nhất), hiện 6 hư ảnh đỏ. Hy sinh cả 6 hư ảnh chống Thiên Kiếp giáng từ Cấm Phiên VL. Nhập thân vào Băng Thần. Côn Cực Tiên (roi mềm trọng bảo Thiên Ngọc tông, sư huynh tặng) xuất hiện — rút nguyên thần VL ra ngoài thân thể, đánh lui. (@c0337)"},{"chuong":"@c0338","importance":"normal","tieuDe":"Bị nổ cánh tay — áp chế hắc khí","text":"Bị VL kích hoạt nổ cánh tay cụt — chú pháp đốt lên trong cơ thể, phun máu đen, hắc khí đầy mặt. Toàn lực áp chế hắc khí trong khi người khổng lồ bị Hồn Thú thu nhỏ còn 2 trượng, vai phải tan chảy. Cuối chương áp chế xong — hắc khí thành đường đen giữa lông mày. (@c0338)"},{"chuong":"@c0339","importance":"major","tieuDe":"Tuyệt Tình Ý Cảnh — thua trước Sinh Tử Luân Hồi","text":"Côn Cực Tiên đánh lui Hồn Thú. Bỏ chạy rồi bị khiêu khích quay lại liều mạng. Dùng Phân Thần Biến: hy sinh Anh Biến trong thời gian ngắn để tạo phân thân chứa toàn bộ cảm ngộ thiên đạo. Triển khai Tuyệt Tình Ý Cảnh qua phân thân: dẫn tình → thân tình → tình yêu (LMU) → hận ý (ĐHN) → cảm ngộ (Đại Ngưu) → tuệ kiếm → tuyệt tình. Phân thân bị Sinh Tử Luân Hồi của VL chặn, than 'Đáng tiếc' rồi tan biến — ý cảnh thua. (@c0339)"},{"chuong":"@c0340","importance":"major","tieuDe":"Thua trận — bị Kiền Phong hạ thủ","text":"Phun máu, nguyên thần bị thương sau ý cảnh, nhưng đạt tia minh ngộ. Mất Băng Thần khi người khổng lồ bị tiêu diệt. Triệu tứ linh (kim, mộc, thủy, hỏa — thiếu thổ) tung sát trận rồi bỏ chạy; cho kim linh tự nổ, tam linh cùng nổ đe dọa cùng chết. Công Tôn Phá can thiệp — Hồng Điệp phải rút lui. Mất nửa mộc linh (VL cắt). Cảnh cáo 'Lần sau nhất định phải chết'. Ba ngày sau bị Kiền Phong hạ thủ trong mật thất — không thể phản kháng, nguyên thần + tứ linh bị cướp để hắn đoạt danh hiệu Chu Tước. (@c0340)"},{"chuong":"@c0341","importance":"major","tieuDe":"Trở thành con rối — đổi tên Tuyệt Tình","text":"Bị Kiền Phong kiểm soát hoàn toàn sau khi bị cướp nguyên thần + tứ linh. Hai mắt trống rỗng, biểu cảm không còn. Kiền Phong đặt tên 'Tuyệt Tình' cho nàng. Đi theo Kiền Phong và Liễu Mi rời khỏi cấm địa. (@c0341)"},{"chuong":"@c0345","importance":"normal","tieuDe":"Dừng trên Chu Tước Sơn — còn tia nguyên thần","text":"Đứng trên Chu Tước Sơn bên cạnh Kiền Phong và Liễu Mi. Kiền Phong tiết lộ biết rõ trong thân thể 'Tuyệt Tình' vẫn còn tia nguyên thần sót của Hồng Điệp chưa bị diệt, nhưng không vội xử lý. Nàng hoàn toàn không phản ứng. (@c0345)"},{"chuong":"@c0368","importance":"bridge","text":"Đứng sau Kiền Phong tại cấm địa Chu Tước Sơn, mắt trống rỗng vô thần. Kiền Phong hỏi nàng (giờ gọi là Tuyệt Tình) có muốn đánh một trận với Tằng Ngưu trước khi Nguyên Thần tịch diệt không. (@c0368)"},{"text":"Kiền Phong đề cập Hồng Điệp là người hầu của hắn và cho rằng sư muội nghịch ngợm này đã kể nhiều về Vương Lâm cho hắn nghe; Hồng Điệp được nói là nhớ mãi không quên Vương Lâm.","bridge":true,"khoang":"@c0391"},{"chuong":"@c0392","importance":"normal","tieuDe":"Bị hút sinh mệnh lực, lộ thân phận bị khống chế","text":"Hồng Điệp xuất hiện mặc áo hồng, xinh đẹp tuyệt trần nhưng hai mắt mờ mịt đờ đẫn như con rối không hồn. Kiền Phong điểm vào giữa lông mày nàng hút sinh mệnh lực để chữa lành thương thế trong nháy mắt, rồi đặt ngón tay bị tiên kiếm chém vào miệng nàng cho liếm sạch máu. Kiền Phong tiết lộ chính sư tôn đã phái Hồng Điệp đi thu thập đạo tâm của Vương Lâm."},{"chuong":"@c0257","importance":"minor","text":"(Nhắc tên) Thiên Chi kiều nữ Tuyết Vực; từng suýt bị một tu sĩ Kết Đan kỳ trong tộc ép, nhờ có người khác mới thoát — chi tiết nền về địa vị/đối xử với nàng ở Tuyết Vực.","nguonNblm":true},{"chuong":"@c0317","importance":"major","text":"Tại Chu Tước quốc, cánh tay phải chỉ còn tà áo trống. TỪ CHỐI dùng Đông Hải Chi Linh (vật khiến tay mọc lại) mà sư huynh mang tới — quyết không khôi phục cánh tay cho tới khi giết được Tằng Ngưu (VL). Bị hắc tuyến (kèm hồng mang) bùng lên giữa mi tâm do VL tế luyện đoạn cánh tay nàng làm bùa nguyền; nàng kịp điểm mi tâm trấn áp, phong ấn lại, căm hận sâu thêm.","nguonNblm":true},{"chuong":"@c0335","importance":"major","text":"Lộ thân phận đệ tử Thiên Ngọc tông (một trong ba tông phái Chu Tước quốc). Trên tế đàn đại chiến (định từ 10 năm trước), tay áo phải trống rỗng; tu vi Hóa Thần hậu kỳ KHÔNG TIẾN nửa bước vì đạo tâm tổn thương do VL phế tay lúc nàng suy yếu nhất — cho rằng phải giết VL mới khôi phục được đạo tâm.","nguonNblm":true},{"chuong":"@c0426","importance":"major","text":"BỊ KIỀN PHONG BIẾN THÀNH KHÔI LỖI: gặp lại trong tình trạng tiều tụy, mắt trống rỗng, bị Kiền Phong (Anh Biến trung kỳ) khống chế và xúi giết VL. Khai chiến bằng trường kiếm đỏ, khối băng đỏ hóa giáp đỏ và roi đen; ẩn có tiên lực dù tu vi chưa tới Anh Biến. Giữa trận lóe lên một tia thần trí, run rẩy cầu VL 'Giết… ta…' rồi lại chỉ còn chiến ý.","nguonNblm":true},{"chuong":"@c0428","importance":"major","text":"CÁI CHẾT: VL bổ chiến phủ; nàng chọn không chống cự cũng không né tránh, mỉm cười kiêu hãnh, thân thể nứt vỡ nổ tung hóa sương máu. Trối lời nhờ VL giết Kiền Phong; để lại di vật là một ngọc giản (ghi quan sát về ý cảnh của Kiền Phong) và Côn Cực Tiên (còn thần niệm một cao thủ Vấn Đỉnh). Hứa lễ vật: sang năm mùa hoa nở, bình nguyên cực bắc Chu Tước Tinh sẽ có một đóa hoa hồng màu xanh lam. Sống chưa đến ba trăm năm.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0291","canhGioi":"Hóa Thần trung kỳ","text":"Tu vi tụt từ Hóa Thần hậu kỳ xuống trung kỳ sau khi kích hoạt Nguyên Khai Thái trốn về Chu Tước quốc.","importance":"major"},{"chuong":"@c0335","canhGioi":"Hóa Thần hậu kỳ (không tiến)","text":"Tu vi Hóa Thần hậu kỳ đóng băng — đạo tâm bị tổn thương do VL phế tay lúc suy yếu nhất khiến không tiến nửa bước. (@c0335)","importance":"minor"},{"chuong":"@c0340","canhGioi":"Bị cướp ý cảnh + tứ linh","text":"Sau khi thua VL, bị Kiền Phong đoạt tuyệt tình ý cảnh sắp viên mãn và tiên thiên tứ linh — Anh Biến trở nên cực kỳ khó khăn. (@c0340)","importance":"major"}],"nhanMach":[{"ten":"Âu Chí","gap":"@c0253","quanHe":"Sứ giả bảo hộ","ghiChu":"Sứ giả Chu Tước Quốc đến tiếp đón và bảo hộ Hồng Điệp.","tag":"dong-hanh"},{"ten":"Vương Lâm","gap":"@c0273","quanHe":"Đối thủ tiên giới","ghiChu":"VL biết tên nàng nhưng nàng không nhận ra VL. Đánh lén VL nhưng không hạ; bị VL gieo hạt giống phá đạo tâm. Tại c0291 bị VL cắt đứt cánh tay phải; VL tuyên bố dùng cánh tay tạo lời nguyền khiến tu vi vĩnh viễn dừng ở Hóa Thần. (@c0273–@c0291)","tag":"doi-thu"},{"ten":"Kiền Phong","tag":"su-mon","quanHe":"Sư huynh (kẻ khống chế)","ghiChu":"Kiền Phong gọi Hồng Điệp là sư muội, khống chế nàng thành con rối không hồn, hút sinh mệnh lực để chữa thương; âm mưu nuốt ý cảnh của nàng."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người nàng nhớ mãi — mối duyên nợ trước","ghiChu":"Hồng Điệp nhớ mãi không quên Vương Lâm; sư tôn phái nàng đi thu thập đạo tâm Vương Lâm. Kiền Phong gọi nàng là sư muội nghịch ngợm đã kể nhiều về Vương Lâm."}],"tuiDo":{"phapBao":[{"ten":"Băng Thanh Quyết","loai":"cong-phap","trangThai":"hien-co","moTa":"Công pháp cần nghiền nát toàn bộ tình cảm, đạt trạng thái lòng như băng đá. Phi kiếm mang ý cảnh vô tình bông tuyết rơi; xuất 5 đạo khí băng hàn hóa 5 ngọn núi tuyết. Nguyên thần xuất khiếu phát sóng lam đông cứng cấm khí.","nguon":"@c0274"},{"ten":"Băng Thần","loai":"phap-bao","trangThai":"bi-mat","moTa":"Tượng người băng khổng lồ cao hơn 10 trượng — pháp bảo Tuyết Vực quốc, 500 năm chế tác. Hồng Điệp có thể nhập thân vào bên trong. Bên trong chứa Côn Cực Tiên. Bị tiêu diệt trong trận đấu với VL.","nguon":"@c0336"},{"ten":"Côn Cực Tiên","loai":"phap-bao","trangThai":"bi-mat","moTa":"Roi mềm (nhuyễn tiên) trọng bảo Thiên Ngọc tông — sư huynh Hồng Điệp tặng. Tốc độ nhanh hơn tia chớp 3 lần; rút nguyên thần đối phương khi ở gần. Bị VL cướp rồi bị Công Tôn Phá thu lại.","nguon":"@c0337"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]},"tuVi":"Cảnh giới không rõ — chưa có thông tin tu vi cụ thể."},"nguon":["@c0246","@c0253","@c0256","@c0268","@c0269","@c0273","@c0274","@c0275","@c0284","@c0285","@c0286","@c0287","@c0288","@c0289","@c0290","@c0291","@c0301","@c0335","@c0336","@c0337","@c0338","@c0339","@c0340","@c0341","@c0345","@c0368","@c0391","@c0392"]},{"id":"au-chi","name":"Âu Chí","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Quốc","trangThai":"su-gia"}],"canhGioiCaoNhat":"Hóa Thần kỳ — tu vi cực cao (rút huyết mạch Thương Long, cố hấp thu thiên kiếp @c0253–@c0254); cụ thể chưa rõ","trangThai":"song — rời cùng Hồng Điệp đến Chu Tước Quốc @c0253","vaiTro":"Sứ giả Chu Tước Quốc đến đón Hồng Điệp","tinhCach":[{"text":"Giả bệnh tật yếu đuối; thực lực cực cao — xuất thủ rút huyết mạch Thương Long; dũng mãnh đến mức cố hấp thu hồng vân thiên kiếp dù thất bại.","chuong":"@c0253"}],"blurb":"Sứ giả Chu Tước Quốc — ngoài giả bệnh tật yếu ớt nhưng tu vi thuộc hàng Hóa Thần kỳ. Đến Tuyết Vực đón Hồng Điệp: rút huyết mạch Thương Long, hạ CVT hôn mê. Cố hấp thu hồng vân thiên kiếp sau khi VL kích nổ sỏi tơ nhưng thất bại. Bảo hộ Hồng Điệp rời đi Chu Tước Quốc.","tabs":{"diem":[{"text":"Ngoài giả bệnh tật; thực lực xuất thủ rút huyết mạch Thương Long, hạ CVT hôn mê — tu vi Hóa Thần kỳ hoặc cao hơn.","chuong":"@c0253"}],"kinhLich":[{"chuong":"@c0253","importance":"normal","tieuDe":"Rút huyết mạch Thương Long — hạ CVT","text":"Xuất hiện cùng Hồng Điệp, rút huyết mạch Thương Long, hạ CVT hôn mê. Thực lực bộc lộ bất ngờ sau khi giả yếu đuối suốt trước đó. (@c0253)"},{"chuong":"@c0254","importance":"normal","tieuDe":"Cố hấp thu thiên kiếp — thất bại","text":"Sau khi VL kích nổ sỏi tơ thiên kiếp, Âu Chí cố hấp thu hồng vân để tăng lực nhưng thất bại. VL thoát vào Nghịch Thiên Châu trước khi Âu Chí có thể chặn. (@c0254)"}],"tuViMoc":[],"nhanMach":[{"ten":"Hồng Điệp","gap":"@c0253","quanHe":"Người được bảo hộ","ghiChu":"Nhiệm vụ đến Tuyết Vực đón Hồng Điệp về Chu Tước Quốc.","tag":"dong-hanh"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0253","@c0254"]},{"id":"mac-tri","name":"Mặc Trí","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ — có Vong Cảnh (ý cảnh) + Súc Địa thành thốn + nhận diện được ý cảnh người khác → tu vi rất cao @c0259","trangThai":"song @c0259","vaiTro":"Tu sĩ bí ẩn — người giảng đạo sinh tử cho Vương Lâm","tinhCach":[{"text":"Ôn hòa, cười cười liên tục; thẳng thắn không giấu ý cảnh; trí nhớ ngắn hạn kém do Vong Cảnh phát tác — quên cuộc trò chuyện vừa xảy ra.","chuong":"@c0259"}],"blurb":"Tu sĩ bí ẩn mặc bạch y, sở hữu ý cảnh Vong Cảnh (quên lãng) và Súc Địa thành thốn. Gặp Vương Lâm trong miếu hoang dưới mưa đêm; nhận ra VL có ý cảnh tỏa hồn. Giảng đạo sinh tử: 'Cơn mưa sinh từ trên trời, rơi xuống đất mà chết — khoảng giữa là nhân sinh.' VL chấn động, vái sâu tạ ân. Lai lịch tông phái hoàn toàn không rõ.","tabs":{"diem":[{"text":"Nhận ra VL có ý cảnh tỏa hồn chỉ bằng quan sát — năng lực nhận diện cực cao.","chuong":"@c0259"},{"text":"Ý cảnh Vong Cảnh gây mất trí nhớ ngắn hạn liên tục: quên tên VL, quên đang nói gì (ít nhất 3 lần trong cuộc trò chuyện). Tự giải thích: 'Từ sau khi hiểu được thiên đạo, trí nhớ thi thoảng lại có vấn đề.'","chuong":"@c0259"}],"kinhLich":[{"chuong":"@c0259","importance":"major","tieuDe":"Giảng đạo sinh tử cho Vương Lâm","text":"Gặp VL trong miếu hoang, nhận ra ý cảnh tỏa hồn. Luận đạo: sinh = lửa, tử = tâm chết; 'Cơn mưa sinh từ trên trời, rơi xuống đất mà chết — khoảng giữa là nhân sinh.' VL chấn động, vái sâu tạ ân rồi rời đi dưới mưa. (@c0259)"}],"tuViMoc":[{"chuong":"@c0259","canhGioi":"Vong Cảnh (ý cảnh quên lãng)","text":"Ý cảnh mới lần đầu xuất hiện trong truyện. Hệ quả: mất trí nhớ ngắn hạn sau khi 'hiểu được thiên đạo'. (@c0259)"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0259","quanHe":"Người được giảng đạo","ghiChu":"Gặp một lần; giảng đạo sinh tử thay đổi nhận thức VL. VL xưng tên giả Đại Ngưu.","tag":"khac"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0259"]},{"id":"tran-hoan","name":"Trần Hoan","cn":"","aliases":["Hoan","Hoàn nhi"],"gioiTinh":"nam","theLuc":[{"ten":"Thủy Mặc Môn","trangThai":"thieu-mon-chu"}],"canhGioiCaoNhat":"Không rõ (dưới Hóa Thần) @c0257","trangThai":"song — rời khỏi biên giới Tuyết Vực sau khi sư phụ hy sinh @c0258","vaiTro":"Thiếu môn chủ Thủy Mặc Môn — thề diệt Tuyết Vực","tinhCach":[{"text":"Cứng cỏi, quyết liệt — nhìn bóng lưng sư phụ khuất dần, dập đầu nhiều cái rồi nắm chặt tay, xoay người đi; thề cả đời phải diệt Tuyết Vực quốc.","chuong":"@c0258"}],"blurb":"Thiếu môn chủ Thủy Mặc Môn — một trong Liên Minh Tứ Phái vừa bị tiêu diệt. Gặp Vương Lâm cùng sư phụ Hóa Thần hậu kỳ. Sư phụ hy sinh tự bão vào Băng Tuyết Thần Điện, thức tỉnh các tu sĩ ẩn dật. Trần Hoan thề cả đời diệt Tuyết Vực, rời đi. (+) Thiếu môn chủ Thủy Mặc Môn, Kết Đan kỳ, dư nghiệt Tứ Phái ẩn nấp trong Tuyết Vực. Tấn công Vương Lâm khi VL xâm nhập nhưng bị khống chế; được sư phụ đẩy ra khỏi biên giới Tuyết Vực để sống sót. [CAN-SOAT-GOP]","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0257","importance":"normal","tieuDe":"Gặp VL — nhận đan dược từ sư phụ đáp đền","text":"Gặp VL cùng sư phụ Hóa Thần hậu kỳ Thủy Mặc Môn. Sư phụ nhận đan dược VL tặng, đáp đền bằng cây quạt 2 lông. VL dùng Thiên Đạo Luân Hồi chữ Sinh chữa thương. (@c0257)"},{"chuong":"@c0258","importance":"normal","tieuDe":"Sư phụ hy sinh — thề diệt Tuyết Vực","text":"Nhìn bóng lưng sư phụ bay thẳng vào Băng Tuyết Thần Điện tự bão. Dập đầu nhiều cái, nắm chặt tay thề: 'Ta. Trần Hoan ở đây thề. Cuộc đời này nhất định phải diệt Tuyết Vực quốc.' Rời đi. (@c0258)"},{"chuong":"@c0257","importance":"normal","tieuDe":"Được sư phụ cứu thoát Tuyết Vực","text":"Ẩn nấp cùng sư phụ (Hóa Thần hậu kỳ sắp tán công) trong cấm chế dưới núi băng Tuyết Vực. Tấn công VL bằng phi kiếm khi VL xâm nhập, bị VL dùng thiên đạo Luân Hồi khống chế. Oán hận Tuyết Vực hủy nhà; quỳ xin chết thay sư phụ. Được sư phụ đẩy ra khỏi vòng sáng biên giới + đưa nửa bình đan dược (VL tặng), nói lời từ biệt. Thoát ra ngoài Tuyết Vực một mình."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão nhân Hóa Thần hậu kỳ Thủy Mặc Môn","gap":"@c0257","quanHe":"Sư phụ","ghiChu":"Sư phụ hy sinh tự bão vào Băng Tuyết Thần Điện để thức tỉnh tu sĩ ẩn dật.","tag":"su-mon"},{"ten":"Vương Lâm","gap":"@c0257","quanHe":"Quen biết tình cờ","ghiChu":"Gặp khi sư phụ tặng cây quạt cho VL; chứng kiến sư phụ hy sinh cùng VL.","tag":"khac"},{"ten":"Lão nhân Thủy Mặc Môn","tag":"su-mon","quanHe":"Sư phụ, hi sinh cứu"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Bị VL khống chế rồi gián tiếp được cứu"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0257","@c0258"]},{"id":"chu-vu-thai","name":"Chu Vũ Thái","cn":"","aliases":["Chu Võ Thái","tu sĩ tai to","Chu Tước thứ mười lăm","đệ thập ngũ Chu Tước"],"gioiTinh":"nam","theLuc":[{"ten":"Vân Tước (bốn người được Vân Tước chọn)","trangThai":"danh-nghia"},{"ten":"Liên minh bốn phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần trung kỳ — đội mũ cỏ Vân Tước @c0374","trangThai":"song","vaiTro":"Đối thủ Hóa Thần thời kinh đô rồi thành cố nhân của Vương Lâm; đại biểu/trọng thần Liên Minh Tứ Phái, mang huyết mạch Thương Long","tinhCach":"Mưu trí, thích đấu trí bằng lời, ban đầu cao ngạo coi VL là đối thủ; về sau kiên định giữ con đường hóa phàm riêng, không để Tuế Nguyệt ý cảnh dao động; trọng tình cố nhân, thức thời, biết tiến thoái; ngoài lạnh trong lo.","blurb":"Tu sĩ tai to, lần đầu xuất hiện ở kinh đô khi tới hỏi tội Vương Lâm vì VL đánh đệ tử (tiểu đạo sĩ Phúc nhi) của hắn. Cùng cảnh giới bán Nguyên Anh chuẩn bị Hóa Thần, hắn nhận VL là đối thủ cạnh tranh lớn nhất đời và đấu trí gieo tâm chướng nhưng thất bại. Hơn mười năm sau tái ngộ giữa bão tuyết, hắn — nay Nguyên Anh hậu kỳ đỉnh, mang huyết mạch Thương Long thủ hộ Liên Minh Tứ Phái — thừa nhận VL đã vượt mình, đại biểu Tứ Phái mời VL gia nhập đại chiến Tuyết Vực và tặng ngọc giản thần thông Hóa Thần kỳ. Trong đại chiến, hắn khống chế Thương Long đại trận nhưng bị sứ giả Chu Tước quốc đánh trọng thương, mất huyết mạch và bị VL cướp túi trữ vật chứa Vũ Đỉnh.","tabs":{"diem":["Nguyên Anh hậu kỳ đỉnh, chỉ còn một bước vào Hóa Thần và đã nắm chút ý cảnh — vượt trội tu sĩ Nguyên Anh thường","Mang huyết mạch Thương Long, là người duy nhất khống chế được Thương Long đại trận thủ hộ Tứ Phái","Theo con đường hóa phàm 'lấy tình thầy trò' (thu đồ → dưỡng dục → tự tay giết đệ tử để nhập thần), khác con đường nhân gian của VL","Từng coi VL là đối thủ cạnh tranh lớn nhất đời rồi cuối cùng thừa nhận VL vượt mình"],"kinhLich":[{"chuong":"@c0238","importance":"normal","tieuDe":"Tu sĩ tai to ra mặt, tìm Vương Lâm hỏi tội","text":"Lần đầu xuất hiện: đệ tử (tiểu đạo sĩ Phúc nhi) bị Vương Lâm phá bản mạng la sát chạy về khóc lóc xin báo thù. Hắn — tu sĩ tai to mặt to mắt nhỏ, uy nghiêm — vung tay triệu hồi đầu lâu xương khô, một chưởng phục hồi bản mạng la sát và trị thương cho đệ tử. Bình tĩnh xác nhận kẻ kia 'trong người không có linh lực, giống phàm nhân', ánh mắt lộ vẻ kỳ dị, bảo đệ tử dẫn đường đi bộ không dùng pháp thuật. Tối đó dẫn đệ tử tới cửa hàng tượng gỗ của VL — cuộc đối đầu sắp xảy ra."},{"chuong":"@c0239","importance":"major","tieuDe":"Đấu trí gieo tâm chướng, nhận Vương Lâm là đối thủ Hóa Thần","text":"Vào cửa hàng, hắn nhận ra các tượng gỗ điêu khắc (văn sĩ trung niên và lão bà Bạch Vân tông) mang ý cảnh, đoán cảnh giới VL ngang mình — đều là tu sĩ bán Nguyên Anh sắp Hóa Thần. Thay vì giao chiến, hai người uống rượu đấu trí: hắn liên tục dùng ngôn từ ẩn huyền cơ (mời thi đua ai Hóa Thần trước, chúc 'trăm năm tất Hóa Thần') để gieo tâm chướng cho VL. VL nhìn thấu, phản kích, vạch trần con đường hóa phàm của hắn (lấy tình thầy trò: thu đồ → dưỡng dục → tự tay giết đệ tử để đau khổ nhập thần) — gieo mầm nghi ngờ cho tiểu đạo sĩ Phúc nhi. Hắn cười khổ biết thua, nhượng bộ vụ Vũ Đỉnh (cho thế tử 3 ngày đem tới đạo quan, không truy cứu) rồi rời đi, âm thầm coi VL là đối thủ cạnh tranh lớn nhất cuộc đời."},{"chuong":"@c0241","importance":"normal","tieuDe":"Tái ngộ giữa bão tuyết","text":"Đến cửa hàng Vương Lâm giữa bão tuyết sau hơn chục năm không gặp, mặc áo tơi bám tuyết dày. Tu vi tinh tiến hơn 10 năm trước nhưng kém VL (người đã cảm ngộ thiên đạo). Giữa lông mày thêm nếp nhăn lo lắng."},{"chuong":"@c0242","importance":"normal","tieuDe":"Tặng ngọc giản, mời gia nhập Tứ Phái","text":"Kinh hoàng nhận ra tượng gỗ lão già áo xanh của VL có Tuế Nguyệt ý cảnh thật; thừa nhận VL vượt mình, còn mình mười năm vẫn đứng tại chỗ. Nhận tượng VL tặng rồi trả lại để giữ con đường hóa phàm riêng không bị dao động. Tặng VL ngọc giản ghi thần thông/pháp thuật tu sĩ Hóa Thần kỳ. Đại biểu Liên Minh Tứ Phái mời VL gia nhập chuẩn bị đại chiến Tuyết Vực; giải thích tuyết không tan do truyền tống trận Tuyết Vực. Để lại ngọc giản truyền âm; trước khi đi tiết lộ Chu Tước tinh nằm sát Vũ chi Tiên Môn."},{"chuong":"@c0243","importance":"normal","tieuDe":"Chặn người áo đen giúp Vương Lâm","text":"Bốn tu sĩ áo đen (Nguyên Anh hậu kỳ, thi hành lệnh Tứ Phái diệt kẻ đáng nghi) hỏi sao hắn không ra tay giết VL. Hắn cười lạnh, cho rằng năm người cộng lại không đủ vì VL từng khắc tam lão Bạch Vân Tông và Tuế Nguyệt ý cảnh Thanh Tùng sư thúc, gọi bốn người là ngu ngốc rồi dừng bước xem kịch. Sau khi VL giết ba người, người thứ tư chạy về phía hắn thì hắn dùng pháp quyết quỷ dị (luồng sáng tím) chặn lại giúp VL — tuy mặt bình thản nhưng lưng áo tơi ướt đẫm vì sợ VL."},{"chuong":"@c0244","importance":"normal","tieuDe":"Diệt khẩu, tỏ rõ lập trường","text":"Giết tu sĩ Nguyên Anh thứ tư còn sống sót bằng pháp quyết tạo ảo giác (đối phương thấy lại cảnh thời thiếu niên nhập môn, không chống cự nổi), rồi đặt tay lên đỉnh đầu xuất linh lực giết, chộp Nguyên Anh bóp nát ngay trước mặt VL để diệt khẩu chứng minh lập trường. Vung tay áo hóa bốn thi thể thành tro bụi. Tự đánh giá mình với VL: chỉ có thể làm bạn chứ không thể làm địch."},{"chuong":"@c0245","importance":"normal","tieuDe":"Báo nghi vấn Tuyết Vực bất thường","text":"Qua ngọc giản truyền âm lại mời VL gia nhập Tứ Phái, kể hết hành động và bí mật gần đây. Nêu nghi hoặc về Tuyết Vực: theo thông lệ Tuyết Vực chỉ để tuyết rơi mười ngày rồi tấn công (quy định Chu Tước quốc cấm tu sĩ quấy nhiễu phàm nhân), nhưng lần này tuyết rơi liên tục bốn tháng — bất thường."},{"chuong":"@c0246","importance":"normal","tieuDe":"Phân tích chiến tranh diệt quốc của Tuyết Vực","text":"Khẳng định Tuyết Vực đang tiến hành chiến tranh diệt quốc (tuyết bốn tháng không giảm, chỉ bị trận pháp che). Báo kết quả ba nhóm tìm viện binh: nhóm minh hữu thất bại (ngũ cấp quốc cấm tham dự), nhóm ngũ cấp phụ thuộc thất bại, nhóm Chu Tước Quốc chưa về. Truyền tin kinh hoàng về nữ tử Tuyết Vực (Hóa Thần hậu kỳ đỉnh, hơn trăm năm tu không dùng đan dược); điều kiện nàng ra cho Chu Tước Quốc là nâng Tuyết Vực lên ngũ cấp và đổi lãnh thổ bằng đất Tứ Phái — Vũ Đỉnh trong tay thái tử là một âm mưu."},{"chuong":"@c0247","importance":"normal","tieuDe":"Lặng lẽ giúp Vương Lâm, không còn dám mời","text":"Biết VL thu gỗ trên bình nguyên tuyết (tu sĩ lân cận phát hiện báo lên Tứ Phái), hắn dùng chức quyền dìm chuyện và tự dẫn người lặng lẽ giúp dọn (nếu không bảy ngày không đủ dọn sạch bình nguyên). Lần này không mời VL gia nhập Tứ Phái nữa — nhận ra Tứ Phái đã đến bước đường cùng, mời người vào lúc này chẳng khác kéo người vào chỗ chết. Cay đắng ôm quyền xoay người đi, bắt đầu suy nghĩ lại con đường của chính mình."},{"chuong":"@c0251","importance":"major","tieuDe":"Khống chế Thương Long đại trận khai chiến","text":"Đứng trên Thương Long (dãy núi Thiên Vân hóa rồng vạn trượng), khống chế Thương Long đại trận với 108 cột sáng bảy màu — chỉ riêng hắn khống chế được nhờ huyết mạch Thương Long thủ hộ Tứ Phái trong thân. Tiếng gầm Thương Long là tín hiệu lệnh quyết chiến khiến tu sĩ Tứ Phái phấn chấn bay ra gia nhập chiến trường, cho thấy địa vị cao của hắn trong Tứ Phái."},{"chuong":"@c0252","importance":"minor","tieuDe":"Ghi chép quái vật người rắn","text":"Được nhắc tên qua ngọc giản thông tri của hắn có ghi thông tin về quái vật mình người đầu rắn — VL đã đọc trước đó và nhớ lại khi quái vật xuất hiện."},{"chuong":"@c0253","importance":"major","tieuDe":"Trọng thương, mất huyết mạch Thương Long","text":"Đứng trên Thương Long điều khiển xuất chiến hướng vật đầu người mình rắn thì bị sứ giả Chu Tước quốc (trung niên nam tử bệnh hoạn) dùng pháp lực rung bật, phun tiên huyết, lao xuống đất như sao băng. Huyết mạch bị rút ra ngưng thành giọt huyết châu ánh tím rơi vào mi tâm Thương Long, khiến Thương Long mất long hồn hóa đá. Hắn hôn mê trong hắc động trên ngọn núi tuyết (chưa chết), bị VL cướp túi trữ vật chứa Vũ Đỉnh; ngọn núi sau đó bị sương lam hóa băng nên số phận chưa rõ."},{"importance":"normal","text":"Giai đoạn sớm (bán Nguyên Anh, biệt danh \"tu sĩ tai to\"): dẫn đệ tử Phúc Nhi đến hỏi tội Vương Lâm thời kinh đô, bị VL dùng ma đầu Hứa Lập Quốc áp chế.","chuong":"@c0238"},{"bridge":true,"khoang":"@c0489","text":"Đang khoanh chân tĩnh tọa trên Chu Tước Tinh xa xôi, đột nhiên mở hai mắt khi thấy bầu trời đỏ rực bởi hồng quang thủy triều Đông Hải Yêu Linh lan tới."},{"chuong":"@c0242","importance":"normal","text":"Đại biểu Liên Minh Tứ Phái tới mời Vương Lâm gia nhập kháng chiến chống Tuyết Vực; tặng Vương Lâm ngọc giản ghi thần thông Hóa Thần kỳ. Khâm phục đạo tâm Vương Lâm khi hắn trả lại tượng gỗ để giữ con đường hóa phàm riêng. Trước khi đi hé lộ manh mối: Chu Tước tinh nằm sát Vũ chi Tiên Môn (một trong tứ đại tiên môn Phong Vũ Lôi Thiên). Tu vi Nguyên Anh hậu kỳ, kém Vương Lâm một chút.","nguonNblm":true},{"chuong":"@c0243","importance":"normal","text":"Từ chối nghe lệnh Tứ Phái giết Vương Lâm, cảnh báo bốn tu sĩ áo đen không đủ sức. Khi Vương Lâm giết ba người, hắn ra tay chặn người thứ tư chạy trốn bằng pháp quyết ánh sáng tím, đứng hẳn về phía Vương Lâm — dù mặt bình thản nhưng lưng áo ướt đẫm mồ hôi vì kiêng dè uy thế Vương Lâm.","nguonNblm":true},{"chuong":"@c0247","importance":"minor","text":"Dùng chức quyền trong Tứ Phái dìm tin Vương Lâm thu gỗ trên bình nguyên tuyết, lặng lẽ dẫn người tới giúp dọn gỗ. Không mời Vương Lâm gia nhập vì biết Tứ Phái đã tới bước đường cùng, bắt đầu nghĩ lại con đường của chính mình.","nguonNblm":true},{"chuong":"@c0253","importance":"normal","text":"Điều khiển Thương Long (vạn trượng) xuất chiến chống quân Tuyết Vực, nhưng bị sứ giả Chu Tước quốc một đòn rút huyết mạch khiến Thương Long mất long hồn hóa đá; bản thân phun tiên huyết, rơi xuống hôn mê trong hắc động trên núi tuyết. Vương Lâm tới cướp túi trữ vật của hắn (chứa Vũ Đỉnh) rồi bỏ chạy.","nguonNblm":true},{"chuong":"@c0439","importance":"major","text":"Được Vương Lâm (thân phận Tằng Ngưu) nhường lại chức Chu Tước; sứ giả Mặc Trí điểm tinh thạch hình trái tim vào mi tâm, phong làm Chu Tước thứ mười lăm, lệnh bế quan một năm trong Chu Tước mộ cảm ngộ Chu Tước Ấn. Một năm sau xuất quan với tu vi Hóa Thần hậu kỳ đại viên mãn — thấp nhất trong các Chu Tước được phong hào, song phối hợp Chu Tước Ấn đủ uy hiếp tu sĩ Anh Biến kỳ; biết mình quá yếu nên lập tức bế quan trong Chu Tước Sơn. Vương Lâm nhường chức vì hắn có ơn lớn và sẽ chăm sóc những người thân của Vương Lâm sau khi hắn rời đi.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Gặp ở kinh đô, đấu trí thua @c0239, coi VL là đối thủ Hóa Thần lớn nhất đời; hơn 10 năm sau tái ngộ thành cố nhân @c0241, nhiều lần giúp ngầm, cuối cùng bị VL cướp túi trữ vật @c0253"},{"ten":"Liên Minh Tứ Phái","tag":"su-mon","quanHe":"Trọng thần/đại biểu, mang huyết mạch Thương Long thủ hộ; khống chế Thương Long đại trận @c0251"}],"tuiDo":{}},"nguon":["@c0238","@c0239","@c0241","@c0242","@c0243","@c0244","@c0245","@c0246","@c0247","@c0251","@c0252","@c0253","@c0489"],"detail":"Một trong bốn người được Vân Tước (nhị tổ Tiên Di Tộc) tuyển chọn bồi dưỡng làm Chu Tước Tử kế nhiệm; sở trường ý cảnh Trảm Tình đạo. Cuối arc Chu Tước mộ được Vương Lâm nhường chức, chính thức trở thành Chu Tước thứ mười lăm của Chu Tước tinh."},{"id":"thu-do","name":"Thủ Đồ","cn":"","aliases":[],"gioiTinh":"nu","theLuc":["Tuyết Vực quốc"],"canhGioiCaoNhat":"Không rõ (thống lĩnh tu sĩ Tuyết Vực)","trangThai":"da-chet (@c0253)","vaiTro":"Sư tỷ của Hồng Diệp","tinhCach":"(không thấy đề cập trong tiểu thuyết)","blurb":"Sư tỷ của Hồng Diệp, được giao thống lĩnh tu sĩ cả nước Tuyết Vực tiến quân chống liên minh Tứ Phái. Theo suy đoán, nàng thay Hồng Diệp ứng kiếp nạn; khi nàng chết thì kiếp nạn của Hồng Diệp tận.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0253","importance":"major","tieuDe":"Ứng kiếp thay Hồng Diệp","text":"Sư tỷ của Hồng Diệp, được giao thống lĩnh tu sĩ cả nước Tuyết Vực tiến quân chống liên minh Tứ Phái, nhận ngũ linh từ Hồng Diệp để chiến đấu. Theo suy đoán của sư phụ Hồng Diệp, Thủ Đồ thay thế Hồng Diệp ứng kiếp nạn; khi Thủ Đồ chết, kiếp nạn Hồng Diệp tận. Đã bỏ mình."}],"tuViMoc":[],"nhanMach":[{"ten":"Hồng Diệp","tag":"su-mon","quanHe":"Sư muội; ứng kiếp thay"}],"tuiDo":{}},"nguon":["@c0253"]},{"id":"chu-van","name":"Chú Vân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Hắc Hồn Phái","Liên Minh Tứ Phái"],"canhGioiCaoNhat":"Hóa Thần Hậu Kỳ","trangThai":"song","vaiTro":"Đại trưởng lão hộ phái Tứ Phái","tinhCach":"Quyết đoán, dám đánh cược; uy nghiêm.","blurb":"Tu sĩ Hắc Hồn Phái, một trong tám Hóa Thần Hậu Kỳ và bốn Đại trưởng lão hộ phái của Liên Minh Tứ Phái. Người phát tín hiệu khai chiến với nữ tử áo trắng (Hồng Diệp) và khởi động sát trận.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0251","importance":"major","tieuDe":"Khai chiến, khởi động sát trận","text":"Tu sĩ Hắc Hồn Phái, một trong tám Hóa Thần Hậu Kỳ của Tứ Phái Liên Minh và một trong bốn Đại trưởng lão hộ phái. Biến hình từ lão già gầy thành trung niên uy nghiêm. Hỏi nữ tử áo trắng có phải Hồng Diệp không; nàng không trả lời đúng. Ra tín hiệu khai chiến và khởi động bước hai của sát trận: 'Đánh cuộc một lần, mặc kệ nàng có phải Hồng Diệp hay không.'"}],"tuViMoc":[],"nhanMach":[{"ten":"Hồng Diệp","tag":"doi-thu","quanHe":"Khai chiến vây giết @c0251"}],"tuiDo":{}},"nguon":["@c0251"]},{"id":"lao-nhan-thuy-mac-mon","name":"Lão nhân Thủy Mặc Môn","cn":"","aliases":["Sư phụ Hoàn"],"gioiTinh":"nam","theLuc":["Thủy Mặc Môn"],"canhGioiCaoNhat":"Hóa Thần hậu kỳ","trangThai":"da-chet (tự nuốt đan dược ở lại Tuyết Vực @c0257)","vaiTro":"Sư phụ của Hoàn (dư nghiệt Tứ Phái)","tinhCach":"Trọng nghĩa, gắn bó cố hương, hi sinh vì đồ đệ.","blurb":"Tu sĩ Hóa Thần hậu kỳ, sư phụ của Hoàn — chính là vị 'làm rung chuyển trời đất' trong Cửu Nhân sát trận liên minh Tứ Phái năm xưa. Tặng Vương Lâm cây quạt hai lông rồi ở lại Tuyết Vực chịu chết để đồ đệ thoát thân.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0257","importance":"major","tieuDe":"Hi sinh cứu đồ đệ, tặng quạt cho VL","text":"Ẩn nấp cùng đệ tử Hoàn trong cấm chế dưới núi băng Tuyết Vực, tu vi sắp tán công. Nhận ra VL không phải tu sĩ Tuyết Vực. Từ chối chạy trốn ('đây là nhà của ta, ta sinh ở đây mà tử cũng ở đây'). Tặng VL cây quạt hai lông (pháp bảo của bạch y nữ tử trong Cửu Nhân sát trận) để báo đáp đan dược. Tại biên giới, mở thông đạo đưa đồ đệ Hoàn ra ngoài + đưa nửa bình đan dược, nói lời từ biệt rồi nuốt hết nửa bình đan dược ở lại."}],"tuViMoc":[],"nhanMach":[{"ten":"Hoàn","tag":"su-mon","quanHe":"Đồ đệ; hi sinh để cứu"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tặng quạt 2 lông báo đáp đan dược"}],"tuiDo":{}},"nguon":["@c0257"]},{"id":"van-tuoc-tu","name":"Vân Tước Tử","cn":"","aliases":["Vân Tước","Vân Tước Tử","lão đầu lôi thôi","lão nhân lôi thôi","sư đệ Chu Tước","#lao-dau-bi-oi"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ (cao thâm, tiết lộ bí mật Vũ Đỉnh)","trangThai":"song","vaiTro":"Lão nhân bí ẩn cạnh Vương Lâm thời hóa phàm","tinhCach":"Cợt nhả, bỉ ổi ngoài mặt nhưng am hiểu thiên cơ.","blurb":"Lão nhân bí ẩn hay lui tới cửa hàng Vương Lâm thời hóa phàm. Tiết lộ nguyên nhân chiến tranh Tứ Phái là tranh đoạt Vũ Đỉnh và bản chất bốn đỉnh Phong/Vũ/Lôi/Thiên dẫn vào tiên môn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0244","importance":"normal","tieuDe":"Tiết lộ bí mật Vũ Đỉnh","text":"Xuất hiện nửa đêm tại cửa hàng VL, mang gà nướng chia VL nửa, khen tu vi VL 'sắp tới Hóa Thần kỳ'. Tiết lộ nguyên nhân chiến tranh Tứ Phái là Vũ Đỉnh (thái tử lấy được, Tuyết Vực đòi lại); giải thích bốn đỉnh Phong/Vũ/Lôi/Thiên cứ sau nhiều năm xuất hiện giữa trời đất, người có nó vào ngày thiên đạo mở ra đi vào tiên môn tương ứng."},{"chuong":"@c0245","importance":"normal","text":"Lần xuất hiện cuối trong đợt rồi rời đi (chi tiết @c0245)."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Lui tới cửa hàng, tiết lộ thiên cơ"}],"tuiDo":{}},"nguon":["@c0244","@c0245"]},{"id":"trung-nien-van-si","name":"Trung niên văn sĩ (Chu Tước quốc)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Chu Tước quốc"],"canhGioiCaoNhat":"Cực cao (thần thức khổng lồ; từng hủy diệt Thương Long dễ dàng)","trangThai":"song","vaiTro":"Người bảo hộ Hồng Điệp cô nương","tinhCach":"Giả bệnh che giấu thực lực; khao khát thiên kiếp.","blurb":"Nhân vật phụ bí ẩn từ Chu Tước quốc, người bảo hộ Hồng Điệp cô nương, tu vi cực cao. Khi thấy tứ hồng thiên kiếp của Vương Lâm thì bỏ chức trách lao tới cố giữ đám mây đỏ nhưng thất bại. Chưa rõ tên thật.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0254","importance":"normal","tieuDe":"Cố giữ thiên kiếp bất thành","text":"Trước đó giả bệnh tật, đứng sau Hồng Điệp làm bảo hộ. Khi thấy tứ hồng thiên kiếp (VL phóng), vẻ bệnh tật biến mất, bỏ chức trách bảo hộ lao về phía đám mây đỏ. Cố giữ đám mây đỏ bằng thần thông nhưng không có sợi tơ thiên kiếp dẫn nên mây vẫn tiêu tán; tuyệt vọng. Phóng thần thức khổng lồ quét qua người VL (bị mù rơm cản). Tu vi cực cao — từng hủy diệt Thương Long dễ dàng."}],"tuViMoc":[],"nhanMach":[{"ten":"Hồng Điệp","tag":"khac","quanHe":"Người bảo hộ"}],"tuiDo":{}},"nguon":["@c0254"]},{"id":"ba-lao-ao-trang-tuyet-vuc","name":"Bà lão áo trắng (Tuyết Vực)","cn":"","aliases":[],"gioiTinh":"nu","theLuc":["Tuyết Vực quốc"],"canhGioiCaoNhat":"Hóa Thần trung kỳ đỉnh","trangThai":"da-chet (bị tứ hồng thiên kiếp hủy diệt @c0254)","vaiTro":"Nữ tu sĩ Tuyết Vực truy sát Vương Lâm","tinhCach":"(không thấy đề cập trong tiểu thuyết)","blurb":"Nữ tu sĩ Tuyết Vực Hóa Thần trung kỳ đỉnh, đang truy sát Vương Lâm thì bị tứ hồng thiên kiếp giáng xuống hủy diệt hoàn toàn cùng tháp băng.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0254","importance":"normal","tieuDe":"Bị thiên kiếp hủy diệt","text":"Đang truy sát VL (Nguyên Anh hậu kỳ). Bị con rối Nguyên Anh kỳ tự bạo + Cực Cảnh làm mê man, buộc phải chui vào tháp băng bỏ chạy. Bị tứ hồng thiên kiếp giáng xuống — lúc bị trói buộc không gian không thể di động — cả tháp băng lẫn bản thân bị hủy diệt hoàn toàn. Có áo trắng với trận pháp thần kỳ (xua tan sức ép tự bạo)."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Truy sát VL, bị thiên kiếp diệt"}],"tuiDo":{}},"nguon":["@c0254"]},{"id":"phac-nam-tu","name":"Phác Nam Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":["Thông Thiên Tháp"],"canhGioiCaoNhat":"Nguyên Anh kỳ","trangThai":"da-chet (bị sứ giả dùng làm lá chắn → hóa tro @c0223)","vaiTro":"Thuộc hạ Sứ Giả Thông Thiên Tháp","tinhCach":"(không thấy đề cập trong tiểu thuyết)","blurb":"Tu sĩ Nguyên Anh kỳ, thuộc hạ Sứ Giả Thông Thiên Tháp. Nhận ra Vương Lâm là đệ tử Hằng Nhạc phái năm xưa; bị chính sứ giả chụp làm lá chắn chắn đòn nên hóa tro bụi.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0223","importance":"major","tieuDe":"Bị dùng làm lá chắn, hóa tro","text":"Nguyên Anh kỳ, thuộc hạ Sứ Giả Thông Thiên Tháp; nhận ra VL là đệ tử Hằng Nhạc phái năm xưa. Dùng hai vòng sáng xanh hồng (phẩm chất cực cao) tấn công VL, bị Cực Cảnh thần thức áp chế. Khi Thông Thiên thuật giáng xuống, bị chính sứ giả chụp làm lá chắn chắn đòn nên hóa tro bụi, chết."},{"chuong":"@c0218","importance":"normal","text":"Thủy tổ Huyền Đạo Tông, cao thủ số 1 Triệu quốc, đã tu tới sát Hóa Thần kỳ ('chỉ còn một lớp giấy'). Vì Đằng gia bị 'sứ giả đại nhân' chỉ định làm đối tượng thí nghiệm, lão miễn cưỡng lên đỉnh Hằng Nhạc quỳ dập đầu 'mượn' hai pháp luân cấp Hóa Thần để cứu Đằng gia — tuyên bố đây là lần ra tay CUỐI CÙNG, ra tối hậu thư 100 năm Đằng gia phải có Hóa Thần kỳ. Xác nhận lão chống lưng đưa Đằng Hóa Nguyên lên Nguyên Anh hậu kỳ.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tấn công VL, bị diệt"}],"tuiDo":{}},"nguon":["@c0223"]},{"id":"ton-dien","name":"Tôn Điên","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Khí các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (cao thâm)","trangThai":"song","vaiTro":"Lão nhân bí ẩn liên quan Luyện Khí các, từng cố ép Vương Lâm bái sư","tinhCach":[],"blurb":"Lão nhân mặc vải bố, tay cầm hồ lô đỏ, cưỡi linh thú Huyền Vũ; tu vi cao thâm, liên quan Luyện Khí các. Gặp lại Vương Lâm tại Tu Ma hải, tặng 1 sợi Cực Quang Hỏa Tuyến cho Văn thú.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0265","importance":"normal","text":"Gặp Vương Lâm tại Tu Ma hải, tặng 1 sợi Cực Quang Hỏa Tuyến"},{"chuong":"@c0266","importance":"normal","text":"Tôn Điên tự vào Toái Tinh loạn thu 7 luồng Cực Quang Hỏa Tuyến rồi tặng VL 1 sợi trước khi rời đi"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0265","@c0266"]},{"id":"van-thu","name":"Văn Thú","cn":"","aliases":["con muỗi khổng lồ"],"gioiTinh":"khac","theLuc":[{"ten":"Vương Lâm (pháp thú)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Trung phẩm linh cấp","trangThai":"song","vaiTro":"Linh thú tọa kỵ của Vương Lâm","tinhCach":[],"blurb":"Linh thú tọa kỵ của Vương Lâm, tốc độ cao trên biển. Dung hợp Cực Quang Hỏa Tuyến (1 sợi Tôn Điên tặng + hơn 10 sợi tự hấp thu) → đột phá trung phẩm linh cấp, thân dài ~30 trượng.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0266","importance":"normal","text":"Đột phá từ hạ phẩm linh cấp lên trung phẩm linh cấp sau khi dung hợp Cực Quang Hỏa Tuyến, thân thể tăng lên ~30 trượng"},{"chuong":"@c0347","importance":"normal","tieuDe":"Được triệu xuất — giết cường đạo, thủ hộ 2 tháng","text":"Được VL triệu xuất từ túi trữ vật sau khi VL đột phá thoát thủy lao (linh lực khôi phục Ngưng Khí tầng 2). Phẫn nộ thấy chủ suy yếu: hút khô 1 cường đạo, đập chết đại hán mặt sẹo (Mã lão tứ). Khống chế hơn 200 người sơn trại. Thủ hộ VL suốt 2 tháng bên hồ nước (thủy lao cũ) trong quá trình VL bế quan. (@c0347)"},{"chuong":"@c0348","importance":"minor","tieuDe":"Thủ hộ bên cạnh VL trong bế quan","text":"Tiếp tục thủ hộ VL bên cạnh trong suốt thời gian VL bế quan hấp thu hài cốt từ bức tranh + phá phong ấn bằng tiên ngọc. (@c0348)"},{"chuong":"@c0349","importance":"normal","tieuDe":"Bay 7 ngày tới Luyện Hồn Tông","text":"Sau khi VL Trúc Cơ sơ kỳ, cùng VL bay liên tục 7 ngày qua nhiều tu chân quốc từ Bì Lô quốc đến lãnh địa Luyện Hồn Tông. (@c0349)"},{"chuong":"@c0382","importance":"normal","text":"Con muỗi khổng lồ được VL thả ra để âm thầm bảo vệ Chu Như trên Nguyệt tinh; suốt một năm cứu nàng vô số lần. Đâm vòi hút sạch tinh hoa huyết nhục một con giun đỏ khổng lồ định đớp Chu Như, cứu nàng rồi vỗ cánh bay đi.","nguonNblm":true},{"chuong":"@c0479","importance":"major","text":"Được xác nhận là thú đến từ tinh không, hung tính vượt xa yêu thú tu chân, sống bằng cắn nuốt vạn vật (đan dược, thiên tài địa bảo, nội đan), càng ăn càng mạnh. Tuy thực lực vẫn ở Nguyên Anh kỳ nhưng yêu thú Hóa Thần gặp cũng khiếp sợ. Mỗi khi VL giết yêu thú Hóa Thần trở lên đều thả Văn thú hút nội đan + huyết nhục để thúc đẩy lớn lên; thân lóe bạch mang, đang ở thời khắc sắp đột phá tiến hóa.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0266","@c0347","@c0348","@c0349"]},{"id":"ly-mo-uyen","name":"Lý Mộ Uyển","cn":"","aliases":["Uyển nhi","Uyển nhi kiếp trước"],"gioiTinh":"nu","theLuc":[{"ten":"Nguyên Anh trong hạt châu Thiên Nghịch (Vương Lâm thủ hộ)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh kỳ (Nguyên Anh hiện ngủ say trong hạt châu Thiên Nghịch) @c0381","trangThai":"khong-ro","vaiTro":"Nhân vật trong quá khứ của trung niên uống rượu, liên quan đến một con Lôi Oa","tinhCach":[],"blurb":"Tên được trung niên uống rượu nhắc đến khi nhìn thấy Lôi Oa của Vương Lâm — có vẻ liên quan đến con vật này theo cách nào đó. Thân phận và tình trạng chưa rõ.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0269","importance":"minor","text":"Tên được nhắc đến bởi trung niên uống rượu khi thấy Lôi Oa của Vương Lâm trước cửa tiên giới"},{"chuong":"@c0303","importance":"normal","text":"100 năm sau khi VL rời Sở quốc, LMU là Trưởng lão Vân Thiên Tông, thân thể suy kiệt vì 3 lần Kết Anh thất bại, ho ra máu, đang già đi. Trả hồn huyết cho hai tùy tùng để họ tự thoát, còn nàng kiên quyết ở lại Vân Thiên Tông — nơi ước định với VL — dù chết. VL cách 80 vạn dặm bỗng cảm ứng tâm linh, quyết về thăm nàng.","nguonNblm":true},{"chuong":"@c0307","importance":"normal","text":"VL trở về điều trị LMU hằng ngày, tặng phương thuốc ngũ phẩm linh đan, kể lại chuyện 100 năm. Phân tích: chỉ Kết Anh mới tăng thọ nhưng thân thể quá yếu không Kết Anh nổi; quyết phải lấy được phương thuốc lục phẩm linh đan để khôi phục thân thể nàng trước. Đưa LMU về Tu Ma Hải thăm động phủ cũ.","nguonNblm":true},{"chuong":"@c0308","importance":"normal","text":"VL dùng pháp lực Hóa Thần 'Bạt Sơn' nâng cả ngọn núi tạo lại động phủ năm xưa giống hệt cho LMU ở Tu Ma Hải, khiến tử khí trên người nàng phai nhạt. Sau đó đưa nàng tới Ma Nghịch thành dự phiên đấu giá Luyện Khí Các để mua phương thuốc.","nguonNblm":true},{"chuong":"@c0312","importance":"major","text":"6+ năm trôi qua, LMU già nua tóc bạc trắng, không thể đi lại, tử khí ngày càng đậm; VL liên tục đưa linh lực duy trì sự sống. Âu Dương Tử dồn hết tâm huyết luyện thành lục phẩm linh đan rồi ngã quỵ. VL cho LMU uống — linh lực thiên địa Sở quốc điên cuồng tụ vào cơ thể nàng (chuẩn bị Kết Anh).","nguonNblm":true},{"chuong":"@c0313","importance":"major","text":"LMU chết: thân thể hóa xương khô tiêu tán dưới lực luân hồi thiên đạo, Kim Đan nứt vỡ. VL dùng bức tranh Sinh tử luân hồi bảo hộ Nguyên Anh nàng, tuyên chiến với sứ giả thiên đạo ('Trời khiến ngươi chết, ta cũng sẽ cướp ngươi về'), mang Nguyên Anh bay vạn dặm điểm cho đầu thai vào bào thai một thiếu nữ sơn thôn. VL bị trọng thương; cần 19 năm để Nguyên Anh LMU khôi phục thần trí.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0269"]},{"id":"ton-van","name":"Tôn Văn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Công Tôn quốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","vaiTro":"Tu sĩ Công Tôn quốc phụ trách mở chiến trường ngoại vực tại Võ Văn quốc","tinhCach":[],"blurb":"Tu sĩ Công Tôn quốc (tu chân quốc cấp bốn), mặc áo lam, phụ trách chiến trường ngoại vực tại thuộc địa Võ Văn quốc. Khi Vương Lâm bước ra từ chiến trường ngoại vực, nhìn không thấu tu vi, đoán Hóa Thần kỳ, cung kính tham kiến rồi vội báo cáo gia tộc.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0267","importance":"normal","text":"Mở chiến trường ngoại vực tại Võ Văn quốc; Vương Lâm từ trong xé cửa bước ra, Tôn Văn cung kính tham kiến"},{"chuong":"@c0268","importance":"minor","text":"Sợ hãi rời đi, bay về tòa nhà hình tháp báo cáo gia tộc về việc gặp tu sĩ Hóa Thần từ chiến trường ngoại vực"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0267","@c0268"]},{"id":"thien-hoa-tien-si","name":"Thiên Hoa tiên sĩ","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tiên giới (Vũ chi)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","vaiTro":"Tiên sĩ thượng cổ của Vũ chi được tiên vương ban thưởng cung điện vì lập công lớn","tinhCach":[],"blurb":"Tiên sĩ của Vũ chi trong tiên giới thời thượng cổ, được Vũ chi đệ ngũ tiên vương ban quần thể cung điện (dựa theo trận pháp, hấp thu tiên khí mười vạn dặm, hiệu quả tu luyện gấp đôi). Thông tin khắc trên bia đá trong tiên giới hoang tàn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0270","importance":"minor","text":"Được Vũ chi đệ ngũ tiên vương ban thưởng quần thể cung điện vì lập công lớn — thông tin khắc trên bia đá Vương Lâm tìm thấy trong tiên giới hoang tàn"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0270"]},{"id":"ton-loi","name":"Tôn Lôi","cn":"","aliases":["lục sư đệ (danh nghĩa Đại La Kiếm Phái)"],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Phái","trangThai":"gia-mao"}],"canhGioiCaoNhat":"Hóa Thần trung kỳ (giấu tu vi, thực lực lộ @c0276)","trangThai":"bat-minh — bị toái phiến tiên giới nuốt vào hư vô sau khi tự bạo hắc châu @c0279","vaiTro":"Nhân vật phụ đối nghịch — đồng hành tạm thời trong tiên giới, nhiều lần lật lọng","tinhCach":[{"text":"Xảo quyệt, tàn nhẫn — giả vờ Hóa Thần sơ kỳ từ đầu; đẩy sư huynh cho tế ti nuốt sạch khi thấy thời cơ; dùng VL làm mồi nhử.","chuong":"@c0276"},{"text":"Thận trọng, biết kiêng dè — nhận ra nguy hiểm từ Cấm Phiên VL trong vách tường, không dám manh động dù tu vi cao hơn.","chuong":"@c0277"}],"blurb":"Tu sĩ Hóa Thần trung kỳ giấu tu vi, trà trộn vào Đại La Kiếm Phái dưới danh nghĩa lục sư đệ. Phản sát tam sư huynh @c0276, lộ tên thật @c0277. Hợp tác ngắn với VL trong Tiên Thú Phủ nhưng nhiều lần phản bội. Tự bạo hắc châu (nguyên thần thứ hai; mất nó tu vi tụt từ Hóa Thần trung kỳ xuống Nguyên Anh kỳ) → gây sụp đổ tiên giới toái phiến, bản thân bị nuốt vào hư vô @c0279.","tabs":{"diem":[{"text":"Hắc châu tự bạo — hy sinh nguyên thần thứ hai để tiêu diệt tế ti; uy năng đạt giới hạn tiên giới toái phiến, gây sụp đổ toàn bộ mảnh vỡ.","chuong":"@c0279"}],"kinhLich":[{"chuong":"@c0276","importance":"normal","tieuDe":"Lộ thực lực — phản sát tam sư huynh","text":"Xuất hiện dưới danh nghĩa lục sư đệ Đại La Kiếm Tông, cùng tam sư huynh vào Tiên Thú Phủ. Giả vờ mới Hóa Thần sơ kỳ. Khi tam sư huynh dùng hắn làm mồi nhử + sau đó phản bội tung chưởng vào lưng, hắn lộ thực lực Hóa Thần trung kỳ: chụp cánh tay sư huynh, cướp túi trữ vật (có Tẩy Linh Hồ) + bảo kiếm, ném sư huynh cho tế ti. Dùng pháp quyết ngăn nguyên thần tam sư huynh bay thoát → tế ti đen nuốt sạch nguyên thần. (@c0276)"},{"chuong":"@c0277","importance":"normal","tieuDe":"Lộ tên thật — đàm phán chia bảo vật","text":"Bỏ rơi sư huynh ('Xin lỗi, sư huynh!') thoát khỏi tế ti. Tự xưng tên thật là Tôn Lôi, thừa nhận không phải người Đại La Kiếm Phái mà trà trộn vào. Đề xuất liên thủ với VL chia 3 bảo vật (tiên ngọc, kiếm tiên, thiết phiến vàng). VL từ chối toàn bộ; Tôn Lôi tức giận nhưng kiêng dè Cấm Phiên ẩn trong vách tường + VL che giấu tu vi. (@c0277)"},{"chuong":"@c0278","importance":"normal","tieuDe":"Thỏa thuận hợp tác — tặng Di Tầm Quyết","text":"Đàm phán với VL: từ chối đưa Tẩy Linh Hồ (cần vào Đại La kiếm), đề nghị Tẩy Linh chi mộc thay thế; tặng Di Tầm Quyết (ngọc giản — thần thông phát hiện khe nứt không gian của Đại La Kiếm Tông). Thỏa thuận VL hộ tống tới hang; nếu không lấy được kiếm tiên thì cả hai vật thuộc VL. Âm mưu: nếu đoạt được kiếm tiên sẽ dùng chí bảo môn phái giết VL rồi rời tiên giới. Kinh ngạc trước uy lực lôi cầu Lôi Oa; bị tế ti đen chọn đuổi (không đuổi VL). (@c0278)"},{"chuong":"@c0279","importance":"major","tieuDe":"Tự bạo hắc châu — tiên giới toái phiến sụp đổ","text":"Gặp lại VL bị thương nặng (mất ngón tay), nhờ ngân giáp hộ thân mới sống sót hai lần truy kích. Hồi phục nhờ đan dược quý. Vào hang: dùng hắc phiến (bảo vật sư môn) xuất nguyên thần phong ấn cả VL + tế ti trong hắc băng 10 hơi thở — lật lọng bỏ VL làm mồi nhử, kế thất bại vì VL dùng Tuế Nguyệt Ý Cảnh thoát nhanh hơn. Chộp kiếm tiên hai lần đều bị kim quang đánh thương (ngân giáp hòa tan). Tế ti vây bủa, bóng ma tử vong bao phủ. Vỗ trán xuất hắc châu (tu luyện mấy trăm năm sau Hóa Thần — địa vị nguyên thần thứ hai; mất nó tụt từ Hóa Thần trung kỳ xuống Nguyên Anh kỳ), hô 'Bạo!' — hắc châu tự bạo; sóng gợn đen khuếch tán, uy năng đạt giới hạn tiên giới toái phiến → thiên địa vỡ tan sụp đổ. Tảng đất dưới chân sụp xuống, cả người bị nuốt biến mất vào hư vô — sinh tử bất minh. (@c0279)"}],"tuVi":"Hóa Thần trung kỳ (giấu tu vi, thực lực lộ @c0276). Sau khi tự bạo hắc châu @c0279, tu vi sẽ tụt xuống Nguyên Anh kỳ nếu còn sống.","tuViMoc":[{"chuong":"@c0276","canhGioi":"Hóa Thần trung kỳ","text":"Thực lực thật lộ khi phản sát tam sư huynh — trước đó giả vờ mới Hóa Thần sơ kỳ."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0277","quanHe":"Đồng hành bất đắc dĩ — đối lập","ghiChu":"Đề xuất liên thủ nhưng nhiều lần tính kế phản bội; VL luôn đi trước một bước.","tag":"doi-thu"}],"tuiDo":{"phapBao":[{"ten":"Tẩy Linh Hồ","loai":"di-bao","trangThai":"hien-co","moTa":"Hồ lô xanh do thủy tổ Đại La Kiếm Tông luyện chế. Hấp thu tiên giới khí nhanh nhất mà không cần ngưng luyện. Cả môn phái chỉ 3 người có. Cướp từ túi trữ vật tam sư huynh @c0276.","nguon":"@c0276"},{"ten":"Hắc phiến (quạt đen)","loai":"phap-bao","trangThai":"hien-co","moTa":"Bảo vật sư môn. Phát hàn khí cực mạnh, kết băng đen bao phủ; nguyên thần cầm đau như bàn là. Phong ấn tối đa 10 hơi thở.","nguon":"@c0279"},{"ten":"Ngân giáp","loai":"phap-bao","trangThai":"mat","moTa":"Áo giáp bạc hộ thân. Giúp Tôn Lôi tránh được hai lần truy kích của tế ti đen. Bị kim quang từ kiếm tiên hòa tan @c0279.","nguon":"@c0279"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0276","@c0277","@c0278","@c0279"]},{"id":"vu-chi-de-ngu-tien-vuong","name":"Vũ chi đệ ngũ tiên vương","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Tiên giới (Vũ chi)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","vaiTro":"Tiên vương thứ năm của Vũ chi trong thời thượng cổ","tinhCach":[],"blurb":"Một trong các tiên vương của Vũ chi trong tiên giới thời thượng cổ. Dùng thần thông chế tác quần thể cung điện (theo trận pháp, hấp thu tiên khí mười vạn dặm, hiệu quả tu luyện gấp đôi) ban thưởng cho Thiên Hoa tiên sĩ vì lập công lớn. Thông tin khắc trên bia đá trong tiên giới hoang tàn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0270","importance":"minor","text":"Ban thưởng quần thể cung điện cho Thiên Hoa tiên sĩ vì lập công lớn — thông tin khắc trên bia đá Vương Lâm tìm thấy trong tiên giới hoang tàn"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0270"]},{"id":"sat-ho","name":"Sất Hổ","cn":"","aliases":["nam tử Cự Ma tộc","tiểu tộc trưởng"],"gioiTinh":"nam","theLuc":[{"ten":"Cự Ma tộc","trangThai":"tiểu tộc trưởng"}],"canhGioiCaoNhat":"Hóa Thần trung kỳ (tự xưng @c0297)","trangThai":"song — trọng thương sau trận đánh Vương Lâm vs Cự Ma tộc @c0371","vaiTro":"phụ — đồng hành VL trong hư vô Tiên Giới; sau đó bế quan tại Chu Tước tinh","tinhCach":[{"text":"Cương cường, đề phòng kẻ lạ; chỉ nhượng bộ trước uy lực áp đảo","chuong":"@c0285"},{"text":"Coi trọng chủng tộc — chịu làm phân thân truyền Si Ý để bảo vệ Cự Ma tộc","chuong":"@c0289"},{"text":"Thực dụng và tính toán — từng do dự nhận phó thác Chu Dật vì lo ngại tộc; sau đó hối hận dữ dội khi thấy Vấn Đỉnh Chi Tinh","chuong":"@c0293"},{"text":"Đánh giá cao VL — tặng Tinh La Bàn sau khi nhận ra VL có tu vi + mưu trí vượt trội","chuong":"@c0296"}],"blurb":"Tiểu tộc trưởng Cự Ma tộc, Hóa Thần trung kỳ. Bị Chu Dật ép làm phân thân truyền Si Ý; đạo tâm vỡ @c0290. Từ chối phó thác Chu Dật rồi hối hận; tặng Tinh La Bàn cho VL @c0296. Đang đồng hành VL trong hư vô sau tiên giới.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0281","importance":"normal","tieuDe":"Gặp VL — mời vào tiên giới toái phiến","text":"Xuất hiện tại truyền tống trận trung tâm tiên giới (Chu Tước tinh), tiếp cận Vương Lâm với lời mời hợp tác bí ẩn. Trán có dấu búa rìu đặc trưng Cự Ma tộc. (@c0281)"},{"chuong":"@c0284","importance":"normal","tieuDe":"Hòa giải — dẫn đường vào mảnh nhỏ","text":"Chứng kiến VL đấu Hồng Điệp; xuất hư ảnh viễn cổ cự nhân uy hiếp buộc hai bên hòa giải. Ba người lập thỏa thuận xuống Tiên Giới Toái Phiến. (@c0284–@c0285)"},{"bridge":true,"khoang":"@c0286–@c0287","text":"Dẫn đường qua sông băng 30 vạn dặm bằng Ngụy Tinh La Bàn; tiết lộ tổ tiên Cự Ma tộc di cư từ nơi khác tới Chu Tước tinh. (@c0286–@c0287)"},{"chuong":"@c0289","importance":"major","tieuDe":"Bị ép — làm phân thân truyền Si Ý","text":"Bị Chu Dật ép buộc làm phân thân tiếp nhận Si Ý — ý cảnh tình si tích lũy ngàn năm. Chấp nhận vì lo ngại an nguy Cự Ma tộc. (@c0289)"},{"chuong":"@c0290","importance":"major","tieuDe":"Đạo tâm vỡ — rìu Khai Thiên tan","text":"Phân thân Si Ý bộc phát khí thế Hóa Thần kỳ; đối đầu lão đầu phụ thể Hồng Điệp. Rìu Khai Thiên vỡ tan → đạo tâm sụp đổ. (@c0290)"},{"bridge":true,"khoang":"@c0291–@c0293","text":"Tinh La Bàn hư hại nghiêm trọng trong tay; chứng kiến Chu Dật đốt Nguyên Thần ngộ đạo, Nữ thi thức dậy. Từ chối phó thác Chu Dật (lo ngại ảnh hưởng tộc), hối hận dữ dội khi thấy Vấn Đỉnh Chi Tinh + lão đầu Anh Biến kỳ mà mình bỏ lỡ. (@c0291–@c0293)"},{"bridge":true,"khoang":"@c0294–@c0295","text":"Chứng kiến VL đối đầu Tôn Thái bằng mưu trí; nhảy vào Tinh La Bàn điều khiển khi cần. Tiếp tục đồng hành VL trong hư vô sau khi thoát tiên giới. Đánh giá VL rất cao — cơ trí, kiên định, tu vi kinh người; muốn kết giao. (@c0294–@c0295)"},{"chuong":"@c0296","importance":"major","tieuDe":"Tặng Tinh La Bàn cho VL","text":"Tặng Tinh La Bàn (bảo vật tộc) cho VL, xóa ấn ký — sau khi suy tính: VL mạnh có thể lấy cưỡng, hơn nữa VL có Vấn Đỉnh Chi Tinh rất có cơ hội thành Vấn Đỉnh. Hộ pháp khi VL tế luyện sửa La Bàn. (@c0296)"},{"bridge":true,"khoang":"@c0297–@c0299","text":"Cùng VL đuổi theo đàn Kiếm Tiên, cướp túi trữ vật dọc đường (thứ 37+). Chiến trung niên Hóa Thần hậu kỳ (đệ tử Thiên Vận Tử) — biến hình khổng lồ cầm búa nhưng bị huyết tinh sát khí ảnh hưởng tâm thần, nghe lời VL rút lui. Chứng kiến cô gái áo trắng + ba kim long, lộ vẻ khiếp sợ. Bị Thiên Vận Tử bắt đi cùng VL. (@c0297–@c0299)"},{"chuong":"@c0301","importance":"normal","tieuDe":"Chứng kiến đồ sát — thề giữ bí mật, chia tay VL","text":"Chứng kiến Tôn Thái đồ sát hơn trăm tu sĩ. Cảm tạ VL không ra lệnh Tôn Thái giết mình. Phát thệ lấy danh nghĩa Cự Ma tộc không tiết lộ sự tình ngày hôm đó. Chia tay VL trước lốc xoáy, mời VL tới Cự Ma tộc uống rượu. Dùng Vu Hồi đỉnh riêng về Chu Tước tinh, sau đó bế quan. 3 ngày trước khi chương mở đầu, trở về Chu Tước tinh — bị Chu Tước quốc cử người áp bức. Khai với họ: không biết tên thật Tằng Ngưu, tu vi sâu không lường, Hồng Điệp xuất thủ trước, sau 3 lần Tằng Ngưu mới phản kháng. Phát thệ rồi bế quan. (@c0301)"},{"chuong":"@c0342","importance":"major","tieuDe":"Phản lại lão tổ — cứu VL, bị phạt bế quan trăm năm","text":"Tham gia vây VL cùng lão tổ Cự Ma tộc + Lý Nguyên Phong theo lệnh lão tổ. Khi VL sắp bị giết, bí mật phản lại: truyền linh lực cho VL hai lần qua đòn giả, chỉ hướng đông nam là đường sống. Tuyên bố Tinh La Bàn là tặng chứ không phải bị cướp; VL là bằng hữu cứu mạng nhiều lần ở tiên giới. Bị lão tổ khống chế bằng lực đạo, phạt bế quan trăm năm luyện thể. Không hối hận — tự nhủ 'quang minh lỗi lạc'. (@c0342)"},{"chuong":"@c0368","importance":"bridge","text":"Ngồi tại cung điện thứ 3 (Cự Ma Thiên), đọc ngọc giản, mặt tái nhợt. Nhận lệnh từ lão đầu bỉ ổi (sư đệ lão tổ cấm địa Chu Tước), mang mũ cỏ đi gặp Liễu Mi để thử Vô Tình đạo của nàng. Nhìn về Tuyết Vực quốc lộ vẻ buồn bã rồi đi. (@c0368)"},{"chuong":"@c0370","importance":"major","tieuDe":"Phân vân giữa tộc và bằng hữu — hét “dừng tay” giữa đám loạn","text":"Ngồi tại cung điện thứ 3, mặt tái nhợt khi biết VL đã giết Lý Nguyên Phong và sắp tới Cự Ma tộc trả thù lão tổ. Đau khổ phân vân: lão tổ dù sai vẫn là hy vọng cả tộc; Tằng Ngưu lại là bằng hữu — lắc đầu không tìm ra đáp án. Khi VL phát thần niệm vào giữa tộc, thầm than rồi biến mất khỏi cung điện. Cuối chương từ xa hét “Tằng Ngưu dừng tay!” — VL ngẩng đầu nhận ra, sự lạnh lẽo trên mặt hơi giảm. (@c0370)"},{"chuong":"@c0281","importance":"major","text":"Cự Ma tộc (tứ cấp tu chân quốc, Chu Tước tinh), chủ động làm quen Vương Lâm (xưng giả Tằng Ngưu) tại tiên giới toái phiến; đoán VL thuộc gia tộc Tằng thị ở Thiên Hồn Quốc. Rủ VL liên thủ thăm dò nơi bí ẩn có quan tài tiên ngọc cắm ba kiếm tiên, hẹn một tháng sau, đưa ngọc giản truyền tống.","nguonNblm":true},{"chuong":"@c0286","importance":"major","text":"Dẫn VL và Hồng Điệp vượt sông băng vạn năm vào hư vô tới tầng toái phiến thứ nhất. Tiết lộ rủ VL vì thấy VL luyện du hồn, hợp dùng trong hư vô. Triệu Tinh La Bàn (bản ngụy của Cự Ma tộc) làm la bàn định hướng; thừa nhận bản thật tu vi hắn không dùng nổi.","nguonNblm":true},{"chuong":"@c0287","importance":"major","text":"Phân vị trí trên Tinh La Bàn (hắn giữa khống chế, VL phía đông, Hồng Điệp phía tây), cấm tản thần thức bừa trong hư vô. Khi gặp sinh vật Hư, nghe VL bay về bắc nên thoát hiểm; sau đó hoàn toàn tin VL. Tiết lộ tổ tiên Cự Ma tộc di cư tới Chu Tước tinh nên thần thông khác người thường.","nguonNblm":true},{"chuong":"@c0289","importance":"major","text":"Cùng VL xuống tầng ba toái phiến; bí mật cho VL biết Chu Dật là lão quái Anh Biến thích thi thể. Bị Chu Dật ép làm phân thân: Chu Dật phóng cầu vồng bảy sắc đáp xuống Thiên Linh cái, hắn ngừng chống cự khi được hứa cảm ngộ Ý Cảnh. Lộ huyết mạch Cự Ma xa xưa.","nguonNblm":true},{"chuong":"@c0290","importance":"major","text":"Bị Chu Dật điều khiển làm phân thân chiến đấu với Hồng Điệp (do lão đầu Thi Âm tông chiếm thân). Thân phình to ba trượng như người khổng lồ bằng sắt, triệu Khai Thiên Phủ; được Chu Dật truyền Si Ý nên đạt khí thế Trảm Tiên, đạo tâm chính là cái rìu. Cuối cùng rìu Khai Thiên vỡ tan, đạo tâm vỡ, kêu lên thảm thiết.","nguonNblm":true},{"chuong":"@c0293","importance":"normal","text":"Lộ thân phận thiếu tộc trưởng Cự Ma tộc. Khi Chu Dật (đã Vấn Đỉnh) nhờ chăm sóc thi thể thê tử, hắn do dự vì sợ ảnh hưởng tương lai trong tộc nên bị Chu Dật loại; sau đó hối hận tột độ khi thấy VL nhận được Vấn Đỉnh Chi Tinh và lão đầu Thi Âm tông.","nguonNblm":true},{"chuong":"@c0295","importance":"normal","text":"Chứng kiến VL dùng mưu trí và bảo tháp đẩy lui Tôn Thái; đánh giá VL rất cao nên một lòng muốn kết giao. Tinh La Bàn hỏng hoàn toàn trong tay hắn; than về tộc sẽ bị phạt bế quan. VL đề nghị sửa La Bàn cho hắn.","nguonNblm":true},{"chuong":"@c0296","importance":"major","text":"Quyết tặng luôn Tinh La Bàn cho VL, xóa ấn ký giao lại; hộ pháp khi VL tế luyện sửa La Bàn bằng Kim Tử Thạch. Khi đàn Kiếm Tiên (vạn kiếm hợp nhất do Chu Dật làm Kiếm Hồn) lao tới, kinh sợ kêu lên có chuyện lớn.","nguonNblm":true},{"chuong":"@c0371","importance":"major","text":"Hai năm sau tại Cự Ma quốc, ra mặt cản VL (gọi tên cũ Tằng Ngưu), khuyên rời đi. Cuối cùng chọn thân phận thiếu tông chủ chủ trì Thông Thiên đại trận (mười hai cột sáng đen) vây VL. Khi VL phá tan đại trận bằng thân thể tam tinh Cổ Thần, hắn là người chủ trì nên bị cắn trả trọng thương, ngã xuống — chốt nợ ân tình hai chiều với VL.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0297","canhGioi":"Hóa Thần trung kỳ","text":"Tự xưng Hóa Thần trung kỳ khi thách đánh trung niên Hóa Thần hậu kỳ (đệ tử Thiên Vận Tử).","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0281","quanHe":"Đồng hành — kết giao","ghiChu":"Từ hợp tác tiên giới thành kết giao thật sự; tặng Tinh La Bàn @c0296; VL không giết hắn sau tiên giới, hắn thề giữ bí mật @c0301.","tag":"dong-hanh"},{"ten":"Cự Ma tộc","gap":"@c0281","quanHe":"Tiểu tộc trưởng","ghiChu":"Phát thệ nhân danh tộc giữ bí mật @c0301; bế quan sau khi về.","tag":"the-luc"}],"tuiDo":{"phapBao":[{"ten":"Tinh La Bàn (bản ngụy Cự Ma tộc)","loai":"phap-bao","trangThai":"da-tang-VL @c0296","moTa":"Bảo vật duy nhất của Cự Ma tộc, dùng định hướng trong hư vô. Hỏng nặng sau tiên giới; VL sửa lại bằng Kim Tử Thạch + ký ức Cổ Thần — thiếu Toái Tinh Thiết. Tặng VL @c0296.","nguon":"@c0286"},{"ten":"Búa (linh khí Cự Ma tộc)","loai":"linh-khi","trangThai":"suy yeu — ngưng kết lại nhưng uy lực giảm","moTa":"Từng bị Chu Dật chiếm và Hồng Điệp phá nát @c0290; ngưng kết lại từ đồ án mi tâm nhưng mỗi lần ngưng uy lực giảm sút. Dùng chém khí xám trung niên đệ tử Thiên Vận Tử @c0297.","nguon":"@c0297"},{"ten":"Vu Hồi đỉnh (riêng)","loai":"phap-bao","trangThai":"hien-co","moTa":"Vật dùng quay về Chu Tước tinh từ tiên giới; Sất Hổ dùng cái riêng của mình, tách với VL ở lốc xoáy.","nguon":"@c0301"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0281","@c0284","@c0285","@c0286","@c0287","@c0288","@c0289","@c0290","@c0291","@c0292","@c0293","@c0294","@c0295","@c0296","@c0297","@c0298","@c0299","@c0301","@c0342","@c0368","@c0370"],"detail":"Thiếu tộc trưởng (thiếu tông chủ) tộc Cự Ma trên Chu Tước tinh, mang huyết mạch Cự Ma xa xưa. Quen VL trong tiên giới toái phiến và trở thành đồng minh; sở hữu Tinh La Bàn (bản ngụy) rồi tặng lại VL. Sau đối đầu VL trong sự kiện Cự Ma quốc và bị thương khi đại trận bị phá."},{"id":"tu-ma-van","name":"Tư Mã Vân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Quỳ Thủy phái","trangThai":"đệ tử"}],"canhGioiCaoNhat":"Hóa Thần sơ kỳ (@c0281)","trangThai":"sống","vaiTro":"phụ","tinhCach":[{"text":"Thực dụng — chủ động đề nghị trao đổi bản đồ để đôi bên cùng có lợi","chuong":"@c0281"}],"blurb":"Tu sĩ Hóa Thần sơ kỳ của Quỳ Thủy phái tại Chu Tước tinh. Trao đổi bản đồ truyền tống với Vương Lâm để giúp VL định vị mảnh nhỏ phía Tây thứ ba.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0281","importance":"normal","tieuDe":"Trao đổi bản đồ với VL","text":"Tiếp cận Vương Lâm tại truyền tống trận, đề nghị trao đổi bản đồ vị trí truyền tống: cung cấp bản đồ mảnh nhỏ phía Tây thứ ba cho VL; nhận lại bản đồ truyền tống VL nắm giữ. (@c0281)"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0281","@c0282"]},{"id":"thien-bao-thuong-nhan","name":"Thiên Bảo thượng nhân","cn":"","aliases":["Thiên Bảo"],"gioiTinh":"nam","theLuc":[{"ten":"không rõ môn phái","trangThai":"đã tịch"}],"canhGioiCaoNhat":"không rõ (tiên nhân trước đại nạn)","trangThai":"đã mất — chết trước đại nạn tiên giới","vaiTro":"phụ","tinhCach":[{"text":"Chuyên tâm luyện chế pháp bảo; để lại ký lục và kho báu trong động phủ","chuong":"@c0281"}],"blurb":"Tiên nhân thời tiền đại nạn, chuyên luyện chế pháp bảo chiến đấu. Để lại Thiết Phiến vàng (ký lục) chứa bản đồ động phủ + Xạ Thần xa (3 chiếc). Thiết Phiến tiêu hủy sau khi mở khóa bí mật.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0276","importance":"minor","text":"Nhắc gián tiếp qua di hài: Vương Lâm phát hiện hài cốt Thiên Bảo thượng nhân trong Tiên Thú Phủ (huyệt động tiên giới), trên ngực có thiết phiến vàng. Nhân vật đã chết từ trước đại nạn tiên giới, chỉ còn di hài (VL phát hiện @c0276–@c0277)."},{"bridge":true,"khoang":"@c0281–@c0283","text":"Chết trước đại nạn tiên giới; để lại Thiết Phiến vàng chứa ký lục định vị động phủ (VL thu được @c0281). Thiết Phiến tan chảy tại cổng động phủ → mở ảo ảnh dẫn vào gian bí mật. Trong động phủ có 3 Xạ Thần xa + tài liệu luyện khí để lộn xộn. VL thu trọn @c0282–@c0283. (@c0281–@c0283)"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0276","@c0277","@c0281","@c0282","@c0283"]},{"id":"chu-dat","name":"Chu Dật","cn":"","aliases":["người trung niên cầm hồ lô","lão trung niên","người luyến nữ thi","trung niên cầm hồ lô uống rượu","Kiếm Tiêu Chi Hồn"],"gioiTinh":"nam","theLuc":[{"ten":"Ngũ Hành Tông","trangThai":"da-roi"},{"ten":"Vũ Chi Tiên Kiếm (Kiếm Tiêu Chi Hồn)","trangThai":"hien-tai"}],"canhGioiCaoNhat":"Vấn Đỉnh kỳ (đột phá @c0293, tức thời trước khi chết)","trangThai":"nguyen-than-nhap-kiem — Kiếm Tiêu Chi Hồn trong Vũ Chi Tiên Kiếm @c0294","vaiTro":"phụ — ân nhân giao phó","tinhCach":[{"text":"Sở thích kỳ dị: thích thu gom thi thể; không ngại dùng ép buộc để đạt mục đích","chuong":"@c0288"},{"text":"Cẩn thận — bí mật theo dõi từ xa trước khi lộ diện","chuong":"@c0283"},{"text":"Tình si tột cùng — đốt cháy Nguyên Thần để cứu thi thể 'Đình nhi', tuyên bố 'vì Đình nhi mà chết, ta tình nguyện'","chuong":"@c0292"}],"blurb":"Đệ tử tài năng nhất Ngũ Hành Tông; bỏ sư môn vì si tình thi thể tiên nhân 'Đình nhi'. Đạt Vấn Đỉnh kỳ lúc hấp hối rồi giao phó bảo tháp Tiên Ngọc + Vấn Đỉnh Chi Tinh + Tôn Thái cho Vương Lâm. Nguyên Thần được 'Đình nhi' phong Kiếm Tiêu Chi Hồn — nhập Vũ Chi Tiên Kiếm, vạn năm bồi dưỡng thành Tiên Tôn.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0283–@c0287","text":"Bí mật theo dõi VL từ xa (cầm hồ lô đỏ, không lộ diện); di chuyển song song nhóm qua sông băng và hư vô Tiên Giới Toái Phiến. Tiết lộ đã biến Tiên Ngọc Quan Tài thành bảo tháp — dùng để lưu giữ thi thể 'Đình nhi' từ Chu Tước tinh. (@c0283–@c0287)"},{"chuong":"@c0288","importance":"normal","tieuDe":"Lộ diện — đại trưởng lão Thi Âm Tông xuất hiện","text":"Chính thức xuất hiện tại đáy động tầng 2; tiết lộ danh tính tu sĩ Ngũ Hành Tông. Nghe thấy tên liền khiến Hồng Điệp biến sắc — hiềm khích cũ. Cùng lão đầu Thi Âm Tông tạo thế đối kháng với nhóm VL. (@c0288)"},{"text":"Dùng thần thông Ngự Linh (lốc xoáy linh lực) ép Sất Hổ phải làm phân thân tiếp nhận Si Ý — ý cảnh tình si tích lũy suốt ngàn năm của hắn. Si Ý bộc phát lên Sất Hổ → khí thế Hóa Thần kỳ Trảm Tiên. (@c0289–@c0290)","bridge":true,"khoang":"@c0289"},{"chuong":"@c0291","importance":"normal","tieuDe":"Đốt Nguyên Thần — cứu Đình nhi","text":"Bảo tháp chứa Đình nhi bị Tôn Thái cướp; túi trữ vật rách nát. Thiêu đốt Nguyên Thần (hành vi tự sát) → thực lực tức thời đạt Anh Biến hậu kỳ. Phá Đệ Tam hồn Tôn Thái, ép lão ném trả thi thể. Ôm Đình nhi cười thỏa mãn. (@c0291)"},{"chuong":"@c0292","importance":"normal","tieuDe":"Ngộ đạo lúc hấp hối — ánh mắt trong sáng","text":"Ôm thi thể Đình nhi, hôn nhẹ lên trán, nhắm mắt mở ra với ánh mắt 'đen trắng rõ ràng' hết si mê. Tia sét đánh xuống, hóa đạo lưu tinh. Tuyên bố: 'Ý Cảnh là si, đạo tâm là Đình nhi. Sáng sinh chiều tử — thì ra nó có nghĩa là như vậy.' Uy áp kinh thiên: nén cả VL + Sất Hổ xuống đất, sập toàn bộ cung điện. (@c0292)"},{"chuong":"@c0293","importance":"major","tieuDe":"Đột phá Vấn Đỉnh — giao phó cho VL","text":"Dùng hạt châu đỏ hòa vào ngôi sao bốc cháy, đạt Vấn Đỉnh kỳ. Hồi ức: đệ tử tài năng nhất Ngũ Tông, đạt Hóa Thần được tặng Vũ Đỉnh vào Tiên Giới, gặp thi thể nữ tiên, si tình phản sư môn. Sư phụ thất bại xung Vấn Đỉnh mà chết. Giao phó VL: bảo tháp Tiên Ngọc (cần 1000 khối tiên ngọc/1000 năm), Vấn Đỉnh Chi Tinh, và ấn ký khống chế Tôn Thái. (@c0293)"},{"chuong":"@c0294","importance":"normal","tieuDe":"Lâm chung — Nguyên Thần nhập kiếm","text":"Thân thể cháy tàn từ chân lên; nhìn VL nói 'Chăm sóc tốt cho nàng!' rồi nở nụ cười mỉm. Đình nhi tỉnh dậy triệu Vũ Chi Nhất Kiếm, điểm ngực Chu Dật hút Nguyên Thần vào kiếm vàng, phong 'Kiếm Tiêu Chi Hồn' — vạn năm bồi dưỡng liệt nhóm Tiên Tôn. (@c0294)"},{"chuong":"@c0594","importance":"normal","tieuDe":"Linh thể bị phong ấn cứu Vương Lâm","text":"Linh thể màu tím của Chu Dật bị phong ấn mấy trăm năm trong Luyện Tiên Hóa Ma đại trận, toàn thân tím chỉ còn điểm sáng ở mi tâm bị yêu khí Cổ Yêu gặm nuốt; tâm hắn đã chết từ khi Đình nhi rời đi nên cố tình mặc Cổ Yêu xâm nhập. Khi Vương Lâm chui tới, hắn tỉnh dậy bảo đối phương đi đi, rồi búng tay phóng một trong bốn đạo bản mệnh kiếm khí còn lại của kiếm linh trong Vũ chi tiên kiếm, đánh tan thần niệm Lăng Thiên Hậu và hồi phục nguyên thần Vương Lâm. Khi nghe Vương Lâm nói nữ nhân tên thật là Thanh Sương chứ không phải Đình nhi, linh thể hắn chấn động, ánh mắt từ trống rỗng hóa hung dữ."},{"chuong":"@c0595","importance":"normal","tieuDe":"Tâm sống lại, phá phong ấn thoát thân","text":"Sau khi xem ngọc giản và biết Đình nhi chính là Thanh Sương, nhi nữ tiên đế Thanh Lâm, hy vọng cứu được nàng khiến tâm đã chết của Chu Dật sống lại. Sức sống bức toàn bộ tử khí tản ra, thân thể trở nên trong suốt. Hắn dung nhập vào thanh kiếm tiên, dùng bản mệnh kiếm khí đập vỡ ba quả cầu thần niệm, làm tan bốn thành kiếm Nguyên Thần và phá trận pháp phong ấn của Lăng Thiên Hậu, thoát ra khỏi cái khe cùng Vương Lâm sau mấy trăm năm bị phong ấn."},{"chuong":"@c0595","importance":"normal","tieuDe":"Truyền thừa kiếm ý cho Hứa Lập Quốc","text":"Chu Dật giao bảo tháp cho Vương Lâm giữ, nhắc lại Vấn Đỉnh chi tinh năm xưa là thù lao cho việc bảo vệ Đình nhi. Hắn chộp Hứa Lập Quốc, truyền kiếm ý viễn cổ vào mắt biến hắn thành kiếm linh cho Vương Lâm, tự thân truyền thừa khiến linh thể bị thương tổn, đồng thời cài lạc ấn phòng Hứa Lập Quốc phản bội."},{"bridge":true,"khoang":"@c0595–@c0595","text":"Chu Dật chỉ cầu Vương Lâm tìm được phụ thân Đình nhi để nàng thức tỉnh, rồi hít sâu vỗ mạnh lên thân kiếm tiên có Hứa Lập Quốc; một luồng khí kỳ dị tỏa ra, sắc mặt tái nhợt, thân thể hư ảo tới nửa ngày mới bình phục."},{"chuong":"@c0596","importance":"normal","tieuDe":"Ban hai đại lễ cho Vương Lâm","text":"Lấy thân phận kiếm linh và người thừa kế kiếm ý viễn cổ, Chu Dật phá lạc ấn trên một thanh Vũ tiên kiếm trao vĩnh viễn cho Vương Lâm, đồng thời cho Hứa Lập Quốc lĩnh hội truyền thừa kiếm ý viễn cổ. Hắn dẫn Vương Lâm xuống đáy Triều Tịch vực tìm hơi thở một đời kiếm linh để ban lễ vật thứ ba, rồi cứu Vương Lâm khỏi sương tím quái dị bằng cách hóa cầu vồng phá sương tăng tốc."},{"chuong":"@c0603","importance":"normal","tieuDe":"Dung thân tiên kiếm trợ chiến","text":"Thần thức Chu Dật dung trong tiên kiếm của Vương Lâm, truyền âm vào tâm thần cảnh báo đó là kiếm khí bổn mạng cực mạnh của Lăng Thiên Hậu khiến Vương Lâm dừng tay quan sát, đồng thời cung cấp tốc độ cực nhanh để Vương Lâm lao tới đoạt lệnh bài và chạy về cửa ra."},{"chuong":"@c0613","importance":"normal","tieuDe":"Hé lộ bị bắt năm xưa","text":"Qua thần thức Văn thú hé lộ trong cuộc chiến Tham Lang - Chu Dật, Chu Dật bị một tu sĩ cực mạnh từ Hỏa Yêu quận bắt đi; nam tử ấy lộ vẻ phiền muộn, hoài niệm khi thấy Chu Dật, gợi mối liên hệ quá khứ chưa lộ."},{"chuong":"@c0289","importance":"major","text":"Lão quái Anh Biến kỳ từ Chu Tước tinh, có sở thích thích thi thể; mang theo nữ thi tiên nhân 'Đình Nhi' (vảy ngược, ai đụng tới là điên cuồng giết). Đã lấy quan tài Ngọc Thạch ở tầng hai toái phiến; dùng thần thông Ngự Linh tạo lốc xoáy. Đối đầu lão đầu Thi Âm tông, ép Sất Hổ làm phân thân bằng cầu vồng bảy sắc.","nguonNblm":true},{"chuong":"@c0290","importance":"major","text":"Bản tôn ngồi nhắm mắt khoanh chân sau lưng Sất Hổ, hư ảnh điều khiển Sất Hổ chiến đấu. Truyền Si Ý (ý cảnh tích lũy ngàn năm) vào Sất Hổ, tuyên bố 'Ý cảnh của ta là Si'.","nguonNblm":true},{"chuong":"@c0292","importance":"major","text":"Tại tầng bốn (tẩm cung Tiên Vương), ôm thi thể Đình Nhi, dần nhớ lại ký ức và thấy xa lạ với nàng. Đốt cháy Nguyên Thần để ngộ đạo cuối đời: ánh mắt hết si mê trở nên trong sáng, hóa đạo lưu tinh tấn công lão đầu Thi Âm tông; uy áp nén cả VL và Sất Hổ, sập cả cung điện. Cảm ngộ 'sáng sinh chiều tử'.","nguonNblm":true},{"chuong":"@c0293","importance":"major","text":"Đột phá Vấn Đỉnh kỳ. Hồi ức lai lịch: vốn là đệ tử tư chất xuất sắc nhất Ngũ Hành Tông, đạt Hóa Thần được tặng Vũ Đỉnh vào Tiên giới, gặp thi thể nữ tiên rồi si tình phản sư môn. Giao phó VL: bảo tháp tiên ngọc chứa thi thể thê tử (đổi mỗi năm một khối tiên ngọc), Vấn Đỉnh Chi Tinh (tăng 30% xác suất đột phá Vấn Đỉnh) và lão đầu Thi Âm tông làm người hầu.","nguonNblm":true},{"chuong":"@c0294","importance":"major","text":"Thân thể cháy tàn, Nguyên Thần sắp tan; dặn VL 'Chăm sóc tốt cho nàng', mỉm cười tạ sư phụ. Nữ thi Đình Nhi thức dậy triệu Vũ Chi Nhất Kiếm, điểm ngực hắn hút Nguyên Thần vào kiếm, phong làm 'Kiếm Tiêu Chi Hồn'.","nguonNblm":true},{"chuong":"@c0595","importance":"major","text":"Hơn trăm năm sau, là Kiếm linh của Vũ tiên kiếm, bị Lăng Thiên Hậu phong ấn trong khe ở Triều Tịch vực vì tâm đã chết. Khi VL trao ngọc giản hé lộ Đình Nhi chính là Thanh Sương — con gái tiên đế Thanh Lâm, tâm hắn sống lại, phá phong ấn bằng bản mệnh kiếm khí. Truyền kiếm ý viễn cổ cho Hứa Lập Quốc; cầu VL tìm phụ thân Đình Nhi để nàng thức tỉnh.","nguonNblm":true},{"chuong":"@c0596","importance":"major","text":"Trao vĩnh viễn một trong bốn thanh Vũ tiên kiếm cho VL, phá lạc ấn để kiếm linh khác không điều khiển được thanh đó. Dẫn VL xuống đáy Triều Tịch vực tìm lễ vật thứ ba (hơi thở một đời kiếm linh), cứu VL khỏi sương mù tím quái dị bằng kiếm khí.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0288","canhGioi":"Anh Biến trung kỳ","text":"Cảnh giới xác nhận khi lộ diện ở đáy động tầng 2.","importance":"minor"},{"chuong":"@c0291","canhGioi":"Anh Biến hậu kỳ (nhất thời)","text":"Thiêu đốt Nguyên Thần → thực lực tạm thời tiếp cận Anh Biến hậu kỳ.","importance":"minor"},{"chuong":"@c0293","canhGioi":"Vấn Đỉnh kỳ","text":"Đột phá Vấn Đỉnh kỳ ngay trước khi chết nhờ hạt châu đỏ + đốt Nguyên Thần ngộ đạo. Lão đầu Tôn Thái xác nhận.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0293","quanHe":"Người được giao phó","ghiChu":"Giao bảo tháp Tiên Ngọc, Vấn Đỉnh Chi Tinh, ấn ký Tôn Thái; nhờ chăm sóc thi thể Đình nhi.","tag":"giao-pho"},{"ten":"Tôn Thái (Đại trưởng lão Thi Âm Tông)","gap":"@c0291","quanHe":"Kẻ thù / bị khống chế","ghiChu":"Cướp bảo tháp Đình nhi, bị Chu Dật phá Đệ Tam hồn; sau đó bị ép làm nô bộc VL.","tag":"doi-thu"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Tiền bối có ân; được Vương Lâm liều vào cứu, đáp lại bằng cách phóng bản mệnh kiếm khí hồi phục nguyên thần cho hắn","ghiChu":"@c0594"},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Truy đuổi Lăng Thiên Hậu từ tiên giới, làm đối phương bị thương bằng Tiên ấn; rồi bị Lăng Thiên Hậu phong ấn tại Triều Tịch vực","ghiChu":"@c0594"},{"ten":"Thanh Sương","tag":"khac","quanHe":"Nữ nhân hắn si mê, ngỡ tên là Đình nhi; tâm hắn chết khi nàng rời đi. Vương Lâm tiết lộ tên thật của nàng là Thanh Sương","ghiChu":"@c0594"},{"ten":"Thanh Sương","tag":"khac","quanHe":"Người si tình ngàn năm (Đình nhi)","ghiChu":"Chu Dật biết Đình nhi chính là Thanh Sương; nay nàng chỉ còn thi thể, tàn hồn sinh từ si tình của hắn đã biến mất."},{"ten":"Thanh Lâm","tag":"khac","quanHe":"Phụ thân của người mình yêu","ghiChu":"Tiên đế, có thể khiến Đình nhi thức tỉnh; Chu Dật nhờ Vương Lâm đi tìm."},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Kẻ phong ấn","ghiChu":"Đã phong ấn Chu Dật mấy trăm năm trong cái khe; Chu Dật tuyên bố sẽ tính sổ khi gặp lại."},{"ten":"Hứa Lập Quốc","tag":"khac","quanHe":"Người được truyền thừa","ghiChu":"Linh thể ký thân kiếm tiên thứ hai; Chu Dật truyền kiếm ý viễn cổ biến hắn thành kiếm linh cho Vương Lâm, cài lạc ấn cảnh báo."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đồng minh, thần thức dung trong tiên kiếm Vương Lâm","ghiChu":"Cảnh báo và trợ tốc cho Vương Lâm tranh đoạt lệnh bài.","gap":"@c0603"}],"tuiDo":{"phapBao":[{"ten":"Hồ lô đỏ","loai":"phap-bao","trangThai":"hien-co","moTa":"Pháp bảo bản thân thường xuyên cầm theo; chức năng chưa rõ.","nguon":"@c0288"},{"ten":"Bảo tháp Tiên Ngọc (giao VL)","loai":"phap-bao","trangThai":"giao-cho-VL @c0293","moTa":"Tạo từ Tiên Ngọc cung điện Tiên Vương. Chứa thi thể Đình nhi; có ý cảnh Vấn Đỉnh bảo vệ phạm vi trăm dặm; cần 1000 khối tiên ngọc/1000 năm. Giao phó VL @c0293.","nguon":"@c0293"},{"ten":"Vấn Đỉnh Chi Tinh (giao VL)","loai":"phap-bao","trangThai":"giao-cho-VL @c0293","moTa":"Viên ngọc đỏ từ mi tâm Chu Dật. Tăng 30% xác suất đột phá Vấn Đỉnh. Tu sĩ Vấn Đỉnh mất nó → tu vi vĩnh viễn thối lui đến chết. Giao phó VL @c0293.","nguon":"@c0293"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0283","@c0287","@c0288","@c0289","@c0290","@c0291","@c0292","@c0293","@c0294","@c0594","@c0595","@c0596","@c0603","@c0613"],"detail":"Đệ tử Ngũ Hành Tông tư chất xuất chúng, vì si tình thi thể nữ tiên (Đình Nhi, thực là Thanh Sương con gái tiên đế Thanh Lâm) mà phản sư môn, lấy Si làm Ý cảnh, đột phá tới Vấn Đỉnh kỳ. Sau khi đốt Nguyên Thần được nữ thi phong làm Kiếm Hồn của Vũ Chi Tiên Kiếm. Là ân nhân/đồng minh then chốt của VL."},{"id":"ton-thai","name":"Tôn Thái","cn":"","aliases":["Tôn Thái","lão đầu Thi Âm Tông","đại trưởng lão Thi Âm Tông","lão giả tóc trắng"],"gioiTinh":"nam","theLuc":[{"ten":"Thi Âm Tông","trangThai":"đại trưởng lão"},{"ten":"Vương Lâm (nô bộc)","trangThai":"hien-tai"}],"canhGioiCaoNhat":"Anh Biến trung kỳ (@c0294; tự xưng)","trangThai":"song — nô bộc VL @c0293; bị phong ấn; Đệ Tứ Hồn chưa trưởng thành; cứu VL @c0343–0344; bị tống xuất Chu Tước tinh @c0345","vaiTro":"phụ — nô bộc tiềm năng của VL","tinhCach":[{"text":"Lạnh lùng, thực dụng; không giết Hồng Điệp vì cần thân thể nàng làm vũ khí tạm","chuong":"@c0289"},{"text":"Chuyên tâm thu gom thi thể tiên nhân — nhiệm vụ Thi Âm Tông","chuong":"@c0288"},{"text":"Kiêu ngạo — coi làm nô tài là 'mối nhục lớn ngoài cái chết'; lập tức phản chủ sau khi Chu Dật chết","chuong":"@c0294"}],"blurb":"Đại trưởng lão Thi Âm Tông, Anh Biến trung kỳ. Tên thật lộ ra là Tôn Thái. Sở hữu Tam Hồn (thông thường) + Đệ Tứ Hồn ẩn trong thi thể trên quan tài. Bị Chu Dật ép làm nô bộc VL vạn năm; lập tức phản chủ khi Chu Dật chết nhưng bị bảo tháp Si Ý cảnh dọa lui.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0288","importance":"normal","tieuDe":"Xuất hiện đáy động tầng 2","text":"Tóc trắng, Anh Biến kỳ, đại trưởng lão Thi Âm Tông. Xuất hiện cùng Chu Dật tại đáy động tầng 2 Tiên Giới Toái Phiến. Nhiệm vụ: thu thi thể tiên nhân cho Thi Âm Tông. (@c0288)"},{"chuong":"@c0289","importance":"normal","tieuDe":"Phụ thể Hồng Điệp — xuống tầng 3","text":"Dùng thuật phụ thể xâm nhập thân Hồng Điệp; cam kết không giết chỉ mượn thân chiến đấu. (@c0289)"},{"chuong":"@c0290","importance":"normal","tieuDe":"Thoát thân — mất hết pháp lực","text":"Dùng thân Hồng Điệp chiến đấu phân thân Si Ý Sất Hổ. Rìu Khai Thiên vỡ → đạo tâm Sất Hổ tan. Thoát thân khỏi Hồng Điệp, toàn bộ pháp lực tiêu tán. (@c0290)"},{"chuong":"@c0291","importance":"normal","tieuDe":"Tam Hồn lộ diện — cướp bảo tháp Đình nhi","text":"Tiết lộ sở hữu Tam Hồn (Chu Dật chỉ diệt được 1). Dùng Đệ Tam hồn (thanh niên) cướp bảo tháp Đình nhi bằng Hắc quỷ trảo. Nhốt Nguyên Thần Chu Dật bằng dây xích tím. Bị Chu Dật thiêu đốt Nguyên Thần truy kích; Đệ Tam bị phá, buộc ném trả thi thể Đình nhi. Bại trận hoàn toàn. (@c0291)"},{"chuong":"@c0293","importance":"normal","tieuDe":"Bị Chu Dật tặng làm nô bộc VL","text":"Chu Dật (Vấn Đỉnh kỳ) chộp lão, ép chọn: làm nô bộc VL vạn năm hoặc bị luyện thành con rối. Tên thật lộ: Tôn Thái. Chấp nhận khi Chu Dật sắp điểm mi tâm. Ấn ký khống chế chuyển qua Chu Dật sang trán VL. (@c0293)"},{"bridge":true,"khoang":"@c0294–@c0295","text":"Gọi VL 'chủ nhân' rồi lập tức phản chủ sau khi Chu Dật chết — đòi VL giải phong ấn, dụ bằng 2 con rối Hóa Thần hậu kỳ + công pháp + tiên đan. Tiết lộ có Đệ Tứ Hồn trong thi thể trên quan tài. VL dùng bảo tháp (Si Tình Ý Cảnh Vấn Đỉnh) dọa lui — lão bị tổn thương do phong ấn nô bộc khuếch đại uy lực bảo tháp. Bỏ chạy, ẩn theo dõi; phân tích lời VL 'tám phần thật', thừa nhận 'giết không được, bắt không được'. Đệ Tứ Hồn chưa trưởng thành — nếu Nguyên Thần bị diệt tu vi hạ + tuổi thọ sụt. (@c0294–@c0295)"},{"text":"Tìm cách xuyên vào Phong Ma Khôn Càn Trận do lão tổ Cự Ma tộc bố trí để vây VL. Dùng Lôi Chi Ý Cảnh (cảm ngộ ở Thiên Lôi Tinh) xuyên trận, cứu VL ra. Giao chiến lão tổ Cự Ma tộc Anh Biến kỳ — biết mình yếu hơn nên chủ động phòng thủ + cầm chân. Đánh giá lão tổ Cự Ma 'Anh Biến kỳ cưỡng ép, thiếu ổn định'. (@c0343)","bridge":true,"khoang":"@c0343"},{"text":"Ném VL nguyên thần tan nát xuống rừng bên dưới để VL tự thoát trước khi trận chiến khiến không gian bất ổn. Giao chiến lão tổ Cự Ma tộc + Lý Nguyên Phong cùng lúc. Kích hoạt Lôi Chi Ý Cảnh — triệu hắc lôi (Thiên Lôi đen) xuống đánh, Lý Nguyên Phong bị thương phải rút lui về Tuyết Vực. Tiếp tục cầm chân lão tổ Cự Ma, tạo thời gian cho VL trốn thoát hoàn toàn. (@c0344)","bridge":true,"khoang":"@c0344"},{"text":"Sau trận chiến, bị lão tổ Cự Ma tộc dùng thiên phú thần thông (lốc xoáy truyền tống) tống xuất khỏi Chu Tước tinh — bị đưa đến một ngôi sao rất xa. (@c0345)","bridge":true,"khoang":"@c0345"},{"text":"Nhận ra Vương Lâm — quân cờ bậc thấp năm xưa ở Chu Tước tinh — nay khí tức sâu không lường, từng giết tu sĩ Vấn Đỉnh, khiến Tôn Thái chấn động tâm thần, nguyên thần rung chuyển. Tôn Thái nay tu vi tụt xuống Hóa Thần kỳ, làm khách khanh nắm tin tức cho Nhiễm gia ở Thành bảo hợp lâu vì có kiến thức luyện đan luyện khí.","bridge":true,"khoang":"@c0625"},{"text":"Kể chuyện bị truyền tống vào La Thiên tinh vực gần Đông Lâm tinh, làm tạp dịch cho Lữ gia gần trăm năm, lạc ấn được người Lữ gia gỡ nhưng vẫn còn. Tiết lộ Đông Lâm tinh có ba gia tộc Hứa-Lữ-Lưu cực mạnh, cùng cấu trúc Thi Âm Tông và Tứ Thánh tông. Cảnh báo bát phẩm đan dược là âm mưu của Lão tổ Nhiễm gia. Tử khí lộ ra, tuổi thọ chỉ còn hai mươi năm; nhờ Vương Lâm mang tro cốt về Ám Nguyệt tinh quê cũ và tặng túi trữ vật để tạ ơn.","bridge":true,"khoang":"@c0625"},{"chuong":"@c0295","importance":"normal","text":"Định giam giữ VL để tìm cách giải khai phong ấn nô bộc, vung trảo chộp thì bị bảo tháp tự bay ra tỏa Si Tình Ý Cảnh của tu sĩ Vấn Đỉnh kỳ (Chu Dật để lại) — do phong ấn nô bộc trong người nên ý cảnh này khắc chế thực sự, gây thương tổn lớn. Bị VL dùng loạt lời hù dọa liên hoàn (dọa diệt Nguyên Thần, thu Đệ Tứ Hồn) đánh vào nội tâm, khiếp sợ bỏ chạy; quay lại thăm dò, kết luận lời VL 'tám phần là thật', tức giận rời đi.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0291","canhGioi":"Anh Biến kỳ (mất pháp lực)","text":"Sau trận tầng 3, mất hết pháp lực; bị nhốt trong không gian sụp đổ.","importance":"minor"},{"chuong":"@c0293","canhGioi":"Anh Biến trung kỳ","text":"Cảnh giới tự xưng khi Chu Dật Vấn Đỉnh kỳ ép làm nô bộc.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0293","quanHe":"Chủ nhân (phong ấn nô bộc)","ghiChu":"Bị Chu Dật ép làm nô tài VL; lập tức muốn phản chủ nhưng bị phong ấn + bảo tháp khống chế. Cứu VL @c0343–0344.","tag":"chu-nhan"},{"ten":"Chu Dật","gap":"@c0288","quanHe":"Người khống chế / bại trận trước","ghiChu":"Chu Dật ép bằng uy lực Vấn Đỉnh kỳ; ấn ký chuyển sang VL sau khi Chu Dật chết.","tag":"doi-thu"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Cố nhân Chu Tước tinh; nay Vương Lâm đã tu vi Vấn Đỉnh, hứa tiễn Tôn Thái và mang tro cốt về Ám Nguyệt tinh","ghiChu":"Tôn Thái sẵn lòng làm người hầu cũng không oán hận, tặng túi trữ vật chứa tiên ngọc và tâm đắc luyện đan luyện khí."},{"ten":"Lão tổ Nhiễm Gia","tag":"doi-thu","quanHe":"Thu nhận Tôn Thái làm khách khanh Nhiễm gia; Tôn Thái cho rằng việc đưa bát phẩm đan dược cho Vương Lâm là âm mưu của lão","ghiChu":""},{"ten":"Chu Dật","tag":"doi-thu","quanHe":"Kẻ năm xưa từng giao chiến với Tôn Thái; chính là người để lại lạc ấn trên thân Vương Lâm","ghiChu":""}],"tuiDo":{"phapBao":[{"ten":"Dây xích tím","loai":"phap-bao","trangThai":"da-dung","moTa":"Bảo vật Thi Âm Tông chuyên khóa Nguyên Thần; phun khí tím từ miệng hóa thành. Bị Chu Dật thiêu Nguyên Thần phá vỡ.","nguon":"@c0291"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0288","@c0289","@c0290","@c0291","@c0292","@c0293","@c0294","@c0295","@c0296","@c0343","@c0344","@c0345","@c0625"]},{"id":"lang-thien-hau","name":"Lăng Thiên Hậu","cn":"","aliases":["Kiếm Tôn Đại La Kiếm Tông","lão già áo xanh","Kiếm Tôn Lăng Thiên Hầu","Lăng Thiên Hậu","Kiếm Tôn"],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"Kiếm Tôn"}],"canhGioiCaoNhat":"Anh Biến kỳ (xác nhận @c0299); nhân vật số một số hai Thiên Vận tinh","trangThai":"song — bị thương Tiên chỉ @c0299; chạy về Thiên Vận tinh @c0300; bị Chu Dật hóa kiếm ảnh đuổi theo","vaiTro":"phụ — đối thủ tiên giới; nhân vật Thiên Vận tinh","tinhCach":[{"text":"Tham công, kiêu ngạo — dám đối đầu cả tiên nhân để đoạt Vũ Chi Tiên Kiếm; phân tích lợi hại nhanh (quay lại sau khi nhận ra cô gái áo trắng không giết mình)","chuong":"@c0298"},{"text":"Kiên gan không bỏ cuộc — chịu đựng dấu tay đen Tiên chỉ vẫn cướp kiếm tiên hình rắn","chuong":"@c0299"}],"blurb":"Kiếm Tôn Đại La Kiếm Tông, nhân vật số một số hai Thiên Vận tinh, Anh Biến kỳ. Cưỡi Kỳ Lân tiên thú vào tiên giới đoạt Vũ Chi Tiên Kiếm. Bị cô gái áo trắng (Đình nhi) đánh vỡ 2 kiếm ảnh bản mạng; bị Tiên chỉ thương tích nặng. Đoạt được 1 kiếm tiên hình rắn (không hồn); bị Chu Dật tái sinh hóa kiếm ảnh đuổi về Thiên Vận tinh.","tabs":{"diem":[],"kinhLich":[{"text":"Cưỡi Kỳ Lân tiên thú xông vào mảnh nhỏ tiên giới, bốn kiếm ảnh bản mạng lóe lên gây thương hàng loạt tu sĩ (kể cả VL + Sất Hổ). Đối đầu cô gái áo trắng: một điểm của nàng vỡ 2/4 kiếm ảnh bản mạng, Kỳ Lân tiên thú phủ phục run rẩy. Bỏ chạy; phân tích nàng muốn dọa mình đi → quay lại với hơn trăm kiếm ảnh tái sinh. (@c0298)","bridge":true,"khoang":"@c0298"},{"text":"Tấn công bằng kiếm ảnh + điện quang kiếm; nhận dấu tay đen Tiên chỉ trước ngực (nửa người trên vỡ nát, phun tiên huyết) nhưng vẫn cướp kiếm tiên hình rắn (mất kiếm hồn). Cô gái áo trắng cho lão kiếm, lấy lại kiếm hồn. Lão ôm kiếm lùi. (@c0299)","bridge":true,"khoang":"@c0299"},{"text":"Nhân cô gái áo trắng chết, lao về phía hai kiếm tiên bên thi thể. Chu Dật tái sinh hóa kiếm ảnh cực lớn truy kích — lão phun tiên huyết chịu trận, nhận thấy 'tiên chỉ quá mức bá đạo', xé khe không gian chạy về Thiên Vận tinh. Mang Kỳ Lân thú cùng thoát. Tuyên bố 'đã lấy được một tiên kiếm'. Bị Chu Dật đuổi vào khe. (@c0300)","bridge":true,"khoang":"@c0300"},{"text":"Kiếm Tôn Lăng Thiên Hầu, Tông chủ Đại La Kiếm Tông trên Thiên Vận Tinh, xuất hiện cùng sấm sét và vô số kiếm quang: một lão già áo xanh râu trắng gầy gò mang khí tức thiên uy, sau lưng có bốn bóng kiếm hư ảo, dưới chân là xà hình bảo kiếm đầy máu tanh. Hắn dẫn hơn vạn đệ tử áo đen đeo kiếm cổ tới chúc thọ, chào hỏi Tôn trưởng lão và lạnh lùng đồng ý làm đối tượng cho Thiên Vận Tử thi triển Tiên thuật.","bridge":true,"khoang":"@c0467"},{"text":"Kiếm Tôn Lăng Thiên Hầu dẫn hơn vạn đệ tử Đại La Kiếm Tông tới chúc thọ; khi Thiên Vận Tử thi triển Dẫn Tiên thuật cuốn đệ tử đi, lão thúc xà hình phi kiếm lao lên rồi triệu Kỳ Lân thú từ mi tâm phản kích, nhưng cuối cùng nhẫn nhịn gọi kiếm tiên về, chờ ba ngày đệ tử trở về.","bridge":true,"khoang":"@c0468"},{"bridge":true,"khoang":"@c0469","text":"Khi Thiên Vận Tử trao phong hiệu Thiên Vận Thất tử cho Côn Bằng Tử, Kiếm Tôn Lăng Thiên Hầu lộ một tia khinh thường."},{"text":"Là quan khách mừng thọ, Kiếm Tôn Lăng Thiên Hầu lộ vẻ kinh ngạc khi thấy Hồn thú khổng lồ Vương Lâm triệu ra từ Xạ Thần xa.","bridge":true,"khoang":"@c0470"},{"text":"Rời đại thọ sớm bằng kiếm quang; trước khi đi nhắc lại ước hẹn với Thiên Vận Tử rằng ba tháng sau lão phải tuyển người tiến vào Đông Hải Yêu Linh chi môn.","bridge":true,"khoang":"@c0472"},{"text":"Là người chưa bao giờ nể mặt Thiên Vận Tử nhưng vẫn cùng lập nhóm thăm dò Đông Hải; lần thứ ba vào được bên trong rồi ra chỉ còn nửa quân số, sau đó tách với Thiên Vận Tử và giữ kín chuyện đã xảy ra.","bridge":true,"khoang":"@c0486"},{"text":"Kiếm Tôn Lăng Thiên Hậu dò hỏi Tham Lang về hạt châu, hoãn việc đến sau Đông Hải Yêu Linh, đổi lại yêu cầu Tham Lang vào trong bảo vệ mười hai đệ tử của lão hoàn thành nhiệm vụ bí mật. Lão vạch trần tâm cơ Tham Lang đang bị người giữ hạt châu bức bách, hứa sẽ mở cửa Yêu Linh cho hắn vào.","bridge":true,"khoang":"@c0488"},{"bridge":true,"khoang":"@c0489","text":"Là tu sĩ kỳ cựu từng chứng kiến Đông Hải Yêu Linh, khi thủy triều khởi động hắn ánh mắt lộ tia sáng kỳ dị, lẩm bẩm “Bắt đầu rồi!”."},{"bridge":true,"khoang":"@c0490","text":"Hai mắt tuôn tinh quang khó tưởng tượng, nhìn chằm chằm vào con sóng hồng quang cuối; phải biến sắc trước sự quỷ dị của thủy triều bảo vật cửa Đông Hải Yêu Linh."},{"text":"Chỉ tay về Đông Hải, bốn kiếm ảnh hư ảo sau lưng hóa bốn đạo cầu vồng đánh vào khối nước khổng lồ lơ lửng, mở ra lối vào hỗn độn xanh đỏ dẫn tới một thế giới khác, hô gọi chúng tu sĩ tiến vào rồi thu kiếm đóng cửa.","bridge":true,"khoang":"@c0491"},{"text":"Tiết lộ Đại La kiếm tông đặt ở Đại La tinh do hắn đưa từ tinh không tới; phá cương phong vào đông bộ bế quan, quyết trong hai trăm năm lấy chín chín yêu linh quy nhất luyện Tiên kiếm thành yêu kiếm để chắc tay thu lệnh bài Đông Hải.","bridge":true,"khoang":"@c0491"},{"text":"Tại Đại La Kiếm Tông trên Đại La Tinh, Lăng Thiên Hậu đang luyện Nguyên Nguyên Tạo Hóa Đan thì biến sắc, dịch chuyển ra ngoài bầu trời Đại La Tinh nhìn hồng quang thiên kiếp, nghi ngờ ‘tên Tham Lang kia’ gặp tai biến khi thấy nó rơi xuống Đông Hải Yêu Linh.","bridge":true,"khoang":"@c0552"},{"text":"Phân thân Lăng Thiên Hậu mặc đạo bào ngồi ở Đại La kiếm tông, nhận ra phong ấn Kiếm linh bị người phát hiện nhưng tin rằng chỉ cần tâm Chu Dật còn ý muốn chết thì không thoát khỏi phong ấn. Thần niệm của hắn ở Triều Tịch vực liên tục công kích Vương Lâm, hóa kiếm khí đánh vỡ ký hiệu bảy nét, song một đạo bản mệnh kiếm khí của Chu Dật cuối cùng đánh tan thần niệm này. Hé lộ hắn bị Chu Dật truy đuổi từ tiên giới, từng bị Tiên ấn làm bị thương nên dẫn về mảnh đất Yêu Linh giao dịch với Cổ Yêu để phong ấn đối phương.","bridge":true,"khoang":"@c0594"},{"text":"Đại năng thanh sam; gi��n vì bổn mạng thần đăng của Kiếm Tiếu Thập Nhị Tử bị dập tắt chín ngọn, muốn tìm Tham Lang hỏi. Mở cánh cửa Yêu Linh ngoài Đông Hải, chấn động chín quận, bảy luồng sáng cầu vồng phóng ra, quát gọi Tham Lang.","bridge":true,"khoang":"@c0613"},{"text":"Lăng Thiên Hậu (Kiếm Tôn) đòi Vương Tạ giao Tham Lang để hỏi việc giết đệ tử Đại La kiếm tông và đoạt lệnh bài. Khi nhận ra Vương Lâm dùng Thất Tinh kiếm trận thì phẫn nộ. Hắn cực kỳ cố kỵ Vân Tiên đạo lữ nên không dám ra tay.","bridge":true,"khoang":"@c0614"},{"chuong":"@c0614","importance":"normal","tieuDe":"Đòi lệnh bài và thẩm vấn Tham Lang","text":"Dùng thần thức quét tới cực bắc, va chạm thần thức Vân Tiên đạo lữ. Đòi Vương Tạ giao Tham Lang ra, thẩm vấn về việc giết đệ tử Đại La kiếm tông và lệnh bài. Phẫn nộ khi thấy Vương Lâm sử dụng Thất Tinh kiếm trận. Cố kỵ Vân Tiên đạo lữ nên không dám ra tay."},{"chuong":"@c0298","importance":"normal","text":"Kiếm Tôn Đại La Kiếm Tông cưỡi Kỳ Lân tiên thú (lửa xanh) vào mảnh vỡ tiên giới tranh kiếm tiên với cô gái áo trắng (tự xưng 'bản quân', nghi tiên quân); bốn kiếm ảnh bản mạng của lão khiến tu sĩ tu vi thấp nhìn vào là bị thương. Bị cô gái áo trắng chỉ một cái điểm phá vỡ 2/4 kiếm ảnh, phải bỏ chạy; lão tự nhận ngay cả Thiên Vận Tử cũng không làm nổi điều đó.","nguonNblm":true},{"chuong":"@c0467","importance":"normal","text":"Gặp lại tại đại thọ vạn năm của Thiên Vận Tử: Lăng Thiên Hầu xuất hiện cùng hơn vạn đệ tử Đại La Kiếm Tông và biển phi kiếm, mang theo xà hình bảo kiếm (Vũ chi đệ nhị kiếm cướp ở tiên giới năm xưa). Bị Thiên Vận Tử chọn làm đối tượng thi triển trung phẩm Dẫn Tiên thuật để hạ nhục, lạnh lùng đồng ý.","nguonNblm":true},{"chuong":"@c0491","importance":"normal","text":"Lăng Thiên Hậu dùng bốn kiếm ảnh mở cánh cửa bí cảnh Đông Hải Yêu Linh cho các tông phái tiến vào (thí luyện 500 năm), ban kiếm khí bảo mệnh cho Kiếm Tiếu Thập Nhị Tử (Tham Lang trà trộn). Tiết lộ Đại La Kiếm Tông không ở Thiên Vận tinh mà ở Đại La tinh. Về bế quan 200 năm để luyện hóa Tiên kiếm thành yêu kiếm nhằm thu lệnh bài.","nguonNblm":true}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"đồng cấp/đối thủ thực lực","ghiChu":"Tu vi và thực lực môn phái của hai bên gần tương đương; Lăng Thiên Hầu đồng ý làm đối tượng cho Thiên Vận Tử thi triển Dẫn Tiên thuật."},{"ten":"Tôn trưởng lão","tag":"dong-minh","quanHe":"quen biết","ghiChu":"Chào hỏi Tôn trưởng lão khi tới dự đại thọ."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"ân oán tiềm ẩn","ghiChu":"Vương Lâm nhận ra thanh xà hình bảo kiếm của Lăng Thiên Hầu là Vũ chi đệ nhị kiếm bị cướp ở Tiên giới năm xưa."},{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"Chủ nhân đại thọ làm nhục mình","ghiChu":"Thiên Vận Tử cuốn đi đệ tử Đại La Kiếm Tông của lão; Lăng Thiên Hầu trách móc nhưng biết thân phận đối phương nên đành chờ ba ngày."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Đệ tử Tử hệ trong đám đông","ghiChu":"Kỳ Lân thú của Lăng Thiên Hầu cộng hưởng tiếng gầm với Tôn Hồn Phiên trong người Vương Lâm."},{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Đại lão có ước hẹn","ghiChu":"Ước hẹn Đông Hải Yêu Linh chi môn."},{"ten":"Thiên Vận Tử","tag":"ban-be","quanHe":"Bạn cũ cùng thăm dò Đông Hải","ghiChu":"Sau lần thứ ba thì tách ra."},{"ten":"Tham Lang","tag":"dong-minh","quanHe":"Cố nhân tới cầu nhờ","ghiChu":"Tham Lang chạy đường xa đến Thiên Vận Tinh tìm lão; Lăng Thiên Hậu ra điều kiện đổi lấy việc giúp hắn."},{"ten":"Tham Lang","tag":"khac","quanHe":"Người Lăng Thiên Hậu nghi ngờ","ghiChu":"Khi thấy thiên kiếp rơi Đông Hải Yêu Linh, Lăng Thiên Hậu lập tức nghi ‘tên Tham Lang kia’ gặp tai biến."},{"ten":"Chu Dật","tag":"doi-thu","quanHe":"Bị Chu Dật (kiếm linh tiên kiếm) truy đuổi từ tiên giới, bị Tiên ấn làm bị thương; bèn dẫn về Yêu Linh phong ấn, mượn yêu khí Cổ Yêu luyện hóa","ghiChu":"@c0594"},{"ten":"Cổ Yêu","tag":"dong-minh","quanHe":"Giao dịch với tàn hồn Cổ Yêu Thủy Yêu quận: phong ấn Chu Dật tại Triều Tịch vực để Cổ Yêu nuốt điểm sáng mi tâm, đoạt thân thể","ghiChu":"@c0594"},{"ten":"Vương Tạ","tag":"doi-thu","quanHe":"Lăng Thiên Hậu cố kỵ Vương Tạ, đòi hắn giao Tham Lang","ghiChu":"@c0614"},{"ten":"Hồ Quyên","tag":"doi-thu","quanHe":"Hồ Quyên bênh Kiếm Tôn quan tâm đệ tử là có tình có lý","ghiChu":"@c0614"},{"ten":"Thần Long","tag":"su-mon","quanHe":"Thần Long là đệ tử, quỳ gọi sư tôn","ghiChu":"@c0614"},{"ten":"Tham Lang","tag":"khac","quanHe":"Đối tượng truy tìm","ghiChu":"Vào Yêu Linh để tìm hỏi Tham Lang về việc bổn mạng thần đăng Kiếm Tiếu Thập Nhị Tử bị dập chín ngọn."},{"ten":"Kiếm Tiếu Thập Nhị Tử","tag":"dong-minh","quanHe":"Liên hệ bổn mạng thần đăng","ghiChu":"Bổn mạng thần đăng của Kiếm Tiếu Thập Nhị Tử bị dập chín ngọn khiến Lăng Thiên Hậu nổi giận."},{"ten":"Vương Tạ","tag":"khac","quanHe":"Lão quái Vân Tiên đạo lữ, cố kỵ lẫn nhau","ghiChu":"Vương Tạ trêu chọc tính nóng nảy của Kiếm Tôn; Lăng Thiên Hậu cực kỳ cố kỵ hai vợ chồng này."},{"ten":"Hồ Quyên","tag":"khac","quanHe":"Đạo lữ của Vương Tạ, cố kỵ lẫn nhau","ghiChu":"Hồ Quyên bênh vực Kiếm Tôn quan tâm đệ tử là có tình có lý."}],"tuiDo":{"phapBao":[{"ten":"Bốn kiếm ảnh bản mạng","loai":"ban-menh-phap-bao","trangThai":"2 bi pha @c0298; 2 con lai tai sinh thanh tren tram","moTa":"Bản mạng pháp bảo 4 kiếm ảnh hư ảo: biến hóa nghìn vạn, sinh sôi không ngớt. Tu vi thấp hơn chỉ liếc mắt bị thương. 2 bị cô gái áo trắng điểm vỡ; 2 còn lại tái sinh thành hơn trăm.","nguon":"@c0298"},{"ten":"Kiếm tiên hình rắn (không hồn)","loai":"phap-bao","trangThai":"hien-co — mat kiem hon","moTa":"Kiếm tiên uốn lượn hình con rắn; kiếm hồn đã bị cô gái áo trắng rút ra trước. Lăng Thiên Hậu đoạt được thân kiếm.","nguon":"@c0299"}],"congPhap":[],"danDuoc":[],"linhThu":[{"ten":"Kỳ Lân tiên thú","loai":"linh-thu","trangThai":"hien-co","moTa":"Linh thú hộ sơn Đại La Kiếm Tông, toàn thân lửa xanh, mũi phun khí trắng hủy diệt; phủ phục khi cô gái áo trắng điểm ngón tay (truyền thừa ký ức tổ tiên bị mất sau tiên giới đại hạo kiếp). Mang Lăng Thiên Hậu thoát @c0300.","nguon":"@c0298"}],"khac":[]}},"nguon":["@c0294","@c0296","@c0297","@c0298","@c0299","@c0300","@c0467","@c0468","@c0469","@c0470","@c0472","@c0486","@c0488","@c0489","@c0490","@c0491","@c0552","@c0594","@c0614","@c0613"]},{"id":"thien-mac-tu","name":"Thiên Mặc Tử","cn":"","aliases":["trung niên văn sĩ","văn sĩ trung tâm tiên giới"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Mặc Tông / Thiên Mặc tinh","trangThai":"chưởng môn"}],"canhGioiCaoNhat":"Cực cao — tốc độ vượt Tinh La Bàn VL gấp mấy lần; dị thú hư vô đều né tránh @c0296","trangThai":"song — về Thiên Mặc tinh @c0299; Đại La Kiếm Tông tuyên chiến","vaiTro":"phụ — thế lực độc lập, đoạt 1 kiếm tiên","tinhCach":[{"text":"Thực dụng và bình thản — chỉ lấy 1 kiếm tiên, không tham; đón nhận chiến thách Đại La Kiếm Tông một cách bình thản","chuong":"@c0299"}],"blurb":"Nhân vật bí ẩn cực mạnh, tự xưng Thiên Mặc Tử. Xuất hiện trong tiên giới theo dõi Vũ Chi Tiên Kiếm; tốc độ vượt Lăng Thiên Hậu nhiều bước. Nhân lúc Thiên Vận Tử + Lăng Thiên Hậu tranh giành, đoạt 1 kiếm tiên cổ kính (mất kiếm hồn), về Thiên Mặc tinh. Đại La Kiếm Tông tuyên chiến diệt sát Thiên Mặc tinh.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0294–@c0298","text":"Ẩn náu trong đám người theo dõi đàn Kiếm Tiên; tốc độ đi trong hư vô cực nhanh (dị thú đều né). Nhận ra Vũ Chi Tiên Kiếm qua tiếng ngân; đuổi theo kiếm quang. (@c0294–@c0298)"},{"chuong":"@c0299","importance":"major","tieuDe":"Đoạt kiếm tiên cổ kính — về Thiên Mặc tinh","text":"Nhân Thiên Vận Tử + Lăng Thiên Hậu giao tranh, tốc độ nhanh hơn cả Lăng Thiên Hậu, đoạt kiếm tiên cổ kính (mất kiếm hồn) trước một bước. Tuyên bố: 'Bốn thanh kiếm tiên ta không tham, chỉ lấy một thanh.' Chui vào hắc động về Thiên Mặc tinh. Đáp lại lời tuyên chiến Lăng Thiên Hậu: 'Một trận quyết chiến giữa ngươi và ta không thể tránh khỏi.' (@c0299)"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[{"ten":"Kiếm tiên kiểu dáng cổ kính (không hồn)","loai":"phap-bao","trangThai":"hien-co — mat kiem hon","moTa":"Kiếm tiên cổ kính từ kim long thứ nhất; kiếm hồn đã bị cô gái áo trắng rút ra. Thiên Mặc Tử đoạt thân kiếm về Thiên Mặc tinh.","nguon":"@c0299"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0294","@c0296","@c0297","@c0299"]},{"id":"de-tu-thien-van-tu","name":"Đệ tử Thiên Vận Tử","cn":"","aliases":["trung niên nam tử huyết tinh"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"de-tu"}],"canhGioiCaoNhat":"Hóa Thần hậu kỳ (@c0297)","trangThai":"song — đã về cùng Thiên Vận Tử @c0299","vaiTro":"phụ — đệ tử Thiên Vận Tử trong tiên giới","tinhCach":[{"text":"Kiêu ngạo — gọi VL + Sất Hổ là 'tiểu bối', tự tin sư tôn vượt mọi đối thủ","chuong":"@c0297"}],"blurb":"Đệ tử Hóa Thần hậu kỳ của Thiên Vận Tử; sở hữu sát chi ý cảnh + huyết tinh sát khí. Được phái vào tiên giới ngăn Đại La Kiếm Tông đoạt Vũ Chi Kiếm Tiên. Gặp VL + Sất Hổ xin đi nhờ Tinh La Bàn; bị từ chối, giao chiến. Thực chất là phân thân Thiên Vận Tử.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0297","importance":"normal","tieuDe":"Gặp VL — xin đi nhờ La Bàn","text":"Giẫm đĩa tròn đuổi kiếm tiên, liếc thấy Tinh La Bàn xin đi nhờ. Sất Hổ nhận ra Hóa Thần hậu kỳ, chọn đánh. Phóng khí xám sát ý, Sất Hổ biến hình cầm búa chém vỡ. Xuất huyết tinh sát khí (tinh thạch hình thoi) → Sất Hổ suýt loạn tâm thần; bị VL kéo Sất Hổ rút lui trên La Bàn. (@c0297)"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[{"ten":"Huyết tinh sát khí (tinh thạch hình thoi)","loai":"phap-bao","trangThai":"hien-co","moTa":"Tinh thể ngưng tụ từ sát khí cực nồng đậm; gây rối loạn tâm thần + thương tổn nguyên thần nếu tiếp xúc mà không tu luyện sát chi ý cảnh.","nguon":"@c0297"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0297","@c0299"]},{"id":"phung-ngoc-son","name":"Phùng Ngọc Sơn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Sơn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ cụ thể (tu sĩ Chu Tước Sơn)","trangThai":"song — hoàn thành nhiệm vụ đưa VL, bay về Chu Tước Sơn @c0335","vaiTro":"Sứ giả Chu Tước Sơn","tinhCach":[{"text":"Cung kính và chuyên nghiệp — đứng ngoài thung lũng chờ 10 ngày để trao chiến thiếp; hoàn thành nhiệm vụ rồi bay về.","chuong":"@c0334"}],"blurb":"Sứ giả Chu Tước Sơn phụng lệnh trao chiến thiếp Hồng Điệp đến VL (Tằng Ngưu), rồi đưa VL qua truyền tống trận đến Chu Tước quốc. Trước đó (@c0315) đã đến đợt đầu mang chiếp khiêu chiến lần đầu.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0315","importance":"normal","tieuDe":"Mời Tằng Ngưu đấu Hồng Điệp","text":"Sứ giả áo trắng thêu bốn rồng vàng đến từ Chu Tước quốc. Đưa thiếp khiêu chiến của Hồng Điệp tới Tằng Ngưu (Vương Lâm). VL hẹn 10 năm sau sẽ nhận đấu. (@c0314–@c0315)"},{"chuong":"@c0334","importance":"normal","tieuDe":"Trao chiến thiếp — dẫn VL đến Chu Tước quốc","text":"Phụng mệnh Chu Tước Sơn đứng ngoài sơn cốc 10 ngày, trao chiến thiếp ước định 10 năm Hồng Điệp–Tằng Ngưu. Cùng VL bước vào truyền tống trận Chu Tước quốc. (@c0334)"},{"bridge":true,"khoang":"@c0335","text":"Đến Chu Tước quốc, gặp Bạch Danh Tuyết tại tế đàn. Hoàn thành nhiệm vụ, tự bay về Chu Tước Sơn phục mệnh. (@c0335)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0315","quanHe":"Người được giao nhiệm vụ tiếp xúc","ghiChu":"Mang chiến thiếp 2 lần; dẫn VL đến Chu Tước quốc @c0334.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0314","@c0315","@c0334","@c0335"]},{"id":"tap-mac","name":"Tạp Mạc","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Lục diệp (tương đương Hóa Thần trung-hậu kỳ)","trangThai":"song","vaiTro":"Thuật Chú Sư lục diệp Tiên Di tộc","tinhCach":"Bình hòa, giao tiếp được — tiếp xúc Vương Lâm một cách hòa bình, sẵn sàng trao đổi thông tin.","blurb":"Thuật Chú Sư lục diệp của Tiên Di tộc (Dã Nhân). Giao tiếp hòa bình với Vương Lâm lần đầu trong Tiên Di Chi Địa, tiết lộ VL có Phù Hồn thuộc về Mặc Mặc và hành tinh tên thật là Phù Văn tinh.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0320","importance":"major","tieuDe":"Tiết lộ Phù Hồn và Phù Văn tinh","text":"Gặp Vương Lâm trong Tiên Di Chi Địa. Giao tiếp hòa bình (không thù địch). Tiết lộ VL có Phù Hồn thuộc về Mặc Mặc; cho biết hành tinh này tên thật là Phù Văn tinh (bị Chu Tước quốc đổi tên). (@c0320)"}],"tuViMoc":[{"chuong":"@c0320","canhGioi":"Lục diệp (Thuật Chú Sư)","text":"Cấp bậc lục diệp xác nhận khi gặp VL — tương đương Hóa Thần trung-hậu kỳ."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0320","quanHe":"Người giao tiếp hòa bình","ghiChu":"Tiết lộ VL có Phù Hồn và bí mật Phù Văn tinh. @c0320.","tag":"khac"}],"tuiDo":{}},"nguon":["@c0320"]},{"id":"ho-lao-tien-di","name":"Hồ lão","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Khí Các (Ma Nghịch thành)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần trung kỳ","trangThai":"mat-tich","vaiTro":"Chủ Luyện Khí Các Tu Ma hải, người dẫn đường vào Tiên Di Chi Địa","tinhCach":[{"text":"Thực dụng, coi mạng người như công cụ — hy sinh Hứa La và Vận Manh toàn bộ tuổi thọ để lấy Luân Hồi Quả không do dự.","chuong":"@c0323"},{"text":"Biết nhìn người, biết sợ — nhận ra VL cực kỳ nguy hiểm; nghĩ 'nổi danh dưới Vô Hư sĩ chắc có nguyên nhân'.","chuong":"@c0321"}],"blurb":"Hóa Thần trung kỳ, chủ Luyện Khí Các Tu Ma hải. Dẫn nhóm gồm Hứa La, Vận Manh, Khâu Tứ Bình và Vương Lâm vào Tiên Di Chi Địa tìm Luân Hồi Quả. Tàn nhẫn hy sinh hai người để đạt mục đích; mất tích sau khi bị thất diệp Thuật Chú Sư bắt trên đường thoát.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0309","importance":"normal","tieuDe":"VL tái ngộ tại đấu giá Luyện Khí Các","text":"VL nhận ra Hồ lão (Hóa Thần kỳ) tại đấu giá Luyện Khí Các Ma Nghịch thành — người từng nhận ra 'cực cảnh trong truyền thuyết' trong cơ thể VL từ khi VL còn Kết Đan. (@c0309)"},{"bridge":true,"khoang":"@c0316–@c0320","text":"Chủ mưu kế hoạch thâm nhập Tiên Di Chi Địa tìm Luân Hồi Quả; dẫn nhóm qua tầng 1 và 2, giết hai ngũ diệp Thuật Chú Sư, bị lục diệp thôi hóa tại cổng tầng 3 — được VL cứu. (@c0316–@c0321)"},{"chuong":"@c0323","importance":"major","tieuDe":"Hy sinh Hứa La + Vận Manh — lấy 2 quả Luân Hồi","text":"Hy sinh toàn bộ tuổi thọ còn lại của Hứa La và Vận Manh để đẩy nhanh quá trình thôi hóa Luân Hồi Thụ. Hai người phun máu ngã xuống; 3 quả Luân Hồi ngưng thực, Hồ lão lấy 2 quả. Mất Thao Thú (Huyền Vũ) khi bị Dã Nhân lục diệp bắt. (@c0323)"},{"chuong":"@c0325","importance":"normal","tieuDe":"Bị lão già lưng gù bắt — mất tích","text":"Sau khi thoát tầng 3, bị trọng thương, dùng thuật bảo toàn sinh mệnh tiêu hao Nguyên Thần chạy trốn. Bị lão già lưng gù (thất diệp, Anh Biến kỳ) bắt được nửa đường. Từ đó mất tích. (@c0325)"}],"tuViMoc":[{"chuong":"@c0309","canhGioi":"Hóa Thần trung kỳ","text":"Tu vi xác nhận khi tái ngộ VL tại Luyện Khí Các."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0309","quanHe":"Đồng minh tạm thời — Tiên Di Chi Địa","ghiChu":"Dẫn VL vào Tiên Di tìm Luân Hồi Quả; VL cứu Hồ lão khi bị thôi hóa; sau đó thoát ra một mình.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0309","@c0316","@c0321","@c0322","@c0323","@c0325"]},{"id":"hua-la-tien-di","name":"Hứa La (nhóm Tiên Di)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Nhóm Hồ lão","trangThai":"da-roi"}],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","vaiTro":"Nhân tố thôi hóa Luân Hồi Thụ","tinhCach":[],"blurb":"Thành viên nhóm Hồ lão, một trong hai nhân tố cần thiết để thôi hóa Luân Hồi Thụ (tuổi thọ 100 năm, hy sinh 1 giáp = 12 năm mỗi lần). Bị Hồ lão hy sinh toàn bộ tuổi thọ trong trận chiến tầng 3 để đẩy nhanh thôi hóa. Thi thể bị Tiên Di tộc lấy đi.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0319–@c0321","text":"Vào Tiên Di Chi Địa cùng nhóm; bị thương ở tầng 2 (áo giáp bạc tổn hại, mặt có ba vết cào). Đến tầng 3 bắt đầu thôi hóa Luân Hồi Thụ — già lão dần vì mất tuổi thọ. (@c0321)"},{"chuong":"@c0323","importance":"normal","tieuDe":"Bị hy sinh — chết","text":"Hồ lão dùng pháp quyết hy sinh toàn bộ tuổi thọ còn lại của Hứa La. Hứa La kêu thảm, phun máu, ngã xuống. Thi thể bị Tiên Di tộc lấy đi sau đó. (@c0323)"}],"tuViMoc":[],"nhanMach":[{"ten":"Hồ lão","gap":"@c0316","quanHe":"Người dẫn đường — kẻ hy sinh mình","ghiChu":"Hồ lão hy sinh toàn bộ tuổi thọ Hứa La để lấy Luân Hồi Quả.","tag":"khac"}],"tuiDo":{}},"nguon":["@c0319","@c0321","@c0323","@c0325"]},{"id":"van-manh","name":"Vận Mạnh","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Nhóm Hồ lão","trangThai":"da-roi"}],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","vaiTro":"Nhân tố thôi hóa Luân Hồi Thụ","tinhCach":[],"blurb":"Thiếu nữ thiên kiều bá mị trong nhóm Hồ lão. Cùng Hứa La là hai nhân tố không thể thiếu để thôi hóa Luân Hồi Quả — mỗi người hy sinh 1 giáp tuổi thọ. Bị Hồ lão hy sinh toàn bộ tuổi thọ. Thi thể bị Tiên Di tộc lấy đi.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0319–@c0321","text":"Vào Tiên Di Chi Địa cùng nhóm; VL ôm eo bay vào tầng 3. Bắt đầu thôi hóa Luân Hồi Thụ cùng Hứa La, mất dần vẻ trẻ trung — già lão theo tuổi thọ tiêu hao. (@c0321)"},{"chuong":"@c0323","importance":"normal","tieuDe":"Bị hy sinh — chết","text":"Hồ lão hy sinh nốt tuổi thọ Vận Manh — nàng phun máu, ánh mắt đau xót nhìn Hồ lão rồi nhắm mắt. Thi thể bị Tiên Di tộc lấy đi. (@c0323)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0321","quanHe":"Người ôm bay vào tầng 3","ghiChu":"VL ôm Vận Manh vào tầng 3; nàng ửng hồng mặt khi bị ôm.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0319","@c0321","@c0323","@c0325"]},{"id":"xi-moc","name":"Xỉ Mộc","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di Tộc","trangThai":"da-roi"}],"canhGioiCaoNhat":"Lục diệp Chiến Thú Sĩ (tương đương Hóa Thần hậu kỳ)","trangThai":"mat — bị Xạ Thần Xa (Hồn Thú xuyên qua + nuốt tàn hồn) giết @c0324","vaiTro":"Lục diệp Chiến Thú Sĩ Tiên Di tộc","tinhCach":[{"text":"Kiêu ngạo, muốn chiến — tự giới thiệu tên tuổi khi đuổi theo VL, đòi đánh một trận.","chuong":"@c0324"}],"blurb":"Lục diệp Chiến Thú Sĩ Tiên Di tộc — loại chiến binh ký hiệu dung nhập sâu vào da thịt thay vì lơ lửng ngoài da như Thuật Chú Sư. Xương xám có ký hiệu tự phục hồi vết nứt sau mỗi đòn tiên kiếm. Đuổi theo VL đòi chiến, bị Xạ Thần Xa (Hồn Thú) xuyên qua cơ thể và nuốt tàn hồn — hóa tro bụi.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0324","importance":"major","tieuDe":"Đuổi theo VL — bị Xạ Thần Xa giết","text":"Đuổi theo VL sau khi VL bỏ chạy khỏi tầng 3, tự giới thiệu 'Xỉ Mộc! Lục diệp Chiến Thú Sĩ!' đòi giao chiến. Bị VL chém 10 kiếm tiên — xương nứt tự phục hồi nhờ ký hiệu. VL kích hoạt Xạ Thần Xa: Hồn Thú vọt tới xuyên qua cơ thể, cắn chặt tàn hồn, Xỉ Mộc nứt từ mi tâm hóa tro bụi. (@c0324)"}],"tuViMoc":[{"chuong":"@c0324","canhGioi":"Lục diệp Chiến Thú Sĩ","text":"Tự giới thiệu cấp bậc khi giao chiến với VL."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0324","quanHe":"Kẻ địch — bị VL giết","ghiChu":"VL dùng Xạ Thần Xa tiêu diệt Xỉ Mộc.","tag":"thu-dich"}],"tuiDo":{}},"nguon":["@c0323","@c0324"]},{"id":"lao-gia-lung-gu-tien-di","name":"Lão già lưng gù (thất diệp)","cn":"","aliases":["lão già lưng gù","lão già lưng còng","lão già gù","Thất Diệp Thuật Chú Sư"],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di Tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Thất diệp Thuật Chú Sư (tương đương Anh Biến kỳ)","trangThai":"bi-nhot — bị VL nhốt trong hư vô khe nứt không gian @c0328; liên hệ tộc linh chờ giải cứu","vaiTro":"Thất diệp Thuật Chú Sư — thủ lĩnh bảo vệ tầng sâu Tiên Di Chi Địa","tinhCach":[{"text":"Lạnh lùng và thực dụng — muốn biến VL thành phù khôi vì 'đệ tử môn phái lớn, nhiều pháp bảo'. Không giết ngay mà muốn luyện thành công cụ.","chuong":"@c0325"}],"blurb":"Thất diệp Thuật Chú Sư Tiên Di tộc, tương đương Anh Biến kỳ — mạnh nhất Tiên Di Chi Địa. 4/5 cơ thể phủ ký hiệu, đeo vòng xương thú chứa ký hiệu nhập môn lục quang. Chặn cổng tầng 1 bịt kín, hạ ký hiệu thực vật thôi hóa VL thành phù khôi. Bị VL nhốt cùng trong hư vô sau 8 tháng truy kích — hóa thành cây khổng lồ chờ tộc linh giải cứu.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0325","importance":"major","tieuDe":"Xuất hiện — chặn cổng tầng 1, thôi hóa VL","text":"Xuất hiện tại cổng tầng 1, dùng ký hiệu vàng khổng lồ khóa kín. Biết VL đã giết Mặc Mặc, Địch Nha, Cổ, Xỉ Mộc qua Phù Oán Chi Linh. Tấn công VL: búng ngón tay phá kiếm mang tiên kiếm, chỉ ra Thiên Kiếp Cấm Phiên không hiệu lực trong Tiên Di (thế giới khác). Muốn biến VL thành phù khôi. (@c0325)"},{"bridge":true,"khoang":"@c0326–@c0328","text":"Đuổi theo VL trong khe nứt không gian — bị Xạ Thần Xa đánh văng trăm trượng + tiên kiếm chém 3 nhát vào ngực. Phản kích bằng ký hiệu thực vật lục quang (từ vòng xương thú vỡ ra), hóa sao sáu cánh — đẩy lui Hồn Thú, khiến ký hiệu thực vật xâm nhập nguyên thần VL. Sau 8 tháng truy kích, ký hiệu lực cạn — hóa thành cây khổng lồ dùng tộc linh liên lạc bên ngoài. Bị VL chém ký hiệu lối ra, nhốt trong hư vô. (@c0326–@c0328)"}],"tuViMoc":[{"chuong":"@c0325","canhGioi":"Thất diệp Thuật Chú Sư (Anh Biến kỳ)","text":"Xác nhận là thất diệp — mạnh nhất Tiên Di Chi Địa, tương đương Anh Biến kỳ tu sĩ bên ngoài."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0325","quanHe":"Kẻ địch — đang bị nhốt bởi VL","ghiChu":"Bị VL nhốt trong hư vô sau 8 tháng truy kích.","tag":"thu-dich"}],"tuiDo":{}},"nguon":["@c0325","@c0326","@c0327","@c0328"]},{"id":"lao-gia-ao-xanh-tien-di","name":"Lão già áo xanh (hộ vệ Tử Tâm)","cn":"","aliases":["Công Tôn","lão già hộ vệ Chu Ngạn Hoành","lão già áo choàng vải xanh","lão già áo xanh (phù khôi ngũ diệp)","lão già thanh sam"],"gioiTinh":"nam","theLuc":[{"ten":"Không rõ (hộ vệ nữ tử áo lụa trắng)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần sơ kỳ","trangThai":"bi-nhot — bị VL bỏ lại trong hư vô @c0330","vaiTro":"Hộ vệ nữ tử áo lụa trắng (Tử Tâm)","tinhCach":[{"text":"Có khí tiết — muốn chết để giải thoát khỏi thân phù khôi, nhưng Tiểu thư không cho; tự nhận thân phận thay vì che giấu khi bị ép.","chuong":"@c0329"}],"blurb":"Hộ vệ Hóa Thần sơ kỳ của nữ tử áo lụa trắng. Vào Tiên Di Chi Địa cùng Tử Tâm (và nhóm 7 người ban đầu, ra chỉ còn 2). Bị Tiên Di tộc luyện thành phù khôi ngũ diệp trong khi ở trong đó. Bản Tôn đánh bại không khó — phát hiện bị thôi hóa. Bị VL bỏ lại trong hư vô sau khi làm mồi nhử tìm VL.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0329","importance":"normal","tieuDe":"Ra khỏi Tiên Di — bị Bản Tôn phát hiện thành phù khôi","text":"Cùng Tử Tâm thoát khỏi Tiên Di Chi Địa (trong 7 người ban đầu, chỉ còn 2). Gặp Bản Tôn — bị đánh bại: pháp bảo hình núi + phi kiếm + pháp đao đều bị đấm vỡ. Bị phát hiện đã thành phù khôi ngũ diệp (thực vật 5 lá ở mi tâm, khí đen vờn quanh). Bản Tôn bắn máu đánh dấu mi tâm, ném vào hố sâu Tiên Di tìm VL. (@c0329)"},{"chuong":"@c0330","importance":"normal","tieuDe":"Bị VL bỏ lại trong hư vô","text":"VL tìm thấy hai người trong hư vô, lấy 2 giọt máu (dấu ấn Bản Tôn) từ mi tâm, Bản Tôn mở lối ra. VL bước ra còn 2 người bị để lại trong hư vô. (@c0330)"}],"tuViMoc":[{"chuong":"@c0329","canhGioi":"Hóa Thần sơ kỳ (+ thân phù khôi ngũ diệp)","text":"Ý cảnh Hóa Thần sơ kỳ bị sát khí Cổ Thần Bản Tôn đánh sụp; đồng thời xác nhận là phù khôi ngũ diệp."}],"nhanMach":[{"ten":"Nữ tử áo lụa trắng (Tử Tâm)","gap":"@c0329","quanHe":"Hộ vệ / Tiểu thư","ghiChu":"Tiểu thư không cho lão tự sát để giải thoát khỏi thân phù khôi.","tag":"phu-thuoc"}],"tuiDo":{}},"nguon":["@c0329","@c0330"]},{"id":"nu-tu-lua-trang-tu-tam","name":"Nữ tử áo lụa trắng (Tử Tâm)","cn":"","aliases":["Tử Tâm","cô gái mặc lụa trắng","nữ tử áo lụa trắng (Tiên Di)","Tử Tâm đạo hữu","Tử"],"gioiTinh":"nu","theLuc":[{"ten":"Không rõ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"bi-nhot — bị VL bỏ lại trong hư vô @c0330","vaiTro":"Nhân vật bí ẩn — vào Tiên Di Chi Địa với nhóm riêng","tinhCach":[{"text":"Có nghĩa khí — không chịu để hộ vệ tự sát để giải thoát khỏi thân phù khôi, chọn cùng nhau vào hư vô.","chuong":"@c0329"}],"blurb":"Nữ tử vóc dáng đẹp mặc lụa trắng, gọi hộ vệ là 'Tiểu thư'. Vào Tiên Di Chi Địa với nhóm riêng 7 người, ra chỉ còn 2. Gặp Bản Tôn — nói dối về xuất thân rồi thú thật. Bị VL bỏ lại trong hư vô sau khi dùng làm mồi nhử tìm đường ra.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0329","importance":"normal","tieuDe":"Ra khỏi Tiên Di — gặp Bản Tôn","text":"Cùng lão già áo xanh thoát Tiên Di (7 người vào, 2 người ra). Bị Bản Tôn chặn đường — pháp đao bị đấm vỡ. Ban đầu nói dối xuất thân, bị Bản Tôn dọa mới thú thật từ Tiên Di Chi Địa ra. Bản Tôn bắn máu đánh dấu mi tâm, ném vào hố sâu tìm VL. (@c0329)"},{"chuong":"@c0330","importance":"normal","tieuDe":"Bị VL bỏ lại trong hư vô","text":"VL tìm thấy trong hư vô, lấy dấu ấn máu, Bản Tôn mở lối thoát. VL bước ra còn nữ tử bị để lại cùng lão già. (@c0330)"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già áo xanh","gap":"@c0329","quanHe":"Hộ vệ","ghiChu":"Lão già hộ vệ; bị thôi hóa thành phù khôi trong Tiên Di.","tag":"phu-thuoc"}],"tuiDo":{}},"nguon":["@c0329","@c0330"]},{"id":"lao-dao-si-van-thien-tong","name":"Lão đạo sĩ (phái nhỏ phụ thuộc Vân Thiên Tông)","cn":"","aliases":["lão đạo sĩ tìm linh căn"],"gioiTinh":"nam","theLuc":[{"ten":"Môn phái nhỏ phụ thuộc Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Trúc Cơ kỳ (đang cố đột phá trung kỳ)","trangThai":"song","vaiTro":"Đệ tử môn phái nhỏ — chuyên tìm linh căn","tinhCach":[{"text":"Kiêu căng và tham lam — coi Chu Như như khối thượng phẩm linh thạch, cưỡng đoạt khỏi cha mẹ không chần chừ.","chuong":"@c0330"}],"blurb":"Đệ tử Trúc Cơ kỳ của môn phái nhỏ phụ thuộc Vân Thiên Tông. Cứ 6 năm xuống núi một lần tìm thiếu niên có linh căn — đã tìm 3 đợt trước, lần này phát hiện Chu Như (Lý Mộ Uyển chuyển sinh) có tư chất tuyệt hảo. Cưỡng đoạt Chu Như bất chấp cha mẹ.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0330","importance":"normal","tieuDe":"Phát hiện Chu Như — cưỡng đoạt đem đi tu tiên","text":"Đến Chu gia thôn trong đợt tìm linh căn 6 năm/lần (đã 3 đợt trước). Điểm trán Chu Như (3 tuổi), kinh ngạc: 'Trời sinh có linh lực, bách mạch đều thông, tử quang thấu thể'. Cưỡng đoạt bé gái bất chấp cha mẹ đau lòng — chính chưởng môn sẽ thưởng thượng phẩm linh thạch cho tư chất tốt. (@c0330)"}],"tuViMoc":[{"chuong":"@c0330","canhGioi":"Trúc Cơ kỳ (đang trùng kích trung kỳ)","text":"Tự nói 'có nó (thưởng thượng phẩm linh thạch) ta trùng kích Trúc Cơ trung kỳ' — xác nhận hiện đang Trúc Cơ sơ/trung kỳ."}],"nhanMach":[{"ten":"Chu Như","gap":"@c0330","quanHe":"Đệ tử đoạt được","ghiChu":"Phát hiện tư chất Chu Như tuyệt hảo và cưỡng đoạt đem về môn phái.","tag":"khac"}],"tuiDo":{}},"nguon":["@c0330"]},{"id":"chu-nhu","name":"Chu Như","cn":"","aliases":["Tiểu Như nhi"],"gioiTinh":"nu","theLuc":[{"ten":"Vương Lâm (cháu nuôi)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (thân xác); Nguyên Anh Lý Mộ Uyển đã được tách ra @c0381","trangThai":"song — ký ức bị Vương Lâm xóa @c0382; đang trong Tiên Ngọc Bảo Tháp @c0383","vaiTro":"Lý Mộ Uyển chuyển sinh — con nuôi tinh thần của VL","tinhCach":[{"text":"Dã tính và bướng bỉnh — 10 tuổi đã đi khắp thâm sơn, quấy rối lão hổ dã thú, dám cưỡi hổ hắc văn.","chuong":"@c0334"},{"text":"Tình cảm thâm hậu với VL — gọi 'thúc thúc', mê man ánh mắt khi nhìn VL (tàn dư tình cảm LMU); khóc khi VL rời đi.","chuong":"@c0331"}],"blurb":"Lý Mộ Uyển chuyển sinh trong thân xác Chu Như — cô bé thôn quê có tư chất tu tiên tuyệt hảo. Nguyên Anh LMU không ổn định, sẽ hồi phục trí nhớ năm 19 tuổi. Được VL nuôi dưỡng dưới Tiên Ngọc Bảo Tháp từ 3 đến 10 tuổi. Gọi VL là 'thúc thúc', gọi nữ thi trong tháp là 'thần tiên tỷ tỷ'.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0314","importance":"major","tieuDe":"Chuyển sinh tại Hạnh Hoa Thôn","text":"Nguyên anh Lý Mộ Uyển (do Vương Lâm dùng tranh sinh tử luân hồi dẫn đường) đầu thai vào bào thai sơn thôn tại Hạnh Hoa Thôn, thành bé gái Chu Như. Thân thể yếu ớt. (@c0314)"},{"chuong":"@c0318","importance":"normal","tieuDe":"Được Vương Lâm thăm","text":"Vương Lâm đến Hạnh Hoa Thôn thăm Chu Như. Bé gái không nhớ ký ức kiếp trước nhưng cảm nhận tình cảm vẫn còn. (@c0318)"},{"chuong":"@c0330","importance":"normal","tieuDe":"3 tuổi — bị lão đạo sĩ cưỡng đoạt đem đi tu tiên","text":"3 tuổi, tư chất tuyệt hảo (bách mạch đều thông, tử quang thấu thể) được lão đạo sĩ phái nhỏ phụ thuộc Vân Thiên Tông phát hiện. Lão cưỡng đoạt đem đi bất chấp cha mẹ đau lòng. Lần đầu tiên mở miệng nói 'Cha! Mẹ!' khi bị ép rời khỏi gia đình. (@c0330)"},{"chuong":"@c0331","importance":"normal","tieuDe":"Được VL cứu — về sống dưới Bảo Tháp","text":"VL (đã thủ hộ 1 năm) xuất hiện tống bay lão đạo sĩ bằng 1 vung tay áo. Cô bé nhìn VL với ánh mắt mê man, gọi 'Thúc… Thúc…'. VL đưa về Tiên Ngọc Bảo Tháp — 2 năm sống bình dị: VL nấu cơm, cô bé bám sát. Nhận 1 chuông Linh Đang từ VL. 4 tuổi trộm chạy lên tháp thấy nữ thi, gọi 'thần tiên tỷ tỷ'. (@c0331)"},{"bridge":true,"khoang":"@c0334","text":"10 tuổi: dã tính lớn, cưỡi lão hổ hắc văn (đặt tên Tiểu Bạch) khắp thâm sơn. Khóc khi VL rời đi, hôn lên trán hắn hứa 'Tiểu Như nhi nhớ người'. Ở lại dưới sự chiếu cố của Thiết Nham và Lôi Oa. (@c0334)"},{"chuong":"@c0353","importance":"minor","tieuDe":"Chơi đùa trong sơn cốc — nhớ thúc thúc","text":"Mặc váy thêu hoa mẫu đơn, đầu tết hai bím tóc — đã lớn hơn. Cưỡi Tiểu Bạch chơi đùa trong sơn cốc ngoài vùng tiên di Sở quốc. Bắt Tiểu Bạch học kêu như mèo, phạt cầm đũa ăn cơm. Thở dài nhớ thúc thúc. (@c0353)"},{"chuong":"@c0567","importance":"normal","tieuDe":"Bái biệt pho tượng, lên núi Chu Tước","text":"Cô gái khoảng hai mươi tuổi mặc áo trắng cưỡi hổ Tiểu Bạch chạy lên Vân Thiên Tông, gọi pho tượng Vương Lâm là thúc thúc, khoe vừa Kết Đan và nhắc lời hứa của Thiết Nham gia gia. Giữa đường nàng gặp Chu Vũ Thái — Chu Tước Tử — được khuyên đi núi Chu Tước tu luyện sẽ nhanh hơn. Thân phận nàng ở Chu Tước tinh cực đặc thù, gần như công chúa nhỏ; ai từng quen Vương Lâm đều đối tốt, ngay cả Tiên Di Tộc cũng xem Chu gia là ngoại lệ. Nàng cưỡi Tiểu Bạch rời đi."},{"chuong":"@c0378","importance":"normal","text":"Sống cùng VL và Tiểu Bạch trên một tiểu tinh cầu cạnh Chu Tước tinh. Được VL bắt cho con cọp tím (đặt tên Tiểu Tử, sức ngang Trúc Cơ hậu kỳ) làm thú cưỡi. Tới mười lăm tuổi, dần hiểu ngày Nguyên Anh Lý Mộ Uyển thức tỉnh là ngày mình phải biến mất nên buông xuôi hy sinh; chải tóc cho VL bằng lược gỗ Thiết Nham tặng, cầu xin hắn một lần thật sự nhìn nàng chứ không phải nhìn Uyển nhi, nhưng bị né tránh.","nguonNblm":true},{"chuong":"@c0379","importance":"normal","text":"Hiểu ra mấy tháng qua Tiểu Bạch lặn lội tìm quả Toái Anh để làm suy yếu Nguyên Anh Lý Mộ Uyển trong người nàng, giúp nàng thoát chết; nhưng nàng than nhẹ, để quả rơi xuống khe núi, xin VL tha cho Tiểu Bạch. Lớn tiếng hứa với bóng lưng xa lạ của thúc thúc rằng sẽ cho hắn và Uyển nhi tỷ tỷ đoàn tụ — chấp nhận tự nguyện hy sinh.","nguonNblm":true},{"chuong":"@c0380","importance":"major","text":"Tháng cuối cùng trên Nguyệt tinh, đã mười chín tuổi, ngủ sâu suốt tháng không tỉnh; Nguyên Anh Lý Mộ Uyển bắt đầu cắn nuốt hồn phách nàng. Trong giấc ngủ vẫn thì thào 'Thúc thúc, con sợ...'. Khi sứ giả thiên đạo luân hồi buông xuống vươn cánh tay chộp lấy nàng, VL bị luân hồi chi lực trói chặt bất lực — số phận nàng treo trên sợi tóc.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0567","canhGioi":"Kết Đan","text":"Chu Như khoe đã Kết Đan thành công, đặt mục tiêu tu luyện tới Nguyên Anh để nhận vật Vương Lâm để lại.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0331","quanHe":"Thúc thúc — người nuôi dưỡng","ghiChu":"Gọi VL là 'thúc thúc'; ánh mắt mê man (tàn dư tình cảm LMU). VL nấu cơm, kể chuyện, bảo vệ 7 năm.","tag":"an-nhan","uuTien":100},{"ten":"Thiết Nham","gap":"@c0334","quanHe":"Người bảo vệ","ghiChu":"Có hắn đi cùng, Chu Như mới có thể chơi đùa không sợ hãi.","tag":"an-nhan"},{"ten":"Tiểu Bạch","tag":"dong-hanh","quanHe":"Hổ Tiểu Bạch làm vật cưỡi của Chu Như, cân nhắc theo nàng rời Chu Tước tinh.","ghiChu":"@c0567"},{"ten":"Chu Vũ Thái","tag":"ho-hang","quanHe":"Chu Tước Tử Chu Vũ Thái khuyên nàng đi núi Chu Tước tu luyện cho nhanh.","ghiChu":"@c0567"}],"tuiDo":{"phapBao":[{"ten":"Chuông Linh Đang","loai":"phap-bao","trangThai":"hien-co","moTa":"1 trong 3 chuông thượng cổ — cảm ứng với người giữ chuông kia dù ở đâu. VL tặng để Chu Như gọi cứu khi nguy hiểm.","nguon":"@c0331"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0314","@c0318","@c0330","@c0331","@c0334","@c0353","@c0567"]},{"id":"tu-do-nam","name":"Tư Đồ Nam","cn":"","aliases":["Bóng người hắc khí","#tu-do-nam-canh-tay","cánh tay cụt (tia thần thức)"],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Tinh (cao thủ lịch sử)","trangThai":"da-roi"}],"canhGioiCaoNhat":"Tia thần thức từ thân xác cũ bị luyện hoá — âm hàn Hoàng Tuyền Thăng Khiếu Quyết cực mạnh; Nguyên Anh thật vẫn trong Thiên Nghịch không gian của VL","trangThai":"phan-than — Nguyên Anh thật trong Thiên Nghịch không gian (khôi phục dần); tia thần thức từ cánh tay cụt bị bảo tháp Chu Dật đẩy lui @c0333","vaiTro":"Sư phụ thật sự của VL — tồn tại phân mảnh","tinhCach":[],"blurb":"Nguyên Anh hết sức Chu Tước tinh — thân thể bị phá nát, Nguyên Anh ẩn vào Nghịch Thiên Châu. Thân xác cũ bị luyện hoá sinh ra tia thần thức từ cánh tay cụt, âm hàn Hoàng Tuyền Thăng Khiếu Quyết cực mạnh (hơn VL vô số lần). Bị thần niệm Chu Dật trong bảo tháp đẩy lui. Nguyên Anh thật trong Thiên Nghịch không gian của VL, khôi phục dần dần.","tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0332–@c0333","text":"Tia thần thức từ cánh tay cụt (trong Đồng Chung Liêu Phàm) tự xưng Tư Đồ Nam, dùng âm hàn Hoàng Tuyền Thăng Khiếu Quyết tấn công VL. Nhận ra Hoàng Tuyền Băng Viêm của VL — sư phụ của lão phu lưu lại Hoàng Tuyền đạo cũng không luyện ra được. Bị thần niệm Chu Dật (Vấn Đỉnh) từ Bảo Tháp đẩy lui, mang Liêu Phàm biến mất. (@c0332–@c0333)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0046","quanHe":"Đệ tử","ghiChu":"Nguyên Anh thật còn trong Thiên Nghịch không gian VL; tia thần thức cánh tay cụt nhận ra Băng Viêm tinh thuần của VL.","tag":"su-mon","uuTien":100}],"tuiDo":{}},"nguon":["@c0332","@c0333"]},{"id":"lieu-pham","name":"Liêu Phàm","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tuyết Vực Quốc","trangThai":"xuat-than"},{"ten":"Băng Tuyết Thần Điện","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần trung kỳ","trangThai":"song — bị cánh tay cụt Tư Đồ Nam bắt đi @c0333","vaiTro":"Tay sai Tông chủ Băng Tuyết Thần Điện — phái đi dò xét Tằng Ngưu","tinhCach":[{"text":"Lạnh lùng và thực dụng — âm mưu ẩn: không thực sự vì Vũ bảo mà đến dò xét; biết trước VL lợi hại vẫn tiếp cận.","chuong":"@c0332"}],"blurb":"Hóa Thần trung kỳ, áo dài xanh nước biển, da trong suốt như băng. Tông chủ Băng Tuyết Thần Điện phái đi dò xét Tằng Ngưu bằng pháp bảo Đồng Chung (ẩn cánh tay cụt Tư Đồ Nam bên trong). Chiến đấu VL: băng đao, hư ảnh lão già, Đồng Chung hóa quỷ trảo — bị tiên kiếm thương, Đồng Chung vỡ lộ cánh tay cụt. Bị chính cánh tay cụt nắm mang đi.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0331","importance":"normal","tieuDe":"Đến đòi Vũ phiến Dư bảo — thực chất dò xét","text":"Đến thung lũng Tằng Ngưu đòi Vũ phiến Dư bảo. Thực chất là vâng mệnh tông chủ Băng Tuyết Thần Điện đến dò xét thực lực VL bằng pháp bảo Đồng Chung. (@c0331–@c0332)"},{"chuong":"@c0332","importance":"normal","tieuDe":"Đại chiến VL — Đồng Chung vỡ, bị cánh tay cụt bắt đi","text":"Dùng băng đao, hư ảnh lão già (huyễn khí), Đồng Chung (12 tháng Chu Tước tinh) hóa quỷ trảo. Bị tiên kiếm VL thương, Đồng Chung nứt. Vẻ như đã đạt mục đích khi Đồng Chung vỡ lộ cánh tay cụt. Bị chính cánh tay cụt tự xưng Tư Đồ Nam nắm mang đi. (@c0332–@c0333)"}],"tuViMoc":[{"chuong":"@c0332","canhGioi":"Hóa Thần trung kỳ","text":"Tu vi xác nhận khi VL quan sát — ngang bằng VL.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0331","quanHe":"Đối thủ dò xét","ghiChu":"VL nhận xét Liêu Phàm là địch thủ hiếm gặp — pháp bảo nhiều vô kể.","tag":"doi-thu"}],"tuiDo":{}},"nguon":["@c0331","@c0332","@c0333"]},{"id":"tong-chu-bang-tuyet-than-dien","name":"Lý Nguyên Phong","cn":"","aliases":["Tông Chủ Băng Tuyết Thần Điện","người đàn ông trung niên Tuyết Vực"],"gioiTinh":"nam","theLuc":[{"ten":"Tuyết Vực Quốc","trangThai":"xuat-than"},{"ten":"Băng Tuyết Thần Điện","trangThai":"lanh-dao"}],"canhGioiCaoNhat":"Anh Biến sơ kỳ (cưỡng ép thăng cấp — Tôn Thái nhận xét @c0343; đạt nhờ ân đức Hồng Điệp)","trangThai":"song — bỏ chạy khi bị Tôn Thái phóng Thiên Lôi truy kích @c0344","vaiTro":"Tông chủ Băng Tuyết Thần Điện — kẻ thù tiềm ẩn của VL","tinhCach":[{"text":"Trầm tĩnh và toan tính kỹ lưỡng — điều tra kỹ pháp bảo VL, lên kế hoạch hai Anh Biến kỳ + đại trận + Cự Ma Tộc trước khi ra tay.","chuong":"@c0333"},{"text":"Đặt cảm xúc cá nhân sau đại cục — biết nợ ân Hồng Điệp nhưng không để thuộc hạ chi phối quyết định.","chuong":"@c0333"}],"blurb":"Tông chủ Băng Tuyết Thần Điện tại Tuyết Vực quốc, tu vi Anh Biến sơ kỳ (đạt nhờ Hồng Điệp — Tôn Thái nhận xét là cưỡng ép). Lên kế hoạch tinh vi giết VL: liên thủ lão tổ Cự Ma tộc, bày Phong Ma Càn Khôn trận phong tỏa không gian, dùng ý cảnh trà hương đại thành đánh bại Sinh Tử Luân Hồi Ý Cảnh của VL. Bỏ chạy khi bị Tôn Thái phóng Thiên Lôi truy kích.","tabs":{"diem":[{"text":"Ý cảnh Trà Hương đại thành — đánh bại Sinh Tử Luân Hồi Ý Cảnh của VL (Hóa Thần trung kỳ), khiến nguyên thần bị thương, mặt nổi dấu ấn lá trà tiêu hao sức sống.","chuong":"@c0343"}],"kinhLich":[{"chuong":"@c0333","importance":"normal","tieuDe":"Tiết lộ kế hoạch giết VL","text":"Pha trà Thiên khuyết vũ ti, nghe thuộc hạ báo cáo trận đánh Liêu Phàm–VL. Phân tích đầy đủ pháp bảo VL. Kế hoạch: đợi sau trận VL–Hồng Điệp, bố trí đại trận ngăn xé không gian, mời Cự Ma Tộc, hai Anh Biến kỳ cùng giết. (@c0333)"},{"chuong":"@c0341","importance":"major","tieuDe":"Kích hoạt trận đồ — bao vây VL cực bắc","text":"Phối hợp với ngoại sự trưởng lão Thiên Ngọc Tông dịch chuyển VL tới cực bắc đại lục Chu Tước. Phong tỏa không gian hoàn toàn — không thể thuấn di, xé không gian hay dùng Tinh La Bàn. Tự xưng thay Hồng Điệp lấy tính mạng VL. (@c0341)"},{"chuong":"@c0342","importance":"normal","tieuDe":"Đòi Cấm Phiên — cùng lão tổ Cự Ma tộc vây VL","text":"Đồng thời với lão tổ Cự Ma tộc vây VL; dùng gió xoáy + linh khí hình cánh tay. Tay trần bắt kiếm quang (hơi chấn tay). Muốn chiếm Cấm Phiên (tiểu kỳ dẫn Tiên Kiếp). Khi Sất Hổ phản lại lão tổ, tiếp tục chuẩn bị đánh tiếp. (@c0342)"},{"chuong":"@c0343","importance":"major","tieuDe":"Ý cảnh Trà Hương phá nguyên thần VL","text":"Truy kích bắt kịp VL đang tháo chạy. Tung Ý cảnh Trà Hương đại thành: dấu ấn lá trà xuất hiện trên mặt VL, mỗi lần lóe sáng thân thể yếu + nguyên thần tiêu tan. VL ngã bất tỉnh. Bị Tôn Thái quát cút (khinh Anh Biến sơ kỳ cưỡng ép). (@c0343)"},{"chuong":"@c0344","importance":"normal","tieuDe":"Lén tấn công VL bất lực — bỏ chạy trước Tôn Thái","text":"Lặng lẽ thuấn di tới định giết VL khi hắn bất lực trong rừng. Bị Tôn Thái phóng Thiên Lôi truy kích, bỏ chạy điên cuồng biến mất. Phong ấn ý cảnh Trà Hương kết hợp phong ấn Tôn Thái ghim chặt tu vi VL. (@c0344)"},{"chuong":"@c0351","importance":"minor","tieuDe":"Đang hồi phục tại Tuyết Vực quốc","text":"Hồi phục trong Băng Tuyết Thần Điện sau khi bị tiên lôi Tôn Thái truy kích thương nặng. Tu vi Anh Biến sơ kỳ cưỡng ép — cả đời không đột phá nữa; thần thức chỉ Hóa Thần hậu kỳ đại viên mãn. Thắc mắc vì sao lão tổ Cự Ma tộc muốn thi thể VL. Hồng Điệp tuyên bố bế quan trăm năm muốn đạt Anh Biến kỳ. (@c0351)"}],"tuViMoc":[{"chuong":"@c0333","canhGioi":"Anh Biến kỳ","text":"Tu vi xác nhận — đạt Anh Biến nhờ ân đức Hồng Điệp.","importance":"major"},{"chuong":"@c0343","canhGioi":"Anh Biến sơ kỳ (cưỡng ép)","text":"Tôn Thái nhận xét Anh Biến sơ kỳ cưỡng ép thăng cấp — khinh thị, quát cút.","importance":"minor"}],"nhanMach":[{"ten":"Hồng Điệp","gap":"@c0333","quanHe":"Ân nhân — hy vọng Tuyết Vực","ghiChu":"Nhờ Hồng Điệp mà đạt Anh Biến; tự xưng báo thù cho Hồng Điệp.","tag":"dong-minh"},{"ten":"Vương Lâm","gap":"@c0333","quanHe":"Kẻ thù — mục tiêu giết","ghiChu":"Bày trận tinh vi; ý cảnh đã làm VL mất tu vi; tiên kiếm VL gián tiếp vào tay lão tổ Cự Ma tộc.","tag":"thu-dich"},{"ten":"Lão tổ Cự Ma tộc","gap":"@c0342","quanHe":"Đồng minh tạm thời","ghiChu":"Nhờ lão tổ bày Phong Ma Càn Khôn trận; lão tổ muốn Thiên Nghịch Châu — hai bên lợi dụng nhau.","tag":"dong-minh"}],"tuiDo":{}},"nguon":["@c0333","@c0341","@c0342","@c0343","@c0344","@c0351"]},{"id":"bach-danh-tuyet","name":"Bạch Danh Tuyết","cn":"","aliases":["Bạch Tuyết"],"gioiTinh":"nu","theLuc":[{"ten":"Nhân Đạo Tiên","trangThai":"de-tu"}],"canhGioiCaoNhat":"Không rõ cụ thể (đệ tử Nhân Đạo tiên, tam sư tỷ)","trangThai":"song — tại Chu Tước quốc @c0335","vaiTro":"Đệ tử Nhân Đạo tiên — tiếp đón VL","tinhCach":[{"text":"Nhiệt tình nhưng có ý đồ riêng — cố ý chọn đường bay qua Thiên Ngọc tông để VL thấy Hồng Điệp trước trận chiến.","chuong":"@c0335"}],"blurb":"Tam sư tỷ Nhân Đạo tiên — nhan sắc tuyệt mĩ, mặc váy tím thêu hoa bách hợp đen, cưỡi tiên hạc trắng. Phụng lệnh sư phụ đến tế đàn đón Tằng Ngưu (VL). Gọi Hồng Điệp là 'Hồng Điệp muội muội'. VL nghi nàng cố ý bay qua Thiên Ngọc tông.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0335","importance":"normal","tieuDe":"Đón tiếp VL — bay qua Thiên Ngọc tông","text":"Đón VL tại tế đàn, giới thiệu Chu Tước quốc (3 tông phái, Chu Tước sơn). Cưỡi tiên hạc trắng đưa VL đến tiên phủ sư tôn Bạch Tuyết. Cố ý bay qua Thiên Ngọc tông để Hồng Điệp (bóng hồng tay áo trống) nhìn thấy VL — VL nhận ra ý đồ. (@c0335)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0335","quanHe":"Khách quý — đang tiếp đón","ghiChu":"VL nghi có ý đồ riêng khi chọn đường bay.","tag":"xa-la"},{"ten":"Hồng Điệp","gap":"@c0335","quanHe":"Sư muội","ghiChu":"Gọi Hồng Điệp là 'muội muội'.","tag":"su-mon"}],"tuiDo":{}},"nguon":["@c0335"]},{"id":"su-ton-bach-tuyet","name":"Sư Tôn Bạch Tuyết","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Nhân Đạo Tiên","trangThai":"lanh-dao"}],"canhGioiCaoNhat":"Anh Biến kỳ","trangThai":"song — tại tiên phủ riêng, Chu Tước quốc @c0335","vaiTro":"Sư phụ Bạch Danh Tuyết — tông chủ Nhân Đạo tiên","tinhCach":[{"text":"Uy nghiêm và thần bí — vào phòng VL mà không bị phát giác; chỉ gõ ngón tay phát áp lực Anh Biến, viết 'Bại, chết' bằng nước trà rồi rời đi không nói lời nào.","chuong":"@c0335"}],"blurb":"Sư phụ Bạch Danh Tuyết, tông chủ Nhân Đạo tiên, tu vi Anh Biến kỳ. Có tiên phủ riêng (thung lũng dãy núi hình rồng) khác với tông môn Nhân Đạo tiên. Người hầu trong tiên phủ đều bị cắt nửa lưỡi. Lén vào phòng VL không bị phát giác, gõ ngón tay phát áp lực, viết 'Bại, chết' cảnh cáo VL nếu thua Hồng Điệp sẽ chết.","tabs":{"diem":[{"text":"Lén vào phòng tu sĩ Hóa Thần trung kỳ mà không bị phát giác — uy lực Anh Biến kỳ.","chuong":"@c0335"}],"kinhLich":[{"chuong":"@c0335","importance":"normal","tieuDe":"Cảnh cáo VL 'Bại, chết'","text":"Sau 10 ngày VL ở tiên phủ, đột nhiên ngồi trong phòng VL không bị phát giác. Gõ ngón trỏ lên bàn phát áp lực vô hình (VL chịu được nhờ tu vi lâu năm Hóa Thần). Rót trà, dùng nước trà viết 'Bại, chết' — ý cảnh cáo: nếu thua Hồng Điệp thì chết. Rời đi không nói. (@c0335)"}],"tuViMoc":[{"chuong":"@c0335","canhGioi":"Anh Biến kỳ","text":"VL đoán tu vi sau khi chịu áp lực gõ ngón tay.","importance":"minor"}],"nhanMach":[{"ten":"Bạch Danh Tuyết","gap":"@c0335","quanHe":"Sư phụ","ghiChu":"Bạch Tuyết phụng mệnh sư phụ đón VL.","tag":"su-mon"},{"ten":"Vương Lâm","gap":"@c0335","quanHe":"Khách — cảnh cáo","ghiChu":"Cảnh cáo VL 'Bại, chết' bằng nước trà; dự định an bài VL gia nhập Nhân Đạo tiên.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0335"]},{"id":"cong-ton-pha","name":"Công Tôn Phá","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Sơn","trangThai":"truong-lao"}],"canhGioiCaoNhat":"Vấn Đỉnh kỳ (trở lên — VL không thể kháng cự)","trangThai":"song — can thiệp và kết thúc trận VL–Hồng Điệp @c0340","vaiTro":"Trưởng lão Chu Tước Sơn — trọng tài trận chiến","tinhCach":[{"text":"Công bằng nhưng quyết đoán — can thiệp đúng lúc khi tam linh sắp nổ; phong thưởng và phạt rõ ràng.","chuong":"@c0340"}],"blurb":"Trưởng lão Chu Tước Sơn, trọng tài trận chiến VL–Hồng Điệp. Tạo cánh cửa ánh sáng (không gian chiến đấu riêng). Can thiệp khi tam linh sắp nổ — lực đạo nhu hòa từ trên trời. Tuyên bố VL thắng, phong ngoại triệu đệ tử Chu Tước quốc, hủy nguyện vọng VL vì cắt mộc linh.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0335","importance":"normal","tieuDe":"Tạo không gian chiến đấu — làm trọng tài","text":"Trưởng lão Chu Tước sơn, tự xưng trọng tài. Bấm quyết tạo cánh cửa ánh sáng kết nối thâm sơn hoang vắng — VL và Hồng Điệp bước vào. (@c0335)"},{"chuong":"@c0340","importance":"major","tieuDe":"Can thiệp — phong VL ngoại triệu đệ tử","text":"Khi tam linh sắp nổ, giáng lực đạo nhu hòa từ trên trời ngăn chặn. Vung tay đẩy VL lùi hơn 10 trượng (VL không thể kháng cự). Tuyên bố VL thắng, phong ngoại triệu đệ tử Chu Tước quốc (được 1 nguyện vọng). Thu Côn Cực Tiên lại. Khi VL cắt mộc linh — hủy nguyện vọng. (@c0340)"}],"tuViMoc":[{"chuong":"@c0335","canhGioi":"Vấn Đỉnh kỳ (trở lên)","text":"Trưởng lão Chu Tước Sơn — VL hoàn toàn không thể kháng cự khi bị đẩy lui.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0335","quanHe":"Tuyên bố thắng — phong thưởng","ghiChu":"Phong VL ngoại triệu đệ tử; hủy nguyện vọng vì cắt mộc linh.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0335","@c0340"]},{"id":"kien-phong","name":"Kiền Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Tử (đệ tử xếp thứ 2, hậu nhân Chu Tước Tử)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến trung kỳ @c0389","trangThai":"song","vaiTro":"Nhân vật bí ẩn cấm địa Chu Tước Sơn — tranh danh hiệu Chu Tước","tinhCach":[{"text":"Tà dị khiến người ta thân thiết — tướng mạo không anh tuấn nhưng khí tức kỳ lạ.","chuong":"@c0340"},{"text":"Kiêu ngạo về sức mạnh — bình luận liệu Tằng Ngưu có tiếp được 1 chiêu '1 thành tu vi' của mình không.","chuong":"@c0340"}],"blurb":"Nam tử bí ẩn ngồi tu luyện trong Viêm Đàm (lửa bất diệt ba vạn năm) cấm địa phía sau Chu Tước Sơn. Gọi lão già hồng quang là 'lão tổ'. Được lệnh cướp tuyệt tình ý cảnh + tứ linh Hồng Điệp để đoạt danh hiệu Chu Tước. Hạ thủ Hồng Điệp trong mật thất — Hồng Điệp hoàn toàn không thể phản kháng. Là kiếp nạn thật sự của Hồng Điệp (sư phụ nàng tính sai). (+) Nhị đệ tử của Chu Tước Tử, trấn giữ Chu Tước kỳ trận với tư cách trận nhãn. Nam tử tóc dài áo trắng, anh tuấn mà toát vẻ tà dị, ôm tham vọng nuốt ý cảnh của cả sư muội lẫn sư tôn. [CAN-SOAT-GOP]","tabs":{"diem":[{"text":"Hạ thủ Hồng Điệp (Hóa Thần hậu kỳ) trong 1 chiêu — điểm ngón tay vào mi tâm, lực như ngọn núi.","chuong":"@c0340"},{"text":"Nhị đệ tử Chu Tước Tử, đảm nhận vai trò trận nhãn Chu Tước kỳ trận — một trong những vị trí then chốt nhất Chu Tước quốc.","chuong":"@c0391"},{"text":"Chủ mưu giải phong ấn và dẫn toàn bộ Cự Ma Tộc về Chu Tước quốc để dung nhập thần thông tộc vào Chu Tước trận.","chuong":"@c0391"},{"text":"Bí mật khống chế sư muội Hồng Điệp như con rối không hồn, dùng sinh mệnh lực nàng chữa thương; đồng thời ôm mưu đoạt ý cảnh của cả Hồng Điệp lẫn sư tôn.","chuong":"@c0392"},{"text":"Dù bị ép lui và phun máu trong tay Vương Lâm, vẫn giữ mạng nhờ Chu Tước trận hộ thân và bình tĩnh thề phục thù.","chuong":"@c0392"}],"kinhLich":[{"chuong":"@c0340","importance":"major","tieuDe":"Hạ thủ Hồng Điệp — đoạt ý cảnh và tứ linh","text":"Nhận lệnh lão tổ: Hồng Điệp vừa có đột phá tuyệt tình ý cảnh sau trận chiến VL — phải nuốt trước khi viên mãn. Vào mật thất, xuất hiện từ hư vô. Điểm ngón tay vào mi tâm Hồng Điệp — phòng ngự tan vỡ, nàng không thể phản kháng. Đoạt tuyệt tình ý cảnh + tiên thiên tứ linh. (@c0340)"},{"chuong":"@c0341","importance":"normal","tieuDe":"Gặp Liễu Mi — cùng tìm Vương Lâm","text":"Ra khỏi quan phòng sau khi Liễu Mi nhận lệnh. Gặp Liễu Mi tại cửa cấm địa. Đe dọa Liễu Mi: nếu không giao VL cho lão tổ, hắn sẽ biến nàng thành người hầu phục vụ mình. Đồng hành cùng Liễu Mi + Hồng Điệp (con rối) đi tìm VL. (@c0341)"},{"chuong":"@c0345","importance":"normal","tieuDe":"Dừng lại trên Chu Tước Sơn — nói biết nguyên thần VL","text":"Cùng Liễu Mi và Hồng Điệp đứng trên Chu Tước Sơn. Nhìn 'Tuyệt Tình' (tên Kiền Phong đặt cho Hồng Điệp), nói rằng hắn biết trong thân thể Hồng Điệp vẫn còn dấu tia nguyên thần chưa bị diệt, nhưng không cần thiết phải giải quyết vội. Đợi tín tức VL. (@c0345)"},{"chuong":"@c0368","importance":"normal","tieuDe":"Khinh miệt chiến tích VL — trêu Tuyệt Tình tại cấm địa","text":"Tại cấm địa Chu Tước Sơn, bóp nát ngọc giản truyền âm sau khi nghe tin VL giết Lý Nguyên Phong. Khinh miệt: 'giết Lý Nguyên Phong chẳng có gì, hắn chỉ là phế vật'. Thách thức VL phải giết lão tổ Cự Ma tộc mới có tư cách làm đối thủ. Quay nhìn Hồng Điệp (Tuyệt Tình — mắt trống rỗng vô thần), cười tà dị, hỏi: 'Có muốn đánh một trận với Tằng Ngưu không? Đây chính là nguyện vọng lớn nhất của ngươi trước khi Nguyên Thần tịch diệt đó.' (@c0368)"},{"text":"Kiền Phong xuất hiện với tư cách trận nhãn Chu Tước kỳ trận khi bị Độn Thiên ép trong ba nhịp thở. Hắn mở lỗ hổng cho Độn Thiên vào rồi khép trận nhốt Vương Lâm bên ngoài, chủ động khiêu chiến. Khi Vương Lâm rút tiên kiếm chém cắt lời, Kiền Phong điểm tay đỡ nhưng bị ép lui trăm trượng, ngón tay phải rỉ máu chảy dọc cánh tay mà không hay — kinh hãi nhận ra đó là tiên bảo.","bridge":true,"khoang":"@c0391"},{"text":"Bị Vương Lâm đánh lén bằng hàng triệu hồn phách Thập Ức Tôn Hồn Phiên, Kiền Phong rút Dùi Chu Tước rồi chuyển Chu Tước trận về hộ thân. Tia sáng xanh quét ngang chống đỡ nhưng vẫn bị chấn thương phun một ngụm máu. Sau khi Vương Lâm rút lui, hắn hút sinh mệnh lực của Hồng Điệp để hồi phục, rồi tiết lộ âm mưu nuốt ý cảnh và kế hoạch của sư tôn đoạt Tôn Hồn Phiên.","bridge":true,"khoang":"@c0392"}],"tuViMoc":[{"chuong":"@c0391","canhGioi":"Anh Biến Trung Kỳ","text":"Được xác nhận ở mức Anh Biến Trung Kỳ khi ra mặt làm trận nhãn và đối đầu Vương Lâm.","importance":"major"}],"nhanMach":[{"ten":"Liễu Mi","gap":"@c0340","quanHe":"Sư muội — đồng minh","ghiChu":"Cả hai tranh danh hiệu Chu Tước; 'trừ ta với sư muội ra thì không thể dành cho người khác'. Đe dọa nàng @c0341.","tag":"dong-minh"},{"ten":"Hồng Điệp","gap":"@c0340","quanHe":"Mục tiêu — đã hạ thủ, đang kiểm soát","ghiChu":"Hồng Điệp là kiếp nạn thật sự của nàng; nuôi dưỡng nhiều năm làm 'thức ăn'; đặt tên 'Tuyệt Tình' @c0345.","tag":"muc-tieu"},{"ten":"Chu Tước Tử","tag":"su-mon","quanHe":"Sư tôn","ghiChu":"Kiền Phong là nhị đệ tử của Chu Tước Tử; nhận Dùi Chu Tước từ sư tôn; bí mật ôm tham vọng nuốt ý cảnh cả sư tôn nếu có cơ hội."},{"ten":"Hồng Điệp","tag":"su-mon","quanHe":"Sư muội (bị khống chế)","ghiChu":"Hồng Điệp là sư muội của Kiền Phong, bị hắn biến thành con rối không hồn; hắn hút sinh mệnh lực nàng chữa thương và cũng âm mưu nuốt ý cảnh nàng."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ trực tiếp","ghiChu":"Chủ động khiêu chiến Vương Lâm tại Chu Tước đại lục; bị tiên kiếm ép lui và hồn phách tự nổ gây thương; thề phục thù và đoạt Tôn Hồn Phiên lẫn ý cảnh Vương Lâm."},{"ten":"Độn Thiên","tag":"doi-thu","quanHe":"Đối lập — cường giả cản trở","ghiChu":"Độn Thiên ép Kiền Phong mở Chu Tước trận, tiến vào đại lục; Kiền Phong không thể ngăn Độn Thiên nhưng nhốt được Vương Lâm."},{"ten":"Lão Tổ Cự Ma Tộc","tag":"dong-minh","quanHe":"Đồng minh (đã dẫn về Chu Tước quốc)","ghiChu":"Kiền Phong chủ mưu giải phong ấn và đưa Cự Ma Tộc về Chu Tước quốc để dung nhập thần thông tộc vào Chu Tước trận."}],"tuiDo":{},"tuVi":"Anh Biến Trung Kỳ — xác nhận khi ra mặt tại Chu Tước đại lục."},"nguon":["@c0340","@c0341","@c0345","@c0368","@c0391","@c0392"]},{"id":"lao-to-cam-dia-chu-tuoc","name":"Lão Tổ Cấm Địa Chu Tước","cn":"","aliases":["Lão già hồng quang"],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Sơn (cấm địa)","trangThai":"lanh-dao"}],"canhGioiCaoNhat":"Không rõ — toàn thân phát hồng quang","trangThai":"song — ở cấm địa phía sau Chu Tước Sơn @c0340","vaiTro":"Thế lực bí ẩn trong cấm địa Chu Tước Sơn — nuôi Hồng Điệp làm mồi","tinhCach":[{"text":"Lạnh lùng và tính toán — nuôi Hồng Điệp nhiều năm chỉ để làm 'thức ăn' cho Kiền Phong khi thích hợp; cảm thán 'đáng tiếc' nhưng không thay đổi quyết định.","chuong":"@c0340"}],"blurb":"Nhân vật bí ẩn toàn thân phát hồng quang trong cấm địa phía sau Chu Tước Sơn. Tướng mạo giống hệt lão nhân nhếch nhác năm xưa tặng mũ rơm cho VL, nhưng khí tức hoàn toàn khác — không phải cùng một người. Nuôi Hồng Điệp nhiều năm như 'thức ăn' cho Kiền Phong. Ra lệnh Kiền Phong cướp ý cảnh Hồng Điệp sau trận chiến với VL. Hỏi Liễu Mi về Vương Lâm.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0340","importance":"major","tieuDe":"Ra lệnh cướp Hồng Điệp — hỏi Liễu Mi về VL","text":"Bay vào cấm địa, lệnh Kiền Phong nuốt tuyệt tình ý cảnh + tứ linh Hồng Điệp (vừa đột phá sau trận VL). Giải thích mục đích: cướp danh hiệu Chu Tước. Cảm thán 'Hồng Điệp, con bé này, có chút đáng tiếc…' rồi quay hỏi Liễu Mi về Vương Lâm — đệ tử Hằng Nhạc phái Triệu quốc. (@c0340)"},{"chuong":"@c0341","importance":"normal","tieuDe":"Ra lệnh Liễu Mi đi tìm VL — bế quan gặm chân gà","text":"Ra lệnh Liễu Mi đi tìm Vương Lâm để làm lò luyện (VL có Thiên Nghịch Châu + Tinh La Bàn mà lão muốn). Đồng thời đang ngồi bế quan trong cấm địa, tay gặm chân gà — biểu hiện khiến sư đệ lão già kinh ngạc nhìn xuyên tới. Một đặc điểm nhận dạng kỳ lạ. (@c0341)"}],"tuViMoc":[],"nhanMach":[{"ten":"Kiền Phong","gap":"@c0340","quanHe":"Hậu bối / Lão tổ","ghiChu":"Kiền Phong gọi lão là 'lão tổ'; lão chỉ huy Kiền Phong.","tag":"phu-thuoc"},{"ten":"Liễu Mi","gap":"@c0340","quanHe":"Đồng minh / thuộc hạ","ghiChu":"Hỏi Liễu Mi về VL @c0340; ra lệnh nàng đi tìm VL @c0341.","tag":"dong-minh"}],"tuiDo":{}},"nguon":["@c0340","@c0341"]},{"id":"tieu-bach","name":"Tiểu Bạch","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thú rừng (thủ hộ Chu Như)","trangThai":"hien-tai"}],"canhGioiCaoNhat":"Trúc Cơ kỳ (đạo hạnh hơn trăm năm)","trangThai":"song — đang trong Tiên Ngọc Bảo Tháp cùng Chu Như @c0383","vaiTro":"Lão hổ hắc văn — thú cưỡi bất đắc dĩ của Chu Như","tinhCach":[{"text":"Tự cao nhưng biết phục kẻ mạnh — nhận ra Thiết Nham kinh sợ, lại thấy tu sĩ cường đại hơn rất cung kính với VL; chọn cúi đầu thay vì phản kháng.","chuong":"@c0334"}],"blurb":"Lão hổ hắc văn (hắc văn trên lông), đạo hạnh hơn trăm năm, tu vi tương đương Trúc Cơ kỳ. Bị Chu Như phát hiện và Thiết Nham bắt về. Tự nhận mình cao quý nên chỉ chấp nhận cúi đầu / ngẩng đầu theo lệnh; từ chối những trò hề như Hắc Hùng trước đó (chổng ngược, cầm đũa). Cuối chương nghe Chu Như dặn 'mỗi ngày đều phải chơi đùa', gầm buồn bã.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0334","importance":"normal","tieuDe":"Bị Chu Như bắt — trở thành thú cưỡi","text":"Chu Như (10 tuổi) phát hiện, Thiết Nham bắt. Nhận ra khí tức mạnh mẽ, cúi đầu chấp nhận làm thú của Chu Như. VL để lại, Chu Như dặn 'mỗi ngày đều phải chơi đùa' — Tiểu Bạch gầm buồn bã. (@c0334)"},{"text":"Con hổ lớn đầu có hoa văn, có linh trí và độc thoại nội tâm, tự xưng hổ gia. Nó hưởng nhiều hổ cái ở Chu Tước tinh, mượn uy lực còn lại của Vương Lâm nên tu sĩ thấy nó liền cung kính. Nay làm vật cưỡi cõng Chu Như, nó đang phân vân có nên theo nàng rời Chu Tước tinh hay không.","bridge":true,"khoang":"@c0567"}],"tuViMoc":[{"chuong":"@c0334","canhGioi":"Trúc Cơ kỳ (đạo hạnh trăm năm)","text":"Tu vi xác nhận khi VL quan sát.","importance":"minor"}],"nhanMach":[{"ten":"Chu Như","gap":"@c0334","quanHe":"Chủ nhân (bất đắc dĩ)","ghiChu":"Chu Như đặt tên Tiểu Bạch, dùng làm thú cưỡi.","tag":"phu-thuoc"},{"ten":"Chu Như","tag":"dong-hanh","quanHe":"Cõng Chu Như đi lại, cân nhắc theo nàng rời tinh.","ghiChu":"@c0567"}],"tuiDo":{}},"nguon":["@c0334","@c0567"]},{"id":"lao-ba-bang-tuyet-than-dien","name":"Lão Bà Băng Tuyết Thần Điện","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Băng Tuyết Thần Điện","trangThai":"thuoc-ha"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song — thuộc hạ tông chủ Băng Tuyết Thần Điện @c0333","vaiTro":"Thuộc hạ tông chủ Băng Tuyết Thần Điện","tinhCach":[{"text":"Phẫn nộ và trung thành — mạnh dạn đòi tông chủ ra tay giết Tằng Ngưu vì chặt tay Hồng Điệp; uống trà quý qua loa khiến tông chủ đau lòng.","chuong":"@c0333"}],"blurb":"Thuộc hạ tóc bạc trắng của tông chủ Băng Tuyết Thần Điện. Phẫn nộ đòi giết Tằng Ngưu vì chặt tay Hồng Điệp — nhắc rằng Hồng Điệp là hy vọng Tuyết Vực quốc và nhờ nàng mà tông chủ đạt Anh Biến. Bị tông chủ lạnh mắt dập lời.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0333","importance":"normal","tieuDe":"Đòi tông chủ giết Tằng Ngưu","text":"Đứng phía dưới ghế tông chủ cùng lão già tóc bạc. Uống trà Thiên khuyết vũ ti qua loa. Đòi tông chủ ra tay bắt giết Tằng Ngưu — nhắc Hồng Điệp là hy vọng Tuyết Vực quốc, nhờ nàng mà tông chủ đạt Anh Biến. Bị tông chủ lạnh mắt: 'Ta sẽ không quên, nhưng cũng không cần ngươi nhắc!' (@c0333)"}],"tuViMoc":[],"nhanMach":[{"ten":"Tông chủ Băng Tuyết Thần Điện","gap":"@c0333","quanHe":"Chủ — thuộc hạ","ghiChu":"Bị tông chủ dập lời dù quan tâm tới Hồng Điệp.","tag":"phu-thuoc"}],"tuiDo":{}},"nguon":["@c0333"]},{"id":"lao-gia-bang-tuyet-than-dien","name":"Lão Già Băng Tuyết Thần Điện","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Băng Tuyết Thần Điện","trangThai":"thuoc-ha"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song — thuộc hạ tông chủ Băng Tuyết Thần Điện @c0333","vaiTro":"Thuộc hạ tông chủ Băng Tuyết Thần Điện","tinhCach":[{"text":"Ít nói, trầm mặc — hồi lâu mới lên tiếng xin tông chủ ra tay; cúi đầu uống trà không tranh lời.","chuong":"@c0333"}],"blurb":"Thuộc hạ tóc bạc trắng của tông chủ Băng Tuyết Thần Điện. Ít nói — trầm mặc hồi lâu mới lên tiếng xin tông chủ ra tay giết Tằng Ngưu. Tương phản với lão bà hay lên tiếng.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0333","importance":"normal","tieuDe":"Xin tông chủ ra tay — ít nói","text":"Đứng phía dưới ghế tông chủ cùng lão bà tóc bạc. Cúi đầu uống trà, không nói gì lúc đầu. Trầm mặc hồi lâu mới lên tiếng: 'Còn mời Tông chủ ra tay!' — lời xin ngắn gọn. (@c0333)"}],"tuViMoc":[],"nhanMach":[{"ten":"Tông chủ Băng Tuyết Thần Điện","gap":"@c0333","quanHe":"Chủ — thuộc hạ","ghiChu":"Ít nói, chỉ xin tông chủ ra tay.","tag":"phu-thuoc"}],"tuiDo":{}},"nguon":["@c0333"]},{"id":"lao-to-cu-ma-toc","name":"Lão Tổ Cự Ma Tộc","cn":"","aliases":["lão tổ Cự Ma","lão già tóc xám"],"gioiTinh":"nam","theLuc":[{"ten":"Cự Ma tộc","trangThai":"lao-to"}],"canhGioiCaoNhat":"Anh Biến kỳ (cưỡng ép — nhận xét của Tôn Thái @c0343)","trangThai":"tu-vong — Nguyên Thần tan biến @c0375","vaiTro":"Lão tổ Cự Ma tộc, Anh Biến kỳ cưỡng ép","tinhCach":[{"text":"Tham lam và lạnh lùng — muốn đoạt Thiên Nghịch Châu + Tinh La Bàn của VL để dâng tu chân liên minh lấy lợi ích cho tộc.","chuong":"@c0342"},{"text":"Xử lý nghiêm — phạt Sất Hổ bế quan trăm năm luyện thể vì dám phản lại lệnh lão.","chuong":"@c0342"}],"blurb":"Lão tổ Cự Ma tộc, tóc xám, Anh Biến kỳ (cưỡng ép). Vây bắt VL tại Chu Tước tinh cùng Lý Nguyên Phong để đoạt Thiên Nghịch Châu + Tinh La Bàn dâng tu chân liên minh. Bố Phong Ma Khôn Càn Trận phong tỏa không gian. Bị Tôn Thái cứu VL rồi cầm chân. Phạt Sất Hổ bế quan trăm năm vì phản lại.","tabs":{"diem":[{"text":"Bố trận Phong Ma Khôn Càn Trận phong tỏa hoàn toàn không gian — VL không thể thuấn di hay xé không gian thoát thoát.","chuong":"@c0343"}],"kinhLich":[{"chuong":"@c0334","importance":"minor","tieuDe":"Hấp thu tiên ngọc — đột phá Anh Biến (nhắc gián tiếp)","text":"Nhắc gián tiếp: một lão tổ Cự Ma tộc hấp thu tiên ngọc do Sất Hổ mang về, đột phá thành tu sĩ Anh Biến kỳ đầu tiên của Cự Ma tộc trên Chu Tước tinh; nhờ đó Cự Ma tộc thăng từ cấp 4 lên cấp 5."},{"chuong":"@c0342","importance":"major","tieuDe":"Vây bắt VL — phạt Sất Hổ","text":"Ra lệnh Sất Hổ cùng tham gia vây bắt VL tại Chu Tước tinh (bên ngoài phạm vi quản lý Chu Tước quốc). Mục tiêu: đoạt Thiên Nghịch Châu + Tinh La Bàn để dâng tu chân liên minh đổi lấy quyền lợi cho tộc. Khi Sất Hổ phản lại (truyền linh lực cho VL), lão dùng lực đạo khống chế Sất Hổ tại chỗ, phạt bế quan trăm năm luyện thể. (@c0342)"},{"chuong":"@c0343","importance":"major","tieuDe":"Bố Phong Ma Khôn Càn Trận — bị Tôn Thái cầm chân","text":"Bố Phong Ma Khôn Càn Trận phong tỏa hoàn toàn không gian quanh VL, ngăn thuấn di + xé không gian. Cùng Lý Nguyên Phong ép VL vào tình thế tuyệt vọng. Bị Tôn Thái đột nhập trận pháp cứu VL; giao chiến Tôn Thái Anh Biến trung kỳ — bị cầm chân đủ lâu để VL thoát. (@c0343)"}],"tuViMoc":[{"chuong":"@c0343","canhGioi":"Anh Biến kỳ (cưỡng ép)","text":"Tôn Thái nhận xét 'Anh Biến kỳ cưỡng ép, thiếu ổn định' khi đánh giá lão.","importance":"normal"}],"nhanMach":[{"ten":"Sất Hổ","gap":"@c0342","quanHe":"Tiểu tộc trưởng — bị phạt","ghiChu":"Sất Hổ phản lại lệnh lão, bị phạt bế quan trăm năm.","tag":"phu-thuoc"},{"ten":"Lý Nguyên Phong","gap":"@c0342","quanHe":"Đồng minh tạm thời","ghiChu":"Cùng vây VL theo kế hoạch chung; sau bị Tôn Thái đánh lui.","tag":"dong-minh"}],"tuiDo":{}},"nguon":["@c0342","@c0343"]},{"id":"lao-gia-gam-chan-ga","name":"Lão Già Gặm Chân Gà","cn":"","aliases":["sư đệ lão tổ cấm địa"],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Sơn (cấm địa)","trangThai":"an-cu"}],"canhGioiCaoNhat":"Không rõ — tu chân quốc cấp một @c0341","trangThai":"song — trong cấm địa Chu Tước Sơn @c0341","vaiTro":"Sư đệ lão tổ cấm địa Chu Tước; bí mật chọn VL làm ứng viên riêng","tinhCach":[{"text":"Phẫn nộ, cương liệt — năm xưa thua cuộc tranh danh hiệu Chu Tước nhưng không cam chịu. Tuyên bố VL là người lão chọn, đe dọa giết Kiền Phong nếu sư huynh giết VL. Hứng thú xem VL có thể lật ngược thế cờ.","chuong":"@c0341"}],"blurb":"Sư đệ của lão tổ cấm địa Chu Tước Sơn, tu chân quốc cấp một. Năm xưa tranh danh hiệu Chu Tước thua sư huynh. Bí mật chọn VL làm ứng viên riêng — phẫn nộ khi sư huynh sắp đặt Liễu Mi dùng VL làm lò luyện, tuyên bố sẽ giết Kiền Phong nếu sư huynh giết VL. Hứng thú xem VL có thể đảo ngược tình thế biến Liễu Mi thành lò luyện của chính mình.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0341","importance":"normal","tieuDe":"Phẫn nộ — tuyên bố VL là người lão chọn","text":"Tu chân quốc cấp một, sư đệ lão tổ cấm địa. Nhận truyền âm từ sư huynh thông báo sắp đặt VL cho Liễu Mi. Phẫn nộ: năm xưa thua cuộc tranh danh hiệu Chu Tước, nhưng VL chính là người lão chọn. Đe dọa nếu sư huynh giết VL, lão sẽ giết Kiền Phong. Nhưng cũng hứng thú xem VL có thể đảo ngược tình thế. (@c0341)"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão Tổ Cấm Địa Chu Tước","gap":"@c0341","quanHe":"Sư huynh — đối thủ ngầm","ghiChu":"Năm xưa thua cuộc tranh danh hiệu Chu Tước; bất mãn với sư huynh, bí mật chọn VL đối kháng Kiền Phong.","tag":"ky-khi"}],"tuiDo":{}},"nguon":["@c0341"]},{"id":"ngoai-su-truong-lao-thien-ngoc-tong","name":"Ngoại Sứ Trưởng Lão Thiên Ngọc Tông","cn":"","aliases":["lão già Thiên Ngọc Tông"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Ngọc Tông","trangThai":"truong-lao"}],"canhGioiCaoNhat":"Không rõ — chức trưởng lão ngoại sứ","trangThai":"song — hoạt động tại Chu Tước tinh @c0341","vaiTro":"Trưởng lão ngoại sứ Thiên Ngọc Tông — thao túng trận đồ dịch chuyển VL cho Tuyết Vực quốc","tinhCach":[{"text":"Tính toán, tận dụng cơ hội — chủ động dùng trận đồ dịch chuyển VL đến Tuyết Vực quốc để tạo ân tình, tuyên bố 'Tuyết Vực quốc thiếu nợ lão phu một món ân tình'.","chuong":"@c0341"}],"blurb":"Trưởng lão ngoại sứ Thiên Ngọc Tông tại Chu Tước tinh, từng ngồi cạnh Công Tôn Phá trong trận VL-Hồng Điệp. Chủ động thao túng trận đồ dịch chuyển VL đến cực bắc cho Tuyết Vực quốc — tuyên bố Tuyết Vực quốc nợ lão ân tình. Không có bằng chứng nhận lệnh từ lão tổ cấm địa.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0341","importance":"normal","tieuDe":"Thao túng trận đồ đưa VL đến Tuyết Vực","text":"Chủ động dùng trận đồ cực lớn hút VL vào rồi dịch chuyển đến cực bắc Chu Tước tinh (Tuyết Vực quốc). Tuyên bố 'Tuyết Vực quốc thiếu nợ lão phu một món ân tình' — tận dụng cơ hội tạo ân tình cho mình. (@c0341)"}],"tuViMoc":[],"nhanMach":[{"ten":"Tuyết Vực Quốc","gap":"@c0341","quanHe":"Bên nhận ân tình","ghiChu":"Chủ động dịch chuyển VL đến Tuyết Vực, tuyên bố Tuyết Vực nợ ân tình.","tag":"loi-dung"}],"tuiDo":{}},"nguon":["@c0341"]},{"id":"hong-mao-tu","name":"Hồng Mao Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"de-tu"}],"canhGioiCaoNhat":"Kết Đan sơ kỳ (@c0349)","trangThai":"song — đệ tử Luyện Hồn Tông @c0349","vaiTro":"Đệ tử Luyện Hồn Tông — gặp VL lúc nhập môn","tinhCach":[{"text":"Thực dụng, đánh giá nhanh — nhận ra VL là Trúc Cơ sơ kỳ nhưng vẫn có thiện chí giải thích tông môn.","chuong":"@c0349"}],"blurb":"Đệ tử Kết Đan sơ kỳ của Luyện Hồn Tông. Gặp VL (lúc đó mới Trúc Cơ sơ kỳ) ở cổng tông môn sau 7 ngày bay từ Bì Lô quốc. Giải thích cơ chế tông môn: đệ tử hạch tâm vài trăm người, ngoại vi vạn người, thi đấu 3 năm một lần. Chỉ dẫn VL gặp Thường Đại Vĩ.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0349","importance":"normal","tieuDe":"Gặp VL ở cổng tông môn — giải thích cơ chế","text":"Gặp VL và Văn Thú ở cổng Luyện Hồn Tông. Kết Đan sơ kỳ. Nhận ra VL Trúc Cơ sơ kỳ. Giải thích: tông môn có đệ tử hạch tâm vài trăm người, đệ tử ngoại vi vạn người; thi đấu 3 năm một lần để thăng hạch tâm. Dẫn VL vào gặp Thường Đại Vĩ nhận ngoại vi đệ tử. (@c0349)"}],"tuViMoc":[{"chuong":"@c0349","canhGioi":"Kết Đan sơ kỳ","text":"Tu vi xác nhận khi gặp VL.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0349","quanHe":"Người mới nhập môn gặp","ghiChu":"Giải thích cơ chế tông môn cho VL.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0349"]},{"id":"thuong-dai-vi","name":"Thường Đại Vĩ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"de-tu"}],"canhGioiCaoNhat":"Không rõ — nam tử trung niên Luyện Hồn Tông @c0349","trangThai":"song — đệ tử Luyện Hồn Tông @c0349–0350","vaiTro":"Đệ tử Luyện Hồn Tông — nhận VL làm ngoại vi đệ tử, cấp động phủ 803","tinhCach":[{"text":"Lạnh nhạt, thực sự không quan tâm — thu xếp nhanh cho VL vào Luyện Hồn Tông như thủ tục hành chính.","chuong":"@c0349"}],"blurb":"Nam tử trung niên của Luyện Hồn Tông, phụ trách tiếp nhận đệ tử ngoại vi. Nhận VL (danh 'Thanh Mộc', Trúc Cơ sơ kỳ) làm ngoại vi đệ tử, cấp ngọc giản giới thiệu tông môn + động phủ 803 để VL bế quan. Không thắc mắc gì về tên giả.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0349","importance":"normal","tieuDe":"Nhận VL làm ngoại vi đệ tử — cấp động phủ 803","text":"Tiếp nhận VL (tên 'Thanh Mộc', Trúc Cơ sơ kỳ) theo giới thiệu của Hồng Mao Tử. Ghi danh VL vào ngoại vi đệ tử Luyện Hồn Tông; cấp ngọc giản chứa thông tin tông môn + động phủ 803 để VL bế quan. Không hỏi gì thêm. (@c0349)"},{"chuong":"@c0350","importance":"minor","tieuDe":"Xác nhận VL đã vào động phủ 803","text":"Ghi nhận VL (Thanh Mộc) đã nhận động phủ 803 và bắt đầu bế quan. Thông tin này sau đó xuất hiện trong ngọc giản báo cho Liễu Mi biết vị trí VL. (@c0350)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0349","quanHe":"Nhận vào ngoại vi đệ tử","ghiChu":"VL dùng tên giả 'Thanh Mộc'; Thường Đại Vĩ cấp động phủ 803.","tag":"xa-la"}],"tuiDo":{}},"nguon":["@c0349","@c0350"]},{"id":"chu-tuoc","name":"Chu Tước Tử Đời Thứ 14","cn":"朱雀","aliases":["Chu Tước","lão quái Chu Tước","Chu Tước Tử","Chu Tước Tử Đời 14","Tước Tử hồng bào"],"gioiTinh":"nam","theLuc":[{"ten":"Chu Tước Sơn","trangThai":"gan-bo"},{"ten":"Tiên Di tộc (phân nhánh danh xưng)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cực cao (thần thức bao trùm toàn Chu Tước quốc)","trangThai":"song","vaiTro":"Tồn tại tối cao trên Chu Tước Sơn, thống trị Chu Tước quốc","tinhCach":[{"text":"Cao ngạo cực độ, coi tu sĩ Hóa Thần chỉ là công cụ (lô đỉnh), mất cũng không tiếc.","chuong":"@c0345"}],"blurb":"Tồn tại tối cao trên Chu Tước Sơn, thần thức bao trùm toàn bộ Chu Tước quốc. Quét thần thức sau trận chiến Tôn Thái vs lão tổ Cự Ma tộc, ra lệnh Liễu Mi đi tìm Vương Lâm và hứa trừng phạt Tuyết Vực quốc.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0345","importance":"normal","tieuDe":"Quét thần thức, ra lệnh Liễu Mi tìm VL","text":"Dừng bế quan, quét thần thức toàn quốc, phát hiện trận chiến 2 Anh Biến kỳ ở cực bắc do Tuyết Vực gây ra. Không tìm thấy VL (nguyên thần VL tan nát nên lọt thần thức). Coi VL chỉ là một cái lô đỉnh, ra lệnh Liễu Mi đi phương bắc tìm. Hứa Tuyết Vực nhất định gặp tai kiếp. Tiếp tục bế quan."},{"bridge":true,"khoang":"@c0379","text":"Ra lệnh tổng tấn công, khởi đầu giai đoạn mới của chiến tranh Tiên Di tộc."}],"tuViMoc":[],"nhanMach":[{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Cấp dưới, nhận lệnh tìm VL","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Coi như công cụ luyện đan (lô đỉnh)","ghiChu":""}],"tuiDo":{}},"nguon":["@c0345","@c0379"]},{"id":"thien-muc","name":"Thiên Mục","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Cự Ma tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần đại viên mãn @c0371","trangThai":"song","blurb":"Đại trưởng lão Cự Ma tộc, bị Vương Lâm đánh lui một quyền khi xung đột tại Chu Tước tinh.","vaiTro":"phu","tinhCach":[{"text":"Uy quyền, cẩn thận","chuong":"@c0371"}],"tabs":{"diem":[{"text":"Đại trưởng lão Cự Ma tộc; Hóa Thần đại viên mãn; bị Vương Lâm đánh lui bằng một quyền @c0371","chuong":"@c0371"}],"kinhLich":[{"bridge":true,"khoang":"@c0371","text":"Xuất hiện đối đầu Vương Lâm, bị đánh lui một quyền."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0371"]},{"id":"mi-co","name":"Mị Cơ","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Tiểu tinh cầu (bị phong ấn trong pháp luân)","trangThai":"da-roi"}],"canhGioiCaoNhat":"Kết Đan (tu vi khi bị bắt) @c0376","trangThai":"khong-ro","blurb":"Nữ tử thiên kiều bá mị với ý cảnh mê hoặc cực mạnh, bị phong ấn trong pháp luân trong túi trữ vật của tiểu tinh cầu; Vương Lâm tìm được và ép khai tên.","vaiTro":"phu","tinhCach":[{"text":"Quyến rũ, nguy hiểm; ý cảnh mê hoặc người xung quanh","chuong":"@c0376"}],"tabs":{"diem":[{"text":"Nữ tử ý cảnh mê hoặc cực mạnh; bị phong ấn trong pháp luân ở tiểu tinh cầu; Vương Lâm bắt, ép khai tên @c0376","chuong":"@c0376"}],"kinhLich":[{"bridge":true,"khoang":"@c0376","text":"Bị Vương Lâm tìm thấy và bắt giữ trong tiểu tinh cầu, khai tên Mị Cơ."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0376"]},{"id":"tieu-tu","name":"Tiểu Tử","cn":"","aliases":["cọp tím"],"gioiTinh":"khac","theLuc":[{"ten":"Chu Như (chủ nhân đặt tên)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Trúc Cư hậu kỳ (sức mạnh thú vật, chưa khai thần trí) @c0378","trangThai":"song","blurb":"Cọp tím dài 3 trượng Chu Như nuôi dưỡng trên Nguyệt tinh; chưa khai thần trí nhưng sức mạnh tương đương Trúc Cư hậu kỳ.","vaiTro":"phu","tinhCach":[{"text":"Hung hãn nhưng thân thiết với Chu Như","chuong":"@c0378"}],"tabs":{"diem":[{"text":"Cọp tím dài 3 trượng, sức mạnh Trúc Cư hậu kỳ, chưa khai thần trí; Chu Như đặt tên Tiểu Tử @c0378","chuong":"@c0378"}],"kinhLich":[{"bridge":true,"khoang":"@c0378","text":"Xuất hiện lần đầu trên Nguyệt tinh, được Chu Như đặt tên và nuôi dưỡng."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0378"]},{"id":"lao-gia-tien-di-to","name":"Lão Giả Tổ Tiên Tiên Di Tộc","cn":"","aliases":["lão giả 11 lá + 12 sơ khai"],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di tộc","trangThai":"da-roi"}],"canhGioiCaoNhat":"Vấn Đỉnh (11 lá + 12 sơ khai) @c0379","trangThai":"tu-vong","blurb":"Tổ tiên cấp cao Tiên Di tộc, 11 lá cộng thêm 12 sơ khai đạt ngang Vấn Đỉnh; hi sinh trong nghi lễ để tộc nhân tái hiện hình thái tu sĩ.","vaiTro":"phu","tinhCach":[{"text":"Hi sinh vì đại nghĩa của tộc, ý chí cường mãnh","chuong":"@c0379"}],"tabs":{"diem":[{"text":"11 lá + 12 sơ khai tương đương Vấn Đỉnh; hi sinh để Tiên Di tộc tái hiện @c0379","chuong":"@c0379"}],"kinhLich":[{"bridge":true,"khoang":"@c0379","text":"Hi sinh trong nghi lễ tái hiện Tiên Di tộc, bỏ mình để tộc nhân chuyển hóa thành tu sĩ."}],"tuViMoc":[{"chuong":"@c0379","canhGioi":"Vấn Đỉnh (11 lá + 12 sơ khai)","text":"Tu vi cao nhất ghi nhận trong nghi lễ hi sinh","importance":"major"}],"nhanMach":[],"tuiDo":{}},"nguon":["@c0379"]},{"id":"so-van-phi","name":"Sở Vân Phi","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Thiên Ngọc tông (cấm địa)","trangThai":"an-cu"}],"canhGioiCaoNhat":"Vấn Đỉnh sơ kỳ @c0379","trangThai":"song","blurb":"Cao thủ Vấn Đỉnh sơ kỳ trong cấm địa Thiên Ngọc tông; xuất hiện gắn với bối cảnh chiến tranh Tiên Di tộc tại Chu Tước tinh.","vaiTro":"phu","tinhCach":[{"text":"Ẩn cư trong cấm địa","chuong":"@c0379"}],"tabs":{"diem":[{"text":"Vấn Đỉnh sơ kỳ trong cấm địa Thiên Ngọc tông; xuất hiện trong bối cảnh Tiên Di tộc xâm chiến @c0379","chuong":"@c0379"}],"kinhLich":[{"bridge":true,"khoang":"@c0379","text":"Được nhắc đến trong bối cảnh cuộc chiến Tiên Di tộc lần đầu bùng nổ."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0379"]},{"id":"tran-phong-khieu","name":"Trần Phong Khiếu","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Đạo tông Triệu quốc (thủ lĩnh)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ @c0387","trangThai":"song","blurb":"Lão giả tóc trắng, thủ lĩnh Thiên Đạo tông Triệu quốc; dẫn đầu toàn bộ tu sĩ tham kiến Vương Lâm là thủy tổ. Năm xưa là thiếu niên được Vương Trác tự tay đưa đến Thiên Đạo tông.","vaiTro":"phu","tinhCach":[{"text":"Kính trọng truyền thống, lãnh đạo tu sĩ Triệu quốc","chuong":"@c0387"}],"tabs":{"diem":[{"text":"Thủ lĩnh Thiên Đạo tông Triệu quốc; dẫn đầu tham kiến Vương Lâm là thủy tổ @c0387","chuong":"@c0387"},{"text":"Năm xưa là thiếu niên được Vương Trác đưa đến Thiên Đạo tông @c0387","chuong":"@c0387"}],"kinhLich":[{"bridge":true,"khoang":"@c0387","text":"Gặp lại Vương Trác và lần đầu tham kiến Vương Lâm là thủy tổ; nghe Vương Trác tiết lộ thân phận thật qua truyền âm."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0387"]},{"id":"ngoc-nhi","name":"Ngọc Nhi","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vương gia Triệu quốc (hậu nhân)","trangThai":"gan-bo"},{"ten":"Vương Trác (đệ tử sau khi được thu nhận)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phàm nhân (chưa tu tiên) @c0384","trangThai":"song","blurb":"Hậu nhân Vương gia Triệu quốc, sáu bảy tuổi, khuôn mặt hồng hào đáng yêu; có thể có linh căn khiến Tiên Di tộc truy đuổi; được Vương Trác thu nhận, truyền thuật tu tiên.","vaiTro":"phu","tinhCach":[{"text":"Đáng yêu, vô tư trong sáng","chuong":"@c0384"}],"tabs":{"diem":[{"text":"Hậu nhân Vương gia Triệu quốc, sáu bảy tuổi; Tiên Di tộc săn vì nghi có linh căn @c0384","chuong":"@c0384"},{"text":"Được Vương Trác thu nhận truyền thuật tu tiên @c0387","chuong":"@c0387"}],"kinhLich":[{"bridge":true,"khoang":"@c0384–@c0387","text":"Cha mẹ đưa chạy trốn Tiên Di tộc đến tổ trạch; được Vương Trác thu nhận truyền thuật tu tiên."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0384","@c0385","@c0387"]},{"id":"yen-hong","name":"Yến Hồng","cn":"","aliases":["lão bà Trĩ Ma Đạo"],"gioiTinh":"nu","theLuc":[{"ten":"Trĩ Ma Đạo","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ @c0388","trangThai":"song","blurb":"Lão bà thủ lĩnh Trĩ Ma Đạo ở đầm lầy Bỉ Lô quốc; Anh Biến hậu kỳ; từng bị Tiên Di tộc đánh trọng thương; giao nộp một nửa tiên ngọc cho Độn Thiên đổi lấy lời hứa trợ chiến.","vaiTro":"phu","tinhCach":[{"text":"Cứng rắn, biết cân nhắc thiệt hơn","chuong":"@c0388"}],"tabs":{"diem":[{"text":"Lão bà thủ lĩnh Trĩ Ma Đạo; Anh Biến hậu kỳ; từng bị Tiên Di tộc đánh trọng thương, dùng tiên ngọc chữa thương @c0388","chuong":"@c0388"},{"text":"Ném xác rùa chặn kiếm quang Vương Lâm (tiên bảo) nhưng thất bại; nhận ra Tằng Ngưu (Vương Lâm) @c0388","chuong":"@c0388"},{"text":"Đồng ý giao một nửa tiên ngọc đổi lấy lời hứa Độn Thiên trợ chiến khi Tiên Di tộc tấn công lần hai @c0388","chuong":"@c0388"}],"kinhLich":[{"tieuDe":"Giao tiên ngọc, ký ước với Luyện Hồn","loai":"normal","chuong":"@c0388","text":"Bị Độn Thiên uy hiếp bằng Thập Ức Tôn Hồn Phiên và Vương Lâm trổ tiên kiếm phá xác rùa; đồng ý giao nộp một nửa tiên ngọc đổi lấy lời hứa trợ chiến khi Tiên Di tộc tấn công Trĩ Ma Đạo lần hai."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0388"]},{"id":"moc-nghiep","name":"Mộc Nghiệp","cn":"","aliases":["lão già lưng còng Tiên Di tộc"],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ (dưới cửu diệp) @c0389","trangThai":"song","blurb":"Lão già lưng còng, sắc mặt âm trầm, hay ho khan; người Tiên Di tộc; chính là kẻ năm xưa truy sát Vương Lâm vào khe nứt không gian - thù truyền kiếp với Vương Lâm. Được cửu diệp cử mang tộc nhân đi họp mặt thiếu tộc trưởng.","vaiTro":"phu","tinhCach":[{"text":"Âm trầm, nguy hiểm; thù hận sâu nặng","chuong":"@c0389"}],"tabs":{"diem":[{"text":"Kẻ thù truyền kiếp của Vương Lâm - năm xưa đẩy hắn vào khe nứt không gian @c0389","chuong":"@c0389"},{"text":"Được cửu diệp cử mang tộc nhân Tiên Di tộc đi họp mặt thiếu tộc trưởng trong cuộc chiến lần hai @c0389","chuong":"@c0389"}],"kinhLich":[{"bridge":true,"khoang":"@c0389","text":"Xuất hiện trong cuộc chiến Tiên Di tộc lần hai; Vương Lâm nhận ra nhưng không lộ mặt do đội mũ rơm."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0389"]},{"id":"nguoi-trung-nien-tien-di","name":"Cửu Diệp Thuật Chú Sư Tiên Di Tộc","cn":"","aliases":["người đàn ông trung niên Tiên Di tộc","cửu diệp"],"gioiTinh":"nam","theLuc":[{"ten":"Tiên Di tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cửu diệp (tương đương Vấn Đỉnh sơ kỳ, mới thăng gần nghìn năm) @c0389","trangThai":"song","blurb":"Người đàn ông trung niên Tiên Di tộc, mặc vải đay, ánh mắt như điện, toàn thân không một ấn ký phù văn; cửu diệp thuật chú sư tương đương Vấn Đỉnh sơ kỳ; dùng Định/Đỉnh/Luyện và năm đỉnh đồng đấu với Độn Thiên; sau lui binh khi thấy mười chủ hồn xuất hiện.","vaiTro":"phu","tinhCach":[{"text":"Cẩn thận, biết lượng sức; rút lui khi thấy bất lợi","chuong":"@c0390"}],"tabs":{"diem":[{"text":"Cửu diệp thuật chú sư, mới thăng cấp gần nghìn năm, tương đương Vấn Đỉnh sơ kỳ @c0389","chuong":"@c0389"},{"text":"Dùng Định/Đỉnh/Luyện và năm đỉnh đồng đấu với Độn Thiên (Hồn trận thập tam) @c0389","chuong":"@c0389"},{"text":"Thay mặt Tiên Di tộc hứa không vào Luyện Hồn tông nửa bước @c0390","chuong":"@c0390"}],"kinhLich":[{"tieuDe":"Đấu Độn Thiên, lui binh","loai":"normal","chuong":"@c0389","text":"Dùng thuật Định/Đỉnh/Luyện và năm đỉnh đồng đấu với Thập Ức Tôn Hồn Phiên của Độn Thiên; bị mười chủ hồn ép lui, thay mặt tộc hứa không xâm phạm Luyện Hồn tông."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0389","@c0390"]},{"id":"trien-bach","name":"Triển Bạch","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Trĩ Ma Đạo (cũ)","trangThai":"phan-do"}],"canhGioiCaoNhat":"Hóa Thần sơ kỳ @c0304","trangThai":"chet — bị Vương Lâm giết @c0306","vaiTro":"Phản diện — kẻ tấn công Vân Thiên Tông","tinhCach":[{"text":"Tàn nhẫn, giết người không chớp mắt — thảm sát tu sĩ Sở quốc bằng sâu độc, giết cả trưởng lão Vân Thiên Tông.","chuong":"@c0304"},{"text":"Kẻ phản đồ — phản lại Trĩ Ma Đạo tại Bì Lô quốc, hơn 100 năm ẩn náu tại Cửu U man hoang tự cường.","chuong":"@c0304"}],"blurb":"Tu sĩ Hóa Thần sơ kỳ, phản đồ Trĩ Ma Đạo (Bì Lô quốc). Sau hơn 100 năm ẩn trong Cửu U man hoang, đúc hợp nguyên thần với ngô công (Trùng Thú đạo), luyện thuật phân thân bất tử. Thảm sát nhiều môn phái Sở quốc bằng sâu độc, tấn công Vân Thiên Tông — bị Vương Lâm giết bằng Thiên Kiếp quyển trục.","tabs":{"diem":[{"text":"Phân thân bất tử — cơ thể phân thân sẽ thay thế bản thể khi bị giết; bị VL giết cả bản thể lẫn nguyên thần.","chuong":"@c0305"},{"text":"Hợp nhất nguyên thần với ngô công tại Cửu U man hoang → Trùng Thú đạo (thiên đạo cảm ngộ Hóa Thần); nguyên thần hình ngô công.","chuong":"@c0306"}],"kinhLich":[{"chuong":"@c0304","importance":"major","tieuDe":"Tấn công Vân Thiên Tông — VL xuất hiện","text":"Nhân Cự Ma tộc rút lui khỏi Sở quốc sau vụ Tằng Ngưu, xông vào Vân Thiên Tông giết các trưởng lão bằng sâu độc. VL bất ngờ xuất hiện tuyên bố 'Ta, chính là Vương Lâm!' (@c0304)"},{"chuong":"@c0305","importance":"major","tieuDe":"Đại chiến Vương Lâm — dùng Cấm Phiên, Tuế Nguyệt, phân thân","text":"Giao chiến VL: dùng Cấm Phiên (thương đen cấm khí), Tuế Nguyệt (9 tượng gỗ), kéo rách không gian chặn truyền tống. VL lần đầu thi triển toàn lực Sinh Tử ý cảnh — cuộn trục đen trắng rộng 10 dặm, cả kẽ nứt không gian cũng đóng lại. Phân thân bất tử kích hoạt nhưng không cứu được. (@c0305)"},{"chuong":"@c0306","importance":"major","tieuDe":"Bị giết bằng Thiên Kiếp quyển trục","text":"VL dùng Thiên Kiếp quyển trục (sinh tử ý cảnh), lốc xoáy nuốt nguyên thần hình ngô công; thân xác hóa máu thịt giòi bọ bị thiêu. VL thu túi trữ vật (toàn sâu bọ). (@c0306)"}],"tuViMoc":[{"chuong":"@c0304","canhGioi":"Hóa Thần sơ kỳ","text":"Xác nhận khi tấn công Vân Thiên Tông. Từng là tu sĩ Trĩ Ma Đạo Bì Lô quốc; sau hơn 100 năm ẩn Cửu U man hoang tự đạt Hóa Thần."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0304","quanHe":"Kẻ giết mình","ghiChu":"VL xuất hiện chặn Triển Bạch khi hắn vừa hạ Vân Thiên Tông. Chiến 2 chương, bị giết hoàn toàn @c0306.","tag":"doi-thu"},{"ten":"Lý Mộ Uyển","gap":"@c0304","quanHe":"Mục tiêu","ghiChu":"Vân Thiên Tông của LMU là đối tượng tấn công. LMU được VL bảo vệ.","tag":"doi-thu"}],"tuiDo":{"phapBao":[{"ten":"Cấm Phiên (thương đen)","loai":"phap-bao","trangThai":"mat-sau-khi-chet","moTa":"Thương màu đen phát cấm khí, dùng khóa thần thức và linh lực đối phương.","nguon":"@c0305"},{"ten":"Tuế Nguyệt (9 tượng gỗ)","loai":"phap-bao","trangThai":"mat-sau-khi-chet","moTa":"9 tượng gỗ thần bí, có thể kéo rách không gian ngăn truyền tống.","nguon":"@c0305"},{"ten":"Kén ngô công (bản mệnh)","loai":"phap-bao","trangThai":"mat-sau-khi-chet","moTa":"Bản mệnh pháp bảo hình kén ngô công; khi nguyên thần hình ngô công bị Thiên Kiếp quyển trục nuốt thì pháp bảo này cũng tan.","nguon":"@c0305"}],"congPhap":[{"ten":"Thuật phân thân bất tử","moTa":"Kỹ thuật phân thân; khi bản thể bị giết, phân thân tiếp tục sống. Bị VL phá bằng Thiên Kiếp quyển trục tiêu diệt hoàn toàn cả nguyên thần.","nguon":"@c0305"}],"danDuoc":[],"linhThu":[{"ten":"Sâu độc (hàng loạt)","moTa":"Vũ khí chủ lực — sâu độc hàng trăm loại. Túi trữ vật sau khi chết toàn sâu bọ.","nguon":"@c0304"}],"khac":[]}},"nguon":["@c0304","@c0305","@c0306"]},{"id":"lu-phi","name":"Lữ Phi","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"da-roi-bo"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ — 143 năm bế tắc @c0306; thần thức 100 trượng trong bài tập ma luyện @c0307","trangThai":"song — theo Vương Lâm cầu Hóa Thần","vaiTro":"Nhân vật phụ — hộ vệ và thuộc hạ Vương Lâm","tinhCach":[{"text":"Quyết tâm kiên định — không ngần ngại bỏ chức đại trưởng lão VTT theo VL; 143 năm bế tắc khiến hướng đi Hóa Thần trở thành lẽ sống.","chuong":"@c0306"},{"text":"Chuyên nghiệp, chu đáo — hộ vệ sát cánh, thần thức tản ra đề phòng trên đường; báo cáo chính xác tình trạng LMU cho VL.","chuong":"@c0307"}],"blurb":"Đại trưởng lão Nguyên Anh hậu kỳ của Vân Thiên Tông, 143 năm bế tắc ở cảnh giới này. Tự nguyện bỏ chức theo Vương Lâm khi hắn trở về, hy vọng đây là cơ hội cuối cùng đạt Hóa Thần. Hiện là hộ vệ đồng hành VL và Lý Mộ Uyển.","tabs":{"diem":[{"text":"Đại trưởng lão Nguyên Anh hậu kỳ VTT; biết VL = Tằng Ngưu; 143 năm ở NA hậu kỳ.","chuong":"@c0306"},{"text":"Thần thức đi vào 100 trượng trong bài tập ma luyện uy áp bảo tháp Chu Dật — tiến hơn Thiết Nham (50 trượng).","chuong":"@c0307"}],"kinhLich":[{"chuong":"@c0306","importance":"major","tieuDe":"Bỏ chức đại trưởng lão — theo VL cầu Hóa Thần","text":"Báo cáo VL tình trạng LMU (3 lần Kết Anh thất bại; lần gần nhất 30 năm trước suýt chết). Sau khi VL lệnh bảo mật, dẫn 2 trưởng lão Nguyên Anh sơ kỳ mới ra ngoài diệt khẩu. Bỏ chức đại trưởng lão theo VL — 143 năm NA hậu kỳ, đây là cơ hội duy nhất cầu Hóa Thần. (@c0306)"},{"bridge":true,"khoang":"@c0307–@c0310","text":"Hộ vệ VL và LMU từ Sở quốc về Tu Ma Hải qua cổ truyền tống trận; thần thức 100 trượng trong bài tập ma luyện. Tham dự đấu giá Luyện Khí Các; nhận lệnh VL bảo vệ LMU khi VL đi tìm Chu Ngạn Hoành. (@c0307–@c0310)"}],"tuViMoc":[{"chuong":"@c0306","canhGioi":"Nguyên Anh hậu kỳ (143 năm bế tắc)","text":"143 năm mắc kẹt ở Nguyên Anh hậu kỳ; VL chỉ dẫn: phải đồng nhất linh lực bề bộn mới có thể cảm ngộ Hóa Thần. Bài tập: ma luyện trong uy áp bảo tháp Chu Dật từ ngoài 100 dặm đến trong 3 dặm."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0306","quanHe":"Chủ nhân — người dẫn đường đến Hóa Thần","ghiChu":"Tự nguyện theo VL; đang ma luyện theo chỉ điểm của VL.","tag":"cap-tren","uuTien":90},{"ten":"Thiết Nham","gap":"@c0306","quanHe":"Đồng đội hộ vệ","ghiChu":"Cùng bỏ chức đại trưởng lão theo VL; cùng thực hiện bài tập ma luyện.","tag":"dong-hanh"},{"ten":"Lý Mộ Uyển","gap":"@c0306","quanHe":"Được bảo vệ","ghiChu":"Hộ vệ LMU theo lệnh VL từ @c0306 đến @c0310.","tag":"cap-tren"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0306","@c0307","@c0308","@c0309","@c0310"]},{"id":"thiet-nham","name":"Thiết Nham","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"da-roi-bo"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ — 172 năm bế tắc @c0306; đã đến bước cuối cùng trước Hóa Thần nhưng dừng bước @c0334","trangThai":"song — thủ hộ Chu Như tại sơn cốc sau khi VL rời đi @c0334","vaiTro":"Nhân vật phụ — hộ vệ và thuộc hạ Vương Lâm","tinhCach":[{"text":"Dứt khoát — bỏ chức đại trưởng lão theo VL không do dự, dù tuổi thọ không còn nhiều.","chuong":"@c0306"},{"text":"Nhận thức rõ giới hạn mình — biết thần thức chỉ 50 trượng, thầm quyết tâm toàn lực tu luyện đạt 3 dặm.","chuong":"@c0307"},{"text":"Trung thành tuyệt đối — dứt khoát buông bỏ tất cả tại Vân Thiên Tông, đi theo bên cạnh VL vì ân công.","chuong":"@c0334"}],"blurb":"Đại trưởng lão Nguyên Anh hậu kỳ của Vân Thiên Tông, 172 năm bế tắc ở cảnh giới này — lâu hơn Lữ Phi. Bỏ chức theo Vương Lâm cầu Hóa Thần. Thần thức yếu hơn Lữ Phi (50 vs 100 trượng), âm thầm quyết tâm đuổi kịp. 4 năm sau tự quay lại, buông bỏ cơ hội Hóa Thần ở tông môn để theo hầu VL; ở lại sơn cốc chiếu cố Chu Như sau khi VL đi Chu Tước quốc.","tabs":{"diem":[{"text":"Đại trưởng lão Nguyên Anh hậu kỳ VTT; 172 năm bế tắc — lâu nhất trong cả đội.","chuong":"@c0306"},{"text":"Thần thức chỉ 50 trượng trong bài tập ma luyện; thầm quyết tâm đạt 3 dặm.","chuong":"@c0307"},{"text":"Lấy được thẻ VIP mời Luyện Khí Các (@c0308) — có quan hệ ở Tu Ma Hải.","chuong":"@c0308"}],"kinhLich":[{"chuong":"@c0306","importance":"major","tieuDe":"Bỏ chức đại trưởng lão — theo VL cầu Hóa Thần","text":"172 năm ở Nguyên Anh hậu kỳ, tuổi thọ không còn nhiều; bỏ chức theo VL là lựa chọn duy nhất. VL chỉ dẫn: đồng nhất linh lực bề bộn, ma luyện trong uy áp bảo tháp. (@c0306)"},{"bridge":true,"khoang":"@c0307–@c0310","text":"Hộ vệ VL và LMU trên đường về Tu Ma Hải; thần thức chỉ 50 trượng trong bài tập. Lấy thẻ VIP mời đấu giá Luyện Khí Các (@c0308). Tham dự đấu giá; nhận lệnh VL bảo vệ LMU khi VL đi tìm Chu Ngạn Hoành. (@c0307–@c0310)"},{"bridge":true,"khoang":"@c0331","text":"1 năm trước c0331 được VL cho về Vân Thiên Tông. (@c0331)"},{"chuong":"@c0334","importance":"normal","tieuDe":"Quay lại theo VL — ở lại thủ hộ Chu Như","text":"Đến thung lũng từ 4 năm trước, dứt khoát buông bỏ Vân Thiên Tông dù đã đến bước cuối trước Hóa Thần. Gọi VL là 'ân công'. VL giao phó Chu Như trước khi đi Chu Tước quốc, Thiết Nham nhận lời. (@c0334)"},{"chuong":"@c0353","importance":"minor","tieuDe":"Thủ hộ sơn cốc — giấu Chu Như tin VL mất tích","text":"Khoanh chân ngồi dưới bảo tháp trong sơn cốc, nhìn Tiểu Chu cưỡi Tiểu Bạch chơi đùa. Biết tin VL mất tích nhưng giấu không nói với Tiểu Chu, vẫn tin tưởng: “Ân công nói trong vòng chín năm nhất định trở về.” (@c0353)"},{"text":"Lão già Thiết Nham mặc đạo bào uy nghiêm, cúi sâu chào pho tượng Vương Lâm rồi ân cần khuyên Chu Như tu luyện tùy tâm. Năm xưa được Vương Lâm chỉ điểm đột phá Nguyên Anh đạt Hóa Thần nên vô cùng cảm kích lẫn kính sợ, túi trữ vật ân công để lại bao năm vẫn không dám đụng. Ông hứa sẽ lập tức trao túi đó khi Chu Như đạt Nguyên Anh, rồi tiễn nàng cưỡi Tiểu Bạch lên đường tới núi Chu Tước.","bridge":true,"khoang":"@c0567"}],"tuViMoc":[{"chuong":"@c0306","canhGioi":"Nguyên Anh hậu kỳ (172 năm bế tắc)","text":"172 năm mắc kẹt — lâu hơn Lữ Phi 29 năm. VL chỉ dẫn: phải đồng nhất linh lực bề bộn, bài tập ma luyện uy áp bảo tháp."},{"chuong":"@c0334","canhGioi":"Cận Hóa Thần (dừng bước)","text":"Đã đến bước cuối cùng trước Hóa Thần nhưng dừng lại vì Vân Thiên Tông không thể giúp tiến thêm.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0306","quanHe":"Chủ nhân — người dẫn đường đến Hóa Thần / ân công","ghiChu":"Tự nguyện theo VL; đang ma luyện theo chỉ điểm. VL có đại ân trong việc Hóa Thần; Thiết Nham buông bỏ tất cả để theo hầu @c0334.","tag":"cap-tren","uuTien":100},{"ten":"Lữ Phi","gap":"@c0306","quanHe":"Đồng đội hộ vệ","ghiChu":"Cùng bỏ chức theo VL; cùng thực hiện bài tập ma luyện — Lữ Phi tiến nhanh hơn.","tag":"dong-hanh"},{"ten":"Lý Mộ Uyển","gap":"@c0306","quanHe":"Được bảo vệ","ghiChu":"Hộ vệ LMU theo lệnh VL.","tag":"cap-tren"},{"ten":"Chu Như","tag":"khac","quanHe":"Thiết Nham che chở, cưng chiều Chu Như như bậc trưởng bối; hứa trao túi trữ vật của Vương Lâm khi nàng đạt Nguyên Anh.","ghiChu":"@c0567"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Được Vương Lâm chỉ điểm đột phá Hóa Thần năm xưa; giữ gìn túi trữ vật ân công để lại.","ghiChu":"@c0567"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0306","@c0307","@c0308","@c0309","@c0310","@c0331","@c0334","@c0353","@c0567"]},{"id":"khau-tu-binh","name":"Khâu Tứ Bình","cn":"","aliases":["lão già áo tía"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ đại viên mãn @c0309","trangThai":"mat — bị thôi hóa thành khôi lỗi (phù rối) trong Tiên Di Chi Địa @c0323","vaiTro":"Nhân vật phụ — bạn cũ của Vương Lâm từ thời Kết Đan","tinhCach":[{"text":"Hung hăng nhưng biết sợ — dùng thần thức quét phòng VL, bị phản công; liếc mắt VL suýt vỡ nguyên anh, lùi ba bước mồ hôi đầm.","chuong":"@c0309"},{"text":"Hồn hậu, trung thực — sau khi nhận ra VL, bộc lộ ngay sự thán phục và kinh ngạc chân thành.","chuong":"@c0309"},{"text":"Biết thời thế — chủ động cầu xin VL cõng bay đổi bảo vật, không vì tự ái mà mất cơ hội.","chuong":"@c0322"}],"blurb":"Bạn cũ Vương Lâm từ thời Kết Đan tại Tu Ma Hải (gặp nhau khoảng c0182–c0207). Nay Nguyên Anh hậu kỳ đại viên mãn — tiến chậm hơn VL rất nhiều. Áo tía, tóc hoa râm. Gặp lại VL tại đấu giá Luyện Khí Các — kinh ngạc khi biết VL đã Hóa Thần. Tặng VL cặp chuông thượng cổ để đổi lấy cơ hội ngồi dưới Luân Hồi Thụ cầu Hóa Thần. Bị lục diệp Thuật Chú Sư thôi hóa trong khi tĩnh tọa — trở thành khôi lỗi.","tabs":{"diem":[{"text":"Từ thời Kết Đan đã không đấu lại VL; Nguyên Anh cũng không lại; nay đạt đại viên mãn mà VL đã Hóa Thần.","chuong":"@c0309"},{"text":"Dùng thần thức quét phòng VL — bị đánh tan; tự mình lên gặp VL, ngẩng đầu bị liếc mắt suýt vỡ nguyên anh, lùi 3 bước mồ hôi trán.","chuong":"@c0309"},{"text":"Muốn góp 4.000 linh thạch giúp VL mua phương thuốc lục phẩm; VL từ chối.","chuong":"@c0310"}],"kinhLich":[{"bridge":true,"khoang":"@c0182–@c0207","text":"Gặp VL lần đầu thời Kết Đan ở Tu Ma Hải. Chia đôi nguyên anh và ngọc giản bản đồ làm kỷ niệm. Từng đánh không lại VL. (@c0182–@c0207 — theo hồi ký @c0309)"},{"chuong":"@c0309","importance":"major","tieuDe":"Tái ngộ Vương Lâm tại Luyện Khí Các","text":"Bị VL liếc mắt suýt vỡ nguyên anh — nhận ra VL là Hóa Thần. VL gợi nhớ chuyện chia đôi nguyên anh + ngọc giản bản đồ. Khâu Tứ Bình thất thanh 'Vương Lâm! Ngươi lại có thể Hóa Thần!' Lão Hồ nhớ ra năm xưa muốn lấy 'cực cảnh' trong người VL nhưng nay VL đã Hóa Thần — từ bỏ ý đồ. (@c0309)"},{"chuong":"@c0310","importance":"minor","tieuDe":"Muốn góp tiền mua phương thuốc — bị VL từ chối","text":"Muốn góp 4.000 thượng phẩm linh thạch giúp VL đấu giá phương thuốc lục phẩm; VL từ chối vì không muốn liên lụy người khác. Phương thuốc bị Chu Ngạn Hoành mua 3 vạn. (@c0310)"},{"chuong":"@c0322","importance":"normal","tieuDe":"Tặng cặp chuông — ngồi dưới Luân Hồi Thụ","text":"Tặng VL cặp chuông thượng cổ (bảo vật lấy từ bụng yêu thú) để được VL cho cưỡi Văn Thú bay vào tầng 3 và ngồi dưới Luân Hồi Thụ cầu cơ Hóa Thần. (@c0322)"},{"chuong":"@c0323","importance":"major","tieuDe":"Bị thôi hóa — trở thành khôi lỗi","text":"Trong khi ngồi tĩnh tọa dưới Luân Hồi Thụ cầu cơ, bị lục diệp Thuật Chú Sư thôi hóa: sức mạnh kỳ lạ bao phủ, không cử động được, dấu ấn kỳ dị trên trán không ngừng sinh trưởng. Hoàn toàn trở thành khôi lỗi (phù rối Tiên Di tộc). Túi trữ vật bị VL giật lấy trước khi bỏ chạy. (@c0323–@c0324)"}],"tuViMoc":[{"chuong":"@c0309","canhGioi":"Nguyên Anh hậu kỳ đại viên mãn","text":"Xác nhận khi tự xưng và VL nhận xét. Từ thời Kết Đan theo VL đến nay đạt đại viên mãn; có thể đang chuẩn bị thử Hóa Thần."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0182","quanHe":"Bạn cũ — kính nể","ghiChu":"Từ thời Kết Đan; từng không đánh lại VL; tái ngộ khi VL đã Hóa Thần, càng kính nể hơn. Tặng chuông đổi lấy cơ hội Hóa Thần @c0322; bị thôi hóa thành khôi lỗi @c0323.","tag":"ban-be","uuTien":80},{"ten":"Lão Hồ","gap":"@c0309","quanHe":"Quen biết tại Luyện Khí Các","ghiChu":"Cùng gặp VL tại đấu giá; có vẻ quen biết nhau trước.","tag":"dong-hanh"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0309","@c0310","@c0322","@c0323","@c0324"]},{"id":"lao-ho-luyen-khi-cac","name":"Lão Hồ","cn":"","aliases":["lão già đầu bạc","ông Hồ","chủ Luyện Khí Các"],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Khí Các","trangThai":"chu-so-huu"}],"canhGioiCaoNhat":"Hóa Thần kỳ @c0308","trangThai":"song","vaiTro":"Nhân vật phụ — chủ/backer Luyện Khí Các tại Tu Ma Hải","tinhCach":[{"text":"Nhạy cảm và có thần thông đặc biệt — nhận ra người qua hình thể dù đổi diện mạo; nhận ra VL dù không còn đội mũ rơm.","chuong":"@c0309"},{"text":"Biết điều dừng lại — từng muốn chiếm đoạt 'cực cảnh' trong VL lúc Kết Đan; nay VL Hóa Thần, ý đồ cũ tan thành mây khói, chủ động xin lỗi.","chuong":"@c0309"},{"text":"Thương nhân nhạy bén — nhận ra huyết kinh mạch Tuyết Vực trong tượng gỗ VL, mua trực tiếp và đổi ngọc giản 2 vạn linh thạch.","chuong":"@c0310"}],"blurb":"Tu sĩ Hóa Thần kỳ, chủ/backer Luyện Khí Các tại Tu Ma Hải. Có thần thông nhận dạng người qua hình thể. Từng gặp VL khi VL còn Kết Đan (bên ngoài Toái Tinh Loạn, VL đội mũ rơm) và có ý định chiếm đoạt 'cực cảnh' trong người VL. Sở hữu Thao thú của Luyện Khí Các.","tabs":{"diem":[{"text":"Thần thông nhận dạng hình thể — nhận ra VL là 'bạn cũ đội mũ rơm bên ngoài Toái Tinh Loạn' dù diện mạo đã thay đổi.","chuong":"@c0309"},{"text":"Năm xưa khi VL mới Kết Đan, lão nhìn ra trong cơ thể VL có 'lực lượng kỳ dị — cực cảnh trong truyền thuyết'; từng muốn thu làm đồ đệ để chiếm. Nay VL Hóa Thần, từ bỏ ý đồ.","chuong":"@c0309"},{"text":"Nhận ra huyết kinh mạch băng tuyết Tuyết Vực trong tượng gỗ VL; mua trực tiếp, tặng ngọc giản 2 vạn linh thạch.","chuong":"@c0310"}],"kinhLich":[{"bridge":true,"khoang":"@c0145–@c0207","text":"Gặp VL lần đầu bên ngoài Toái Tinh Loạn khi VL còn Kết Đan, đội mũ rơm. Nhận ra 'cực cảnh trong truyền thuyết' trong người VL; từng muốn thu VL làm đồ đệ rồi chiếm đoạt lực lượng đó. (Nhắc lại @c0309)"},{"chuong":"@c0308","importance":"normal","tieuDe":"Xuất hiện ở nền — nhận ra VL là khách VIP","text":"Xuất hiện âm thầm quan sát từ phía sau trong khu VIP Luyện Khí Các. Hứa La nhận ra VL là Hóa Thần qua khí tức. Lão Hồ ở phòng VIP tầng 3 cùng lầu với VL. (@c0308)"},{"chuong":"@c0309","importance":"major","tieuDe":"Lên lầu ba gặp VL — nhận ra 'bạn cũ'","text":"Lên tầng 3 gặp VL, nhận ra ngay đây là 'người đội mũ rơm bên ngoài Toái Tinh Loạn' nhờ thần thông hình thể. Kể chuyện hỏa tuyến trong động Toái Tinh Loạn nay to gấp mấy lần. Sau khi VL cho tái ngộ Khâu Tứ Bình, lão nhớ lại ý đồ cũ (chiếm cực cảnh) — nay VL Hóa Thần ngang ngửa, từ bỏ. (@c0309)"},{"chuong":"@c0310","importance":"normal","tieuDe":"Mua tượng gỗ VL — tặng ngọc giản 2 vạn","text":"Nhận ra huyết kinh mạch trong tượng gỗ VL là thuật băng tuyết khôi lỗi Tuyết Vực quốc. Trực tiếp mua tượng gỗ (giám định viên chỉ đánh giá 5.000), tặng VL ngọc giản màu tím trị giá 2 vạn thượng phẩm linh thạch đổi được tại bất kỳ cửa hàng Luyện Khí Các. (@c0310)"}],"tuViMoc":[{"chuong":"@c0308","canhGioi":"Hóa Thần kỳ","text":"Xác nhận khi Hứa La nhận ra VL là Hóa Thần — lão Hồ cũng Hóa Thần, hai người ở cùng tầng VIP."}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0145","quanHe":"Bạn cũ — từng có ý đồ","ghiChu":"Từng muốn chiếm 'cực cảnh' trong người VL. Nay VL Hóa Thần — từ bỏ, chủ động xin lỗi. Có quan hệ thương mại (mua tượng gỗ @c0310).","tag":"khac","uuTien":70},{"ten":"Luyện Khí Các","gap":"@c0308","quanHe":"Chủ/backer — sở hữu Thao thú","ghiChu":"Tổ chức đấu giá nổi tiếng Tu Ma Hải; lão Hồ là người đứng sau.","tag":"the-luc"}],"tuiDo":{"phapBao":[{"ten":"Thao thú của Luyện Khí Các","loai":"linh-thu","trangThai":"hien-co","moTa":"Sinh vật đặc biệt gắn liền với Luyện Khí Các, lão Hồ sở hữu. Công dụng cụ thể chưa được tiết lộ rõ trong c0309.","nguon":"@c0309"}],"congPhap":[{"ten":"Thần thông nhận dạng hình thể","moTa":"Thần thông đặc biệt cho phép nhận ra người qua hình thể dù diện mạo thay đổi. Bổ sung: có thể nhìn ra 'cực cảnh trong truyền thuyết' trong cơ thể tu sĩ.","nguon":"@c0309"}],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0308","@c0309","@c0310"]},{"id":"chu-ngan-hoanh","name":"Chu Ngạn Hoành","cn":"","aliases":["Tử Tâm (Phiêu Miểu tông)","nữ áo xanh","người phòng giữa lầu ba","Chu Ngạn Hoành"],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Chưa rõ","trangThai":"song","vaiTro":"Nhân vật mới — ẩn ý muốn giao dịch riêng với Vương Lâm về phương thuốc lục phẩm","tinhCach":[{"text":"Mưu lược — cố ý nâng giá lên 3 vạn (khi VL mới ra 2 vạn) rồi chờ VL tại vách núi, chủ động tạo cơ hội giao dịch riêng.","chuong":"@c0310"}],"blurb":"Nhân vật nữ bí ẩn, áo xanh, che mặt bằng lụa trắng. Mua phương thuốc lục phẩm với giá 3 vạn tại đấu giá Luyện Khí Các — cố tình đẩy giá để thu hút chú ý VL. Sau đó chủ động chờ VL ngoài thành Ma Nghịch, có hộ vệ Hóa Thần sơ kỳ theo.","tabs":{"diem":[{"text":"Biết VL là tu sĩ Hóa Thần và cố ý tạo cơ hội gặp gỡ riêng — mục đích chưa rõ, nhiều khả năng muốn đổi chác phương thuốc lục phẩm.","chuong":"@c0310"},{"text":"Có lão già hộ vệ Hóa Thần sơ kỳ (mới đột phá, chưa vững) theo bảo vệ.","chuong":"@c0310"}],"kinhLich":[{"chuong":"@c0310","importance":"normal","tieuDe":"Mua phương thuốc lục phẩm — chờ VL ngoài thành","text":"Từ phòng giữa lầu ba Luyện Khí Các nâng giá lên 3 vạn khi VL ra 2 vạn, đoạt phương thuốc lục phẩm. Sau đó rời thành Ma Nghịch, chờ VL tại vách núi 3.000 dặm, tự xưng 'vãn bối tham kiến VL'. Vương Lâm nhận ra ngay mục đích, đuổi kịp và uy hiếp lão hộ vệ."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0310","quanHe":"Chủ động tiếp cận","ghiChu":"Biết VL là Hóa Thần; cố tình tạo cơ hội gặp riêng. Mục đích chưa rõ.","tag":"khac","uuTien":80}],"tuiDo":{"phapBao":[{"ten":"Phương thuốc lục phẩm","loai":"dan-duoc-phuong-thuoc","trangThai":"hien-co","moTa":"Mua 3 vạn thượng phẩm linh thạch tại đấu giá Luyện Khí Các. Phong ấn còn nguyên. VL quyết tìm lấy.","nguon":"@c0310"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0310"]},{"id":"hua-la","name":"Hứa La","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Khí Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ","trangThai":"song","vaiTro":"Nhân viên cấp cao Luyện Khí Các tại thành Ma Nghịch","tinhCach":[{"text":"Cung kính, biết nhìn người — nhận ra Vương Lâm là tu sĩ Hóa Thần qua thái độ sợ hãi của Thiết Nham trước VL, từ đó phục vụ VIP đặc biệt.","chuong":"@c0308"}],"blurb":"Trung niên có địa vị cao trong Luyện Khí Các ở Tu Ma nội hải. Nhận ra Vương Lâm là tu sĩ Hóa Thần, cung kính mời lên phòng VIP lầu ba và phục vụ chu đáo.","tabs":{"diem":[{"text":"Nhận ra Vương Lâm là Hóa Thần nhờ quan sát thái độ sợ hãi của Thiết Nham (Nguyên Anh hậu kỳ) trước VL.","chuong":"@c0308"}],"kinhLich":[{"bridge":true,"khoang":"@c0308–@c0310","text":"Tiếp đãi Vương Lâm tại Luyện Khí Các — mời lên lầu ba VIP, báo cáo lão tổ, giới thiệu phương thuốc lục phẩm trong buổi đấu giá, bắt tượng gỗ VL ném xuống giao giám định viên."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách VIP Hóa Thần","ghiChu":"Cung kính phục vụ tại Luyện Khí Các"}],"tuiDo":{}},"nguon":["@c0308","@c0309","@c0310"]},{"id":"loi-oa","name":"Lôi Oa","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Yêu thú — loại lôi điện @c0353","trangThai":"song — đang ở sơn cốc ngoài vùng tiên di Sở quốc cùng Thiết Nham và Chu Như @c0353","vaiTro":"Nhân vật phụ — linh thú của Vương Lâm","tinhCach":[{"text":"Lười biếng nhưng giàu ký ức — nằm phơi nắng hồi tưởng cuộc sống ở chỗ cổ thần, nhớ VL và Văn thú.","chuong":"@c0353"}],"blurb":"Yêu thú lôi điện, được Vương Lâm bắt mang ra khỏi chỗ cổ thần — nơi nó lớn lên bằng cách đánh nhau giành thức ăn và học phun lôi cầu. Ở lại sơn cốc Sở quốc cùng Thiết Nham và Chu Như khi VL ra đi.","tabs":{"diem":[{"text":"Lớn lên ở chỗ cổ thần — chiến đấu với yêu thú, học phun lôi cầu, hoành hành; bị VL bắt mang đi.","chuong":"@c0353"}],"kinhLich":[{"chuong":"@c0353","importance":"minor","tieuDe":"Phơi nắng sơn cốc — nhớ chỗ cổ thần và VL","text":"Nằm lười biếng phơi nắng cách Thiết Nham hơn trăm trượng, đôi mắt thật lớn nhìn mặt trời. Hồi tưởng cuộc sống ở chỗ cổ thần — từ nhỏ đánh nhau với yêu thú cướp thức ăn/địa bàn, học phun lôi cầu, dần hoành hành. Nhớ VL (người bắt nó ra) và Văn thú. (@c0353)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0353","quanHe":"Chủ nhân — người bắt ra khỏi chỗ cổ thần","ghiChu":"VL bắt Lôi Oa mang ra khỏi chỗ cổ thần; Lôi Oa nhớ VL khi nằm phơi nắng.","tag":"cap-tren","uuTien":100}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0353"]},{"id":"tu-ma-lao-gia","name":"Tư Mã (lão giả)","cn":"","aliases":["lão giả Tử Chú thuật"],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"ngoai-vi-de-tu"}],"canhGioiCaoNhat":"Kết Đan hậu kỳ @c0355","trangThai":"song — bị Luyện Hồn Tông cuốn vào nội môn sau khi thua VL @c0356","vaiTro":"Nhân vật phụ — đối thủ đại hội Luyện Hồn Tông","tinhCach":[{"text":"Kiên định, mục tiêu rõ ràng — vào nội môn để kết hợp Tử Chú thuật với hồn phiên thuật, đạt đỉnh cao.","chuong":"@c0355"}],"blurb":"Ngoại vi đệ tử Luyện Hồn Tông tu luyện Tử Chú thuật nhiều năm. Lọt top 4 giải đấu, vào chung kết đấu với VL. Thi triển Tử Chú thuật nhưng VL hoá giải bằng ý niệm, lực cắn trả khiến lão phun máu hôn mê. Sư tôn Tư Mã cực kỳ cường đại.","tabs":{"diem":[{"text":"Ánh mắt âm trầm, tu Tử Chú thuật nhiều năm; sư tôn đánh giá đủ sức khiêu chiến Anh Biến kỳ.","chuong":"@c0355"},{"text":"Bị VL hoá giải Tử Chú thuật bằng ý niệm — phun máu, mắt vô thần, ngã nhào.","chuong":"@c0356"}],"kinhLich":[{"chuong":"@c0355","importance":"normal","tieuDe":"Chung kết đại hội — thi triển Tử Chú thuật đấu VL","text":"Ánh mắt kiên định, nhớ lời sư tôn về Tử Chú thuật. Quát 'tử', ngón tay điểm ra — hư không gợn sóng. VL đứng yên cảm thụ không phản công. Không biết VL đã nhìn thấu toàn bộ căn nguyên Tử Chú thuật ngay lập tức. (@c0355)"},{"chuong":"@c0356","importance":"normal","tieuDe":"Bại trận — bị cắn trả phun máu hôn mê","text":"VL dùng ý niệm hoá giải Tử Chú thuật, lực cắn trả quật ngược. Tư Mã run lên, phun máu, hai mắt vô thần, ngã nhào. Linh quang Luyện Hồn Tông cuốn vào nội môn — kết thúc ở Toả Thần phong. (@c0356)"}],"tuViMoc":[{"chuong":"@c0355","canhGioi":"Kết Đan hậu kỳ","text":"Tu vi khi đấu VL tại chung kết đại hội. Bị VL (Nguyên Anh hậu kỳ) hoá giải dễ dàng.","importance":"normal"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0355","quanHe":"Đối thủ thua cuộc","ghiChu":"Dùng Tử Chú thuật đấu VL trong chung kết — thua hoàn toàn, bị cắn trả phun máu. VL nhìn thấu căn nguyên Tử Chú thuật của lão.","tag":"ke-thu","uuTien":60}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0355","@c0356"]},{"id":"vuong-chan","name":"Vương Chấn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"noi-mon-de-tu"}],"canhGioiCaoNhat":"Không rõ (nội môn đệ tử) @c0356","trangThai":"song @c0356","vaiTro":"Nhân vật phụ — nội môn đệ tử dẫn đường Vương Lâm","tinhCach":[{"text":"Sùng kính Hóa Thần tu sĩ, mục tiêu trở thành Kim hoàn thứ mười; coi Tằng Ngưu là thiên hạ đệ nhất nhân dưới Anh Biến kỳ.","chuong":"@c0356"}],"blurb":"Nội môn đệ tử Luyện Hồn Tông, chủ trì trận chung kết và dẫn VL vào nội môn. Giới thiệu cấu trúc 3 phong + Cửu Kim hoàn + 2 Huyết hoàn. Hào hứng kể về Tằng Ngưu giết một Hóa Thần lão tổ Luyện Hồn Tông.","tabs":{"diem":[{"text":"Ôm quyền gọi VL là 'sư đệ', ánh mắt sùng kính cuồng nhiệt khi nhắc Hóa Thần — mục tiêu thành Kim hoàn thứ 10.","chuong":"@c0356"}],"kinhLich":[{"chuong":"@c0356","importance":"normal","tieuDe":"Dẫn VL vào nội môn — giới thiệu cấu trúc","text":"Ôm quyền chào, gọi 'sư đệ'. Dẫn VL bay qua nội môn đại trận, giới thiệu 3 phong (Luyện Hồn, Trừu Phách, Toả Thần), Cửu Kim hoàn (9 Hóa Thần bế quan), 2 Huyết hoàn (2 Thuỷ Tổ Anh Biến). Kể về Tằng Ngưu giết 1 lão tổ đi du lịch + vụ Độn Thiên Thuỷ Tổ chuẩn bị truy tìm thì Tằng Ngưu mất tích. (@c0356)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0356","quanHe":"Sư đệ (theo cách gọi)","ghiChu":"Dẫn VL vào nội môn, gọi là 'sư đệ Thanh Mộc'. Không biết VL là Tằng Ngưu.","tag":"dong-hanh","uuTien":40}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0356"]},{"id":"ngo-dao-khai","name":"Đại trưởng lão Luyện Hồn Phong","cn":"","aliases":["Đại trưởng lão Luyện Hồn Phong","lão nhân áo xanh Luyện Hồn Phong"],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"dai-truong-lao"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ — thiếu lĩnh ngộ ý cảnh là Hóa Thần @c0360","trangThai":"song — bị VL điểm hôn mê, mất Vạn Hồn Phiên và Tử Mộc Phiên Linh @c0360","vaiTro":"Nhân vật phụ — đại trưởng lão Luyện Hồn Phong, Luyện Hồn Tông","tinhCach":[{"text":"Tham vọng đạt Hóa Thần — 3 lần liều mình thách đấu Kim sắc Hồn Phiên dù nguy hiểm tột độ.","chuong":"@c0360"},{"text":"Biết thời thế — khi gặp thần thức mạnh hơn nhiều lần lão tổ Hóa Thần, lập tức quỳ xuống xưng 'tham kiến lão tổ'.","chuong":"@c0360"}],"blurb":"Đại trưởng lão Luyện Hồn Phong — một trong 3 người Nguyên Anh Hậu kỳ thủ hộ Luyện Hồn Tông khi toàn bộ Hóa Thần bế quan. Chỉ còn thiếu lĩnh ngộ ý cảnh là Hóa Thần, đã 3 lần liều mình chiến đấu Kim sắc Hồn Phiên. Sở hữu Vạn Hồn Phiên và Thần Phiên Linh mượn từ Toả Thần phong. Bị VL điểm hôn mê, mất toàn bộ pháp bảo. (+) Đại trưởng lão nội môn Luyện Hồn Phong của Luyện Hồn Tông, Nguyên Anh hậu kỳ đại viên mãn sắp Hóa Thần; tính lạnh lùng, mang oán khí với hai sư huynh và muốn đóng cửa không thu đệ tử. [CAN-SOAT-GOP]","tabs":{"diem":[{"text":"Sở hữu Vạn Hồn Phiên (chủ hồn Nguyên Anh hậu kỳ + 10 phó hồn). Mượn Thần Phiên Linh trọng bảo của Toả Thần phong.","chuong":"@c0360"},{"text":"Lần 3 chiến đấu Kim sắc Hồn Phiên: 2 Kỳ Lân trói bằng Thần Phiên Linh, con thứ 3 xuất hiện — sắp bỏ cuộc thì VL ra tay.","chuong":"@c0360"},{"text":"Lão nhân mặc áo xanh, ánh mắt sáng ngời, giọng lạnh lùng; muốn đóng cửa không thu đệ tử","chuong":"@c0356"}],"kinhLich":[{"chuong":"@c0356","importance":"normal","tieuDe":"Kiểm tra VL — Đại trưởng lão Luyện Hồn Phong","text":"Lão nhân mặc áo xanh, ánh mắt sáng ngời. Dùng uy áp Nguyên Anh hậu kỳ thử VL, ấn ngón tay vào mi tâm phóng hàn khí kiểm tra ký ức. Phát hiện tu vi VL là Kết Đan đại viên mãn (bị VL đánh lừa). An bài VL tự tu luyện không cần sư phụ. (@c0356)"},{"chuong":"@c0360","importance":"major","tieuDe":"Lần 3 chiến Kim sắc Hồn Phiên — bị VL điểm hôn mê, mất pháp bảo","text":"Dùng Vạn Hồn Phiên + Vạn hồn phệ + Huyết tế chiến Kỳ Lân phó hồn lần 3. Khi con thứ 3 xuất hiện sắp bỏ cuộc thì VL phóng thần thức khổng lồ (mạnh hơn lão tổ Hóa Thần gấp mấy lần). Kinh hãi quỳ xuống 'tham kiến lão tổ'. VL đập vỡ Kỳ Lân + điểm 1 cái khiến lão hôn mê. Mất Vạn Hồn Phiên và Tử Mộc Phiên Linh. (@c0360)"},{"chuong":"@c0356","importance":"normal","tieuDe":"Thử thách và an bài Vương Lâm","text":"Ngồi trong đại điện tối trên đỉnh Luyện Hồn Phong, dùng uy áp thử Vương Lâm (danh Thanh Mộc), ấn ngón tay vào mi tâm kiểm tra và phát hiện tu vi thực là Kết Đan đại viên mãn (bị Vương Lâm đánh lừa). An bài hắn đổi phục sức ở Thiên Các, chọn công pháp ở Tàng Kinh Các, tự mở động phủ tu luyện. Sau đó đối thoại bằng thần thức với hai sư huynh, bất mãn và đuổi họ đi, quát đừng xem vào việc Luyện Hồn Phong."}],"tuViMoc":[{"chuong":"@c0360","canhGioi":"Nguyên Anh hậu kỳ — cận Hóa Thần","text":"Chỉ còn thiếu lĩnh ngộ ý cảnh là Hóa Thần. Thần thức mạnh nhưng VL (thực chất Hóa Thần không ý cảnh) vượt xa.","importance":"normal"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0356","quanHe":"Bị áp chế — mất pháp bảo","ghiChu":"Kiểm tra VL khi vào nội môn; sau đó bị VL điểm hôn mê và mất Vạn Hồn Phiên + Tử Mộc Phiên Linh.","tag":"ke-thu","uuTien":70},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Tiếp nhận và an bài Vương Lâm (danh Thanh Mộc) vào Luyện Hồn Phong","ghiChu":"@c0356. Tranh giành VL với hai vị trưởng lão (sư huynh) của hai phong còn lại — Trừu Phách phong và Tỏa Thần phong; hai vị này đối thoại qua thần thức, có oán khí khi VL thuộc về Luyện Hồn Phong."}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]},"tuVi":"Nguyên Anh hậu kỳ đại viên mãn, sắp Hóa Thần chỉ thiếu lĩnh ngộ thiên đạo @c0356."},"nguon":["@c0356","@c0360"]},{"id":"hua-van","name":"Hứa Vân","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"noi-mon-de-tu"}],"canhGioiCaoNhat":"Kết Đan trung kỳ @c0357","trangThai":"song — đang ở gần động phủ VL tại Luyện Hồn Phong @c0360","vaiTro":"Nhân vật phụ — đệ tử Luyện Hồn Tông ở gần VL","tinhCach":[{"text":"Quyết đoán, lanh lợi — chủ động giải thích phương pháp chế tác Hồn Phiên 3 phần để lấy lòng VL.","chuong":"@c0357"},{"text":"Ngoài cứng trong mềm — biểu tình kiên cường thường ngày nhưng khi hôn mê lộ vẻ nhu nhược, bất lực.","chuong":"@c0359"}],"blurb":"Nội môn đệ tử Luyện Hồn Tông, Kết Đan trung kỳ. Trước đây dựa vào tu sĩ trung niên, sau khi tu sĩ đó thua VL liền chủ động theo VL. Giả làm thị thiếp Thanh Mộc để thu hồn phách thuận tiện. Cao hơn Lưu Vi một đầu, tính cách quyết đoán.","tabs":{"diem":[{"text":"Quần áo màu ngọc bích, thân thể cao hơn Lưu Vi. Chủ động giải thích phương pháp Hồn Phiên chia 3 phần để lấy lòng VL.","chuong":"@c0357"},{"text":"Giả làm thị thiếp Thanh Mộc — dùng danh tiếng VL bắt hồn phách dễ hơn nhiều.","chuong":"@c0358"}],"kinhLich":[{"chuong":"@c0357","importance":"normal","tieuDe":"Theo VL sau khi tu sĩ dựa vào thua cuộc","text":"Sau khi tu sĩ trung niên thua VL, chủ động giới thiệu bản thân, giải thích phương pháp chế tác Hồn Phiên chia 3 phần (Luyện Hồn/Trừu Phách/Toả Thần). Bị VL đuổi nhưng quyết ở gần động phủ VL để được nể mặt. (@c0357)"},{"chuong":"@c0358","importance":"normal","tieuDe":"Giả thị thiếp Thanh Mộc — bắt hồn phách thuận lợi","text":"Cùng Lưu Vi giả làm thị thiếp Thanh Mộc sư huynh. Bàn về lợi ích — bắt hồn phách nhiều hơn nhiều nhờ danh tiếng VL. Khi Quách Đông Kiện tới, tự xưng 'thị thiếp' và quát đuổi. Lo ngại bị phát hiện tuyên truyền. (@c0358)"},{"chuong":"@c0359","importance":"minor","tieuDe":"Bị VL điểm hôn mê khi Liễu Mi tới","text":"Bị VL điểm cách không hôn mê khi Liễu Mi xuất hiện. Biểu tình hôn mê lộ vẻ nhu nhược bất lực — ngược với vẻ kiên cường bên ngoài. VL quan sát và ngộ ra bản chất 'ngoài cứng trong mềm' của nàng. (@c0359)"},{"chuong":"@c0360","importance":"minor","tieuDe":"Tỉnh dậy — tạo động phủ tu luyện","text":"Tỉnh dậy sau khi hôn mê, cùng Lưu Vi tạo động phủ nhỏ tu luyện riêng, không giao tiếp VL. (@c0360)"}],"tuViMoc":[{"chuong":"@c0357","canhGioi":"Kết Đan trung kỳ","text":"Tu vi xác nhận khi được giới thiệu trong nhóm tu sĩ trung niên.","importance":"normal"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0357","quanHe":"Dựa vào danh tiếng","ghiChu":"Ở gần động phủ VL để được nể mặt; giả thị thiếp Thanh Mộc bắt hồn phách. Bị VL điểm hôn mê @c0359.","tag":"khac","uuTien":50},{"ten":"Lưu Vi","gap":"@c0357","quanHe":"Sư muội","ghiChu":"Đi cùng từ khi theo VL; thường xuyên bàn việc cùng nhau.","tag":"dong-hanh","uuTien":60}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0357","@c0358","@c0359","@c0360"]},{"id":"luu-vi","name":"Lưu Vi","cn":"","aliases":["sư muội của Hứa Vân"],"gioiTinh":"nu","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"noi-mon-de-tu"}],"canhGioiCaoNhat":"Kết Đan trung kỳ (ước tính — muốn đạt Kết Đan hậu kỳ bằng Bách Hồn phiên) @c0358","trangThai":"song — đang ở gần động phủ VL tại Luyện Hồn Phong @c0360","vaiTro":"Nhân vật phụ — đệ tử Luyện Hồn Tông, sư muội Hứa Vân","tinhCach":[{"text":"Ngoài mềm trong cứng — dáng lả lướt dịu dàng bên ngoài nhưng khi hôn mê lộ vẻ tàn nhẫn kiên định.","chuong":"@c0359"}],"blurb":"Nội môn đệ tử Luyện Hồn Tông, sư muội Hứa Vân. Dáng người nhỏ nhắn thấp hơn Hứa Vân một đầu, lả lướt. Mong luyện chế Bách Hồn phiên để đạt Kết Đan hậu kỳ. Cùng Hứa Vân giả làm thị thiếp Thanh Mộc để bắt hồn phách thuận lợi.","tabs":{"diem":[{"text":"Dáng người nhỏ nhắn, thấp hơn Hứa Vân một đầu, lả lướt; mong luyện Bách Hồn phiên đạt Kết Đan hậu kỳ.","chuong":"@c0358"}],"kinhLich":[{"chuong":"@c0357","importance":"minor","tieuDe":"Sư muội Hứa Vân — theo dựa vào VL","text":"Cùng Hứa Vân dựa vào tu sĩ trung niên bị VL đánh bại. Tướng mạo thượng đẳng. Lo lắng hỏi Hứa Vân cách xử lý khi bị VL đuổi. Quyết định cùng sư tỷ ở gần nơi VL lập động phủ. (@c0357)"},{"chuong":"@c0358","importance":"normal","tieuDe":"Bàn chuyện bắt hồn phách — mong luyện Bách Hồn phiên","text":"Bàn với Hứa Vân: số hồn phách bắt nhiều hơn nhiều nhờ danh tiếng Thanh Mộc. Mong luyện chế Bách Hồn phiên để đạt Kết Đan hậu kỳ — cần bắt đủ hồn phách. Lo ngại bị phát hiện tuyên truyền. (@c0358)"},{"chuong":"@c0359","importance":"minor","tieuDe":"Bị VL điểm hôn mê khi Liễu Mi tới","text":"Bị VL điểm cách không hôn mê. Biểu tình hôn mê lộ vẻ tàn nhẫn kiên định — ngược với dáng vẻ lả lướt dịu dàng thường ngày. VL ngộ ra bản chất 'ngoài mềm trong cứng' của nàng. (@c0359)"},{"chuong":"@c0360","importance":"minor","tieuDe":"Tỉnh dậy — tạo động phủ tu luyện","text":"Tỉnh dậy cùng Hứa Vân, tạo động phủ nhỏ tu luyện riêng. (@c0360)"}],"tuViMoc":[{"chuong":"@c0358","canhGioi":"Kết Đan trung kỳ hoặc thấp hơn (ước tính)","text":"Mong đạt Kết Đan hậu kỳ bằng Bách Hồn phiên — hàm ý tu vi hiện tại chưa đến đó.","importance":"minor"}],"nhanMach":[{"ten":"Hứa Vân","gap":"@c0357","quanHe":"Sư tỷ","ghiChu":"Luôn đi cùng và bàn việc với sư tỷ.","tag":"dong-hanh","uuTien":60},{"ten":"Vương Lâm","gap":"@c0357","quanHe":"Dựa vào danh tiếng","ghiChu":"Ở gần động phủ VL; bị VL điểm hôn mê @c0359.","tag":"khac","uuTien":40}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0357","@c0358","@c0359","@c0360"]},{"id":"quach-dong-kien","name":"Quách Đông Kiện","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"noi-mon-de-tu"}],"canhGioiCaoNhat":"Nguyên Anh sơ kỳ @c0358","trangThai":"song — quy phục VL, giao Hồn Phiên hai kim tuyến @c0359","vaiTro":"Nhân vật phụ — đệ tử Luyện Hồn Tông đấu VL","tinhCach":[{"text":"Có phong thái thần tiên, tự tin — tới bái phỏng 'Thanh Mộc', bị từ chối thì nổi giận phóng thanh long.","chuong":"@c0358"},{"text":"Biết thời thế — khi thấy VL thi triển Hồn Tuyền liền hoàn toàn từ bỏ chống cự.","chuong":"@c0359"}],"blurb":"Nội môn đệ tử Luyện Hồn Tông, Nguyên Anh sơ kỳ. Nam tử trung niên tướng mạo anh tuấn, tóc dài, áo bào màu tro — vài phần phong thái thần tiên. Sở hữu Hồn Phiên hai kim tuyến (Thiên Hồn Phiên) chứa hồn phách Nguyên Anh kỳ. Đến bái phỏng VL, bị từ chối nổi giận, phóng thanh long bị VL phá — giao Hồn Phiên khi VL thi triển Hồn Tuyền.","tabs":{"diem":[{"text":"Sở hữu Hồn Phiên hai kim tuyến (Thiên Hồn Phiên) chứa hồn phách Nguyên Anh kỳ có hai sừng.","chuong":"@c0358"},{"text":"Người thứ hai trong đệ tử Luyện Hồn Phong từng luyện ra Hồn Tuyền (trước VL).","chuong":"@c0359"}],"kinhLich":[{"chuong":"@c0358","importance":"normal","tieuDe":"Tới bái phỏng Thanh Mộc — giao chiến rồi bị áp chế","text":"Bay tới xin gặp Thanh Mộc, bị Hứa Vân chặn. Nổi giận quát 'lừa gạt!', phóng thanh long tấn công động phủ. VL bước ra phá tan bằng bàn tay hư không, thi triển Thiên Hồn Phiên Huyễn Ảnh (đầu lâu khổng lồ sau lưng). Kinh hãi lùi lại. Phóng Hồn Phiên hai kim tuyến, kêu gọi hồn phách Trúc Cơ, Kết Đan, Nguyên Anh tấn công. (@c0358)"},{"chuong":"@c0359","importance":"normal","tieuDe":"Quy phục VL — giao sinh hồn Nguyên Anh","text":"Khi thấy VL thi triển Hồn Tuyền hút sạch hồn phách, hoàn toàn từ bỏ chống cự. Chúc mừng VL là người thứ 3 luyện ra Hồn Tuyền (chỉ 3 tháng). Khai: sinh hồn Nguyên Anh (hai sừng) đổi từ Tô Kim Thế ở Trừu Phách phong bằng Bách Hồn Phiên 900 hồn phách. (@c0359)"}],"tuViMoc":[{"chuong":"@c0358","canhGioi":"Nguyên Anh sơ kỳ","text":"Tu vi xác nhận khi VL quét thần thức đánh giá đối thủ.","importance":"normal"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0358","quanHe":"Bại trước — giao Hồn Phiên","ghiChu":"Đến bái phỏng VL rồi xung đột; bị áp chế Thiên Hồn Phiên Huyễn Ảnh và Hồn Tuyền; cuối cùng giao sinh hồn Nguyên Anh.","tag":"ke-thu","uuTien":50}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0358","@c0359"]},{"id":"don-thien","name":"Độn Thiên","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"thuy-to"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ (@c0363)","trangThai":"sống — đang bế quan @c0370","vaiTro":"Thủy tổ Luyện Hồn Tông — người tặng Thập Ức Tôn Hồn Phiên cho VL","tinhCach":[{"text":"Tính toán xa, hào phóng — đợi VL 2 năm, tặng ba phần đại lễ (khôi phục nguyên thần, nâng tu vi, Thập Ức Hồn Phiên bản sao).","chuong":"@c0363"},{"text":"Mạnh miệng và cứng rắn — xua Liễu Mi khỏi ngàn dặm, không ngại đắc tội Chu Tước quốc.","chuong":"@c0363"}],"blurb":"Thủy tổ Luyện Hồn Tông, Anh Biến hậu kỳ, một trong hai Thủy tổ Huyết hoàn. Mặc trường bào xanh nhạt, sắc mặt xám xịt nhưng mắt rất sáng. Đợi VL 2 năm rồi tặng ba phần đại lễ: xua Liễu Mi, khôi phục nguyên thần VL bằng tiên lực (200 năm chưa dùng), dùng Thập Ức Hồn Phiên nâng tu vi VL lên Hóa Thần hậu kỳ. Chỉ định VL làm người kế thừa, giao bản sao hồn phiên + ngọc giản trận pháp định vị trước khi bế quan. Muốn VL thu hồn phách mình khi lão chết.","tabs":{"diem":[{"text":"Anh Biến hậu kỳ nhưng dám đối kháng tu sĩ Vấn Đỉnh nhờ Thập Ức Hồn Phiên.","chuong":"@c0363"},{"text":"200 năm không dùng tiên lực; lần đầu dùng để khôi phục nguyên thần VL trong 5 tức.","chuong":"@c0363"}],"kinhLich":[{"chuong":"@c0356","importance":"minor","text":"Nhắc tên gián tiếp: Vương Chấn giới thiệu cấu trúc Luyện Hồn Tông có 2 Huyết hoàn (2 Thuỷ tổ Anh Biến bế quan), trong đó có Độn Thiên Thuỷ tổ. Kể chuyện Tằng Ngưu từng giết một Hóa Thần lão tổ Luyện Hồn Tông đi du lịch; Độn Thiên chuẩn bị truy tìm thì Tằng Ngưu mất tích."},{"chuong":"@c0362","importance":"bridge","text":"Thanh âm già nua từ vòng sáng đỏ vang lên khi VL đang đối đầu 9 Hóa Thần của tông: 'Tiểu hữu! Lão phu chờ ngươi đã lâu.' (@c0362)"},{"chuong":"@c0363","importance":"major","tieuDe":"Tặng ba phần đại lễ — nhận VL làm người kế thừa","text":"Xuất hiện mặc trường bào xanh nhạt, xua chín vị Hóa Thần đi. Tặng VL ba lễ: (1) Đuổi Liễu Mi khỏi ngàn dặm Luyện Hồn Tông trong 10 tức, dọa giết bất chấp thân phận đệ tử Chu Tước; Liễu Mi thấy Thập Ức Hồn Phiên biến sắc, cắn răng rời đi. (2) Dùng uy áp Anh Biến kỳ + tiên lực (200 năm chưa dùng) khôi phục hoàn toàn nguyên thần VL trong 5 tức — phong ấn Tôn Thái tan, tu vi khôi phục Hóa Thần trung kỳ (tinh tiến hơn trước). (3) Dùng Thập Ức Hồn Phiên nâng tu vi VL lên Hóa Thần hậu kỳ đỉnh phong. Tiết lộ muốn VL thu hồn phách mình khi lão chết — ám chỉ VL kế thừa hồn phiên + Luyện Hồn Tông. (@c0363)"},{"chuong":"@c0367","importance":"normal","tieuDe":"Gặp VL sau đại lễ — xác nhận ý cảnh Anh Biến","text":"Gặp VL sau khi VL đột phá ý cảnh Anh Biến. Xác nhận ý cảnh VL đạt cấp Anh Biến (Anh Biến biến cấp). Tiết lộ nguyên nhân giúp đỡ VL — có liên quan mục đích lâu dài của lão với Luyện Hồn Tông. Giao ngọc giản trận pháp định vị + dặn dò trước khi vào bế quan. (@c0367)"},{"chuong":"@c0369","importance":"bridge","text":"Đang bế quan trong vòng tròn đỏ như máu tại Luyện Hồn tông. Đoán trước VL sẽ tới, để lại túi trữ vật (ngọc giản + Thập Ức Tôn Hồn Phiên bản sao) nhờ Âu Dương Thiên giao cho VL. Chỉ định VL là người kế thừa Luyện Hồn tông (Thiếu tông chủ). (@c0369)"},{"chuong":"@c0370","importance":"bridge","text":"Thở dài khi VL rời Luyện Hồn tông — ngụ ý lão biết diễn biến nhưng không can thiệp. (@c0370)"},{"importance":"normal","text":"Tông chủ đương nhiệm Luyện Hồn tông, sở hữu Thập Ức Tôn Hồn Phiên; thọ nguyên còn chưa tới 2 năm. Giao ước với Vương Lâm: trao Hồn Phiên + Luyện Hồn tông, đổi lời hứa VL xây Thiên Thê tháp 999 tầng + đưa tông lên lục cấp.","chuong":"@c0387"},{"importance":"normal","text":"Dẫn Vương Lâm cướp tiên ngọc khắp Bỉ Lô quốc theo truyền thống Luyện Hồn tông để gom đủ tiên ngọc cho VL đột phá Anh Biến.","chuong":"@c0388"},{"importance":"normal","text":"Dùng Thập Ức Tôn Hồn Phiên đẩy lui cửu diệp thuật chú sư Tiên Di tộc (Mộc Nghiệp) trong cuộc chiến thứ hai của Tiên Di tộc.","chuong":"@c0389"},{"importance":"normal","text":"Cởi mở bí mật Tôn Hồn Phiên cho người kế thừa Vương Lâm; thay mặt hứa không vào Luyện Hồn tông nửa bước.","chuong":"@c0390"}],"tuViMoc":[{"chuong":"@c0363","canhGioi":"Anh Biến hậu kỳ","text":"Tự xưng + tiết lộ 200 năm chưa dùng tiên lực khi giúp VL.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0362","quanHe":"Người kế thừa được chọn","ghiChu":"Đợi 2 năm, tặng ba lễ + bản sao hồn phiên. Gọi VL 'Tiểu hữu'. Muốn VL thu hồn phách mình khi chết.","tag":"do-truyen"}],"tuiDo":{"phapBao":[{"ten":"Thập Ức Hồn Phiên (chủ phiên)","loai":"phap-bao","trangThai":"hien-co — đang bế quan bên cạnh","moTa":"Chí bảo Luyện Hồn Tông — lá cờ lớn cao 3 trượng, chứa vô số hồn phách tổ tiên tự nguyện hiến tế, trong đó có ít nhất 12 hồn phách Anh Biến kỳ màu vàng tím. Có nó tông bất diệt, mất nó tông diệt. Độn Thiên nhờ bảo vật này dám đối kháng tu sĩ Vấn Đỉnh dù chỉ Anh Biến hậu kỳ. Chủ phiên đang bên lão bế quan; bản sao đã trao VL.","nguon":"@c0363"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0356","@c0362","@c0363","@c0367","@c0369","@c0370","@c0374","@c0387","@c0388","@c0389","@c0390"]},{"id":"to-kim-the","name":"Tô Kim Thế","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông — Trừu Phách phong","trangThai":"de-tu"}],"canhGioiCaoNhat":"Chưa rõ cụ thể — đệ tử tu vi cao nhất Trừu Phách phong (trừ Đại trưởng lão) (@c0362)","trangThai":"sống — ở Trừu Phách phong @c0362","vaiTro":"Đệ tử Trừu Phách phong — bán ngọc giản cho VL","tinhCach":[{"text":"Thẳng thắn — không mặc cả, chủ động đề nghị giao dịch công bằng.","chuong":"@c0362"}],"blurb":"Đệ tử tu vi cao nhất Trừu Phách phong (trừ Đại trưởng lão) của Luyện Hồn Tông. Sở hữu ngọc giản Trừu Phách (lấy từ Luyện Hồn phong nhiều năm trước) và Luyện Hồn phiên còn thiếu hơn 300 tử hồn để thành Thiên hồn phiên. Giao dịch thẳng thắn với VL: đổi ngọc giản lấy 300 tử hồn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0362","importance":"normal","tieuDe":"Đổi ngọc giản Trừu Phách lấy 300 tử hồn","text":"Đệ tử tu vi cao nhất Trừu Phách phong. Sở hữu ngọc giản Trừu Phách ghi chép 3 thần thông (Định Thần, Dẫn Hồn, Tự Cổ) và Luyện Hồn phiên thiếu hơn 300 tử hồn nữa thành Thiên hồn phiên. Chủ động đề nghị giao dịch với VL (xưng danh Thanh Mộc): đổi ngọc giản hồng sắc lấy 300 tử hồn để hoàn thành hồn phiên. VL đồng ý. Tính cách thẳng thắn. (@c0362)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0362","quanHe":"Bán hàng — giao dịch","ghiChu":"Đổi ngọc giản Trừu Phách lấy 300 tử hồn; không biết VL thật ra là ai.","tag":"giao-dich"}],"tuiDo":{"phapBao":[{"ten":"Luyện Hồn phiên (gần Thiên hồn phiên)","loai":"phap-bao","trangThai":"hoan-chinh-sau-giao-dich","moTa":"Thiếu hơn 300 tử hồn nữa thành Thiên hồn phiên; nhận 300 tử hồn từ VL để hoàn thành.","nguon":"@c0362"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0362"]},{"id":"au-duong-thien","name":"Âu Dương Thiên","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Luyện Hồn Tông","trangThai":"de-tu-hoa-than"}],"canhGioiCaoNhat":"Hóa Thần (@c0369)","trangThai":"sống — ở Luyện Hồn tông @c0369","vaiTro":"Đệ tử Luyện Hồn Tông — người trung gian giao túi trữ vật Độn Thiên cho VL","tinhCach":[{"text":"Trung thành và thẳng thắn — ở tông 700 năm, dù khiếp sợ sức mạnh trong túi trữ vật vẫn không nảy lòng tham.","chuong":"@c0369"}],"blurb":"Trung niên nam tử, tu sĩ Hóa Thần, ở Luyện Hồn Tông 700 năm. Canh chín vòng sáng vàng chờ VL theo lệnh Độn Thiên. Gọi VL là 'Thiếu tông chủ'. Giao túi trữ vật (ngọc giản + Thập Ức Tôn Hồn Phiên bản sao) cho VL. Từng dùng thần thức kiểm tra túi trữ vật — khiếp sợ, nhưng không nảy lòng tham vì trung thành với tông.","tabs":{"diem":[{"text":"Ở Luyện Hồn tông 700 năm — lần đầu thấy Độn Thiên giao vật cho người khác, xác nhận đây là sự kiện chưa từng có.","chuong":"@c0369"}],"kinhLich":[{"chuong":"@c0369","importance":"normal","tieuDe":"Giao túi trữ vật Độn Thiên — xác nhận VL là người kế thừa","text":"Xuất hiện canh chín vòng sáng vàng tại Luyện Hồn tông, cung kính gọi VL là 'Thiếu tông chủ'. Thông báo Độn Thiên đã bế quan và để lại túi trữ vật cho VL. Kể: ở tông 700 năm, lần đầu thấy Độn Thiên giao vật cho người ngoài — VL không phải chủ phiên nhưng là phân thân (người kế thừa). Từng âm thầm dùng thần thức kiểm tra túi trữ vật — khiếp sợ sức mạnh bên trong, nhưng trung thành với tông nên không nảy lòng tham. (@c0369)"}],"tuViMoc":[{"chuong":"@c0369","canhGioi":"Hóa Thần","text":"Xuất hiện canh giữ, tu vi xác nhận qua ngữ cảnh.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0369","quanHe":"Phục vụ — coi là Thiếu tông chủ","ghiChu":"Giao túi trữ vật theo lệnh Độn Thiên.","tag":"the-luc"},{"ten":"Độn Thiên","gap":"@c0369","quanHe":"Thủy tổ — cấp trên","ghiChu":"Ở tông 700 năm, nhận lệnh Độn Thiên canh giữ và giao vật cho VL.","tag":"the-luc"}],"tuiDo":{"phapBao":[],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0369"]},{"id":"truong-lao-toc-bac-cu-ma-toc","name":"Trưởng lão tóc bạc Cự Ma tộc","cn":"","aliases":["Lão già tóc bạc trắng như cước"],"gioiTinh":"nam","theLuc":[{"ten":"Cự Ma tộc","trangThai":"truong-lao"}],"canhGioiCaoNhat":"Chưa rõ — bị VL đánh 1 quyền phun máu dù đã biến khổng lồ 10 trượng (@c0370)","trangThai":"bị phong ấn tu vi — khí xám chui vào người @c0370","vaiTro":"Trưởng lão Cự Ma tộc — người đầu tiên đối mặt VL, ra lệnh toàn tộc giết Tằng Ngưu","tinhCach":[{"text":"Cứng rắn với kẻ địch — khi VL nói 'giết', lão giận quá hóa cười và lập tức ra lệnh toàn tộc.","chuong":"@c0370"}],"blurb":"Lão già tóc bạc trắng như cước, trưởng lão Cự Ma tộc. Khi VL thuấn di vào giữa tộc và xưng danh 'Tằng Ngưu', lão từ hư không xuất hiện. Khi VL tuyên bố 'giết', lão giận quá hóa cười, dùng lệnh bài trưởng lão (nổ thành tro bụi, phát sóng vô hình) ra lệnh toàn tộc giết Tằng Ngưu. Biến khổng lồ 10 trượng, cầm cự phủ có tia chớp tím. Bị VL thốt 'Biến!' chấn Nguyên Thần, dùng thần thông ổn định rồi tiếp tục bổ búa — bị 1 quyền của VL phun máu lùi mấy trượng, bị khí xám phong ấn.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0370","importance":"normal","tieuDe":"Ra lệnh toàn tộc giết Tằng Ngưu — bị phong ấn","text":"Từ hư không xuất hiện khi VL thuấn di vào giữa tộc. Hỏi danh tính — VL đáp 'Tằng Ngưu', cả tộc kinh hãi. VL tuyên bố tới giết lão tổ — lão giận quá hóa cười, vỗ túi trữ vật lấy lệnh bài đen (trưởng lão), lệnh toàn tộc dùng mọi biện pháp giết Tằng Ngưu. Lệnh bài nổ thành tro bụi, sóng vô hình phủ khắp tộc. Mấy trăm tộc nhân hét lớn, biến khổng lồ, xuất Khai Thiên phủ. Lão biến khổng lồ 10 trượng, cầm cự phủ lớn có tia chớp tím. Bị VL thốt 'Biến!' — Nguyên Thần chấn động, nghiêng ngả; dùng thần thông ổn định, tiếp tục bổ búa. Bị 1 quyền VL đánh phun máu lùi mấy trượng va vào tộc nhân. Bị 2 luồng khí xám từ bức tranh Sinh Tử luân hồi chui vào cơ thể — tu vi bị phong ấn. (@c0370)"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","gap":"@c0370","quanHe":"Kẻ thù — đã bị đánh bại","ghiChu":"Lệnh toàn tộc giết VL nhưng bị phong ấn tu vi.","tag":"doi-thu"}],"tuiDo":{"phapBao":[{"ten":"Lệnh bài đen (trưởng lão Cự Ma tộc)","loai":"phap-bao","trangThai":"da-dung-tan","moTa":"Dùng 1 lần — nổ thành tro bụi, phát sóng vô hình khuếch tán phủ khắp tộc, truyền lệnh giết Tằng Ngưu tới mọi tộc nhân.","nguon":"@c0370"}],"congPhap":[],"danDuoc":[],"linhThu":[],"khac":[]}},"nguon":["@c0334","@c0370"]},{"id":"dinh-nhi","name":"Đình Nhi","cn":"","aliases":["cô gái áo trắng","bản vương"],"gioiTinh":"nu","theLuc":[{"ten":"Kiếm hồn của Chu Dật","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Bề trên của tiên nhân (vượt tiên nhân)","trangThai":"tu-vong","blurb":"Tàn hồn sinh ra từ sự si tình của Chu Dật, tự nhận không phải tiên quân thực sự; hơn 2.000 năm thủ hộ kiếm tiên, cuối cùng phóng hết tiên lực hy sinh cứu Chu Dật.","vaiTro":"Tàn hồn thủ hộ kiếm tiên, người yêu của Chu Dật","tinhCach":[{"text":"Ánh mắt bình thản không gợn sóng, lạnh lùng khi giao chiến","chuong":"@c0299"},{"text":"Si tình, cam tâm hy sinh toàn bộ vì Chu Dật","chuong":"@c0300"}],"tabs":{"diem":[{"text":"Tên Đình Nhi do Chu Dật đặt; nàng tự nhận không phải Đình Nhi nhưng thích cái tên này, từng được Chu Dật sắc phong làm Kiếm Hồn","chuong":"@c0296"},{"text":"Bản chất là tàn hồn, được sinh ra bởi sự si tình của Chu Dật, không phải tiên quân thực sự (tiên quân thực sự không có tình cảm)","chuong":"@c0300"}],"kinhLich":[{"chuong":"@c0296","importance":"normal","tieuDe":"Ra mặt — tự xưng 'bản vương', sắc phong Chu Dật làm Kiếm Hồn","text":"Xuất hiện dưới dạng cô gái áo trắng, tự xưng 'bản vương'. Tự nhận không phải Đình Nhi (tên do Chu Dật đặt) nhưng thích cái tên ấy. Sắc phong Chu Dật làm Kiếm Hồn — hé lộ mối liên hệ giữa nàng và Chu Dật."},{"chuong":"@c0299","importance":"major","tieuDe":"Chiến Lăng Thiên Hậu, hao tiên khí","text":"Nghênh tiếp Lăng Thiên Hậu xông tới, vung tay phá vỡ hơn trăm kiếm ảnh; mỗi lần ra tay tử khí tràn ra vì tiên khí hơn 2000 năm đang cạn. Giữ lại hơn nửa tiên lực để biến hồn cho Chu Dật, lần lượt rút kiếm hồn ném vào mi tâm kim long. Bị Lăng Thiên Hậu nhận ra là bề trên của tiên nhân nhưng công kích càng yếu."},{"chuong":"@c0300","importance":"major","tieuDe":"Hy sinh cứu Chu Dật rồi chết","text":"Phóng thích toàn bộ tiên lực còn lưu giữ tạo màn sương mười trượng đẩy Lăng Thiên Hậu ra. Để lại lời trăng trối hé lộ bản chất tàn hồn và hơn 2.000 năm thủ hộ, nở nụ cười vui vẻ lần đầu rồi thi thể ngã xuống xuyên qua thân Chu Dật. Hai thanh kiếm tiên hóa bạch quang vọt về phía Vương Lâm."},{"chuong":"@c0306","importance":"minor","tieuDe":"Nhắc gián tiếp","text":"Vương Lâm kể chuyện Chu Dật và Đình Nhi cho Lý Mộ Uyển nghe; thi thể nàng nằm trong bảo tháp Chu Dật, được thả tại thung lũng âm hàn Sở quốc."}],"tuVi":"Tiên nhân cấp, kiểm soát kiếm tiên (một chỉ phá hai kiếm ảnh Lăng Thiên Hậu @c0298); thực chất là bề trên của tiên nhân, vượt tiên nhân — nếu không giữ tiên lực biến hồn Chu Dật thì một điểm tay đủ giết Lăng Thiên Hậu @c0299.","nhanMach":[{"ten":"Chu Dật","tag":"ban-be","quanHe":"Người yêu — Đình Nhi là tàn hồn sinh ra từ sự si tình của Chu Dật, hy sinh để biến hồn cứu chàng","ghiChu":"@c0300"},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Kẻ tranh đoạt kiếm tiên, bị nàng đả thương nặng","ghiChu":"@c0299"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0296","@c0299","@c0300","@c0306"]},{"id":"au-duong-tu","name":"Âu Dương Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh trung kỳ","trangThai":"song","blurb":"Luyện đan sư Vân Thiên Tông, một lòng vì luyện đan tới mức quên hết phàm tục; người có khả năng Hóa Thần nhất tông, cuối cùng luyện thành lục phẩm linh đan — giấc mộng cả đời.","vaiTro":"Luyện đan sư chủ lực của Vương Lâm","tinhCach":[{"text":"Chuyên tâm luyện đan, sớm cắt đứt ý niệm phàm tục, đắm chìm tới mức quên ăn quên ngủ","chuong":"@c0306"},{"text":"Khi nghiên cứu đan phương cao cấp thì táo bạo gắt gỏng, không kiên nhẫn trả lời ai","chuong":"@c0312"}],"tabs":{"diem":[{"text":"Được mô tả một lòng vì luyện đan, không ai lo hắn tiết lộ thân phận Tằng Ngưu ra ngoài","chuong":"@c0306"},{"text":"Vương Lâm nhận xét trong Vân Thiên Tông chỉ Âu Dương Tử có khả năng Hóa Thần nhất vì sống vì luyện đan nên có thể cảm ngộ thiên đạo","chuong":"@c0312"}],"kinhLich":[{"chuong":"@c0303","importance":"minor","tieuDe":"Nhắc tên — nghiên cứu Tục Mệnh đan","text":"Liễu Phỉ nói Âu Dương Tử đã nghiên cứu Tục Mệnh đan nhiều năm sắp thành công, nhưng Lý Mộ Uyển bác bỏ rằng dù luyện thành cũng chỉ kéo thêm chút sức sống."},{"chuong":"@c0311","importance":"major","tieuDe":"Tìm xong dược liệu thay thế lục phẩm","text":"Được gọi đến nghiên cứu phương thuốc lục phẩm Quy Nguyên đan, nhìn đan phương như thấy điều theo đuổi cả đời. Gần như một ngày một đêm nghiên cứu xong 137 loại dược liệu; suốt hai năm mất ăn mất ngủ, cuối cùng tìm được dược liệu thay thế ba loại cuối bằng 34 loại dược liệu phối hợp."},{"chuong":"@c0312","importance":"major","tieuDe":"Luyện thành lục phẩm linh đan","text":"Đắm chìm vào luyện đan hơn sáu năm, vài lần bị dừng ở một khâu rồi mới đột phá; cuối cùng luyện thành lục phẩm linh đan màu lửa đỏ, hưng phấn tuyên bố thành công rồi ngã xuống vì tâm thần hao tổn quá độ (không chết). Hoàn thành giấc mộng cả đời."},{"chuong":"@c0313","importance":"minor","tieuDe":"Bất tỉnh, được mang về tông","text":"Sau khi luyện xong, tâm thần hao tổn bất tỉnh; được Thiết Nham ôm cùng Lữ Phi bay đi Vân Thiên Tông theo lệnh Vương Lâm."}],"tuVi":"Tu vi dừng ở Nguyên Anh trung kỳ; Vương Lâm đánh giá nếu đạt Nguyên Anh hậu kỳ đại viên mãn thì Hóa Thần trở ngại không lớn vì hắn sống vì luyện đan nên dễ cảm ngộ thiên đạo @c0312.","nhanMach":[{"ten":"Lý Mộ Uyển","tag":"dong-minh","quanHe":"Cùng nghiên cứu đan phương; đan dược hắn luyện vốn chuẩn bị cho nàng","ghiChu":"@c0307"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Giao đan phương lục phẩm cho hắn nghiên cứu và luyện chế","ghiChu":"@c0311"},{"ten":"Thiên Vân Tử","tag":"su-mon","quanHe":"Ngũ cấp luyện đan sư cuối cùng VTT đã chết; nếu còn sống cùng nghiên cứu sẽ nhanh hơn","ghiChu":"@c0311"}],"tuiDo":{"phapBao":[],"danDuoc":[{"ten":"Lục phẩm linh đan (Quy Nguyên đan)","loai":"dan-duoc","trangThai":"da-luyen-thanh","moTa":"Viên thuốc màu lửa đỏ tươi, do Âu Dương Tử tự tay luyện thành sau hơn sáu năm.","nguon":"@c0312"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0303","@c0307","@c0306","@c0311","@c0312","@c0313"]},{"id":"cong-ton-truong","name":"Công Tôn Trường","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh hậu kỳ","trangThai":"mat-tich","blurb":"Một trong các đại trưởng lão Nguyên Anh hậu kỳ của Vân Thiên Tông; đi tìm tu sĩ ngoại lai diệt Thanh Thiên môn rồi mất tích, ngầm hiểu đã chết.","vaiTro":"Đại trưởng lão Vân Thiên Tông","tinhCach":[],"tabs":{"diem":[{"text":"Là một trong bốn đại trưởng lão Nguyên Anh hậu kỳ của Vân Thiên Tông; 30 năm trước Lưu trưởng lão Hóa Thần thất bại thân vong nên chỉ còn ba, nay mất thêm một","chuong":"@c0302"}],"kinhLich":[{"chuong":"@c0302","importance":"normal","tieuDe":"Mất tích khi truy tìm tu sĩ ngoại lai","text":"Bảy ngày trước đi tìm tu sĩ ngoại lai (kẻ diệt Thanh Thiên môn), đến nay chưa quay về. Tống Thanh lộ vẻ bi ai ngầm hiểu đã chết; Lý Mộ Uyển hỏi thăm tin tức."}],"tuVi":"Nguyên Anh hậu kỳ — một trong các đại trưởng lão mạnh nhất Vân Thiên Tông @c0302.","nhanMach":[{"ten":"Tống Thanh","tag":"su-mon","quanHe":"Đồng môn Vân Thiên Tông, bi ai khi hắn mất tích","ghiChu":"@c0302"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0302"]},{"id":"phong-son","name":"Phong Sơn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Đệ tử Vân Thiên Tông, bị Vương Lâm nhắc tên trong lệnh phong tỏa.","vaiTro":"Đệ tử Vân Thiên Tông","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0306","importance":"minor","tieuDe":"Nhắc tên trong lệnh phong tỏa","text":"Vương Lâm ra lệnh Liễu Phỉ, Tống Thanh, Phong Sơn cùng bất cứ kẻ nào không được ra ngoài trước khi hắn đi ra; không có hành động hay mô tả thêm."}],"tuVi":"Chưa rõ tu vi @c0306.","nhanMach":[{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Bị Vương Lâm nhắc tên trong lệnh phong tỏa","ghiChu":"@c0306"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0306"]},{"id":"thien-van-tu-luyen-dan","name":"Thiên Vân Tử","cn":"","aliases":["#thien-van-tu-luyen-dan"],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Ngũ cấp luyện đan sư","trangThai":"tu-vong","blurb":"Vị ngũ cấp luyện đan sư cuối cùng của Vân Thiên Tông, đã chết nhiều năm trước do Hóa Thần thất bại (khác với Thiên Vận Tử — sư phụ ký danh của Vương Lâm).","vaiTro":"Ngũ cấp luyện đan sư Vân Thiên Tông (đã mất)","tinhCach":[],"tabs":{"diem":[{"text":"Lưu ý phân biệt: khác với Thiên Vận Tử (Thiên Vận Tinh, sư phụ ký danh của Vương Lâm)","chuong":"@c0311"}],"kinhLich":[{"chuong":"@c0311","importance":"minor","tieuDe":"Nhắc tên — đã chết","text":"Được nhắc là vị ngũ cấp luyện đan sư cuối cùng của Vân Thiên Tông, đã chết nhiều năm trước do Hóa Thần thất bại; nếu còn sống cùng Lý Mộ Uyển và Âu Dương Tử nghiên cứu lục phẩm đan phương chắc chắn nhanh hơn không ít."}],"tuVi":"Ngũ cấp luyện đan sư; chết do Hóa Thần thất bại @c0311.","nhanMach":[{"ten":"Âu Dương Tử","tag":"su-mon","quanHe":"Đồng môn luyện đan Vân Thiên Tông","ghiChu":"@c0311"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0311"]},{"id":"ly-son","name":"Lý Sơn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Đạo Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Đệ tử Huyền Đạo Tông chuyên buôn bán pháp khí xảo trá tại hội giao lưu phái Hằng Nhạc; nổi tiếng với phích lịch đạn tự chế.","vaiTro":"","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0044","importance":"minor","text":"Đệ tử Huyền Đạo Tông, bày bán pháp khí xảo trá (phi kiếm giả Tử Ngọ Kim Tiễn, phích lịch đạn tự chế) cho đệ tử phái Hằng Nhạc; mưu kế dụ đối phương dùng đạn thối để lập công. Vương Lâm âm thầm quan sát."},{"chuong":"@c0046","importance":"minor","text":"Bán phích lịch đạn cho Vương Lâm. VL phát hiện bên trong đạn có một đạo thần thức của Lý Sơn dùng điều khiển kích nổ, bèn dùng thần thức bao phủ và nuốt đạo thần thức đó vào trong."}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khách mua phích lịch đạn — bị VL nuốt thần thức trong đạn"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0044","@c0046","@c0047"]},{"id":"chu-lam","name":"Chu Lâm","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Vân Thiên Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Kết Đan sơ kỳ","trangThai":"khong-ro","blurb":"Cửu đại đệ tử Vân Thiên Tông, đệ tử của Lý Mộ Uyển; là sư phụ (qua phân thân) của Vương Lâm trong thân phận tại Vân Thiên Tông.","vaiTro":"","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0189","importance":"minor","text":"Trung niên nam tử, cửu đại đệ tử Vân Thiên Tông, tu vi Kết Đan sơ kỳ (đệ tử nội tông); là sư phụ (phân thân) của Vương Lâm, đang bế quan nên Lý Mộ Uyển trêu mình là 'sư tổ' của VL."},{"chuong":"@c0198","importance":"minor","text":"Theo lệnh Lý Mộ Uyển, đón Vương Lâm tại Bắc Uyển rồi mở trận pháp trên vách dẫn vào phòng bí mật để VL gặp Lý Mộ Uyển. Bị VL thận trọng lén hạ một đạo cấm chế và đòi xem linh phù chứng minh thân phận. Tự biết bị cuốn vào chuyện bí mật của sư phụ nên lo bị liên lụy."}],"tuViMoc":[],"tuVi":"Kết Đan sơ kỳ","nhanMach":[{"ten":"Lý Mộ Uyển","tag":"su-mon","quanHe":"Sư phụ"},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Đệ tử (danh nghĩa) — đón và dẫn VL gặp Lý Mộ Uyển"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0189","@c0195","@c0198"]},{"id":"tien-con","name":"Tiền Côn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Độc Ma Vương Cung","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Kết Đan trung kỳ","trangThai":"tu-vong","blurb":"Ngũ đại đệ tử Độc Ma Vương Cung, phụng mệnh truy sát Vân Phi để thu hồi ngọc giản; chạm trán Vương Lâm vừa ra khỏi Loạn Tinh Hải và bị VL giết diệt khẩu.","vaiTro":"","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0177","importance":"minor","text":"Nam trung niên mặt chữ điền, ngũ đại đệ tử Độc Ma Vương Cung, tu vi Kết Đan trung kỳ; phụng mệnh truy sát Vân Phi gần một tháng để thu hồi ngọc giản phương đan dược. Khi Vương Lâm xé khe không gian bước ra khỏi Toái Tinh Loạn, khí thế như thần ma khiến Tiền Côn sợ hết hồn."},{"chuong":"@c0179","importance":"normal","tieuDe":"Bị Vương Lâm giết diệt khẩu","text":"Đoán ra Vương Lâm là người từ Loạn Tinh Hải đi ra (lão tổ không về mà lại có thanh niên lạ bước ra). Ném cát đen tấn công rồi bỏ chạy, bị VL dùng ma đầu Hứa Quốc Lập thôn phệ thần thức, đoạt kim đan + túi trữ vật; thi thể bị thiêu thành tro. Chết."}],"tuViMoc":[],"tuVi":"Kết Đan trung kỳ","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ thù — bị VL giết diệt khẩu @c0179"},{"ten":"Vân Phi","tag":"doi-thu","quanHe":"Mục tiêu truy sát"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0177","@c0179"]},{"id":"tong-su-thuc-hang-nhac","name":"Tống sư thúc","cn":"","aliases":["Tống sư thúc (Hằng Nhạc Phái)"],"gioiTinh":"nam","theLuc":[{"ten":"Hằng Nhạc Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Trưởng lão Hằng Nhạc Phái, bạn cũ 20 năm của Âu Dương (trưởng lão Huyền Đạo Tông); nổi tiếng ủ rượu mạnh.","vaiTro":"","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0040","importance":"minor","text":"Trưởng lão Hằng Nhạc Phái, quen biết Âu Dương (trưởng lão Huyền Đạo Tông) từ 20 năm trước; nổi tiếng ủ rượu mạnh. Hàn huyên vui vẻ với Âu Dương sau cuộc tỷ thí."}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Âu Dương","tag":"ban-be","quanHe":"Bạn cũ 20 năm"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0040"]}]};