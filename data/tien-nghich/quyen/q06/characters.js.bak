/* characters q06 (241 mục) — ra-the: gộp thẻ trùng - gop trung 2026-06-24 - gop theo danh sach 2026-06-25 - gop theo danh sach 2026-06-25 - gop theo danh sach 2026-06-27 - sua the 2026-06-27 */
window.__LIBQ=window.__LIBQ||{};window.__LIBQ["tien-nghich"]=window.__LIBQ["tien-nghich"]||{};window.__LIBQ["tien-nghich"]["q06"]=window.__LIBQ["tien-nghich"]["q06"]||{};window.__LIBQ["tien-nghich"]["q06"]["characters"]={"updatedAt":"2026-06-24","count":197,"chars":[{"id":"vuong-lam","name":"Vương Lâm","gioiTinh":"nam","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0458","importance":"major","tieuDe":"Lấy toàn bộ tiên ngọc Phẩm Linh Các","text":"Với thân phận Đệ thất tử Tử hệ đã 103 năm chưa lĩnh tiên ngọc, Vương Lâm vào tiên cảnh tầng bảy Phẩm Linh Các, chọn lấy toàn bộ và thu trọn 123.600 khối tiên ngọc cao như núi vào túi trữ vật, định bế quan trong ba tháng để đột phá Anh Biến trung kỳ, tranh đoạt danh hiệu thiên vận thất tử."},{"chuong":"@c0458","importance":"bridge","tieuDe":"Năm người vây kích tại Tử Lâm Các","text":"Vừa về Tử Lâm Các, hắn bị năm người hợp vây gồm tứ sư tỷ Tử hệ, Triệu Tinh Sát, đệ tử thứ hai Lam tông, Tư Mã Như Phong và một người y phục xanh nửa bước vấn đỉnh; tứ sư tỷ bắt quyết thi triển Tử thuật - Na di bao trùm mười dặm để khởi chiến."},{"chuong":"@c0459","importance":"bridge","tieuDe":"Bị vây khốn thạch lâm khốn địa","text":"Vương Lâm bị tứ sư tỷ cùng Triệu Tinh Sát, nhị sư huynh và hai người Thanh-Lam hai hệ liên thủ khóa không gian, phát bốn đạo sát khí chấn nhiếp rồi na di tới thạch lâm khốn địa ngoài Thiên Vận Tông hơn mười ngàn dặm. Tứ sư tỷ hẹn ba năm sau tới thả ra, để hắn yên tĩnh bế quan."},{"bridge":true,"khoang":"@c0459–@c0459","text":"Hắn thử phá vây nhiều cách — chém kiếm quang bằng tiên kiếm, bay thẳng lên trên chịu lực cản tương đương Anh Biến hậu kỳ, rồi cho Hứa Lập Quốc và loan đao lao thử — đều bị trận pháp triệt tiêu.","importance":"normal"},{"chuong":"@c0459","importance":"major","tieuDe":"Quyết tu luyện đột phá Anh Biến trung kỳ","text":"Nhận ra kẻ địch định vây tới khi tranh đoạt danh hiệu Thiên Vận Thất Tử kết thúc, Vương Lâm quyết không chờ ba năm mà tự phá nơi này. Hắn tìm được biên giới thạch lâm, ngồi khoanh chân hấp thu lượng lớn tiên ngọc luyện công, sau lưng hiện quầng sáng vàng báo hiệu tiên lực đạt bão hòa."},{"chuong":"@c0460","importance":"bridge","tieuDe":"Hoàn tất hấp thu tiên lực","text":"Toàn bộ tiên lực điên cuồng nhập thể, Vương Lâm dồn toàn lực hấp thu suốt ba tháng tại thạch lâm cách Thiên Vận Tông hơn mười ngàn dặm."},{"chuong":"@c0460","importance":"normal","tieuDe":"Đột phá chấn thiên địa","text":"Mở mắt phát hai luồng quang như trăng rằm, một cái nhấn tay làm thạch lâm mười dặm tan thành bụi; há miệng hút thu khí tức như phễu rồi thét dài chấn động thiên địa, vụt đứng dậy dáng như đội trời đạp đất."},{"chuong":"@c0461","importance":"normal","tieuDe":"Phá trận thoát thạch lâm","text":"Sau ba tháng bị tấm màn sáng hình vòm vây khốn trong thạch lâm rộng mười dặm, Vương Lâm bay lên sát đỉnh màn, dùng Tịch Diệt Chỉ điểm tạo vô số vết nứt nhưng trận tự khôi phục; hắn chuyển sang Hóa Ma Chỉ nghịch hóa toàn bộ tiên lực thành ma hỏa tím, thiêu rụi cả tấm màn chỉ trong ba nhịp thở."},{"chuong":"@c0461","importance":"normal","tieuDe":"Trở về Thiên Vận Tông báo thù","text":"Không thuộc địa hình, Vương Lâm thả nguyên thần Tào Nhất Đấu dẫn đường, thuấn di ba mươi vạn dặm về hướng tây; hồi tưởng bị Tử hệ nhất mạch chèn ép na di vây khốn, hắn lập thề ai phạm ta giết không tha, xuất hiện thành cầu vồng tím từ đằng đông ngay giữa thọ yến ngàn năm của Thiên Vận Tử đúng lúc Triệu Tinh Sát chúc rượu."},{"chuong":"@c0462","importance":"bridge","tieuDe":"Xông vào thọ yến truy sát kẻ thù","text":"Cưỡi đám mây tím phá không tới Tử Tông Sơn trên Thiên Vận Tinh, kinh động cả buổi thọ yến của sư tôn Tử hệ. Hắn dùng Cấm Phiên xé tan Thượng chi lực của nhị sư huynh, cảnh cáo các tu sĩ tông phái khác không được can dự, rồi khơi ma hỏa quyết tâm đòi mạng."},{"chuong":"@c0462","importance":"normal","tieuDe":"Ma hỏa tự bạo phá quyết Triệu Tinh Sát","text":"Khi Triệu Tinh Sát bước ra dùng Đại tự tại thiên địa quyết bọc ma hỏa hòng cản, Vương Lâm hô “Bạo”, ma hỏa tự nổ phát tiết ma khí và lửa tím, thiêu vỡ quầng sáng trắng, quét nghìn trượng tạo hố lớn khiến mọi tu sĩ tản chạy."},{"chuong":"@c0462","importance":"normal","tieuDe":"Đả thương nguyên thần Hứa Lập Quốc","text":"Vương Lâm vung tiên kiếm và loan đao chém tan màn sương đen Tiên Ma thể của Hứa Lập Quốc, rồi dùng Côn Cực Tiên kéo dài đánh trúng nguyên thần đang thuấn di trốn cách nghìn trượng, khiến nguyên thần run rẩy sắp tan, lưng hiện vết thương sâu, phát tiết lượng lớn tiên lực tinh hoa."},{"chuong":"@c0463","importance":"normal","tieuDe":"Uy hiếp Triệu Tinh Sát giữa Tử Tông","text":"Vương Lâm thu nốt nguyên thần đối phương vào Tôn Hồn Phiên rồi chỉ thẳng Triệu Tinh Sát, tuyên bố ai cản trở sẽ thành kẻ thù. Các chấp pháp trưởng lão Tử Tông do dự không ai dám tiến lên."},{"chuong":"@c0463","importance":"bridge","tieuDe":"Đối đầu Cổ Yêu, triệu Hồn Thú","text":"Khi Triệu Tinh Sát triệu hư ảnh cổ yêu trăm trượng, Vương Lâm dùng Tôn Hồn Phiên thu hồi chủ hồn bị lốc xoáy đỏ hút, rồi vỗ Xạ Thần Xa triệu Hồn Thú đâm xuyên thân yêu vật. Ánh mắt lạnh thấu xương của cổ yêu khiến hắn liên tưởng tới hóa thân của cổ thần thiên đạo sứ giả."},{"bridge":true,"khoang":"@c0463–@c0463","text":"Sau khi Xích Liệt quát đuổi cổ yêu kết thúc trận, Vương Lâm điềm tĩnh thu Khu Thú Quyển, ung dung đi tới ngồi vào bàn trống thứ ba dưới chỗ tứ sư tỷ — vị trí thuộc về hắn.","importance":"bridge"},{"chuong":"@c0464","importance":"bridge","tieuDe":"Thay chủ yến hội Tử hệ","text":"Sau khi Xích Liệt bắt Triệu Sát Tinh đi, Vương Lâm trở thành tâm điểm yến hội ngày cuối, được các tu sĩ tông phái kéo đến chúc rượu vì nhận định hắn chắc chắn trở thành Thiên Vận Thất Tử."},{"chuong":"@c0464","importance":"bridge","tieuDe":"Nhận ngọc giản hai cấm pháp","text":"Đêm khuya yến tàn, tứ sư tỷ trao ngọc giản chứa cấm pháp đại na di và một cấm pháp do sư tôn phỏng tiên thuật sáng tạo, coi như xin lỗi việc tháng trước; Vương Lâm nhận, không muốn trở mặt hoàn toàn."},{"chuong":"@c0464","importance":"bridge","tieuDe":"Tu thành thuật đại na di","text":"Trong mật thất tầng ba Tử Lâm Các, Vương Lâm thử cấm pháp dịch chuyển mười vạn dặm, bước bảy bước trong hào quang bạc rồi xuất hiện trên đỉnh núi cách đó mười vạn dặm, xác nhận đã tới đúng Thiên Vận Tinh."},{"chuong":"@c0464","importance":"normal","tieuDe":"Khai mở tu luyện tiên thuật","text":"Vương Lâm đặt tên Cửu Chuyển Luyện Tiên Quyết cho cấm pháp thứ hai, tu liên tiếp nhất chuyển, nhị chuyển, tam chuyển, ngưng tụ luồng kim tiên lực sắc bén ở tay trái — đánh dấu lần đầu tu thành tiên thuật chân chính nhờ đã có tiên thể bậc trung."},{"chuong":"@c0464","importance":"bridge","tieuDe":"Dự lễ giảng đạo Thiên Vận Tử","text":"Trời sáng, Vương Lâm tới dự lễ giảng đạo vạn năm một lần của sư tôn; quét mắt nhận ra ba cao thủ trong sáu tông: Tư Mã Như Phong, nam tử họ Vương của Thanh Tông (nửa bước Vấn Đỉnh) và người trung niên Cam Tông từng đánh Sất Hổ."},{"chuong":"@c0465","importance":"bridge","tieuDe":"Dự thọ yến vạn năm Thiên Vận Tử","text":"Với thân phận đệ tử Tử Hệ, Vương Lâm dự đại thọ vạn năm của Thiên Vận Tử, đánh giá thực lực thất hệ và nhận thấy nhiều đệ tử ẩn giấu bản lãnh, trừ ba người Tử Hệ thì các Hệ khác đều có thể hoành hành ở Chu Tước Tinh. Hắn chứng kiến Tôn trưởng lão từ tu chân liên minh giáng lâm bằng kim quang trận pháp khổng lồ."},{"bridge":true,"khoang":"@c0465","text":"Khi Thiên Vận Tử bắt đầu giảng Thiên Vận Chi Đạo, con tiểu điêu ba mắt của Tôn trưởng lão bất ngờ bay tới đậu lên vai Vương Lâm, ba mắt phát tia sáng âm u dò xét hắn; Vương Lâm thấy con chim quen quen liền chăm chú quan sát.","importance":"bridge"},{"chuong":"@c0466","importance":"normal","tieuDe":"Tinh Ngân điêu tìm tới","text":"Một con tử điêu ba mắt đậu trên vai Vương Lâm; qua truyền thừa ký ức cổ thần Đồ Ti hắn nhận ra đó là Tinh Ngân điêu còn nhỏ. Con chim không màng thượng phẩm tinh thạch, chỉ chăm chú nhìn hắn vì bị khí tức cổ thần cực yếu trên người hắn thu hút, song lượng khí tức quá ít khiến hắn thất vọng."},{"chuong":"@c0466","importance":"bridge","tieuDe":"Vấn đạo trước sư tôn","text":"Được Thiên Vận Tử gọi đích danh chỉ điểm trước tu sĩ bốn phía và đệ tử lục hệ, Vương Lâm cung kính hỏi cách phân biệt tu tiên, tu chân và tu đạo. Nghe sư tôn giảng ba bước tu đạo, hắn vẫn hoài nghi có thực sự tồn tại bước thứ ba hay không, dẫn tới việc Thiên Vận Tử tiết lộ về ‘hắn’."},{"bridge":true,"khoang":"@c0466–@c0466","text":"Vương Lâm thử dụ tử điêu bằng tiên ngọc; con chim đoạt nuốt liền hai khối với tốc độ khó tưởng tượng rồi đậu sang vai Tôn trưởng lão, mắt vẫn dán vào túi trữ vật của hắn.","importance":"bridge"},{"chuong":"@c0467","importance":"normal","tieuDe":"Gặp lại Lăng Thiên Hầu","text":"Tại lễ đại thọ vạn năm, Vương Lâm lặng nghe trọn ba ngày giảng đạo của Thiên Vận Tử và dần có lĩnh ngộ. Hắn chứng kiến Tiên thuật lần đầu trong đời khi Thiên Vận Tử thi triển trung phẩm Dẫn Tiên thuật, đồng thời nhận ra xà hình bảo kiếm dưới chân Lăng Thiên Hầu chính là Vũ chi đệ nhị kiếm từng thấy ở Tiên giới."},{"bridge":true,"khoang":"@c0467","text":"Khi thiên uy vô thanh của Dẫn Tiên thuật giáng xuống khiến tiên lực trong người hỗn loạn, Vương Lâm vận tam chuyển kim tiên lực từ cánh tay trái lưu chuyển toàn thân, khống chế không để nó hòa lẫn tiên lực vốn có, nhờ đó dần đứng vững lại.","importance":"bridge"},{"chuong":"@c0468","importance":"bridge","tieuDe":"Trụ vững khảo nghiệm áp lực Tử hệ","text":"Trong khảo nghiệm áp lực phân loại đệ tử tại đại thọ Thiên Vận Tử, Vương Lâm cùng Tứ sư tỷ là hai người duy nhất của Tử hệ trụ vững; hắn vận kim tiên lực ba vòng khôi phục sắc mặt, được Tứ sư tỷ liếc nhìn đầy thâm ý."},{"chuong":"@c0468","importance":"normal","tieuDe":"Giấu Tôn Hồn Phiên trước Kỳ Lân thú","text":"Khi Lăng Thiên Hầu triệu Kỳ Lân thú từ mi tâm, Tôn Hồn Phiên trong nguyên thần Vương Lâm phát tiếng gầm rít cộng hưởng khiến Kỳ Lân thú dừng lại quét mắt tìm kiếm; hắn lập tức vận Tôn Hồn Phiên che giấu toàn bộ tàn hồn, tránh bị phát hiện."},{"bridge":true,"khoang":"@c0468","text":"Quan sát Dẫn Tiên thuật của Thiên Vận Tử, Vương Lâm lĩnh hội sâu thêm rằng Tiên thuật do hư ảo tạo thành nhưng tồn tại vĩnh hằng, chỉ cần có khẩu quyết, phương pháp và tư cách là thi triển được ở bất kỳ đâu.","importance":"bridge"},{"chuong":"@c0469","importance":"bridge","tieuDe":"Tranh phong hiệu, đấu Triệu Hân Mộng","text":"Vương Lâm (Lão Thất) ban đầu định bỏ cuộc tranh phong hiệu Thiên Vận Thất tử vì linh cảm điều bất thường nơi Vận Đường, nhưng bị Thiên Vận Tử đích thân khuyên giải — người thứ hai sau Tôn Vân được sư phụ khuyên — nên đổi ý quyết tranh đoạt. Hắn khai chiến với Tứ sư tỷ Triệu Hân Mộng: nàng dùng Tử Ma thủ mô phỏng từ Hoá Ma chỉ của hắn, Vương Lâm đáp trả bằng Hoá Ma chỉ khiến ma khí ngập trời gào rít bao phủ bốn phía."},{"chuong":"@c0470","importance":"bridge","tieuDe":"Phá bẫy hấp thu ma lực","text":"Vương Lâm thi triển Hoá Ma chỉ đối đầu Tử Ma thủ của Triệu Hân Mộng; nàng dùng hạt châu hô ‘Thu’ hút ma lực để cướp đoạt, nhưng Vương Lâm vạch trần đây chỉ là tia hư ảo do tiên lực chuyển hoá, tâm niệm khẽ động liền khiến nó tự sụp. Hắn từ chối nhường, viện lời hứa với Tư Đồ Nam không truyền ba thức sát chiêu ra ngoài."},{"chuong":"@c0470","importance":"bridge","tieuDe":"Ngũ chuyển luyện tiên trong vài ngày","text":"Đối đáp Cửu chuyển luyện tiên quyết của Triệu Hân Mộng, Vương Lâm dù mới nhận công pháp vài ngày đã lập tức tu ra tam chuyển, tứ chuyển rồi ngũ chuyển kim tiên lực, chịu đau đớn cực lớn mà thần sắc thong dong, lại rút chiến phủ Cự Ma Tộc và Xạ Thần xa uy hiếp. Triệu Hân Mộng thừa nhận đã xem thường hắn rồi bỏ cuộc."},{"chuong":"@c0470","importance":"normal","tieuDe":"Giao chiến Trần Đào","text":"Trần Đào (Vấn Đỉnh) đánh ấn quyết chấn nhiếp nhưng chỉ đẩy lùi Vương Lâm hơn mười trượng thay vì trăm trượng như dự tính. Vương Lâm phóng ngũ chuyển kim tiên lực, bị Trần Đào đẩy lên cửu chuyển phản công; hắn dùng chiến phủ chém rồi thi Đại Na Di khiến cơn lốc cửu chuyển biến mất ngay trước mặt, sau đó triệu Hồn thú từ Xạ Thần xa khiến cả trường chấn động."},{"chuong":"@c0471","importance":"bridge","tieuDe":"Lần đầu mở phong ấn Xạ Thần xa","text":"Trong trận đấu với Trần Đào tại lễ chúc thọ, Vương Lâm lần đầu kết ấn mở đạo phong ấn thứ nhất của Xạ Thần xa, khiến Hồn thú bạo tăng từ mười trượng lên hơn trăm trượng và đoạt được thiên uy thần thông mới."},{"chuong":"@c0471","importance":"bridge","tieuDe":"Thi triển Hoàng tuyền chỉ","text":"Biết mình không phải đối thủ Vấn Đỉnh kỳ nhưng không từ bỏ, Vương Lâm cưỡng dùng sát chiêu cuối Hoàng tuyền chỉ của Tư Đồ Nam: tiêu tan sinh mạng, hiện Sinh tử luân hồi ý cảnh, khiến toàn trường sững sờ và các đại nhân vật như Thiên Vận Tử, Lăng Thiên Hầu chú ý."},{"chuong":"@c0472","importance":"bridge","tieuDe":"Bại trận trước Trần Đào","text":"Phóng hai đạo Hoàng tuyền chỉ (một từ ngón út, một từ Luân hồi ý cảnh hóa thành) công kích Trần Đào gây nổ kinh thiên động địa, nhưng Trần Đào nhờ kỳ ngộ đạt Vấn Đỉnh trung kỳ nên đỡ được. Vương Lâm bị đẩy lùi hơn trăm trượng, phun một ngụm tiên huyết, tiên lực hỗn loạn nên tuyên bố bỏ cuộc; Trần Đào do đó đoạt phong hiệu Thiên Vận Thất tử của Tử hệ."},{"chuong":"@c0472","importance":"bridge","tieuDe":"Thành đệ tử chân chính Thiên Vận Tử","text":"Được Thiên Vận Tử gọi theo về Tổng tông tế bái Tổ linh, hứa truyền Cấm pháp thần thông và ban pháp bảo bản mạng, chính thức trở thành đệ tử chân chính. Giải đúng câu đố ba ngọn núi (nhìn ra hai sườn núi hai bên là giả do Chân huyễn pháp) nên được đặc ân tự chọn Cấm pháp thần thông thay vì bị chỉ định."},{"chuong":"@c0472","importance":"normal","tieuDe":"Vượt kỷ lục Toái Tiên chi địa","text":"Leo ngọn núi trắng phủ Cửu U chi hàn không dùng thuấn di, đạp băng đối mặt khảo nghiệm Toái Tiên chi địa. Đi được hai mươi mốt bước (vượt xa cực hạn Anh Biến trung kỳ mà Thiên Vận Tử dự đoán), rồi bước thứ hai mươi hai và thêm năm bước nữa, tiến gần kỷ lục hai mươi sáu bước của Tôn Vân."},{"chuong":"@c0473","importance":"bridge","tieuDe":"Bái sư nhập Thiên Vận Tông","text":"Vương Lâm chính thức quỳ bái Thiên Vận Tử, được thu làm đệ tử thứ bảy của Tử hệ dưới ánh sáng chín màu. Hắn thề chỉ cần sư phụ và Thiên Vận Tông không phụ hắn thì hắn sẽ không phụ lại; một tòa Tế đàn bảy màu hạ xuống, lệnh bài khắc danh tự cháy hóa lửa tím bay về tế đàn. Sau đó được Thiên Vận Tử hỏi muốn chọn loại Cấm pháp thần thông nào."},{"chuong":"@c0474","importance":"bridge","tieuDe":"Chọn Cấm pháp thần thông phòng thân","text":"Vương Lâm điểm lại sở học (Cấm pháp Đại Na Di, Ngân Long la bàn) và nhận ra chúng chỉ hữu dụng với tu sĩ Vấn Đỉnh, không đủ đối phó kẻ vượt Vấn Đỉnh hay đạt cảnh giới Toái Niết. Hắn xin Thiên Vận Tử truyền ‘Sinh tồn pháp thuật’ nhưng bị từ chối, nên được sư phụ điểm ánh sáng bảy màu đưa vào thế giới bảy màu để tự chọn theo cơ duyên."},{"chuong":"@c0474","importance":"normal","tieuDe":"Từ chối Sát Lục Tiên quyết","text":"Trong thế giới bảy màu, Vương Lâm phát hiện một Thiên Vận Tử áo xám dị thường (người ‘hơn một người’ — thứ 3601), mọi công kích đều xuyên qua như ảo ảnh. Qua sáu lần chạm mặt, người áo xám tiết lộ Thiên Vận Tử đưa hắn tới chính vì Sát Lục Tiên quyết, ra điều kiện ‘xuất thủ không lưu người sống’. Vương Lâm thi triển Sinh tử Luân hồi ý cảnh rồi trầm mặc từ chối: ‘Ta không học!’, sau đó nhận lấy ngọc giản người áo xám để lại."},{"chuong":"@c0476","importance":"bridge","tieuDe":"Rời Thiên Vận Tinh tới Địa Tinh","text":"Vương Lâm dùng Truyền tống trận khổng lồ của Huyền Uyên Phái do Triệu Tứ kích hoạt, vượt liên tinh cầu rời Thiên Vận Tinh để tới Địa Tinh, mang theo lệnh bài khắc chữ “Thất” biểu thị thân phận Tử hệ Lão Thất."},{"chuong":"@c0476","importance":"normal","tieuDe":"Nhậm chức sứ giả Linh Nhạc quốc","text":"Tới Huyền Uyên Phái được Thiếu Tông Hứa Vân Sơn nghênh đón và kết giao; sau hai ngày, hắn được đưa tới Ngũ cấp tu chân quốc Linh Nhạc quốc để nhận chức sứ giả, ngầm tìm chỗ tĩnh tu tránh cạnh tranh ở Thiên Vận Tông."},{"bridge":true,"khoang":"@c0476–@c0476","text":"Trong hoa viên, Vương Lâm ngẫm về việc đề cao tu vi để đối phó mối uy hiếp Thác Lâm, nghiền ngẫm Sát lục tiên quyết, Sinh chi lạc ấn hộ thể và việc Thiên nghịch châu còn thiếu kim thuộc tính, nhớ tới Chu Tước Tinh xa xôi.","importance":"bridge"},{"chuong":"@c0477","importance":"bridge","tieuDe":"Nhậm Sứ giả Huyền Uyên Phái","text":"Vương Lâm chính thức nhậm chức Sứ giả của Huyền Uyên Phái tại Linh Nhạc quốc, được hơn trăm tu sĩ cung kính đón tiếp. Hứa Vân Sơn cáo từ rời đi, để mình hắn ở lại tọa trấn Thông Thiên tháp."},{"bridge":true,"khoang":"@c0477","text":"Hắn tuyên bố bế quan, cấm mọi người bước vào phạm vi ngàn dặm, dùng Cấm Phiên phóng hắc khí tạo màn sương đen và thả Chủ hồn từ Tôn Hồn Phiên ra phòng bị, rồi nghiên cứu Sát Lục Tiên quyết suốt hơn một tháng nhưng không tìm được điểm khởi đầu.","importance":"normal"},{"chuong":"@c0477","importance":"bridge","tieuDe":"Áp chế Xạ Thần xa cắn trả","text":"Xạ Thần xa lần đầu cắn trả kể từ khi giải khai đạo phong ấn đầu tiên. Vương Lâm đã chuẩn bị trước, đại chiến với Khuất thú bên trong mấy ngày, dùng bí pháp áp chế khiến lần cắn trả thất bại."},{"chuong":"@c0477","importance":"normal","tieuDe":"Thu cấm chế, quyết đi Đông Hải","text":"Vương Lâm ngộ ra Sát Lục Tiên quyết phải cảm ngộ từ giết chóc thật, bèn thu hết màn sương đen ngàn dặm ngưng tụ thành khối cầu điện quang đen hóa Cấm Phiên tím đen, thu Chủ hồn vào Tôn Hồn Phiên tế luyện. Nhớ lời sư phụ dặn đến Đông Hải trong ba tháng (còn hơn một tháng), hắn lên đường, trước hết tới Ngũ Linh Sơn gặp Thiên Thai lão nhân."},{"chuong":"@c0478","importance":"bridge","tieuDe":"Chọn Địa Ma Bắc Giới tu Sát Lục Tiên quyết","text":"Vương Lâm hỏi Thiên Thai lão nhân về nơi yêu thú tụ tập, nhận ngọc giản ghi ba chỗ rồi thuấn di tới Cực Bắc Địa Tinh, bước thẳng qua tấm bia Địa Ma Bắc Giới vào làn sương mù để tu luyện Sát Lục Tiên quyết — công pháp phải ở trong giết chóc mới lĩnh ngộ huyền diệu."},{"bridge":true,"khoang":"@c0478","text":"Hắn để tâm tới Đại La Kiếm Tông nhằm tìm tung tích Chu Dật tiền bối, đồng thời tò mò về Diệu Kim quả mà nhóm kiếm tu tranh chấp.","importance":"bridge"},{"chuong":"@c0479","importance":"normal","tieuDe":"Nuôi Văn thú bằng yêu thú Hóa Thần","text":"Phi hành trong Tùng Mãng Sơn mạch tu luyện Sát Lục Tiên quyết, Vương Lâm giết tiểu thú sương đen và Bôn Ngưu thú (tương đương Hóa Thần kỳ), thu bụi khí nghi là sinh lực và thả Văn thú hấp thu nội đan, huyết nhục con mồi để thúc nó lớn lên."},{"chuong":"@c0479","importance":"normal","tieuDe":"Lần theo Đại La Kiếm Tông tìm Diệu Kim quả","text":"Vương Lâm dùng thần thức theo dõi đoàn Đại La Kiếm Tông, dự định dùng hai lão Anh Biến sơ kỳ làm thí luyện giả cho Sát Lục Tiên quyết, rồi cưỡi Văn thú bay nhanh về phía Nam nơi có Diệu Kim quả."},{"chuong":"@c0480","importance":"bridge","tieuDe":"Bám theo đoàn Đại La Kiếm Tông","text":"Ngồi trên Văn thú vô thanh vô tức, Vương Lâm âm thầm đi theo đoàn Đại La Kiếm Tông tiến vào Địa Ma Bắc Giới tìm Diệu Kim quả. Dựa vào ký ức Cổ Thần Đồ Ti, hắn nhận ra Diệu Kim quả thực chất là kim linh căn mà các tu sĩ kiếm tông không biết cách dùng đúng — nuốt vào khiến thân thể cứng rắn, là thuốc bổ hi���m có với Cổ Thần thuở nhỏ. Hắn nhắm đoạt vật này cho Văn thú đang loé bạch mang khát vọng, vỗ đầu nó gật đầu cho phép."},{"text":"Tại sơn cốc, Vương Lâm phá Huyết Thủ ấn, diệt Thiên Quỷ đầu rồi dùng kính tản tia sáng phát Tứ chuyển hàm tiên lực vỗ tan kiếm quang của Thạch Phương. Tiên ảnh đánh trọng thương nguyên thần ly thể, Văn thú nuốt sạch thân xác chỉ còn hài cốt; dù Thạch Phương đoạt xá Quách Tà Dật siêu tốc rồi cầu xin hiến ngọc giản, Vương Lâm vẫn phóng khí xám khiến hắn nổ tung.","bridge":true,"khoang":"@c0483","importance":"major"},{"text":"Vương Lâm tới mảng hoa vàng phía Tây sơn cốc hái một Diệu Kim quả, định dùng tăng kim thuộc tính cho Nghịch Thiên châu (sau trận Chu Tước mộ vẫn thiếu gần một nửa), nếu không thì cho Văn thú ăn; chưa l��p tức tra hỏi Trưởng lão Đại La Kiếm Tông đang bị giam.","bridge":true,"khoang":"@c0483","importance":"bridge"},{"chuong":"@c0484","importance":"bridge","tieuDe":"Luyện thành bốn kim linh căn","text":"Hiểu ra Diệu Kim quả không trực tiếp làm viên mãn kim thuộc tính của Nghịch Thiên châu, Vương Lâm dùng phương pháp điều hoà thừa kế trong ký ức Đồ Ti: bố trí ngọc giản khắc văn, kết thủ ấn cổ quái và thốt Chú ngôn ép hoa, quả, cành cây héo rũ. Quá trình khoảng nửa nén hương, hắn bới đất thu được bốn kim linh căn cỡ ngón tay cái, kỳ dị giống nhân sâm."},{"chuong":"@c0484","importance":"bridge","tieuDe":"Phân chia kim linh căn","text":"Hắn ném một kim linh căn cho Văn thú khiến nó bắt đầu biến hoá, kim quang bọc thành lồng vàng; một rễ cho Lôi Oa; một rễ cuối tặng Thiên Cầm coi như đền cơ duyên đã chiếm. Thân cây hắn thu lại lưu cho bổn tôn."},{"bridge":true,"khoang":"@c0484","text":"Hoá khói rời sơn cốc, nhoáng qua dãy núi phóng vào chỗ sâu Địa Ma Bắc giới.","importance":"bridge"},{"chuong":"@c0485","importance":"bridge","tieuDe":"Tra Hỏi Bí Mật Đông Hải","text":"Vương Lâm khống chế lão già thấp người của Đại La Kiếm Tông bằng phi kiếm cực cứng và thanh loan đao quỷ dị, ép lão khai bí mật về Kiếm Tôn từ tiên giới trở về cùng Đông Hải Yêu Linh chi môn — ba đại cấm địa, huyết tinh thí luyện, phần thưởng Yêu Linh quán đính. Khai xong, hắn để loan đao xuyên đầu giết lão rồi rời đi; khi lão dùng Tam phân thần thức thuật tái sinh, khí xám truy sát của hắn quay lại hút sạch sức sống lão."},{"chuong":"@c0485","importance":"bridge","tieuDe":"Sát Lục Tiên Quyết Ba Phân","text":"Ẩn trong Địa Ma Bắc giới hai mươi ngày tu Sát lục tiên quyết, Vương Lâm chuyển hoá sinh lực thành Sinh ấn, lần này ngưng kết được ba phân — ba phù văn xám bao phủ toàn thân khiến thân thể cứng hoá, kiếm chỉ miết qua không xuyên thấu. Còn sáu ngày là hết hạn ba tháng, hắn ra khỏi Địa Ma Bắc giới, ánh mắt quyết đoán hướng về Đông Hải, định đi cứu Chu Dật và tìm kim thuộc tính giúp Nghịch Thiên châu viên mãn để Lý Mộ Uyển thức tỉnh."},{"bridge":true,"khoang":"@c0487","text":"Được Thiên Vận Tử cử đi Đông Hải Yêu Linh, hóa đạo cầu vồng tử quang tới hội hợp với Tôn Vân Sơn rồi cùng vào trận pháp tinh không của Huyền Uyên phái để di chuyển tới cửa Đông Hải.","importance":"bridge"},{"chuong":"@c0488","importance":"bridge","tieuDe":"Bái kiến sư tôn trước cửa Đông Hải","text":"Vương Lâm hóa thân ảnh tử sắc phóng tới cửa Đông Hải Yêu Linh, tách khỏi Tôn Vân Sơn rồi cung kính tham kiến sư tôn Thiên Vận Tử. Hắn được tu sĩ nhận ra qua áo tử sắc và tử sắc lệnh bài là Tử Hệ Lão Thất Thiên Vận Tông, đứng vào hàng cùng chín đồng môn, được Thiên Vận Tử nhìn đầy thâm ý và nhắc có thể lấy được bảo vật."},{"bridge":true,"khoang":"@c0488–@c0488","text":"Sự xuất hiện của hắn thu hút chú ý của Lăng Thiên Hậu, Tham Lang, Diêu Tích Tuyết cùng nhiều lão quái; thủy triều Đông Hải năm nghìn năm một lần bắt đầu khởi động.","importance":"bridge"},{"chuong":"@c0489","importance":"bridge","tieuDe":"Chứng kiến thủy triều Đông Hải Yêu Linh","text":"Lần đầu đặt chân tới cửa Đông Hải Yêu Linh, Vương Lâm chứng kiến hiện tượng thủy triều năm nghìn năm một lần: vật trôi nổi xoay tròn ngưng tụ thành cột thanh khí cao ngàn trượng rồi nổ tan phát hồng quang. Đạo tâm hắn kiên định, không bị thần thông xoay tròn lôi cuốn. Khi cổ uy áp nồng hơn thiên uy gấp bội đè xuống như Thập Vạn Đại Sơn khiến thân thể rắc rắc sắp vỡ, hắn dùng đạo khí xám lóe trên mi tâm hóa thành ký hiệu bao trùm toàn thân, gắng chống đỡ tới cực hạn."},{"chuong":"@c0490","importance":"bridge","tieuDe":"Phá hồng quang nhìn thấy lệnh bài","text":"Khi cửa Đông Hải Yêu Linh bên ngoài Thiên Vận Tinh mở ra, hồng quang nghìn năm điên cuồng rút về như thủy triều, cuốn theo vô số pháp bảo, linh thạch, yêu thú vô chủ. Nhờ ký ức Cổ Thần Đồ Ti, Vương Lâm nhận ra nhiều vật luyện khí quý cùng một thanh đại kiếm rỉ sét hình cánh cửa trong hồng quang. Trước con sóng cuối ngăn cản thần thức, hắn vận ba đạo ấn ký khí xám trên mi tâm thành thần thông ánh mắt, chịu đau đớn chảy máu mắt để xuyên thủng tầng tầng hồng quang, nhìn rõ một khối lệnh bài kim quang khắc ký hiệu khiến mọi cao thủ đại biến sắc."},{"chuong":"@c0491","importance":"bridge","tieuDe":"Tiến nhập thế giới Đông Hải yêu linh","text":"Cố ý chậm chân vào cánh cửa Đông Hải yêu linh sau cùng, bị một lực kỳ dị đẩy tản khỏi chín đồng môn, một mình rơi xuống hoang nguyên giữa thế giới hỗn độn tự hình thành bên trong."},{"chuong":"@c0491","importance":"bridge","tieuDe":"Lập kế hoạch năm trăm năm","text":"Định ở lại năm trăm năm để tu Sát lục tiên quyết tới đại thành (ngưng kết lạc ấn sinh mệnh chống Thác Sâm), tìm cứu Chu Dật nơi phong ấn của Lăng Thiên Hậu, và truy tìm thanh đại kiếm Cự Phú để học kiếm kỹ kiếm hồn, tất cả nhằm đề phòng Thác Sâm thoát khốn truy sát."},{"chuong":"@c0492","importance":"normal","tieuDe":"Phát hiện sơn cốc trận pháp thượng cổ","text":"Sau khi bay mười ngày qua bình nguyên hoang vu, Vương Lâm phát hiện vùng núi non trùng điệp, chứng kiến một người nửa xích lõa không có linh lực nhưng linh tính kinh người săn giết dã thú. Theo người này tới một sơn cốc, hắn nhận ra bên ngoài cốc có trận pháp ẩn giấu khí tức sinh mạng do tu sĩ thượng cổ bố trí, thủ pháp khác hẳn liên minh tu chân, trong thời gian ngắn không thể phá giải."},{"bridge":true,"khoang":"@c0492","text":"Hắn trầm tư về khối lệnh bài bí ẩn từng khiến Thiên Vận Tử và Lăng Thiên Hậu biến sắc, định mượn năm trăm năm ẩn náu ở tinh cầu để tăng nhanh tu vi và tránh Thác Sâm. Khi thử trận pháp thì bị luồng khí xanh thôn phệ linh quang phản kích; cuối cùng hắn làm tan trường côn, dùng lực vô hình giam bốn người trong cốc để tra hỏi, rồi hai người nữa từ trong cốc đi ra.","importance":"bridge"},{"chuong":"@c0493","importance":"bridge","tieuDe":"Phá trận sơn cốc bộ tộc xích lõa","text":"Vương Lâm quan sát thượng cổ trận pháp ngoài sơn cốc bộ tộc thân trâu mình người, bắt giữ rồi thả tộc nhân, đối thoại với trưởng lão Âu Dương Hoa và được chỉ điểm về Cổ yêu thành. Sau đó hắn nhận ra Âu Dương Hoa trước mặt chỉ là thế thân hư ảo, dùng Cấm Phiên phóng chín trăm chín mươi chín đạo cấm khí công phá trận, rồi triển khai Cấm pháp chi mâu nghênh chiến thanh ảnh xanh do trận tạo."},{"chuong":"@c0494","importance":"bridge","tieuDe":"Phá trận thượng cổ sơn cốc","text":"Bị vây trong trận pháp thượng cổ của Âu Dương Hoa, Vương Lâm dùng trường mâu cấm khí câu giờ, vận thượng cổ cấm chế của cổ thần để tính toán rồi phóng ra tám mươi ba tổ hợp cấm chế đánh tan lồng thanh quang thôn phệ vạn vật, áp sát sơn cốc khiến Âu Dương Hoa hoảng sợ cầu tha."},{"chuong":"@c0495","importance":"normal","tieuDe":"Bức tranh Hoàng Long chấn động","text":"Vào sơn cốc tộc Âu Dương Hoa, khôi phục trận pháp cổ bảo vệ tộc nhân rồi tặng ba bình ngọc đan dược cố bổn bồi nguyên làm lời tạ lỗi. Tại nhà Âu Dương Hoa, hắn thấy bức tranh ố vàng vẽ Hoàng Long thượng tiên; nguyên thần chấn động, hồi tưởng quê nhà Chu Tước tinh và thời thiếu niên từ sơn thôn ra ngoài gia nhập Hằng Nhạc phái."},{"chuong":"@c0496","importance":"bridge","tieuDe":"Hấp thu yêu lực ngọc yêu linh","text":"Tại sơn cốc bộ tộc Âu Dương Hoa, Vương Lâm dùng hơn mười bình ngọc đan dược đổi lấy ngọc yêu linh (kết tinh tiên lực) khảm trong vách đá xanh thẫm. Hắn chụp lấy tinh thạch trắng, hấp thu khí tức cực lạnh yêu dị: khí tức chạy theo các khớp xương chứ không qua kinh mạch, tụ tại đan điền hóa thành tinh thể cỡ hạt gạo xoay như tinh vân, toàn thân biến hóa rõ ràng."},{"bridge":true,"khoang":"@c0496–@c0496","text":"Trầm ngâm về bức tranh người giống Hoàng Long chân nhân của Hằng Nhạc phái, nghe Âu Dương Hoa giải thích về Thiên Yêu quận, đêm yêu linh và quy luật người bên ngoài; khi đi qua khu cư dân, xoa đầu một hài đồng và nhớ tới Đại Ngưu lúc nhỏ.","importance":"bridge"},{"chuong":"@c0497","importance":"bridge","tieuDe":"Đổi yêu lực kết tinh ở Hồ Lô Cốc","text":"Tại thung lũng Hồ Lô Cốc trên Thiên Vận Tinh, Vương Lâm hấp thu yêu lực hống khiến yêu khí trong người biến hóa thành đoàn yêu hỏa; hắn nhận định yêu lực kết tinh giống tiên lực nhưng quỷ dị, có thể dung hợp đẩy tu vi. Hắn phất tay áo cho Âu Dương Hoa hơn mười bình ngọc để đổi lấy yêu lực kết tinh duy nhất của thung lũng, rồi ngồi thiền nghiên cứu trong đan điền."},{"bridge":true,"khoang":"@c0497","text":"Vương Lâm tách một tia nguyên thần hóa thần thức phóng đi xa, thấy yêu linh Đông Hải tạo đạo khí tím khuếch tán hình tròn hủy diệt sinh khí, rồi phát hiện Hắc y nam tử đang hấp thu yêu lực và tuyên bố coi hắn là con mồi; hắn nhận ra đối thủ là tu sĩ Ứng Biến hậu kỳ đại viên mãn.","importance":"major"},{"chuong":"@c0497","importance":"bridge","tieuDe":"Hiện thân cứu Hồ Lô Cốc","text":"Khi trận pháp thung lũng bị sóng yêu khí công phá sắp vỡ và Hắc y nam tử hóa điện quang phi kiếm lao tới, Vương Lâm bước một bước hóa khói nhẹ xuất hiện ở cửa cốc bên cạnh Âu Dương Hoa; lúc này hắn vẫn để đối thủ lầm tưởng mình chỉ Ứng Biến trung kỳ."},{"chuong":"@c0498","importance":"bridge","tieuDe":"Giao chiến La mỗ ngoài thung lũng yêu linh","text":"Tại Thiên Yêu quận, Vương Lâm gia cố trận pháp thung lũng giam yêu linh bằng Cấm Phiên rồi bước ra ngoài đối đầu hắc y nam tử La mỗ. Hắn diệt một đầu yêu linh thú, xuất kiếm tiên cùng loan đao làm rạn phi kiếm địch và đả thương ngực y. Khi La mỗ tung Kiếm toái cùng Địa diệt chi hỏa hóa sáu rồng lửa, Vương Lâm thi triển Sinh Chi Lạc Ấn chống đỡ, gây vụ nổ long trời rồi bước ra từ bóng tối suýt điểm trúng đối phương."},{"bridge":true,"khoang":"@c0499","text":"Giao chiến với Hắc y nam tử (La mỗ) trong vùng Yêu linh khí lãng: bị phối hợp kiếm vỡ hàn quang và hắc hỏa phá mất một tầng Sinh chi lạc ấn, đáp trả bằng Côn Cực Tiên đả thương nguyên thần đối phương; khi đối thủ phun độc khí rút lui, hắn niệm thần chú Phong gọi gió phá độc thoát ra rồi truy kích, quyết không tha.","importance":"major"},{"chuong":"@c0500","importance":"major","tieuDe":"Mở Xạ Thần Xa ép lui Hắc y nam tử","text":"Trong trận sinh tử với Hắc y nam tử (Anh Biến hậu kỳ đại viên mãn), Vương Lâm dùng chủ hồn — gồm tàn hồn kỳ lân — làm mồi nhử Quỷ ảnh, thừa cơ ném Khu Thú Quyển. Hắn thi triển Hóa ma chỉ và Sinh chi lạc ấn xuyên qua khói độc, rồi mở Xạ Thần Xa, dùng Cửu Tự Chân Ngôn khống chế Hồn thú nhằm thẳng đối thủ, buộc Hắc y nam tử bỏ thân xác cho nguyên thần chạy trốn."},{"chuong":"@c0501","importance":"major","tieuDe":"Bắt sống nguyên thần La Vân","text":"Sau khi hồn thú thiêu hủy thân thể Hắc y nam tử, Vương Lâm lần đầu phối hợp ăn ý với hồn thú qua Xạ Thần Xa, dùng Côn Cực Tiên quấn bắt nguyên thần đối phương (Anh Biến hậu kỳ đại viên mãn) trước khi hắn kịp tự nổ, giam vào hồn phiên. Khi hồn thú phẫn nộ vì bị cướp mồi, Xạ Thần Xa hóa Khu Thú Quyển hút mạnh tiên lực, Vương Lâm phải dùng tiên ngọc chống đỡ."},{"chuong":"@c0501","importance":"major","tieuDe":"Thi triển Sưu Hồn Thuật đoạt ký ức","text":"Vương Lâm lập cấm chế ngăn La Vân tự bạo, ép hắn lộ thân phận người Thiên Quỷ Đạo, rồi niệm Sưu Hồn rút kết tinh trong đan điền cùng toàn bộ ký ức của La Vân. Hắn dự định luyện nguyên thần đã suy yếu của La Vân thành một chủ hồn trong Tôn hồn phiên, và thấy trong ký ức có vài thuật ma cấm Thiên Quỷ Đạo đáng tu luyện."},{"chuong":"@c0502","importance":"normal","tieuDe":"Thấu hiểu cơ chế vùng đất yêu linh","text":"Qua ký ức La Vân, Vương Lâm nắm rõ vùng đất yêu linh chia mười quận, mỗi quận phong ấn một Cổ yêu chi linh; dung hợp được thì tu vi tăng vọt và có cơ hội vào cảnh thần chi thủy. Hắn định kế hoạch nhập Thiên Yêu quận để đạt chiến công, và phát hiện yêu tinh La Vân cộng yêu lực đã hấp thu vừa đủ ba giáp — hiểu vì sao La Vân muốn giết mình."},{"bridge":true,"khoang":"@c0502","text":"Hắn liên tưởng thần chi thủy với Thủy cảnh, nhớ lại tài liệu Cực Cảnh - Đạo cảnh - Thủy cảnh từng chiếm ở động tiên ngầm trong Tu Ma Hải, mơ tưởng kết hợp Cực cảnh và Thủy cảnh thành đại đạo luân hồi rồi tự kiềm chế.","importance":"normal"},{"bridge":true,"khoang":"@c0502","text":"Dịch chuyển tới bình nguyên có khe rãnh, hắn há mồm hút các chủ hồn âm hồn (gồm một đầu lân) dung nhập Tôn Hồn Phiên, rồi dùng thuật đám bụi khí hóa hàn quang truy diệt Thiên quỷ phản chủ của La Vân đang suy yếu trốn trong khe, phủ đầy tro bụi lên thân nó.","importance":"bridge"},{"chuong":"@c0503","importance":"major","tieuDe":"Thu Phục Thiên Quỷ","text":"Vương Lâm dụ Thiên quỷ ra khỏi khe rãnh, dùng Côn Cực Tiên chuyên đánh nguyên thần quất cho suy yếu. Theo trí nhớ La Vân, hắn biết Thiên quỷ sau phản bội cần bốn chín ngày tu dưỡng nên quyết bắt sống lúc nó yếu nhất. Khi Thiên quỷ phun Bản mạng chi hỏa định hủy roi, Côn Cực Tiên lóe một đạo kim quang chụp tắt lửa khiến Thiên quỷ suýt tiêu tan; hắn vội thu roi, dùng hồn phiên cuộn Thiên quỷ vào giữ lại."},{"bridge":true,"khoang":"@c0503","text":"Ba ngày sau hắn về sơn cốc tộc Âu Dương Hoa qua trận pháp đã dung hợp cấm phiên, vào cấm địa tọa định. Hắn tính ở lại giáo hóa cư dân, truyền thuật hồn phiên để gây dựng lực lượng riêng trước khi tới thành Cổ Yêu, nhắm khôi phục Tôn hồn phiên và đoạt Cổ yêu chi linh. Hắn lưu khẩu quyết Luyện Hồn, Trừu Phách cùng cách chế tác hồn phiên vào hai ngọc giản, cố ý cài một sơ hở trí mạng chỉ mình biết để có thể trực tiếp khống chế hồn phiên của đệ tử.","importance":"bridge"},{"chuong":"@c0504","importance":"normal","tieuDe":"Truyền Luyện Hồn thuật cho cốc yêu linh","text":"Vương Lâm chế tác yêu giản chứa khẩu quyết luyện hồn, cưỡng ép song chỉ đả thông một kinh mạch giúp trưởng lão Âu Dương Hoa đột phá nhị tinh, rồi tuyên bố truyền thụ thuật luyện hồn cho toàn bộ cư dân sơn cốc — thứ cực hiếm nơi vùng đất yêu linh."},{"bridge":true,"khoang":"@c0504","text":"Suốt ba tháng hắn nghiên cứu yêu tinh, dung hợp hai khối thành ‘Ba giáp yêu tinh’ ẩn yêu lực vô biên; nuốt thử khiến thân hóa yêu dị (đồng tử dựng đứng) nhưng vận chuyển toàn bộ chỉ đạt Trúc Cơ kỳ vì lượng yêu lực chưa đủ, sau đó rút yêu lực về và trở lại trạng thái siêu phàm.","importance":"normal"},{"chuong":"@c0505","importance":"bridge","tieuDe":"Cài sơ hở khống chế hồn thú","text":"Tại sơn cốc ở Thiên Vận Tinh, Vương Lâm chế hồn phiên thay thế từ cươn thụ chi mộc, da dã thú và thủ ấn để bù tài liệu thiếu khuyết, rồi cải biến Luyện Hồn Thuật cài backdoor khiến mọi hồn thú do người học thuật phong ấn đều bị hắn hoàn toàn điều khiển và chấn nhiếp."},{"chuong":"@c0505","importance":"bridge","tieuDe":"Chấn nhiếp sư tử cánh dài phản phệ","text":"Khi hồn phách sư tử cánh dài quay đầu phản phệ Thập Tam, Vương Lâm chỉ một tiếng hừ “Nghiệt súc, ngươi dám!” đã khiến nó tan nát rồi nằm bẹp thuần phục; hắn lướt mấy trăm trượng hiện thân, khiến cả sơn cốc kinh hãi sùng kính."},{"bridge":true,"khoang":"@c0505–@c0505","text":"Vương Lâm coi trọng ngộ tính của Thập Tam, trao ngọc giản phương pháp chế hồn phiên mới, mặc Âu Dương Hoa định kế tấn công bộ tộc cách ngàn dặm v��i một câu “Tùy ngươi!”.","importance":"bridge"},{"chuong":"@c0506","importance":"bridge","tieuDe":"Lập kế Tán Hồn Dưỡng Phách","text":"Đóng vai ‘thượng tiên’ ẩn ở sơn cốc, Vương Lâm thao túng bộ lạc tu Luyện Hồn Thuật để gom hồn phách và yêu tinh. Hắn để tộc nhân phong ấn hồn phách vào Hồn Phiên, chỉ cần khởi ý là thu về — kế sách ‘tán hồn dưỡng phách’ nhằm hồi phục thập ức tôn Hồn Phiên."},{"bridge":true,"khoang":"@c0506–@c0506","text":"Thu phục con sư tử yêu thú làm chủ hồn cho Hồn Phiên của Thập Tam, cảnh cáo về rủi ro chủ hồn cắn trả; ban khẩu quyết Luyện Hồn Thuật theo công lao; nuốt nhị giáp yêu tinh Âu Dương Hoa dâng, dung hợp thành ngũ giáp yêu tinh trong đan điền.","importance":"bridge"},{"chuong":"@c0507","importance":"bridge","tieuDe":"Cứu Thập Tam, nhận Chiến thư","text":"Cứu Thập Tam khỏi yêu vật tơ hồng ký sinh, thu chủ hồn sư tử thành dấu ấn ngón tay; nhận ra việc lão áo trắng cướp hồn phiên và để lời nhắn là Chiến thư khiêu khích."},{"chuong":"@c0507","importance":"bridge","tieuDe":"Nhổ đất phá trận Thiên Thủy","text":"Không phá nổi trận pháp viễn cổ mười dặm, dùng Khai Thiên phủ đào vòng quanh ven trận rồi nhổ cả mảnh đất mười dặm bay lên, mang về thung lũng luyện hóa bằng lửa sáu chủ hồn."},{"chuong":"@c0507","importance":"normal","tieuDe":"Giết lão áo trắng, lập bộ lạc Luyện Hồn","text":"Bóp cổ giết lão áo trắng, giam nguyên thần vào cờ Tôn Hồn; thu nạp toàn bộ dân Thiên Thủy, dung hợp ba trận thành trận hai mươi dặm, lập bộ lạc Luyện Hồn với hơn năm trăm nam đinh."},{"bridge":true,"khoang":"@c0507","text":"Hai năm ở Yêu Linh chi địa, hấp thu yêu lực từ vạn vật; bộ lạc Luyện Hồn mỗi tháng đánh chiếm bộ lạc nhỏ thu tù binh và yêu tinh.","importance":"bridge"},{"chuong":"@c0508","importance":"bridge","tieuDe":"Dựng bộ lạc Luyện Hồn hùng mạnh","text":"Mở rộng trận pháp lên bốn mươi dặm rồi dùng Tôn Hồn phiên tạo màn sương đen tế dưỡng hồn phách cho toàn tộc. Qua bốn năm, bộ lạc bành trướng tới gần ba trăm dặm với hơn năm nghìn nam đinh, thôn tính hầu hết bộ lạc trong mười vạn dặm; hắn ba lần ra tay diệt cao thủ tọa trấn rồi dừng tấn công, để mười vạn dặm thành thế chân vạc."},{"chuong":"@c0508","importance":"normal","tieuDe":"Cứu và thu phục Thập Tam","text":"Phát hiện Thập Tam tự nhiên luyện thể nhờ tích yêu lực trong xương cốt máu thịt; dùng Nguyên thần đọc trí nhớ, cảm động trước sự kiên trì hơn một năm của hắn nên ra tay cứu chữa và truyền Luyện Thể thuật của Cự Ma Tộc, hứa truyền khẩu quyết tầng một Cổ Thần nếu thành tựu."},{"chuong":"@c0508","importance":"bridge","tieuDe":"Lên đường tới Cổ Yêu thành","text":"Luyện hai ngọc giản truyền âm làm đường lui (một mang theo, một để lại bộ lạc), dẫn Thập Tam và Hổ Bào rời bộ lạc, triệu Văn Thú làm tọa kỵ tiến về Cổ Yêu thành."},{"chuong":"@c0509","importance":"bridge","tieuDe":"Tới Cổ Yêu thành giành chức vị","text":"Vương Lâm cưỡi Văn Thú vượt ba ngàn vạn dặm tới Cổ Yêu thành trong Thiên Yêu quận, mang theo Thập Tam và Hổ Bào. Hắn không thu liễm tiên lực, phá quy củ ở cửa Bắc, thị uy đám yêu binh bằng một quyền vào không trung khiến cả đám đông cứng rồi bị đẩy bay thổ huyết."},{"chuong":"@c0509","importance":"normal","tieuDe":"Đối đầu Tả dực Yêu tương","text":"Được Diêu Nghiêu lĩnh dẫn qua Truyền tống trận tới cung điện Yêu tương, Vương Lâm hóa giải đòn quyền thử của Tả dực Yêu tương bằng Tịch Diệt chỉ, từ chối chức Trưởng lão (chức trong không binh quyền) vì chỉ muốn chức ngoài có binh quyền. Khi bị ra đòn Thập Băng Chiến Ý, hắn đứng vững vận Sát lục tiên quyết kết hợp Hóa Ma chỉ nghịch hóa tiên lực thành ma khí mà tiếp."},{"chuong":"@c0510","importance":"bridge","tieuDe":"Đối đầu Thập Băng Quyền Ý","text":"Tại Cổ Yêu thành, Vương Lâm giao chiến với Tả dực Yêu tương dưới thần công Thập Băng Quyền Ý gồm tám lần sụp đổ ngày càng mạnh. Hắn lần lượt dùng Hóa Ma chỉ chống lần thứ nhất, Sát lục tiên quyết tạo hai con rồng khí xám và lốc xoáy giết chóc cho lần thứ hai, rồi ngưng thành trường kiếm bảy thước khí xám chém vỡ lần thứ ba. Đến lần thứ tư mạnh gấp ngàn lần khiến trường kiếm vỡ nát, hắn không muốn lộ Hoàng Tuyền chỉ ở Yêu linh nguy cơ nên thu khí xám về, hiện hai đạo Sanh ấn phòng hộ trên mi tâm."},{"chuong":"@c0510","importance":"bridge","tieuDe":"Cảm ngộ “niềm tin”","text":"Giữa lần sụp đổ thứ tư, Vương Lâm cảm nhận trong quyền ý ẩn chứa một niềm tin vô bờ bến, ánh mắt sáng ngời — loại cảm ngộ mấy trăm năm hiếm thấy, được ví như Chu Dật năm xưa lúc linh lực thiêu đốt ngộ ra, hé mở một bước lĩnh ngộ sắp tới."},{"chuong":"@c0511","importance":"normal","tieuDe":"Ngộ Thần Thông Niềm Tin","text":"Dưới sức ép Thập Băng Quyền Ý của Tả dực Yêu tướng, Vương Lâm cảm nhận được ‘niềm tin tất thắng’ tích lũy từ tâm niệm vô số kẻ bại trận, ngộ ra bản chất quyền ý là Thần thông Niềm tin — đạo tâm thăng hoa, nguyên thần dung nhập đạo tâm, một niềm tin vững có thể đổi cả trời đất. Hắn nhận ra mấu chốt phá quyền ý không nằm ở tu vi mà ở niềm tin, từ đó dung niềm tin vào pháp thuật và lần đầu khơi dậy uy lực chân chính của Hóa Ma chỉ."},{"chuong":"@c0511","importance":"bridge","tieuDe":"Một Chỉ Hóa Ma Chân Chính","text":"Vương Lâm chỉ thẳng lên trời, tiên lực vô thanh vô tức hóa thành ma khí khác hẳn lối nghịch chuyển; tóc dài quá gối, ma văn xanh bạc hiện ở mi tâm, ma khí lan trăm trượng hóa lửa xanh. Nửa Sanh ấn còn sót dung hợp tâm tính, sinh trưởng lại thành đầy đủ và bao trùm toàn thân. Hắn lĩnh ngộ thêm ‘Ma niệm’ — nghịch thiên tùy ý, phá hư đạo pháp, tự đi con đường riêng."},{"chuong":"@c0511","importance":"bridge","tieuDe":"Phá Bảy Lần Sụp Đổ Quyền Ý","text":"Dùng Hóa Ma chỉ tạo biển lửa ma rồi hóa thân đen như bóng ma, Vương Lâm phá liên tiếp lần sụp đổ thứ năm và thứ sáu của Thập Băng Quyền Ý. Đến lần thứ bảy, hắn dồn niềm tin vô bờ vào hai chữ ‘Nhường đường’ khiến đợt sụp đổ tan biến, trở thành người đầu tiên cảm ngộ được dưới quyền ý này khiến Tả dực Yêu tướng lần đầu chấn động sau mấy ngàn năm."},{"chuong":"@c0512","importance":"bridge","tieuDe":"Thống lĩnh Cổ Yêu thành","text":"Trong khảo nghiệm của Tả Dực Yêu tương, Vương Lâm nhập ma vượt qua bảy lần ‘sụp đổ’ của Thập Băng Quyền, đối kháng được lần thứ tám hóa dạng nước lũ; khi lần thứ chín im lìm xuất hiện, hắn quyết đoán lùi ra nghìn trượng để bảo toàn đạo tâm thay vì liều đánh. Được khen biết tiến biết lùi, hắn được phong Thống lĩnh Cổ Yêu thành nắm một vạn yêu binh, nhận một lệnh bài đồng."},{"chuong":"@c0512","importance":"normal","tieuDe":"Nén ma niệm thành phong ấn","text":"Vào trung tâm Cổ Yêu thành, hắn khoanh chân thổ nạp bốn ngày bốn đêm để khôi phục đạo tâm. Nhận ra đạo của mình không phải ma đạo, nếu để ma niệm tràn lan sẽ thành ma đầu mất thần trí, hắn không loại trừ mà nén ma niệm thành một điểm phong ấn trong cơ thể để giữ làm uy lực về sau. Hắn cũng làm rõ động cơ nhập ma là lĩnh ngộ Niềm tin và đoạt lấy chức vị bên ngoài."},{"bridge":true,"khoang":"@c0512","text":"Ngày thứ năm, Thập Tam và Hổ Bào hội hợp; ba người dạo Cổ Yêu thành. Vương Lâm ngờ cả vùng Yêu linh Đông Hải là động phủ một vị tiên đế, cư dân như gia súc trong ‘hàng rào tre’. Ở Trúc Thanh lâu, hắn uống rượu Trúc Thanh và hoài niệm loại rượu duy nhất từng uống thời phàm nhân ở Chu Tước Tinh do Đại Ngưu để lại.","importance":"bridge"},{"chuong":"@c0513","importance":"normal","tieuDe":"Tâm ma trỗi dậy, ngộ ma niệm","text":"Uống rượu cùng Thập Tam và Hổ Bào, Vương Lâm chìm trong hồi ức hơn mười năm sống đời phàm nhân, nhớ Đại Ngưu và Chu Tước tinh — nơi hắn sinh ra. Niềm xúc động muốn trở về cố hương kéo dài bất thường khiến tâm ma bị áp chế lớn mạnh, chén rư��u vỡ cắm vào tay mà hắn không hay. Cuối cùng sáu đạo yêu lực mất khống chế chui vào mi tâm, ma niệm hút trọn khiến hắn bừng tỉnh khỏi hồi ức, ánh mắt trở lại trong sáng và kinh hãi nhận ra ma niệm lợi hại."},{"chuong":"@c0514","importance":"normal","tieuDe":"Thoát nhập ma nhờ nuốt yêu lực","text":"Bị ma niệm còn sót lôi ký ức Chu Tước tinh khiến đắm chìm tựa kiếp nạn; nhờ yêu lực sáu yêu binh tung hoành trong tửu lâu mà tìm được đường đột phá, dung hợp yêu lực vào tiên lực rồi cắn nuốt toàn bộ sáu luồng yêu lực, thần trí khôi phục."},{"chuong":"@c0514","importance":"bridge","tieuDe":"Khu trừ sạch ma niệm","text":"Về khách sạn vận tiên lực dò khắp cơ thể suốt hai ngày, trục xuất hết ma niệm kết thành ba quả cầu đen, thu vào túi trữ vật để dùng làm thủ đoạn ảnh hưởng đạo pháp đối phương về sau."},{"bridge":true,"khoang":"@c0514–@c0514","text":"Rời tửu lâu, vung tay tạo gió hóa giải đòn trường kiếm yêu khí của nam tử âm trầm, để lại lời sẽ còn gặp lại.","importance":"normal"},{"chuong":"@c0514","importance":"bridge","tieuDe":"Tới quân doanh, đối diện vạn yêu binh","text":"Theo quản sự tham quân qua Truyền Tống trận tới quân doanh; khi qua trận, truyền lực ôn hòa cứu Hổ Bào loạn yêu lực và chữa thương Thập Tam; đứng giữa hơn vạn yêu binh giáp đen dồn sát khí mà vẫn hết sức bình thản, đáp lại bằng ánh mắt lạnh lẽo."},{"chuong":"@c0515","importance":"bridge","tieuDe":"Nhậm chức Thống lĩnh Hắc Giáp quân","text":"Vương Lâm từ pháp trận bước ra, chính thức nhậm chức tân thống lĩnh đạo quân yêu binh một vạn người Hắc Giáp quân ở Yêu Linh chi địa, với Tư Mã Viêm làm phó thống lĩnh. Khi hắn lệnh toàn quân lui ra, không một yêu binh nào động đậy cho tới khi Tư Mã Viêm lên tiếng, chúng cười khinh miệt sau lưng hắn. Vương Lâm không tranh chấp, cùng Thập Tam và Hổ Bào ngồi thổ nạp ngoài bãi đất trống suốt ba ngày, dùng thần thức quan sát toàn bộ vạn yêu binh và nắm rõ cơ cấu mười Thống đội."},{"bridge":true,"khoang":"@c0515","text":"Dựa vào ghi chép tổ tiên do La Vân đưa, Vương Lâm hiểu rõ quy tắc Cửu quận yêu binh cùng quy định mười người không nghe hiệu lệnh, quyết không vội ra tay mà ẩn nhẫn chờ thời cơ chỉnh đốn toàn quân như một thợ săn rình mồi.","importance":"bridge"},{"chuong":"@c0516","importance":"bridge","tieuDe":"Ép Phục Quân Doanh Thiên Yêu","text":"Sau nửa tháng ẩn nhẫn thổ nạp trong quân doanh Thiên Yêu quận, Vương Lâm ra tay bóp chết Tôn thống đội kẻ sỉ nhục mình là phế vật, phá tu vi và hút yêu khí từ thất khiếu xác chết. Hắn trảm nửa ngàn yêu binh phản kháng bằng kiếm tiên và loan đao, hấp thu yêu lực mấy trăm xác yêu binh tạo thành lốc yêu lực quanh thân. Khi chín ngàn yêu binh sắp trận vây khốn và Tư Mã Viêm phóng tới chất vấn, hắn vẫn ngồi khoanh chân, sai Thập Tam viện dẫn quân quy điều mười ba và điều hai để ép cả đám phải lùi, rồi nhắm mắt cho Thập Tam đếm ngược nhịp hô hấp."},{"chuong":"@c0517","importance":"normal","tieuDe":"Trình ngọc giản thoát truy cứu","text":"Khi quản sự tham quân và lão già áo vải bố tới thị uy, Vương Lâm chỉ một cái liếc mắt khiến phong ấn trong thân lão già suýt vỡ, rồi ném ngọc giản lưu hình ảnh chứng minh thống lĩnh giết người vô cớ. Quản sự bỏ ý truy cứu, sinh lòng kết giao và hứa bẩm báo Yêu Tương đại nhân theo hướng có lợi cho hắn."},{"chuong":"@c0517","importance":"bridge","tieuDe":"Dựng lầu bùn đất lập uy","text":"Vương Lâm nhấn tay xuống đất, mặt đất rung chuyển phun lên một ngôi lầu hai tầng bằng bùn đất uy nghiêm, chấn nhiếp Tư Mã Viêm cùng chín ngàn yêu binh; uy danh trong Hắc Giáp quân ngày càng vượt Tư Mã Viêm."},{"chuong":"@c0518","importance":"normal","tieuDe":"Diêu Tích Tuyết cầu phá trận","text":"Trong lầu tối doanh trại Hắc Giáp quân, Vương Lâm bị Diêu Tích Tuyết xông vào nhờ trợ giúp bài trừ một trận pháp cấm chế mười tám phong ấn. Hắn ban đầu từ chối vì đang luyện hóa yêu lực và nghi nàng giấu giếm, nhưng dao động mạnh khi nàng hứa cung cấp đủ tiên ngọc để hắn đạt Vấn Đỉnh sơ kỳ. Hắn hoãn quyết định, hẹn sau bốn tháng cho câu trả lời."},{"bridge":true,"khoang":"@c0518","text":"Vương Lâm khổ tu trong Hắc Giáp quân, sau khi hấp thu yêu lực của năm trăm yêu binh và Tôn thống đội, yêu tinh trong cơ thể dung hợp đạt gần ngàn giáp nên tốc độ hút yêu khí tăng vọt; hắn dùng cơn gió giải trừ khống chế của Diêu Tích Tuyết trên Thập Tam và ra hiệu cho Thập Tam ngừng can dự.","importance":"bridge"},{"chuong":"@c0519","importance":"normal","tieuDe":"Nhận Huyết Hồn đan, ước hẹn cổ sơn","text":"Trước lời nhờ bài trừ phong ấn của Diêu Tích Tuyết, Vương Lâm liên tục trì hoãn để nâng giá, cuối cùng nhận cây đèn Huyết Hồn đan cùng túi tiên ngọc đủ tu tới Anh Biến hậu kỳ, hẹn ba ngày sau canh ba lên cổ sơn cùng đi. Triệu hồn phách Tào Nhất Đấu giám định, hắn dần sinh nghi sự hào hiệp bất thường của đối phương cùng việc phương pháp phân biệt đan quá phổ biến, đoán ra đèn chỉ là phế đan độc do Huyết Tổ tung ra để giữ bảo vật thật."},{"chuong":"@c0520","importance":"bridge","tieuDe":"Luận phá Huyết Hồn đan giả","text":"Từ thân phận thấp kém của Tào Nhất Đấu cùng thái độ hào hiệp của Diêu Tích Tuyết, Vương Lâm suy ra Huyết Hồn đan có thật-giả mà chỉ cha con Huyết Tổ mới phân biệt được, xác định viên đan nàng đưa là giả khiến người dùng tử vong. Hắn không vạch trần, lặng lẽ cất cây đèn vào túi trữ vật, giữ thế chủ động."},{"chuong":"@c0520","importance":"normal","tieuDe":"Luyện thành Tiên tinh","text":"Thu túi trữ vật Diêu Tích Tuyết với lượng tiên ngọc đủ tu tới Anh Biến hậu kỳ, hắn chìm xuống lòng đất ba ngày hấp thu điên cuồng. Dựa kết cấu yêu tinh học được ở bộ lạc Luyện Hồn, hắn cô đọng tiên lực thành ‘Tiên tinh’ — vật giống yêu tinh nhưng tỏa tiên lực, chứa lượng bằng một phần mười số tiên ngọc."},{"chuong":"@c0520","importance":"bridge","tieuDe":"Truyền tống tới không gian Tôn Long","text":"Theo Diêu Tích Tuyết tới cổ sơn ngoài quân doanh ngàn dặm, hắn cùng nàng vượt truyền tống trận lúc trăng tím cực điểm, tới một không gian giống tinh không chỉ toàn ánh sáng. Hắn nhận ra con đường uốn lượn là thân giao long Tôn Long do thần thông bố trí, định moi bí mật từ Diêu Tích Tuyết thì trong đầu chợt nảy một ý nghĩ."},{"text":"Tại Yêu Linh chi địa, Vương Lâm tĩnh tâm cảm ngộ ý cảnh Sinh Tử luân hồi (tay trái sinh, tay phải tử, ở giữa là thời gian bất biến) mà vẫn phân một niệm cảnh giác Diêu Tích Tuyết. Khi lực lượng thần bí từ trời giáng xuống, hắn dùng ấn ký Sát Lục chi đạo trên mi tâm cùng Sinh ấn, chọn nghe thanh âm thay vì nhìn ảnh, nắm bắt được tiếng tự xưng “Ta là Thanh Sương” và đắc kim phù ấn sáu nét — phức tạp, lấn át hẳn kim phù ba nét của Diêu Tích Tuyết.","bridge":true,"khoang":"@c0521","importance":"bridge"},{"bridge":true,"khoang":"@c0521","text":"Hai người bước lên con đường Tôn Long lắc lư trong hư không, đi cực nhanh ba ngày mới được một phần ba đường; tới bình đài phong ấn đầu tiên, Vương Lâm quan sát Diêu Tích Tuyết kích hoạt rồi phong ấn tượng đá, hiểu thêm thực lực của nàng.","importance":"bridge"},{"text":"Trên con đường Tôn Long, Vương Lâm một mình ác chiến với pho tượng đá ba mắt ở bình đài thứ ba. Hắn nhận ra tượng vốn không tồn tại mà chỉ là một đống cấm chế chồng lớp, liền dùng Cấm phiên hấp thu nguồn lực lẫn rừng cột đá nhọn, rồi phun máu triệt tiêu ánh sáng vàng từ con mắt thứ ba và hét bốn tiếng phá vỡ tượng. Cuối cùng hắn vẽ ký tự hai nét bằng tiên lực, hút lấy ký tự vàng dung hợp vào nét vẽ của mình.","bridge":true,"khoang":"@c0522","importance":"bridge"},{"text":"Trên đài phong ấn đường Tôn Long, Vương Lâm vẽ thành công ba nét phù văn trong mắt; khi tiên lực dung nhập, ký hiệu phát kim quang xua tan hắc khí, ẩn chứa ấn ký thiên đạo. Hắn không vẽ ra nổi nét thứ tư vì thiếu căn cứ, nhưng kim phù đủ uy thế buộc Diêu Tích Tuyết phải dùng huyết ngọc trăm năm hóa giải.","bridge":true,"khoang":"@c0523","importance":"bridge"},{"chuong":"@c0523","importance":"normal","tieuDe":"Dùng kế tiên tinh phong ấn Diêu Tích Tuyết","text":"Tự xưng chỉ Anh Biến trung kỳ, Vương Lâm cố ý trúng đạo kiếm khí thứ nhất rồi chấn nát tiên tinh giấu trong người để bùng tiên lực chống đỡ, diễn cảnh trọng thương văng vào hư vô đánh lừa Diêu Tích Tuyết. Khi nàng kiệt lực vì hai đạo kiếm khí sau, hắn đội mũ rơm Vân Tước Tử che thần thức bay lên, điểm mi tâm phong ấn nàng giữa sự sống và cái chết, đoạt sạch bốn túi trữ vật rồi đề nghị giao dịch."},{"text":"Vương Lâm mặc cả giảm năm mươi năm trong tổng năm trăm năm phong ấn để đổi một câu trả lời, kèm lời cảnh báo nếu nàng nói dối thì về sau y sẽ không tới mở phong ấn. Diêu Tích Tuyết chỉ đáp muốn vào không có nguyên nhân, không chịu khai thật, nên y bấm pháp quyết bủa hàng loạt cấm chế thành vòng tròn tản hắc quang, ôm nàng ném vào rồi hô Phong, thu thành quả cầu nhốt nàng cất vào túi trữ vật.","bridge":true,"khoang":"@c0524","importance":"bridge"},{"chuong":"@c0524","importance":"bridge","tieuDe":"Phá Bình Cảnh Thuật Cấm Chế","text":"Trong khu vườn trung tâm động phủ tiên cấm, Vương Lâm thôi diễn cấm chế suốt hai tháng, liên tục bắn tiên lực dẫn phát thử từ ba nghìn biến hóa lên hơn một vạn, mắt đỏ ngầu quên cả thân ở động phủ người khác. Nhờ sở học cấm chế thượng cổ thời Cổ Thần cộng sách cổ ở Chu Tước Tinh và mấy trăm năm dung hợp, khi chín trăm chín mươi chín tổ cấm chế trên cấm phiên hoàn thành, y vô tình phá vỡ bình cảnh, độ nắm chắc phá giải tăng từ bốn phần lên năm phần."},{"bridge":true,"khoang":"@c0524","text":"Qua vấn đáp với Động Phủ Chi Linh, Vương Lâm xác nhận tư cách tiến vào, đọc dấu vết ba tiền nhân (một người dùng Mai Hoa Thập Bát Cấm, hai kẻ cưỡng ép phá lấy đồ) rồi men theo đường sinh tiến vào khu vườn; đi nhiều vòng tới cách bàn đá ba bốn trượng thì trận pháp đột nhiên xoay ngược đổi phương hướng vận chuyển, nổ cơn lốc đen sấm chớp như Du Long.","importance":"bridge"},{"chuong":"@c0525","importance":"normal","tieuDe":"Đại tiến tu vi, sát ngưỡng Vấn Đỉnh","text":"Phá cấm chế tiến vào bàn đá, kích hoạt chùm sáng vạn trượng mở ra động phủ và nhận tư cách sở hữu cùng Động Phủ Lệnh. Vương Lâm đoạt được bầu rượu chứa mười giọt mỹ tửu, uống một giọt liền chìm vào giấc ngủ say suốt một năm. Trong giấc ngủ tiên lực điên cuồng tăng trưởng, Yêu Tinh trong đan điền vỡ tan hòa vào tiên lực; tỉnh dậy hắn kinh hoàng nhận ra tiên lực đã vượt xa Anh Biến hậu kỳ đại viên mãn, chỉ cần cảm ngộ thành công ý cảnh là đủ sức trùng kích Vấn Đỉnh."},{"bridge":true,"khoang":"@c0525–@c0525","text":"Hắn phong ấn cất kỹ bầu rượu cùng chín giọt còn lại, dự định khi ý cảnh đủ sẽ quay lại nơi thần bí này trùng kích Vấn Đỉnh, rồi dùng lệnh bài thủy tinh rời khỏi động phủ, xem đó là kho báu lớn sẽ trở lại khai thác.","importance":"normal"},{"chuong":"@c0526","importance":"major","tieuDe":"Áp chế quân doanh Hắc Giáp quân","text":"Sau hơn một năm mất tích, Vương Lâm truyền tống về ngoài Cổ Yêu Thành rồi lao tới quân doanh Hắc Giáp quân. Hắn phá tan màn sương đen phòng hộ, chỉ một tiếng quát “Lui ra!” đã chấn nhiếp bốn thống lĩnh, rồi từng bước áp khí thế tới Đô Thống và thi triển Tịch Diệt Chỉ khiến thiên địa biến sắc."},{"bridge":true,"khoang":"@c0526","text":"Hắn mở ba trong bốn túi trữ vật cướp của Diêu Tích Tuyết, né cạm bẫy tử tuyến trên túi thứ tư, thu được tiên ngọc, Ngọc phù huyết sắc, Huyết Hồn Đan và la bàn huyết sắc; sau đó dùng ba ngày hiệu chỉnh la bàn cùng trận truyền tống, ba mươi ngày bố trí cấm chế biến trận thành cạm bẫy nuốt người ngoài vào khe không gian.","importance":"bridge"},{"text":"Tại vùng đất Yêu Linh, Vương Lâm hạ gục Đô thống Tần Lâm bằng Tịch Diệt Chỉ, phá tan Huyền Vũ hóa thân của hắn. Hắn thi triển Sưu hồn thuật lên Tư Mã Viêm, đọc ra việc Hổ Bào bị phế tu vi ném vào hắc lao rồi mất tích, còn Thập Tam bị phế rồi bị Tần Lâm mang dâng cho Yêu Tướng. Phẫn nộ, hắn vận Sát Lục Tiên quyết giết Tư Mã Viêm, luyện hóa toàn thân công phu đối phương thành tia khí xám tụ ở tay phải. Hắn tha Tần Lâm vì có công có tội, rồi quyết tâm xông thẳng sáu cửa vào cung Yêu Tướng để cứu Thập Tam, dù điều đó tương đương chống lại cả Thiên Yêu Quận.","bridge":true,"khoang":"@c0527","importance":"major"},{"bridge":true,"khoang":"@c0527","text":"Tu vi Vương Lâm lúc này ở Anh Biến đại viên mãn, chênh lệch như hào sâu so với Anh Biến hậu kỳ, đã gần tiếp cận Vấn Đỉnh; tự nhận mình không hợp làm người tu đạo, chỉ cầu cả đời không thẹn lương tâm. Hắn hiện thân trước cửa thứ sáu, thả tiên kiếm chứa Hứa Lập Quốc bay ra chuẩn bị phá cửa.","importance":"normal"},{"text":"Để cầu kiến Yêu Tướng, Vương Lâm một mình xông phá liên tiếp năm cánh cửa cung điện, lần lượt thi triển Tịch Diệt Chỉ, Sát Lục Tiên quyết, Hóa Ma Chỉ rồi Hoàng Tuyền Chỉ, giết vô số yêu binh và các cường giả trấn cửa. Cuối cùng hắn chạm trán người cao lớn dùng Thập Băng Quyền ý ở cửa thứ nhất, bị sóng chấn đẩy lùi hơn ba trượng mới đứng vững, còn Yêu Tướng thì suốt trận không hề ra mặt.","bridge":true,"khoang":"@c0528","importance":"normal"},{"text":"Đối đầu chiêu Yêu Hải Bách Lãng của Mạc Lệ Hải, Vương Lâm dùng Sát Lục chi khí cùng phù văn thần thông từ tượng đá thứ hai phản kích, rồi tạo một chưởng ấn hư ảo mang khí thế hủy thiên diệt địa. Chưởng ấn thực ra vô lực, nhưng buộc Mạc Lệ Hải không dám đánh cuộc mạng sống, phải nhận thua và thả người.","bridge":true,"khoang":"@c0529","importance":"bridge"},{"chuong":"@c0529","importance":"bridge","tieuDe":"Nhận chức Tả dực đệ nhất phó tướng","text":"Mạc Lệ Hải mời Vương Lâm làm Tả dực đệ nhất phó tướng, hứa nếu trợ giúp tại so đấu Thiên Yêu thành ba tháng sau sẽ tiến cử lên Yêu Đế. Vương Lâm nhận lời, cứu được Thập Tam đang bị giam."},{"bridge":true,"khoang":"@c0529","text":"Tìm khắp Cổ Yêu thành và hắc lao nhưng không thấy dấu vết linh hồn Hổ Bào, Vương Lâm về bộ lạc Luyện Hồn được toàn tộc quỳ nghênh lão tổ; ba ngày sau đánh thức Thập Tam, nắm rõ mọi chuyện một năm qua.","importance":"bridge"},{"bridge":true,"khoang":"@c0530–@c0530","text":"Trong Luyện Hồn cốc, Vương Lâm ghi nhớ trọn chín tầng Cự Linh Cửu Tu rồi xóa ba tầng sau, chỉ chép sáu tầng đầu vào ngọc giản xanh ném cho Thập Tam, dặn bảo vệ bộ tộc Luyện Hồn; sau đó ngồi một mình dưỡng hồn bằng hắc vụ do Tôn Hồn Phiên hóa thành, tính toán ba tháng sau phải lên đường tới kinh thành Thiên Yêu quận nên không thể mang theo Tôn Hồn Phiên.","importance":"bridge"},{"text":"Trong sơn cốc bộ lạc Luyện Hồn, cho Diêu Tích Tuyết cơ hội đổi câu trả lời lấy 50 năm giảm phong ấn; nàng từ chối, hắn phá nỗ lực tự sát bằng châm tinh khí giấu trong miệng và phá tâm cảnh hận nhập đạo, thu nàng thành quả cầu cấm chế cất vào túi trữ vật, tiếc rằng tu vi chưa tới Vấn Đỉnh nên chưa dùng được Sưu Hồn Thuật.","bridge":true,"khoang":"@c0531","importance":"bridge"},{"chuong":"@c0531","importance":"normal","tieuDe":"Bàn giao bộ lạc Luyện Hồn","text":"Hai tháng sau, trước hẹn ước với Yêu tướng, dặn Âu Dương Hoa phái mấy trăm tộc nhân tiềm nhập các bộ lạc lớn nhỏ dùng Hồn Phách Thủ Thần chống Linh Thang Loạn Thần rồi truyền Luyện Hồn Thuật, trao ngọc giản phần hai (thần thông rút phách) chỉ cho chi chính; thu Tôn Hồn Phiên vào nguyên thần, ném nhiều Hồn Phiên thường thay thế phủ bầu trời rồi rời đi, Âu Dương Hoa quỳ xưng lão tổ."},{"chuong":"@c0531","importance":"normal","tieuDe":"Lên đường tới kinh đô Thiên Yêu","text":"Bay tới Cổ Yêu thành gặp Yêu tướng Mạc Lực Hải, cùng qua ba truyền tống trận hướng kinh thành Thiên Yêu quận, ấp ủ ý định bắt một người Đại La Kiếm Tông trong mười kẻ tới đây để hỏi nơi Chu Dật bị phong ấn."},{"text":"Theo Mạc Lệ Hải qua truyền tống trận thứ mười bốn vào Đế Đô của Thiên Yêu quận, được giới thiệu công khai là “Vương tướng” bạn tốt của Mạc Lệ Hải để nhập cuộc chiến Yêu tướng với thân phận trợ thủ. Mười chín kỵ binh giáp đen dưới trướng Mạc Lệ Hải đồng loạt tham kiến hắn.","bridge":true,"khoang":"@c0532","importance":"bridge"},{"text":"Cùng Mạc Lệ Hải phóng ngựa về phủ ở Hồng thành; cuối đường nghe tiếng vó ngựa phía trước, hắn lóe mắt nhận ra một người quen.","bridge":true,"khoang":"@c0532","importance":"bridge"},{"text":"Trên quân đạo, Vương Lâm trợ thủ Mạc Lệ Hải một điểm xảo diệu hóa giải lực của Thạch Tiễn, rồi nhận ra tên gầy gò chính là Trần Đào — sư huynh đồng hệ bị Đại La Kiếm Tông đánh trọng thương tụt từ Vấn Đỉnh trung kỳ xuống Anh Biến viên mãn. Hắn ném tặng một túi Tuy Bình đan để biểu thị thiện chí, ngầm tính liên kết đồng môn đối phó Đại La Kiếm Tông.","bridge":true,"khoang":"@c0533","importance":"normal"},{"bridge":true,"khoang":"@c0533","text":"Vào Mạc phủ ở phía nam sau hòn giả sơn, Vương Lâm tu luyện bốn ngày, thổ nạp Yêu lực chuyển hóa thành tiên lực bồi đắp Nguyên Thần, nhắm tới chức Yêu tướng tại kinh đô Thiên Yêu quận.","importance":"normal"},{"chuong":"@c0533","importance":"bridge","tieuDe":"Sát Lục Chi Khí bộc phát","text":"Một lần ngồi luyện Sát Lục Tiên Quyết kéo dài bảy ngày, Sát Lục Chi Khí lan ra khiến hai quân sĩ hầu cận phát điên sát khí, mắt đỏ hồng, Yêu lực tiêu tán hơn nửa. Vương Lâm tỉnh lại sinh nghi: vì sao giết nhiều sinh linh mà Sát Lục Chi Khí lại sinh ra ít, hồi tưởng từng lần luyện hóa để tìm nguyên nhân."},{"bridge":true,"khoang":"@c0534","text":"Truy xét quy luật sinh ra Sát Lục Chi Khí mà không tìm ra điểm chung, hắn xác định Sát Lục Tiên Quyết là trọng điểm chuyến vào lãnh thổ Yêu linh và định thí nghiệm, thôi diễn hàng loạt để lĩnh ngộ phần huyền bí còn ẩn.","importance":"bridge"},{"chuong":"@c0534","importance":"normal","tieuDe":"Lời hứa bên dòng Thiên Yêu","text":"Giấu tiên lực giả làm thư sinh dạo Hồng thành, giữa phố xá náo nhiệt vẫn thấy cô độc; nghe tiếng đàn bi thương từ một thuyền hoa gợi nhớ Uyển Nhi, hắn vuốt mi tâm như chạm vào nàng trong Hạt Châu Thiên Nghịch và thề sẽ gặp lại nàng."},{"text":"Phát hiện trong Hồng lao của Hồng thành ẩn một cỗ yêu khí cường đại không kém Mạc Lệ Hải, Vương Lâm về Mạc phủ đề nghị được đưa vào lao ngục để giết chóc tu luyện. Hắn vung tay tạo năm đạo sát lục khí hóa thành năm con thương long, bị Mạc Lệ Hải đánh tan thì dung hợp lại len qua quyền phong chấn động yêu giáp đối phương, khiến hắn kinh ngạc và chốt cho vào bảy ngày.","bridge":true,"khoang":"@c0535","importance":"normal"},{"chuong":"@c0535","importance":"bridge","tieuDe":"Tẩy lễ tâm linh ba ngày","text":"Ba ngày liền Vương Lâm không tu luyện, không thổ nạp, chỉ ngồi bên sông uống rượu nghe tiếng đàn bi thương từ hoa thuyền để tẩy rửa tâm linh. Hắn độc thoại về đạo nghịch thiên cô độc, về việc trong lòng phải giữ một tia cảm động kẻo chỉ là thuận thiên, và về chí cầu thoát khỏi thân phận con kiến hôi; rồi đập vỡ vò rượu, phong ấn lại mọi cảm xúc, ánh mắt trở nên thâm thúy."},{"text":"Nửa đêm theo Mạc Lệ Hải phóng tới Hồng lao ở Hồng thành, được nam tử họ Hứa tiếp nhận và cho một tháng trong lồng giam dưới lòng đất để nghiên cứu sát lục khí. Sau năm ngày giết hơn nửa ngàn phạm nhân, hắn vẫn cách một tầng giấy mỏng, nhận ra mình còn thiếu sát tâm.","bridge":true,"khoang":"@c0536","importance":"bridge"},{"bridge":true,"khoang":"@c0536","text":"Hứa chỉ điểm về sát tâm, ra điều kiện sau này nhờ Vương Lâm dùng thần thông sát lục giết yêu tướng Thạch Tiễn, rồi tiết lộ bí mật tầng đáy Hồng lao.","importance":"bridge"},{"chuong":"@c0536","importance":"major","tieuDe":"Ngộ sát lục chi tâm trong biển máu","text":"Vương Lâm hòa vào chu kỳ chém giết của thế giới máu tầng đáy, mất ý thức thi triển Tịch Diệt Chỉ và Hóa Ma Chỉ, trở thành một trong hơn trăm người sống sót. Tỉnh lại hắn ngộ ra phải có sát lục chi tâm mới luyện hóa được sát lục khí, dần nối nó với ý cảnh sinh tử luân hồi của mình; huyết sát vụ trên thân dày tới hơn trăm trượng, cuối cùng chỉ còn hắn và một thanh niên tóc đen khi ngân long hiện ra hút mạnh."},{"text":"Trong thế giới huyết sắc của Hồng Lao, Vương Lâm minh ngộ bản chất Sát Lục tiên quyết — lấy sát niệm đoạt tính mệnh người khác, luyện sinh cơ thành lạc ấn sinh mệnh, “từ tử tới sinh” hợp luân hồi chi đạo. Khí Sát Lục bạo phát khiến 792 rồi cuối cùng 3792 đạo sát lục khí xám vờn quanh hắn.","bridge":true,"khoang":"@c0537","importance":"bridge"},{"chuong":"@c0537","importance":"bridge","tieuDe":"Đánh bại một trảo Đế Kiếm","text":"Vương Lâm dùng 3792 đạo sát lục khí như kiếm phá vỡ một trảo của ngân long Đế Kiếm — lần đầu con mồi đánh bại nó, khiến nó phẫn nộ phun kiếm quang. Hắn hóa điện quang dùng hơn ba nghìn lạc ấn làm phòng hộ, lao khỏi thế giới huyết sắc."},{"bridge":true,"khoang":"@c0537","text":"Nam tử họ Hứa dẫn Vương Lâm theo đường bí mật trốn khỏi Hồng Lao; hắn thu khí tức chạy bộ về Mạc phủ, được Mạc Lệ Hải đưa xuống động bế quan và ẩn trong Thiên Nghịch Châu suốt một tháng tránh Đế Kiếm lùng sục.","importance":"bridge"},{"bridge":true,"khoang":"@c0537","text":"Mạc Lệ Hải định kế cho Vương Lâm ra trận thay tại đại hội Yêu Tướng đêm yêu linh; hắn ngồi bên sông nghe đàn nữ tử mắt đen, đối ẩm chào thanh niên áo xanh mang yêu lực, rồi cùng Mạc Lệ Hải viếng phủ phó soái Huyền Thành.","importance":"bridge"},{"chuong":"@c0538","importance":"bridge","tieuDe":"Trấn áp phó soái Huyền Thành","text":"Đóng vai tùy tùng của Mạc Lệ Hải bái kiến phó soái Huyền Thành. Khi bị thách thi triển thần thông mạnh nhất, Vương Lâm phóng hai nghìn đạo sát lục chi khí như rồng giận, xuyên thủng mãnh hổ yêu khí và màn yêu giáp bảy tấc, ép phó soái Vấn Đỉnh Sơ Kỳ liên tục lui và phải công nhận tư cách. Sau đó đồng ý trợ giúp Mạc Lệ Hải trong đại hội Yêu Tướng, cùng uống rượu chôn hơn năm trăm năm."},{"text":"Giữa thời loạn trước cuộc đấu Yêu Tướng, Vương Lâm — phó tướng Mạc Lệ Hải — vẫn bình thản mỗi sáng ra bờ sông nghe đàn uống rượu, thu liễm tiên lực tránh Đế Kiếm dò tìm. Khi một sát thủ áo đen của Yêu Linh (Hóa Thần hậu kỳ) tới thử, hắn chỉ điểm ngón cái phải dùng Tịch Diệt Chỉ giết gọn một đòn, thu đám khí xám từ thất khiếu đối phương vào tay phải.","bridge":true,"khoang":"@c0539","importance":"major"},{"text":"Đang ngồi nghe đàn bên bờ sông thì bị nhóm sát thủ của “lão tổ” truy bắt. Vương Lâm dùng Tịch Diệt Nhất Chỉ giết chết sát thủ số bốn, rồi lần đầu quay đầu phóng Sát Lục Đạo từ ánh mắt màu hồng áp chế sát thủ số hai khiến hắn tâm thần suýt sụp đổ, cả nhóm áo đen khiếp sợ.","bridge":true,"khoang":"@c0540","importance":"normal"},{"text":"Tại Mạc phủ, Vương Lâm chạm trán Mạt Dương của Đại La Kiếm Tông tới đưa chiến thư. Hắn đi xuyên qua khí thế Mạt Dương, hóa giải sạch sáu mươi tư đạo kiếm khí bằng dấu ấn hộ thể, bắt sống cự kiếm tím bằng tay phải ngàn dấu ấn rồi dùng sát lục chi khí từ mắt đánh tan Tà Dương Chi Hồn, khiến Mạt Dương hộc máu vì mất kiếm bản mệnh.","bridge":true,"khoang":"@c0541","importance":"normal"},{"chuong":"@c0541","importance":"normal","tieuDe":"Giả tha rồi âm thầm hạ sát Mạt Dương","text":"Vương Lâm ném trả cự kiếm, nói không muốn đối địch Đại La Kiếm Tông tại vùng đất Yêu Linh, nhờ chuyển lời tới Kiếm Tiếu Thập Nhị Tử. Khi Mạt Dương rời đi nghìn trượng thầm thề báo thù, đám khí xám ẩn trong cự kiếm chui vào đầu hắn, hóa ấn chú cắt đứt nguyên thần với thân thể, hấp thu tinh hoa huyết nhục và tiên lực khiến Mạt Dương hóa thây khô; Vương Lâm hiện thân đoạt thi thể rồi biến mất."},{"bridge":true,"khoang":"@c0541","text":"Trước đó Vương Lâm áp chế một yêu tu lớn tuổi đến tự bộc tiên yêu lực hòng thoát thân; hắn gài một tia khí xám âm thầm đuổi theo, rồi ngồi uống rượu bên bờ sông, nhận định đại hội Yêu Tướng là “trò chơi” Yêu Đế dựng để người ngoài thừa cơ chém giết.","importance":"bridge"},{"text":"Luyện hóa thi thể và nguyên thần Mạt Dương trong Mạc phủ. Phát hiện ở mi tâm nguyên thần Mạt Dương có một đường chỉ lam — đạo kiếm khí bảo mệnh Lăng Thiên Hậu ban cho mười hai đệ tử Đại La Kiếm Tông năm xưa ở cửa Yêu Linh Đông Hải. Vương Lâm cắn răng nuốt thẳng sợi chỉ lam, nguyên thần suýt đứt liên hệ với thân thể, tĩnh tọa ba ngày rồi mở mắt lóe kiếm ảnh.","bridge":true,"khoang":"@c0542","importance":"normal"},{"chuong":"@c0542","importance":"bridge","tieuDe":"Xuất quan trước đại hội Yêu Tướng","text":"Bước ra khỏi phòng với khí thế như nhất đại tông sư rồi thu liễm như phàm nhân, khiến Mạc Lệ Hải khiếp sợ. Nghe tin Mạc Lệ Hải đã bại trận trước Mặc Phi; ngày mai là đại hội Yêu Tướng tranh đoạt."},{"text":"Tại trận chiến Yêu Tướng ở Đế Đô, Vương Lâm đóng vai người trợ giúp cho Mạc Lệ Hải. Bị Hoàng Phó Soái coi thường vì chỉ là Anh Biến hậu kỳ viên mãn, nhưng Huyền Phó Soái quả quyết hắn sẽ vào tam giáp, thậm chí đứng đầu. Bị Thạch Tiêu khiêu chiến rồi hăm dọa giết; Vương Lâm cự tuyệt vì “đánh nhau mà không giết người thì không có hứng”.","bridge":true,"khoang":"@c0543","importance":"normal"},{"chuong":"@c0543","importance":"bridge","tieuDe":"Đối mặt Ngao Địch khiêu chiến","text":"Yêu Tướng Ngao Địch chớp cơ hội ra khiêu chiến vì thắng Vương Lâm tương đương thắng Mạc Lệ Hải. Vương Lâm bình thản đáp lại rằng đối phương không phải là đối thủ của hắn."},{"text":"Tại đại hội Yêu Tướng của Thiên Yêu Môn, Vương Lâm bước một bước phá đất bức Ngao Địch lộ thân, túm tay phải truyền tiên lực phá hủy toàn bộ kinh mạch, dùng Sinh Chi Lạc Ấn hóa giải hư ảnh long quy tới tầng thứ tám rồi rung tay làm vỡ nát xương cốt đối phương thành phế nhân. Lần đầu một người ngoài đánh phế một Yêu Tướng chỉ trong chớp mắt, chấn động cả khán đài Yêu Tướng – Yêu Soái.","bridge":true,"khoang":"@c0544","importance":"bridge"},{"chuong":"@c0544","importance":"bridge","tieuDe":"Đẩy lui trường thương Kim tổng quản","text":"Khi Kim tổng quản ngưng ánh sáng mặt trời thành trường thương vàng phóng tới cứu Ngao Địch, Vương Lâm dùng Sinh Chi Lạc Ấn vỗ hai cái vào hai vị trí khác nhau khiến trường thương đổi hướng lướt qua, lạnh lùng chất vấn đối phương có muốn phá vỡ quy tắc. Kim tổng quản đành thu thương, liếc Vương Lâm thật sâu — gieo mối ân oán."},{"bridge":true,"khoang":"@c0544","text":"Sau đó Vương Lâm cảm nhận được Hứa Lập Quốc xin ra ngoài, mở khe túi trữ vật thả ma đầu Kiếm Linh bay đi đuổi theo thiếu nữ Kiếm Linh của Đế Kiếm; hết ngày đầu đại hội, sáu trận đã phân thắng bại.","importance":"bridge"},{"text":"Trong lúc nghỉ giữa vòng tỷ thí tranh đoạt Yêu Tướng, Vương Lâm nhận ra Hứa Lập Quốc che giấu nhiều thủ đoạn và lòng trung thành chỉ duy trì khi chủ nhân mạnh. Hắn thu hồi sát khí, cắt liên hệ tiên kiếm, dùng cấm chế bắt lại kẻ định trốn rồi cảnh báo nguy cơ bị luyện hóa.","bridge":true,"khoang":"@c0545","importance":"bridge"},{"chuong":"@c0545","importance":"normal","tieuDe":"Thu phục Tiểu Hắc Đao","text":"Khi loan đao đen Tiểu Hắc tự xông ra tập kích hai lần nhắm giữa lông mày, Vương Lâm dựa Sinh Chi Lạc Ấn bật ra, phóng hơn ba nghìn đạo Sát lục chi khí ép loan đao thành quả cầu rồi in dấu ấn nguyên thần thu phục."},{"chuong":"@c0545","importance":"bridge","tieuDe":"Ngộ chữ “nghịch” hướng Vấn Đỉnh","text":"Từ ánh đèn lồng Mạc phủ leo lét mà ngoan cường và bình minh quét tan bóng đêm, Vương Lâm phân biệt “tránh” với “nghịch”, lóe lên cảm ngộ về chữ nghịch — mấu chốt đưa hắn tiến tới Vấn Đỉnh, một biến đổi âm thầm bén rễ."},{"chuong":"@c0545","importance":"bridge","tieuDe":"Đối thoại thanh niên trên thuyền tranh","text":"Vương Lâm lên thuyền tranh nghe đàn của Minh Phí cô nương, đáp tiếng đàn khiến hắn “nhớ tới cố nhân”, hai người nhận nhau là tục nhân và hẹn uống rượu tới bình minh."},{"chuong":"@c0546","importance":"bridge","tieuDe":"Vào vòng hai gõ Chiến Yêu Cổ","text":"Sau khi chia tay thanh niên ôm đàn trên thuyền, Vương Lâm cùng 48 Yêu Tướng vào vòng hai cuộc tranh đoạt Yêu Tướng tại Đế Đô. Vòng hai đổi luật thành gõ thánh vật Chiến Yêu Cổ. Hắn được Huyền Phó Soái âm thầm đánh giá là “đáng sợ” hơn cả Mặc Phi. Cuối cùng bị nam tử mặc kim giáp gọi tên, đáp lạnh và bị thách đánh cược."},{"chuong":"@c0546","importance":"bridge","tieuDe":"Nhận ra Mặc Phi giống nam tử Hồng Lao","text":"Khi mặt nạ Mặc Phi vỡ lộ khuôn mặt anh tuấn, Vương Lâm sững lại nhận ra hắn giống hệt nam tử tóc đen ở chỗ sâu nhất Hồng Lao."},{"text":"Vương Lâm cá cược với Kim tổng quản, đòi một cánh tay của hắn nếu đánh vượt năm tiếng trống trên Yêu Cổ. Hắn vận hơn ba ngàn Lạc Ấn Sinh Mệnh làm lá chắn, đánh liền năm tiếng hợp nhất mà thân thể không di động, rồi tiếp tục tới tiếng thứ chín — vượt qua kỷ lục tám tiếng của đệ nhất yêu tướng Mặc Phi, vang danh Thiên Yêu quận.","bridge":true,"khoang":"@c0547","importance":"bridge"},{"chuong":"@c0547","importance":"bridge","tieuDe":"Ngộ đạo Thuận - Nghịch","text":"Vương Lâm ngộ ra phản lực Yêu Cổ là khí tức bất khuất, cuồng ngạo nghịch thiên trong ý niệm; lực đánh là thuận, tiếng trống vang là nghịch, một thuận một nghịch ẩn tàng biến hóa thiên địa. Hắn tiến chín bước vuốt mặt trống, cả người như dung hợp vào Yêu Cổ."},{"text":"Đánh Yêu Cổ tới tiếng thứ mười, Vương Lâm thu hồi Sinh Chi Lạc Ấn cho lực phản chấn tiến thẳng vào người để tẩy tủy — mồ hôi đen tiết ra nhưng lực vận chuyển loạn khiến sắc mặt trắng xanh. Hắn ngộ ra mình bị thương không phải do tu vi yếu mà do dung hợp theo đạo của Yêu Cổ chứ không phải đạo của riêng mình, một chữ “nghịch” chia thành nhiều con đường tùy cảm ngộ.","bridge":true,"khoang":"@c0548","importance":"bridge"},{"chuong":"@c0548","importance":"bridge","tieuDe":"Trống truyền niệm chấn động toàn trường","text":"Vương Lâm đem ý niệm bi thương cùng cảm ngộ tiếng đàn hoa thuyền hòa vào tiếng trống thứ mười một, đạt cảnh giới “trống truyền niệm” — lấy bi nhập thần, dùng thần nhập niệm, lấy niệm đánh trống, dùng trống truyền đạo. Bi niệm lan khắp Thiên Yêu thành, gây cộng hưởng tâm linh khiến cả khán đài Yêu soái, Yêu tướng cùng văn thần rơi lệ; Huyền Hôn soái ngờ hắn chính là người Yêu Đế chờ đợi nhiều năm, Thiên soái lần đầu đứng thẳng kinh ngạc nhận ra danh tính Vương Lâm."},{"text":"Khi gõ Yêu Cổ tới tiếng trống thứ mười một truyền niệm, Vương Lâm lần đầu cảm nhận sự kêu gọi của Vấn Đỉnh, đứng cạnh biên giới Vấn Đỉnh. Hắn nhận ra tu đạo bảy trăm năm, Ý Cảnh nhập thể đã viên mãn, Ý Cảnh Vấn Đỉnh đã có tám phần, song đạo tâm chưa viên mãn vì còn một tia bi thương — chấp niệm về Lý Mộ Uyển. Hắn tuyên bố trong lòng “Ta phải Vấn Đỉnh”.","bridge":true,"khoang":"@c0549","importance":"bridge"},{"chuong":"@c0549","importance":"bridge","tieuDe":"Gõ trống tẩy tủy","text":"Vương Lâm gõ thêm các tiếng trống thứ mười hai, mười ba, mười bốn, đem bi ai dung nhập tiếng trống tạo lực trùng kích đi vào cơ thể, mồ hôi đen tiết ra khắp lỗ chân lông, đạt tẩy tủy thật. Thiên soái tán thưởng đây mới là tẩy tủy thật, trước chỉ là tẩy da lông."},{"chuong":"@c0549","importance":"bridge","tieuDe":"Do dự cái giá phải quên","text":"Để đạo tâm viên mãn đạt Vấn Đỉnh, Vương Lâm phải xóa sạch ký ức và tình cảm với Lý Mộ Uyển. Hắn nâng tay định hạ xuống Yêu Cổ thì bàn tay run lên, do dự chưa hạ — nếu quên, dù Lý Mộ Uyển trong Nghịch Thiên châu có ngày thức tỉnh, hắn cũng chỉ vô tình mỉm cười tiễn nàng về Chu Tước Tinh."},{"text":"Đứng trước Yêu Cổ ở quảng trường Đế Đô, Vương Lâm chống lại sự cám dỗ xóa bi thương để lên Vấn Đỉnh — vì làm vậy sẽ biến Lý Mộ Uyển thành Lô Đỉnh. Hắn ngộ ra đạo của mình là Nghịch: nghịch thiên mà đi, giữ trọn tình cảm chứ không thuận thiên trốn chạy. Hạ quyết tâm dồn bi niệm lên tay phải, vỗ tiếng trống thứ mười lăm lên Yêu Cổ, bùng khí tức nghịch thiên như vô số kiếm sắc đâm lên trời, chấn động cả Thiên Yêu thành.","bridge":true,"khoang":"@c0550","importance":"bridge"},{"text":"Chớp thời cơ Kim Ô Húc bị trọng thương kép, Vương Lâm chụp lấy hắn đập thẳng vào Yêu Cổ, dồn toàn bộ bi niệm cả đời vào một kích cuối cùng để vượt Anh Biến kỳ. Tiếng trống thứ mười lăm vang lên giết chết Kim Ô Húc, đưa hắn thành đệ nhất nhân trên danh nghĩa Thiên Yêu quận.","bridge":true,"khoang":"@c0551","importance":"normal"},{"chuong":"@c0551","importance":"bridge","tieuDe":"Mở đạo nghịch thiên — gọi thiên kiếp","text":"Tiếng trống thứ mười lăm hóa thiên bi địa bi, dung hợp sấm sét trời đất, đánh bật bi thương ra ngoài và mở một con đường tu hành nghịch thiên trên đạo tâm viên mãn. Vương Lâm ngẩng đầu “Ta đã giữ lại được!”, luận về thiên đạo và gọi thiên kiếp giáng xuống — chỉ khi xuất hiện người nghịch tu thiên kiếp thật mới giáng."},{"text":"Tại quảng trường vạn trượng trong Thiên Yêu thành (Đế Đô), Vương Lâm đánh tiếng trống thứ mười lăm bên cạnh Yêu Cổ. Tiên lực để tiến Vấn Đỉnh đã viên mãn, đạo tâm cũng lột xác viên mãn, chỉ chờ hai bên dung hợp để tiến hóa từ người thành tiên. Việc bảo lưu ý niệm nghịch thiên tu hành khiến hồng quang thiên kiếp từ hư vô giáng lâm, ngưng tụ thành hồng vân khổng lồ trên bầu trời Đế Đô.","bridge":true,"khoang":"@c0552","importance":"bridge"},{"chuong":"@c0552","importance":"bridge","tieuDe":"Nghênh hồng lôi bằng Cấm Phiên","text":"Hồng lôi đỏ như máu mang thiên sát giáng thẳng vào Vương Lâm cùng tuyết sát đầy trời. Hắn ngưng tụ hơn ba nghìn bảy trăm đạo Sinh Chi Lạc Ấn khắp thân, vỗ túi trữ vật khiến Cấm Phiên rung lên tạo hắc vụ cấm chế, chỉ tay biến hắc quang thành cơn lốc đen khổng lồ đón đánh hồng lôi. Hai bên va chạm nổ vang chấn động khiến nhiều người trong thành chảy máu tai ngất xỉu."},{"text":"Tại Thiên Yêu Thành, Vương Lâm độ hồng lôi thiên kiếp, lần lượt dùng Cấm Phiên, trăm đạo Tịch Diệt Chỉ, Sát Lục Long ba nghìn bảy trăm Sinh ấn và Hóa Ma Chỉ đỉnh phong nghịch chuyển cả núi tiên ngọc thành ma lực vô tận để phá đạo lôi kiếp đầu. Hô “Trời muốn giết người, ta muốn diệt trời”, giữ vững đạo tâm bất khuất dù tan thân.","bridge":true,"khoang":"@c0553","importance":"normal"},{"chuong":"@c0554","importance":"bridge","tieuDe":"Chịu đòn trừng phạt thứ hai thiên kiếp","text":"Đứng trên mảnh vỡ quảng trường vạn trượng Đế Đô Thiên Yêu thành, Vương Lâm đối mặt đòn trừng phạt thứ hai của thiên kiếp. Thiên uy đè ép, hồng vân hạ liên tục nghiền nát cả tòa thành, hắn bị đè chìm sâu vào lòng đất, kinh mạch đứt đoạn, khớp xương vỡ nát, nhưng đạo tâm quyết không khuất phục. Cuối cùng nghe giọng nói âm u tự xưng Cổ Yêu giảng giải về nghịch tu và lịch sử tộc Cổ."},{"text":"Vương Lâm nhận giao kèo với Cổ Yêu — được sửa thân thể mạnh hơn xưa, mượn hư ảnh Cổ Yêu chống thiên kiếp (Diệt đạo, Vân toái) và nuốt cả Xích Tiêu Vân Mang, đổi lấy việc tương lai thu hồi thánh vật tám Yêu quận. Sau đó vào thần bí động phủ, nuốt Vấn Đỉnh Chi Tinh của Chu Dật, suýt thất bại Vấn Đỉnh nhưng viên ngọc của Chu Dật (Ý cảnh Chí Tử Si Ý) tan vỡ dồn nguyên khí cứu hắn, hình thành Vấn Đỉnh Chi Tinh mới to bằng ngón tay.","bridge":true,"khoang":"@c0555","importance":"bridge"},{"chuong":"@c0556","importance":"normal","tieuDe":"Tiến lên Vấn Đỉnh","text":"Sau mười năm tĩnh tọa nuôi dưỡng kén nguyên thần trong động phủ ở Thiên Yêu quận, kén nứt vỡ, nguyên thần mới bay ra đã thành thực chất với Vấn Đỉnh Chi Tinh tỏa nguyên khí lưu chuyển khắp thân. Hắn mở mắt thốt “Vấn Đỉnh!”, sau bảy trăm năm tu đạo cuối cùng đạt cảnh giới Vấn Đỉnh sơ kỳ — tồn tại cao nhất ở mọi lục cấp tu chân quốc. Nguyên khí cần bốn mươi chín ngày để củng cố."},{"chuong":"@c0556","importance":"bridge","tieuDe":"Bị tập kích đoạt nguyên khí","text":"Vừa đứng dậy, Vương Lâm thấy một vòng xoáy đen xuất hiện không tiếng động trên bầu trời tiên phủ đúng lúc hắn vừa tiến Vấn Đỉnh. Bản tính cẩn thận, hắn lập tức dùng lệnh bài động phủ bấm pháp quyết thuấn di; bộ xương cánh tay đen chìa ra từ vòng xoáy chộp hụt. Truyền tống bị can nhiễu khiến hắn xuất hiện lệch tới một đồng bằng khổng lồ ở Hỏa Yêu quận. Vòng xoáy lại đuổi tới, lần này hắn quyết ở lại xem cánh tay có thần thông gì."},{"text":"Vừa tiến Vấn Đỉnh, nguyên thần mới hình thành chưa kết hợp xong, Vương Lâm bị cánh tay bộ xương đen vung trảo tập kích rồi Thiên Ma Phong cuốn nửa nguyên thần muốn bay theo. Hắn dùng sát tâm đập vào sát ý sinh sát khí nồng đậm, kéo nửa nguyên thần đang thoát ra quay về cơ thể, rồi thi triển thần thông rút lui để tránh rắc rối.","bridge":true,"khoang":"@c0557","importance":"normal"},{"bridge":true,"khoang":"@c0557","text":"Hắn phát hiện phương xa có hàng ngàn cấm chế phản ứng dây chuyền che giấu một khu vườn; dùng thủ pháp phá tiên cấm động phủ, xuyên qua không kích hoạt, thấy đồng bằng trồng hơn một vạn cây Thăng Tiên Quả.","importance":"normal"},{"chuong":"@c0557","importance":"normal","tieuDe":"Hạ bộ xương cánh tay đen","text":"Bộ xương cánh tay (hộ uyển) đuổi tới phá cấm chế. Vương Lâm rút tiên kiếm chứa Hứa Lập Quốc hóa kiếm long quấn bộ xương, rồi thi triển Ma Chỉ hấp thụ yêu lực trời đất búng ra làm bộ xương khô tan vỡ. Ký hiệu trên hộ uyển kích hoạt, tro khuếch tán dựng nhà lao ma lực nghìn trượng giam không gian, sinh hắc ảnh một sừng Thiên Ma Loạn Vũ chui vào cơ thể chấn động nguyên thần."},{"chuong":"@c0557","importance":"normal","tieuDe":"Diệt hắc ảnh — Hoàng Tuyền Chỉ Vấn Đỉnh","text":"Để ép xuất hắc ảnh, Vương Lâm cô đọng hơn một vạn Thăng Tiên Quả thành một giọt đỏ như máu rồi nuốt, lấy cơn hưng phấn và đau đớn cực điểm làm động lực ép từng luồng hắc ảnh ra khỏi cơ thể. Hắn thi triển Hoàng Tuyền Chỉ bằng tu vi Vấn Đỉnh — dẫn động Ý Cảnh nguyên thần bao hàm Sinh Tử Luân Hồi, gần tiếp cận hạ phẩm tiên thuật Tiểu Thiên, làm phiến không gian sụp đổ và diệt hắc ảnh một sừng. Kẻ trong hắc tháp gầm rống phẫn nộ, ý chí lao ra dung nhập hư vô. Vương Lâm phong ấn hộ uyển bằng cấm chế mạng nhện, cất vào túi trữ vật, chiến ý vẫn chưa tan."},{"text":"Sau khi hút một phần mười chất dịch Thăng Tiên Quả, hai mắt Vương Lâm đỏ hồng, hắn vung trảo dưới tu vi Vấn Đỉnh thu gần mười vạn Thăng Tiên Quả vào túi trữ vật. Bị tiếng hừ lạnh từ đạo thần thức trong hắc tháp đánh vào tâm thần làm phun máu, vết thương khơi dậy sát tính năm xưa từng khiến Tu Ma Hải và Triệu Quốc run sợ — thứ đã bị xóa lúc hóa phàm nay thức tỉnh, khiến hắn nổi điên thay vì bỏ chạy.","bridge":true,"khoang":"@c0558","importance":"bridge"},{"chuong":"@c0558","importance":"major","tieuDe":"Luyện hóa Thăng Tiên Quả, thi triển Tịch Diệt","text":"Vương Lâm phá nát mười vạn Thăng Tiên Quả, dung hợp luyện hóa thành một giọt đỏ máu rồi nuốt vào, lại uống bốn trên mười giọt tiên dịch trong bầu rượu thu được ở động phủ — tiên lực nổ như sấm sét trong kinh mạch, chịu nổi nhờ Vấn Đỉnh cường hóa kinh mạch và năm xưa Cổ Yêu thôi hóa thân thể. Hắn gầm lên thi triển toàn lực Tịch Diệt, sóng Tịch Diệt tràn ra làm mọi cỏ cây chim thú khô héo, sinh cơ hóa khí bạch sắc khôi phục nguyên thần và xác thịt đã tan vỡ, điên cuồng truy đuổi đạo thần thức trong hắc tháp."},{"text":"Đang trọng thương, Vương Lâm bị Tử Thử cùng ba vạn Yêu binh vây giết, nhưng nhờ chiến ý cuồng dại và độ mẫn cảm sát khí khủng bố, hắn đảo hướng lao tới điểm chết Tử Thử trong nháy mắt, rồi tàn sát sạch ba vạn Yêu binh, hấp thu Sinh Chi Lạc Ấn để khôi phục thân thể. Trên đường tiến về chiến trường viễn cổ, hắn giết luôn hai đệ tử Anh Biến hậu kỳ của Mạc Tổ, thôn phệ sinh cơ vạn vật khiến đất đai cây cối khô héo, gây tử vong khổng lồ qua Hỏa Yêu quận và bị hơn mười Yêu tướng phái ra vây bắt.","bridge":true,"khoang":"@c0559","importance":"normal"},{"text":"Toàn thân trọng thương trong trạng thái điên cuồng chiến ý và sát khí, Vương Lâm bị Hỏa Yêu quận bố trận bao vây tại Vạn Yêu sơn. Hắn giết Yêu tướng Duẫn Đông bằng Tịch Diệt Chỉ, ngửa cổ gầm Giết rồi triệu ba vạn Thương Long khí sát lục vờn quanh người như Ma Tôn hàng lâm, lao xuống áp đảo mười vạn Yêu binh. Khi hơn mười Yêu tướng hợp công, hắn dùng tu vi Vấn Đỉnh thi triển Hoàng Tuyền Chỉ, hiện dòng sông hoàng tuyền khổng lồ giáng xuống như hồng thủy.","bridge":true,"khoang":"@c0560","importance":"normal"},{"text":"Đối mặt Hổ Bào — kẻ hắn từng cứu mạng và truyền Luyện Hồn thuật nay nuôi hận muốn làm yêu đế đệ thập quận — Vương Lâm vạch trần dã tâm độc tôn thần thông cướp hồn của hắn. Khi Hổ Bào lùa trăm ngàn hồn phách viễn cổ lao tới, Vương Lâm chỉ vỗ tay, một đạo phù văn lóe lên khiến toàn bộ hồn phách quay sang phục tùng hắn, vì hắn mới là đích hệ truyền thừa và đã cố ý lưu chỗ thiếu sót trên thuật để khống chế tuyệt đối. Sau đó hắn thả Thập Ức Tôn Hồn Phiên, dung hợp hồn phách thành một hồn trong suốt, cách không đánh một quyền khiến Hổ Bào tứ phân ngũ liệt.","bridge":true,"khoang":"@c0562","importance":"major"},{"chuong":"@c0562","importance":"bridge","tieuDe":"Hắc tháp tỏa ma khí","text":"Sau khi thanh tỉnh, Vương Lâm nhìn xa trông thấy một tòa hắc tháp cao màu đen; dưới tháp một lão giả mặc áo giáp đen đang nhìn về phía hắn. Hắn cảm nhận ma khí chân chính cực nồng đậm tỏa ra từ tháp, khác hẳn khí của người tu ma, biết người trong tháp là tuyệt đại cường giả."},{"text":"Vương Lâm hai lần áp chế cơn điên cuồng do Thăng Tiên quả phản công (ý đồ thay thế thần thức hắn), lấy lại thanh tỉnh trước một lão giả hắc giáp bước ra từ dưới hắc tháp với khí tức Vấn Đỉnh hậu kỳ. Tự nhận Vấn Đỉnh sơ kỳ khó thắng Vấn Đỉnh hậu kỳ nếu không có vật nghịch thiên, hắn lấy kiếm khí của Lăng Thiên Hậu làm chỗ dựa; xuất đạo Hóa Hoàng Tuyền cùng kiếm khí chấn nhiếp đối phương, đạo niệm hóa thân thành Hoàng Long phá mưa đen, rồi vỗ Tôn Hồn Phiên ngưng hóa Hoàng Tuyền chi hồn, thêm mười ba vạn đạo sát lục chi khí khiến Hoàng Tuyền mang sát khí. Trận chiến còn dang dở.","bridge":true,"khoang":"@c0563","importance":"bridge"},{"bridge":true,"khoang":"@c0563–@c0563","text":"Chống Phong rồi Lôi của lão giả bằng Hoàng Tuyền và Nhất chỉ Hoàng Tuyền (Hoàng Tuyền sụp một phần ba); đối diện thần niệm khổng lồ trong hắc tháp tra hỏi chưởng ấn học từ đâu, đáp rằng học từ tiên giới và bị hạ lệnh bắt sống.","importance":"bridge"},{"text":"Trên viễn cổ chiến trường, Vương Lâm thi triển Hoàng Tuyền đích thực — dung hợp mười ba vạn đạo sát lục chi khí, một trăm ngàn hồn phách và đạo cuộc đời mình thành một thể, lại vung Tôn Hồn Phiên hút hồn phách tiếp sức, đối đầu thần thông của hắc giáp lão giả. Khi lão giả ngưng hóa ma liêm đao bằng Ma đạo, hắn ngưng tụ kiếm khí bá đạo của Kiếm Tôn Lăng Thiên Hậu trên đầu ngón tay, đè bẹp mọi thần thông, đánh tan Phong Vũ Lôi Điện lẫn ma đao, rồi nhân lúc phóng kiếm khí mà thừa cơ rút lui khỏi áp lực của lão giả.","bridge":true,"khoang":"@c0564","importance":"bridge"},{"chuong":"@c0564","importance":"bridge","tieuDe":"Uy Hiếp Diêu Tích Tuyết Đòi Huyết Hồn Đan","text":"Vương Lâm lấy ra hoàn Huyết Hồn đan đầy phù văn lóe theo nhịp tim nhưng chưa biết cách dùng. Hắn phân một đạo thần thức vào túi trữ vật, tới tiểu cầu bị vô số cấm chế phong ấn nơi giam Diêu Tích Tuyết, uy hiếp nàng nói ra phương pháp sử dụng đan, dọa sẽ bóp nát túi trữ vật dung nàng vào hư vô đến tận tuyệt thọ nguyên. Thần niệm hắn đánh vào thần thức nàng như sấm khiến nàng thanh tỉnh rồi giãy dụa gần suy sụp."},{"text":"Tại động phủ ngầm dưới Long Đàm bên ngoài thành Thiên Yêu, Vương Lâm khoanh chân ngồi dưới pho tượng Cổ Yêu, suốt mấy tháng dùng cấm chế cùng lạc ấn nguyên thần (mượn lực Cổ Yêu) liên tục ấn lên hồn một Tán ma khổng lồ. Hắn nhận ra tu vi hiện tại chưa đủ để nuốt Tán ma, nên chuyển hướng dần khống chế để về sau hoặc nuốt tăng tu vi, hoặc dùng nó làm phôi thể luyện Nguyên thần thứ hai.","bridge":true,"khoang":"@c0567","importance":"major"},{"chuong":"@c0567","importance":"bridge","tieuDe":"Truyền thuyết đệ nhất Chu Tước Tinh","text":"Ở Vân Thiên Tông, truyền thuyết về Vương Lâm được kể lại: tu đạo hai trăm năm làm loạn Tu Ma Hải, cứu mỹ nhân Vân Thiên Tông, tàn sát nước Triệu khiến mặt đất hóa đỏ và diệt cả nhà họ Đằng, vào Tiên giới chém Hồng Điệp, đánh bại Liễu Mi, đánh Kiền Phong, bái Độn Thiên làm sư, đuổi Tuyết Vực, diệt Cự Ma lão tổ, nổi danh trận Tiên Di tộc và đoạt danh hiệu đệ nhất Chu Tước Tinh. Hắn cự tuyệt kế vị Chu Tước, thoái vị nhường cho Chu Vũ Thái rồi rời đi không rõ tung tích."},{"text":"Vương Lâm xuất quan, cảm nhận sát khí đại quân Cổ Yêu. Gặp lại thanh niên từng uống rượu năm xưa, nhìn ra viên yêu tinh trong đan điền và xác nhận đối phương chính là Yêu Đế Cổ Vân Phong; hai bên thừa nhận địa vị tương đương (sứ giả Tổ Linh ↔ Yêu Đế).","bridge":true,"khoang":"@c0570","importance":"normal"},{"chuong":"@c0570","importance":"major","tieuDe":"Chấn vỡ kiếm khí Đế kiếm","text":"Vì Hứa Lập Quốc đòi gặp kiếm linh Đế kiếm (Song nhi, cháu gái Yêu Đế), Song nhi oán hận thúc giục Đế kiếm phóng kiếm khí công kích. Với tu vi Vấn Đỉnh, Vương Lâm hừ lạnh chấn vỡ toàn bộ kiếm khí — vượt xa thuở Anh Biến hậu kỳ từng kiêng kị thanh kiếm này."},{"bridge":true,"khoang":"@c0570","text":"Vương Lâm hỏi tung tích Mặc Phi, nhận từ Yêu Đế quả ngọc giản trắng cho phép điều động Thiên soái cùng thân phận sứ giả Tổ Linh, rồi rời đi định tới thành Tùng Đào quận Hỏa Yêu.","importance":"bridge"},{"text":"Cải trang áo giáp đen như Ma Tôn, mượn lệnh Yêu Đế xông vào đại quân yêu binh quận Thiên Yêu đang đánh thành Tùng Đào, tuyên bố bắt giết phó soái Mặc Phi. Dùng hư chiêu Tịch Diệt chỉ đánh lừa rồi Na Di chí mạng, Hoàng Tuyền trấn áp chém chết Hợi Trư (người Đại La Kiếm Tông, Anh Biến hậu kỳ), cắt đầu luyện hóa và bắt thanh Khuyển kiếm.","bridge":true,"khoang":"@c0571","importance":"major"},{"chuong":"@c0571","importance":"major","tieuDe":"Sưu hồn lộ Tham Lang, lo Thiên Nghịch Châu","text":"Sưu hồn nguyên thần Hợi Trư ném vào Hồn phiên làm chủ hồn, biết Đại La Kiếm Tông còn có Tham Lang (đạt Âm Hư chi cảnh, vượt Vấn Đỉnh) âm thầm bảo vệ — tướng mạo quen mắt dù chưa từng gặp. Cái tên Tư Đồ Nam khiến hắn lấy ngọc giản cũ ra, nghi Tham Lang là kẻ thù năm xưa của Tư Đồ Nam và có thể biết bí mật Thiên Nghịch Châu; lo lắng độ khó viên mãn Kim thuộc tính cuối cùng."},{"text":"Vương Lâm nghi ngại đất Yêu Linh quỷ dị (tranh Hoàng Long, người giống Mặc Phi và Lăng Thiên Hậu), ngờ Thiên Vận Tử có mục đích khi dẫn hắn vào. Hắn ở trong tháp trung tâm mười năm không ra, được bộ lạc Luyện Hồn tôn làm Lão tổ kiêm người thủ hộ, củng cố lạc ấn trên Tán ma và thôi diễn 9999 tổ hợp cấm chế dung nhập Cấm phiên.","bridge":true,"khoang":"@c0573","importance":"bridge"},{"chuong":"@c0573","importance":"major","tieuDe":"Hy sinh Khu Thú Quyển hàng phục hồn thú","text":"Để mở đạo phong ấn thứ hai Xạ Thần Xa (phong hồn thú Lôi), Vương Lâm chấp nhận Khu Thú Quyển sẽ sụp đổ. Hắn dịch chuyển ra ngàn dặm, triệu Xạ Thần Xa, đè hồn thú thân trăm trượng, cắn ngón tay vẽ huyết phù vào mi tâm nó, mở Đạo phong ấn thứ nhất, đánh vỡ miệng hồn thú; ánh sáng đen hóa thân hồn thú chui vào da hắn tới Nguyên thần — hắn cười lạnh, mắt tỏa ánh sáng chói."},{"text":"Vương Lâm dùng Nguyên thần Xuất khiếu bắt hồn thú trong Xạ Thần Xa thứ hai, in liên tiếp các đạo huyết phù dung hợp khí Nguyên thần để kích nó tiến hóa. Hắn bấm pháq quyết hô mở đạo phong ấn thứ hai, biến hồn thú thành Lôi Thú mọc sừng bạc (loài hiếm hơn kỳ lân tiên giới), rồi tạo huyết phù thứ tư in lên mi tâm để hạ lạc ấn hoàn tất. Tuy chỉ ra sừng bạc thay vì sừng vàng hoàn mỹ, uy lực Lôi Thú đủ đối kháng Vấn Đỉnh trung kỳ.","bridge":true,"khoang":"@c0574","importance":"major"},{"bridge":true,"khoang":"@c0574","text":"Vương Lâm tự lượng định thực lực Vấn Đỉnh sơ kỳ của mình rồi thuấn di về bảo tháp bộ lạc Luyện Hồn, khoanh chân trầm tư về cảnh giới và các pháp bảo nghịch thiên đang sở hữu.","importance":"bridge"},{"text":"Vương Lâm khảo sát Tiên chủng (vân xanh) trên người Tôn Vân Sơn, Sưu hồn Tiên vệ rồi luyện hóa Nguyên thần thu được Toái ngọc chứa tiên lực và một đạo ý niệm. Hắn đoán ra bí mật dung hợp Toái ngọc tạo tu sĩ Vấn Đỉnh sơ kỳ, lấy vị trí Liên minh từ Tôn Vân Sơn rồi quyết đi diệt Lão Tổ vì đã hai lần bị trêu chọc.","bridge":true,"khoang":"@c0576","importance":"major"},{"chuong":"@c0576","importance":"bridge","tieuDe":"Hồn Tuyền hút sạch chướng khí","text":"Bước vào vùng chướng khí vạn dặm của Liên minh, Vương Lâm nhận ra Hồn Phách thuật của Lão Tổ, bấm quyết hô Hồn Tuyền khiến toàn bộ chướng khí mê vụ sôi trào, bị hút ngưng tụ thành một đoàn khí mật độ cực cao, khiến căn cứ lần đầu trong vô số năm lộ ra dưới ánh mặt trời."},{"text":"Vương Lâm ngưng hoá sương mù áp tới Toà thành trắng, lạnh lùng ép hơn trăm tu sĩ phiêu phù bên ngoài tản đường; ánh mắt sát nhân của Sát lục tiên quyết làm một thanh niên Tu sĩ Liên minh trào máu, mở thẳng một con đường tới thành.","bridge":true,"khoang":"@c0577","importance":"bridge"},{"chuong":"@c0577","importance":"major","tieuDe":"Một chỉ Tịch Diệt giết Tiên vệ","text":"Khi Lão Tổ ra lệnh giết, một Tiên vệ áo đen hoá mãnh thú nuốt Vương Lâm; hắn điểm một chỉ quát Toái, hắc mang mang đạo niệm Tịch Diệt phá toái hư không xuyên qua mãnh thú, giết tức khắc Tiên vệ Vấn Đỉnh."},{"chuong":"@c0577","importance":"bridge","tieuDe":"Cự tuyệt giảng hoà","text":"Lão Tổ nhận ra Vương Lâm qua lời Tôn Nhược Nam, động lòng muốn giảng hoà thả đi, nhưng Vương Lâm cự tuyệt, gọi hai Tiên vệ đã giết chỉ là hai khối Toái ngọc không bù được việc bị trêu chọc; Lão Tổ nổi giận triệu tám Tiên vệ và Tiên đế."},{"text":"Đối đầu lão già tự xưng người Tiên giới tại Toà thành màu trắng. Vương Lâm dùng Hoàng tuyền nghênh chiến ảo thuật công kích “Tiên Đế”, đạo tâm kiên định hạ chân đạp vỡ hư ảnh, xuyên qua tám Tiên vệ đẩy chúng vào Hoàng tuyền và Luân hồi, thu tám khối Toái ngọc rồi quét sập Toà thành.","bridge":true,"khoang":"@c0578","importance":"bridge"},{"chuong":"@c0578","importance":"normal","tieuDe":"Kỳ Lân khắc chế Tiên thú chi lương","text":"Lão già thấp bé cùng ba nữ tử đồng tu lộ diện, thả Tiên thú chi lương (sợi tơ xanh). Vương Lâm nhận ra Tiên lương từng gặp ở động phủ năm xưa và trên người Tôn Vân Sơn, khiến lão kinh hãi. Hắn triệu đầu Kỳ Lân thú trong Hồn Phiên — thiên địch của Tiên lương — hút sạch toàn bộ Tiên lương, lão già choáng váng há hốc mồm."},{"text":"Đối đầu lão già thấp bé khống chế Tiên vệ, Vương Lâm nói toạc bí mật lão không có nguyên lực. Nhận ra phù văn lão vẽ giống đúc phù văn trên Tôn Long chi lộ, hắn sinh ham muốn mãnh liệt đoạt cây Toả Thần bút, triệu Lôi thú từ Xạ Thần xa đánh sụp phù văn rồi rượt đuổi lão qua hơn mười lần độn thuật.","bridge":true,"khoang":"@c0579","importance":"bridge"},{"bridge":true,"khoang":"@c0579","text":"Lão ném Tiên bút vào hư vô; Vương Lâm sai Hứa Lập Quốc dẫn Tiểu hắc tử đuổi theo, đồng thời thi triển Đại Na Di thuật ép lão tới cùng đường khiến lão phải rút Khốn Tiên võng.","importance":"bridge"},{"text":"Khi Lôi Suất phá thủng màn sương đen Tôn Hồn Phiên, định huỷ toà tháp thờ phụng, Vương Lâm áo trắng tóc dài từ trong tháp thốt một tiếng ‘Định’ khoá cứng hắn, rồi bước ra vung tay áo đánh hắn phun máu văng khỏi bộ lạc. Trước trận pháp của Thuỷ Yêu Quận, lần đầu hắn toàn lực thi triển Định Thân thuật ‘một chữ Định, thiên địa bất động’, định trụ toàn bộ yêu binh hai Quận, mở màn tàn sát của tộc nhân Luyện Hồn bộ lạc.","bridge":true,"khoang":"@c0583","importance":"bridge"},{"text":"Sau một tháng, Vương Lâm rời Luyện Hồn bộ lạc (để lại một đạo thần thức thủ hộ), ghé Động phủ ghi nhớ mười một phù văn ở Tôn Long chi lộ rồi thi triển Đại Na Di tới Hoả Yêu Quận. Hắn thử phá phong ấn yêu mạc của Cổ Yêu nhưng bị phản lực đánh văng, đụng độ thần thức Cổ Yêu Hoả Yêu Quận quát đuổi. Hắn tuyên bố với Bối La rằng bước đầu của ước định khỏi phải chờ nữa.","bridge":true,"khoang":"@c0584","importance":"bridge"},{"chuong":"@c0584","importance":"bridge","tieuDe":"Triệu và phân Sát Lục khí trăm vạn đạo","text":"Vương Lâm thốt “Sát lục khí, tụ!”, khiến tộc nhân Luyện Hồn bộ lạc ẩn nấp khắp Hoả Yêu Quận trong yêu binh, người áo đen và tướng lĩnh song phương suốt trăm năm cùng thoát sát khí — mười vạn đạo Sát Lục khí ngưng gần thành thực chất tụ về hắn. Hắn thốt “Phân!”, mười vạn đạo tách đôi liên tiếp hơn mười lần, biến thành trăm vạn đạo phủ kín thiên địa."},{"text":"Vương Lâm phá không tới Vân Vụ sơn hải của Thủy Yêu quận tìm Triều Tịch thâm uyên, tu vi đã đạt Vấn Đỉnh sơ kỳ. Hắn gặp nhóm bốn người do Đỗ Kiến (xích hệ đệ tử Thiên Vận Tử) dẫn đầu, nhận lời cùng kết bạn vào thâm uyên chủ yếu vì lưu tâm thần thông phát hiện ngoài ngàn dặm của Mộ Dung Trác. Hắn sớm nhìn thấu thâm ý ác độc và đố kị của Đỗ Kiến nhưng vẫn ngầm phối hợp.","bridge":true,"khoang":"@c0589","importance":"normal"},{"text":"Vương Lâm dùng Hoàng Tuyền cuốn sạch tiên huyết và bướu thịt ô uế của Đỗ Kiến, rồi phong ấn nguyên thần đối thủ, chặt đứt liên hệ với thân thể và dùng Cấm Phiên tạo quả cầu cấm chế thu hắn vào túi trữ vật. Hắn nhận xét Đỗ Kiến tuy mạnh trong cùng đẳng cấp nhưng chưa đủ tư cách trước đạo niệm của mình.","bridge":true,"khoang":"@c0591","importance":"major"},{"chuong":"@c0591","importance":"major","tieuDe":"Phá thần thông kim phù","text":"Vương Lâm điểm Tịch Diệt Chỉ xuyên thủng kim phù chứa phi trùng dễ dàng, khiến Mộ Dung Trác gọi đó là “vô thị thần thông”. Khi thử một tia kiếm khí Lăng Thiên Hậu lên phi trùng, nó chỉ run mà không chết, khiến hắn kinh ngạc về sức chống chịu lạ thường của chúng."},{"bridge":true,"khoang":"@c0591–@c0591","text":"Bốn người tiếp tục hạ xuống Triều Tịch thâm uyên, Vương Lâm dùng thủy tinh của Bối La dò đường; hắn nhận ra Triệu Y Huyên và Từ Phi là người Thi Âm Tông qua thần thông kỳ dị nhưng chọn không vạch trần.","importance":"bridge"},{"chuong":"@c0591","importance":"major","tieuDe":"Chia tay và cảnh báo Mộ Dung Trác","text":"Tới gần đáy thâm uyên — nơi Bối La cảm ứng được bản thể Chu Dật nhưng chưa định vị — Vương Lâm cáo từ Mộ Dung Trác với lời kết giao hiếm có, truyền âm cảnh báo đề phòng Triệu, Từ nhị nữ là người Thi Âm Tông, trong đó một người đã “thi thể phụ nguyên thần”."},{"chuong":"@c0591","importance":"major","tieuDe":"Phá thần thức do thám Từ Phi","text":"Sau khi ba người khuất bóng, Vương Lâm triệu sợi tóc Từ Phi cài lại trên vách khe, chà tay bốc lục hỏa và phun nguyên thần chi khí thổi tan đạo thần thức bên trong, khiến Từ Phi đang phi hành dưới thâm uyên run lên, chảy huyết nơi khóe miệng."},{"text":"Vương Lâm dồn toàn lực phá ba đợt thần niệm Lăng Thiên Hậu canh giữ khe sâu, dùng Hoàng Tuyền, hóa Trăm vạn sinh ấn thành khí giết chóc và thúc Lôi thú công kích, cố tình không xuất kiếm khí của Lăng Thiên Hậu vì sợ bị đoạt. Chui qua lỗ hổng thần niệm vào sâu trong khe, hắn rút tiên bút vẽ ký hiệu bảy nét — mỗi nét rút một tia nguyên thần — làm sáng rực cả vực. Ký hiệu vỡ khi đụng kiếm khí Lăng Thiên Hậu, hắn phun sáu ngụm máu, mất sáu trong bảy đạo nguyên thần. Cuối cùng gặp được linh thể tím của Chu Dật trong Luyện Tiên Hóa Ma đại trận.","bridge":true,"khoang":"@c0594","importance":"major"},{"chuong":"@c0594","importance":"major","tieuDe":"Được Chu Dật cứu, lộ tên Thanh Sương","text":"Chu Dật tỉnh dậy, từ chối được cứu nhưng phóng một đạo bản mệnh kiếm khí phá quả cầu thần niệm thứ tư, đánh tan thần niệm Lăng Thiên Hậu thành điểm sáng dung nhập, hồi phục và tăng trưởng nguyên thần Vương Lâm. Vương Lâm ném trả Bảo tháp lưu thần thức Chu Dật, tuyên bố lời hứa năm xưa đã hoàn thành, rồi tiết lộ nữ nhân Chu Dật si mê không phải Đình nhi mà tên thật là Thanh Sương, khiến linh thể Chu Dật chấn động."},{"text":"Vương Lâm trả ngọc giản của Thanh Lâm cho Chu Dật, để Chu Dật biết Đình nhi chính là Thanh Sương. Sau khi Chu Dật phá phong ấn của Lăng Thiên Hậu thoát ra, Vương Lâm nhận giữ bảo tháp và được Chu Dật truyền kiếm ý viễn cổ vào Hứa Lập Quốc, biến hắn thành kiếm linh phục vụ mình. Vương Lâm cũng nhận lời đi tìm phụ thân của Đình nhi là tiên đế Thanh Lâm.","bridge":true,"khoang":"@c0595","importance":"bridge"},{"bridge":true,"khoang":"@c0595–@c0595","text":"Vương Lâm tạ ơn việc năm xưa được tặng Vấn Đỉnh chi tinh, rồi kinh ngạc kêu thất thanh trước hành động bí ẩn cuối cùng của Chu Dật khi hắn vỗ mạnh lên thân kiếm tiên.","importance":"bridge"},{"text":"Chu Dật phá lạc ấn như Hoàng Đế ban thánh chỉ, tách một trong bốn thanh Vũ tiên kiếm trao vĩnh viễn cho Vương Lâm; từ nay kiếm linh khác (kể cả nữ thi áo trắng nếu thức tỉnh) cũng không điều khiển được thanh này. Hứa Lập Quốc lĩnh hội truyền thừa kiếm ý viễn cổ, thành kiếm linh đời thứ nhất của thanh kiếm này. Hai đại lễ cho Vương Lâm cơ hội luân hồi không diệt như người con gái áo trắng.","bridge":true,"khoang":"@c0596","importance":"major"},{"chuong":"@c0596","importance":"bridge","tieuDe":"Xuống đáy Triều Tịch vực tìm lễ vật thứ ba","text":"Theo Chu Dật xuống đáy Triều Tịch vực tìm hơi thở một đời kiếm linh; quan sát hố sâu năm-ngàn-năm bộc phát, đoán đó là nguồn thủy triều Đông Hải, cảm thán bản thân bé nhỏ và nghĩ tới Thiên Vận Tử đứng trước cửa con đường tu đạo thứ ba."},{"bridge":true,"khoang":"@c0596–@c0596","text":"Bức tranh thần bí lấy ở Chu Tước tinh tự mở, hiện bóng nữ tím giục “Đi xuống”; Vương Lâm ngờ trong hố có thứ liên quan đến bức tranh. Sương mù tím quái dị tràn ra cản thần thức, hắn suýt nguy, đứng lên kiếm tiên ngưng thần xua sương, được Chu Dật hóa cầu vồng phá sương đưa tới hơi thở một đời kiếm linh.","importance":"bridge"},{"text":"Bị nhốt cùng bốn đệ tử Đại La kiếm tông trong làn Tử khí (sương tím) đang co lại, Vương Lâm mượn kiếm thức của Chu Dật để ‘nhìn’ xuyên sương. Hắn lần lượt giết kẻ tu vi yếu nhất (Anh Biến trung kỳ), rút sức sống Tị Xà thành thây khô, rồi giả giọng Tuất Cẩu lừa Ngọ Mã thu hồi kiếm khí mà điểm mi tâm giết chết. Đúng mười lần h�� hấp, Chu Dật cưỡng chế mang hắn hóa kiếm quang bay ra, thu được ba thanh bảo kiếm và hai đạo kiếm khí, chỉ sót Tuất Cẩu.","bridge":true,"khoang":"@c0601","importance":"major"},{"chuong":"@c0601","importance":"major","tieuDe":"Tham Lang truy bắt vì hơi thở Tư Đồ Nam","text":"Thoát khỏi sương tím, Vương Lâm rơi vào bầy Văn thú hơn vạn con do Tham Lang điều khiển. Tham Lang không định giết mà muốn bắt nguyên thần hắn để tra hỏi nơi ở Tư Đồ Nam, do tại Đông Hải Yêu Linh đã nhận ra hơi thở Tư Đồ Nam trên người hắn. Giữa lúc nguy cấp, một bóng tím tách khỏi đàn bay thẳng về phía Vương Lâm — chính là Văn thú của hắn."},{"text":"Cùng Thần Long không hẹn mà hợp công Tham Lang giữa đàn Văn thú: điều khiển con Văn thú của mình nuốt đồng loại để áp chế cả đàn lao vào Tham Lang, rồi dùng Tịch Diệt Chỉ và Sát Lục Tiên Quyết tấn công. Khi sát lục khí ‘Tán’ hóa trăm vạn bị tiên lực trong sơn hồn phá tan, hắn nhận ra ngọn núi tiên giới của Tham Lang vốn ẩn chứa tiên lực có sẵn; may nhờ một tia sát lục khí lưu trong nguyên thần có thể sinh sôi khôi phục nên không tổn hao vĩnh viễn.","bridge":true,"khoang":"@c0602","importance":"major"},{"text":"Vương Lâm điều khiển đàn Văn thú vây Tham Lang, mượn thân Thần Long và tiên kiếm Chu Dật dung thân để di chuyển. Hắn hai lần thi triển tiên thuật ‘Định’ khống chế Thần Long rồi Tham Lang đúng tích tắc để chụp lấy lệnh bài cổ kính. Tuy nhiên ngay khi gần tới cửa ra Hỏa Yêu quận, hắn bị đại đỉnh Càn Khôn nghịch chuyển của Tham Lang đảo vị, rơi vào chỗ Thần Long đang bị sương mù vây khốn.","bridge":true,"khoang":"@c0603","importance":"bridge"},{"text":"Bị Tham Lang vây trong sương khói, Vương Lâm được Chu Dật phá vây rồi tháo chạy xuống vực. Hắn dùng Lôi Thú từ Xạ Thần Xa, phù văn tiên bút, huyết ngọc Diêu Tích Huyết phòng hộ, rồi thi tiên thuật Định định thân đệ nhị nguyên thần lôi hệ của Tham Lang. Tam Tài kiếm trận xuyên thủng thân nó, hắn mặc ma giáp đánh Hóa Ma Chỉ và Hoàng Tuyền Chỉ phá nát lạc ấn mi tâm, diệt sạch đệ nhị nguyên thần.","bridge":true,"khoang":"@c0604","importance":"major"},{"chuong":"@c0604","importance":"major","tieuDe":"Lao vào hố sâu né Thái Cổ Lôi Long","text":"Đệ nhị nguyên thần nổ tan, linh thân Thái Cổ Lôi Long thoát phong ấn ôm cừu hận lao tới. Vương Lâm tới đáy vực gặp hố sâu vô hạn có lực hút mạnh; vốn không phải lần đầu vào nên hắn vận tiên lực nương một bên lao thẳng xuống an toàn, còn Lôi Long mới thức tỉnh không nắm quy luật nên giãy giụa phóng điện đánh vỡ vách đá."},{"text":"Bị kẹt trong hố sâu lực hút cực mạnh, Vương Lâm dùng Tam Tài Kiếm Trận rồi Tiên Kiếm và Loan Đao đâm vách đá làm điểm tựa, liên tục thi triển định thân thuật khắc chế Lôi Long. Nắm thời cơ Thái Cổ Lôi Long tự tách thân làm hai để trốn lực hút và suy yếu nhất, hắn phóng nguyên thần hóa cực lớn, dùng thần thông thôn hồn một ngụm nuốt nửa linh thể của nó rồi điên cuồng hấp thu lôi lực.","bridge":true,"khoang":"@c0605","importance":"major"},{"text":"Trong khe đá, Vương Lâm nuốt Thái Cổ Lôi Long vào nguyên thần. Lôi Long phản kích dữ dội đẩy nguyên thần tới ranh giới sắp tiêu tan; hắn đưa nguyên thần ra khỏi Thiên Linh cái, một bên cắn nuốt một bên in cấm chế phong ấn. Sau nhiều năm tháng, nguyên thần thu nhỏ thành hình Nguyên Anh ba thước, không còn trong suốt mà tản điện quang như vạn ngân xà, biến dị hoàn toàn thành dạng Thiên Lôi. Thân thể rơi vào chết giả rồi khôi phục nhưng gầy yếu hơn xưa.","bridge":true,"khoang":"@c0606","importance":"major"},{"chuong":"@c0606","importance":"major","tieuDe":"Thành quả và cái giá biến dị","text":"Bản lãnh vẫn ở Vấn Đỉnh Sơ Kỳ nhưng nguyên thần nay như một đạo Thiên Lôi, thần thông đều ẩn lôi uy mạnh — đủ áp đảo Vấn Đỉnh Trung Kỳ, phối pháp bảo có thể đấu Vấn Đỉnh Hậu Kỳ. Mới luyện hóa được một phần năm Lôi Long, phần còn lại bị phong ấn. Hắn phát hiện nguyên thần không còn thể thoát ly thân thể, nghi là cái giá của biến dị, rồi gác lại lấy lệnh bài màu tím ra xem."},{"text":"Vương Lâm dùng nguyên thần hút lôi hỏa, tay phải hút sạch lửa nguyên khí đang thiêu đốt nguyên thần Đỗ Kiến, cứu hắn khỏi nguy cơ tiêu tán. Hơn mười ngày sau nguyên thần Đỗ Kiến dung hợp hoàn toàn, đạt Vấn Đỉnh Sơ Kỳ.","bridge":true,"khoang":"@c0608","importance":"major"},{"chuong":"@c0608","importance":"normal","tieuDe":"Luyện chế Đỗ Kiến thành Tiên Vệ Đồng cấp","text":"Vương Lâm ép Đỗ Kiến đồng ý làm vật liệu, in ấn quyết tiên ý lên giữa lông mày hắn rồi tiến hành bí thuật luyện chế Tiên Vệ. Bước một thất bại không biết bao nhiêu lần, phải nung chảy hàng loạt pháp bảo cũ thành chất lỏng thay vật liệu; sau cùng hoàn thành khôi lỗi Tiên Vệ chỉ đạt Đồng cấp."},{"bridge":true,"khoang":"@c0608–@c0608","text":"Khi dọn túi trữ vật, một đóa hoa hồng màu lam hiện ra trong tay khiến Vương Lâm thoáng thấy thân ảnh đỏ như lửa; hắn do dự rồi thu hồi, không đưa vào luyện hóa. Trước bước hai mài nhỏ nguyên thần đầy rủi ro, lực hút bên ngoài cái khe ngày càng mạnh, hắn cắn răng triệu Tôn Hồn Phiên ra.","importance":"major"},{"bridge":true,"khoang":"@c0608","text":"Mục đích cốt lõi: trong ngọc giản có thần thông chỉ Tiên Vệ mới thi triển được, giúp hắn có cơ hội rời khỏi nơi này. Bước một thất bại nhiều lần; thiếu vật liệu nên Vương Lâm dọn túi trữ vật, nung chảy hàng loạt pháp bảo cũ thành chất lỏng dung hợp vào khôi lỗi. Khi đang dọn, một đóa hoa hồng màu lam hiện ra trong tay khiến hắn thấy thân ảnh đỏ như lửa, do dự rồi thu hồi không luyện hóa.","importance":"normal"},{"chuong":"@c0608","importance":"major","tieuDe":"Hoàn thành Tiên Vệ Đồng cấp","text":"Sau hai tháng, thân thể khôi lỗi Đỗ Kiến phát hào quang, hoàn thành bước một nhưng chỉ đạt Đồng cấp (trong bốn trình độ Kim/Ngân/Đồng/Thiết). Vương Lâm do dự hiếm thấy trước bước hai mài nhỏ nguyên thần — chỉ một lần thất bại là hỏng hẳn. Lực hút bên ngoài cái khe ngày càng mạnh suốt hơn nửa năm, cuối cùng hắn cắn răng triệu Tôn Hồn Phiên, đầu lâu xanh đen hiện ra gào thét."},{"chuong":"@c0608","importance":"major","tieuDe":"Luyện chế Tiên Vệ Đồng cấp","text":"Cứu nguyên thần Đỗ Kiến khỏi lửa thiêu, giúp hắn đạt Vấn Đỉnh Sơ Kỳ. Ép Đỗ Kiến đồng ý làm vật liệu luyện chế Tiên Vệ, hứa ngàn năm sau cho tự do. Trải qua nhiều tháng thất bại ở bước một, dùng pháp bảo cũ trong túi trữ vật nung chảy thay vật liệu, cuối cùng hoàn thành Tiên Vệ Đồng cấp. Do dự trước bước hai (mài nhỏ nguyên thần, chỉ một lần thất bại là hỏng hẳn), triệu Tôn Hồn Phiên — đầu lâu xanh đen hiện ra gào thét."},{"text":"Vương Lâm lôi Thiên Quỷ ra khỏi Tôn Hồn Phiên, dùng nó làm hung khí đoạt hư thể cho khôi lỗi. Qua hơn nửa năm luyện hóa, Thiên Quỷ dung hợp với nguyên thần Đỗ Kiến rồi bị xóa mờ mà liên kết chặt chẽ, hoàn thành bước luyện hóa thứ hai cực khó. Hắn nhỏ máu kích hoạt, luyện thành khôi lỗi Tiên Vệ thứ nhất có khí tức ngang cảnh giới âm dương hư thực (xấp xỉ Tư Đồ Nam năm đó), rồi nạp trăm vạn đạo sát lục chi khí và gắn ngọc giản truyền thần thông, ra lệnh ‘Ẩn’ cho nó nấp vào thân ảnh mình.","bridge":true,"khoang":"@c0609","importance":"major"},{"chuong":"@c0609","importance":"bridge","tieuDe":"Nghiên cứu kiếm Cự Phú trong tuyệt địa","text":"Sau khi xác định phải nắm chắc sáu phần thần thông Tiên Vệ mới rời khe, Vương Lâm lấy ra thanh đại kiếm Cự Phú — đệ nhất kiếm của hắn, lớn như một cánh cửa — vuốt thân kiếm và dung nhập tâm thần để dò tìm bí mật còn ẩn giấu của nó. Trong khe tối đầy tiếng gào khóc và lực hút từ hố sâu, hắn cô độc hồi tưởng 800 năm tu đạo, nhớ cha mẹ, được tiểu cầu bạch quang chứa bóng hình Uyển Nhi bầu bạn."},{"chuong":"@c0609","importance":"major","tieuDe":"Luyện thành khôi lỗi Tiên Vệ thứ nhất","text":"Trong tuyệt địa (cái khe), Vương Lâm lôi Thiên Quỷ ra khỏi Tôn Hồn Phiên, dùng nó làm hung khí đoạt hư thể cho khôi lỗi. Nhấn Thiên Quỷ vào lông mày khôi lỗi, nạp lôi quang ẩn hỏa khí, dùng roi khắc chế quất khi nó chống cự. Qua hơn nửa năm, Thiên Quỷ và nguyên thần Đỗ Kiến dung hợp xóa mờ, hoàn thành bước luyện hóa thứ hai. Nhỏ máu kích hoạt, khôi lỗi mở mắt linh hoạt sắc bén, khí tức ngang cảnh giới âm dương hư thực. Nạp trăm vạn đạo sát lục chi khí và ngọc giản thần thông vào khôi lỗi, ra lệnh Ẩn — Tiên Vệ hóa hư vô ẩn vào thân ảnh hắn."},{"chuong":"@c0609","importance":"bridge","tieuDe":"Nghiên cứu kiếm Cự Phú","text":"Lấy đại kiếm Cự Phú (đệ nhất kiếm, lớn như cánh cửa) ra nghiên cứu, dung nhập tâm thần tìm bí mật ẩn giấu bên trong nhưng chưa có kết quả."},{"bridge":true,"khoang":"@c0609","text":"Vương Lâm dự định nắm chắc sáu phần thần thông Tiên Vệ mới rời tuyệt địa, lấy ra đại kiếm Cự Phú dung nhập tâm thần để tìm bí mật của nó. Cô độc trong cái khe tối đen, hắn hồi tưởng tám trăm năm tu đạo, nhớ cha mẹ và Uyển Nhi — bóng hình mờ ảo trong tiểu cầu bạch quang bầu bạn bù đắp nỗi cô đơn.","importance":"bridge"},{"text":"Sau hai năm mắc kẹt trong khe nứt dưới hố sâu vùng đất Yêu Linh, Vương Lâm tĩnh tâm cảm thụ ý chí ẩn trong Cự Phú và lĩnh ngộ được thức kiếm quyết duy nhất — Trảm La Quyết. Khi hắn thu tâm thần ra, Cự Phú hoàn toàn tiêu tan như đã hoàn thành truyền thừa cả đời, chỉ để lại một thức kinh thiên cảm ngộ.","bridge":true,"khoang":"@c0610","importance":"major"},{"bridge":true,"khoang":"@c0610","text":"Tu vi Vấn Đỉnh của hắn chững lại, ba cửa ải Trung Kỳ, Hậu Kỳ, đại viên mãn ví như ba ngọn núi lớn. Hắn nhiều lần bị cuộn tranh nữ tử thần bí gọi ‘Đi xuống’ nhưng chém một kiếm khiến tranh im tiếng; Lôi Oa thức tỉnh, ở bên hắn nuốt tia chớp hắn búng ra.","importance":"bridge"},{"chuong":"@c0610","importance":"normal","tieuDe":"Tai họa ngầm Sát Lục Chi Tâm","text":"Vương Lâm phát hiện Sát Lục Chi Tâm dị biến mấy tháng trước — loại dị biến có nguy cơ khiến hắn phát điên như từng nuốt quả tiên, thậm chí kích động hủy bỏ toàn bộ Sát Lục Chi Khí đã chuyển lên con rối Tiên Vệ. Đây là tai họa ngầm khiến hắn quyết trừ bỏ mọi phiền toái trước khi luyện thức đạo niệm thứ ba."},{"chuong":"@c0610","importance":"bridge","tieuDe":"Thử lực hút, lao tới Truyền Tống Trận","text":"Vương Lâm quyết đoán bước qua ranh giới khe, vận tiên lực chống cự lực hút cực mạnh xé thân thể, cảm thụ khí âm hàn dung nhập cơ thể. Cuối cùng hắn nhảy ra khỏi miệng khe, Thất Tinh Kiếm Trận theo sát, lao về bãi đá có Truyền Tống Trận cổ xưa cách hai mươi trượng phía dưới; vài sợi tơ hồng bị hút khỏi da hóa khí đỏ tan biến."},{"chuong":"@c0610","importance":"major","tieuDe":"Lĩnh ngộ Trảm La Quyết","text":"Sau hai năm tĩnh tâm cảm thụ ý chí bên trong Cự Phú, Vương Lâm ngộ được thức kiếm quyết duy nhất — Trảm La Quyết. Cảm ngộ xong, Cự Phú hoàn toàn tiêu tan như đã hoàn thành truyền thừa cả đời, chỉ còn lại một thức kinh thiên trong tay hắn."},{"chuong":"@c0610","importance":"bridge","tieuDe":"Sát Lục Chi Tâm dị biến","text":"Mấy tháng trước, Vương Lâm cảm thấy Sát Lục Chi Tâm phát sinh dị biến — tai họa ngầm có thể khiến hắn phát điên như từng nuốt quả tiên năm xưa, thậm chí kích động hủy bỏ toàn bộ Sát Lục Chi Khí. Đây là động cơ khiến hắn quyết trừ sạch phiền toái trước khi sáng tạo đạo niệm thức thứ ba."},{"bridge":true,"khoang":"@c0610","text":"Vương Lâm mắc kẹt ba năm trong khe nứt dưới hố sâu vùng đất Yêu Linh; lực hút bùng nổ hai năm trước kéo cơ hội rời khỏi từ sáu phần xuống hai phần. Hắn bình tĩnh chờ lực hút suy yếu, ngộ ra Tuyền Hồn còn thiếu một mạng hung sát nên dự tính sau này đi khắp nhân gian rút khí hung sát từ hồn phách phàm nhân. Cuộn tranh nữ tử thần bí lần thứ tư gọi “Đi xuống”, hắn chém một kiếm khiến tranh im tiếng; Lôi Oa thức tỉnh nuốt tia chớp hắn búng ra. Cuối cùng hắn bước qua ranh giới khe chống cự lực hút, rồi nhảy ra lao về phía Truyền Tống Trận cổ cách hai mươi trượng, vài sợi tơ hồng bị hút khỏi da hóa khí đỏ tan biến.","importance":"normal"},{"chuong":"@c0610","importance":"normal","tieuDe":"Ba năm mắc kẹt khe nứt hố sâu","text":"Vương Lâm ngồi tu suốt ba năm trong khe nứt dưới hố sâu vùng đất Yêu Linh. Hai năm trước khi vuốt thân Cự Phú, lực hút hố sâu bùng nổ kéo cơ hội rời khỏi (nhờ thần thông con rối Tiên Vệ) từ sáu phần xuống còn hai phần; hắn vẫn bình tĩnh chờ lực hút suy yếu."},{"chuong":"@c0610","importance":"normal","tieuDe":"Tai họa ngầm Sát Lục Chi Tâm dị biến","text":"Vương Lâm phát hiện mấy tháng trước Sát Lục Chi Tâm bắt đầu dị biến — loại dị biến có thể khiến hắn phát điên như từng nuốt quả tiên năm xưa, thậm chí kích động hủy bỏ toàn bộ Sát Lục Chi Khí (đã chuyển hết lên con rối Tiên Vệ). Đây là tai họa ngầm khiến hắn quyết trừ bỏ phiền toái trước khi luyện thức thứ ba của đạo niệm."},{"chuong":"@c0610","importance":"bridge","tieuDe":"Lao tới Truyền Tống Trận cổ","text":"Vương Lâm chém kiếm khiến cuộn tranh nữ tử (lần thứ tư gọi “Đi xuống”) cuộn lại im tiếng. Hắn quyết đoán bước qua ranh giới khe, chống cự lực hút xé thân, cảm thụ khí âm hàn; cuối cùng nhảy khỏi khe, Thất Tinh Kiếm Trận theo sát, lao về bãi đá có Truyền Tống Trận cổ cách hai mươi trượng, vài sợi tơ hồng bị hút khỏi da hóa khí đỏ tan biến."},{"text":"Bị cầm chân trong tuyệt địa hố sâu lực hút suốt mười bảy năm, Vương Lâm trước tiên lợi dụng chính lực hút bức hết những sợi tơ đỏ của Sát Lục Tiên Quyết khỏi thân thể, khiến làn da lộ lại sắc bình thường. Sau đó hắn buông lỏng tâm thần để lực hút xuyên thấu qua người; trải nhiều năm thân thể rồi cả nguyên thần dần hòa làm một với lực hút. Cuối cùng hắn ngộ ra phải tự biến mình thành một bộ phận của lực hút, bước xuống vực sâu vô tận tựa hoàng tuyền và lĩnh ngộ thành công Đệ Tam Thức trong thần thông đạo niệm — Hoàng Tuyền Chi Lực.","bridge":true,"khoang":"@c0611","importance":"major"},{"chuong":"@c0611","importance":"major","tieuDe":"Lĩnh ngộ Đệ Tam Thức Hoàng Tuyền Chi Lực","text":"Sau mười bảy năm bị nhốt trong tuyệt địa hố sâu khí âm hàn nồng đậm, Vương Lâm bức hết những sợi tơ đỏ của Sát Lục Tiên Quyết khỏi thân thể, rồi dung nhập trọn vẹn cả thân thể lẫn nguyên thần vào lực hút khủng khiếp của hố sâu. Hắn bước xuống vực, tự hóa thành một bộ phận của lực hút, thân dừng giữa không trung, lĩnh ngộ thành công Đệ Tam Thức trong thần thông đạo niệm — Hoàng Tuyền Chi Lực — và tuyên bố đã đến lúc rời đi."},{"bridge":true,"khoang":"@c0611","text":"Mất bốn năm bức sợi tơ đỏ cuối cùng khỏi da thịt, sáu năm để lực hút xuyên thẳng qua thân thể nhưng nguyên thần vẫn chưa hòa; thanh âm nữ tử trong nguyên thần thúc giục “Đi xuống…”.","importance":"major"},{"text":"Nữ tử trong bức tranh phá vỡ im lặng mười ba năm, dụ Vương Lâm xuống đáy hố sâu vùng yêu linh bằng lời tiết lộ lai lịch thật của Thiên Nghịch châu và cách cứu sống tàn hồn nữ tử trong hạt châu. Vì hy vọng đó, hắn tạm mất tỉnh táo của tám trăm năm tu đạo, cầm tranh lao xuống. Nhìn xuyên dòng xoáy thấy La Thiên tinh vực, hắn nhận ra nữ tử giấu nhiều bí mật và đang gài bẫy, bèn lật kèo: không qua dòng xoáy mà phong ấn nàng triệt để, dùng cả con rối Tiên Vệ đánh thêm phong ấn khi nàng cố thoát, rồi chôn sâu bức tranh trong vách đá trước khi rời đi.","bridge":true,"khoang":"@c0612","importance":"major"},{"chuong":"@c0612","importance":"bridge","tieuDe":"Chống lực hút bằng Thất Tinh Kiếm Trận","text":"Tại miệng khe có dòng xoáy cực lớn phát ra lực hút khủng khiếp, Vương Lâm ngồi thích ứng bảy ngày rồi triển khai Thất Tinh Kiếm Trận để cố định thân hình. Dưới lực hút, sát lục chi ý của hắn hóa thành tơ đỏ lộ ra dưới da, số lượng lên tới trăm vạn — đúng bằng số Sinh Mệnh Lạc Ấn."},{"chuong":"@c0612","importance":"major","tieuDe":"Lật kèo phong ấn nữ tử trong tranh","text":"Nữ tử trong bức tranh — im lặng mười ba năm — bất ngờ mang theo cảm xúc van xin rồi dụ Vương Lâm đưa nàng về La Thiên tinh vực, đổi lấy lời hứa tổ tiên nàng giúp cứu sống tàn hồn nữ tử trong Thiên Nghịch châu. Vì hy vọng cứu tàn hồn, hắn tạm mất tỉnh táo, cầm tranh lao xuống đáy hố, nhìn xuyên dòng xoáy thấy La Thiên tinh vực. Sau cùng nhận ra âm mưu, hắn lật kèo: phá tảng đá truyền tống trận, ném tranh cắm vào vách đá rồi đánh vô số cấm chế phong ấn suốt mấy tháng, vỗ sụp cái khe chôn sâu bức tranh, rồi triệu con rối Tiên Vệ phong ấn triệt để mới rời đi."},{"chuong":"@c0612","importance":"bridge","tieuDe":"Chống lực hút bằng Thất Tinh Kiếm Trận","text":"Tại hành lang đáy hố có dòng xoáy cực lớn phát ra lực hút khủng khiếp, Vương Lâm ngồi thích ứng bảy ngày rồi triển khai Thất Tinh Kiếm Trận giữ thân. Sát lục chi ý của hắn hóa thành tơ đỏ lộ dưới da, số lượng lên tới trăm vạn — bằng đúng số Sinh Mệnh Lạc Ấn."},{"chuong":"@c0612","importance":"bridge","tieuDe":"Nhìn xuyên dòng xoáy thấy La Thiên tinh vực","text":"Sau thời gian dài bay xuống, Vương Lâm tới hành lang có dòng xoáy cực lớn — nguồn lực hút. Lực lượng từ bức tranh ngưng tụ ở hai mắt cho hắn nhìn xuyên dòng xoáy, thấy một mảnh tinh không vô số tu chân tinh — quê hương nữ tử là La Thiên tinh vực, tức Lôi tiên giới. Hắn ngồi thích ứng lực hút bảy ngày rồi triển khai Thất Tinh Kiếm Trận chống cự; sát lục chi ý hóa tơ đỏ lộ dưới da, số lượng lên tới trăm vạn bằng đúng số Sinh Mệnh Lạc Ấn."},{"chuong":"@c0612","importance":"normal","tieuDe":"Lật kèo phong ấn vĩnh viễn nữ tử trong tranh","text":"Nhận ra nữ tử giấu nhiều bí mật và lời mời giao dịch (đưa nàng về La Thiên tinh vực đổi lời hứa tổ tiên cứu tàn hồn) là cái bẫy, Vương Lâm không qua dòng xoáy mà bay lên, phá tảng đá che truyền tống trận, ném tranh cắm sâu vào vách đá rồi đánh vô số cấm chế phong ấn suốt mấy tháng, vỗ sụp cái khe chôn sâu bức tranh. Khi nữ tử cố thoát nứt ra ba động, hắn triệu con rối Tiên Vệ đánh thêm phong ấn mênh mông đè lên, hai lần phong ấn triệt để mới rời đi."},{"text":"Vương Lâm cân nhắc nữ tử trong tranh (nghi là tai họa ngầm, chỉ tin ba phần), mối đe dọa Thiên Vận Tử cùng việc giấu Thiên Nghịch châu, quyết rời vùng đất Yêu Linh đi La Thiên tinh vực để đề cao tu vi, định ghé Hướng gia ở Đông Lâm tinh dò thân phận nữ tử trong tranh — vì lão tổ tộc nàng được cho là có thể khiến Uyển nhi sống lại.","bridge":true,"khoang":"@c0613","importance":"major"},{"bridge":true,"khoang":"@c0613","text":"Nhờ Thất Tinh kiếm trận, con rối Tiên Vệ hóa lốc đen và lực hút hố sâu yếu đi, lại được con Văn thú màu tím (rời hắn hơn mười năm) lao xuống đón, Vương Lâm thoát khỏi hố sâu.","importance":"bridge"},{"chuong":"@c0613","importance":"bridge","tieuDe":"Thu phục đàn Văn thú","text":"Qua thần thức Văn thú cũ, Vương Lâm thấy lại biến cố cuộc chiến Tham Lang–Chu Dật năm xưa: hai tu sĩ Hỏa Yêu quận bắt cả hai cùng phần lớn đàn Văn thú. Hắn dẫn đàn Văn thú sang Thủy Yêu quận mở túi trữ vật; chỉ ấu thú chịu vào, hơn hai phần ba Văn thú trưởng thành tự đoạn tâm mạch tự vẫn vì bị vương bỏ rơi."},{"chuong":"@c0613","importance":"bridge","tieuDe":"Phong ấn động phủ huyền bí","text":"Vương Lâm dùng tấm thủy tinh truyền tống về động phủ còn vô số cấm chế chưa phá, phong ấn nó và phá bỏ truyền tống trận để từ nay không ai (kể cả Huyết Tổ) vào được, từ biệt động phủ chi linh đứng lặng ở cửa động."},{"bridge":true,"khoang":"@c0613","text":"Tới bộ lạc Luyện Hồn ở Thiên Yêu quận, hắn gọi Thập Tam và Âu Dương Hoa vào bảo tháp, để lại công pháp (gồm cả công pháp Cự Ma tộc) cho Thập Tam rồi rời đi; hai người dập đầu bi ai.","importance":"bridge"},{"chuong":"@c0613","importance":"bridge","tieuDe":"Giết Thạch Tiêu báo lời hứa","text":"Tại yêu tướng phủ Thiên Yêu quận, Vương Lâm hiện thân dưới ánh trăng, thi triển thần thông bóng Âm dương hư thật lao qua thân Thạch Tiêu (tu vi ngang Vấn Đỉnh trung kỳ) đập vỡ vụn mọi bộ phận cơ thể hắn — báo lời hứa năm xưa lấy mạng. Hắn dặn Trần Đào “Cẩn thận, sư tôn” rồi rời đi."},{"chuong":"@c0613","importance":"major","tieuDe":"Quyết rời Yêu Linh đi La Thiên","text":"Sau khi cân nhắc nữ tử trong tranh (kẻ bị nghi là tai họa ngầm dụ hắn tới La Thiên tinh vực) cùng mối đe dọa từ đám Thiên Vận Tử, Vương Lâm quyết rời vùng đất Yêu Linh sớm, định ghé Hướng gia ở Đông Lâm tinh dò thân phận nàng vì lão tổ tộc nàng được cho là có thể khiến Uyển nhi sống lại; chờ tu vi ngang Thiên Vận Tử mới quay về tra xét động phủ."},{"chuong":"@c0613","importance":"bridge","tieuDe":"Thu phục Văn thú, từ biệt thuộc hạ","text":"Vương Lâm dẫn Văn thú sang Thủy Yêu quận mở túi trữ vật; chỉ ấu thú chịu vào, hơn hai phần ba Văn thú trưởng thành tự đoạn tâm mạch tự vẫn vì bị vương bỏ rơi. Hắn truyền tống về động phủ, phong ấn và phá truyền tống trận để không ai (kể cả Huyết Tổ) vào được, từ biệt động phủ chi linh; tới bộ lạc Luyện Hồn để lại công pháp (gồm công pháp Cự Ma tộc) cho Thập Tam, từ biệt Thập Tam và Âu Dương Hoa."},{"text":"Khi đám lão quái vừa bước vào vùng đất Yêu Linh, Vương Lâm lập tức lao xuống vực sâu triều tịch ở Thủy Yêu quận. Hắn hòa hợp với lực hút, thả Thất Tinh kiếm trận tạo lực đẩy gia tốc, dung nhập dòng xoáy thông tới La Thiên tinh vực để thoát thân. Trước khi biến mất hắn để lại câu nói về hư phủ thứ tư khiến Huyết Tổ rơi vào thế bị các lão quái nghi kỵ, ngăn được Huyết Tổ truy kích vì Diêu Tích Huyết.","bridge":true,"khoang":"@c0614","importance":"major"},{"chuong":"@c0614","importance":"bridge","tieuDe":"Thoát khỏi đám lão quái qua dòng xoáy","text":"Lao vào vực sâu triều tịch, dùng Thất Tinh kiếm trận tạo lực đẩy dung nhập lực hút để tăng tốc, bước lên dòng xoáy thông tới La Thiên tinh vực rời đi trước mặt đám lão quái. Trước khi biến mất, tiết lộ bí mật hư phủ thứ tư khiến Huyết Tổ rơi vào thế bị nghi kỵ, ngăn truy kích."},{"text":"Sau khi dung nhập trận lốc xoáy tựa như qua một truyền tống trận, Vương Lâm hiện ra ở một tinh không hoàn toàn xa lạ. Đây không phải Liên Minh Tinh Vực quê hương mà là La Vân Tinh Vực thuộc Lôi chi tiên giới — một trong tứ đại tiên giới phong-vũ-lôi-điện. Hắn xuất tinh la bàn dạo quanh với vẻ bỡ ngỡ, bước vào một thế giới rộng lớn hơn hẳn những gì từng biết.","bridge":true,"khoang":"@c0615","importance":"bridge"},{"chuong":"@c0615","importance":"major","tieuDe":"Thiên Lôi cứu nhóm Nhiễm gia","text":"Vương Lâm bắt gặp bốn tu sĩ Nhiễm Vân Tinh bị Minh vụ trùng vây trong sương độc. Chỉ một ánh mắt như thực chất của hắn đã khiến lũ trùng run rẩy rút lui. Sau khi truyền âm hỏi đường tới Hợp vân thánh, hắn nâng tay thi triển Thiên Lôi chân chính — sấm chớp do nguyên thần dung hợp Thái Cổ Lôi Long sinh ra — tiêu tan toàn bộ sương mù, đám trùng cảm nhận lôi uy chân chính nên lùi rất nhanh."},{"chuong":"@c0615","importance":"major","tieuDe":"Thiên Lôi giải vây Minh vụ trùng","text":"Vương Lâm dùng ánh mắt như thực chất khiến Minh vụ trùng run rẩy rút lui, rồi thử thu hồi để sương vây lại mà nghe bốn người cầu cứu. Sau khi hỏi đường tới Hợp vân thánh, hắn chỉ tay thi triển Thiên Lôi chân chính sinh từ nguyên thần dung hợp Thái Cổ Lôi Long, sấm sét như rồng tiêu tan toàn bộ sương độc, Minh vụ trùng cảm lôi uy chân chính nên lùi rất nhanh."},{"chuong":"@c0615","importance":"major","tieuDe":"Giải vây nhóm Nhiễm Vân Tinh","text":"Gặp bốn người Nhiễm Vân Tinh bị Minh vụ trùng vây trong sương độc, Vương Lâm chỉ bằng một ánh mắt thực chất đã khiến đám trùng run rẩy rút lui. Hắn thử thu hồi ánh mắt để dò xét, hỏi đường tới Hợp vân thánh, rồi thi triển Thiên Lôi chân chính (do nguyên thần dung hợp Thái Cổ Lôi Long) tiêu tan toàn bộ sương mù Minh vụ trùng."},{"text":"Sau khi cứu bốn người Nhiễm gia khỏi Minh vụ trùng và sấm sét, Vương Lâm được Nhiễm Nguyệt nghi là Lôi Tiên sứ giả; hắn không thừa nhận cũng không phủ nhận, xưng tên giả Hứa Mộc, theo bốn người dẫn đường tới Nhiễm Vân Tinh để ẩn nấp tránh đám Thiên Vận Tinh truy đuổi. Tới nơi, hắn che tu vi Vấn Đỉnh xuống Kết Đan hậu kỳ, dựa vào tiên vệ thần thông đổi tướng mạo, vào thành Tôn gia thuê một động phủ cấp dưới ở thành bắc.","bridge":true,"khoang":"@c0616","importance":"major"},{"bridge":true,"khoang":"@c0616","text":"Hắn xưng tên giả Hứa Mộc đề phòng đám Thiên Vận Tử truy đuổi, nhân lúc bốn người dẫn đường tìm hiểu La Thiên Tinh Vực, hỏi về Thiên Huyễn Tinh và Đông Lâm Tinh để chuẩn bị về sau.","importance":"bridge"},{"chuong":"@c0616","importance":"bridge","tieuDe":"Ẩn nấp tại Nhiễm Vân Tinh","text":"Vào Nhiễm Vân Tinh, Vương Lâm bị ba cỗ thần thức cực mạnh quét tới nhưng đánh lui; phân tích nơi này chỉ có ba phương thế lực với ba Vấn Đỉnh, linh lực sung mãn, là chỗ tốt để ẩn nấp tránh truy đuổi của Thiên Vận Tinh."},{"bridge":true,"khoang":"@c0616","text":"Hắn che tu vi Vấn Đỉnh sơ kì xuống Kết Đan hậu kì, dựa tiên vệ thần thông đổi tướng mạo (không dùng thuật biến hóa thông thường dễ bị lộ), dùng phi kiếm bình thường bay tới thành Tôn gia.","importance":"major"},{"chuong":"@c0616","importance":"major","tieuDe":"Thuê động phủ thành bắc Tôn gia","text":"Vương Lâm vào thành Tôn gia, nộp linh thạch, tới thành bắc thuê phòng cấp dưới (trăm khối hạ phẩm linh thạch) nhận lệnh bài phòng thứ năm phía tây. Bị thanh niên canh giữ khinh miệt là tu sĩ ngoại lai nhờ đan dược mới đạt Kết Đan; cấm chế cửa trong mắt hắn cực kỳ đơn giản, không cần phá giải vẫn bước vào."},{"text":"Vương Lâm an cư trong phòng xá linh khí dày tại Nhiễm Vân Tinh, gia cố cấm chế và thổ nạp. Hắn kiểm điểm tài nguyên thấy tiên ngọc hao hụt gần hết sau Vấn Đỉnh, tiên dịch chỉ còn năm giọt, xác định việc thu hoạch tiên ngọc hằng ngày là tối quan trọng. Hắn luyện chế ba Ngụy tiên bảo (phi kiếm, gương đồng, trâm cài tóc) và sáng tạo thủ pháp “ngụy kế thừa” bằng phong ấn đặc thù.","bridge":true,"khoang":"@c0617","importance":"normal"},{"chuong":"@c0617","importance":"major","tieuDe":"Chế tạo bộ ba Ngụy tiên bảo","text":"An cư trong phòng xá mới linh khí dày đặc ở Nhiễm Vân Tinh, Vương Lâm dùng nguyên thần khí hóa thành ba khuôn đúc, luyện chế phi kiếm, gương đồng và trâm cài tóc — gọi là Ngụy tiên bảo. Hắn nhập Tuế Nguyệt Ý Cảnh vào gương đồng, Thiên Huyễn Vô Tình Đạo (mô phỏng Liễu Mi năm xưa) vào trâm cài tóc, và một đạo na di ấn quyết vào phi kiếm. Tuy chất lượng không bằng cả hạ phẩm Tiên Bảo chân chính nhưng dùng được tiên lực và ẩn ý cảnh thần thông, ngay tu sĩ Anh Biến không có tiên lực cũng có thể dùng linh lực để vận."},{"chuong":"@c0617","importance":"bridge","tieuDe":"Sáng tạo thủ pháp Ngụy kế thừa","text":"Vương Lâm suy diễn cách khiến pháp bảo có năng lực kế thừa như Tôn Hồn Phiên hay Xạ Thần Xa, vốn chỉ Đại Tông Sư luyện khí mới làm được. Hắn nghĩ lệch sang việc thêm cho pháp bảo một đạo phong ấn đặc thù và cất bí quyết mở phong ấn vào ngọc giản — nếu phong ấn đủ mạnh thì hiệu quả gần như kế thừa thật. Hắn thử nghiệm thành công trên gương đồng, dẫn khói nến qua hạt châu xanh rồi áp vào các kí hiệu hắc quang."},{"bridge":true,"khoang":"@c0617","text":"Vương Lâm gia cố cấm chế phòng xá, thổ nạp linh khí nhưng nhận ra cách thông thường không nâng được tu vi; kiểm điểm thấy tiên ngọc hao hụt gần hết sau Vấn Đỉnh, chỉ còn năm giọt tiên dịch, từ đó xác định phải thu hoạch tiên ngọc hằng ngày. Hắn gạt bỏ ý cướp đoạt rồi sáng hôm sau ra ngoài, đi qua chỗ gã thanh niên ngồi hấp thụ tinh hoa trời đất nơi núi đá.","importance":"bridge"},{"text":"Ẩn thân giả dạng tu sĩ bình thường ở một thành tu sĩ (tu vi đã đạt Hóa Thần Hậu), Vương Lâm đi tìm chốn buôn bán pháp bảo để bán thanh phi kiếm tự luyện chế. Tới Bảo Hợp Lâu ở thành đông thì bị Lô Phong chặn theo lệ ‘hai không tiến, một không ra’ và chê phi kiếm thấp kém; hắn chỉ liếc mắt một cái đã khiến Nguyên Anh của Lô Phong gần sụp đổ. Sau đó hắn sang Thanh Trúc Các, nơi văn sĩ trẻ xem phi kiếm rồi kinh khiếp.","bridge":true,"khoang":"@c0618","importance":"major"},{"chuong":"@c0618","importance":"major","tieuDe":"Bị Lô Phong chặn ở Bảo Hợp Lâu","text":"Tại Bảo Hợp Lâu, Vương Lâm bị Lô Phong nêu nguyên tắc “hai không tiến, một không ra” mời ra do không đủ mười vạn linh thạch. Hắn trình phi kiếm bị Lô Phong chê thấp kém; trước khi rời đi, hắn chỉ liếc mắt nhìn thẳng vào mắt Lô Phong khiến gã rúng động, Nguyên Anh gần sụp đổ, mặt tái nhợt lùi vài bước."},{"chuong":"@c0618","importance":"bridge","tieuDe":"Phi kiếm khiến văn sĩ Thanh Trúc Các kinh khiếp","text":"Vương Lâm tới Thanh Trúc Các, được văn sĩ trẻ tiếp đón hiền hòa. Hắn trình thanh phi kiếm tự luyện; văn sĩ dùng thần thức xem xét thì đột nhiên mở tròn mắt, kinh khiếp nhìn chằm chằm — phi kiếm bề ngoài tầm thường lại ẩn chứa điều phi phàm."},{"chuong":"@c0618","importance":"major","tieuDe":"Bị Lô Phong từ chối, dọa lui bằng một ánh mắt","text":"Tại Bảo Hợp Lâu, hắn bị Lô Phong chặn vì không đủ mười vạn linh thạch (từ khi đạt Hóa Thần Hậu chủ yếu dùng tiên ngọc). Phi kiếm tự luyện bị Lô Phong chê thấp kém, từ chối thu. Trước khi đi, Vương Lâm liếc thẳng vào mắt Lô Phong khiến gã rúng động, Nguyên Anh gần sụp đổ, mặt tái nhợt lùi mấy bước. Sau đó hắn tới Thanh Trúc Các, văn sĩ trẻ xem phi kiếm rồi kinh khiếp."},{"text":"Vương Lâm đổi bộ dạng hành sự tại La Thiên Tinh Vực, ghé Thanh Trúc Các trên Nhiễm Vân Tinh đem bán thanh phi kiếm ngụy tiên bảo. Hắn để lão già áo xanh kiểm định, bán phi kiếm ba nghìn tiên ngọc rồi đưa ra mặt gương đồng kế thừa ngụy tiên bảo ra giá năm vạn tiên ngọc, ngầm bày thế “phòng vệ” để có cớ giết người đoạt bảo nếu đối phương ra tay cướp.","bridge":true,"khoang":"@c0619","importance":"normal"},{"chuong":"@c0619","importance":"major","tieuDe":"Bán ngụy tiên bảo tại Thanh Trúc Các","text":"Tại Thanh Trúc Các trên Nhiễm Vân Tinh (La Thiên Tinh Vực), dưới bộ dạng thay đổi và tu vi biểu hiện Kết Đan hậu kì, Vương Lâm đem bán thanh phi kiếm ngụy tiên bảo có lạc ấn thuấn di (nuôi dưỡng bằng ý cảnh sinh tử luân hồi), thuật Đại Na Di và lôi điện kì dị. Sau khi Tôn Mặc thử nghiệm và mời trưởng lão Anh Biến tới, lão già áo xanh kiểm định, định danh ngụy tiên bảo rồi mua với giá ba nghìn tiên ngọc, tiên lực tràn ngập cả Thanh Trúc Các."},{"chuong":"@c0619","importance":"bridge","tieuDe":"Bày thế phòng vệ với gương đồng","text":"Vương Lâm lấy ra mặt gương đồng kế thừa ngụy tiên bảo khiến lão già áo xanh khiếp sợ và lộ rõ lòng tham, ra giá năm vạn tiên ngọc. Tâm tình đã đạt trình độ Đại Tông Sư, hắn thong dong ngầm tính: nếu đối phương chủ động cướp bảo thì hắn giết người đoạt bảo cũng là phòng vệ hợp tình hợp lí, để đứng vững chân ở Nhiễm Vân Tinh."},{"chuong":"@c0619","importance":"major","tieuDe":"Bán ngụy tiên bảo tại Thanh Trúc Các","text":"Vương Lâm đem phi kiếm ngụy tiên bảo (chứa lạc ấn thuấn di, thuật Đại Na Di, lôi điện kì dị) tới Thanh Trúc Các trên Nhiễm Vân Tinh bán cho trưởng lão Anh Biến hậu kì với giá ba nghìn tiên ngọc. Sau đó lấy ra gương đồng kế thừa ngụy tiên bảo khiến lão già khiếp sợ và tham lam, ra giá năm vạn tiên ngọc — số tiền lão tích lũy trăm năm dành cho Vấn Đỉnh. Vương Lâm ngầm bố trí thế phòng vệ: nếu đối phương cướp bảo thì hắn giết người đoạt bảo cũng hợp tình hợp lí, để đứng vững chân ở Nhiễm Vân Tinh."},{"text":"Dưới lốt người thanh niên dòng trưởng gia tộc tu chân, Vương Lâm bán ngọc giản kế thừa của gương đồng (ngụy tiên bảo) tại Thanh Trúc Các cho một lão già Anh Biến, thu hơn một vạn tiên ngọc cùng toàn bộ số dư túi trữ vật. Khi bị một tu sĩ Nguyên Anh trung kỳ (do Tôn trưởng lão xúi) chặn cướp bằng thần thông sương mù hóa bàn tay, hắn phất tay quét tan đòn tập kích, làm tan gần nửa nguyên anh kẻ địch rồi truy đuổi về thành Tôn gia, giáng uy áp khổng lồ buộc cả gia tộc chống đỡ. Hắn ngầm phô đạo khí Vấn Đỉnh khiến lão hắc y Anh Biến hậu kỳ đại viên mãn (đang mượn đạo khí Vấn Đỉnh của Lão tổ) phải nhận lỗi, ép lấy hai mươi vạn tiên ngọc bồi thường rồi rời đi.","bridge":true,"khoang":"@c0620","importance":"major"},{"text":"Vương Lâm định kế hành sự khiêm tốn ở Nhiễm Vân Tinh dưới danh Hứa Mộc — hờ hững nhìn ngoài, không tham dự tình thế, tạo một luồng lực vô hình khiến các tồn tại đỉnh cao không dám xúc phạm, nhằm yên tu rồi quay về Liên Minh Tinh Vực. Bị một nữ giả nam tĩnh tọa dưới ngọn núi gần chỗ ở giáo huấn về tu chân, hắn cười khổ vâng dạ. Dùng nghìn khối tiên ngọc thổ nạp ba ngày, nhận ra Vấn Đỉnh ngốn tiên ngọc khổng lồ hơn Anh Biến rất nhiều.","bridge":true,"khoang":"@c0621","importance":"major"},{"chuong":"@c0621","importance":"major","tieuDe":"Nhận tiên ngọc và lệnh bài đấu giá","text":"Tôn Khải Minh của Tôn Gia hạ tu vi xuống Kết Đan kỳ tới gặp, giao túi trữ vật chứa hai mươi vạn tiên ngọc; Vương Lâm nhận mà không kiểm tra, xưng tên là Hứa Mộc. Khi lão buộc phải thăm dò tu vi và nhắc cuộc đấu giá bảy ngày sau ở Bảo Hợp Lâu của Nhiễm Gia có một viên bát phẩm thứ thần đan, hắn phóng áp lực vô hình khiến lão run rẩy, rồi bảo mang lệnh bài đến và nhận khối lệnh bài đấu giá hồng sắc."},{"chuong":"@c0621","importance":"bridge","tieuDe":"Định kế khiêm tốn ở Nhiễm Vân Tinh","text":"Vương Lâm xác lập cách hành sự ẩn thân tại Nhiễm Vân Tinh dưới danh Hứa Mộc: hờ hững nhìn ngoài, không tham dự tình thế, tạo một luồng lực vô hình khiến các tồn tại đỉnh cao không dám xúc phạm, nhằm yên tâm tu luyện rồi quay về Liên Minh Tinh Vực. Khi bị một thanh niên gầy gò giáo huấn về tu chân, hắn cười khổ vâng dạ, cảm khái chưa từng có ai dám đứng trước mặt hắn nói những lời như vậy."},{"chuong":"@c0621","importance":"major","tieuDe":"Thổ nạp tiên ngọc, suy tư khan hiếm","text":"Hắn dùng nghìn khối tiên ngọc bắt pháp quyết ép tiên khí co rút quanh mình, thổ nạp ba ngày khiến nghìn khối hóa bụi phấn. Nhận ra tu vi Vấn Đỉnh ngốn tiên ngọc khổng lồ hơn nhiều Anh Biến, kể cả thêm hai mươi vạn của Tôn Gia cũng không đủ tiến Vấn Đỉnh trung kỳ; suy đoán tu sĩ bước thứ hai có thể không cần hoặc có cách thay tiên ngọc."},{"chuong":"@c0621","importance":"bridge","tieuDe":"Nhận tiên ngọc và lệnh bài đấu giá","text":"Tôn Khải Minh cung kính giao túi trữ vật chứa hai mươi vạn tiên ngọc, hỏi tên; Vương Lâm bình thản đáp tên là Hứa Mộc và nhận mà không kiểm tra. Lão bẩm bảy ngày sau Bảo Hợp Lâu của Nhiễm Gia tổ chức đấu giá có một viên bát phẩm thứ thần đan; Vương Lâm phóng áp lực vô hình khiến lão run rẩy, rồi bảo mang đến và nhận lệnh bài đấu giá hồng sắc."},{"text":"Dưới danh Hứa Mộc trên Nhiễm Vân Tinh, Vương Lâm cảnh cáo lão già hắc y dùng bát phẩm thần đan thăm dò hắn “Không còn lần thứ hai đâu”. Hắn luận rõ phẩm cấp đan dược nhờ ký ức Lý Mộ Uyển, nhận ra hắc y được tu sĩ Vấn Đỉnh Tôn Gia chống lưng, dùng cách ôn hòa do không nhìn ra tu vi của hắn.","bridge":true,"khoang":"@c0622","importance":"bridge"},{"chuong":"@c0622","importance":"bridge","tieuDe":"Tám bước áp đảo lão tổ Tôn Tích","text":"Sau bảy ngày hấp thụ hai mươi vạn tiên ngọc, Vương Lâm xuất quan, thấy người áo tím Tôn Tích chờ trước cổng thành Bắc. Vì cảm động trước Tôn Lăng kiên quyết bảo vệ mình, hắn bước ra, đi liên tục tám bước áp bức, mỗi bước như sấm sét nổ trong tâm thần khiến Tôn Tích trắng bệch lui bước, phải ôm quyền cầu hòa."},{"chuong":"@c0622","importance":"bridge","tieuDe":"Từ chối rồi nhận điều kiện Lôi tiên giới","text":"Trên đường tới Bảo Hợp Lâu thành Đông, Vương Lâm bác lời cầu cạnh ban đầu của Tôn Tích vì gia tộc “không nuôi nổi hai người Vấn Đỉnh”. Tôn Tích bèn đề nghị tặng suất đi Lôi tiên giới trăm năm sau ở La Thiên Tinh Vực — nơi Lôi Đỉnh do Lôi Tiên Điện khống chế."},{"chuong":"@c0622","importance":"normal","tieuDe":"Nhìn thấu bẫy đan dược Tôn Gia","text":"Vương Lâm cảnh cáo lão già hắc y dùng bát phẩm thần đan thăm dò, khiến lão kinh hãi tan biến. Hắn luận rõ phẩm cấp đan dược nhờ ký ức Lý Mộ Uyển từng là Luyện Đan Đại Sư, nhận ra cái bẫy của Tôn Gia: nếu không động tâm lấy lệnh bài thì lộ ra tu vi đã ở bước thứ hai. Hắn bỏ qua chuyện này."},{"chuong":"@c0622","importance":"bridge","tieuDe":"Tám bước áp đảo lão tổ Tôn Tích","text":"Sau bảy ngày hấp thụ tiên ngọc, Vương Lâm đối mặt người áo tím trước cổng thành Bắc. Hắn bảo vệ Tôn Lăng đang run rẩy mà vẫn kiên cường giữ thành, bước ra dùng tám bước uy thế áp bức, mỗi bước như sấm sét nổ trong tâm thần, khiến lão tổ Vấn Đỉnh sơ kỳ Tôn Tích trắng bệch liên tục lui, phải ôm quyền cầu hòa."},{"chuong":"@c0622","importance":"bridge","tieuDe":"Từ chối Tôn Tích, nghe điều kiện Lôi tiên giới","text":"Tôn Tích lộ thân phận lão tổ Tôn Gia, cầu Vương Lâm giúp, đề nghị dốc toàn lực gia tộc nhưng bị bác vì gia tộc không nuôi nổi hai người Vấn Đỉnh. Tôn Tích bèn đề nghị tặng suất đi Lôi tiên giới trăm năm sau, đồng thời hé lộ nghi ngờ về lai lịch của Vương Lâm."},{"text":"Dưới thân phận cải trang “Hứa huynh”, Vương Lâm dùng mối quan hệ cứu mạng Tôn Tuyết Sơn để đáp lời Tôn Tích, khiến lão tổ Tôn Gia chỉ có thể hoài nghi mà không truy đến cùng, càng thêm kiêng dè và muốn kết giao.","bridge":true,"khoang":"@c0623","importance":"normal"},{"chuong":"@c0623","importance":"normal","tieuDe":"Nhận ra cạm bẫy đan dược Nhiễm Gia","text":"Tại Bảo Hợp Lâu thành Đông, Vương Lâm dùng thần thức phát hiện một hình bóng già nua ở lầu ba với dấu vết đã tiêu tán hơn phân nửa, thốt “Là hắn!”. Nghe Tôn Tích kể chuyện bốn năm trước, hắn nhận ra bát phẩm đan dược là mồi nhử do lão tổ Vấn Đỉnh Nhiễm Gia giăng nhằm dụ hắn mua mà dính vào ân oán diệt tộc với Huyễn Gia; thầm cảnh giác trước tâm cơ thâm độc đó."},{"chuong":"@c0623","importance":"normal","tieuDe":"Hóa giải nghi ngờ thân phận","text":"Dưới thân phận cải trang ‘Hứa huynh’, Vương Lâm mượn mối quan hệ cứu mạng Tôn Tuyết Sơn để đáp lời truy vấn của Tôn Tích, khiến lão tổ Tôn Gia chỉ còn hoài nghi mà không dám truy đến cùng, càng thêm kiêng dè và muốn kết giao."},{"chuong":"@c0623","importance":"normal","tieuDe":"Nhận ra cạm bẫy bát phẩm đan dược","text":"Tới Bảo Hợp Lâu dự đấu giá, Vương Lâm dùng thần thức phát hiện một hình bóng già nua ở lầu ba với dấu vết đã tiêu tán hơn phân nửa, thầm thốt ‘Là hắn!’. Nghe Tôn Tích kể chuyện bốn năm trước, hắn hiểu ra Nhiễm Gia bày bát phẩm đan dược làm mồi nhử nhằm kéo hắn vào ân oán diệt tộc với Huyễn Gia, liền cảnh giác mà tạm chưa quyết mua."},{"text":"Ngồi tầng bốn dưới danh nghĩa họ Hứa, Vương Lâm lạnh nhạt hô giá một khối tiên ngọc cho món bát phẩm “đan dược” khởi điểm một vạn, khiến cả đại sảnh xôn xao. Khi sứ giả Nhiễm Gia cắn răng chấp nhận, hắn vung trảo cách không hút viên thuốc về tay, ném ra một khối tiên ngọc rồi ôm quyền chào Tôn Tích, thuấn di rời đi. Trong lòng hắn ngầm cảnh giác đây là cái bẫy muốn lôi mình vào một cục diện nhất định.","bridge":true,"khoang":"@c0624","importance":"bridge"},{"chuong":"@c0624","importance":"bridge","tieuDe":"Nhận ra cố nhân Tôn Thái","text":"Bị lão già tầng ba đuổi theo, ban đầu lão tưởng nhận lầm người mà bỏ đi, Vương Lâm trầm mặc rồi gọi đích danh “Tôn Thái”. Hắn phóng thần thức đảo qua người Tôn Thái dò xét, hỏi vì sao thần thông Cự Ma Tộc lão tổ năm xưa lại đưa được lão tới La Thiên Tinh Vực và vì sao lạc ấn trên người lão còn sót lại rất nhạt. Khi Tôn Thái vừa nhắc Đông Lâm Tinh, hắn liền cuốn lão thuấn di vào thành Bắc, về phòng riêng để tra hỏi cặn kẽ."},{"text":"Tại Thành bảo hợp lâu trên Nhiễm Vân tinh, Vương Lâm gặp lại Tôn Thái — Đại trưởng lão Thi Âm Tông năm xưa ở Chu Tước tinh, nay tu vi tụt xuống Hóa Thần kỳ, làm khách khanh nắm tin tức cho Nhiễm gia. Vương Lâm tự xưng tu vi Vấn Đỉnh khiến Tôn Thái chấn động, từ đó moi được nhiều bí mật về cục diện tinh vực.","bridge":true,"khoang":"@c0625","importance":"major"},{"chuong":"@c0625","importance":"normal","tieuDe":"Lời hứa nhân quả với Tôn Thái","text":"Dùng ý cảnh sinh tử luân hồi, Vương Lâm liếc một cái nhìn ra tử khí và tuổi thọ Tôn Thái chỉ còn hai mươi năm. Vương Lâm hứa nếu hai mươi năm sau còn ở Nhiễm Vân tinh sẽ đích thân tiễn hắn, đồng thời nhận lời mang tro cốt Tôn Thái về Ám Nguyệt tinh để lá rụng về cội; đặc biệt hỏi Đông Lâm tinh có Hướng gia hay không nhưng Tôn Thái không biết. Tôn Thái tặng túi trữ vật chứa tiên ngọc và tâm đắc luyện đan luyện khí để tạ ơn."},{"chuong":"@c0625","importance":"major","tieuDe":"Đối thoại Tôn Thái luân lạc","text":"Vương Lâm gặp lại Tôn Thái — vị Đại trưởng lão Thi Âm Tông năm xưa ở Chu Tước tinh, nay tu vi tụt xuống Hóa Thần kỳ, luân lạc làm khách khanh Nhiễm gia. Khi Tôn Thái dò hỏi tu vi, Vương Lâm bình thản đáp “Vấn Đỉnh”, khiến Tôn Thái cười khổ không tin và hiểu ra vì sao Lão tổ Nhiễm gia chịu đưa bát phẩm đan dược cho hắn."},{"chuong":"@c0625","importance":"bridge","tieuDe":"Hỏi về Đông Lâm tinh và Hướng gia","text":"Vương Lâm hỏi Đông Lâm tinh có Hướng gia hay không; Tôn Thái nghĩ kỹ rồi lắc đầu nói theo hiểu biết của hắn thì không có. Hắn cũng tiếp nhận tin về cấu trúc Thi Âm Tông, Tứ Thánh tông và việc bản thân có thể tính là đệ tử bên ngoài Tứ Thánh tông qua xuất thân Chu Tước tinh."},{"text":"Sau khi Tôn Thái rời đi, Vương Lâm dịch chuyển tới cánh đồng hoang cách thành Tôn gia hơn mười vạn dặm, rải gần ba mươi vạn khối tiên ngọc lập một trận pháp lớn trong phạm vi mười dặm (trận không tên, chế từ thức thứ ba của Đạo Hóa Hoàng Tuyền). Hắn hô “Vỡ!” khiến toàn bộ tiên ngọc tự nổ, bùng lên cơn lốc tiên lực khổng lồ; rồi hô “Hút!”, há mồm nuốt trọn cơn lốc, nguyên thần như hắc động cắn nuốt tiên lực, đột phá tới Vấn Đỉnh trung kỳ. Hắn cố ý phô diễn uy lực như lời cảnh cáo, thần thức trải khắp tinh cầu rồi dùng Đại Na Di rời đi.","bridge":true,"khoang":"@c0626","importance":"major"},{"chuong":"@c0626","importance":"bridge","tieuDe":"Cảm ngộ nhân quả sinh tử","text":"Vương Lâm nhắm mắt nối tiếp ý cảnh sinh tử luân hồi, lĩnh ngộ nhân quả là căn nguyên của sinh và tử — hôm qua nhân hôm nay quả, sinh tử chỉ là một biến hóa của nhân quả; trong mắt lóe tia hiểu ra nhưng vẫn mơ hồ “nhìn được mà sờ không tới”."},{"chuong":"@c0626","importance":"normal","tieuDe":"Tôn Thái buông bỏ tặng quà","text":"Tôn Thái tới gặp, tặng túi trữ vật chứa hơn năm vạn tiên ngọc, buông bỏ việc khôi phục tu vi cùng oán hận mấy trăm năm, chỉ xin Vương Lâm đưa hắn về quê nhà dưới chân Thiên Sơn rồi tập tễnh rời đi trong ánh chiều tà."},{"text":"Dưới danh “Hứa mỗ”, Vương Lâm bước ra hư không cho con rối Tiên vệ đánh tan Chưởng Tâm Lôi rồi huých trọng thương lão tổ Nhiễm gia. Hắn buộc lão tổ Nhiễm gia giao chín phần tiên ngọc, ép Tôn Tích nộp bảy phần và Tiêu Dao tán nhân (Triệu mỗ) nộp chín phần cùng đan dược, túi trữ vật và di vật người Huyễn gia chết bốn năm trước, lấy việc che chở chuyện cũ làm cớ. Sau khi thu vật phẩm, hắn biến mất, để lại lời nếu người Huyễn gia tới sẽ tự ra tay.","bridge":true,"khoang":"@c0627","importance":"bridge"},{"chuong":"@c0627","importance":"major","tieuDe":"Cảm ngộ Sinh Tử Luân Hồi dung hợp nguyên thần","text":"Vương Lâm dùng Na Di về Tôn gia thành, đi bộ trên phố suy tư. Ý cảnh Sinh Tử Luân Hồi nay đã dung hợp làm một với nguyên thần, nguyên thần chính là sự cảm ngộ về sinh tử. Hắn ngẫm phía trước sinh tử là đạo nhân quả quá lớn, đã nắm được “tử” qua Đạo Hóa Hoàng Tuyền lúc Vấn Đỉnh nhưng còn truy tìm đạo “sinh”."},{"chuong":"@c0627","importance":"bridge","tieuDe":"Áp chế lão tổ Nhiễm gia, ép nộp tiên ngọc","text":"Dưới danh Hứa mỗ, Vương Lâm bước ra hư không, con rối Tiên vệ đánh tan Chưởng Tâm Lôi rồi huých trọng thương lão tổ Nhiễm gia. Hắn trách lão tổ kéo Hứa mỗ vào chuyện bốn năm trước, ra điều kiện che chở: ép lão tổ Nhiễm gia chín phần tiên ngọc, Tôn Tích bảy phần, Tiêu Dao tán nhân chín phần cùng đan dược, túi trữ vật và toàn bộ di vật người Huyễn gia chết bốn năm trước. Thu đủ vật phẩm rồi biến mất, để lại lời nếu người Huyễn gia tới hắn sẽ tự ra tay."},{"chuong":"@c0627","importance":"major","tieuDe":"Cảm ngộ đạo Sinh Tử Luân Hồi","text":"Dùng Na Di về Tôn gia thành, đi bộ trên phố suy tư ý cảnh. Ý cảnh sinh tử luân hồi đã dung hợp làm một với nguyên thần, nguyên thần nay chính là cảm ngộ Sinh Tử Luân Hồi. Hắn ngẫm rằng phía trước sinh tử là nhân quả, đã nắm được mặt “tử” qua Đạo Hóa Hoàng Tuyền lúc Vấn Đỉnh, nhưng đạo của “sinh” thì còn chưa rõ ở nơi nào."},{"text":"Tại Nhiễm Vân tinh, Vương Lâm kiểm tra di vật người Huyễn gia do ba lão tổ Nhiễm gia đưa: cây lược đen, đôi đá lửa tử kim, lệnh bài, ngọc giản. Nhờ trí nhớ Cổ Thần Đồ Ti, hắn nhận ra đôi đá lửa là pháp bảo thiên nhiên hình thành — tài liệu luyện khí sinh kim hỏa. Đọc ngọc giản, hắn phát hiện công pháp Thiên Huyễn Vô Tình đạo của Huyễn gia và tin tức mỏ quáng Kim Viêm ở Vân Hà tinh, liền quyết đoạt mỏ để lấp đầy tính kim loại còn thiếu của hạt châu Thiên Nghịch.","bridge":true,"khoang":"@c0628","importance":"normal"},{"chuong":"@c0628","importance":"bridge","tieuDe":"Lệnh Tôn Tích lấy tinh đồ","text":"Không biết Vân Hà tinh ở đâu, Vương Lâm buông thần thức quét toàn bộ Nhiễm Vân tinh, truyền âm tới Tôn Tích đang thổ nạp trong tổ trạch Tôn gia, ra lệnh khắc toàn bộ tinh đồ La Thiên tinh vực vào ngọc giản đưa tới. Hắn nổi sát khí, kẻ nào tranh đoạt mỏ Kim Viêm thì giết."},{"chuong":"@c0628","importance":"major","tieuDe":"Giải mã di vật người Huyễn gia","text":"Trở về phía bắc thành Nhiễm Vân tinh, Vương Lâm gặp lại người tu sĩ trẻ và khích lệ y giữ tâm cảnh thiện lương để đạt Hóa Thần. Về phòng, hắn lần lượt kiểm tra di vật người Huyễn gia mà ba lão tổ Nhiễm gia đưa cho: cây lược đen, đôi đá đánh lửa tử kim, lệnh bài thân phận và ngọc giản. Nhờ trí nhớ Cổ Thần Đồ Ti, hắn nhận ra đôi đá lửa là pháp bảo thiên nhiên hình thành, một loại tài liệu luyện khí sinh kim hỏa."},{"chuong":"@c0628","importance":"normal","tieuDe":"Phát hiện mỏ Kim Viêm ở Vân Hà tinh","text":"Vương Lâm dùng Tiên Vệ soi lệnh bài, nhìn ra trong đó cài thần thông nhỏ liên quan mệnh hồn báo cho Huyễn gia biết chủ nhân đã chết. Hắn cho thần thức dung nhập ngọc giản, đánh nát đạo sóng đưa tin sắp tràn ra, đọc được công pháp Thiên Huyễn Vô Tình đạo (phá cấm chế bằng huyết mạch) cùng tin tức về mỏ quáng Kim Viêm ở Vân Hà tinh. Hắn định đoạt mỏ Kim Viêm để lấp đầy tính kim loại còn thiếu của hạt châu Thiên Nghịch, nổi sát khí với kẻ tranh đoạt, rồi truyền âm lệnh Tôn Tích khắc tinh đồ La Thiên tinh vực vào ngọc giản đưa tới."},{"text":"Dưới giả danh Hứa Mộc, Vương Lâm nghiên cứu mười ngày ngọc giản tinh đồ của Tôn Tích, xác định Vân Hà tinh — tinh cầu độc bỏ đi không có tu sĩ — làm đích đến, rồi sửa sang pháp bảo chuẩn bị lên đường. Khi rời đi bị lão tổ Nhiễm gia, Tiêu Dao tán nhân và Tôn Tích chặn đường tra hỏi vì ngờ hắn ôm của cải bỏ trốn; hắn lạnh lùng khẳng định giữ lời.","bridge":true,"khoang":"@c0629","importance":"bridge"},{"chuong":"@c0629","importance":"major","tieuDe":"Trọng thương Huyễn Đông bằng Tịch Diệt chỉ","text":"Khi Huyễn Đông của Huyễn gia giáng lâm Nhiễm Vân tinh đòi diệt người tham dự, Vương Lâm “cầm tiền của người, thay người trừ tai họa” ra tay: thần thức hóa sấm kết thành chữ Cút, rồi phóng Tịch Diệt chỉ nhuốm điện quang đậm đặc phá vỡ kim kiếm, đánh Huyễn Đông phun máu, điện quang quỷ dị hành hạ nguyên thần khiến hắn phải bỏ chạy về bẩm báo. Lúc này tu vi vẫn Vấn Đỉnh sơ kỳ nhưng tiên lực đã cực gần Vấn Đỉnh trung kỳ, chỉ cần cảm ngộ ý cảnh là đột phá."},{"chuong":"@c0629","importance":"major","tieuDe":"Định rời Nhiễm Vân tinh đi Vân Hà tinh","text":"Sau mười ngày nghiên cứu kỹ ngọc giản tinh đồ của Tôn Tích, Vương Lâm (mang danh Hứa Mộc) xác định đích đến là Vân Hà tinh — tinh cầu bỏ đi tràn ngập khói độc, cách nơi này mấy tháng đường. Hắn sửa sang lại pháp bảo rồi rời phòng, giẫm chân biến mất xuất hiện trên tầng cương phong hướng chân trời."},{"chuong":"@c0629","importance":"major","tieuDe":"Đánh trọng thương Huyễn Đông","text":"Bị ba người Nhiễm gia chặn hỏi việc rời đi, Vương Lâm khẳng định giữ lời. Khi Huyễn Đông của Huyễn gia giáng lâm đòi giết người tham dự, hắn nhận tiền trừ tai họa: hóa thần thức thành chữ Cút rồi xuất Tịch Diệt chỉ nhuốm điện quang đậm đặc, đánh vỡ kim kiếm, trọng thương Huyễn Đông khiến hắn phun máu bỏ chạy."},{"text":"Dưới thân phận Hứa Mộc, Vương Lâm dùng Thất Tinh kiếm trận và tà hồn Thất Sanh Tiếu kéo Huyễn Đông ra khỏi hư vô, áp sát khống chế nguyên thần. Hắn giao Huyễn Đông cho ba lão tổ Nhiễm gia rồi đột ngột dùng Sưu hồn thuật moi trí nhớ, phát hiện Huyễn Mi — con gái nuôi kiêm đệ tử duy nhất của Lão tổ Huyễn gia — chính là Liễu Mi, kẻ có cừu hận với hắn từ Chu Tước tinh. Hắn bóp chết Huyễn Đông, thu nguyên thần vào Tôn hồn phiên.","bridge":true,"khoang":"@c0630","importance":"major"},{"chuong":"@c0630","importance":"bridge","tieuDe":"Rời đi tới Vân Hà tinh","text":"Tự lượng không liều chết với Lão tổ Huyễn gia (cảnh giới Âm Dương Hư Thực, có Tiên Vệ), Vương Lâm rời tầng cương phong, dùng Tinh la bàn hóa rồng bạc bay vào tinh không, theo tinh đồ đi thẳng tới Vân Hà tinh lấy mỏ quặng Kim Viêm để hạt châu Thiên Nghịch trở nên toàn vẹn, thề giết kẻ nào tranh đoạt. Một tháng sau Vân Hà tinh hiện trong thần thức hắn."},{"chuong":"@c0630","importance":"major","tieuDe":"Sưu hồn phát hiện Liễu Mi","text":"Tuyên bố giao Huyễn Đông cho ba lão tổ Nhiễm gia rồi đột ngột dùng Sưu hồn thuật (mượn lực Tiên Vệ) moi trí nhớ Huyễn Đông. Trong ký ức vỡ vụn, hắn nhận ra Huyễn Mi — con gái nuôi của Lão tổ Huyễn gia — chính là Liễu Mi, người từng có cừu hận với hắn ở Chu Tước tinh; hắn bóp chết Huyễn Đông, thu nguyên thần vào Tôn hồn phiên."},{"chuong":"@c0630","importance":"bridge","tieuDe":"Hướng tới Vân Hà tinh","text":"Lượng sức không liều chết với Lão tổ Huyễn gia (cảnh giới Âm Dương Hư Thực, có Tiên Vệ), Vương Lâm dùng Tinh la bàn hóa rồng bạc bay vào tinh không, theo tinh đồ đi thẳng tới Vân Hà tinh lấy mỏ quặng Kim Viêm — cơ hội khiến hạt châu Thiên Nghịch toàn vẹn; một tháng sau Vân Hà tinh hiện trong thần thức hắn."},{"text":"Vương Lâm cưỡi rồng bạc tới Vân Hà tinh — tu chân tinh cầu hoang phế phủ sương mù dày, thần thức không vào được. Hắn dùng Thất Tinh kiếm trận tạo kình khí xoắn ốc như mũi dùi xuyên sương mù, thu Tinh la bàn rồi xâm nhập, vào trong là vùng đất tử khí đậm đặc đầy xúc tu hư thối và thành trì hoang tàn.","bridge":true,"khoang":"@c0631","importance":"bridge"},{"chuong":"@c0631","importance":"normal","tieuDe":"Chạm trán Vọng Nguyệt","text":"Khi tìm mỏ Kim Viêm, Vương Lâm gặp Vọng Nguyệt — mãnh thú nghìn trượng ký sinh trong cơ thể bộ tộc Cổ Thần. Nhờ trí nhớ Cổ Thần Đồ Ti, hắn nhận ra Vọng Nguyệt sức mạnh không kém tu sĩ đại thần thông Khuy Niết và có ba hình dạng, lập tức trầm xuống tránh né, nghi Vân Hà tinh có xác Cổ Thần, rồi dùng thổ độn chui vào vách đá tiếp tục tìm mỏ."},{"chuong":"@c0631","importance":"bridge","tieuDe":"Chạm trán Vọng Nguyệt","text":"Khi bay tìm mỏ, xúc tu trên đất đột nhiên co rút, từ chân trời xuất hiện mây đỏ và một mãnh thú nghìn trượng giống rồng mà không phải rồng. Nhờ trí nhớ Cổ Thần Đồ Ti, hắn nhận ra đó là Vọng Nguyệt — ký sinh hút máu Cổ Thần, lập tức trầm xuống chui vào khe nứt tránh né, nghi nơi đây có xác Cổ Thần. Sau đó dùng thổ độn chui vào vách đá tiếp tục tìm mỏ."},{"text":"Một mình thám sát tầng ngầm Vân Hà tinh, Vương Lâm phát hiện mỏ quáng Kim Viêm kéo dài vô số dặm. Nhờ thói quen thận trọng nhiều năm, hắn không vội thu mỏ mà men theo quan sát, nhận ra sự thật chấn động: cả tinh cầu chính là một con Vọng Nguyệt khổng lồ đang ngủ say, mỏ Kim Viêm là xương cốt của nó. Hành động thu mỏ trực tiếp sẽ kích thích Vọng Nguyệt thức tỉnh giết người tại chỗ.","bridge":true,"khoang":"@c0632","importance":"normal"},{"chuong":"@c0632","importance":"bridge","tieuDe":"Kế lấy xương Vọng Nguyệt","text":"Dựa trí nhớ Cổ Thần Đồ Ti, Vương Lâm hiểu Vọng Nguyệt là loài ký sinh thích hút máu Cổ Thần và chỉ hấp thu vật chất khi có ấn quyết Cổ Thần dẫn dắt — thứ chỉ mình hắn có. Hắn nghĩ ra cách tinh luyện dược vật từ Thăng Tiên Quả khiến Vọng Nguyệt hôn mê trong lúc ngủ say để lấy xương an toàn, rồi điều khiển tinh la bàn rời Vân Hà tinh hướng tới Nhiễm Vân tinh."},{"chuong":"@c0632","importance":"bridge","tieuDe":"Kế lấy xương bằng Thăng Tiên Quả","text":"Dựa trí nhớ Cổ Thần Đồ Ti, hắn hiểu Vọng Nguyệt là loài ký sinh thích hút máu Cổ Thần, xúc tu là khí quan mẫn cảm nhất. Hắn lập kế tinh luyện dược vật từ Thăng Tiên Quả khiến Vọng Nguyệt hôn mê khi ngủ say để lấy xương an toàn — then chốt là chỉ mình hắn có ấn quyết Cổ Thần dẫn dắt Vọng Nguyệt hấp thu vật chất ngoài máu Cổ Thần. Hắn cưỡi tinh la bàn rời Vân Hà tinh, hoãn việc viên mãn Thiên Nghịch, hướng tới Nhiễm Vân tinh."},{"text":"Vì đã thu tiên ngọc của ba lão tổ Nhiễm Vân tinh dưới thân phận Hứa Mộc, Vương Lâm cưỡi tinh la bàn hóa cầu vồng bạc xuyên tinh không trở về. Hắn xuyên qua cấm chế mới, đổi dung mạo, kinh hãi khi thấy tu vi Liễu Mi đã đạt Vấn Đỉnh hậu kỳ đại viên mãn nhờ được Lão tổ Huyễn gia Hoán huyết. Liễu Mi nhận ra ánh mắt lạnh lùng không đổi của hắn, gọi đúng tên, nhắc chuyện năm xưa ở Chu Tước tinh. Hắn phóng Tịch Diệt chỉ phong khai chiến, Liễu Mi tạo quầng sáng pháp quyết đỡ, quầng sáng nứt vô số vết.","bridge":true,"khoang":"@c0633","importance":"major"},{"chuong":"@c0633","importance":"major","tieuDe":"Đụng độ Liễu Mi, khai chiến","text":"Đổi dung mạo đối mặt Liễu Mi, kinh hãi nhận thấy tu vi nàng đã đạt Vấn Đỉnh hậu kỳ đại viên mãn (do Lão tổ Huyễn gia nâng tiên lực). Hắn bảo nàng cứ rời đi nhưng Liễu Mi nhận ra hắn qua ánh mắt lạnh lùng, gọi đúng tên, nhắc chuyện Chu Tước tinh năm xưa và quyết không cho hắn đi. Vương Lâm phóng Tịch Diệt chỉ phong, Liễu Mi bấm pháp quyết tạo quầng sáng đỡ, quầng sáng nứt vô số vết."},{"text":"Bị Liễu Mi đoán đúng tu vi chỉ là Vấn Đỉnh sơ kỳ, Vương Lâm nổi giận triệu Thất Tinh kiếm trận khai chiến. Hắn dùng Đạo hóa Hoàng Tuyền có đạo niệm và điện quang đối kháng Vạn Huyễn Thiên Ma đạo của Liễu Mi, lần lượt chống lại các hình huyễn Hồng Điệp, Chu Như, mẹ hắn, cha hắn, Vương Trác, Độn Thiên và Lý Mộ Uyển hiện ra để công tâm.","bridge":true,"khoang":"@c0634","importance":"bridge"},{"chuong":"@c0634","importance":"major","tieuDe":"Buông bỏ phá Vạn Huyễn Thiên Ma đạo","text":"Vương Lâm nhận thấu pháp môn Vạn Huyễn Thiên Ma đạo gợi nguyên thần chi hỏa đốt cháy thể xác tinh thần, bèn nhắm mắt buông bỏ. Đám huyễn hóa khói tụ thành sương mù trong lòng bàn tay; nhờ nguyên thần ẩn chứa thượng cổ Lôi Long mang lôi uy thiên địa, hắn miễn nhiễm huyễn thuật và bóp nát đoàn sương, khiến Liễu Mi bị thương hiện thân. Khi Liễu Mi thả oán khí hắc mang, hắn thổi tan sương lộ đôi mắt đen chứa oán diễm khiến hắn sững lại."},{"chuong":"@c0634","importance":"major","tieuDe":"Phá Vạn Huyễn Thiên Ma đạo","text":"Bị Liễu Mi truy tận trên Nhiễm Vân tinh, Vương Lâm dùng Thất Tinh kiếm trận và Đạo hóa Hoàng Tuyền có đạo niệm nghênh chiến. Liễu Mi thi triển Vạn Huyễn Thiên Ma đạo lần lượt biến thành Hồng Điệp, Chu Như, mẹ hắn, cha hắn, Vương Trác, Độn Thiên và Lý Mộ Uyển để công tâm. Vương Lâm nhắm mắt buông bỏ, để đám huyễn hóa khói nhập thể; nhờ nguyên thần ẩn chứa thượng cổ Lôi Long có lôi uy thiên địa nên huyễn thuật không lay động được, hắn bóp nát đoàn sương phá huyễn, khiến Liễu Mi bị thương hiện thân."},{"chuong":"@c0634","importance":"bridge","tieuDe":"Đấu khẩu ân oán Chu Tước tinh","text":"Liễu Mi tố Vương Lâm năm xưa trên Chu Tước tinh dùng tàn hồn với ý cảnh ô uế phá thân xử nữ của nàng; Vương Lâm đáp do nàng ra tay trước, tàn hồn ý cảnh chỉ là ngoài ý muốn. Liễu Mi cười độc ác thả ra một đạo sương đen oán khí kinh thiên phủ mười dặm như quỷ cảnh; hắc mang lướt qua Tiên vệ khôi lỗi xông thẳng tới. Vương Lâm kết kiếm chỉ thổi tan sương, lộ ra một đôi mắt đen đục ngầu chỉ chứa oán diễm khiến hắn sững lại."}],"tuViMoc":[{"chuong":"@c0459","canhGioi":"Anh Biến kỳ","text":"Đặt mục tiêu tu luyện đột phá tới Anh Biến trung kỳ để có đủ lực phá vỡ trận pháp khốn địa; chuyên tâm hấp thu tiên ngọc, tiên lực trong cơ thể đạt bão hòa dung nhập thân thể làm lực lượng dự phòng.","importance":"minor"},{"chuong":"@c0461","canhGioi":"Anh Biến trung kỳ","text":"Nhờ lượng lớn tiên ngọc trợ giúp đột phá khi còn bị vây trong thạch lâm, Vương Lâm tiến lên Anh Biến trung kỳ, uy lực Hóa Ma Chỉ nhờ đó tăng mấy lần.","importance":"minor"},{"chuong":"@c0462","canhGioi":"Anh Biến Trung Kỳ","text":"Khi tái xuất phá vây, Vương Lâm đã đột phá lên Anh Biến Trung Kỳ, khiến Triệu Tinh Sát kinh hãi vì hắn vừa thoát vây vừa tăng cảnh giới.","importance":"minor"},{"chuong":"@c0472","canhGioi":"Anh Biến trung kỳ","text":"Lĩnh ngộ Vấn Tâm chỉ cảnh tại Toái Tiên chi địa: khi tâm lạnh lẽo hơn cả vạn vật băng hàn, ý chí bất khuất vờn quanh thân, thần thức từ nguyên thần quét lui hàn khí xâm nhập kinh mạch. Đồng thời lĩnh ngộ Luân hồi đạo chính là đại Vô tình đạo, sau lưng hiện ra Luân hồi Hoạ trục chỉ hai màu đen trắng. Thuộc hệ tu tâm — không phải tu vi chính.","importance":"major"},{"chuong":"@c0473","canhGioi":"Anh Biến kỳ","importance":"major","text":"Ý cảnh nhập thể: trên nền hai mươi bước, Vương Lâm dung một tia cảm ngộ vào tâm cảnh, bước thêm năm bước đạt cực hạn hai mươi bảy bước, mở ra con đường lên Vấn Đỉnh. Sinh Tử Luân Hồi đạo của hắn là loại lĩnh ngộ cực hiếm khó thực chất hóa nhất; nhờ kết hợp Vấn Tâm chi đạo tại Toái Tiên chi địa mới khai thông. Bước thứ hai mươi tám nếu bước ra sẽ khiến tu vi sụp đổ, nguyên thần tiêu tan."},{"chuong":"@c0483","canhGioi":"Anh Biến","text":"Tu vi xác nhận đã đạt Anh Biến trung kỳ; nhờ vậy không còn ngại đối kháng trực tiếp nguyên thần ly thể dung trong bản mạng pháp khí như thuở chưa có Côn Cực tiên.","importance":"minor"},{"chuong":"@c0498","canhGioi":"Anh Biến trung kỳ","text":"Được La mỗ xác nhận tu vi mới Anh Biến trung kỳ; dù vậy hắn từng đấu mười một trận với tu sĩ Vấn Đỉnh, lực công hùng mạnh khiến nhiều thế lực chú ý.","importance":"minor"},{"chuong":"@c0500","canhGioi":"Anh Biến trung kỳ","text":"Đang ở Anh Biến trung kỳ, kém đối thủ Anh Biến hậu kỳ đại viên mãn một bậc, nhưng nhờ Thiên Quỷ hấp thu tiên lực của địch và thủ đoạn áp chế mà giành thế thượng phong.","importance":"minor"},{"chuong":"@c0507","canhGioi":"Anh Biến hậu kỳ (yêu tinh ba mươi bốn giáp)","text":"Sau hai năm hấp thu yêu lực ở Yêu Linh chi địa, nâng yêu tinh từ năm giáp lên ba mươi bốn giáp; tiên ngọc gần đủ Anh Biến hậu kỳ, mở ra con đường dùng yêu lực thay tiên ngọc để hướng tới Vấn Đỉnh.","importance":"major"},{"chuong":"@c0517","canhGioi":"Anh Biến kỳ","importance":"minor","text":"Sau mấy tháng thổ nạp luyện hóa yêu lực dung nhập tiên lực, tiến tới Anh Biến hậu kỳ."},{"chuong":"@c0518","canhGioi":"Anh Biến trung kỳ","text":"Tu vi đang ở Anh Biến trung kỳ; hấp thu yêu lực gần ngàn giáp yêu tinh để dồn sức đột phá Anh Biến hậu kỳ, dự tính lên đại viên mãn rồi dẫn yêu binh ra ngoài huyết tẩy tu sĩ thu tiên ngọc, tiến tới Vấn Đỉnh.","importance":"minor"},{"chuong":"@c0525","canhGioi":"Anh Biến hậu kỳ","text":"Sau khi uống một giọt mỹ tửu và ngủ say một năm, tiên lực tăng vọt vượt xa mức Anh Biến hậu kỳ đại viên mãn; Yêu Tinh trong đan điền vỡ vụn, yêu lực bị thôn phệ hòa làm một bộ phận của tiên lực. Tu vi đã không còn đối thủ trong Anh Biến kỳ, chỉ chờ cảm ngộ ý cảnh là đủ sức tiến lên Vấn Đỉnh.","importance":"major"},{"chuong":"@c0526","canhGioi":"Anh Biến","text":"Tu vi nâng lên Anh Biến hậu kỳ đại viên mãn, đã thuộc hàng đỉnh trong Anh Biến kỳ; tốc độ nhảy vọt nhanh hơn sấm chớp.","importance":"minor"},{"chuong":"@c0536","canhGioi":"Anh Biến kỳ","text":"Tu luyện Sát lục tiên quyết trong Hồng lao, ngộ được sát lục chi tâm và liên hệ với ý cảnh sinh tử luân hồi — thuộc hệ thần thông sát đạo, không phải bước đột phá tu vi chính.","importance":"normal"},{"chuong":"@c0551","canhGioi":"Anh Biến kỳ","text":"Dồn toàn bộ bi niệm, tạp niệm và bi thương đời người vào một kích cuối, vượt qua Anh Biến kỳ; đạo tâm viên mãn mở ra con đường tu hành nghịch thiên.","importance":"major"},{"chuong":"@c0553","canhGioi":"Vấn Đỉnh","text":"Bước vào kiếp hồng lôi thiên kiếp tại Thiên Yêu Thành; sau khi phá đạo lôi kiếp đầu, hồng vân ngưng tụ và thiên uy giáng lâm báo hiệu kiếp nạn lớn hơn còn tiếp diễn. Thuộc tiến trình độ kiếp, không phải đột phá cảnh giới thường.","importance":"minor"},{"chuong":"@c0555","canhGioi":"Vấn Đỉnh kỳ","text":"Tiến lên Vấn Đỉnh: dung hợp tiên lực và Ý Cảnh Sinh Tử Luân Hồi thành Vấn Đỉnh Chi Tinh — trái tim nguyên thần. Suýt thất bại do nguyên khí không kết tinh, được Vấn Đỉnh Chi Tinh của Chu Dật tan vỡ tiếp sức. Sau khi thành, kén nguyên thần co lại bao lấy hai Vấn Đỉnh Chi Tinh, sinh khí tức mới.","importance":"major"},{"chuong":"@c0556","canhGioi":"Vấn Đỉnh","text":"Xuất kén nguyên thần, đột phá lên Vấn Đỉnh sơ kỳ sau bảy trăm năm tu đạo; nguyên thần hóa thực chất mang Vấn Đỉnh Chi Tinh, cần bốn mươi chín ngày củng cố nguyên khí.","importance":"major"},{"chuong":"@c0557","canhGioi":"Vấn Đỉnh","text":"Lần đầu thi triển Tịch Diệt Chỉ và Hoàng Tuyền Chỉ dưới thực lực Vấn Đỉnh; hắc quang Tịch Diệt Chỉ mạnh gấp mười lần trước. Nguyên thần Vấn Đỉnh vừa hình thành còn cần thời gian kết hợp, dễ bị Thiên Ma Phong cướp đi.","importance":"minor"},{"chuong":"@c0562","canhGioi":"Vấn Đỉnh kỳ","text":"Vương Lâm nhận ra nguyên thần vẫn chưa dung hợp hoàn toàn với thân thể; cần thêm nửa tháng nữa mới đạt cảnh giới Nguyên Nhục Quy Nhất, khi đó mới thật sự củng cố được Vấn Đỉnh kỳ.","importance":"minor"},{"chuong":"@c0567","canhGioi":"Hướng tới Vấn Đỉnh","text":"Vương Lâm nhắm tới việc luyện Nguyên thần thứ hai — thần thông độc đáo chỉ thể hiện sau khi đạt cảnh giới Vấn Đỉnh, mấu chốt nằm ở phôi thể Nguyên thần thứ hai. Hắn dự định dùng Tán ma khổng lồ ở Long Đàm làm phôi thể.","importance":"major"},{"chuong":"@c0589","canhGioi":"Vấn Đỉnh sơ kỳ","text":"Tu vi của Vương Lâm đã ổn định ở Vấn Đỉnh sơ kỳ, dáng vẻ đã bước ra một bước chứ không giống vừa mới đạt được, khiến Đỗ Kiến kinh ngạc về tốc độ tu vi.","importance":"minor"},{"chuong":"@c0626","canhGioi":"Vấn Đỉnh trung kỳ","text":"Nhờ trận pháp hấp thu gần ba mươi vạn tiên ngọc, nuốt trọn cơn lốc tiên lực qua Đạo Hóa Hoàng Tuyền, Vương Lâm đột phá lên Vấn Đỉnh trung kỳ. Để tiến xa hơn cần cảm ngộ ý cảnh — điều không thể gấp, có thể một giây hoặc trăm năm.","importance":"major"},{"chuong":"@c0629","canhGioi":"Vấn Đỉnh sơ kỳ","importance":"minor","text":"Tu vi vẫn ở Vấn Đỉnh sơ kỳ nhưng tiên lực đã cực kỳ gần Vấn Đỉnh trung kỳ, chỉ cần cảm ngộ ý cảnh là có thể đột phá; pháp thuật thần thông đủ sức đánh thắng tu sĩ Vấn Đỉnh trung kỳ, giết Huyễn Đông dễ như trở bàn tay."},{"chuong":"@c0610","canhGioi":"Vấn Đỉnh","text":"Sau khi đạt Vấn Đỉnh — đỉnh cao đầu tiên của tu đạo mà rất ít người trong Tinh Không đạt tới — tu vi Vương Lâm tăng chậm dần. Ba cửa ải Vấn Đỉnh Trung Kỳ, Hậu Kỳ, đại viên mãn được ví như ba ngọn núi lớn chắn đường.","importance":"minor"}],"tuVi":"","nhanMach":[{"ten":"Trương Hướng Phàm","tag":"dong-minh","quanHe":"Đệ tử mở khóa trận pháp Phẩm Linh Các, cung kính dẫn Vương Lâm vào lấy tiên ngọc","ghiChu":"@c0458"},{"ten":"Tư Mã Như Phong","tag":"doi-thu","quanHe":"Đệ tử hàng thứ hai Lam tông, tham gia vây kích Vương Lâm","ghiChu":"@c0458"},{"ten":"Tứ sư tỷ (Tử hệ)","tag":"doi-thu","quanHe":"Đồng hệ Tử nhưng được người nhờ vả nên ra tay vây kích","ghiChu":"@c0458"},{"ten":"Người y phục xanh (như tượng băng)","tag":"doi-thu","quanHe":"Sư huynh ẩn mình nửa bước vấn đỉnh, coi Vương Lâm không xứng ra tay","ghiChu":"@c0458"},{"ten":"Thủy tổ đại nhân (Thiên Vận Tông)","tag":"su-mon","quanHe":"Thủy tổ tông môn, từng dặn chỉ cần không phạm môn quy thì khỏi quản Vương Lâm","ghiChu":"@c0458"},{"ten":"Tứ sư tỷ (Tử hệ)","tag":"su-mon","quanHe":"Sư tỷ đồng môn","ghiChu":"Trực tiếp na di Vương Lâm tới khốn địa, hẹn ba năm thả ra; từng hứa truyền thần thông na di cho hắn sau khi mọi chuyện giải quyết."},{"ten":"Đại sư huynh (Thiên Vận Tông)","tag":"doi-thu","quanHe":"Sư huynh đồng môn","ghiChu":"Người bố trí trận pháp thạch lâm vây khốn Vương Lâm."},{"ten":"Tào Nhất Đấu","tag":"dong-minh","quanHe":"Nguyên thần bị Vương Lâm thu nhận làm người dẫn đường","ghiChu":"Vương Lâm hứa cho một thân thể anh biến để đổi lấy việc dẫn đường về Thiên Vận Tông."},{"ten":"Triệu Tinh Sát","tag":"doi-thu","quanHe":"Đại sư huynh Tử hệ nhất mạch đứng sau việc na di vây khốn Vương Lâm","ghiChu":"Vương Lâm trở về quyết báo thù sự chèn ép của Triệu Tinh Sát và Tử hệ nhất mạch."},{"ten":"Hứa Lập Quốc","tag":"doi-thu","quanHe":"Kẻ thù bị Vương Lâm truy sát giữa thọ yến, đánh trọng thương nguyên thần","ghiChu":"Nhị sư huynh Tử hệ Thiên Vận Tông"},{"ten":"Triệu Tinh Sát","tag":"doi-thu","quanHe":"Cản Vương Lâm bằng Đại tự tại thiên địa quyết nhưng bị ma hỏa tự bạo phá vỡ","ghiChu":""},{"ten":"Bạch Vi","tag":"khac","quanHe":"Đệ tử Tử hệ, mỉm cười kỳ dị khi thấy Vương Lâm trở lại nhưng không ra tay","ghiChu":""},{"ten":"Triệu Tinh Sát","tag":"doi-thu","quanHe":"Đối thủ tranh danh hiệu Thiên Vận Thất Tử","ghiChu":"Bị Vương Lâm uy hiếp, đáp trả bằng thuật triệu Cổ Yêu nhưng bị phản phệ."},{"ten":"Xích Liệt","tag":"su-mon","quanHe":"Sư thúc trong Thiên Vận Tông","ghiChu":"Xuất hiện quát đuổi cổ yêu, vô tình cứu Hồn Thú của Vương Lâm."},{"ten":"Xích Liệt","tag":"su-mon","quanHe":"Tiền bối Thiên Vận Tông cùng tông, sư đệ của sư tôn","ghiChu":"Tiết lộ sư phụ kỳ vọng cao ở Vương Lâm và đại sư huynh sẽ không tranh danh hiệu Thiên Vận Thất Tử."},{"ten":"Tư Mã Như Phong","tag":"doi-thu","quanHe":"Đệ tử hàng thứ ba Lam Tông cùng Thiên Vận Tông","ghiChu":"Anh Biến đại viên mãn, gần Vấn Đỉnh; được Vương Lâm nhận ra trong lễ giảng đạo."},{"ten":"Tôn trưởng lão","tag":"khac","quanHe":"Cao thủ tu chân liên minh giáng lâm thọ yến","ghiChu":"Tiểu điêu ba mắt của Tôn trưởng lão đậu vai dò xét riêng Vương Lâm; hắn thấy quen quen."},{"ten":"Côn Bằng Tử","tag":"khac","quanHe":"Đầu lĩnh Hoàng Hệ cùng dự thọ yến","ghiChu":"Được Thiên Vận Tử tặng lại phi kiếm trung phẩm tiên khí."},{"ten":"Lăng Thiên Hầu","tag":"doi-thu","quanHe":"Kiếm Tôn Đại La Kiếm Tông","ghiChu":"Vương Lâm nhận ra thanh xà hình bảo kiếm của Lăng Thiên Hầu là Vũ chi đệ nhị kiếm bị hắn cướp ở Tiên giới năm xưa, gợi mở ân oán liên quan các thanh Vũ chi kiếm."},{"ten":"Triệu Hân Mộng","tag":"doi-thu","quanHe":"Tứ sư tỷ đồng môn","ghiChu":"Khiêu chiến Vương Lâm trong cuộc tranh phong hiệu; mô phỏng Hoá Ma chỉ của hắn để sáng chế Tử Ma thủ."},{"ten":"Vận Đường","tag":"khac","quanHe":"Đại sư huynh Hoàng hệ đồng môn","ghiChu":"Vương Lâm phát hiện biểu hiện quỷ dị: mắt Vận Đường co rút khi tinh thể vàng xuất hiện, ánh mắt thoáng sợ hãi rồi mỉm cười với hắn."},{"ten":"Trần Đào","tag":"doi-thu","quanHe":"Tử hệ Lão Lục giành phong hiệu","ghiChu":"Trần Đào khinh thường Vương Lâm, hai bên giao chiến tranh phong hiệu Thiên Vận Thất tử."},{"ten":"Triệu Hân Mộng","tag":"doi-thu","quanHe":"Tứ sư tỷ Tử hệ","ghiChu":"Gài bẫy hấp thu ma lực thất bại, thừa nhận xem thường Vương Lâm rồi bỏ cuộc."},{"ten":"Trần Đào","tag":"doi-thu","quanHe":"Đối thủ tại lễ chúc thọ","ghiChu":"Trần Đào tự xưng sư huynh, Vương Lâm phủ nhận tư cách đó của hắn; hai người giao chiến."},{"ten":"Lão già mặt đỏ","tag":"khac","quanHe":"Khách chúc thọ nhận ra sát chiêu","ghiChu":"Lão già mặt đỏ thấy Hoàng tuyền chỉ của Vương Lâm giống hệt sát chiêu của một “người điên” lão từng gặp."},{"ten":"Trần Đào","tag":"doi-thu","quanHe":"Sư huynh đệ Tử hệ kiêm đối thủ","ghiChu":"Thắng Vương Lâm đoạt phong hiệu Thiên Vận Thất tử, hẹn tái chiến sau khi Vương Lâm đạt Vấn Đỉnh."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư phụ","ghiChu":"Nhận Vương Lâm làm đệ tử chân chính, hứa truyền Cấm pháp thần thông và pháp bảo bản mạng, sắp đặt khảo nghiệm Toái Tiên chi địa."},{"ten":"Lăng Thiên Hầu","tag":"khac","quanHe":"Kiếm Tôn quen biết qua đại thọ","ghiChu":"Có ước hẹn với Thiên Vận Tử về Đông Hải Yêu Linh chi môn ba tháng sau."},{"ten":"Thiên Vận Tử áo xám","tag":"khac","quanHe":"Nhân vật bí ẩn ‘hơn một người’ trong thế giới bảy màu, nắm Sát Lục Tiên quyết, mời truyền nhưng Vương Lâm từ chối; vẫn để lại ngọc giản","ghiChu":"@c0474"},{"ten":"Hứa Vân Sơn","tag":"dong-minh","quanHe":"Thiếu Tông Huyền Uyên Phái chủ động ra đón và kết giao, đưa Vương Lâm tới Linh Nhạc quốc","ghiChu":"Cùng tu vi Anh Biến Trung kỳ"},{"ten":"Triệu Tứ","tag":"khac","quanHe":"Tu sĩ vận hành Truyền tống trận đưa Vương Lâm tới Địa Tinh, kính gọi hắn là Thất sư tổ"},{"ten":"Thiên Thai lão nhân","tag":"khac","quanHe":"Cao thủ đệ nhất Linh Nhạc quốc; từng đến Thông Thiên tháp thăm dò Vương Lâm rồi khiếp sợ, cuối chương Vương Lâm tìm đến tại Ngũ Linh Sơn","ghiChu":"@c0477"},{"ten":"Hứa Vân Sơn","tag":"dong-minh","quanHe":"Đưa Vương Lâm đến nhậm chức Sứ giả, gọi là Vương huynh, hẹn ngày sau cùng uống rượu","ghiChu":"@c0477"},{"ten":"Thiên Thai lão nhân","tag":"dong-minh","quanHe":"Tu sĩ Anh Biến kỳ phục vụ, trao ngọc giản ba chỗ yêu thú","ghiChu":"Gọi Vương Lâm là Sứ giả đại nhân"},{"ten":"Văn thú","tag":"khac","quanHe":"Vật nuôi","ghiChu":"Yêu thú đến từ tinh không, Vương Lâm nuôi lớn bằng cách thả hấp thu yêu thú Hóa Thần trở lên; đang ở thời khắc sắp tiến hóa."},{"ten":"Thiên Cầm cô nương","tag":"khac","quanHe":"Cùng hướng tới Diệu Kim quả","ghiChu":"Vương Lâm âm thầm theo dõi đoàn của nàng (bị Đại La Kiếm Tông ép dẫn đường)."},{"ten":"Thạch Phương","tag":"doi-thu","quanHe":"Đối thủ bị Vương Lâm đánh tan nguyên thần, nuốt thân xác và cuối cùng giết chết dù đã đoạt xá Quách Tà Dật.","ghiChu":"@c0483"},{"ten":"Thiên Cầm cô nương","tag":"khac","quanHe":"Nữ tử tiểu bối quỳ cầu Vương Lâm giết Thạch Phương cùng Trưởng lão Đại La Kiếm Tông, nguyện làm trâu ngựa hầu hạ.","ghiChu":"@c0483"},{"ten":"Thiên Cầm cô nương","tag":"an-nhan","quanHe":"Tặng Thiên Cầm sợi kim linh căn cuối cùng coi như đền bù cơ duyên đã chiếm.","ghiChu":"@c0484"},{"ten":"Lão già thấp người (Trưởng lão Đại La Kiếm Tông)","tag":"doi-thu","quanHe":"Tù nhân khai bí mật rồi bị giết","ghiChu":"Bắt giam tra hỏi về Kiếm Tôn và Đông Hải Yêu Linh chi môn, sau đó xử tử bằng loan đao và khí xám Sát lục tiên quyết."},{"ten":"Kiếm Tôn","tag":"khac","quanHe":"Mục tiêu liên quan chuyến đi","ghiChu":"Kẻ phong ấn Chu Dật và 1/3 kiếm hồn trong Đông Hải Yêu Linh chi môn — nơi Vương Lâm sắp tới."},{"ten":"Tôn Vân Sơn","tag":"dong-minh","quanHe":"Bạn đồng hành cùng đi Đông Hải Yêu Linh","ghiChu":"Tôn Vân Sơn cố đợi để cùng đi cho có bạn"},{"ten":"Tôn Nhược Nam","tag":"khac","quanHe":"Muội của Tôn Vân Sơn, lén bám theo hắn","ghiChu":"Nhìn Vương Lâm thoáng lóe kinh ngạc"},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Kẻ truy tìm sợi tơ Thiên Kiếp và tìm Vương Lâm","ghiChu":"Xuất hiện ngay tại nơi Vương Lâm đang đến"},{"ten":"Trần Đào","tag":"doi-thu","quanHe":"Đồng môn Tử hệ Thiên Vận Tông","ghiChu":"Lão lục từng tranh phong hào Thiên Vận Thất Tử; nhìn Vương Lâm với ánh mắt kỳ dị khi hắn tới cửa Đông Hải."},{"ten":"Tôn Vân Sơn","tag":"dong-hanh","quanHe":"Đồng hành tới Đông Hải","ghiChu":"Tách ra trước cửa, nhờ Vương Lâm chiếu cố, hẹn gặp lại trong Đông Hải Yêu Linh."},{"ten":"Diêu Tích Tuyết","tag":"khac","quanHe":"Người được phụ thân dặn theo dõi Vương Lâm","ghiChu":"Thấy ánh mắt yêu dị mang khí xám của hắn sau khi dùng thần thông liền chấn động, hiểu vì sao phụ thân bảo nàng phải chú ý đến hắn (@c0490)."},{"ten":"Tôn Vân Sơn","tag":"dong-minh","quanHe":"Người báo cho Vương Lâm rằng hành trình Đông Hải kéo dài năm trăm năm","ghiChu":"@c0491"},{"ten":"Người xích lõa vẽ nhựa cây (thợ săn)","tag":"khac","quanHe":"Người chủng tộc lạ Vương Lâm gặp đầu tiên trong sơn cốc","ghiChu":"Vương Lâm nhường con thú, sau đó giam giữ để tra hỏi nguồn gốc nơi này."},{"ten":"Âu Dương Hoa","tag":"doi-thu","quanHe":"Trưởng lão bộ tộc sơn cốc, đối đầu qua trận pháp","ghiChu":"Khuyên Vương Lâm rời đi tới Cổ yêu thành rồi điều khiển trận pháp phản kích."},{"ten":"Âu Dương Hoa","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Âu Dương Hoa vây Vương Lâm bằng trận pháp thượng cổ, chiêu hàng tàn nhẫn rồi cầu tha khi bị phá trận."},{"ten":"Âu Dương Hoa","tag":"khac","quanHe":"Trưởng lão tộc nhân sơn cốc thần phục, mời vào cốc và kể về Hoàng Long cùng đêm yêu linh","ghiChu":""},{"ten":"Hoàng Long","tag":"khac","quanHe":"Người trong bức tranh cổ khiến Vương Lâm chấn động nguyên thần","ghiChu":""},{"ten":"Hắc y nam tử","tag":"doi-thu","quanHe":"Tu sĩ Thiên Vận Tinh săn yêu linh, tuyên bố coi Vương Lâm là con mồi để lấy yêu tinh tiến vào Thiên Yêu Thành","ghiChu":"Gặp @c0497; đối thủ lầm tưởng Vương Lâm chỉ Ứng Biến trung kỳ."},{"ten":"Âu Dương Hoa","tag":"khac","quanHe":"Tu sĩ trông coi Hồ Lô Cốc, đổi yêu lực kết tinh và cầu Vương Lâm cứu mạng khi yêu linh tấn công","ghiChu":"@c0497"},{"ten":"La mỗ","tag":"doi-thu","quanHe":"Đối thủ chạm trán ngoài thung lũng yêu linh","ghiChu":"Ban đầu tưởng Vương Lâm là người Đại La Kiếm Tông, sau nhận ra hắn là đệ tử Thiên Vận Tử; lo khó giết vì Vương Lâm có pháp bảo bảo mệnh."},{"ten":"Tử hệ lão Lục","tag":"doi-thu","quanHe":"Sư huynh đồng môn Tử hệ","ghiChu":"Từng dùng tu vi Vấn Đỉnh đè ép, khiến Vương Lâm mất danh hiệu Thiên Vận Thất Tử."},{"ten":"La mỗ (Hắc y nhân)","tag":"doi-thu","quanHe":"Đối thủ giao chiến trong Yêu linh khí lãng","ghiChu":"Tu sĩ Anh Biến hậu kỳ đại viên mãn, tự xưng hành sự thay Tôn sư; bị Vương Lâm đả thương nguyên thần, đáp trả bằng Ma cấm triệu Quỷ ảnh."},{"ten":"Hắc y nam tử (mặt sẹo)","tag":"doi-thu","quanHe":"Đối thủ sinh tử","ghiChu":"Áp chế bằng Hóa ma chỉ và Xạ Thần Xa, buộc hắn bỏ thân xác chạy nguyên thần; trước đó từng dùng cùng sát chiêu đấu Tử hệ lão Tứ."},{"ten":"La Vân","tag":"doi-thu","quanHe":"Đối thủ bị Vương Lâm diệt thân, bắt sống nguyên thần và Sưu Hồn đoạt ký ức","ghiChu":"Tu sĩ Thiên Quỷ Đạo, bị giam vào hồn phiên để luyện chủ hồn (@c0501)"},{"ten":"Quỷ Chân Nhân","tag":"doi-thu","quanHe":"Sư tôn của La Vân, bị La Vân dọa sẽ báo thù Vương Lâm","ghiChu":"Mầm xung đột tương lai với Thiên Quỷ Đạo (@c0501)"},{"ten":"La Vân","tag":"doi-thu","quanHe":"Tu sĩ Thiên Quỷ Đạo bị Vương Lâm hấp thu ký ức","ghiChu":"Vương Lâm nắm trọn ký ức về vùng đất yêu linh từ La Vân; hiểu La Vân muốn giết mình để đoạt giáp yêu lực còn thiếu."},{"ten":"Âu Dương Hoa","tag":"su-mon","quanHe":"Đệ tử quy phục","ghiChu":"Được Vương Lâm đả thông kinh mạch đột phá nhị tinh và truyền thụ thuật luyện hồn; đ���i xưng hô thành vãn bối, hành lễ như đệ tử."},{"ten":"Thập Tam","tag":"khac","quanHe":"Thuộc hạ được coi trọng","ghiChu":"Thanh niên Vương Lâm âm thầm theo dõi, có ngộ tính trời sinh với Luyện Hồn Thuật; Vương Lâm trao phương pháp mới và cứu hắn khi bị sư tử phản phệ."},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Tộc nhân chủ lực được Vương Lâm dạy Luyện Hồn Thuật và ban chủ hồn","ghiChu":""},{"ten":"Âu Dương Hoa","tag":"dong-minh","quanHe":"Người dẫn dắt bộ lạc, cung kính gọi Vương Lâm ‘thượng tiên’, dâng yêu tinh đổi khẩu quyết","ghiChu":""},{"ten":"Thập Tam","tag":"su-mon","quanHe":"đệ tử (gọi Sư phụ)","ghiChu":"Cứu khỏi yêu vật, cân nhắc truyền thuật Cổ Thần rồi từ bỏ, tiếc tư chất khi Thập Tam bị phế."},{"ten":"Âu Dương Hoa","tag":"dong-minh","quanHe":"tộc nhân thân tín","ghiChu":"Giao Âu Dương Hoa thu nạp dân Thiên Thủy và quản bộ lạc Luyện Hồn."},{"ten":"Lão già áo trắng","tag":"doi-thu","quanHe":"kẻ thù bị giết","ghiChu":"Đánh phế Thập Tam, cướp hồn phiên — Vương Lâm bóp cổ giết, giam nguyên thần vào cờ Tôn Hồn."},{"ten":"Lão già áo xám (Thiên Thủy)","tag":"khac","quanHe":"hàng phục, thu làm tộc nhân Luyện Hồn","ghiChu":"Sau khi lão áo trắng chết, mở trận pháp và quy thuận, sinh hứng thú với thuật Luyện hồn."},{"ten":"Hổ Bào","tag":"su-mon","quanHe":"Đệ tử thiên tài được giữ bên người","ghiChu":"Đánh giá là thiên tài, giữ bên người vừa bồi dưỡng vừa khống chế."},{"ten":"Diêu Nghiêu lĩnh","tag":"dong-minh","quanHe":"Người quen cũ","ghiChu":"Từng gặp ở ngoài cửa Đông Hải Yêu linh; tại Cổ Yêu thành nàng hóa giải cầu máu, từ chối giao chiến và dẫn Vương Lâm đi gặp Tả dực Yêu tương."},{"ten":"Tả dực Yêu tương","tag":"doi-thu","quanHe":"Chủ Cổ Yêu thành thử thách","ghiChu":"Ra đòn thử Vương Lâm để xét ban chức; bị Vương Lâm hóa giải Tịch Diệt chỉ rồi tiếp Thập Băng Chiến Ý."},{"ten":"Tả dực Yêu tương","tag":"doi-thu","quanHe":"Đối thủ giao chiến tại Cổ Yêu thành","ghiChu":"Tả dực Yêu tương thi triển Thập Băng Quyền Ý, thách Vương Lâm phá tám lần sụp đổ để áp sát."},{"ten":"Tả dực Yêu tướng","tag":"doi-thu","quanHe":"Đối thủ thử thách","ghiChu":"Chủ nhân Thập Băng Quyền Ý; ban đầu xem thường rồi chấn động khi Vương Lâm phá được tới lần thứ bảy bằng niềm tin."},{"ten":"Vân Lệ Hải","tag":"cap-tren","quanHe":"Tả Dực Yêu tương phong Vương Lâm làm Thống lĩnh Cổ Yêu thành","ghiChu":"Khen hắn biết tiến lùi, trao lệnh bài đồng, hẹn bảy ngày sau tới quân doanh."},{"ten":"Thống lĩnh (Nghiêu Lĩnh, Cổ Yêu thành)","tag":"doi-thu","quanHe":"Yêu binh khiêu khích","ghiChu":"Cảm nhận trong cơ thể Vương Lâm có hai luồng lực lượng quỷ dị đang chém giết nhau, ném vò rượu tấn công."},{"ten":"Quản sự tham quân","tag":"khac","quanHe":"Quản sự dưới trướng Yêu Tương, tới đưa Vương Lâm tới quân doanh","ghiChu":"Kiểm tra lệnh bài đồng rồi vẽ Truyền Tống trận đưa đi (@c0514)"},{"ten":"Nam tử âm trầm","tag":"doi-thu","quanHe":"Đầu lĩnh sáu yêu binh trong tửu lâu, đối đầu thoáng qua","ghiChu":"Tấn công bằng trường kiếm yêu khí nhưng bị hóa giải; Vương Lâm hẹn sẽ gặp lại (@c0514)"},{"ten":"Tư Mã Viêm","tag":"doi-thu","quanHe":"Phó thống lĩnh Hắc Giáp quân dưới quyền Vương Lâm","ghiChu":"Bề ngoài quy phục nhưng nắm thực quyền mười Thống đội, ngày càng khiếp sợ vì nhìn không thấu Vương Lâm."},{"ten":"Tôn thống đội","tag":"doi-thu","quanHe":"Thống đội yêu binh dưới quyền Tư Mã Viêm","ghiChu":"Sỉ nhục Vương Lâm là phế vật, bị hắn bóp nát cổ, phá tu vi và hút yêu khí."},{"ten":"Tư Mã Viêm","tag":"doi-thu","quanHe":"Thống lĩnh quân doanh Thiên Yêu quận","ghiChu":"Bày kế chờ Vương Lâm lộ diện, sau bị hắn dùng quân quy phản chế khi ra mặt chất vấn."},{"ten":"Lão già áo vải bố","tag":"khac","quanHe":"Người đi cùng quản sự tham quân tới thị uy","ghiChu":"Bị một cái liếc mắt của Vương Lâm làm phong ấn suýt vỡ, sau đó ôm quyền bội phục tu vi của hắn."},{"ten":"Diêu Tích Tuyết","tag":"khac","quanHe":"Nữ tu quân doanh thứ ba","ghiChu":"Sau khi xông “nơi đó” thất bại lần thứ tư, nàng nghĩ tới việc nhờ Vương Lâm giúp đỡ."},{"ten":"Diêu Tích Tuyết","tag":"dong-minh","quanHe":"Thống lĩnh yêu binh tìm tới nhờ Vương Lâm phá trận cấm chế, lấy tiên ngọc làm điều kiện","ghiChu":"Mới gặp ba lần, Vương Lâm nghi nàng che giấu nhiều chuyện"},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Canh gác ngoài lầu cho Vương Lâm; được Vương Lâm dùng gió giải trừ khống chế"},{"ten":"Diêu Tích Tuyết","tag":"dong-minh","quanHe":"Con gái Huyết Tổ, nhờ Vương Lâm giúp bài trừ phong ấn","ghiChu":"Trao Huyết Hồn đan, lệnh bài Huyết Phù và tiên ngọc làm thù lao; hẹn ba ngày sau ở cổ sơn"},{"ten":"Diêu Tích Tuyết","tag":"doi-thu","quanHe":"Con gái Huyết Tổ, dẫn dắt Vương Lâm qua truyền tống trận tới không gian Tôn Long","ghiChu":"Đưa hắn tiên ngọc và Huyết Hồn đan (b�� hắn luận ra là giả), hứa trao lệnh bài Huyết Phủ khi trở về; Vương Lâm đề phòng và toan moi bí mật."},{"ten":"Diêu Tích Tuyết","tag":"dong-minh","quanHe":"Người đồng hành trên con đường Tôn Long; Vương Lâm ngầm đề phòng vì nàng có Huyết Hồn đan rất khó giết, tự nhủ chưa phải lúc trở mặt.","ghiChu":"@c0522"},{"ten":"Diêu Tích Tuyết","tag":"doi-thu","quanHe":"Đối thủ bị Vương Lâm dùng kế phản đòn, phong ấn giữa sinh tử và đoạt hết trữ vật.","ghiChu":"Con gái Huyết Tổ; trước đó cùng tiến vào đường Tôn Long."},{"ten":"Động Phủ Chi Linh","tag":"khac","quanHe":"Tia linh hồn động phủ ra ba đạo kiếm khí khảo nghiệm; Vương Lâm lợi dụng để giăng kế.","ghiChu":""},{"ten":"Diêu Tích Tuyết","tag":"doi-thu","quanHe":"Đối tượng bị Vương Lâm phong ấn","ghiChu":"Mặc cả giảm năm mươi năm đổi một câu trả lời nhưng nàng không hợp tác, nên bị nhốt vào quả cầu cấm chế cất trong túi trữ vật."},{"ten":"Động Phủ Chi Linh (động phủ tiên cấm)","tag":"khac","quanHe":"Linh thể canh giữ động phủ giải đáp cho y","ghiChu":"Cho biết điều kiện tư cách tiến vào, Hộ Phủ Thần Thông, cách mở phong ấn và rời đi."},{"ten":"Đô Thống Hắc Giáp quân","tag":"doi-thu","quanHe":"Chỉ huy quân doanh Hắc Giáp quân, ra lệnh giết Vương Lâm rồi bị hắn áp chế.","ghiChu":"Đối đầu @c0526"},{"ten":"Tần Lâm","tag":"doi-thu","quanHe":"Đô thống yêu dân bị Vương Lâm đánh bại rồi tha","ghiChu":"Kẻ đã mang Thập Tam đi dâng cho Yêu Tướng"},{"ten":"Yêu Tương đại nhân","tag":"doi-thu","quanHe":"Đối tượng Vương Lâm quyết xông cung đòi người","ghiChu":"Kẻ thu nhận Thập Tam"},{"ten":"Lão già quản lý quân doanh Hắc Giáp","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Lão già từng để ý tới hắn hơn một năm trước, lần này hóa mãng xà đánh lén và bị hắn giết bằng Hóa Ma Chỉ tại cửa thứ ba."},{"ten":"Đệ nhất Đô Thống","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đô Thống thấp bé chặn Hoàng Tuyền Chỉ của hắn cách ba tấc rồi bị đẩy lùi xô sập cửa, phun huyết bắn ra xa."},{"ten":"Người cao lớn (Thập Băng Quyền ý)","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Cao thủ trấn cửa thứ nhất, tung Thập Băng Quyền ý nghênh chiến ngang ngửa Hoàng Tuyền Chỉ."},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Đối thủ rồi tạm thời quy phục dưới danh nghĩa","ghiChu":"Bị Vương Lâm dùng chưởng ấn hư ảo uy hiếp, phong Vương Lâm làm Tả dực đệ nhất phó tướng."},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Thuộc hạ trung thành","ghiChu":"Nhận sáu tầng Cự Linh Cửu Tu, quỳ thề cả đời chỉ tuân mệnh Vương Lâm và tôn hắn làm Lão tổ."},{"ten":"Hổ Bào","tag":"doi-thu","quanHe":"Thuộc hạ cũ trở mặt","ghiChu":"Từng được Vương Lâm truyền Luyện Hồn Thuật; nay nuôi hận vì chờ Vương Lâm cứu khỏi hắc lao vô vọng, thề báo thù."},{"ten":"Mạc Lực Hải","tag":"dong-minh","quanHe":"Đồng hành tới kinh đô Thiên Yêu quận","ghiChu":"Gặp ở tường thành cửa đông Cổ Yêu thành, cùng qua ba truyền tống trận."},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"doi-thu","quanHe":"Mục tiêu treo đầu — giam con gái làm con tin tìm đường sống","ghiChu":"Thừa nhận tu vi Huyết Tổ vượt xa mình."},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Yêu tướng kết giao, bảo chứng thân phận “Vương tướng” và mời về phủ","ghiChu":"Mạc Lệ Hải dặn thuộc hạ gặp Vương Lâm như gặp chính mình"},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Sư huynh đồng hệ","ghiChu":"Gặp lại trên quân đạo Thiên Yêu quận; Vương Lâm tặng đan dược thiện chí và tính liên kết đối phó Đại La Kiếm Tông."},{"ten":"Thạch Tiễn","tag":"khac","quanHe":"Người thanh niên tà dị đi cùng Trần Đào","ghiChu":"Kình địch của Mạc Lệ Hải trong cuộc chiến Yêu tướng."},{"ten":"Lý Mộ Uyển","tag":"the-thiep","quanHe":"Người thân đã mất, hiện ở trong Hạt Châu Thiên Nghịch","ghiChu":"Tiếng đàn trên thuyền hoa gợi hắn nhớ tiếng đàn của nàng ở sơn cốc Chu Tước Tinh; hắn thề sẽ gặp lại nàng."},{"ten":"Cô gái mù trên thuyền hoa","tag":"khac","quanHe":"Người dưng gặp thoáng qua","ghiChu":"Đi ngang thuyền hoa nghe nàng gảy đàn; nàng cảm nhận được bóng hắn tan vào đêm."},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Đối tác giao dịch — yêu tu chủ Mạc phủ, sắp xếp cho Vương Lâm vào Hồng lao đổi lấy sự trợ giúp","ghiChu":"@c0535"},{"ten":"Minh Huyên","tag":"khac","quanHe":"Nữ tử đánh đàn trên hoa thuyền; tiếng đàn bi thương của nàng khiến Vương Lâm cảm ngộ về đạo","ghiChu":"@c0535"},{"ten":"Nam tử họ Hứa","tag":"dong-minh","quanHe":"Người phụ trách Hồng lao tiếp nhận và chỉ điểm sát tâm cho Vương Lâm; ra điều kiện đổi việc giết yêu tướng Thạch Tiễn.","ghiChu":"Gặp @c0536."},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Đưa Vương Lâm tới Hồng lao, trả giá ba tầng đầu Thập Băng Quyền Ý để hắn được vào tu luyện.","ghiChu":"@c0536."},{"ten":"Thanh Sương","tag":"khac","quanHe":"Danh tính trong thanh âm thần bí Vương Lâm nghe được khi đắc kim phù ấn","ghiChu":"Tự xưng “Ta là Thanh Sương”, thân phận chưa rõ"},{"ten":"Nam tử họ Hứa","tag":"an-nhan","quanHe":"Người canh giữ bậc thang cao nhất Hồng Lao, dẫn Vương Lâm trốn thoát; có giao hẹn chưa tiết lộ giữa hai người","ghiChu":"@c0537"},{"ten":"Thanh niên áo xanh (trên họa thuyền)","tag":"khac","quanHe":"Đối ẩm từ xa bên sông, nâng rượu chào nhau; gọi Vương Lâm là “tiểu tử rất thú vị”","ghiChu":"@c0537"},{"ten":"Phó soái Huyền Thành","tag":"doi-thu","quanHe":"Bị Vương Lâm trấn áp","ghiChu":"Phó soái Thiên Yêu Thành kiêu ngạo coi thường Vương Lâm, bị một chiêu sát lục chi khí ép lui và gây nội thương."},{"ten":"Mạc Lệ Hải","tag":"cap-tren","quanHe":"Chủ tướng (Vương Lâm làm phó tướng)","ghiChu":"Vương Lâm đánh giá Mạc Lệ Hải tâm cơ sâu, thủ đoạn nhiều, không bất lực như đang thể hiện."},{"ten":"Nam tử lớn tuổi áo đen (đầu lĩnh sát thủ)","tag":"doi-thu","quanHe":"Đầu lĩnh nhóm sát thủ truy bắt Vương Lâm","ghiChu":"Kinh hãi gọi tên Sát Lục Đạo khi thấy ánh mắt của Vương Lâm.","gap":"@c0540"},{"ten":"Sát thủ số hai (thanh niên áo đen)","tag":"doi-thu","quanHe":"Đối thủ trực tiếp, bị Sát Lục Đạo áp chế suýt sụp đổ tâm thần","gap":"@c0540"},{"ten":"Sát thủ số bốn (trung niên mắt sáng)","tag":"doi-thu","quanHe":"Bị Vương Lâm giết bằng Tịch Diệt Nhất Chỉ","gap":"@c0540"},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Đồng minh người Mạc phủ, chờ Vương Lâm xuất quan ba ngày rồi báo tin bại trận trước Mặc Phi","ghiChu":"@c0542"},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Đệ nhất nhân trong đám Yêu Tướng, đối thủ tiềm tàng trong cuộc tranh đoạt sắp tới","ghiChu":"@c0542"},{"ten":"Thạch Tiêu","tag":"doi-thu","quanHe":"Yêu Tướng khiêu chiến rồi hăm dọa giết Vương Lâm cho hả giận","ghiChu":"Gặp tại trận chiến Yêu Tướng @c0543"},{"ten":"Ngao Địch","tag":"doi-thu","quanHe":"Yêu Tướng ra khiêu chiến, bị Vương Lâm coi thường","ghiChu":"@c0543"},{"ten":"Huyền Phó Soái","tag":"doi-thu","quanHe":"Phó Soái có thù cũ, căm ghét nhưng tin Vương Lâm sẽ dẫn đầu","ghiChu":"@c0543"},{"ten":"Hoàng Phó Soái","tag":"khac","quanHe":"Phó Soái nghi ngờ thực lực Vương Lâm, đánh cược về hắn với Huyền Phó Soái","ghiChu":"@c0543"},{"ten":"Ngao Địch","tag":"doi-thu","quanHe":"Yêu Tướng bị Vương Lâm đánh phế kinh mạch và xương cốt thành phế nhân tại đại hội","ghiChu":"@c0544"},{"ten":"Nam tử mặc giáp vàng","tag":"doi-thu","quanHe":"Kim tổng quản can thiệp cứu Ngao Địch, bị Vương Lâm đẩy lui trường thương rồi đe dọa tội trảm — kết mối ân oán","ghiChu":"@c0544"},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Người chiêu mộ Vương Lâm, mừng thầm vì quyết định sáng suốt khi thấy uy thế của hắn","ghiChu":"@c0544"},{"ten":"Thanh niên trên thuyền tranh","tag":"khac","quanHe":"Người lạ mời lên thuyền tranh nghe đàn uống rượu, cùng nhận nhau là tục nhân","ghiChu":"Đối thoại tại Hồng Thành @c0545"},{"ten":"Minh Phí (cô nương)","tag":"khac","quanHe":"Nữ tử đánh đàn trên thuyền tranh, tiếng đàn khơi cảm ngộ của Vương Lâm","ghiChu":"@c0545"},{"ten":"Thiếu môn chủ Ngọc Kiếm Môn (nam tử áo trắng)","tag":"khac","quanHe":"Cảm phục Vương Lâm, cáo từ trước khi dẫn đoàn rời Thiên Yêu Thành","ghiChu":"@c0545"},{"ten":"Mạt Dương","tag":"doi-thu","quanHe":"Kẻ địch bị giết","ghiChu":"Kiếm Tiếu Thập Nhị Tử của Đại La Kiếm Tông; khiêu chiến Vương Lâm tại Mạc phủ, bị hóa giải kiếm khí, đoạt kiếm bản mệnh rồi âm thầm hạ sát hóa thây khô."},{"ten":"Nam tử mặc kim giáp","tag":"doi-thu","quanHe":"Chủ trì vòng hai phụng mệnh Đế Quân, tỏa sát khí với Vương Lâm và thách đánh cược","ghiChu":"Gặp tại Thiên Yêu Môn @c0546"},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Yêu Tướng đệ nhất gõ 8 tiếng Chiến Yêu Cổ; Vương Lâm nhận ra giống nam tử tóc đen Hồng Lao","ghiChu":"@c0546"},{"ten":"Huyền Phó Soái","tag":"khac","quanHe":"Phó Soái chọn Vương Lâm để đánh cược, âm thầm cho rằng hắn đáng sợ","ghiChu":"@c0546"},{"ten":"Tà Liên","tag":"khac","quanHe":"Nữ yêu tướng duy nhất chú ý tới Vương Lâm khi hắn gõ trống","ghiChu":"Mắt đẹp lóe tinh quang nhìn Vương Lâm trên khán đài"},{"ten":"Tà Liên","tag":"doi-thu","quanHe":"Nữ Yêu tướng châm biếm Vương Lâm","ghiChu":"Lộ vẻ châm biếm, ngầm hỏi Vương Lâm có vứt bỏ được cảm động lưu luyến không (@c0549)."},{"ten":"Trần Đào","tag":"doi-thu","quanHe":"Người chọn đưa Vương Lâm đến giúp Yêu tướng","ghiChu":"Lần đầu thấy chán ghét Vương Lâm (@c0549)."},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Tu sĩ Đại La Kiếm Tông quan sát khảo nghiệm","ghiChu":"Lạnh lùng nhìn Vương Lâm, ám chỉ hắn và một người xưa đều từng được hâm mộ."},{"ten":"Thiên soái","tag":"khac","quanHe":"Yêu Soái ngăn Kim Ô Húc giết Vương Lâm","ghiChu":"Kinh hãi nhận ra Vương Lâm chọn con đường giống Yêu Đế năm xưa, phóng xuống cản Kim Ô Húc."},{"ten":"Kim Ô Húc","tag":"doi-thu","quanHe":"Yêu nhân tập kích Vương Lâm","ghiChu":"Phóng tới sau lưng với quyền cầm mặt trời quyết giết hắn trước tiếng trống thứ mười lăm; bị tiếng quát từ thuyền và đòn từ tháp đen đánh vỡ kim giáp."},{"ten":"Kim Ô Húc","tag":"doi-thu","quanHe":"Đối thủ bị Vương Lâm giết","ghiChu":"Chụp Kim Ô Húc đang trọng thương đập lên Yêu Cổ, dùng tiếng trống thứ mười lăm đánh nát thân hắn (@c0551)."},{"ten":"Thiên Soái","tag":"dong-minh","quanHe":"Yêu soái tán thưởng","ghiChu":"Thiên soái nhìn Vương Lâm với ánh tán thưởng của trưởng bối với hậu bối (@c0551)."},{"ten":"Lý Mộ Uyển","tag":"the-thiep","quanHe":"Người Vương Lâm từng vì nàng nghịch thiên cải mệnh","ghiChu":"Vương Lâm hồi tưởng năm xưa từng vì nàng nghịch thiên cải mệnh, dẫn động thiên đạo sứ giả hàng lâm."},{"ten":"Thiên soái","tag":"khac","quanHe":"Yêu soái chứng kiến","ghiChu":"Đứng gần nhất khi Vương Lâm độ kiếp, ném cho hắn bình ngọc chứa một viên đan dược rồi rời đi. @c0553"},{"ten":"Người thanh niên trên thuyền hoa","tag":"khac","quanHe":"Cường giả thần bí","ghiChu":"Định bắt Vương Lâm khỏi Đế Đô để độ kiếp nơi khác nhưng hắn bị thiên kiếp khóa chặt không đem đi được. @c0553"},{"ten":"Lý Mộ Uyển","tag":"khac","quanHe":"Chấp niệm","ghiChu":"Hình bóng mà Vương Lâm muốn giữ lại, ẩn trong hắc mang Hóa Ma Chỉ khi đấu thiên. @c0553"},{"ten":"Cổ Yêu (giọng nói âm u)","tag":"khac","quanHe":"Giọng nói am hiểu thiên đạo vang trong tâm thần Vương Lâm lúc nguy kịch, giảng giải về nghịch tu và tộc Cổ, tự xưng Cổ Yêu","ghiChu":"@c0554"},{"ten":"Cổ Yêu","tag":"an-nhan","quanHe":"Lão tổ tông Thiên Yêu quận; lập giao kèo sửa thân thể, mượn hư ảnh chống thiên kiếp; hẹn ba tháng sau gặp ở Long Đàm.","ghiChu":"@c0555"},{"ten":"Vân Độn","tag":"dong-minh","quanHe":"Bị năm lão tổ giao trách nhiệm đưa Vương Lâm về Long Đàm sau ba tháng.","ghiChu":"@c0555"},{"ten":"Chủ nhân áo giáp trong hắc tháp","tag":"doi-thu","quanHe":"Kẻ địch bí ẩn trong hắc tháp","ghiChu":"Tồn tại bị thương nặng ngụ trong áo giáp, phái cánh tay xương đen đi đoạt nguyên khí Vương Lâm sau khi hắn vừa tiến Vấn Đỉnh."},{"ten":"Hứa Lập Quốc","tag":"dong-minh","quanHe":"Khí linh trong tiên kiếm của Vương Lâm; lần này quyết lập công chuộc tội điều kiếm chém bộ xương, cuối chương run sợ trước trạng thái của Vương Lâm.","ghiChu":"@c0557"},{"ten":"Tử Thử","tag":"doi-thu","quanHe":"Đô Thống Hỏa Yêu quận chứng kiến Vương Lâm điên cuồng","ghiChu":"Tử Thử thấy Vương Lâm phun máu trong trạng thái điên cuồng thì hai mắt sáng ngời, nảy ý đồ với kẻ Vấn Đỉnh đang trọng thương. @c0558"},{"ten":"Tử Thử","tag":"doi-thu","quanHe":"Kẻ tham nguyên thần Vấn Đỉnh của Vương Lâm để dưỡng Kiếm Linh, liều mạng tấn công và bị Vương Lâm giết trong nháy mắt","ghiChu":"@c0559"},{"ten":"Mạc Tổ","tag":"doi-thu","quanHe":"Cường giả Ma Vực; Vương Lâm giết hai đệ tử thân truyền của ông, gieo mối thù tiềm tàng","ghiChu":"@c0559"},{"ten":"Duẫn Đông","tag":"doi-thu","quanHe":"Yêu tướng xung phong giao chiến, bị Vương Lâm giết bằng Tịch Diệt Chỉ","ghiChu":"@c0560"},{"ten":"Phó soái (Hỏa Yêu quận)","tag":"doi-thu","quanHe":"Phó soái tọa trấn chỉ huy vây diệt Vương Lâm","ghiChu":"@c0560"},{"ten":"Hổ Bào","tag":"doi-thu","quanHe":"Kẻ từng được hắn cứu mạng và truyền Luyện Hồn thuật, sau nuôi hận phản lại; bị hắn đoạt quyền khống chế hồn phách rồi giết chết.","ghiChu":"@c0562"},{"ten":"Chủ nhân áo giáp trong hắc tháp","tag":"doi-thu","quanHe":"Lão giả hắc giáp khoác Sáo Tiêu giáp bước ra từ hắc tháp, vâng lệnh thần niệm tấn công Vương Lâm bằng Phong–Vũ–Lôi–Điện hòng bắt sống.","ghiChu":"@c0563"},{"ten":"Thực thể trong tháp đen (chiến trường viễn cổ)","tag":"doi-thu","quanHe":"Thần niệm khổng lồ ẩn trong hắc tháp, từng nhiều lần khiến Vương Lâm trọng thương dọc đường; tra hỏi nguồn gốc chưởng ấn rồi ra lệnh bắt sống hắn.","ghiChu":"@c0563"},{"ten":"Lăng Thiên Hậu","tag":"an-nhan","quanHe":"Chủ nhân đạo kiếm khí mà Vương Lâm sử dụng làm vật nghịch thiên; lão giả phán người phát ra kiếm khí này tu vi sợ đạt toái niết tam cảnh.","ghiChu":"@c0563"},{"ten":"Chủ nhân áo giáp trong hắc tháp","tag":"doi-thu","quanHe":"Kẻ địch trên viễn cổ chiến trường","ghiChu":"Vương Lâm dùng kiếm khí Lăng Thiên Hậu phá ma đao của lão giả; lão giả nhận ma khí từ hắc tháp hóa thành ma nhân khổng lồ đuổi giết hắn. @c0564"},{"ten":"Diêu Tích Tuyết","tag":"doi-thu","quanHe":"Tù nhân bị phong ấn","ghiChu":"Vương Lâm uy hiếp nàng để đòi phương pháp dùng Huyết Hồn đan. @c0564"},{"ten":"Chu Như","tag":"ho-hang","quanHe":"Chu Như gọi Vương Lâm là thúc thúc, kính ngưỡng pho tượng và quyết tu tới Nguyên Anh để nhận vật hắn để lại.","ghiChu":"@c0567"},{"ten":"Thiết Nham","tag":"an-nhan","quanHe":"Năm xưa Vương Lâm chỉ điểm Thiết Nham đột phá Nguyên Anh đạt Hóa Thần; Thiết Nham giữ túi trữ vật hắn để lại, không dám đụng.","ghiChu":"@c0567"},{"ten":"Cổ Vân Phong","tag":"dong-minh","quanHe":"Yêu Đế","ghiChu":"Chính là thanh niên từng uống rượu suốt đêm với Vương Lâm năm xưa; tỏ thiện ý xem Vương Lâm là người cùng đường, trao ngọc giản điều động Thiên soái."},{"ten":"Song nhi","tag":"doi-thu","quanHe":"Kiếm linh Đế kiếm, cháu gái Yêu Đế","ghiChu":"Oán hận Hứa Lập Quốc và Vương Lâm suốt mười năm, thúc giục Đế kiếm tấn công Vương Lâm."},{"ten":"Hợi Trư","tag":"doi-thu","quanHe":"Đối thủ bị Vương Lâm chém đầu, Sưu hồn ném vào Hồn phiên làm chủ hồn","ghiChu":"Người Đại La Kiếm Tông, Anh Biến hậu kỳ"},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Phó soái Vương Lâm tuyên bố bắt giết để đoạt thanh thế, nhưng thực ra nhắm Hợi Trư"},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Người Đại La Kiếm Tông âm thầm bảo vệ, tướng mạo quen mắt; nghi là kẻ thù năm xưa của Tư Đồ Nam"},{"ten":"Lão tổ (lão già dáng cực kỳ thấp bé)","tag":"doi-thu","quanHe":"Kẻ nhìn trúng Vương Lâm, ra lệnh truy bắt để luyện thành Tiên vệ mới","ghiChu":"Chủ tòa thành trắng trong chướng khí biên giới quận Hỏa Yêu - Kim Yêu"},{"ten":"Tôn Vân Sơn","tag":"khac","quanHe":"Tu sĩ bị Tiên chủng khống chế được Vương Lâm cứu xét; khai vị trí Liên minh, được Vương Lâm đưa ngọc giản phòng thân","ghiChu":"@c0576"},{"ten":"Lão Tổ Liên minh","tag":"doi-thu","quanHe":"Lão tổ Tu sĩ liên minh từ Tiên giới, hai lần trêu chọc Vương Lâm; mục tiêu chinh phạt","ghiChu":"@c0576"},{"ten":"Tôn Nhược Nam","tag":"doi-thu","quanHe":"Nữ tử trước người Lão Tổ, muội muội Tôn Vân Sơn; nhận ra và gọi tên Vương Lâm, cho rằng hắn không thể so với Lão Tổ","ghiChu":"@c0577"},{"ten":"Lão Tổ Liên minh","tag":"doi-thu","quanHe":"Chủ Toà thành trắng, từng hai lần trêu chọc, muốn bắt Vương Lâm luyện Tiên vệ; bị cự tuyệt liền triệu tám Tiên vệ giết","ghiChu":"@c0577"},{"ten":"Lão già thấp bé (Toà thành trắng)","tag":"doi-thu","quanHe":"Đối thủ — tự xưng người Tiên giới, Vấn Đỉnh trung kỳ, điều khiển tám Tiên vệ và Tiên thú chi lương, bị Vương Lâm áp đảo","ghiChu":"@c0578"},{"ten":"Tôn Vân Sơn","tag":"khac","quanHe":"Vương Lâm từng thấy sợi tơ Tiên lương trên người y; chưa nói rõ việc nhận ra Tiên lương với y","ghiChu":"@c0578"},{"ten":"Lão tổ (lão già dáng cực kỳ thấp bé)","tag":"doi-thu","quanHe":"Đối thủ — lão già khống chế Tiên vệ, bị Vương Lâm áp đảo và truy đoạt pháp bảo Tiên giới","ghiChu":"@c0579"},{"ten":"Tiểu hắc tử","tag":"dong-minh","quanHe":"Linh của thanh loan đao đen của Vương Lâm, được sai đuổi theo Tiên bút vào hư vô","ghiChu":"@c0579"},{"ten":"Lôi Suất","tag":"doi-thu","quanHe":"Phó soái Lôi Yêu Quận đem quân vây bộ lạc","ghiChu":"Vương Lâm định thân rồi đánh văng hắn phun máu khỏi bộ lạc."},{"ten":"Nữ Phó soái Thuỷ Yêu Quận","tag":"doi-thu","quanHe":"Phó soái Thuỷ Yêu Quận mưu bắt tộc nhân","ghiChu":"Bị Định Thân thuật định trụ, sau ba tức loé lam quang thoát ra bỏ chạy."},{"ten":"Cổ Yêu của Hoả Yêu Quận","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Thần thức Cổ Yêu Hoả Yêu Quận quát đuổi Vương Lâm, phẫn nộ khi biết hắn do Bối La phái tới."},{"ten":"Đỗ Kiến","tag":"doi-thu","quanHe":"Xích hệ đệ tử Thiên Vận Tử rủ Vương Lâm kết bạn vào Triều Tịch thâm uyên nhưng trong lòng đầy đố kị ác ý, lo Vương Lâm tranh địa vị tử hệ.","ghiChu":"Quen biết từ trăm năm trước khi Vương Lâm còn là Anh Biến trung kỳ."},{"ten":"Mộ Dung Trác","tag":"dong-minh","quanHe":"Mặc môn tứ đại đệ tử, có thần thông phát hiện ngoài ngàn dặm; bày tỏ tôn kính ngầm với Vương Lâm. Vương Lâm nhận lời kết bạn chủ yếu vì coi trọng giá trị của hắn."},{"ten":"Triệu Y Huyên","tag":"khac","quanHe":"Nữ tử Phù Vân phái có thể nhìn thấu nội tâm; xếp Vương Lâm vào số ba người hơn trăm năm nàng không dò thấu."},{"ten":"Từ Phi","tag":"khac","quanHe":"Nữ tử Phù Vân phái nhu nhược; tên trùng một đồng môn hồi nhỏ của Vương Lâm, gợi hồi ức song hắn xác nhận không quen biết."},{"ten":"Đỗ Kiến","tag":"doi-thu","quanHe":"Đối thủ cùng đẳng cấp bị Vương Lâm đánh bại, phong ấn nguyên thần và thu vào túi trữ vật.","ghiChu":"@c0591"},{"ten":"Mộ Dung Trác","tag":"dong-minh","quanHe":"Đồng hành vượt Triều Tịch thâm uyên; Vương Lâm kết giao hiếm có và cảnh báo về Thi Âm Tông.","ghiChu":"@c0591"},{"ten":"Triệu Y Huyên","tag":"doi-thu","quanHe":"Bị Vương Lâm nhận diện là người Thi Âm Tông qua thần thông kỳ dị; lộ tham niệm khi thấy “vô thị thần thông”.","ghiChu":"@c0591"},{"ten":"Từ Phi (Phù Vân phái)","tag":"doi-thu","quanHe":"Nghi là người Thi Âm Tông đã thi thể phụ nguyên thần; cài tóc do thám Vương Lâm và bị hắn phá thần thức, chảy huyết.","ghiChu":"@c0591"},{"ten":"Chu Dật","tag":"an-nhan","quanHe":"Tiền bối có ân; Vương Lâm liều mình vào Triều Tịch vực cứu, được Chu Dật phóng bản mệnh kiếm khí cứu lại và hồi phục nguyên thần","ghiChu":"@c0594"},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Kẻ phong ấn Chu Dật; thần niệm canh giữ khe liên tục công kích Vương Lâm","ghiChu":"@c0594"},{"ten":"Chu Dật","tag":"an-nhan","quanHe":"Cố nhân – ân nhân kiếm linh","ghiChu":"Vương Lâm tìm tới cứu Chu Dật; Chu Dật phá phong ấn, giao bảo tháp và tạo kiếm linh cho Vương Lâm, chỉ cầu Vương Lâm tìm phụ thân Đình nhi."},{"ten":"Hứa Lập Quốc","tag":"dong-minh","quanHe":"Kiếm linh dưới trướng","ghiChu":"Linh thể ký thân thanh kiếm tiên thứ hai, được Chu Dật truyền kiếm ý viễn cổ thành kiếm linh phục vụ Vương Lâm, bị cài lạc ấn phòng phản bội."},{"ten":"Thanh Lâm","tag":"khac","quanHe":"Người cần tìm","ghiChu":"Tiên đế, phụ thân Đình nhi; Vương Lâm nhận lời tìm để giúp Đình nhi thức tỉnh."},{"ten":"Thần Long","tag":"doi-thu","quanHe":"Đồng cảnh bị nhốt","ghiChu":"Đại sư huynh Đại La kiếm tông quyết đoán phá vây thoát một mình, bỏ rơi cả Vương Lâm lẫn các sư đệ trong sương tím."},{"ten":"Ngọ Mã","tag":"doi-thu","quanHe":"Kẻ bị giết","ghiChu":"Đệ tử Đại La kích động giết Vương Lâm; bị hắn giả giọng Tuất Cẩu lừa thu kiếm khí rồi điểm mi tâm giết."},{"ten":"Tị Xà","tag":"doi-thu","quanHe":"Kẻ bị giết","ghiChu":"Bị Vương Lâm áp tay rút sức sống hóa thây khô trong sương tím."},{"ten":"Tuất Cẩu","tag":"doi-thu","quanHe":"Kẻ sống sót","ghiChu":"Đệ tử Đại La duy nhất Vương Lâm chưa kịp giết; giọng nói của hắn bị Vương Lâm giả để lừa Ngọ Mã."},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Kẻ truy bắt","ghiChu":"Điều bầy Văn thú vây Vương Lâm để bắt nguyên thần tra hỏi nơi ở Tư Đồ Nam."},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Đối thủ tu hành mấy vạn năm","ghiChu":"Hợp lực cùng Thần Long vây công nhưng bị Tham Lang dùng Phệ Tử thuật thoát vây."},{"ten":"Thần Long","tag":"dong-minh","quanHe":"Đồng minh tạm thời chống Tham Lang","ghiChu":"Không hẹn mà cùng chớp thời cơ hợp công."},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Đối thủ tranh đoạt lệnh bài","ghiChu":"Vương Lâm hai lần dùng ‘Định’ cản Tham Lang đoạt lệnh bài; bị Tham Lang đảo vị bằng đại đỉnh.","gap":"@c0603"},{"ten":"Thần Long (Đại La Kiếm Tông)","tag":"doi-thu","quanHe":"Đối thủ tranh đoạt lệnh bài","ghiChu":"Vương Lâm mượn thân Thần Long di chuyển rồi dùng ‘Định’ khống chế làm hắn rơi lệnh bài.","gap":"@c0603"},{"ten":"Chu Dật","tag":"dong-minh","quanHe":"Đồng minh, thần thức dung trong tiên kiếm","ghiChu":"Truyền âm cảnh báo về kiếm khí Lăng Thiên Hậu và cung cấp tốc độ cho Vương Lâm.","gap":"@c0603"},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Đối thủ truy sát","ghiChu":"Tham Lang vây Vương Lâm bằng cái đỉnh nghịch Càn Khôn và đệ nhị nguyên thần lôi hệ; Vương Lâm diệt được đệ nhị nguyên thần khiến Tham Lang phun máu."},{"ten":"Chu Dật","tag":"dong-minh","quanHe":"Kiếm linh trong tiên kiếm trợ giúp","ghiChu":"Chu Dật phá vây rồi cầm chân Tham Lang cho Vương Lâm rút lui."},{"ten":"Thái Cổ Lôi Long","tag":"doi-thu","quanHe":"Con rồng sấm thái cổ truy đuổi Vương Lâm trong hố sâu, cuối cùng bị hắn dùng thần thông thôn hồn nuốt nửa linh thể và hấp thu lôi lực.","ghiChu":"@c0605"},{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Người được nhắc tới như bậc kiến thức cao, song ngay cả ông cũng không dám nuốt Thái Cổ Lôi Long như Vương Lâm","ghiChu":"@c0606"},{"ten":"Đỗ Kiến","tag":"khac","quanHe":"Người Vương Lâm cứu nguyên thần khỏi lửa thiêu rồi ép làm vật liệu luyện chế Tiên Vệ","ghiChu":"Hứa ngàn năm sau nếu Đỗ Kiến chưa tử sẽ trả tự do"},{"ten":"Nữ tử trong nguyên thần","tag":"khac","quanHe":"Thanh âm bí ẩn trong nguyên thần","ghiChu":"Một thanh âm nữ tử ẩn trong nguyên thần Vương Lâm vang lên thúc giục hắn bước xuống hố sâu; chưa lộ danh tính."},{"ten":"Văn thú","tag":"dong-minh","quanHe":"Linh thú cũ tái ngộ","ghiChu":"Con Văn thú màu tím rời hắn hơn mười năm, nay mừng rỡ nâng hắn ra khỏi hố; được hắn thu vào túi trữ vật."},{"ten":"Thạch Tiêu","tag":"doi-thu","quanHe":"Kẻ thù bị giết","ghiChu":"Thạch Tiêu khinh miệt, dọa giết Vương Lâm; bị hắn dùng Âm dương hư thật giết tại yêu tướng phủ, báo lời hứa năm xưa."},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Sư huynh","ghiChu":"Trần Đào bênh “Vương Lâm là sư đệ của ta”; chứng kiến Vương Lâm giết Thạch Tiêu, được dặn “Cẩn thận, sư tôn”."},{"ten":"Vương Tạ","tag":"khac","quanHe":"Nam trong Vân Tiên đạo lữ giam giữ Tham Lang và Thần Long; xuất hiện cùng thời điểm Vương Lâm rời đi","ghiChu":"@c0614"},{"ten":"Hồ Quyên","tag":"khac","quanHe":"Nữ trong Vân Tiên đạo lữ","ghiChu":"@c0614"},{"ten":"Nhiễm Nguyệt","tag":"dong-minh","quanHe":"Nữ tu Nhiễm gia được Vương Lâm cứu khỏi vòng vây Minh vụ trùng","ghiChu":"Nhiễm Nguyệt thất kinh trước thần thông của hắn, hứa Nhiễm gia báo đáp. @c0615"},{"ten":"Tôn Tuyết Sơn","tag":"dong-minh","quanHe":"Tu sĩ đi cùng nhóm Nhiễm gia, người chỉ đường tới Hợp vân thánh cho Vương Lâm","ghiChu":"Hứa dùng Xích diệu thạch và dẫn đường để đền ơn cứu mạng. @c0615"},{"ten":"Nhiễm Thần","tag":"dong-minh","quanHe":"Nam tu Nhiễm gia được Vương Lâm giải vây","ghiChu":"@c0615"},{"ten":"Nhiễm Phong","tag":"dong-minh","quanHe":"Nam tu Nhiễm gia được Vương Lâm giải vây","ghiChu":"@c0615"},{"ten":"Nữ tử trong cuộn tranh","tag":"khac","quanHe":"Thân ảnh nữ tử thần bí hiện ra từ bức tranh trong túi trữ vật, bốn lần gọi ‘Đi xuống’ trong ba năm","ghiChu":"Thân phận và mục đích chưa rõ; Vương Lâm chém kiếm khiến tranh im tiếng"},{"ten":"Nữ tử trong bức tranh","tag":"doi-thu","quanHe":"Đối tượng đối đầu","ghiChu":"Hồn nữ tử trong bức tranh dụ Vương Lâm đưa về La Thiên tinh vực, hứa tổ tiên nàng cứu sống tàn hồn; Vương Lâm nhận ra âm mưu nên phong ấn nàng vĩnh viễn trong vách đá."},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Nữ tử Nhiễm gia dẫn đường, nghi Vương Lâm là Lôi Tiên sứ giả, hỏi tên và xuất thân của hắn","ghiChu":"Vương Lâm xưng tên giả Hứa Mộc với nàng"},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Người La Vân Tinh Vực, cực kỳ tôn kính cuồng nhiệt, nguyện dẫn đường đi Nhiễm Vân Tinh và cung cấp thông tin về La Thiên Tinh Vực"},{"ten":"Liễu Mi","tag":"khac","quanHe":"Người mà Vương Lâm hồi tưởng biểu hiện Thiên Huyễn Vô Tình Đạo năm xưa để mô phỏng nhập vào trâm cài tóc.","ghiChu":"Không trực tiếp xuất hiện chương này."},{"ten":"Lô Phong","tag":"doi-thu","quanHe":"Người gác cửa Bảo Hợp Lâu khinh rẻ và từ chối phi kiếm của Vương Lâm; bị ánh mắt hắn dọa cho Nguyên Anh gần sụp","ghiChu":"@c0618"},{"ten":"Tôn lão","tag":"khac","quanHe":"Lão già ở Bảo Hợp Lâu thoáng thấy bóng dáng Vương Lâm ‘quen quen’, lộ tia nghi hoặc","ghiChu":"@c0618"},{"ten":"Văn sĩ trẻ Thanh Trúc Các","tag":"khac","quanHe":"Văn sĩ coi Thanh Trúc Các nhận phi kiếm của Vương Lâm, dùng thần thức xem rồi kinh khiếp","ghiChu":"@c0618"},{"ten":"Gã thanh niên ngoài thành bắc","tag":"khac","quanHe":"Tu sĩ tu vi thấp khinh thường nhưng vẫn chỉ Vương Lâm tới Bảo Hợp Lâu","ghiChu":"@c0618"},{"ten":"Tôn Mặc","tag":"khac","quanHe":"Tu sĩ Kết Đan tiếp đón tại Thanh Trúc Các","ghiChu":"Thử và trả giá phi kiếm, mời trưởng lão Anh Biến tới kiểm định cho Vương Lâm.","gap":"@c0619"},{"ten":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","tag":"doi-thu","quanHe":"Trưởng lão Anh Biến mua bảo","ghiChu":"Kiểm định và mua phi kiếm ba nghìn tiên ngọc, khiếp sợ tham lam trước gương đồng kế thừa ngụy tiên bảo.","gap":"@c0619"},{"ten":"Tôn Khải Minh","tag":"khac","quanHe":"Lão già hắc y phụ trách tòa thành Tôn Gia nơi Vương Lâm trú","ghiChu":"Giao hai mươi vạn tiên ngọc và lệnh bài đấu giá; nhận lệnh tộc thăm dò tu vi Hứa Mộc."},{"ten":"Người thanh niên nữ giả nam","tag":"khac","quanHe":"Nữ giả nam tu luyện gần chỗ ở Vương Lâm, từng giáo huấn hắn về tu chân","ghiChu":"Tướng mạo thật chưa lộ."},{"ten":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","tag":"khac","quanHe":"Đối tác giao dịch","ghiChu":"Lão già Anh Biến mua ngọc giản kế thừa gương đồng của Vương Lâm với hơn một vạn tiên ngọc.","gap":"@c0620"},{"ten":"Người đàn ông trung niên gầy yếu (cướp bảo Tôn gia)","tag":"doi-thu","quanHe":"Kẻ tập kích cướp bảo, bị Vương Lâm đánh tan gần nửa nguyên anh","gap":"@c0620"},{"ten":"Tôn trưởng lão (chi nhánh Tôn gia)","tag":"doi-thu","quanHe":"Trưởng lão Tôn gia xúi người trung niên cướp bảo, sau bị Vương Lâm đối chất","gap":"@c0620"},{"ten":"Lão già mặt đỏ (Tôn gia)","tag":"doi-thu","quanHe":"Lão Tôn gia dọa nạt đòi chờ trưởng bối, sau xin ý lão hắc y","gap":"@c0620"},{"ten":"Lão già hắc y (Tôn gia Anh Biến hậu kỳ)","tag":"doi-thu","quanHe":"Lão hắc y mang đạo khí Vấn Đỉnh ra dàn xếp, đồng ý bồi thường hai mươi vạn tiên ngọc","gap":"@c0620"},{"ten":"Nam tử tóc dài dưới đáy biển (Nhiễm Vân Tinh)","tag":"doi-thu","quanHe":"Tu sĩ ẩn dưới hải dương kiêng dè cái liếc cảnh cáo của Vương Lâm rồi rời đi","gap":"@c0620"},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Lão tổ Vấn Đỉnh Tôn Gia tới thăm dò, bị Vương Lâm áp đảo rồi cầu giúp","ghiChu":"Tôn Tích đề nghị tặng suất đi Lôi tiên giới đổi lấy trợ giúp"},{"ten":"Tôn Lăng","tag":"khac","quanHe":"Thanh niên Tôn Gia kiên quyết bảo vệ Hứa Mộc trước Tôn Tích, khiến Vương Lâm cảm động","ghiChu":""},{"ten":"Tôn Tích","tag":"khac","quanHe":"Lão tổ Tôn Gia, kiêng dè Vương Lâm, kể chuyện bốn năm trước và gián tiếp cảnh báo về cạm bẫy đan dược.","ghiChu":"@c0623"},{"ten":"Tôn Khải Minh","tag":"khac","quanHe":"Tộc nhân đời thứ ba Tôn Gia phụ trách tòa thành, cung kính nghênh đón Vương Lâm.","ghiChu":"@c0623"},{"ten":"Tôn Thái","tag":"an-nhan","quanHe":"Cố nhân từ Chu Tước tinh; ân nhân năm xưa từng trợ giúp Vương Lâm thoát chết khỏi lão tổ Cự Ma tộc","ghiChu":"Nay Tôn Thái luân lạc Hóa Thần kỳ, Vương Lâm hứa tiễn và mang tro cốt về quê cũ; nhận túi trữ vật tặng."},{"ten":"Tôn Thái","tag":"khac","quanHe":"Nhận túi trữ vật và lời gửi gắm","ghiChu":"Tôn Thái buông bỏ tất cả, nhờ Vương Lâm đưa về quê nhà dưới chân Thiên Sơn."},{"ten":"Liễu Mi","tag":"khac","quanHe":"Người được Liễu Mi nhung nhớ","ghiChu":"Liễu Mi than pháp bảo “chuẩn bị cho hắn” nay đã vô dụng."},{"ten":"Lão tổ Nhiễm gia","tag":"doi-thu","quanHe":"Bị Vương Lâm dùng Tiên vệ áp chế, buộc nộp tiên ngọc che chở chuyện bốn năm trước","ghiChu":"@c0627"},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Bị ép hiện thân nộp bảy phần tiên ngọc","ghiChu":"@c0627"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Người Tôn gia ở Nhiễm Vân tinh nhận lệnh Vương Lâm","ghiChu":"Được truyền âm lệnh khắc tinh đồ La Thiên tinh vực vào ngọc giản đưa tới."},{"ten":"Người thanh niên nữ giả nam","tag":"khac","quanHe":"Tu sĩ trẻ lòng thiện lương được Vương Lâm khích lệ","ghiChu":"Vương Lâm tiên đoán y giữ nguyên tâm cảnh có thể đạt Hóa Thần."},{"ten":"Huyễn Đông","tag":"doi-thu","quanHe":"Tộc vệ Huyễn gia giáng lâm Nhiễm Vân tinh đòi diệt người tham dự; bị Vương Lâm dùng Tịch Diệt chỉ đánh trọng thương phải bỏ chạy.","ghiChu":"@c0629"},{"ten":"Huyễn Đông","tag":"doi-thu","quanHe":"Tộc vệ Huyễn gia bị Vương Lâm bắt sống, dùng Sưu hồn thuật moi trí nhớ rồi bóp chết, thu nguyên thần vào Tôn hồn phiên.","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Phát hiện Huyễn Mi — con gái nuôi của Lão tổ Huyễn gia — chính là Liễu Mi, kẻ có cừu hận từ Chu Tước tinh; cảnh báo nếu nàng càn quấy thì sẽ giết.","ghiChu":"@c0630"},{"ten":"Lão tổ Huyễn Gia","tag":"doi-thu","quanHe":"Cường giả cảnh giới Âm Dương Hư Thực có Tiên Vệ, vừa trở về; Vương Lâm tự lượng không liều chết, định trả thù bằng cách giết tộc nhân.","ghiChu":"@c0630"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng phía với ba nhà Nhiễm Vân tinh đang bị Huyễn gia nhắm diệt; Vương Lâm hướng tới Nhiễm Vân tinh.","ghiChu":""},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Cố nhân từ Chu Tước tinh, nay đối đầu","ghiChu":"Liễu Mi nhận ra Vương Lâm qua ánh mắt; hai bên khai chiến tại Nhiễm Vân tinh."},{"ten":"Tôn Tích","tag":"khac","quanHe":"Lão tổ Tôn gia từng tìm Vương Lâm vì việc phân thân nhưng bị từ chối","ghiChu":"Vương Lâm dưới thân phận Hứa Mộc đã thu tiên ngọc của ba lão tổ."},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Đối thủ có ân oán cũ trên Chu Tước tinh","ghiChu":"Liễu Mi tố Vương Lâm dùng tàn hồn ý cảnh ô uế phá tấm thân xử nữ của nàng; quyết chấm dứt ân oán, biến hóa thành nhiều người thân của hắn để công tâm rồi thả oán khí."},{"ten":"Đỗ Kiến","tag":"khac","quanHe":"Người được Vương Lâm cứu nguyên thần rồi ép luyện chế thành Tiên Vệ Đồng cấp","ghiChu":"Cứu khỏi lửa thiêu, giúp đạt Vấn Đỉnh Sơ Kỳ rồi biến thành khôi lỗi nhân thể pháp bảo (@c0608)"},{"ten":"Diêu Tích Tuyết","tag":"khac","quanHe":"Phương án dự phòng nếu luyện chế Đỗ Kiến thất bại","ghiChu":"Vương Lâm tính sẽ lấy Diêu Tích Tuyết để thử lại (@c0608)"},{"ten":"Nữ tử trong cuộn tranh","tag":"khac","quanHe":"Thân ảnh nữ tử bí ẩn hiện ra từ bức tranh trong túi trữ vật, bốn lần gọi “Đi xuống”; bị Vương Lâm chém một kiếm khiến cuộn lại im tiếng.","ghiChu":"Thân phận và mục đích chưa rõ."},{"ten":"Nữ tử trong nguyên thần","tag":"khac","quanHe":"Thanh âm nữ tử bí ẩn ẩn trong nguyên thần Vương Lâm, thúc giục “Đi xuống…” khi hắn lĩnh ngộ lực hút","ghiChu":"Chưa lộ danh tính"},{"ten":"Nữ tử trong bức tranh (La Thiên tinh vực)","tag":"doi-thu","quanHe":"Hồn nữ tử trong bức tranh, dụ Vương Lâm đưa về La Thiên tinh vực; bị hắn nhận ra âm mưu và phong ấn vĩnh viễn.","ghiChu":"@c0612"},{"ten":"Tôn Tuyết Sơn","tag":"khac","quanHe":"Người dẫn đường tới Hợp vân thánh để đền ơn cứu mạng","ghiChu":""},{"ten":"Nhiễm Thần","tag":"khac","quanHe":"Một trong bốn người được Vương Lâm cứu","ghiChu":""},{"ten":"Nhiễm Phong","tag":"khac","quanHe":"Một trong bốn người được Vương Lâm cứu","ghiChu":""},{"ten":"Nhiễm Nguyệt","tag":"khac","quanHe":"Nữ tử Nhiễm gia được hắn cứu, nghi hắn là Lôi Tiên sứ giả rồi người Hứa gia","ghiChu":"Hỏi tên, xuất thân của hắn; giải thích về Đông Lâm Tinh"},{"ten":"Tôn Vân Sơn","tag":"khac","quanHe":"Một trong bốn người được cứu, thầm khẳng định hắn là sứ giả Lôi Tiên","ghiChu":""},{"ten":"Gã thanh niên (núi đá Nhiễm Vân Tinh)","tag":"doi-thu","quanHe":"Người lạ ngồi hấp thụ tinh hoa trời đất nơi núi đá, đợi Vương Lâm đi xa mới mở mắt lộ vẻ khinh miệt","ghiChu":"Danh tính chưa lộ"},{"ten":"Văn sĩ trẻ Thanh Trúc Các","tag":"khac","quanHe":"Tiếp đón Vương Lâm, kinh khiếp khi xem phi kiếm","ghiChu":""},{"ten":"Tôn Mặc","tag":"khac","quanHe":"Người tiếp Vương Lâm tại Thanh Trúc Các, thử và trả giá phi kiếm rồi mời trưởng lão Anh Biến tới","ghiChu":"Gặp @c0619"},{"ten":"Vương Tạ","tag":"doi-thu","quanHe":"Lão quái Vân Tiên đạo lữ, thuộc phe truy tìm Vương Lâm","ghiChu":"Vương Tạ giam Tham Lang và Thần Long rồi thả ra trước mặt các lão quái; gián tiếp đặt Vương Lâm vào thế bị tố cáo giữ lệnh bài."},{"ten":"Hồ Quyên","tag":"doi-thu","quanHe":"Đạo lữ của Vương Tạ, thuộc phe lão quái","ghiChu":"Cùng Vương Tạ xuất hiện trước đám lão quái."},{"ten":"Nhiễm Nguyệt","tag":"khac","quanHe":"Nữ tu sĩ Nhiễm gia được Vương Lâm cứu khỏi vòng vây Minh vụ trùng; nàng thất kinh trước thần thông của hắn và hứa Nhiễm gia báo đáp.","ghiChu":"Gặp @c0615"},{"ten":"Tôn Tuyết Sơn","tag":"khac","quanHe":"Nam tu sĩ đi cùng nhóm Nhiễm gia, hứa dùng Xích diệu thạch báo đáp và dẫn đường tới Hợp vân thánh cho Vương Lâm.","ghiChu":"Gặp @c0615"},{"ten":"Nhiễm Thần","tag":"khac","quanHe":"Một trong ba nam bị vây, cung kính cầu Vương Lâm cứu.","ghiChu":"Gặp @c0615"},{"ten":"Nhiễm Phong","tag":"khac","quanHe":"Một trong ba nam bị vây, cung kính cầu Vương Lâm cứu.","ghiChu":"Gặp @c0615"},{"ten":"Tôn lão","tag":"khac","quanHe":"Lão già Bảo Hợp Lâu thoáng thấy bóng dáng hắn quen quen, lộ tia nghi hoặc","ghiChu":"Gặp @c0618"},{"ten":"Văn sĩ trẻ Thanh Trúc Các","tag":"khac","quanHe":"Văn sĩ nhận phi kiếm hắn trình, dùng thần thức xem rồi kinh khiếp","ghiChu":"Gặp @c0618"},{"ten":"Nữ tử trong bức tranh","tag":"doi-thu","quanHe":"Hồn nữ tử trong bức tranh dụ Vương Lâm đưa về La Thiên tinh vực; bị hắn nhận ra âm mưu và phong ấn vĩnh viễn","ghiChu":"@c0612"},{"ten":"Tôn Mặc","tag":"khac","quanHe":"Thanh niên tiếp đón tại Thanh Trúc Các, người thử và trả giá phi kiếm","ghiChu":"Tu sĩ Kết Đan, thành viên Thanh Trúc Các"},{"ten":"Người thanh niên nữ giả nam","tag":"khac","quanHe":"Người lạ ở gần chỗ trú","ghiChu":"Một phụ nữ giả nam dùng pháp thuật che mặt, tĩnh tọa thổ nạp dưới ngọn núi gần chỗ ở; lên giọng giáo huấn Vương Lâm về tu chân. Vương Lâm đã phát hiện thân phận nữ từ mấy ngày trước nhưng chưa thấy tướng mạo thật."},{"ten":"Tôn Khải Minh","tag":"khac","quanHe":"Người phụ trách tòa thành (Tôn Gia)","ghiChu":"Lão già hắc y hạ tu vi xuống Kết Đan kỳ khi vào gặp, giao hai mươi vạn tiên ngọc và lệnh bài đấu giá, đồng thời nhận lệnh tộc thăm dò tu vi Vương Lâm."},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Lão tổ Vấn Đỉnh sơ kỳ Tôn Gia tới thăm dò, bị Vương Lâm áp đảo rồi quay sang cầu cạnh","ghiChu":"Gặp @c0622, đề nghị tặng suất Lôi tiên giới"},{"ten":"Tôn Lăng","tag":"khac","quanHe":"Thanh niên Tôn Gia phòng thủ thành Bắc, kiên quyết bảo vệ Hứa Mộc trước Tôn Tích khiến Vương Lâm trầm mặc","ghiChu":"@c0622"},{"ten":"Tôn Thái","tag":"an-nhan","quanHe":"Cố nhân từ thời liên quan Cự Ma Tộc, nhận ra nhau tại Bảo Hợp Lâu","ghiChu":"Vương Lâm gọi đích danh, cuốn lão về phòng riêng tra hỏi về thần thông Cự Ma Tộc và lạc ấn (@c0624)"},{"ten":"Người đàn ông mặc hồng bào (sứ giả Nhiễm Gia)","tag":"doi-thu","quanHe":"Người Nhiễm Gia rao bán đan dược; bị Vương Lâm hô giá thấp đoạt bảo","ghiChu":"Vương Lâm trả một khối tiên ngọc, vung trảo đoạt viên thuốc khỏi tay hắn (@c0624)"},{"ten":"Tôn Thái","tag":"an-nhan","quanHe":"Ân nhân năm xưa luân lạc","ghiChu":"Năm xưa Tôn Thái từng trợ giúp Vương Lâm thoát chết trước lão tổ Cự Ma tộc; nay gặp lại, Vương Lâm hứa tiễn và mang tro cốt hắn về Ám Nguyệt tinh."},{"ten":"Lão tổ Nhiễm gia","tag":"doi-thu","quanHe":"Người tu vi cao nhất Nhiễm Vân tinh, bị Vương Lâm áp chế và ép nộp tiên ngọc dưới danh Hứa mỗ","ghiChu":"@c0627"},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Tu sĩ liên can việc bốn năm trước, bị ép nộp bảy phần tiên ngọc","ghiChu":"@c0627"},{"ten":"Tiêu Dao tán nhân (Triệu mỗ)","tag":"doi-thu","quanHe":"Người đàn ông trung niên liên can việc bốn năm trước, bị ép nộp tiên ngọc, đan dược và di vật người Huyễn gia","ghiChu":"@c0627"},{"ten":"Người tuổi trẻ (tu sĩ ở phía bắc thành)","tag":"khac","quanHe":"Tu sĩ trẻ lòng dạ thiện lương ở phía bắc thành Nhiễm Vân tinh; Vương Lâm khích lệ y giữ tâm cảnh để đạt Hóa Thần.","ghiChu":"Gặp lại @c0628."},{"ten":"Huyễn Đông","tag":"doi-thu","quanHe":"Tộc vệ Huyễn gia đến đòi giết người tham dự; bị Vương Lâm đánh trọng thương phải bỏ chạy về bẩm báo.","ghiChu":"@c0629"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Cừu hận sâu từ Chu Tước tinh; nay là Huyễn Mi, con gái nuôi của Lão tổ Huyễn gia","ghiChu":"Vương Lâm cảnh báo nếu nàng càn quấy thì chỉ có thể giết (@c0630)"},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Lão tổ Nhiễm gia kiêng kỵ Vương Lâm, được giao Huyễn Đông để xử lý","ghiChu":"@c0630"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Lão tổ muốn quan hệ tốt với Hứa Mộc, giải thích chuyện Lão tổ Huyễn gia và Huyễn Mi","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Cố nhân hóa địch","ghiChu":"Tái ngộ ở Nhiễm Vân tinh; Liễu Mi nhận ra qua ánh mắt, quyết không cho Vương Lâm đi và khai chiến. @c0633"},{"ten":"Tôn Tích","tag":"khac","quanHe":"Người từng cầu nhờ","ghiChu":"Tôn Tích từng tìm Vương Lâm vì việc liên quan phân thân nhưng bị từ chối. @c0633"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[{"ten":"Tiên ngọc","loai":"tài nguyên tu luyện","trangThai":"dang-co","moTa":"123.600 khối tiên ngọc lấy từ Phẩm Linh Các, dùng để hấp thu đột phá Anh Biến trung kỳ","nguon":"@c0458"}],"linhThao":[],"khac":[{"ten":"Lệnh bài Phẩm Linh Các","loai":"vật phẩm","trangThai":"da-dung","moTa":"Lệnh bài lấy tiên ngọc, ấn vào trận pháp ba đạo bạch ngân để mở cửa truyền tống lên tầng bảy và xác nhận thân phận lĩnh tiên ngọc","nguon":"@c0458"}]}},"nguon":["@c0458","@c0459","@c0460","@c0461","@c0462","@c0463","@c0464","@c0465","@c0466","@c0467","@c0468","@c0469","@c0470","@c0471","@c0472","@c0473","@c0474","@c0476","@c0477","@c0478","@c0479","@c0480","@c0483","@c0484","@c0485","@c0487","@c0488","@c0489","@c0490","@c0491","@c0492","@c0493","@c0494","@c0495","@c0496","@c0497","@c0498","@c0499","@c0500","@c0501","@c0502","@c0503","@c0504","@c0505","@c0506","@c0507","@c0508","@c0509","@c0510","@c0511","@c0512","@c0513","@c0514","@c0515","@c0516","@c0517","@c0518","@c0519","@c0520","@c0522","@c0523","@c0524","@c0525","@c0526","@c0527","@c0528","@c0529","@c0530","@c0531","@c0532","@c0533","@c0534","@c0535","@c0536","@c0521","@c0537","@c0538","@c0539","@c0540","@c0542","@c0543","@c0545","@c0541","@c0546","@c0547","@c0548","@c0549","@c0550","@c0551","@c0552","@c0553","@c0554","@c0555","@c0556","@c0557","@c0558","@c0559","@c0560","@c0562","@c0563","@c0564","@c0567","@c0570","@c0571","@c0573","@c0574","@c0576","@c0578","@c0579","@c0583","@c0584","@c0589","@c0591","@c0594","@c0595","@c0596","@c0601","@c0602","@c0603","@c0604","@c0605","@c0606","@c0608","@c0609","@c0611","@c0613","@c0614","@c0615","@c0610","@c0612","@c0616","@c0617","@c0618","@c0619","@c0621","@c0620","@c0622","@c0623","@c0625","@c0626","@c0627","@c0628","@c0629","@c0630","@c0631","@c0632","@c0633","@c0634","@c0624"],"aliases":["Hứa Mộc","Hứa mỗ","Hứa huynh"]},{"id":"trieu-tinh-sat","name":"Triệu Tinh Sát","gioiTinh":"nam","tabs":{"diem":[],"kinhLich":[{"text":"Sắc mặt ôn hòa tiêu sái, Triệu Tinh Sát hiện ra từ gợn sóng bên cạnh Vương Lâm, là một trong năm người hợp vây tại Tử Lâm Các.","bridge":true,"khoang":"@c0458"},{"text":"Trong khi canh giữ tử vụ đại trận trước thọ yến, độc thoại điểm danh sáu vị tử còn lại (lão nhị bỏ cuộc, lão tam không để vào mắt, lão tứ nữ có cách giữ, lão ngũ bị phạt thiên ngục, lão lục xuất ngoại sinh tử chưa rõ), cảnh cáo lão thất chớ tranh đoạt với mình.","bridge":true,"khoang":"@c0460"},{"text":"Nhận ra Kim Ma tử trên chiến xa vàng, toát mồ hôi lạnh cung kính ra mắt rồi dẫn đường đưa chiến xa về Thiên Vận Tinh dự thọ yến.","bridge":true,"khoang":"@c0460"},{"chuong":"@c0461","importance":"normal","tieuDe":"Chủ tọa thọ yến Thiên Vận Tử","text":"Đại sư huynh Tử hệ nhất mạch ngồi chủ tọa tiệc thọ yến ngàn năm của sư tôn Thiên Vận Tử; vừa đứng dậy chúc rượu thì Vương Lâm — kẻ hắn từng mượn sức người ngoài na di vây khốn trong thạch lâm — xuất hiện thành cầu vồng tím từ chân trời đằng đông lao thẳng tới."},{"text":"Sắc mặt cực xấu khi thấy Vương Lâm phá vây đạt Anh Biến Trung Kỳ, bóp nát chén rượu. Lão bước ra chắn trước nhị sư huynh, thi triển Đại tự tại thiên địa quyết tạo quầng sáng trắng bọc ma hỏa, nhưng bị ma hỏa tự bạo thiêu vỡ nên phải lui lại.","bridge":true,"khoang":"@c0462"},{"text":"Sau khi cản thất bại, Triệu Tinh Sát đứng nhìn Hứa Lập Quốc bị Vương Lâm truy sát mà cười lạnh, không hề ra tay cứu, hé lộ rạn nứt và toan tính trong nội bộ Tử hệ.","bridge":true,"khoang":"@c0462"},{"text":"Bị Vương Lâm dồn ép và bị lão tứ từ chối trợ giúp, Triệu Tinh Sát dùng trước thuật triệu Cổ Yêu vốn định để dành cho dịp tranh danh hiệu Thiên Vận Thất Tử. Ký hiệu cổ quái lóe giữa lông mày gọi ra hư ảnh yêu vật trăm trượng, nhưng càng dùng thân thể hắn càng suy yếu.","bridge":true,"khoang":"@c0463"},{"chuong":"@c0463","importance":"normal","tieuDe":"Phản phệ và tham kiến Xích Liệt","text":"Cổ yêu bị tiếng hét của Xích Liệt buộc rút lui, Triệu Tinh Sát phun máu, cười u ám nhìn Vương Lâm. Hắn cung kính tham kiến Xích Liệt sư thúc, xác nhận mấy ngàn năm trước khi mới bái nhập Thiên Vận Tông từng gặp mặt một lần."},{"chuong":"@c0464","importance":"normal","tieuDe":"Bị Xích Liệt áp giải","text":"Sau khi gượng dùng yêu linh chưa kịp luyện hóa, Triệu Sát Tinh bị Xích Liệt túm mang đi để sư phụ trừng phạt, mất chức chủ yến hội về tay Vương Lâm."}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tham gia nhóm năm người vây kích Vương Lâm","ghiChu":"@c0458"},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"sư tôn","ghiChu":"Triệu Tinh Sát là đại sư huynh Tử hệ thuộc Thiên Vận Thất tử của Thiên Vận Tử."},{"ten":"Kim Ma tử","tag":"khac","quanHe":"khách chúc thọ","ghiChu":"Cung kính nghênh đón, dẫn đường về Thiên Vận Tinh."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"đối thủ ngầm (nghi là lão thất)","ghiChu":"Triệu Tinh Sát cảnh cáo lão thất, đối tượng có thể chính là Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Sư đệ bị hắn chèn ép, na di vây khốn","ghiChu":"Vương Lâm trở về quyết báo thù giữa thọ yến."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối đầu, cản bất thành rồi bị ma hỏa đánh lui","ghiChu":""},{"ten":"Hứa Lập Quốc","tag":"khac","quanHe":"Đồng môn Tử hệ mà Triệu Tinh Sát bỏ mặc không cứu","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ, bị hắn tố giết lão nhị","ghiChu":"Định dùng Cổ Yêu trừ Vương Lâm nhưng thất bại."},{"ten":"Tứ sư tỷ (Tử hệ)","tag":"khac","quanHe":"Cầu viện trợ nhưng bị từ chối","ghiChu":"Lão tứ viện cớ đã đền ân ba tháng trước và không tranh danh hiệu."},{"ten":"Xích Liệt","tag":"su-mon","quanHe":"Sư thúc Thiên Vận Tông","ghiChu":"Tham kiến cung kính, từng gặp mấy ngàn năm trước."},{"ten":"Xích Liệt","tag":"su-mon","quanHe":"Tiền bối tông môn áp giải","ghiChu":"Bị Xích Liệt túm đi sau khi gượng dùng yêu linh."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0458","@c0460","@c0461","@c0462","@c0463","@c0464"],"aliases":["Triệu Sát Tinh"]},{"id":"tu-ma-nhu-phong","name":"Tư Mã Như Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Lam tông (Thiên Vận Tông)","trangThai":"gan-bo"},{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến kỳ","trangThai":"song","blurb":"Đệ tử đứng hàng thứ hai thuộc Lam tông của Thiên Vận Tông, y phục lam thêu ba con lam long, tươi cười ôn hòa nhưng tham gia vây kích Vương Lâm.","vaiTro":"Đệ tử Lam tông Thiên Vận Tông, một trong năm người vây kích Vương Lâm","tinhCach":[{"text":"Tươi cười ôn hòa nhưng ngầm hiểm, khéo quan sát đối thủ","chuong":"@c0458"}],"tabs":{"diem":[{"text":"Y phục lam thêu ba con lam long, đứng hàng thứ hai trong đệ tử Lam tông","chuong":"@c0458"}],"kinhLich":[{"text":"Tư Mã Như Phong tươi cười hiện thân trong nhóm vây kích Vương Lâm tại Tử Lâm Các, đoán Vương Lâm đã Anh Biến hậu kỳ đại viên mãn, rồi giới thiệu một vị sư huynh ẩn mình mạnh hơn hẳn.","bridge":true,"khoang":"@c0458"},{"importance":"normal","chuong":"c0615","text":"Nam tu sĩ Nhiễm gia Nhiễm Vân Tinh (La Thiên Tinh Vực), Anh Biến sơ kì; một trong ba nam đi cùng Nhiễm Nguyệt, Nhiễm Thần, Tôn Tuyết Sơn","nguonNblm":true},{"importance":"normal","chuong":"c0627","text":"Gia chủ Huyễn gia tại Thiên Huyễn tinh phía nam; giải thích người mất tích chỉ là tộc nhân chi nhánh tu vi Vấn Đỉnh trung kỳ, được lão tổ cho thêm ba tháng tìm người đủ tư cách hơn","nguonNblm":true},{"importance":"normal","chuong":"c0631","text":"Bị tông chủ Loan Phượng tinh ra lệnh truy nã, bị hai cô gái áo rực rỡ dùng quả cầu ánh sáng đỏ ép trời đất truy sát gần trăm năm","nguonNblm":true},{"importance":"normal","chuong":"c0609","text":"Năm xưa từng có cảnh giới âm dương hư thực — được Vương Lâm dùng làm mốc so sánh khí tức Tiên Vệ","nguonNblm":true},{"importance":"normal","chuong":"c0628","text":"Theo lời ông, hạt châu Thiên Nghịch tràn đầy (đủ tính kim loại) thì có thể nhận chủ","nguonNblm":true},{"importance":"normal","chuong":"c0618","text":"Tu vi Hóa Thần (theo lời Lô Phong mơ hồ biết: Tôn lão từng đạt Anh Biến trung kì rồi tụt xuống Hóa Thần); nhưng đây là thông tin về Tôn lão — phần riêng Lô Phong: gã có quan hệ cung kính, kính nể Tôn lão ở Bảo Hợp Lâu, không dám nói hết sự thật với Tôn lão.","nguonNblm":true}],"tuViMoc":[],"tuVi":"Đệ tử Anh Biến kỳ đứng hàng thứ hai thuộc Lam tông Thiên Vận Tông.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tham gia vây kích, đoán định tu vi Vương Lâm","ghiChu":"@c0458"},{"ten":"Người y phục xanh (như tượng băng)","tag":"dong-minh","quanHe":"Giới thiệu vị sư huynh ẩn mình nửa bước vấn đỉnh","ghiChu":"@c0458"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0458"]},{"id":"tu-su-ty-tu-he","name":"Tứ sư tỷ (Tử hệ)","cn":"","aliases":["Tứ sư tỷ","Tứ sư tỷ (Tử hệ)"],"gioiTinh":"nu","theLuc":[{"ten":"Tử hệ (Thiên Vận Tông)","trangThai":"gan-bo"},{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ","trangThai":"song","blurb":"Nữ tử Anh Biến hậu kỳ thuộc Tử hệ Thiên Vận Tông; được người nhờ vả nên ra tay, thi triển Tử thuật - Na di trong cuộc vây kích Vương Lâm.","vaiTro":"Sư tỷ đồng hệ Tử của Vương Lâm, một trong năm người vây kích","tinhCach":[{"text":"Bất đắc dĩ ra tay vì chịu lời nhờ vả của người khác","chuong":"@c0458"}],"tabs":{"diem":[{"text":"Anh Biến hậu kỳ, thuộc Tử hệ và sử dụng Tử thuật","chuong":"@c0458"}],"kinhLich":[{"text":"Bất đắc dĩ thừa nhận được người nhờ vả, tứ sư tỷ bắt quyết điểm vào hư không, một tia sáng bạc lan ra bao trùm mười dặm, mở màn cuộc vây kích Vương Lâm tại Tử Lâm Các.","bridge":true,"khoang":"@c0458"},{"text":"Tứ sư tỷ — nữ tử xinh đẹp như tiên tử đội mũ tơ tằm — dùng thần thông na di đưa Vương Lâm tới thạch lâm khốn địa, hứa sau ba năm sẽ tới thả ra và truyền thần thông na di cho hắn khi mọi chuyện giải quyết xong. Trước khi rời đi, nàng nói với đại sư huynh rằng nhân tình năm đó nay đã hồi báo, từ nay hai người không còn liên quan, rồi hóa ngân quang bay về Thiên Vận Tông.","bridge":true,"khoang":"@c0459"},{"text":"Khi Triệu Tinh Sát lớn tiếng cầu viện, lão tứ bình thản đáp ân tình ba tháng trước đã đền đáp và đã đồng ý không tranh đoạt danh hiệu Thiên Vận Thất Tử với hắn, đòi một lý do mới chịu ra tay. Triệu Tinh Sát cắn răng tức giận mất chỗ dựa.","bridge":true,"khoang":"@c0463"},{"chuong":"@c0464","importance":"normal","tieuDe":"Trao ngọc giản hai cấm pháp","text":"Đêm khuya yến tàn, tứ sư tỷ đưa Vương Lâm một ngọc giản chứa cấm pháp đại na di cùng một cấm pháp do sư tôn phỏng theo hạ phẩm tiên thuật sáng tạo, coi như xin lỗi việc tháng trước — lúc đó nàng dùng cấm pháp phong ấn nhưng chưa thực sự ra tay."},{"bridge":true,"khoang":"@c0465","text":"Trong thọ yến, Tứ sư tỷ truyền âm than thở với Vương Lâm rằng Tử Tông đang sa sút vì tranh đoạt nội bộ quá nhiều, danh hiệu Thiên Vận Thất Tử thay đổi thường xuyên, không còn uy phong như thời Tôn Vân sư đệ năm xưa."},{"bridge":true,"khoang":"@c0468","text":"Tứ sư tỷ thần thái như thường, bình tĩnh trụ vững khảo nghiệm áp lực cùng Vương Lâm; khi thấy hắn vượt trội nàng liếc một cái đầy thâm ý nhưng không nói gì."},{"text":"Sau khi Bạch Vi bỏ cuộc, Triệu Hân Mộng nhíu mắt nhìn Vương Lâm, đòi giao chiến một trận để hắn không đạt phong hiệu quá đơn giản. Khi khai chiến nàng giật lui hơn mười trượng, vận Tử Ma thủ — thần thông tự sáng chế bằng cách mô phỏng Hoá Ma chỉ của Vương Lâm — đẩy tử quang gào rít lao tới.","bridge":true,"khoang":"@c0469"},{"text":"Triệu Hân Mộng bắt chước Tử Ma thủ dụ Vương Lâm dùng Hoá Ma chỉ để cướp ma lực, định không tranh phong hiệu Thiên Vận Thất tử với hắn. Nàng dùng hạt châu trắng hút ma lực khiến nó hoá đen, nhưng Vương Lâm khiến ma lực hư ảo tự sụp, hạt châu vỡ vụn; nàng đe doạ nhưng bị từ chối.","bridge":true,"khoang":"@c0470"},{"text":"Nàng thi Cửu chuyển luyện tiên quyết tu ra kim sắc lốc xoáy năm vòng, nhưng kinh ngạc khi Vương Lâm chỉ vài ngày đã đạt ngũ chuyển lại rút chiến phủ và Xạ Thần xa. Triệu Hân Mộng thừa nhận đã xem thường hắn rồi rời đi, sau đó truyền âm cho Trần Đào về việc Tôn Vân.","bridge":true,"khoang":"@c0470"},{"importance":"normal","chuong":"c0610","text":"Sát Lục Tiên Quyết do Thiên Vận Tử truyền thực chất là cạm bẫy trí mạng: khi tu luyện sinh ra Sát Lục Chi Tâm, về sau dị biến có thể khiến Vương Lâm phát điên, thậm chí kích động hủy bỏ toàn bộ Sát Lục Chi Khí.","nguonNblm":true}],"tuViMoc":[],"tuVi":"Nữ tử Anh Biến hậu kỳ thuộc Tử hệ Thiên Vận Tông.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đồng hệ Tử nhưng ra tay vây kích theo lời nhờ vả","ghiChu":"@c0458"},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Sư đệ đồng môn (lão thất)","ghiChu":"Đích thân na di đưa hắn tới khốn địa, hẹn ba năm thả; hứa truyền thần thông na di."},{"ten":"Đại sư huynh (Thiên Vận Tông)","tag":"doi-thu","quanHe":"Sư huynh đồng môn, từng có nhân tình","ghiChu":"Tuyên bố nhân tình năm xưa đã hồi báo, cắt đứt quan hệ với đại sư huynh."},{"ten":"Triệu Tinh Sát","tag":"khac","quanHe":"Người từng chịu ân, nay cầu viện","ghiChu":"Lão tứ từ chối trợ giúp."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Sư đệ cùng Tử hệ","ghiChu":"Trao ngọc giản hai cấm pháp xin lỗi việc tháng trước."},{"ten":"Tôn Vân","tag":"su-mon","quanHe":"Sư đệ Tử Hệ thời còn uy phong, được nhắc lại khi than về sự sa sút","ghiChu":""},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Đồng môn Tử hệ","ghiChu":"Hai người duy nhất của Tử hệ trụ vững khảo nghiệm; Tứ sư tỷ liếc Vương Lâm đầy thâm ý trước biểu hiện vượt trội của hắn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Lão Thất đồng môn","ghiChu":"Khiêu chiến và giao chiến với Vương Lâm; mô phỏng Hoá Ma chỉ của hắn thành Tử Ma thủ."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư phụ"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Thất sư đệ Tử hệ (giả danh)","ghiChu":"Gài bẫy hấp thu ma lực bất thành, đánh giá thấp rồi bỏ cuộc."},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Đồng môn Tử hệ","ghiChu":"Truyền âm cho Trần Đào về việc Tôn Vân khiến hắn biến sắc."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Tử thuật - Na di","moTa":"Pháp thuật Tử hệ, bắt quyết điểm vào hư không phát tia sáng bạc bao trùm mười dặm","nguon":"@c0458"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0458","@c0459","@c0463","@c0464","@c0465","@c0468","@c0469","@c0470"]},{"id":"nguoi-y-phuc-xanh-tuong-bang","name":"Người y phục xanh (như tượng băng)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nửa bước vấn đỉnh kỳ","trangThai":"song","blurb":"Vị sư huynh ẩn mình do Tư Mã Như Phong giới thiệu; lạnh lùng như chúa tể thiên hạ, tu vi đã bước nửa bước vào vấn đỉnh kỳ.","vaiTro":"Cường giả ẩn mình trong nhóm vây kích Vương Lâm","tinhCach":[{"text":"Lạnh lùng kiêu ngạo, đứng như tượng băng ngàn năm, coi đối thủ không xứng để ra tay","chuong":"@c0458"}],"tabs":{"diem":[{"text":"Tu vi nửa bước vấn đỉnh kỳ, ánh mắt đầy vẻ chúa tể thiên hạ","chuong":"@c0458"}],"kinhLich":[{"text":"Một tiếng nói lạnh như băng vang lên, người y phục xanh xuất hiện sau lưng Vương Lâm vài chục trượng, đứng như tượng băng ngàn năm, liếc một cái rồi nhắm mắt dưỡng thần vì coi Vương Lâm không xứng để ra tay.","bridge":true,"khoang":"@c0458"},{"importance":"normal","chuong":"c0619","text":"Tu vi Anh Biến hậu kỳ (chưa hoàn hảo); được Tôn Mặc cung kính mời ra mặt khi Vương Lâm tới Thanh Trúc Các","nguonNblm":true},{"importance":"normal","chuong":"c0622","text":"Tu sĩ Khuy Niết Kỳ, người gia tộc Huyễn Gia trên La Thiên Tinh Vực; vài ngàn năm chưa quay về quê hương","nguonNblm":true},{"importance":"normal","chuong":"c0630","text":"Cũng có Tiên Vệ trong tay (theo trí nhớ Huyễn Đông bị moi); Liễu Mi (Huyễn Mi) là đệ tử duy nhất, gia chủ Huyễn gia tương lai","nguonNblm":true}],"tuViMoc":[],"tuVi":"Tu vi đã bước nửa bước vào vấn đỉnh kỳ.","nhanMach":[{"ten":"Tư Mã Như Phong","tag":"dong-minh","quanHe":"Được Tư Mã Như Phong giới thiệu là sư huynh ẩn mình","ghiChu":"@c0458"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tham gia vây kích nhưng coi Vương Lâm không xứng để ra tay","ghiChu":"@c0458"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0458"]},{"id":"thuy-to-thien-van-tong","name":"Thủy tổ đại nhân (Thiên Vận Tông)","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Thủy tổ của Thiên Vận Tông; từng dặn chỉ cần Vương Lâm không phạm môn quy thì khỏi quản, và cạnh tranh nội bộ giữa đệ tử của ông cực kỳ khốc liệt.","vaiTro":"Thủy tổ tông môn Thiên Vận Tông, được nhắc tên","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Được ba chấp pháp trưởng lão nhắc tới: Thủy tổ từng dặn chỉ cần Vương Lâm không phạm môn quy thì khỏi quản; cạnh tranh nội bộ giữa các đệ tử của ông cực kỳ khốc liệt.","bridge":true,"khoang":"@c0458"},{"importance":"normal","chuong":"c0613","text":"Cùng Thiên Vận Tử, Huyết Tổ và bảy tám lão giả vào sớm mười năm; mở cửa Yêu Linh chấn động chín quận, bảy luồng cầu vồng phóng ra, quát gọi Tham Lang vì bổn mạng thần đăng của Kiếm Tiếu Thập Nhị Tử bị dập chín ngọn.","nguonNblm":true},{"importance":"normal","chuong":"c0614","text":"Là sư tôn của Thần Long; phẫn nộ khi thấy Thất Tinh kiếm trận; cố kỵ Vân Tiên đạo lữ (Vương Tạ, Hồ Quyên) nên không dám ra tay.","nguonNblm":true},{"importance":"normal","chuong":"c0616","text":"Một trong bốn người (cùng Nhiễm Nguyệt, Tôn Tuyết Sơn) được Vương Lâm cứu khỏi Minh vụ trùng và sấm sét; sắc mặt biến đổi khi Nhiễm Nguyệt hỏi về Lôi Tiên sứ giả, thầm khẳng định Vương Lâm chính là sứ giả của Lôi Tiên.","nguonNblm":true},{"importance":"normal","chuong":"c0615","text":"Nam tu sĩ đi cùng nhóm Nhiễm gia (Nhiễm Nguyệt, Nhiễm Thần, Nhiễm Phong) từ La Thiên Tinh Vực; tu vi Anh Biến sơ kì, người La Vân Tinh Vực.","nguonNblm":true},{"importance":"normal","chuong":"c0623","text":"Là vãn bối Tôn Gia; Tôn Tích nhận xét tu vi khá cao nhưng thiếu kinh nghiệm, cảm kích vì \"Hứa huynh\" (Vương Lâm) đã cứu mạng hắn.","nguonNblm":true},{"importance":"normal","chuong":"c0619","text":"Thanh niên tu sĩ Kết Đan tại Thanh Trúc Các (Nhiễm Vân Tinh, La Thiên Tinh Vực); thử phi kiếm Vương Lâm bán, đánh giá tính dung hợp đạt linh bảo bậc trung-cao","nguonNblm":true},{"importance":"normal","chuong":"c0621","text":"Tộc nhân đời thứ ba Tôn Gia, phụ trách tòa thành Vương Lâm trú; lão già mặc hắc y, tu vi vốn cao, tự hạ xuống Kết Đan kỳ khi vào gặp.","nguonNblm":true},{"importance":"normal","chuong":"c0624","text":"Ngồi cạnh Tôn Tích tầng bốn; đông cứng, hồi lâu không nói nên lời trước màn ra giá của Vương Lâm.","nguonNblm":true},{"importance":"normal","chuong":"c0622","text":"Tu vi Nguyên Anh kỳ, người Tôn Gia phụ trách phòng thủ cổng thành Bắc; tư chất không tốt nhưng cần cù, tĩnh tọa thổ nạp dưới ngọn núi","nguonNblm":true},{"importance":"normal","chuong":"c0625","text":"Vốn là Đại trưởng lão Thi Âm Tông chi Chu Tước tinh, tu vi từng đạt Anh Biến (trước khi luân lạc).","nguonNblm":true},{"importance":"normal","chuong":"c0626","text":"Tặng Vương Lâm túi trữ vật (hơn năm vạn tiên ngọc cùng tâm đắc luyện đan luyện khí), buông bỏ chấp niệm khôi phục tu vi và oán hận mấy trăm năm, tập tễnh rời đi dưới ánh chiều tà.","nguonNblm":true},{"importance":"normal","chuong":"c0629","text":"Phái thuộc hạ Huyễn Đông đến Nhiễm Vân tinh lập uy, ra lệnh diệt người tham dự; Huyễn Đông định bẩm báo nếu thất bại, báo trước thế lực Huyễn gia sẽ truy đến.","nguonNblm":true}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Thủy tổ tông môn, ra lệnh không quản chừng nào Vương Lâm chưa phạm môn quy","ghiChu":"@c0458"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0458"]},{"id":"kim-ma-tu","name":"Kim Ma tử","gioiTinh":"nam","tabs":{"diem":[{"text":"Tôn giả độc chiếm một tiểu tinh, hoành hành ngang ngược, tính nóng nảy, giết người vô số.","chuong":"@c0460"},{"text":"Thân to như quả cầu thịt, da trong suốt như thủy tinh.","chuong":"@c0460"}],"kinhLich":[{"text":"Đáp chiến xa vàng cao hơn ngàn trượng do bốn yêu thú khổng lồ nâng đỡ, kèm mười tùy tùng trường sam bạc, tới Thiên Vận Tinh dự thọ yến; được Triệu Tinh Sát cung kính dẫn đường, thân phận chỉ đủ ngồi ở thọ tiệc do Xích tông tổ chức.","bridge":true,"khoang":"@c0460"},{"importance":"normal","chuong":"c0612","text":"Hồn/ý thức trong bức tranh, chỉ lộ bóng lưng; tự xưng thuộc Hướng gia ở Đông Lâm tinh, La Thiên tinh vực (Lôi tiên giới)","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0460","canhGioi":"Thông thiên (đồn đạt Hư Thật nhị ý)","text":"Tu vi loại thông thiên, có lời đồn đã chạm tới cảnh giới truyền thuyết Hư Thật nhị ý.","importance":"major"}],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"khách chúc thọ","ghiChu":"Tự thân tới chúc đại thọ ngàn năm."},{"ten":"Triệu Tinh Sát","tag":"khac","quanHe":"người nghênh đón","ghiChu":"Được dẫn đường về Thiên Vận Tinh."}],"tuiDo":{"phapBao":[{"ten":"Chiến xa màu vàng của Kim Ma tử","trangThai":"dang-co","moTa":"Chiến xa khổng lồ cao hơn ngàn trượng đầy mũi nhọn, bốn yêu thú nâng đỡ; trên xe có ghế lớn và mười tùy tùng.","nguon":"@c0460"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"theLuc":[{"ten":"Thiên Vận Tông","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Thông thiên","trangThai":"song","vaiTro":"Tôn giả độc chiếm một tiểu tinh thuộc Thiên Vận Tông, khách chúc thọ Thiên Vận Tử.","blurb":"Tôn giả thân tròn như cầu thịt da trong như thủy tinh, hoành hành ngang ngược, tu vi thông thiên đồn đạt Hư Thật nhị ý.","nguon":["@c0460"]},{"id":"thien-van-tu","name":"Thiên Vận Tử","cn":"","aliases":["Sư tôn Tử tông","#thien-van-tu-su-ton"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Sư tôn của Tử tông trong Thiên Vận Tông, được tông môn mở thọ yến ngàn năm và sẽ giảng đạo sau bảy ngày.","vaiTro":"Sư tôn của Tử hệ nhất mạch, nhân vật cấp cao trên Thiên Vận Tinh.","tinhCach":[],"tabs":{"diem":[{"text":"Bậc sư tôn được cả Tử tông tổ chức thọ yến ngàn năm","chuong":"@c0461"}],"kinhLich":[{"text":"Thiên Vận Tông mở thọ yến ngàn năm mừng sư tôn Thiên Vận Tử, bày tiệc tiên quả sơn tửu náo nhiệt; bảy ngày thọ yến xong sẽ là ngày Thiên Vận Tử giảng đạo, một tháng sau là kỳ Tử Hoàng nhị tông tranh đoạt danh hiệu Thiên Vận Thất tử.","bridge":true,"khoang":"@c0461"},{"text":"Thiên Vận Tử xuất hiện trên quầng sáng bảy màu, được đệ tử đích hệ bảy tông và vô số tu sĩ tham bái. Ông mời lão bằng hữu Tôn trưởng lão từ tu chân liên minh xuất hiện, nhận phi kiếm trung phẩm tiên khí rồi tặng lại Côn Bằng Tử, sau đó khoanh chân ngồi giảng Thiên Vận Chi Đạo với cốt lõi ‘nghe theo mệnh trời’.","bridge":true,"khoang":"@c0465"},{"text":"Ngồi khoanh chân trên tường vân, Thiên Vận Tử giảng đạo cho đệ tử lục hệ và tu sĩ bốn phía: liệt kê bảy cảnh Ngưng Khí tới Vấn Đỉnh thuộc chữ ‘tu’ (bước một), bước hai là hư thực nhị ý và toái niết tam cảnh nơi hầu hết tu sĩ phải dừng chân, bước ba là chữ ‘đạo’ cầu thiên vận. Hắn phân biệt tu tiên, tu chân, tu đạo và thừa nhận chính mình bước một còn chưa hoàn thành.","bridge":true,"khoang":"@c0466"},{"text":"Đáp lời hoài nghi của Vương Lâm, Thiên Vận Tử than nhẹ lộ vẻ bồi hồi hiếm thấy, kể rằng ba ngàn năm trước hắn cũng không tin có bước thứ ba cho tới khi gặp được ‘hắn’ — một nhân vật bí ẩn cực mạnh.","bridge":true,"khoang":"@c0466"},{"text":"Kết thúc ba ngày giảng đạo nhân đại thọ vạn năm, trước truy hỏi của tu sĩ, Thiên Vận Tử tiết lộ về “hắn” — kẻ duy nhất lão biết đã đạt tới bước thứ ba và từng khiến Tu Chân Liên Minh nếm khổ một lần. Sau đó lão tuyên bố thi triển một trung phẩm Tiên thuật tên Dẫn Tiên thuật, lấy Lăng Thiên Hầu làm đối tượng, phóng xích mang lên trời hiện mảnh màu đỏ mây cuộn như rồng kèm thiên uy giáng xuống.","bridge":true,"khoang":"@c0467"},{"text":"Trong đại thọ vạn năm tuổi, Thiên Vận Tử thi triển Dẫn Tiên thuật (Trung phẩm Tiên thuật), hô “Dẫn độ” cuốn hơn vạn đệ tử Đại La Kiếm Tông mê man bay lên hư không, triệu hư ảnh sứ giả Tiên giới ấn chưởng phong kín; làm nhục Kiếm Tôn Lăng Thiên Hầu và hứa ba ngày sau trả người.","bridge":true,"khoang":"@c0468"},{"text":"Lão công bố trong bảy hệ đệ tử chỉ Hoàng hệ và Tử hệ chưa ai nắm phong hiệu Thiên Vận Thất tử, hôm nay sẽ xuất hiện người mang phong hiệu từ hai hệ này; nh��c lại lão Tam Hoàng hệ từng đạt phong hiệu rồi mất tích ở tinh không ba mươi năm trước.","bridge":true,"khoang":"@c0468"},{"text":"Thiên Vận Tử chủ trì phân phong hiệu Thiên Vận Thất tử, trao tinh thể vàng cho Côn Bằng Tử của Hoàng hệ và nhấn mạnh phong hiệu là dấu hiệu thân phận của Thiên Vận Tông. Khi Vương Lâm định bỏ cuộc, lão ngẩn ra rồi đích thân khuyên giải, cho nửa nén hương suy xét, dặn đừng để người ngoài mê hoặc; lão liếc Vận Đường bằng ánh mắt âm trầm khiến lão này run sợ.","bridge":true,"khoang":"@c0469"},{"text":"Lão hé lộ ba vạn năm trước từng gặp ‘hắn’, người để lại lời rằng chỉ khi tìm được kẻ phù hợp số phận mới tiến được bước thứ ba của Thiên Vận đạo. Suốt ba vạn năm lão thất bại vô số lần, tổn thất hơn nửa đệ tử, nay chăm chú nhìn ngón trỏ Vương Lâm để xét hắn có phải người đó, ánh mắt cuối cùng lộ một tia chán nản.","bridge":true,"khoang":"@c0469"},{"text":"Sắp đại thọ vạn năm, Thiên Vận Tử nhận đoá Thất thải lưu ly quang từ Trần Đào, phán chỉ Trần Đào và Vương Lâm đủ tư cách tranh phong hiệu Thiên Vận Thất tử nhưng chỉ một người đạt; hắn tán thưởng cả hai trong trận giao đấu.","bridge":true,"khoang":"@c0470"},{"text":"Tuyên Trần Đào thắng và trao phong hiệu Thiên Vận Thất tử của Tử hệ; kết thúc đại thọ vạn năm tuổi khiến tu sĩ tản đi. Nhận Vương Lâm làm đệ tử chân chính, đưa về Tổng tông ba ngọn núi tại Thiên Vận Tinh, khảo Vương Lâm câu đố Chân huyễn pháp rồi sắp đặt khảo nghiệm leo Toái Tiên chi địa.","bridge":true,"khoang":"@c0472"},{"text":"Thiên Vận Tử triệu Vương Lâm lên đỉnh, kể nguồn gốc Thiên Vận Tông: tổ tiên không phải tu sĩ mà là Thiên vận số, cả đời theo đuổi Thiên vận, tin hết thảy vận số là trời định. Lão vốn không định tới Chu Tước Tinh, vừa lúc gặp Vương Lâm đang cảm ngộ Hóa Thần tìm bản nguyên thiên đạo nên vì quý tài và vận số thầy trò mà thu làm đệ tử thứ bảy của Tử hệ. Lão xé không trung tỏa ánh sáng bảy màu Tối hỉ thất thải chiếu rọi gần nửa bầu trời Thiên Vận Tinh, rồi hỏi Vương Lâm chọn loại Cấm pháp thần thông nào.","bridge":true,"khoang":"@c0473"},{"text":"Thiên Vận Tử bình tĩnh để Vương Lâm tự chọn thần thông, từ chối yêu cầu ‘Sinh tồn pháp thuật’ (vi sư không có), rồi nâng tay phải điểm ánh sáng bảy màu, mở ra thế giới bảy màu chứa 3600 đạo Cấm pháp thần thông để đệ tử chọn theo cơ duyên. Lão sở hữu thần thông bảy màu (Tối hỷ khẩu thất thải) và từng có hứa hẹn với Thiên Vận Tử áo xám.","bridge":true,"khoang":"@c0474"},{"text":"Ngày thành đạo từng mời bạn tốt (gồm Kiếm Tôn Lăng Thiên Hậu) lập nhóm đến Đông Hải thăm dò ba lần: hai lần đầu về tay không, lần thứ ba vào được bên trong nhưng ra chỉ còn nửa quân số; sau đó tách với Lăng Thiên Hậu, không ai nói ra chuyện đã xảy ra.","bridge":true,"khoang":"@c0486"},{"text":"Tuyên bố trong Đông Hải có Cổ Yêu tồn tại, lập nơi này thành một trong những cấm địa — cửa Đông Hải Yêu Linh; cùng Lăng Thiên Hậu và các lão quái thống nhất không cho người ngoài tiến vào, khiến Tu Chân Liên Minh đành để mặc.","bridge":true,"khoang":"@c0486"},{"text":"Thiên Vận Tử mặc áo trắng từ đám mây bảy màu bước ra, dẫn chín đệ tử Thiên Vận Tông tới cửa Đông Hải Yêu Linh và được nghênh đón long trọng nh��t. Lão cùng Trần Đào tìm kiếm Vương Lâm, khi hắn tới thì bảo đứng phía sau, nhắc xem trọng việc trọng đại và nhìn hắn đầy thâm ý.","bridge":true,"khoang":"@c0488"},{"bridge":true,"khoang":"@c0489","text":"Quan sát thủy triều Đông Hải Yêu Linh, ánh mắt bình tĩnh ngầm lấp lánh tia sáng bảy màu, băn khoăn không biết lần này vật gì sẽ bị hút đến."},{"bridge":true,"khoang":"@c0490","text":"Sắc mặt khẽ biến rồi vội xoay người khi con sóng hồng quang cuối ập tới; đại biến sắc khi khối lệnh bài kim quang lộ ra giữa thủy triều cửa Đông Hải Yêu Linh."},{"text":"Điều mười đệ tử Thiên Vận Tông (gồm Vương Lâm) vào cánh cửa; xác nhận có tất cả ba cái lệnh bài liên quan đại bí mật Thiên Vận Tinh, ước định năm trăm năm sau theo chu kỳ thí luyện sẽ tụ tập tiến vào lần nữa, dặn mọi người chuẩn bị cẩn thận vì chuyện năm đó.","bridge":true,"khoang":"@c0491"},{"text":"Về bảo tháp bảy màu trong dãy núi tam sắc ở Thiên Vận Tinh, rải vài mẩu xương thú đen kịt tỏa khí tà dị quanh mình để quan sát, nhận xét Vương Lâm là kẻ may mắn nhưng ngầm hỏi vận may còn lại bao nhiêu, khóe miệng lộ nụ cười.","bridge":true,"khoang":"@c0491"},{"text":"Sau hai trăm năm chuẩn bị kế hoạch, Thiên Vận Tử trên Thiên Vận Tông mở mắt bấm pháp quyết tính toán, nhận ra thiên kiếp rơi trên lãnh thổ Yêu Linh có quan hệ kỳ quái với Thiên Vận Tinh của hắn nhưng không tính ra rõ.","bridge":true,"khoang":"@c0552"},{"text":"Vào trong vùng đất Yêu Linh, thuật bói không còn bị Đông Hải cản trở, Thiên Vận Tử bấm độn dò ra vị trí Vương Lâm, ánh mắt xuyên qua vực sâu triều tịch tới tận hố sâu. Hắn thấy trên người Vương Lâm không có lạc ấn nào của Sát Lục Tiên Quyết nhưng không kịp ngăn vì lực lượng dòng xoáy quá mạnh. Cuối chương lộ ánh mắt kỳ dị khó dò khi nhìn dòng xoáy.","bridge":true,"khoang":"@c0614"}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn trưởng lão","tag":"ban-be","quanHe":"Lão bằng hữu từ tu chân liên minh, được mời dự đại thọ","ghiChu":"Xưng hô thân mật, gọi nhau là lão quái."},{"ten":"Côn Bằng Tử","tag":"su-mon","quanHe":"Đệ tử đầu lĩnh Hoàng Hệ, được tặng phi kiếm tiên khí","ghiChu":""},{"ten":"Hắc y nhân (mặt sẹo)","tag":"khac","quanHe":"Tu sĩ hắc y mặt sẹo trầm giọng hỏi hắn về bước thứ ba của tu đạo giữa buổi giảng.","ghiChu":""},{"ten":"Lăng Thiên Hầu","tag":"doi-thu","quanHe":"khách dự đại thọ kiêm đối tượng thi triển Tiên thuật","ghiChu":"Hai cao thủ đối thoại trêu chọc nhau; Lăng Thiên Hầu lạnh lùng đồng ý làm đối tượng để Thiên Vận Tử biểu diễn Dẫn Tiên thuật."},{"ten":"Lăng Thiên Hầu","tag":"doi-thu","quanHe":"Khách dự thọ bị làm nhục","ghiChu":"Thiên Vận Tử ra tay với đệ tử Đại La Kiếm Tông của Lăng Thiên Hầu, khiến lão âm trầm trách móc nhưng đành nhẫn nhịn chờ ba ngày."},{"ten":"Vận Đường","tag":"su-mon","quanHe":"Đệ tử lão đại Hoàng hệ","ghiChu":"Thiên Vận Tử nhìn Vận Đường bằng ánh mắt thâm thuý rồi âm trầm khi lão nhường phong hiệu và lộ biểu hiện quỷ dị."},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Đệ tử lâu năm","ghiChu":"Nhận kỳ bảo Trần Đào dâng, cho hắn tranh phong hiệu."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Đệ tử chân chính mới thu nhận","ghiChu":"Hứa truyền Cấm pháp thần thông và pháp bảo bản mạng, cho đặc ân tự chọn."},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Đệ tử Tử hệ","ghiChu":"Trao phong hiệu Thiên Vận Thất tử."},{"ten":"Lăng Thiên Hầu","tag":"khac","quanHe":"Kiếm Tôn có ước hẹn","ghiChu":"Ba tháng sau phải tuyển người tiến vào Đông Hải Yêu Linh chi môn."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Đệ tử thứ bảy của Tử hệ","ghiChu":"Thu nhận sau khi Vương Lâm đạt ý cảnh nhập thể hai mươi bảy bước."},{"ten":"Thiên Vận Tử áo xám","tag":"khac","quanHe":"Có hứa hẹn từ trước; nhờ đó người áo xám mới truyền Sát Lục Tiên quyết cho đệ tử của Thiên Vận Tử","ghiChu":"@c0474"},{"ten":"Lăng Thiên Hậu","tag":"ban-be","quanHe":"Bạn cũ cùng thăm dò Đông Hải","ghiChu":"Sau lần thứ ba thì tách ra, giữ kín bí mật."},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị Huyết Tổ bảy lần khiêu chiến."},{"ten":"Vương Tạ","tag":"doi-thu","quanHe":"Vương Tạ co đồng tử khi nhìn Thiên Vận Tử bấm độn","ghiChu":"@c0614"}],"tuiDo":{}},"nguon":["@c0461","@c0465","@c0466","@c0467","@c0468","@c0469","@c0470","@c0472","@c0473","@c0474","@c0486","@c0488","@c0489","@c0490","@c0491","@c0552","@c0614"]},{"id":"bach-vi","name":"Bạch Vi","cn":"","gioiTinh":"nam","trangThai":"song","tabs":{"diem":[],"kinhLich":[{"text":"Khi Vương Lâm phá vây xông vào thọ yến, mắt Bạch Vi lộ tia kỳ dị, chỉ mỉm cười khó hiểu mà ung dung uống rượu, không hề ra tay, gợi ý còn ẩn tình giữa các đệ tử Tử hệ.","bridge":true,"khoang":"@c0462"},{"chuong":"@c0464","importance":"normal","tieuDe":"Lộ tâm tư báo thù đại sư huynh","text":"Trên đường về Tử Vi Các, Bạch Vi lộ vẻ ác độc, lẩm bẩm trách sư tôn bất công đã cấy yêu linh vào thân đại sư huynh — nếu yêu linh thức tỉnh, đại sư huynh khôi phục bản lãnh thì hắn vĩnh viễn không báo được thù; ngoài mặt vẫn chúc mừng Vương Lâm."},{"bridge":true,"khoang":"@c0468","text":"Trong khảo nghiệm áp lực phân loại đệ tử Tử hệ, Bạch Vi kiên trì thêm một lúc rồi than thầm, rơi xuống ngồi trên mặt đất."},{"bridge":true,"khoang":"@c0469","text":"Trong cuộc tranh phong hiệu, Bạch Vi cung kính tuyên bố bỏ cuộc."},{"text":"Đệ tử Tử hệ Bạch Vi nhận ra Trần Đào khi hắn trở về, sắc mặt không tự nhiên và im lặng.","bridge":true,"khoang":"@c0470"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Cùng phe Tử hệ; quan sát Vương Lâm trở lại với nụ cười kỳ dị","ghiChu":""},{"ten":"Đại sư huynh (Tử hệ)","tag":"doi-thu","quanHe":"Đối tượng báo thù","ghiChu":"Lo yêu linh thức tỉnh sẽ khôi phục bản lãnh đại sư huynh, hắn không báo được thù."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư tôn","ghiChu":"Trách sư tôn bất công đã cấy yêu linh vào thân đại sư huynh."},{"ten":"Trần Đào","tag":"su-mon","quanHe":"Đồng môn Tử hệ","ghiChu":"Nhận ra Trần Đào, sắc mặt không tự nhiên."}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0462","@c0464","@c0468","@c0469","@c0470"]},{"id":"xich-liet","name":"Xích Liệt","cn":"","aliases":["Xích Liệt sư thúc","Lão già mặt đỏ hồng bào"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ (cao thâm)","trangThai":"song","blurb":"Sư thúc trong Thiên Vận Tông, lão già hồng bào mặt đỏ đeo hồ lô rượu; chỉ một tiếng hét đã buộc cổ yêu rút lui.","vaiTro":"Sư thúc bậc trên trong Thiên Vận Tông","tinhCach":[{"text":"Phóng khoáng, ham rượu, tiếc chén rượu dở dang hơn cả việc đệ tử đánh nhau","chuong":"@c0463"},{"text":"Nể sợ tổ sư Thiên Vận Tử","chuong":"@c0463"}],"tabs":{"diem":[{"text":"Hóa từ một đám mây đỏ, sặc mùi rượu, mắng đệ tử đánh nhau làm dở chén rượu","chuong":"@c0463"},{"text":"Uy nghiêm trấn yêu: chỉ một tiếng hét “Nghiệt súc! Cút đi cho ta!” đã khiến cổ yêu run rẩy buông mồi","chuong":"@c0463"}],"kinhLich":[{"text":"Khi cổ yêu định nuốt Hồn Thú của Vương Lâm, từ tổng tông Thiên Vận Tông vang tiếng hét của Xích Liệt buộc cổ yêu thu nhỏ rút về. Một đám mây đỏ hóa thành lão già hồng bào mặt đỏ đeo hồ lô, mắng các đệ tử đánh nhau và lo Thiên Vận Tử trách.","bridge":true,"khoang":"@c0463"},{"text":"Xích Liệt khẳng định yêu linh trong Triệu Sát Tinh vừa hình thành đã gượng dùng, túm hắn để sư phụ trừng phạt; tiết lộ sư phụ kỳ vọng cao ở Vương Lâm và đại sư huynh sẽ không xuất hiện tranh danh hiệu Thiên Vận Thất Tử, rồi hóa mây đỏ mang Triệu Sát Tinh bay đi.","bridge":true,"khoang":"@c0464"},{"chuong":"@c0464","importance":"minor","tieuDe":"Báo lịch giảng đạo","text":"Trước khi rời đi, Xích Liệt ôm quyền xin lỗi các tu sĩ tông phái và thông báo hôm sau là ngày sư huynh Thiên Vận Tử giảng đạo."}],"tuVi":"Cảnh giới chưa nêu rõ, song uy thế đủ trấn áp cổ yêu chỉ bằng một tiếng hét.","nhanMach":[{"ten":"Triệu Tinh Sát","tag":"su-mon","quanHe":"Đệ tử bậc dưới trong tông","ghiChu":"Triệu Tinh Sát tham kiến, từng gặp mấy ngàn năm trước."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Đệ tử trong tông","ghiChu":"Tiếng hét của Xích Liệt vô tình cứu Hồn Thú của Vương Lâm."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Tổ sư mà Xích Liệt nể sợ","ghiChu":"Sợ bị Thiên Vận Tử trách phạt."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư huynh","ghiChu":"Báo lịch giảng đạo hôm sau của sư huynh."},{"ten":"Triệu Tinh Sát","tag":"khac","quanHe":"Đệ tử cháu (lão đại Tử hệ) bị áp giải","ghiChu":"Túm đi sau khi hắn gượng dùng yêu linh chưa luyện hóa."}],"tuiDo":{"phapBao":[{"ten":"Hồ lô lớn","loai":"vật đựng rượu","moTa":"Hồ lô lớn đeo sau lưng, đựng rượu; Xích Liệt sặc mùi rượu khi xuất hiện.","nguon":"@c0463"}]},"tuViMoc":[]},"nguon":["@c0463","@c0464"]},{"id":"khuong-thien-ton","name":"Khương Thiên Tôn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thủy Vân Môn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh Hậu Kỳ","trangThai":"song","blurb":"Trưởng lão Vấn Đỉnh Hậu Kỳ của Thủy Vân Môn; người nhận ra hư ảnh là cổ yêu trong truyền thuyết thượng cổ và gọi tên Yêu lực.","vaiTro":"Trưởng lão Thủy Vân Môn, kiến thức uyên bác về thượng cổ","tinhCach":[{"text":"Trầm tĩnh, ngồi im suốt bảy ngày quan sát","chuong":"@c0463"}],"tabs":{"diem":[{"text":"Suốt bảy ngày ngồi im, chỉ nhẹ giọng khi nhận ra cổ yêu truyền thuyết","chuong":"@c0463"}],"kinhLich":[{"text":"Khi hư ảnh yêu vật xuất hiện, Khương Thiên Tôn nghi đó là cổ yêu trong truyền thuyết thượng cổ và xác nhận “Rất giống”. Lúc khí tức cổ yêu vượt xa linh lực, sánh ngang tiên lực và ma hỏa của Vương Lâm, ông gọi đó là “Yêu lực”.","bridge":true,"khoang":"@c0463"}],"tuViMoc":[{"chuong":"@c0463","canhGioi":"Vấn Đỉnh Hậu Kỳ","text":"Ra mặt với cảnh giới Vấn Đỉnh Hậu Kỳ, một trong các Vấn Đỉnh trưởng lão hiện diện.","importance":"major"}],"nhanMach":[],"tuiDo":{}},"nguon":["@c0463"]},{"id":"nam-tu-ho-vuong-thanh-tong","name":"Nam tử họ Vương (Thanh Tông)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thanh Tông","trangThai":"gan-bo"},{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nửa bước Vấn Đỉnh","trangThai":"song","blurb":"Đệ tử Thanh Tông của Thiên Vận Tông, mặt lạnh như băng, đã bước nửa bước vào Vấn Đỉnh — vượt cả Tư Mã Như Phong.","vaiTro":"Đệ tử mạnh của Thanh Tông trong lễ giảng đạo Thiên Vận Tử","tinhCach":[{"text":"Mặt lạnh như băng, ít biểu lộ","chuong":"@c0464"}],"tabs":{"diem":[{"text":"Nửa bước Vấn Đỉnh, vượt Tư Mã Như Phong","chuong":"@c0464"}],"kinhLich":[{"text":"Theo đoàn Thanh Tông kính bái tổng tông trong lễ giảng đạo Thiên Vận Tử; Vương Lâm quét mắt nhận ra hắn đã bước nửa bước vào Vấn Đỉnh, vượt Tư Mã Như Phong.","bridge":true,"khoang":"@c0464"},{"importance":"normal","chuong":"c0619","text":"Đứng tần ngần bàng hoàng sau khi lão già áo xanh kiểm định phi kiếm là ngụy tiên bảo và Vương Lâm bán xong; chưa hết kinh ngạc trước cảnh tượng vừa chứng kiến.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0464","canhGioi":"Nửa bước Vấn Đỉnh","text":"Tu vi đã bước nửa bước vào Vấn Đỉnh, vượt cả Tư Mã Như Phong Anh Biến đại viên mãn.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Cùng dự lễ giảng đạo Thiên Vận Tử","ghiChu":"Bị Vương Lâm nhận ra tu vi nửa bước Vấn Đỉnh."},{"ten":"Tư Mã Như Phong","tag":"doi-thu","quanHe":"Cùng sáu tông Thiên Vận Tông","ghiChu":"Tu vi vượt Tư Mã Như Phong."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0464"]},{"id":"nguoi-trung-nien-cam-tong","name":"Người trung niên Cam Tông","cn":"","aliases":["Người đàn ông trung niên (Cam Tông)"],"gioiTinh":"nam","theLuc":[{"ten":"Cam Tông","trangThai":"gan-bo"},{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến Hậu Kỳ","trangThai":"song","blurb":"Đệ tử vị trí thứ tư Cam Tông (Chanh Tông) của Thiên Vận Tông; năm xưa ở tiên giới từng dùng Sát Khí Huyết Tinh đánh nhau với Sất Hổ.","vaiTro":"Cao thủ Cam Tông Vương Lâm nhận ra trong lễ giảng đạo","tinhCach":[],"tabs":{"diem":[{"text":"Năm xưa đánh Sất Hổ ở tiên giới bằng Sát Khí Huyết Tinh","chuong":"@c0464"}],"kinhLich":[{"text":"Đứng vị trí thứ tư đoàn Cam Tông trong lễ giảng đạo Thiên Vận Tử; Vương Lâm nhận ra hắn chính là người năm xưa đánh nhau với Sất Hổ ở tiên giới, khi đó chưa tới Anh Biến nay đã đạt Anh Biến Hậu Kỳ.","bridge":true,"khoang":"@c0464"}],"tuViMoc":[{"chuong":"@c0464","canhGioi":"Anh Biến Hậu Kỳ","text":"Năm xưa ở tiên giới chưa tới Anh Biến, nay đã Anh Biến Hậu Kỳ.","importance":"major"}],"nhanMach":[{"ten":"Sất Hổ","tag":"doi-thu","quanHe":"Đối thủ trận đánh năm xưa ở tiên giới","ghiChu":"Từng dùng Sát Khí Huyết Tinh đánh nhau với Sất Hổ."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Cùng dự lễ giảng đạo, bị nhận ra","ghiChu":"Vương Lâm nhận ra qua ký ức tiên giới."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Sát Khí Huyết Tinh","trangThai":"dang-co","moTa":"Thần thông/pháp thuật từng dùng đánh Sất Hổ ở tiên giới năm xưa.","nguon":"@c0464"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0464"]},{"id":"ton-thien","name":"Tôn trưởng lão","cn":"","aliases":["#ton-truong-lao"],"gioiTinh":"nam","theLuc":[{"ten":"Tu chân liên minh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (cao thủ tột bậc tiên giới)","trangThai":"song","blurb":"Cao thủ uy áp tột bậc từ tu chân liên minh, được Thiên Vận Tử mời tới dự đại thọ vạn năm với danh nghĩa lão bằng hữu.","vaiTro":"Lão bằng hữu khách quý của Thiên Vận Tử, cao thủ tu chân liên minh","tinhCach":[{"text":"Hào sảng, thân thiết suồng sã với Thiên Vận Tử, gọi đối phương là Thiên Vận lão quái và đùa cợt thoải mái.","chuong":"@c0465"},{"text":"Uy áp khủng khiếp, chỉ một ánh mắt khiến các cao thủ phải cúi đầu.","chuong":"@c0465"}],"tabs":{"diem":[{"text":"Giáng lâm bằng đạo kim quang vạn trượng ngưng tụ thành trận pháp khổng lồ, khiến mặt trời mất màu, trời đất ảm đạm.","chuong":"@c0465"},{"text":"Dáng vẻ khoảng bốn mươi tuổi, thân hình cường tráng như pho tượng chiến tiên, mặt cương nghị, mắt như có tia chớp, mặc trường bào màu tím.","chuong":"@c0465"},{"text":"Nuôi một con tiểu điêu ba mắt đậu trên vai, tốc độ nhanh hơn tia chớp vô số lần.","chuong":"@c0465"}],"kinhLich":[{"chuong":"@c0465","importance":"normal","tieuDe":"Giáng lâm thọ yến Thiên Vận Tử","text":"Được Thiên Vận Tử mời từ hư không, Tôn trưởng lão hiện thân giữa đại thọ vạn năm, uy áp khiến cao thủ phải cúi đầu. Hắn tặng một thanh phi kiếm trung phẩm tiên khí ngưng luyện vạn năm làm hậu lễ, rồi ngồi một bên nghe Thiên Vận Tử giảng đạo."},{"bridge":true,"khoang":"@c0466–@c0466","text":"Trưởng lão đến từ liên minh tu chân dự buổi giảng đạo; tử điêu đậu lên vai lão nhai nuốt tiên ngọc, lão mỉm cười gật đầu với Vương Lâm. Khi Thiên Vận Tử nhắc tới ‘hắn’, sắc mặt lão lập tức khó coi, hồi tưởng mang theo nhiều vẻ sợ hãi vì rõ ràng biết đó là ai."},{"bridge":true,"khoang":"@c0467","text":"Dự lễ đại thọ vạn năm, Tôn trưởng lão sắc mặt khó coi và muốn ngăn Thiên Vận Tử nhắc về “hắn” nhưng đành để lão nói; vốn quen biết Lăng Thiên Hầu nên có lời chào hỏi khi vị Kiếm Tôn xuất hiện."},{"text":"Tôn trưởng lão xác nhận đoá hoa Trần Đào dâng là Thất thải lưu ly quang, nhận xét hoả hậu còn kém cánh thứ bảy.","bridge":true,"khoang":"@c0470"},{"importance":"normal","chuong":"c0616","text":"Đại trưởng lão Huyễn gia trên Thiên Huyễn Tinh (bắc vực chủ tinh La Thiên Tinh Vực); vẻ kiêu ngạo, mặt buồn đau lẫn hiểm độc, bay không dùng la bàn/pháp bảo, chỉ giẫm chân tại chỗ như na di.","nguonNblm":true}],"tuViMoc":[],"tuVi":"Cao thủ tột bậc của tu chân liên minh; thực lực không rõ cảnh giới nhưng uy áp khiến các cao thủ Thiên Vận Tông phải cúi đầu.","nhanMach":[{"ten":"Thiên Vận Tử","tag":"ban-be","quanHe":"Lão bằng hữu, được mời dự đại thọ vạn năm","ghiChu":"Xưng hô thân mật, gọi nhau là lão quái / Thiên Vận lão quái."},{"ten":"Côn Bằng Tử","tag":"khac","quanHe":"Người được Thiên Vận Tử chuyển tặng phi kiếm của ông","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Đệ tử Tử Hệ bị tiểu điêu ba mắt của ông dò xét riêng","ghiChu":""},{"ten":"Lăng Thiên Hầu","tag":"dong-minh","quanHe":"quen biết","ghiChu":"Lăng Thiên Hầu chào hỏi Tôn trưởng lão như người quen khi tới dự đại thọ."}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm màu vàng (trung phẩm tiên khí)","loai":"phi-kiem","trangThai":"da-dung","moTa":"Trung phẩm tiên khí do Tôn trưởng lão tự ngưng luyện vạn năm, đem tặng Thiên Vận Tử làm hậu lễ thọ yến (sau đó được tặng lại Côn Bằng Tử).","nguon":"@c0465"}],"linhThu":[{"ten":"Tiểu điêu ba mắt","moTa":"Con chim toàn thân màu tím, ba mắt phát tia sáng âm u, đậu trên vai Tôn trưởng lão; tốc độ nhanh hơn tia chớp vô số lần. Trong thọ yến nó bay tới đậu vai Vương Lâm dò xét.","nguon":"@c0465"}]}},"nguon":["@c0465","@c0466","@c0467","@c0470"]},{"id":"con-bang-tu","name":"Côn Bằng Tử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Hoàng Hệ (Thiên Vận Tông)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Người đứng đầu Hoàng Hệ của Thiên Vận Tông, được Thiên Vận Tử tặng lại phi kiếm trung phẩm tiên khí trong thọ yến.","vaiTro":"Đầu lĩnh Hoàng Hệ Thiên Vận Tông","tinhCach":[{"text":"Trung thành, dễ xúc động trước ân điển của sư tôn; run rẩy tạ ơn khi nhận bảo vật.","chuong":"@c0465"}],"tabs":{"diem":[{"text":"Đứng đầu Hoàng Hệ, được Thiên Vận Tử ban tặng phi kiếm trung phẩm tiên khí ngay tại thọ yến.","chuong":"@c0465"}],"kinhLich":[{"chuong":"@c0465","importance":"normal","tieuDe":"Nhận phi kiếm trung phẩm tiên khí","text":"Tại đại thọ vạn năm, Thiên Vận Tử nhận thanh phi kiếm trung phẩm tiên khí của Tôn trưởng lão rồi ném tặng lại cho Côn Bằng Tử; hắn run lên xúc động, cung kính tạ ơn sư tôn."},{"chuong":"@c0469","importance":"normal","tieuDe":"Nhận phong hiệu Thiên Vận Thất tử Hoàng hệ","text":"Sau khi Vận Đường nhường ngôi và đề cử, Côn Bằng Tử (Nhị sư đệ Hoàng hệ) được Thiên Vận Tử trao tinh thể vàng — dấu hiệu phong hiệu Thiên Vận Thất tử của Hoàng hệ, hứa truyền một bản Hạ phẩm Tiên thuật đầy đủ nếu giữ phong hiệu ngàn năm và một bảo mệnh pháp bảo khi xuất quan. Hắn kích động quỳ bái nhận lời rồi vào bế quan cảm thụ tinh thể vàng."}],"tuViMoc":[],"tuVi":"Không rõ cảnh giới; là đầu lĩnh Hoàng Hệ Thiên Vận Tông.","nhanMach":[{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư tôn / thủy tổ Thiên Vận Tông, ban tặng phi kiếm tiên khí","ghiChu":""},{"ten":"Tôn trưởng lão","tag":"an-nhan","quanHe":"Người ngưng luyện thanh phi kiếm mà hắn được nhận","ghiChu":""},{"ten":"Vận Đường","tag":"su-mon","quanHe":"Đại sư huynh Hoàng hệ","ghiChu":"Vận Đường chủ động bỏ cuộc, đề cử Côn Bằng Tử là người thích hợp nhất với phong hiệu."}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm màu vàng (trung phẩm tiên khí)","loai":"phi-kiem","trangThai":"dang-co","moTa":"Trung phẩm tiên khí do Tôn trưởng lão ngưng luyện vạn năm, được Thiên Vận Tử chuyển tặng tại thọ yến.","nguon":"@c0465"}]}},"nguon":["@c0465","@c0469"]},{"id":"hac-y-nhan-mat-seo","name":"Hắc y nhân (mặt sẹo)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Tu sĩ mặc hắc y tỏa hung khí, mặt có vết sẹo hung ác chạy từ mặt xuống cổ, hỏi Thiên Vận Tử về bước thứ ba của tu đạo.","vaiTro":"Tu sĩ bí ẩn dự buổi giảng đạo của Thiên Vận Tử.","tinhCach":[{"text":"Trầm tĩnh nhưng ẩn chứa hung khí dày đặc, khiến trong vòng mười trượng quanh thân không tu sĩ nào dám lại gần.","chuong":"@c0466"}],"tabs":{"diem":[{"text":"Quanh thân mười trượng không ai dám lại gần, hung khí cuộn trào, mặt có vết sẹo hung ác từ mặt xuống cổ.","chuong":"@c0466"}],"kinhLich":[{"text":"Giữa buổi giảng đạo trên tường vân, hắc y nhân trầm giọng hỏi Thiên Vận Tử về bước thứ ba của tu đạo, dẫn tới phần giải thích chữ ‘đạo’ và thiên vận.","bridge":true,"khoang":"@c0466"}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Hỏi Thiên Vận Tử về bước thứ ba của tu đạo trong buổi giảng.","ghiChu":""}],"tuiDo":{}},"nguon":["@c0466"]},{"id":"han-bi-an","name":"Hắn (nhân vật bí ẩn)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Nhân vật bí ẩn Thiên Vận Tử gặp ba ngàn năm trước, khiến hắn tin có bước thứ ba của tu đạo; Tôn trưởng lão biết và lộ vẻ sợ hãi khi nhớ lại.","vaiTro":"Nhân vật cực mạnh được nhắc tới, chưa lộ diện.","tinhCach":[],"tabs":{"diem":[{"text":"Sự tồn tại đủ khiến cả Thiên Vận Tử thay đổi nhận thức về bước thứ ba và khiến Tôn trưởng lão sợ hãi.","chuong":"@c0466"}],"kinhLich":[{"text":"Thiên Vận Tử kể rằng ba ngàn năm trước nhờ gặp ‘hắn’ mới tin có bước thứ ba của tu đạo; Tôn trưởng lão hiển nhiên biết ‘hắn’ là ai và lộ vẻ sợ hãi.","bridge":true,"khoang":"@c0466"},{"bridge":true,"khoang":"@c0467","text":"Được Thiên Vận Tử tiết lộ là kẻ duy nhất lão từng biết đã đạt tới bước thứ ba, từng khiến Tu Chân Liên Minh nếm đau khổ một lần duy nhất; như đoá phù dung sớm nở tối tàn, nay đã biệt tích không tung tích, danh tính bỏ ngỏ."}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Người Thiên Vận Tử gặp ba ngàn năm trước, làm hắn tin có bước thứ ba.","ghiChu":""}],"tuiDo":{}},"nguon":["@c0466","@c0467"]},{"id":"lao-tam-hoang-he-thien-van","name":"Lão Tam (Hoàng hệ)","gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"}],"trangThai":"mat-tich","blurb":"Đệ tử Hoàng hệ của Thiên Vận Tử, ba mươi năm trước từng đạt phong hiệu Thiên Vận Thất tử rồi mất tích thần bí khi ra tinh không.","vaiTro":"Nhân vật được nhắc tên","tabs":{"diem":[{"text":"Từng mang phong hiệu Thiên Vận Thất tử nhưng một lần ra tinh không thì bặt vô âm tín cho tới nay","chuong":"@c0468"}],"kinhLich":[{"chuong":"@c0468","importance":"normal","tieuDe":"Mất tích ở tinh không","text":"Ba mươi năm trước, lão Tam Hoàng hệ đạt phong hiệu Thiên Vận Thất tử, nhưng trong một lần ra tinh không thì mất tích thần bí, đến nay vẫn bặt tin."}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư phụ","ghiChu":"Thiên Vận Tử nhắc tới lão Tam khi tuyên bố tranh đoạt phong hiệu Thiên Vận Thất tử cho Hoàng hệ và Tử hệ."}],"tuiDo":{}},"nguon":["@c0468"]},{"id":"van-duong","name":"Vận Đường","aliases":["Đại sư huynh Hoàng hệ","Lão đại Hoàng hệ"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"},{"ten":"Hoàng hệ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Lão đại Hoàng hệ, dung mạo xấu xí nhiều nếp nhăn; từng làm Thiên Vận Thất tử hơn 800 năm rồi bị lão Tam đoạt, tính nhàn nhã không tranh đoạt nhưng ẩn giấu điều quỷ dị.","vaiTro":"Đại sư huynh Hoàng hệ, người chủ động nhường phong hiệu nhưng để lộ biểu hiện bí ẩn khiến Vương Lâm và Thiên Vận Tử để ý.","tinhCach":[{"text":"Nhàn nhã, không có tâm tranh đoạt, chỉ thích tu luyện thong dong","chuong":"@c0469"},{"text":"Ẩn giấu điều quỷ dị — mắt co rút và lộ vẻ sợ hãi khi tinh thể vàng xuất hiện","chuong":"@c0469"}],"tabs":{"diem":[{"text":"Từng làm Thiên Vận Thất tử hơn 800 năm rồi bị lão Tam đoạt mất","chuong":"@c0469"},{"text":"Theo Thiên Vận Tử trước cả Côn Bằng Tử (hơn 2000 năm), tính tình quái gỡ không tiếp xúc người khác","chuong":"@c0469"}],"kinhLich":[{"text":"Trong cuộc tranh phong hiệu Hoàng hệ, Vận Đường — chỉ còn lại cùng Côn Bằng Tử — cung kính xin bỏ cuộc, tự nhận không có tâm tranh đoạt và đề cử Nhị sư đệ Côn Bằng Tử là người thích hợp nhất với phong hiệu. Khi tinh thể vàng từ mi tâm Thiên Vận Tử bay ra, hai mắt lão co rút rồi lập tức bình tĩnh; bị Vương Lâm nhìn lâu, lão ngẩng đầu quét mắt rồi khoé miệng mỉm cười, sau lại run sợ trước ánh mắt âm trầm của Thiên Vận Tử.","bridge":true,"khoang":"@c0469"},{"chuong":"@c0555","importance":"normal","tieuDe":"Bị năm lão tổ phạt khôi phục Thiên Yêu Thành","text":"Hớt hải xuất hiện ở quảng trường Đế Đô, xưng ‘Tôn nhi Vân Độn xin ra mắt ngũ vị lão tổ gia gia’. Bị lệnh trong ba tháng phải khôi phục Thiên Yêu Thành (Cổ Yêu thành) đã bị thiên kiếp đè sụp, nếu không hoàn thành sẽ bị giam Long Đàm (mức phạt leo thang đến cả đời). Đồng thời được giao đưa Vương Lâm về Long Đàm gặp Cổ Yêu sau ba tháng."}],"tuViMoc":[],"tuVi":"Tu vi chưa rõ; che giấu rất giỏi, từng đủ sức làm Thiên Vận Thất tử Hoàng hệ hơn 800 năm.","nhanMach":[{"ten":"Côn Bằng Tử","tag":"su-mon","quanHe":"Nhị sư đệ Hoàng hệ","ghiChu":"Vận Đường nhường phong hiệu, đề cử Côn Bằng Tử."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư phụ","ghiChu":"Bị Thiên Vận Tử nhìn bằng ánh mắt âm trầm khiến run lòng cúi đầu."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Sư đệ đồng môn (Lão Thất)","ghiChu":"Vương Lâm phát hiện biểu hiện quỷ dị của lão; ánh mắt sợ hãi của lão khiến Vương Lâm do dự bỏ cuộc."},{"ten":"Cổ Yêu","tag":"su-mon","quanHe":"Lão tổ tông Thiên Yêu quận mà Vân Độn phải đưa Vương Lâm về diện kiến.","ghiChu":"@c0555"}],"tuiDo":{}},"nguon":["@c0469","@c0555"]},{"id":"tran-dao","name":"Tử hệ lão Lục","aliases":["Tử hệ Lão Lục","Lão Lục","Lão Lục Tử hệ"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Vận Tông","trangThai":"gan-bo"},{"ten":"Tử hệ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh kỳ","trangThai":"song","blurb":"Tử hệ Lão Lục, đệ tử lâu năm của Thiên Vận Tử, từng đạt phong hiệu Thiên Vận Thất tử trước thời Tôn Vân; trở về đòi tranh lại phong hiệu. (+) Sư huynh đồng môn Tử hệ của Vương Lâm; từng dùng tu vi Vấn Đỉnh đè ép khiến Vương Lâm mất danh hiệu Thiên Vận Thất Tử. [CAN-SOAT-GOP]","vaiTro":"Đệ tử kỳ cựu Tử hệ trở về tranh phong hiệu, đối thủ mới của Vương Lâm trong tiệc đại thọ.","tinhCach":[{"text":"Kiêu ngạo, khinh thường Vương Lâm, chỉ thừa nhận Tôn Vân mới là Thất sư đệ thật.","chuong":"@c0470"},{"text":"Hiếu chiến, hứng thú trước cường địch — xé áo lộ nửa thân, rút trường thằng nghênh chiến.","chuong":"@c0470"}],"tabs":{"diem":[{"text":"Từng đạt phong hiệu Thiên Vận Thất tử trước Tôn Vân, năm xưa thua Tôn Vân rồi rời tông ra tinh ngoại rèn luyện.","chuong":"@c0470"},{"text":"Tu vi Vấn Đỉnh, vị trí lão Lục trong Tử hệ Thiên Vận Tử.","chuong":"@c0498"}],"kinhLich":[{"text":"Một đạo tử khí xông tới hiện ra Trần Đào, dâng cho Thiên Vận Tử đoá Thất thải lưu ly quang cướp được ở Hắc Mặc Tinh — thiên địa kỳ bảo xếp thứ 93 Tu Chân Liên Minh. Hắn đòi lại phong hiệu Thiên Vận Thất tử; khi Triệu Hân Mộng truyền âm về Tôn Vân, hắn biến sắc.","bridge":true,"khoang":"@c0470"},{"text":"Trần Đào (Vấn Đỉnh) đánh ấn quyết chấn nhiếp nhưng chỉ đẩy lùi Vương Lâm mười trượng nên kinh ngạc; hắn đẩy ngũ chuyển kim tiên lực của Vương Lâm lên cửu chuyển phản công, rồi nổ tan đòn nuốt của Hồn thú khiến quần áo rách bươm. Hứng thú trước cường địch, hắn xé áo lộ nửa thân, rút ra trường thằng đen như sợi gân sinh vật toả khí tức hoang dã (trận chưa dứt).","bridge":true,"khoang":"@c0470"},{"text":"Trần Đào khoe Long cân rút từ xác một con yêu long ở Yêu Tinh, vung từ góc độ khó tin buộc lấy cổ Hồn thú của Vương Lâm rồi đứng trên đầu nó siết chặt khống chế.","bridge":true,"khoang":"@c0471"},{"text":"Sau khi Vương Lâm mở phong ấn Xạ Thần xa khiến Hồn thú phản công, Trần Đào dựng tử sắc quang cầu phòng ngự nhưng vẫn bị tổn thương; hắn mỉa mai Vương Lâm “có tư cách làm sư đệ”, bị phản bác, rồi hóa tàn ảnh lao tới tấn công.","bridge":true,"khoang":"@c0471"},{"text":"Đỡ được hai đạo Hoàng tuyền chỉ của Vương Lâm nhờ trước khi trở về có kỳ ngộ đạt Vấn Đỉnh trung kỳ, thừa nhận một chỉ này vượt ngoài dự liệu. Thắng trận nên được Thiên Vận Tử trao phong hiệu Thiên Vận Thất tử của Tử hệ; lão điểm mi tâm đưa cảm ngộ phong hiệu vào người hắn.","bridge":true,"khoang":"@c0472"},{"bridge":true,"khoang":"@c0488–@c0488","text":"Lão lục Trần Đào, đệ tử Tử hệ mặc áo tím uy áp như kiếm sắc, sốt ruột chờ Vương Lâm tới cửa Đông Hải; khi thấy thân ảnh tử sắc thì mừng thầm gọi “Lão Thất”, rồi nhìn Vương Lâm bằng ánh mắt kỳ dị."},{"text":"Bị mười người Đại La Kiếm Tông tiến vào Yêu Linh Chi Địa liên thủ đánh trọng thương cả Nguyên Thần, tu vi tụt từ Vấn Đỉnh trung kỳ xuống Anh Biến viên mãn. Gặp lại sư đệ Vương Lâm trên quân đạo, nhận túi Tuy Bình đan thiện chí; hắn tính nếu đủ tài liệu sẽ luyện một lò Thiên Nguyên đan để ngắn hạn khôi phục về Vấn Đỉnh sơ kỳ, và hết lời nể phục sức mạnh Vương Lâm.","bridge":true,"khoang":"@c0533"},{"text":"Tu sĩ Vấn Đỉnh kỳ; ước lượng thời đỉnh cao có thể gõ hơn mười tiếng, nay đã uống đan dược chỉ gõ bảy tiếng (không hơn Mặc Phi). Khen Mặc Phi là đệ nhất dưới Vấn Đỉnh kỳ, tiếc bản thân chưa đạt Vấn Đỉnh trung kỳ.","bridge":true,"khoang":"@c0546"},{"text":"Đã khôi phục tới Vấn Đỉnh trung kỳ, đả tọa cùng Thạch Tiêu tại yêu tướng phủ Thiên Yêu quận, sắp được tiến cử làm yêu tướng để tới long đàm cảm ngộ. Y bênh Vương Lâm là sư đệ, chứng kiến Vương Lâm giết Thạch Tiêu và được dặn “Cẩn thận, sư tôn”.","bridge":true,"khoang":"@c0613"},{"text":"Được nhắc lại: từng dùng tu vi Vấn Đỉnh đè ép Vương Lâm, khiến danh hiệu Thiên Vận Thất Tử không thuộc về Vương Lâm.","bridge":true,"khoang":"@c0498"}],"tuViMoc":[{"chuong":"@c0470","canhGioi":"Vấn Đỉnh kỳ","text":"Trần Đào tu vi Vấn Đỉnh, đủ sức đẩy kim tiên lực lên cửu chuyển.","importance":"minor"},{"chuong":"@c0472","canhGioi":"Vấn Đỉnh trung kỳ","text":"Trước khi trở về tham dự đại thọ, nhờ một kỳ ngộ mà đạt tới Vấn Đỉnh trung kỳ, đủ sức đỡ Hoàng tuyền chỉ của Vương Lâm.","importance":"major"},{"chuong":"@c0533","canhGioi":"Anh Biến viên mãn","text":"Vốn ở Vấn Đỉnh trung kỳ, bị Đại La Kiếm Tông đánh trọng thương ảnh hưởng Nguyên Thần nên tụt xuống Anh Biến viên mãn; có thể tạm khôi phục Vấn Đỉnh sơ kỳ nếu luyện được Thiên Nguyên đan.","importance":"major"},{"chuong":"@c0613","canhGioi":"Vấn Đỉnh trung kỳ","text":"Đã khôi phục tới Vấn Đỉnh trung kỳ.","importance":"minor"}],"nhanMach":[{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Sư phụ","ghiChu":"Đệ tử lâu năm, dâng kỳ bảo mừng đại thọ vạn năm của sư phụ."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tranh phong hiệu Thiên Vận Thất tử","ghiChu":"Khinh thường rồi giao chiến với Vương Lâm."},{"ten":"Tôn Vân","tag":"doi-thu","quanHe":"Người từng đoạt phong hiệu của hắn","ghiChu":"Năm xưa thua Tôn Vân; thừa nhận Tôn Vân mới là Thất sư đệ thật."},{"ten":"Triệu Hân Mộng","tag":"su-mon","quanHe":"Đồng môn Tử hệ","ghiChu":"Triệu Hân Mộng truyền âm về Tôn Vân khiến hắn biến sắc."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ tại lễ chúc thọ","ghiChu":"Trần Đào (Vấn Đỉnh kỳ) tự xưng sư huynh, giao chiến với Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Sư huynh đệ Tử hệ kiêm đối thủ","ghiChu":"Hẹn tái chiến với Vương Lâm sau khi đối phương đạt Vấn Đỉnh."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Trưởng bối Thiên Vận Tông","ghiChu":"Trao phong hiệu Thiên Vận Thất tử."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Sư đệ đồng hệ","ghiChu":"Tự nhận Vương Lâm là sư đệ; nhận đan dược thiện chí của Vương Lâm."},{"ten":"Thạch Tiễn","tag":"dong-minh","quanHe":"Đồng hành nâng đỡ","ghiChu":"Thạch Tiễn thu thập tài liệu giúp Trần Đào luyện Thiên Nguyên đan."},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Đối thủ cuộc chiến Yêu tướng","ghiChu":"Trần Đào tự nhận nếu chưa bị thương có thể giết được Mạc Lệ Hải."},{"ten":"Thạch Tiêu","tag":"dong-minh","quanHe":"Đáp Thạch Tiêu hỏi về số tiếng có thể gõ được","ghiChu":"@c0546"},{"ten":"Thạch Tiêu","tag":"dong-minh","quanHe":"Đồng liêu yêu tướng phủ","ghiChu":"Đả tọa cùng nhau, được Thạch Tiêu định tiến cử làm yêu tướng; chứng kiến Thạch Tiêu bị Vương Lâm giết."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Sư huynh đồng môn Tử hệ","ghiChu":"Đè ép Vương Lâm, gây ân oán."}],"tuiDo":{"phapBao":[{"ten":"Trường thằng đen","trangThai":"dang-co","moTa":"Sợi dây như gân sinh vật rút ra từ thân, toả khí tức hoang dã, dùng đối phó Hồn thú.","nguon":"@c0470"}],"khac":[{"ten":"Thất thải lưu ly quang","moTa":"Đoá hoa kỳ bảo cướp ở Hắc Mặc Tinh, dâng cho Thiên Vận Tử.","trangThai":"da-dung","nguon":"@c0470"}]},"tuVi":"Tu vi Vấn Đỉnh."},"nguon":["@c0470","@c0471","@c0472","@c0488","@c0533","@c0546","@c0613","@c0498"]},{"id":"lao-gia-mat-do-ho-lo-do","name":"Lão già mặt đỏ (mang hồ lô đỏ)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Vị khách lạ mặt đỏ mang hồ lô đỏ lớn đến lễ chúc thọ, vừa uống rượu vừa nhận ra Hoàng tuyền chỉ của Vương Lâm giống hệt sát chiêu của một “người điên” lão từng gặp.","vaiTro":"Nhân vật bí ẩn quan khán tại lễ chúc thọ","tinhCach":[{"text":"Phóng khoáng, mê rượu","chuong":"@c0471"}],"tabs":{"diem":[{"text":"Nhận ra mối liên hệ giữa sát chiêu Hoàng tuyền chỉ và một “lão quái / người điên” lão từng gặp thuở mới đến nơi này","chuong":"@c0471"}],"kinhLich":[{"text":"Lão già mặt đỏ mang hồ lô đỏ đến chúc thọ, vừa uống rượu vừa ngạc nhiên khi thấy Hoàng tuyền chỉ của Vương Lâm giống hệt sát chiêu của “người điên kia” mà lão từng gặp khi mới tới nơi này; danh tính lão chưa lộ.","bridge":true,"khoang":"@c0471"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Quan khán nhận ra sát chiêu","ghiChu":"Thấy Hoàng tuyền chỉ của Vương Lâm giống sát chiêu một nhân vật bí ẩn lão từng gặp."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0471"]},{"id":"thien-van-tu-ao-xam","name":"Thiên Vận Tử áo xám","aliases":["Người áo xám","Hơn một người"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ (siêu việt Vấn Đỉnh)","trangThai":"khong-ro","blurb":"Một Thiên Vận Tử mặc áo bào màu tro, mắt xám, trẻ tuổi hơn các Thiên Vận Tử khác — là người ‘hơn một người’ (thứ 3601) trong thế giới bảy màu, nắm giữ Sát Lục Tiên quyết.","vaiTro":"Nhân vật bí ẩn xuất hiện trong tâm thần Thiên Vận Tử, mời truyền Sát Lục Tiên quyết cho Vương Lâm.","tinhCach":[{"text":"Lạnh lùng, sát khí cực mạnh — chỉ một chữ làm sụp phong ấn của 3600 Thiên Vận Tử","chuong":"@c0474"},{"text":"Kỳ dị, kiêng kỵ con số bảy","chuong":"@c0474"}],"tabs":{"diem":[{"text":"Là ‘hơn một người’ — thực thể thứ 3601 trong thế giới bảy màu, không có tiên lực dao động, mọi công kích xuyên qua như ảo ảnh","chuong":"@c0474"},{"text":"Sát khí mạnh nhất Vương Lâm từng gặp; một chữ ‘Cút!’ đẩy lui 3600 Thiên Vận Tử mấy vạn dặm","chuong":"@c0474"},{"text":"Nắm giữ Sát Lục Tiên quyết, thân được hàng tỷ Sinh chi lạc ấn thủ hộ","chuong":"@c0474"}],"kinhLich":[{"text":"Khi Vương Lâm vào thế giới bảy màu chọn thần thông, người áo xám ngồi thổ nạp bất động giữa 3600 Thiên Vận Tử. Sát khí của lão khiến cả 3600 Thiên Vận Tử hô ‘Phong!’ phong ấn, nhưng một chữ ‘Cút!’ làm phong ấn sụp đổ, để lộ tổng số 3601 — hơn một người.","bridge":true,"khoang":"@c0474"},{"chuong":"@c0474","importance":"normal","tieuDe":"Mời truyền Sát Lục Tiên quyết","text":"Sau sáu lần chạm mặt, người áo xám hỏi Vương Lâm có phải đệ tử Thiên Vận Tử, tiết lộ lão được đưa tới vì Sát Lục Tiên quyết, ra điều kiện ‘không lưu người sống’. Khi Vương Lâm từ chối, lão không đáp câu hỏi về quan hệ với sư phụ, hoá một ngọc giản từ bụi khí để lại rồi biến mất."}],"tuVi":"Cảnh giới chưa nói rõ nhưng siêu việt Vấn Đỉnh; thân được hàng tỷ Sinh chi lạc ấn thủ hộ, dù Thiên Vận Tinh sụp đổ cũng bình yên vô sự.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người thứ sáu được đưa tới; được mời truyền Sát Lục Tiên quyết nhưng từ chối, vẫn được để lại ngọc giản","ghiChu":"@c0474"},{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Có hứa hẹn từ trước nên mới chịu truyền cho đệ tử của Thiên Vận Tử; quan hệ cụ thể chưa tiết lộ","ghiChu":"@c0474"}],"tuiDo":{"congPhap":[{"ten":"Sát Lục Tiên quyết","trangThai":"dang-co","moTa":"Tiên quyết bắt chước từ một loại Tiên thuật vô danh, dựa vào giết chóc đoạt sinh lực ngưng kết Sinh chi lạc ấn phòng thủ.","nguon":"@c0474"}]}},"nguon":["@c0474"]},{"id":"hua-van-son","name":"Hứa Vân Sơn","cn":"","aliases":["Thiếu Tông Huyền Uyên Phái"],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến Trung kỳ","trangThai":"song","blurb":"Thiếu Tông của Huyền Uyên Phái trên Địa Tinh, chủ động ra đón và kết giao với Vương Lâm.","vaiTro":"Thiếu Tông Huyền Uyên Phái, người dẫn dắt Vương Lâm khi tới Địa Tinh và đưa hắn nhậm chức sứ giả Linh Nhạc quốc.","tinhCach":[{"text":"Tinh ý, biết nhìn xa, chủ động kết giao với người có tiềm lực lớn","chuong":"@c0476"}],"tabs":{"diem":[{"text":"Cầm bảo phiến ngọc bích, phong thái ung dung của một Thiếu Tông","chuong":"@c0476"},{"text":"Khi biết sứ giả mới là Tử hệ Lão Thất Vương Lâm thì rung động muốn kết giao sớm","chuong":"@c0476"}],"kinhLich":[{"chuong":"@c0476","importance":"normal","tieuDe":"Nghênh đón sứ giả Tử hệ","text":"Ba ngày trước biết tin từ một bằng hữu Thiên Vận Tông rằng có người Tử hệ sẽ tới Địa Tinh làm sứ giả Linh Nhạc quốc; khi biết đó là Vương Lâm — đệ tử mới của Thiên Vận Tử — hắn cầm bảo phiến ngọc bích cùng mấy Trưởng lão tóc bạc ra Truyền tống trận chờ đón, ôm quyền xưng Thiếu tông và mời với tư cách chủ nhà."},{"bridge":true,"khoang":"@c0476–@c0476","text":"Sau hai ngày quan hệ đã hoà hợp, Hứa Vân Sơn đưa Vương Lâm tới Linh Nhạc quốc nhận chức sứ giả."},{"bridge":true,"khoang":"@c0477","text":"Cùng Vương Lâm bay tới Linh Nhạc quốc đưa hắn nhậm chức Sứ giả, cười cáo từ gọi Vương Lâm là Vương huynh, hẹn ngày sau uống rượu rồi hóa sét bay đi."}],"tuViMoc":[{"chuong":"@c0476","canhGioi":"Anh Biến Trung kỳ","text":"Tu vi ngang hàng Vương Lâm khi gặp mặt.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Chủ động ra đón và kết giao, làm chủ nhà dẫn Vương Lâm tới Linh Nhạc quốc"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đưa Vương Lâm đến nhậm chức Sứ giả Huyền Uyên Phái, xưng hô thân thiết","ghiChu":"@c0477"}],"tuiDo":{"phapBao":[{"ten":"Bảo phiến ngọc bích","moTa":"Cây quạt gấp màu ngọc bích Hứa Vân Sơn cầm khi ra đón Vương Lâm.","nguon":"@c0476"}]}},"nguon":["@c0476","@c0477"]},{"id":"trieu-tu","name":"Triệu Tứ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hoá Thần (hướng tới hậu kỳ)","trangThai":"song","blurb":"Tu sĩ Huyền Uyên Phái vận hành Truyền tống trận, người tiễn Vương Lâm tới Địa Tinh.","vaiTro":"Tu sĩ trông coi và kích hoạt Truyền tống trận của Huyền Uyên Phái.","tinhCach":[{"text":"Hâm mộ kẻ mạnh, chuyên tâm tu luyện","chuong":"@c0476"}],"tabs":{"diem":[{"text":"Kính gọi Vương Lâm là “Tử hệ Thất sư tổ”, hâm mộ nhìn theo sau khi tiễn","chuong":"@c0476"}],"kinhLich":[{"text":"Triệu Tứ kết quyết đánh một đạo thanh quang vào Truyền tống trận mười dặm, khiến toàn trận chấn động và truyền Vương Lâm rời đi; sau đó hắn lẩm bẩm không biết Thất sư tổ tới Địa Tinh làm gì rồi khoanh chân thổ nạp, quyết sớm đạt Hoá Thần hậu kỳ.","bridge":true,"khoang":"@c0476"}],"tuViMoc":[{"chuong":"@c0476","canhGioi":"Hoá Thần","text":"Đang tu luyện hướng tới Hoá Thần hậu kỳ.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Vận hành Truyền tống trận tiễn Vương Lâm tới Địa Tinh, kính gọi là Thất sư tổ"}]},"nguon":["@c0476"]},{"id":"lao-to-huyen-minh","name":"Lão Tổ Huyền Minh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vượt Vấn Đỉnh","trangThai":"song","blurb":"Lão Tổ đứng đầu Huyền Uyên Phái trên Địa Tinh, tu vi vượt quá Vấn Đỉnh.","vaiTro":"Người đứng đầu Huyền Uyên Phái, thế lực tu chân mạnh nhất Địa Tinh.","tinhCach":[],"tabs":{"diem":[{"text":"Tu vi vượt quá Vấn Đỉnh, là chỗ dựa của Huyền Uyên Phái","chuong":"@c0476"}],"kinhLich":[{"bridge":true,"khoang":"@c0476–@c0476","text":"Được nhắc tới là Lão Tổ đứng đầu Huyền Uyên Phái — Lục cấp tu chân quốc duy nhất trên Địa Tinh, tu vi vượt quá Vấn Đỉnh."},{"importance":"normal","chuong":"c0616","text":"Tu vi đạt Vấn Đỉnh, tu luyện Thiên Huyễn Vô Tình Đạo, mơ hồ có thể tiến tới Vạn Ảo Thiên Ma Đạo","nguonNblm":true}],"nhanMach":[]},"nguon":["@c0476"]},{"id":"thien-thai-lao-nhan","name":"Thiên Thai lão nhân","cn":"","aliases":["Lão nhân tóc bạc trắng","Cao thủ đệ nhất Linh Nhạc quốc"],"gioiTinh":"nam","theLuc":[{"ten":"Linh Nhạc quốc","trangThai":"gan-bo"},{"ten":"Ngũ Linh Sơn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn (một chân vào Vấn Đỉnh)","trangThai":"song","blurb":"Cao thủ đệ nhất Linh Nhạc quốc, lão nhân tóc bạc ở Ngũ Linh Sơn, tu vi gần chạm cảnh giới Vấn Đỉnh.","vaiTro":"Tu sĩ mạnh nhất Linh Nhạc quốc; sau khi thăm dò Vương Lâm và thấy Khuất thú thì khiếp sợ, hạ lệnh lập cấm địa quanh Thông Thiên tháp.","tinhCach":[{"text":"Điềm tĩnh, thận trọng, biết tiến thoái","chuong":"@c0477"}],"tabs":{"diem":[{"text":"Tu vi cao nhất Linh Nhạc quốc, đã đặt một chân vào cảnh giới Vấn Đỉnh","chuong":"@c0477"},{"text":"Hấp thu thái âm lực thổ nạp trên đỉnh Ngũ Linh Sơn","chuong":"@c0477"}],"kinhLich":[{"text":"Là cao thủ đệ nhất Linh Nhạc quốc, lão nhân đến Thông Thiên tháp thăm dò vị tân Sứ giả. Ba ngày sau trở về với sắc mặt cực kỳ khó coi, mắt hiện vẻ khiếp sợ vì tận mắt thấy Khuất thú; các tông phái liền truyền lệnh cấm đệ tử bước vào phạm vi ngàn dặm quanh tháp.","bridge":true,"khoang":"@c0477"},{"text":"Lão đang ngồi khoanh chân trên đỉnh Ngũ Linh Sơn hấp thu thái âm lực thì Vương Lâm tìm đến. Lão mở mắt bình tĩnh nói ra mắt Sứ giả đại nhân, Vương Lâm ôm quyền đáp lời.","bridge":true,"khoang":"@c0477"},{"bridge":true,"khoang":"@c0478","text":"Tự trách vì để lão đạo phá quy củ tiến vào phạm vi ngàn dặm quanh Thông Thiên Tháp, kinh động Khuất thú khiến Vương Lâm không thu phục được; cung kính trao Vương Lâm ngọc giản ghi ba chỗ yêu thú tụ tập, nhận ra giữa mi tâm hắn ẩn sát khí và đoán hắn đi vì giết chóc."}],"tuViMoc":[{"chuong":"@c0477","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tu vi cao nhất Linh Nhạc quốc, gần như đặt một chân vào cảnh giới Vấn Đỉnh.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Tân Sứ giả Huyền Uyên Phái mà lão thăm dò rồi khiếp sợ; cuối chương Vương Lâm tìm đến lão tại Ngũ Linh Sơn","ghiChu":"@c0477"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Tôn xưng Sứ giả đại nhân, phục vụ và trao ngọc giản","ghiChu":""}],"tuiDo":{}},"nguon":["@c0477","@c0478"]},{"id":"quach-ta-dat","name":"Quách Tà Dật","aliases":["Quách đại sư huynh"],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Lục đại đệ tử Đại La Kiếm Tông, đại sư huynh của nhóm năm người tới Địa Ma Bắc Giới.","vaiTro":"Đệ tử kiếm tu Đại La Kiếm Tông","tinhCach":[{"text":"Khéo léo, dùng thủ đoạn mượn danh sư môn để chiếm lợi","chuong":"@c0478"}],"tabs":{"diem":[{"text":"Mượn danh Đại La Kiếm Tông và lời mời trợ trận để chiếm Diệu Kim quả","chuong":"@c0478"}],"kinhLich":[{"text":"Trung tuần mặc trường sam trắng xanh đeo trường kiếm cổ, làm đại sư huynh nhóm năm người, bảo chờ Sư bá rồi mới tiến vào; mâu thuẫn với Thiên Cầm cô nương về Diệu Kim quả, rồi cung kính tham kiến lão sư thúc Hoá Thần hậu kỳ và quỳ một gối ra mắt hai Kiếm Các Trưởng lão.","bridge":true,"khoang":"@c0478"},{"text":"Là tu sĩ Đại La Kiếm Tông, Quách Tà Dật khai với hai Trưởng lão về việc sư môn Thiên Cầm phát hiện Diệu Kim quả, chỉ về phía nàng và cầu xin cho nàng một quả sau khi thu được. Sau đó hắn ân cần bắt chuyện muốn hàn gắn với Thiên Cầm.","bridge":true,"khoang":"@c0479"},{"chuong":"@c0481","importance":"normal","tieuDe":"Dựng cục hại sư huynh Thiên Cầm","text":"Là kẻ dựng nên việc đẩy sư huynh Thiên Cầm vào sơn cốc Cửu Lê trùng; nắm chặt bảo kiếm trong tay áo, lóe sát khí về phía Thiên Cầm và thừa nhận hai bên đã kết thù."},{"chuong":"@c0483","importance":"major","tieuDe":"Bị Thạch Phương đoạt xá","text":"Nguyên thần ly thể Thạch Phương lao tới, xuyên liễu diệp phi kiếm qua mi tâm Quách Tà Dật mà đoạt xá siêu tốc, chiếm lấy thân thể hắn; sau đó thân xác cùng chung số phận nổ tung khi Vương Lâm giết Thạch Phương."},{"importance":"normal","chuong":"c0613","text":"Bị hai tu sĩ Hỏa Yêu quận (một nam một nữ, tu vi cực mạnh) một trảo bắt đi cùng Tham Lang; nam tử lộ vẻ phiền muộn, hoài niệm khi thấy Chu Dật — gợi mối liên hệ quá khứ","nguonNblm":true},{"importance":"normal","chuong":"c0625","text":"Là kẻ năm xưa giao chiến với Tôn Thái; chính là người để lại lạc ấn khống chế trên thân Vương Lâm","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0478","canhGioi":"Kết Đan trở lên","text":"Đại đệ tử dẫn đầu nhóm, tu vi cao hơn các sư đệ sư muội Kết Đan","importance":"minor"}],"nhanMach":[{"ten":"Thiên Cầm cô nương","tag":"doi-thu","quanHe":"Được nàng mời trợ trận nhưng chiếm Diệu Kim quả, bị nàng căm hận","ghiChu":""},{"ten":"Lão già Hoá Thần hậu kỳ (sư thúc Quách Tà Dật)","tag":"su-mon","quanHe":"Sư thúc, dẫn ra mắt hai Trưởng lão","ghiChu":""},{"ten":"Thiên Cầm cô nương","tag":"khac","quanHe":"Người hắn khai ra rồi muốn hàn gắn","ghiChu":"Hắn khiến nàng bị ép dẫn đường rồi xin cho nàng một quả, sau ân cần bắt chuyện."},{"ten":"Lão già cao người (Trưởng lão Đại La Kiếm Tông)","tag":"su-mon","quanHe":"Trưởng lão tông môn","ghiChu":"Tra hỏi hắn và đồng ý cho Thiên Cầm một quả."},{"ten":"Lão già thấp người (Trưởng lão Đại La Kiếm Tông)","tag":"su-mon","quanHe":"Trưởng lão tông môn","ghiChu":"Hỏi hắn số lượng Diệu Kim quả."},{"ten":"Thiên Cầm","tag":"doi-thu","quanHe":"Kết thù sau khi hại chết sư huynh nàng","ghiChu":"@c0481"},{"ten":"Lữ Tùng Nghĩa","tag":"su-mon","quanHe":"Sư thúc, lão già Hóa Thần kỳ đi cùng","ghiChu":"@c0481"},{"ten":"Nữ tử (sư muội Quách Tà Dật)","tag":"su-mon","quanHe":"Sư muội đi cùng, gọi hắn là sư huynh","ghiChu":"@c0481"},{"ten":"Thạch Phương","tag":"doi-thu","quanHe":"Bị trưởng lão Thạch Phương đoạt xá, mất thân xác.","ghiChu":"@c0483"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478","@c0479","@c0481","@c0483"]},{"id":"thien-cam-co-nuong","name":"Thiên Cầm cô nương","gioiTinh":"nu","theLuc":[],"trangThai":"song","blurb":"Nữ tử xinh đẹp mời Quách Tà Dật trợ trận nhưng bị hắn mượn danh sư môn chiếm Diệu Kim quả.","vaiTro":"Nữ tu tranh chấp Diệu Kim quả","tinhCach":[{"text":"Đầy thù hận, thẳng thắn mắng kẻ dùng thủ đoạn đê tiện","chuong":"@c0478"}],"tabs":{"diem":[{"text":"Căm hận Quách Tà Dật vì bị chiếm đoạt Diệu Kim quả","chuong":"@c0478"}],"kinhLich":[{"text":"Mặc quần lụa trắng thắt nơ bướm tơ tằm, mắng Quách Tà Dật mượn danh Đại La Kiếm Tông dùng thủ đoạn đê tiện; được hắn hứa để lại một quả Diệu Kim quả mang về sư môn.","bridge":true,"khoang":"@c0478"},{"text":"Bị Quách Tà Dật khai ra việc sư môn nàng phát hiện Diệu Kim quả, Thiên Cầm bị hai Trưởng lão Anh Biến sơ kỳ của Đại La Kiếm Tông ép dẫn đường vào Địa Ma Bắc Giới. Nội tâm chua xót hận Quách Tà Dật phản bội, nhưng vì khí tức hai Trưởng lão vượt xa sư môn nhỏ bé của nàng, nàng đành cắn răng cam chịu, chỉ mong đạt được một Diệu Kim quả.","bridge":true,"khoang":"@c0479"},{"bridge":true,"khoang":"@c0480","text":"Dẫn đường cho đoàn Đại La Kiếm Tông tới sơn cốc nơi sư môn vãn bối phát hiện Diệu Kim quả hai tháng trước, rồi lui về sau; bị lão già Hoá Thần kỳ liếc nhìn thân thể với quang mang kỳ lạ."},{"chuong":"@c0481","importance":"normal","tieuDe":"Mất sư huynh trong sơn cốc","text":"Chứng kiến sư huynh áo trắng bị Cửu Lê trùng chui vào cơ thể ăn thịt đến chết, nàng chấn động gặng hỏi tiền bối vì sao, nở nụ cười thê thảm rồi chuyển sang bình tĩnh đáng sợ."},{"chuong":"@c0483","importance":"normal","tieuDe":"Quỳ cầu Vương Lâm","text":"Thiên Cầm run rẩy quỳ xin Vương Lâm giết Thạch Phương và Trưởng lão Đại La Kiếm Tông đang bỏ chạy, nguyện làm trâu ngựa hầu hạ. Vẫn là xử nữ nên từng bị Thạch Phương định mượn thân để chữa thương; than rằng sư môn tốn công biết sơn cốc có Diệu Kim quả nhưng cục diện đã đổi khác khi Vương Lâm xuất hiện."},{"text":"Quan khán Vương Lâm hành sự, ban đầu ngỡ hắn bố trí trận pháp, sau đau lòng như rỉ máu khi thấy Diệu Kim quả héo rũ. Cuối cùng nàng vỡ lẽ giá trị thật của Diệu Kim quả nằm ở gốc rễ, theo bản năng tiếp lấy sợi kim linh căn Vương Lâm tặng rồi về bên đồng môn, hoá cầu vồng rời đi.","bridge":true,"khoang":"@c0484"}],"tuViMoc":[],"nhanMach":[{"ten":"Quách Tà Dật","tag":"doi-thu","quanHe":"Mời trợ trận nhưng bị chiếm Diệu Kim quả, sinh thù hận","ghiChu":""},{"ten":"Quách Tà Dật","tag":"doi-thu","quanHe":"Từng tin tưởng, nay hận vì bị phản bội","ghiChu":"Quách Tà Dật khai ra việc sư môn nàng phát hiện Diệu Kim quả khiến nàng bị ép dẫn đường; sau đó hắn ân cần muốn hàn gắn nhưng nàng càng chua xót."},{"ten":"Lão già cao người (Trưởng lão Đại La Kiếm Tông)","tag":"doi-thu","quanHe":"Kẻ ép nàng dẫn đường","ghiChu":"Đồng ý cho nàng một quả sau khi thu được, ra lệnh dẫn đường."},{"ten":"Nam tử áo trắng (đồng môn Thiên Cầm)","tag":"su-mon","quanHe":"Cùng sư môn","ghiChu":"Đồng môn tức giận thay nàng nhưng bị nàng quát im."},{"ten":"Nam tử áo trắng (đồng môn Thiên Cầm)","tag":"su-mon","quanHe":"Sư huynh, bị hại chết trong sơn cốc","ghiChu":"@c0481"},{"ten":"Quách Tà Dật","tag":"doi-thu","quanHe":"Kẻ dựng cục đẩy sư huynh nàng vào cốc, kết thù","ghiChu":"@c0481"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Quỳ cầu Vương Lâm cứu mạng, nguyện làm trâu ngựa hầu hạ.","ghiChu":"@c0483"},{"ten":"Thạch Phương","tag":"su-mon","quanHe":"Trưởng lão sư môn định mượn thân xử nữ của nàng để chữa thương.","ghiChu":"@c0483"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Được Vương Lâm tặng một sợi kim linh căn coi như đền lại cơ duyên Diệu Kim quả đã bị chiếm.","ghiChu":"@c0484"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478","@c0479","@c0480","@c0481","@c0483","@c0484"]},{"id":"lao-gia-hoa-than-su-thuc-quach-ta-dat","name":"Lão già Hoá Thần hậu kỳ (sư thúc Quách Tà Dật)","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một trong ba lão tóc bạc hắc y đeo bảo kiếm cổ, tu vi Hoá Thần hậu kỳ, sư thúc của Quách Tà Dật.","vaiTro":"Trưởng bối Đại La Kiếm Tông","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Cùng hai Kiếm Các Trưởng lão lao tới bằng trường hồng, khí lãng thổi bay những người khác lui hơn mười trượng; dẫn Quách Tà Dật ra mắt hai Trưởng lão.","bridge":true,"khoang":"@c0478"},{"bridge":true,"khoang":"@c0480","text":"Trong đoàn tiến vào Địa Ma Bắc Giới, thỉnh thoảng liếc nhìn thân thể yêu kiều của Thiên Cầm với quang mang kỳ lạ, lộ ý đồ; không nhận ra sự kinh hoàng của hai Trưởng lão trước áp lực quỷ dị."},{"importance":"normal","chuong":"c0615","text":"Nam tu sĩ Nhiễm gia, Nhiễm Vân Tinh thuộc La Thiên Tinh Vực; tu vi Anh Biến sơ kì.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0478","canhGioi":"Hoá Thần hậu kỳ","text":"Tu vi Hoá Thần hậu kỳ","importance":"minor"}],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Là sư thúc, dẫn ra mắt hai Trưởng lão","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478","@c0480"],"aliases":["Lão già Hoá Thần hậu kỳ (sư thúc Quách Tà Dật)"]},{"id":"hai-kiem-cac-truong-lao","name":"Hai Kiếm Các Trưởng lão","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Hai lão già hắc y tu vi Anh Biến sơ kỳ đeo bảo kiếm cổ, Trưởng lão Kiếm Các của Đại La Kiếm Tông.","vaiTro":"Trưởng lão Kiếm Các Đại La Kiếm Tông","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Lao tới cùng lão Hoá Thần hậu kỳ, được Quách Tà Dật quỳ một gối tham kiến.","bridge":true,"khoang":"@c0478"}],"tuViMoc":[{"chuong":"@c0478","canhGioi":"Anh Biến sơ kỳ","text":"Cả hai tu vi Anh Biến sơ kỳ","importance":"minor"}],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Được Quách Tà Dật quỳ tham kiến","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478"]},{"id":"thieu-nu-ket-dan-dai-la-kiem-tong","name":"Thiếu nữ Kết Đan hậu kỳ (Đại La Kiếm Tông)","gioiTinh":"nu","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một trong hai nữ tử nhóm Quách Tà Dật, tu vi Kết Đan hậu kỳ, báo có người tiến vào Địa Ma Bắc Giới.","vaiTro":"Đệ tử Đại La Kiếm Tông","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0478","text":"Mặc quần lụa miệng xinh, báo với nhóm thấy có người vừa tiến vào Địa Ma Bắc Giới."}],"tuViMoc":[{"chuong":"@c0478","canhGioi":"Kết Đan hậu kỳ","text":"Tu vi Kết Đan hậu kỳ","importance":"minor"}],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Đại sư huynh dẫn đầu nhóm","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478"]},{"id":"nam-tu-ao-lam-dai-la-kiem-tong","name":"Nam tử áo lam (Đại La Kiếm Tông)","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Đệ tử trẻ chừng hai mươi bảy tám tuổi nịnh hót, đề cao Đại La Kiếm Tông và Quách Tà Dật.","vaiTro":"Đệ tử Đại La Kiếm Tông","tinhCach":[{"text":"Nịnh hót, tâng bốc đại sư huynh và sư môn","chuong":"@c0478"}],"tabs":{"diem":[],"kinhLich":[{"bridge":true,"khoang":"@c0478","text":"Khen Đại La Kiếm Tông là môn phái số một số hai Thiên Vận Tinh và đề cao Quách Tà Dật."},{"text":"Kẻ được Quách Tà Dật nịnh hót; trong khi mọi người kinh sợ, hắn lại thầm say mê cảnh tượng nam tử áo trắng bị Cửu Lê trùng ăn thịt.","bridge":true,"khoang":"@c0481"}],"tuViMoc":[],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Đại sư huynh được hắn tâng bốc","ghiChu":""},{"ten":"Quách Tà Dật","tag":"khac","quanHe":"Được Quách Tà Dật nịnh hót","ghiChu":"@c0481"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0478","@c0481"]},{"id":"lao-gia-cao-nguoi-dai-la-kiem-tong","name":"Lão già cao người (Trưởng lão Đại La Kiếm Tông)","cn":"","aliases":["Trưởng lão cao người Đại La Kiếm Tông","Lão già cao người (Trưởng lão Đại La Kiếm Tông)","Lão già cao họ Thạch","Thạch Phương Trưởng lão"],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến sơ kỳ","trangThai":"song","blurb":"Một trong hai Trưởng lão Anh Biến sơ kỳ của Đại La Kiếm Tông tham gia chuyến tìm Diệu Kim quả.","vaiTro":"Trưởng lão tra hỏi và ép dẫn đường","tinhCach":[{"text":"Hống hách nhưng còn giữ lời, đồng ý cho Thiên Cầm một quả.","chuong":"@c0479"}],"tabs":{"diem":[],"kinhLich":[{"text":"Cùng lão già thấp người tra hỏi Quách Tà Dật về Diệu Kim quả, đồng ý cho Thiên Cầm một quả sau khi thu được rồi ra lệnh cho nàng dẫn đoàn vào Địa Ma Bắc Giới.","bridge":true,"khoang":"@c0479"},{"text":"Trưởng lão Anh Biến sơ kỳ Thạch Phương cảm nhận áp lực quỷ dị như vạn sơn áp đỉnh trong Địa Ma Bắc Giới — cảm giác chưa từng gặp từ khi Hoá Thần — song vẫn quyết đi nhanh hơn. Tới sơn cốc, lão bấm quyết ngưng tụ một chiếc côn nồng đậm tiên lực hoá tiên phong thổi tan cây cối, mở thông đạo lộ ra phiến Diệu Kim quả, rồi nhận ra ổ Cửu Lê trùng ẩn dưới lá khô gần đó.","bridge":true,"khoang":"@c0480"},{"text":"Xưng danh Trưởng lão Đại La Kiếm Tông, dùng cấm thuật Kiếm phong chi cấm qua ngọc giản đỏ phong ấn nam tử áo trắng cùng đàn Cửu Lê trùng. Khi kẻ mạnh trong bụi khí xuất hiện, bấm quyết hóa bóng kiếm hư ảo hơn mười trượng chém xuống, nhưng kiếm bị đợt bụi khí phá tan.","bridge":true,"khoang":"@c0481"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già thấp người (Trưởng lão Đại La Kiếm Tông)","tag":"dong-minh","quanHe":"Đồng liêu cùng tông","ghiChu":"Hai Trưởng lão cùng tham gia chuyến tìm Diệu Kim quả."},{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Tu sĩ cùng tông bị tra hỏi","ghiChu":"Tra hỏi hắn về Diệu Kim quả."},{"ten":"Thiên Cầm cô nương","tag":"doi-thu","quanHe":"Người bị ép dẫn đường","ghiChu":"Ra lệnh nàng dẫn đường, hứa cho một quả."},{"ten":"Lão già thấp người (Trưởng lão Đại La Kiếm Tông)","tag":"dong-minh","quanHe":"Cùng là Trưởng lão Đại La Kiếm Tông, phối hợp ăn ý","ghiChu":"@c0481"},{"ten":"Người trong bụi khí (giọng lạnh lẽo)","tag":"doi-thu","quanHe":"Kẻ mạnh phá tan kiếm của hắn","ghiChu":"@c0481"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0479","@c0480","@c0481"]},{"id":"lao-gia-thap-nguoi-dai-la-kiem-tong","name":"Lão già thấp người (Trưởng lão Đại La Kiếm Tông)","cn":"","aliases":["Trưởng lão thấp người Đại La Kiếm Tông","Lão già thấp người (Trưởng lão Đại La Kiếm Tông)"],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến sơ kỳ","trangThai":"song","blurb":"Một trong hai Trưởng lão Anh Biến sơ kỳ của Đại La Kiếm Tông, mắt bừng tinh quang khi nghe Diệu Kim quả có khoảng trăm quả.","vaiTro":"Trưởng lão tham lam Diệu Kim quả","tinhCach":[{"text":"Tham lam, mắt bừng tinh quang khi nghe số lượng Diệu Kim quả.","chuong":"@c0479"}],"tabs":{"diem":[],"kinhLich":[{"text":"Hỏi Thiên Cầm số lượng Diệu Kim quả; nghe đáp ước chừng trăm quả thì mắt bừng tinh quang, lộ rõ tham vọng.","bridge":true,"khoang":"@c0479"},{"text":"Trưởng lão Anh Biến sơ kỳ cảm giác kích động muốn giết người khi gặp Khổ Ảnh thú, từng đề nghị rời đi. Tới sơn cốc, lão chỉ ra cần dược dẫn đối phó Cửu Lê trùng rồi bất ngờ dùng lực vô hình chụp lấy gã đồng môn áo trắng bên người Thiên Cầm, ném thẳng vào sơn cốc làm mồi, lộ nụ cười tàn nhẫn.","bridge":true,"khoang":"@c0480"},{"text":"Tiến vào sơn cốc trước, bắn kiếm khí diệt sạch Cửu Lê trùng còn sót, ra lệnh cho Lữ Tùng Nghĩa đi hái Diệu Kim quả. Khi bụi khí áp tới, ném ra gương đồng một mặt tỏa thanh quang chống đỡ, nhưng gương bị giọng lạnh lẽo phá vỡ răng rắc.","bridge":true,"khoang":"@c0481"},{"text":"Sau khi Vương Lâm phá Huyết Thủ ấn và diệt Thiên Quỷ đầu, lão già thấp người liều mạng bỏ chạy nhưng bị thanh loan đao cùng kiếm tiên (nhốt Hứa Lập Quốc) đuổi theo giam giữ, chờ Vương Lâm tra hỏi.","bridge":true,"khoang":"@c0483"},{"text":"Ở chỗ sâu Địa Ma Bắc giới, lão mặt tái nhợt khoanh chân ngồi trên đại thụ không dám cử động: cách mi tâm một tấc có thanh loan đao lơ lửng bất động, cách thiên linh cái một tấc là một kiếm tiên với kiếm quang nồng đậm không tiêu tán đang đe doạ.","bridge":true,"khoang":"@c0484"},{"chuong":"@c0485","importance":"normal","tieuDe":"Khai Bí Mật Rồi Bị Diệt","text":"Tu sĩ Đại La Kiếm Tông, từng đến Địa Tinh cùng Thạch Phương và trêu chọc phải Vương Lâm. Bị phi kiếm cực cứng và loan đao quỷ dị của Vương Lâm khống chế đến không dám chạy, lão đành đứng chờ và cam đoan khai thật: chuyện Kiếm Tôn trở về bị kiếm hồn truy kích, phong ấn 1/3 kiếm hồn trong Đông Hải Yêu Linh chi môn, cùng bí mật ba đại cấm địa và phần thưởng Yêu Linh quán đính. Khai xong bị loan đao xuyên đầu, lão tu Tam phân thần thức thuật tái sinh lần cuối, thề về Đại La Kiếm Tông báo thù, nhưng vừa bay đi liền bị hai làn khí xám của Vương Lâm xuyên thân hút sạch sức sống mà chết thật."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già cao người (Trưởng lão Đại La Kiếm Tông)","tag":"dong-minh","quanHe":"Đồng liêu cùng tông","ghiChu":"Hai Trưởng lão cùng tham gia chuyến tìm Diệu Kim quả."},{"ten":"Thiên Cầm cô nương","tag":"doi-thu","quanHe":"Người bị tra hỏi số lượng quả","ghiChu":"Hỏi nàng số lượng Diệu Kim quả."},{"ten":"Lữ Tùng Nghĩa","tag":"dong-minh","quanHe":"Sai đi hái Diệu Kim quả","ghiChu":"@c0481"},{"ten":"Người trong bụi khí (giọng lạnh lẽo)","tag":"doi-thu","quanHe":"Kẻ mạnh phá vỡ gương đồng của lão","ghiChu":"@c0481"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm truy sát, giam giữ chờ thẩm vấn.","ghiChu":"@c0483"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ bắt giam và xử tử","ghiChu":"Ép khai bí mật Đông Hải Yêu Linh chi môn rồi giết cả hai lần."},{"ten":"Thạch Phương","tag":"dong-hanh","quanHe":"Bạn đồng hành đến Địa Tinh","ghiChu":"Cùng đến Địa Tinh; lời khai của lão bị Vương Lâm lấy lời Thạch Phương làm chuẩn đối chiếu."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0479","@c0480","@c0481","@c0483","@c0484","@c0485"]},{"id":"nam-tu-ao-trang-dong-mon-thien-cam","name":"Nam tử áo trắng (đồng môn Thiên Cầm)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Sư môn của Thiên Cầm","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Tu sĩ cùng sư môn với Thiên Cầm, tức giận trách Đại La Kiếm Tông nhưng bị Thiên Cầm quát im.","vaiTro":"Đồng môn bất bình của Thiên Cầm","tinhCach":[{"text":"Nóng nảy, bất bình thay sư môn nhưng phải nhẫn nhịn.","chuong":"@c0479"}],"tabs":{"diem":[],"kinhLich":[{"text":"Tức giận trách Đại La Kiếm Tông về việc sư môn phải hy sinh nhiều trưởng bối mới tìm được Diệu Kim quả, nhưng bị Thiên Cầm quát ‘Câm mồm!’ buộc phải im lặng nhẫn nhịn.","bridge":true,"khoang":"@c0479"},{"bridge":true,"khoang":"@c0480","text":"Bị lão già thấp người dùng lực vô hình chụp lấy và ném thẳng vào sơn cốc làm dược dẫn thử Cửu Lê trùng; vừa tiến vào liền bị vô số điểm đỏ Cửu Lê trùng lao tới."},{"chuong":"@c0481","importance":"normal","tieuDe":"Bị Cửu Lê trùng ăn thịt đến chết","text":"Bị ném vào giữa sơn cốc, vô số Cửu Lê trùng phá quần áo chui vào da thịt; chưa đến ba tức toàn thân lộ huyết sắc, hắn tự cào cấu da thịt lộ cả xương cốt, dãy dụa thảm thiết rồi tắt tiếng, hai mắt ảm đạm tuyệt vọng oán hận."}],"tuViMoc":[],"nhanMach":[{"ten":"Thiên Cầm cô nương","tag":"su-mon","quanHe":"Cùng sư môn","ghiChu":"Bị nàng quát im khi tức giận trách Đại La Kiếm Tông."},{"ten":"Thiên Cầm","tag":"su-mon","quanHe":"Sư muội chứng kiến hắn chết","ghiChu":"@c0481"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0479","@c0480","@c0481"]},{"id":"lu-tung-nghia","name":"Lữ Tùng Nghĩa","gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Hóa Thần kỳ","trangThai":"song","blurb":"Lão già Hóa Thần kỳ, sư thúc của Quách Tà Dật, được sai vào sơn cốc Địa Ma Bắc giới hái Diệu Kim quả.","vaiTro":"Trợ thủ trong nhóm Quách Tà Dật và hai Trưởng lão Đại La Kiếm Tông, đảm nhận việc hái Diệu Kim quả.","tinhCach":[{"text":"Tuân lệnh, hành động dứt khoát, lao như điện về phía Diệu Kim quả khi được sai.","chuong":"@c0481"}],"tabs":{"diem":[{"text":"Lão già Hóa Thần kỳ, vai vế sư thúc của Quách Tà Dật.","chuong":"@c0481"}],"kinhLich":[{"text":"Vào sơn cốc thứ ba sau hai Trưởng lão, được lão già lùn ra lệnh đi hái Diệu Kim quả. Khi biến cố bụi khí nổ ra, lão lao như điện tới được bên cạnh đóa hoa trên tảng đá vàng.","bridge":true,"khoang":"@c0481"}],"tuViMoc":[{"chuong":"@c0481","canhGioi":"Hóa Thần kỳ","text":"Xuất hiện với cảnh giới Hóa Thần kỳ.","importance":"minor"}],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Cháu (sư điệt)","ghiChu":"@c0481"},{"ten":"Lão già lùn (Trưởng lão Đại La Kiếm Tông)","tag":"dong-minh","quanHe":"Nhận lệnh hái Diệu Kim quả","ghiChu":"@c0481"}],"tuiDo":{}},"nguon":["@c0481"]},{"id":"nu-tu-su-muoi-quach-ta-dat","name":"Nữ tử (sư muội Quách Tà Dật)","gioiTinh":"nu","trangThai":"song","blurb":"Nữ tử gọi Quách Tà Dật là sư huynh; tái nhợt run rẩy trước cảnh tàn khốc trong sơn cốc.","tabs":{"diem":[],"kinhLich":[{"text":"Đi cùng nhóm Quách Tà Dật, sắc mặt tái nhợt và run rẩy vì kinh sợ khi chứng kiến nam tử áo trắng bị Cửu Lê trùng ăn thịt.","bridge":true,"khoang":"@c0481"}],"tuViMoc":[],"nhanMach":[{"ten":"Quách Tà Dật","tag":"su-mon","quanHe":"Sư huynh","ghiChu":"@c0481"}],"tuiDo":{}},"nguon":["@c0481"]},{"id":"nguoi-trong-bui-khi-giong-lanh-leo","name":"Người trong bụi khí (giọng lạnh lẽo)","gioiTinh":"khong-ro","trangThai":"khong-ro","blurb":"Kẻ mạnh ẩn trong đoàn bụi khí nồng đậm, thực lực áp đảo hai Trưởng lão Đại La Kiếm Tông; danh tính chưa rõ.","tabs":{"diem":[{"text":"Ẩn trong bụi khí, chỉ một câu nói và một đợt bụi khí đã phá vỡ gương đồng và kiếm của hai Trưởng lão.","chuong":"@c0481"}],"kinhLich":[{"text":"Xuất hiện sau cơn gió mát khiến hai Trưởng lão đại biến sắc mặt. Đoàn bụi khí nồng đậm bùng lên như vạn mã, phá tan thanh quang gương đồng và kiếm khí Thạch Phương; từ trong bụi khí truyền ra giọng lạnh lẽo: “Ánh sáng của đom đóm há có thể so sánh với ánh trăng!”","bridge":true,"khoang":"@c0481"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Phương","tag":"doi-thu","quanHe":"Phá tan kiếm của Thạch Phương","ghiChu":"@c0481"},{"ten":"Lão già lùn (Trưởng lão Đại La Kiếm Tông)","tag":"doi-thu","quanHe":"Phá vỡ gương đồng của lão","ghiChu":"@c0481"}],"tuiDo":{}},"nguon":["@c0481"]},{"id":"thach-phuong","name":"Thạch Phương","gioiTinh":"nam","aliases":[],"theLuc":[{"ten":"Sư môn của Thiên Cầm","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"tu-vong","blurb":"Trưởng lão của nhóm tiểu bối (đồng môn Thiên Cầm, Quách Tà Dật), tinh thông đoạt xá siêu tốc; bị Vương Lâm tiêu diệt tại sơn cốc.","vaiTro":"Phản diện một chương — trưởng lão kiếm tu nguyên thần ly thể đối đầu Vương Lâm.","tinhCach":[{"text":"Gian xảo, tham sống sợ chết: đoạt xá vật chủ, cầu xin và sẵn sàng giết môn hạ để mua mạng.","chuong":"@c0483"}],"tabs":{"diem":[{"text":"Nắm phương pháp đoạt xá siêu tốc, gần như khôi phục thần trí tức thì sau khi chiếm thân.","chuong":"@c0483"}],"kinhLich":[{"text":"Kiếm quang cùng nguyên thần ly thể của Thạch Phương xông tới mi tâm Vương Lâm nhưng bị Tứ chuyển hàm tiên lực vỗ tan, tiên ảnh đánh trọng thương nguyên thần, Văn thú nuốt sạch thân xác. Hắn vội đoạt xá tiểu bối Quách Tà Dật theo lối siêu tốc, cầu xin tha mạng, giết hai tiểu bối để chứng minh thành ý và hiến ngọc giản đoạt xá.","bridge":true,"khoang":"@c0483"},{"chuong":"@c0483","importance":"normal","tieuDe":"Bị khí xám nổ tung","text":"Sau khi ghi ngọc giản, Thạch Phương tranh thủ bỏ chạy khỏi sơn cốc nhưng thân vừa đoạt xá quá suy yếu; hai đạo khí xám của Vương Lâm chui vào kinh mạch khiến thân hắn nổ tung, để lại một khối cầu xám."},{"importance":"normal","chuong":"c0613","text":"Phó tướng yêu tướng phủ Thiên Yêu quận, tu vi ngang Vấn Đỉnh trung kỳ; khinh miệt Vương Lâm.","nguonNblm":true}],"tuViMoc":[],"tuVi":"Tu sĩ có nguyên thần ly thể dung trong bản mạng phi kiếm; cảnh giới cụ thể không nêu rõ.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm đánh tan nguyên thần, nuốt thân xác và cuối cùng giết chết.","ghiChu":"@c0483"},{"ten":"Quách Tà Dật","tag":"doi-thu","quanHe":"Tiểu bối bị Thạch Phương đoạt xá làm vật chủ.","ghiChu":"@c0483"},{"ten":"Thiên Cầm cô nương","tag":"su-mon","quanHe":"Trưởng lão của nhóm tiểu bối có Thiên Cầm; định mượn thân xử nữ Thiên Cầm để chữa thương.","ghiChu":"@c0483"}],"tuiDo":{"phapBao":[{"ten":"Liễu diệp phi kiếm","loai":"bản mạng pháp khí","trangThai":"mat","moTa":"Phi kiếm hình lá liễu dung nguyên thần ly thể, bị tiên ảnh đánh chấn động hào quang ảm đạm.","nguon":"@c0483"}]}},"nguon":["@c0483"]},{"id":"kiem-ton","name":"Kiếm Tôn","gioiTinh":"nam","theLuc":[],"trangThai":"khong-ro","blurb":"Cường giả từ tiên giới trở về, bị một đạo kiếm hồn đáng sợ truy kích; sau mấy ngày giao chiến đã phong ấn hơn 1/3 kiếm hồn cùng Chu Dật tại chỗ sâu trong Đông Hải Yêu Linh chi môn.","vaiTro":"Nhân vật được nhắc tới, liên quan trực tiếp đến mục tiêu chuyến đi của Vương Lâm.","tabs":{"diem":[{"text":"Từ tiên giới trở về, đủ sức phong ấn một đạo kiếm hồn cường đại trong cấm địa.","chuong":"@c0485"}],"kinhLich":[{"text":"Theo lời khai của lão già Đại La Kiếm Tông: lúc Kiếm Tôn từ tiên giới trở về có một đạo kiếm hồn đáng sợ từ chân trời truy kích, đánh nhau mấy ngày, cuối cùng kiếm hồn tan vỡ; hơn 1/3 bị Kiếm Tôn phong ấn tại chỗ sâu trong Đông Hải Yêu Linh chi môn, cùng nơi đó phong ấn Chu Dật.","bridge":true,"khoang":"@c0485"},{"text":"Hóa thanh kiếm cổ mang thiên uy phóng tới cửa Đông Hải Yêu Linh, ngồi khoanh chân trên Hùng Lân thú với bốn đạo kiếm quang hư ảnh sau lưng, dẫn theo Kiếm Tiếu Thập Nhị Tử của Đại La Kiếm Tông; tạo khoảng trống trăm dặm khiến tu sĩ vội tránh né.","bridge":true,"khoang":"@c0487"},{"chuong":"@c0487","importance":"normal","tieuDe":"Mục đích nhốt kiếm hồn","text":"Tiết lộ ý đồ mượn hiện tượng thủy triều năm nghìn năm một lần để hút đạo kiếm hồn của một nữ quân tiên giới chìm sâu vĩnh viễn vào Đông Hải, quyết không để vật ấy rơi vào tay Thiên Vận lão tặc; ngay sau đó lão hữu cũ Tham Lang phá hư không xông tới tìm hắn."}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới cụ thể; đủ sức phong ấn kiếm hồn cường đại.","nhanMach":[{"ten":"Chu Dật","tag":"doi-thu","quanHe":"Người bị phong ấn","ghiChu":"Bị Kiếm Tôn phong ấn trong Đông Hải Yêu Linh chi môn."},{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"Kình địch cả đời, hai người đối lập kéo dài nhiều năm"},{"ten":"Tham Lang","tag":"dong-minh","quanHe":"Lão hữu cũ tới nhờ vả, muốn tặng hắn một cơ duyên cực lớn"},{"ten":"Diêu Tích Tuyết","tag":"khac","quanHe":"Lão quái phải kiêng nể hắn ở cửa Đông Hải"}],"tuiDo":{}},"nguon":["@c0485","@c0487"],"aliases":["Kiếm Tôn","Lăng Thiên Hậu","Lăng Thiên lão hữu"]},{"id":"dieu-tich-tuyet","name":"Diêu Tích Tuyết","cn":"","aliases":["Con gái Huyết Tổ","#dieu-tich-huyet"],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Con gái duy nhất của Huyết Tổ Diêu Tinh Hải, được cha truyền toàn bộ công pháp huyết hệ; xuất hiện ngồi trên huyết ngọc khổng lồ bay tới ngoài Đông Hải Yêu Linh. (+) Nữ nhi của Huyết Tổ, đang mất tích; khí tức bị cảm nhận trên người Vương Lâm, nghi bị hắn bắt đi. [CAN-SOAT-GOP]","vaiTro":"Cường giả huyết hệ trẻ tuổi đến chờ cửa Đông Hải Yêu Linh mở.","tinhCach":[{"text":"Lạnh lùng, kín tiếng — đến nơi không nói lời nào, nhắm mắt khoanh chân ngồi chờ.","chuong":"@c0486"}],"tabs":{"diem":[{"text":"Mắt phượng mi cong, da trắng bóng như thủy tinh, ánh mắt ẩn thâm thúy u hàn khiến người nhìn vào như vạn kiếp bất phục.","chuong":"@c0486"},{"text":"Cùng cha Huyết Tổ là hai người duy nhất biết bí mật hư phủ thứ tư","chuong":"@c0614"}],"kinhLich":[{"text":"Giữa hồng quang che trời và mùi máu tanh nồng đậm, nàng ngồi trên bức tượng huyết ngọc khổng lồ bay tới ngoài cửa Đông Hải Yêu Linh, dừng ở chỗ trống rồi nhắm chặt mắt khoanh chân ngồi, không nói lời nào.","bridge":true,"khoang":"@c0486"},{"bridge":true,"khoang":"@c0487","text":"Là con gái Huyết Tổ, có uy thế lớn nên trong phạm vi trăm trượng quanh nàng không ai dám tới; khi Kiếm Tôn Lăng Thiên Hậu xuất hiện ở cửa Đông Hải Yêu Linh nàng cũng phải kinh hãi than “Kiếm Tôn!”."},{"bridge":true,"khoang":"@c0488–@c0488","text":"Diêu Tích Tuyết ngồi trên khối huyết sắc ngọc thạch, theo lời dặn của phụ thân quan sát Vương Lâm; kinh ngạc vì một đệ tử tu vi tầm thường vừa gia nhập Thiên Vận Tử đã được chỉ đích danh vào Đông Hải."},{"text":"Đang ngồi trên khối huyết ngọc ở phương xa quan sát thủy triều hồng quang, nàng vô ý đảo mắt nhìn qua chỗ Vương Lâm. Vừa thấy ánh mắt hắn dày đặc tơ máu lẫn khí xám yêu dị sau khi vận thần thông, nàng chấn động không tự chủ, mặt tái nhợt vội cúi đầu, trong lòng dậy sóng và hiểu ra vì sao phụ thân dặn nàng phải chú ý đến người này.","bridge":true,"khoang":"@c0490"},{"text":"Đứng trên huyết ngọc lộ vẻ suy tư, cắn răng hóa thành đạo huyết quang bay vào lối vào cánh cửa Đông Hải yêu linh.","bridge":true,"khoang":"@c0491"},{"text":"Đứng xa quan sát trận đấu của Vương Lâm, Diêu Tích Tuyết nhớ lại ba năm trước nàng cũng bại dưới Thập Băng Quyền Ý: đến lần thứ tư đã quá sức, nhờ Huyết thuật gia truyền của dòng Huyết tổ mới sống quá lần thứ năm, cuối cùng bại ở lần thứ tám và được ban chức Thống lĩnh.","bridge":true,"khoang":"@c0510"},{"text":"Đứng quan sát ở xa, Diêu Tích Tuyết biến sắc nhìn Vương Lâm phá liên tiếp các lần sụp đổ của Thập Băng Quyền Ý. Nàng nhớ lại lời phụ thân Huyết Tổ rằng người có chú ý đến Vương Lâm, càng thêm để tâm tới hắn.","bridge":true,"khoang":"@c0511"},{"bridge":true,"khoang":"@c0512","text":"Chứng kiến Vương Lâm được phong Thống lĩnh, nàng định mở miệng nói gì đó nhưng bị Vương Lâm phớt lờ không nhìn; nàng nhíu mày hừ nhẹ rồi bỏ đi."},{"text":"Tại quân doanh thứ ba, đêm trăng tím nửa-năm-một-lần, nàng dùng la bàn đỏ, cây đèn trắng và giọt máu lam thi triển pháp thuật xông vào vực sâu nơi thủy triều theo kế hoạch của phụ thân. Lần thứ tư vẫn thất bại, nhờ Huyết Hồn đan mới tái sinh trở về; nàng phá được hơn một nửa và nghĩ nếu có người giúp nhất định thành công — rồi gọi tên Vương Lâm.","bridge":true,"khoang":"@c0517"},{"text":"Bị Vương Lâm lỡ hẹn ở cổ sơn, Diêu Tích Tuyết nổi giận hóa tia sáng trắng xông thẳng vào quân doanh Hắc Giáp quân — trận pháp doanh trại vô hiệu với nàng vì nàng là thống lĩnh. Nàng dùng tia sáng đỏ khống chế Thập Tam, phong tỏa chín ngàn yêu binh, rồi vào lầu cầu Vương Lâm cùng phá trận pháp mười tám phong ấn, hứa cung cấp toàn bộ tiên ngọc làm trọng tạ.","bridge":true,"khoang":"@c0518"},{"bridge":true,"khoang":"@c0518","text":"Nàng hé lộ trận có mười tám phong ấn mà một mình chỉ phá được tới cái thứ mười một; nội tâm nàng giấu việc phá trận liên quan sinh tử — đã thất bại bốn lần, chết bốn lần, hao bốn viên Huyết Hồn đan trong số mười ba viên do phụ thân luyện."},{"chuong":"@c0519","importance":"normal","tieuDe":"Trao Huyết Hồn đan nhờ bài trừ phong ấn","text":"Sau khi chứng kiến Vương Lâm đánh trận với Yêu Tương, nàng tin chỉ hắn đủ sức giúp bài trừ phong ấn cấm chế bí mật trên người mình. Bị hắn liên tục trì hoãn, nàng nổi giận rồi rốt cuộc giao cây đèn Huyết Hồn đan, ném thêm túi tiên ngọc cùng lời hứa lệnh bài Huyết Phù, hẹn ba ngày sau canh ba ở cổ sơn cùng đi; sự hào phóng khác thường này khiến Vương Lâm sinh nghi."},{"text":"Trên cổ sơn dưới trăng tím, nàng xuất bảy pho tượng đỏ như máu, cắn lưỡi vẽ ký tự máu trăm trượng dựng trận ẩn thân khiến thần thức không soi thấy chính mình, nói cả Yêu Tương cũng không phát hiện được. Sau đó nàng dùng la bàn đỏ canh thời điểm yêu khí cực điểm, dẫn Vương Lâm vượt truyền tống trận tới không gian Tôn Long, hứa trao lệnh bài Huyết Phủ và tiên ngọc khi trở về.","bridge":true,"khoang":"@c0520"},{"text":"Diêu Tích Tuyết đắc kim phù ấn ba nét — ký hiệu màu vàng ngưng tụ trong mi tâm tỏa uy nghiêm như vô thượng tiên tôn. Khi Vương Lâm đắc kim phù sáu nét, kim phù trong mắt nàng nhạt hẳn đi như đốm lửa so với trăng rằm; nàng khó chịu, vô thức tránh ánh mắt hắn rồi dẫn hắn lên con đường Tôn Long. Tới bình đài đầu tiên, nàng kích hoạt pho tượng đá (uy lực ngang Anh Biến sơ kỳ) rồi ném ngọc phù màu máu hô “Phong!” phong ấn tượng dễ dàng, hẹn Vương Lâm phá giải tầng thứ hai.","bridge":true,"khoang":"@c0521"},{"text":"Nữ tử áo đỏ cùng Vương Lâm men theo con đường Tôn Long qua các bình đài. Tới bình đài thứ ba có tượng đá ba mắt, nàng nhường Vương Lâm thử trước. Vương Lâm ngầm đoán cái ngọc phù đỏ như máu của nàng do phụ thân — Huyết Tổ — luyện chế, và nhận định nàng sở hữu Huyết Hồn đan nên dù bị đánh lén cũng sống lại được, rất khó giết.","bridge":true,"khoang":"@c0522"},{"text":"Đưa Vương Lâm vượt các tầng phong ấn để tới động phủ tiên nhân, nói dối rằng có mười tám tầng. Nàng hé lộ cha mình là Huyết Tổ nghe tin động phủ từ miệng một Yêu Đế, và mình đã uống Huyết Hồn Đan nên không sợ chết khi tiếp ba đạo kiếm khí.","bridge":true,"khoang":"@c0523"},{"chuong":"@c0523","importance":"major","tieuDe":"Bị phong ấn giữa sinh tử","text":"Sau khi gắng tiếp đạo kiếm khí thứ hai và thứ ba đến cạn tiên lực, nàng bị Vương Lâm từ hư vô bay lên điểm mi tâm, đứt kinh mạch, phong ấn toàn thân giữa sự sống và cái chết — vô hiệu hóa Huyết Hồn Đan vốn phải chết mới dùng được — rồi mất sạch trữ vật."},{"text":"Bị Vương Lâm chất vấn vì sao vội vàng vào động phủ, Diêu Tích Tuyết chỉ đáp muốn vào không có nguyên nhân, từ chối khai thật. Vương Lâm lạnh mặt bủa cấm chế nhốt nàng vào một quả cầu hắc quang, áp phong ấn cực hạn năm trăm năm trong Yêu Linh rồi cất vào túi trữ vật.","bridge":true,"khoang":"@c0524"},{"chuong":"@c0531","importance":"major","tieuDe":"Vỡ kế tự sát & bị thu vào túi trữ","text":"Trong sơn cốc Luyện Hồn, từ chối đề nghị giảm phong ấn 50 năm của Vương Lâm, mắng chửi thề báo thù qua phụ thân Huyết Tổ; giấu tia tinh khí nguyên thần cuối cùng hóa cây châm đỏ trong miệng định chặn sinh cơ của Sinh Chi Lạc Ấn để tự sát nhưng bị Vương Lâm lôi ra bóp vỡ, kế chuyển hận nhập đạo cầu thoát phong ấn cũng bị phá bằng kích thích tuần hoàn cấm chế, cuối cùng bị thu thành quả cầu cấm chế cất vào túi trữ vật."},{"chuong":"@c0564","importance":"normal","tieuDe":"Bị Uy Hiếp Đòi Cách Dùng Huyết Hồn Đan","text":"Diêu Tích Tuyết bị Vương Lâm phong ấn trong tiểu cầu đầy cấm chế ở túi trữ vật, đang trong trạng thái kỳ dị vừa thống khổ vừa nhục nhã (mặt hồng, mồ hôi đầm đìa). Vương Lâm phân thần thức tới uy hiếp nàng nói ra phương pháp dùng Huyết Hồn đan, dọa bóp nát túi trữ vật dung nàng vào hư vô. Thần niệm hắn đánh vào thần thức nàng như sấm khiến nàng thanh tỉnh rồi giãy dụa gần như suy sụp."},{"importance":"normal","chuong":"c0613","text":"Nữ nhi duy nhất, thân nhân duy nhất của Huyết Tổ (đại năng xích bào).","nguonNblm":true},{"importance":"normal","chuong":"c0614","text":"Khí tức của nàng được Huyết Tổ cảm nhận trên người Vương Lâm, suy ra nàng mất tích liên quan tới Vương Lâm, nghi đã bị hắn bắt đi.","nguonNblm":true},{"importance":"normal","chuong":"c0623","text":"Một trong ba người (cùng Tôn Tích và lão tổ Nhiễm Gia) đồng thời xuất thủ cướp năm viên bát phẩm đan dược từ một tu sĩ ngoại lai trọng thương chạy đến Thiên Vận Tinh bốn năm trước; tu sĩ này chết trong tay Nhiễm Gia lão tổ.","nguonNblm":true},{"text":"Huyết Tổ cảm nhận khí tức Diêu Tích Huyết trên người Vương Lâm, suy ra nàng mất tích liên quan tới Vương Lâm, có thể đã bị hắn bắt đi.","bridge":true,"khoang":"@c0614"}],"tuViMoc":[],"tuVi":"Được Huyết Tổ truyền toàn bộ công pháp huyết hệ; tu vi cụ thể chưa rõ.","nhanMach":[{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"cha-me","quanHe":"Cha ruột","ghiChu":"Được cha coi như ngọc quý, truyền toàn bộ công pháp."},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"cha-me","quanHe":"Phụ thân"},{"ten":"Kiếm Tôn","tag":"khac","quanHe":"Đại lão khiến nàng phải kiêng nể"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người nàng được phụ thân dặn chú ý","ghiChu":"Bị ánh mắt mang khí xám của Vương Lâm làm chấn động (@c0490)."},{"ten":"Tả dực Yêu tương","tag":"doi-thu","quanHe":"Người thi triển Thập Băng Quyền Ý khiến nàng bại trận","ghiChu":"Diêu Tích Tuyết bại ở lần thứ tám của quyền ý, sau nhận chức Thống lĩnh ở Cổ Yêu thành."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Đối tượng để tâm","ghiChu":"Quan sát Vương Lâm phá Thập Băng Quyền Ý, nhớ lời phụ thân về hắn."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người nàng nghĩ tới để nhờ giúp xông “nơi đó”","ghiChu":""},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Tìm tới nhờ Vương Lâm cùng phá trận cấm chế, dùng tiên ngọc làm mồi"},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"cha-me","quanHe":"Phụ thân, người dày công luyện mười ba viên Huyết Hồn đan cho nàng"},{"ten":"Thập Tam","tag":"doi-thu","quanHe":"Khống chế Thập Tam bằng tia sáng đỏ khi xông vào lầu Vương Lâm"},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"cha-me","quanHe":"Phụ thân, tu sĩ đứng thứ ba Thiên Vận tinh","ghiChu":"Sở hữu độc môn Huyết Hồn đan; động phủ cất nhiều tiên ngọc"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người nàng nhờ giúp bài trừ phong ấn","ghiChu":"Trao Huyết Hồn đan và tiên ngọc làm thù lao"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đối tượng nàng tìm cách lôi kéo, đưa tiên ngọc và Huyết Hồn đan rồi dẫn vào không gian Tôn Long","ghiChu":"Hành xử hào hiệp nhưng theo mưu kế của Huyết Tổ; Vương Lâm đã đề phòng."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người đồng hành trên con đường Tôn Long.","ghiChu":"@c0522"},{"ten":"Huyết Tổ Diêu Tinh Hải","tag":"cha-me","quanHe":"Phụ thân; được cho là người luyện chế ngọc phù đỏ như máu có thần thông.","ghiChu":"@c0522"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Định mượn tay phá phong ấn rồi diệt, nhưng bị phản đòn và phong ấn giữa sinh tử.","ghiChu":""},{"ten":"Động Phủ Chi Linh","tag":"khac","quanHe":"Quen biết công pháp Huyết Quân của tổ tiên nàng nên đã ba lần tha mạng nàng.","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người phong ấn nàng","ghiChu":"Đề nghị giảm năm mươi năm đổi câu trả lời, nàng không hợp tác nên bị nhốt và mang theo."},{"ten":"Thanh Sương","tag":"khac","quanHe":"Danh tính liên quan tới lực lượng thần bí ban kim phù ấn tại Yêu Linh chi địa","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ giam cầm và uy hiếp nàng","ghiChu":"Bị ép nói cách dùng Huyết Hồn đan. @c0564"},{"ten":"Huyết Tổ","tag":"cha-me","quanHe":"Cha","ghiChu":"@c0614"}],"tuiDo":{"phapBao":[{"ten":"Huyết ngọc (tượng huyết sắc)","trangThai":"dang-co","moTa":"Bức tượng huyết sắc khổng lồ bằng ngọc thạch, tỏa hồng quang và mùi máu tanh, dùng làm phương tiện bay trong tinh không.","nguon":"@c0486"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0486","@c0487","@c0488","@c0490","@c0491","@c0510","@c0511","@c0512","@c0517","@c0518","@c0519","@c0520","@c0522","@c0523","@c0524","@c0531","@c0521","@c0564","@c0614"]},{"id":"huyet-to-dieu-tinh-hai","name":"Huyết Tổ Diêu Tinh Hải","cn":"","aliases":["Huyết Tổ"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Thông Thiên","trangThai":"song","blurb":"Lão quái tu vi thông thiên của Thiên Vận Tinh, từng bảy lần khiêu chiến Thiên Vận Tử; độc chiếm Huyết Tinh khai hoang nạp huyết tu luyện ma công, cha của Diêu Tích Tuyết.","vaiTro":"Cường giả huyết hệ ẩn cư, được nhắc tới trong chương (chưa ra mặt).","tinhCach":[{"text":"Cô độc, cường ngạnh — cả đời không thu đồ đệ, chỉ dồn tâm huyết cho con gái.","chuong":"@c0486"}],"tabs":{"diem":[{"text":"Bảy lần khiêu chiến Thiên Vận Tử đều thất bại nhưng tu vi càng lúc càng cao, lần thứ bảy thi triển Huyết Công kinh người.","chuong":"@c0486"}],"kinhLich":[{"text":"Bảy lần khiêu chiến chủ nhân Thiên Vận Tinh là Thiên Vận Tử, tuy đều thất bại nhưng tu vi mỗi lần một mạnh; lần thứ bảy thi triển Huyết Công khiến người kinh sợ.","bridge":true,"khoang":"@c0486"},{"text":"Độc chiếm một tinh cầu bên ngoài Thiên Vận Tinh (Huyết Tinh), khai hoang nạp huyết tu luyện ma công; cả đời không thu đồ đệ, đem toàn bộ công pháp truyền cho con gái rồi nghịch thiên cải mệnh.","bridge":true,"khoang":"@c0486"},{"chuong":"@c0613","importance":"normal","tieuDe":"Bất an vì nữ nhi mất tích","text":"Đại năng xích bào; bất an vì mất liên lạc với Diêu Tích Huyết — nữ nhi duy nhất, thân nhân duy nhất. Cùng đám đại năng tiến vào cánh cửa Yêu Linh; quét thần thức ngang vùng đất Yêu Linh không thấy nàng, sắc mặt càng âm trầm."},{"text":"Khoảnh khắc cuối, thần thức Huyết Tổ cảm nhận khí tức Diêu Tích Huyết — nữ nhi của mình — trên người Vương Lâm, suy ra con gái mất tích liên quan Vương Lâm, quát hỏi nữ nhi ở đâu. Vương Lâm để lại câu hư phủ không chỉ có ba mà có bốn tòa, bí mật vốn chỉ Huyết Tổ và Diêu Tích Huyết biết, khiến các lão quái nghi kỵ. Huyết Tổ thừa nhận có hư phủ thứ tư đã bị Vương Lâm chiếm cứ, đề nghị liên thủ đưa Tham Lang vào La Thiên tinh vực bắt người này về.","bridge":true,"khoang":"@c0614"},{"chuong":"@c0614","importance":"normal","tieuDe":"Cảm khí Diêu Tích Huyết, bị Vương Lâm phản kích","text":"Thần thức cảm nhận khí tức Diêu Tích Huyết trên người Vương Lâm, suy ra con gái mất tích liên quan Vương Lâm. Quát hỏi nữ nhi ở đâu nhưng Vương Lâm để lại câu nói bí mật hư phủ thứ tư rồi biến mất, khiến Huyết Tổ rơi vào thế bị các lão quái nghi kỵ. Thừa nhận hư phủ thứ tư tồn tại, đề nghị cử Tham Lang vào La Thiên tinh vực truy bắt Vương Lâm, mỗi người đặt cấm chế."}],"tuViMoc":[],"tuVi":"Tu vi thông thiên, sở trường công pháp huyết hệ.","nhanMach":[{"ten":"Diêu Tích Tuyết","tag":"cha-me","quanHe":"Con gái ruột","ghiChu":"Coi như ngọc quý, truyền toàn bộ công pháp."},{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bảy lần khiêu chiến."},{"ten":"Diêu Tích Huyết","tag":"cha-me","quanHe":"Huyết Tổ là cha của Diêu Tích Huyết; cảm khí tức con gái trên người Vương Lâm","ghiChu":"@c0614"},{"ten":"Tham Lang","tag":"khac","quanHe":"Huyết Tổ đề nghị cử Tham Lang vào La Thiên tinh vực bắt Vương Lâm","ghiChu":"@c0614"},{"ten":"Diêu Tích Huyết","tag":"cha-me","quanHe":"Cha — con gái","ghiChu":"Nữ nhi duy nhất, thân nhân duy nhất; biến mất khỏi vùng đất Yêu Linh khiến Huyết Tổ bất an."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[{"ten":"Huyết Công","moTa":"Ma công huyết hệ sở trường, thi triển trong lần thứ bảy khiêu chiến Thiên Vận Tử.","nguon":"@c0486"}],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0486","@c0614","@c0613"]},{"id":"ton-van-son","name":"Tôn Vân Sơn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thiếu tông chủ Huyền Uyên phái, hay cầm quạt thúy ngọc; ngăn em gái lên Đông Hải Yêu Linh và long trọng chờ đón Vương huynh đến qua truyền tống trận.","vaiTro":"Người chủ trì truyền tống trận của Huyền Uyên phái, đón Vương Lâm.","tinhCach":[{"text":"Điềm tĩnh, có uy — quát mắng em gái nhưng vẫn giữ phong thái thong dong.","chuong":"@c0486"}],"tabs":{"diem":[{"text":"Thường cầm quạt thúy ngọc đập nhẹ vào lòng bàn tay, chốc chốc nhìn về phương xa chờ khách.","chuong":"@c0486"}],"kinhLich":[{"text":"Trước truyền tống trận khổng lồ của Huyền Uyên phái, ngăn em gái áo hồng đòi lên Đông Hải Yêu Linh, viện cớ tu vi nàng không đủ và phụ thân đã bế quan ra lệnh cấm, sai lão Huyền Nhất bắt nàng mang về tông phái.","bridge":true,"khoang":"@c0486"},{"text":"Phát hiện có người đến qua truyền tống trận liền mỉm cười nhìn về chân trời, nói “Vương huynh! Tôn mỗ chờ huynh đã lâu!”.","bridge":true,"khoang":"@c0486"},{"bridge":true,"khoang":"@c0487","text":"Cố đợi Vương Lâm để cùng đi Đông Hải Yêu Linh; than do gia phụ bắt buộc phải đi dù nguy hiểm; dẫn theo ba trưởng lão Huyền Uyên phái hộ vệ và ra lệnh mở trận pháp tinh không, nhưng từ chối cho muội Tôn Nhược Nam đi theo."},{"bridge":true,"khoang":"@c0488–@c0488","text":"Tôn Vân Sơn đồng hành cùng Vương Lâm tới cửa Đông Hải, âm trầm vì phải vội lên đường mới kịp ngày cuối; tách khỏi Vương Lâm, nhờ chiếu cố và hẹn gặp lại trong Đông Hải Yêu Linh."},{"text":"Bị Tiên chủng (vân xanh) của lão tổ liên minh khống chế, Tôn Vân Sơn kính sợ Vương Lâm, xác nhận bản chất Tiên chủng và khai căn cứ Liên minh ở giao giới phía bắc Hoả Yêu Quận và Kim Yêu Quận. Hắn cúi đầu cảm tạ, hứa báo đáp nếu trở lại Thiên Vận Tinh, được Vương Lâm đưa ngọc giản phòng thân.","bridge":true,"khoang":"@c0576"},{"text":"Một trong bốn người được Vương Lâm cứu khỏi Minh vụ trùng và sấm sét. Khi Nhiễm Nguyệt hỏi về Lôi Tiên sứ giả, sắc mặt hắn biến đổi, trong lòng thầm khẳng định Vương Lâm chính là sứ giả của Lôi Tiên.","bridge":true,"khoang":"@c0616"}],"tuViMoc":[],"tuVi":"Thiếu tông chủ Huyền Uyên phái; tu vi cụ thể chưa rõ.","nhanMach":[{"ten":"Em gái Tôn Vân Sơn","tag":"ho-hang","quanHe":"Em gái","ghiChu":"Ngăn nàng lên Đông Hải."},{"ten":"Huyền Nhất","tag":"cap-tren","quanHe":"Lão già cao thủ dưới trướng","ghiChu":"Sai bắt em gái mang về."},{"ten":"Vương Lâm","tag":"ban-be","quanHe":"Vương huynh","ghiChu":"Long trọng chờ đón qua truyền tống trận."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Bạn đồng hành cùng đi Đông Hải Yêu Linh"},{"ten":"Tôn Nhược Nam","tag":"ho-hang","quanHe":"Xá muội, bị hắn từ chối cho đi theo"},{"ten":"Huyền Nhất","tag":"su-mon","quanHe":"Trưởng lão Huyền Uyên phái phụ trách an toàn cho hắn"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Được Vương Lâm khảo sát Tiên chủng và cho ngọc giản phòng thân; khai vị trí Liên minh","ghiChu":"@c0576"},{"ten":"Tôn Nhược Nam","tag":"ho-hang","quanHe":"Muội muội","ghiChu":"@c0576"},{"ten":"Lão Tổ Liên minh","tag":"doi-thu","quanHe":"Bị lão tổ liên minh gắn Tiên chủng khống chế","ghiChu":"@c0576"},{"ten":"Vương Lâm","tag":"dong-hanh","quanHe":"Ân nhân cứu mạng; hắn tin Vương Lâm là sứ giả Lôi Tiên"},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Cùng nhóm bốn người được cứu"}],"tuiDo":{"phapBao":[{"ten":"Quạt thúy ngọc","trangThai":"dang-co","moTa":"Chiếc quạt ngọc thường cầm, hay đập thân quạt vào lòng bàn tay.","nguon":"@c0486"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0486","@c0487","@c0488","@c0576","@c0616"]},{"id":"huyen-nhat","name":"Huyền Nhất","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Một trong ba lão già đầu tóc trắng khí tức kinh người theo Tôn Vân Sơn, cao thủ Huyền Uyên phái; được lệnh bắt tiểu thư mang về tông phái.","vaiTro":"Cao thủ hộ vệ của Huyền Uyên phái.","tinhCach":[],"tabs":{"diem":[{"text":"Đầu tóc trắng xóa, khí tức kinh người, đứng sau lưng thiếu tông chủ.","chuong":"@c0486"}],"kinhLich":[{"text":"Được Tôn Vân Sơn sai đi bắt em gái áo hồng đang đòi lên Đông Hải Yêu Linh mang về tông phái.","bridge":true,"khoang":"@c0486"},{"bridge":true,"khoang":"@c0487","text":"Là một trong ba lão già trưởng lão Huyền Uyên phái phụ trách an toàn cho Tôn Vân Sơn; được lệnh cùng hai lão già quay vào trận pháp tinh không để hộ tống chuyến đi Đông Hải Yêu Linh."}],"tuViMoc":[],"tuVi":"Cao thủ Huyền Uyên phái; tu vi cụ thể chưa rõ.","nhanMach":[{"ten":"Tôn Vân Sơn","tag":"su-mon","quanHe":"Thiếu tông chủ chủ quản","ghiChu":"Nhận lệnh hành sự."},{"ten":"Tôn Vân Sơn","tag":"su-mon","quanHe":"Người được hắn hộ vệ"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0486","@c0487"]},{"id":"em-gai-ton-van-son","name":"Em gái Tôn Vân Sơn","cn":"","aliases":["Em gái Tôn Vân Sơn","Xá muội Tôn Vân Sơn"],"gioiTinh":"nu","theLuc":[{"ten":"Huyền Uyên Phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Cô gái trẻ khoảng hai mươi tuổi mặc áo hồng nhạt, da trong suốt như thủy tinh, tỏa hương như cây Bách Linh; đòi anh trai cho lên Đông Hải Yêu Linh.","vaiTro":"Tiểu thư Huyền Uyên phái muốn vào Đông Hải Yêu Linh.","tinhCach":[{"text":"Bướng bỉnh, ngang ngạnh — đòi đi cho bằng được, viện cớ mẹ đã đồng ý.","chuong":"@c0486"}],"tabs":{"diem":[{"text":"Hóa từ một đám mây hồng, da trong suốt như thủy tinh, tỏa mùi thơm như cây Bách Linh.","chuong":"@c0486"}],"kinhLich":[{"text":"Đòi anh trai Tôn Vân Sơn cho lên Đông Hải Yêu Linh, ra điều kiện nếu vượt qua được thì phải để nàng đi; khi bị từ chối liền viện cớ “Mẹ đã đồng ý rồi!”.","bridge":true,"khoang":"@c0486"},{"text":"Bị huynh Tôn Vân Sơn từ chối cho đi Đông Hải Yêu Linh, nàng đắc ý lấy ra miếng truyền tống ngọc giản lén trộm của cha, hóa thành sợi tơ trắng phóng vào cầu vồng truyền tống để lén đi theo, hy vọng tìm được bảo vật ở Đông Hải.","bridge":true,"khoang":"@c0487"}],"tuViMoc":[],"tuVi":"Tu vi chưa đủ để vào Đông Hải theo lời Tôn Vân Sơn.","nhanMach":[{"ten":"Tôn Vân Sơn","tag":"ho-hang","quanHe":"Anh trai","ghiChu":"Bị anh ngăn không cho lên Đông Hải."},{"ten":"Tôn Vân Sơn","tag":"ho-hang","quanHe":"Huynh trưởng, người từ chối cho nàng đi theo"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người nàng lén bám theo, gọi “Vương đại ca”"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0486","@c0487"]},{"id":"tham-lang","name":"Tham Lang","aliases":["#tham-lang-dai-la-kiem-tong"],"gioiTinh":"nam","theLuc":[{"ten":"Tán tu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Người đàn ông trung niên bao phủ tử khí, cưỡi đống xương khô khổng lồ; chủ hung từng muốn cướp Hạt Châu Thiên Nghịch của Tư Đồ Nam, nay thân mang thương nặng tìm tới lão hữu Kiếm Tôn. (+) Người Đại La Kiếm Tông âm thầm bảo vệ ở đất Yêu Linh, tu vi vượt Vấn Đỉnh đạt Âm Hư chi cảnh; nghi là kẻ thù năm xưa của Tư Đồ Nam. [CAN-SOAT-GOP]","vaiTro":"Cường địch tiềm tàng truy tìm Vương Lâm","tinhCach":[{"text":"Tham lam, thủ đoạn — muốn thôn phệ thượng cổ tu sĩ để khôi phục tu vi","chuong":"@c0487"},{"text":"Khôn khéo, biết tránh kẻ mạnh hơn (Tư Đồ Nam) và mượn lực lão hữu","chuong":"@c0487"}],"tabs":{"diem":[{"text":"Bao phủ tử khí, cưỡi mấy nghìn bộ xương khô khổng lồ trong đó có một bộ cực lớn của mãnh thú thượng cổ","chuong":"@c0487"},{"text":"Tu vi vượt Vấn Đỉnh, đạt Âm Hư chi cảnh","chuong":"@c0571"},{"text":"Tướng mạo khiến Vương Lâm thấy quen dù chưa gặp","chuong":"@c0571"}],"kinhLich":[{"text":"Vì thân mang thương nặng và muốn tránh Tư Đồ Nam, hắn rời Chu Tước Tinh đến Đại La Kiếm Tông tìm Kiếm Tôn không gặp nên đuổi theo tới cửa Đông Hải; phá toái hư không xông vào phạm vi trăm dặm, chào “Lăng Thiên lão hữu” và đề nghị tặng Kiếm Tôn một cơ duyên cực lớn để đè đầu Thiên Vận Tử dễ như trở bàn tay.","bridge":true,"khoang":"@c0487"},{"text":"Tham Lang kể với Lăng Thiên Hậu chuyện mấy vạn năm trước Tu Chân Liên Minh treo thưởng một bộ thượng phẩm tiên thuật hoàn chỉnh để tìm một hạt châu; thừa nhận vết thương của hắn liên quan đến hạt châu đó và đang bị người giữ nó bức bách. Hắn nhận lời giúp Lăng Thiên Hậu, hóa thành bóng ma ẩn sau lưng lão, cảm thấy Vương Lâm quen thuộc như cố nhân năm xưa.","bridge":true,"khoang":"@c0488"},{"text":"Đã sớm biến mất sau lưng Lăng Thiên Hậu, hóa thành đạo kiếm khí bảo mệnh được ban cho đệ tử cuối cùng của Kiếm Tiếu Thập Nhị Tử, theo Đại La kiếm tông tiến vào cánh cửa yêu linh.","bridge":true,"khoang":"@c0491"},{"text":"Đang vây khốn Đại La kiếm tông bằng Văn thú và khói đen ở lối ra Hỏa Yêu quận, Tham Lang mở mắt cảm nhận hơi thở Lăng Thiên Hậu (chỉ một phần) lẫn một hơi thở xa lạ, ngờ là tới vì lệnh bài, rồi lại nhắm mắt.","bridge":true,"khoang":"@c0594"},{"text":"Qua thần thức Văn thú hé lộ năm xưa Tham Lang bị một tu sĩ cực mạnh từ Hỏa Yêu quận một trảo bắt đi trong cuộc chiến với Chu Dật. Lăng Thiên Hậu vào Yêu Linh quát gọi tìm hỏi Tham Lang.","bridge":true,"khoang":"@c0613"},{"text":"Bị Vân Tiên đạo lữ giam, Tham Lang chối việc giết đệ tử Đại La kiếm tông, lấy mấy vạn năm tu hành ra thề không đoạt lệnh bài. Bị cả nhóm lão quái nhìn chằm chằm (hắn là kẻ tu vi yếu nhất, chỉ trên Thần Long), hắn vội khai người Thiên Vận Tông đã cướp lệnh bài chính là Vương Lâm — kẻ giết người Đại La kiếm tông. Cuối chương Huyết Tổ đề nghị cử hắn vào La Thiên tinh vực bắt Vương Lâm, bị mỗi lão quái đặt một cấm chế khống chế.","bridge":true,"khoang":"@c0614"},{"text":"Được nhắc qua trí nhớ Hợi Trư mà Vương Lâm Sưu h���n lấy được: người Đại La Kiếm Tông âm thầm bảo vệ ở đất Yêu Linh, tu vi đạt Âm Hư chi cảnh chỉ kém Dương Thật chi cảnh của Tư Đồ Nam. Tướng mạo quen mắt với Vương Lâm dù chưa từng gặp, bị nghi là kẻ thù năm xưa của Tư Đồ Nam.","bridge":true,"khoang":"@c0571"},{"text":"Tham Lang điều khiển gián tiếp bầy Văn thú hơn vạn con (qua Vương thú) nhưng không dám tới gần vì chúng tàn bạo khó thuần. Khi Vương Lâm thoát khỏi sương tím, hắn lùa Văn thú lao tới, định bắt nguyên thần Vương Lâm để tra hỏi nơi ở Tư Đồ Nam — do tại Đông Hải Yêu Linh đã nhận ra hơi thở Tư Đồ Nam trên người hắn.","bridge":true,"khoang":"@c0601"},{"text":"Bị Vương Lâm và Thần Long hợp công giữa đàn Văn thú. Hắn dùng Thất Ma Châm khống chế Văn thú lớn, thi triển Phệ Tử Nhất Thức rút lục khí từ vách đá thôn phệ Tịch Diệt Chỉ và đánh tan Long hồn của Thần Long, rồi dùng Phệ Tử nhị thức rút sơn hồn từ một ngọn núi tiên giới hắn từng đoạt và phong ấn mấy vạn năm trước. Sơn hồn đè trọng thương Thần Long, phá tan sát lục khí và giúp hắn thoát vòng vây Văn thú; hắn gọi đúng tên hai thần thông của đối thủ và chê chúng chưa hoàn chỉnh, rồi tham lam tiến về quả cầu sương mù để đoạt lệnh bài bên trong.","bridge":true,"khoang":"@c0602"},{"text":"Bị đàn Văn thú của Vương Lâm vây khốn, Tham Lang dùng Phệ Tử Tam Thức thả đệ nhị nguyên thần phóng thần lôi đen đuổi đánh Thần Long, rồi đau lòng xuất chí bảo tiên giới Thiên Mê Hương để thoát vòng vây. Hai lần bị Vương Lâm dùng ‘Định’ cản đoạt lệnh bài, hắn phẫn nộ vỗ túi trữ vật lấy ra đại đỉnh Càn Khôn nghịch chuyển, niệm ‘Càn Khôn nghịch chuyển, thiên địa phiên thân’ phóng hắc quang đảo ngược trời đất và vị trí ba người.","bridge":true,"khoang":"@c0603"},{"text":"Bị Vân Tiên đạo lữ thả ra trước các lão quái, đứng sau Hồ Quyên và Vương Tạ như lão nô. Bị Lăng Thiên Hậu thẩm vấn về lệnh bài và việc giết đệ tử; chối, thề không đoạt lệnh bài, khai Vương Lâm giữ lệnh bài và là kẻ giết người. Tu vi yếu nhất trong đám lão quái (chỉ trên Thần Long). Huyết Tổ đề nghị cử hắn vào La Thiên tinh vực truy bắt Vương Lâm, mỗi lão quái đặt một cấm chế trên người hắn.","bridge":true,"khoang":"@c0614"}],"tuViMoc":[{"chuong":"@c0571","canhGioi":"Âm Hư chi cảnh","text":"Tu vi vượt Vấn Đỉnh đạt Âm Hư chi cảnh, chỉ kém Dương Thật chi cảnh của Tư Đồ Nam.","importance":"major"}],"nhanMach":[{"ten":"Kiếm Tôn","tag":"dong-minh","quanHe":"Lão hữu cũ mà hắn tới nhờ vả"},{"ten":"Tư Đồ Nam","tag":"doi-thu","quanHe":"Người sở hữu Hạt Châu Thiên Nghịch mà hắn từng muốn cướp, nay phải tránh mặt"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người hắn truy tìm cùng sợi tơ Thiên Kiếp"},{"ten":"Lăng Thiên Hậu","tag":"dong-minh","quanHe":"Người được cầu nhờ","ghiChu":"Tham Lang tìm tới nhờ xuất thủ chuyện hạt châu, đổi lại bảo vệ mười hai đệ tử của lão trong Đông Hải."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Cảm giác quen thuộc","ghiChu":"Tham Lang cảm thấy trên người Vương Lâm sinh ra cảm giác như cố nhân năm xưa rồi thu hồi ánh mắt."},{"ten":"Vương Tạ","tag":"doi-thu","quanHe":"Bị Vương Tạ giam trong túi trữ vật","ghiChu":"@c0614"},{"ten":"Hồ Quyên","tag":"doi-thu","quanHe":"Bị Hồ Quyên và Vương Tạ giam","ghiChu":"@c0614"},{"ten":"Thần Long","tag":"doi-thu","quanHe":"Thần Long tố Tham Lang hại các sư đệ; Tham Lang vây Thần Long trong tử vụ vì lệnh bài","ghiChu":"@c0614"},{"ten":"Huyết Tổ","tag":"khac","quanHe":"Huyết Tổ đề nghị cử Tham Lang vào La Thiên tinh vực bắt Vương Lâm","ghiChu":"@c0614"},{"ten":"Chu Dật","tag":"doi-thu","quanHe":"Đối thủ cuộc chiến năm xưa","ghiChu":"Trong cuộc chiến Tham Lang - Chu Dật, cả hai cùng bị hai tu sĩ Hỏa Yêu quận bắt đi."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tướng mạo quen mắt với Vương Lâm; bị nghi liên quan kẻ thù Tư Đồ Nam"},{"ten":"Tư Đồ Nam","tag":"doi-thu","quanHe":"Nghi là kẻ thù năm xưa từng làm thân thể Tư Đồ Nam tan vỡ"},{"ten":"Hợi Trư","tag":"dong-minh","quanHe":"Cùng Đại La Kiếm Tông ở đất Yêu Linh"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Mục tiêu truy bắt"},{"ten":"Tư Đồ Nam","tag":"doi-thu","quanHe":"Đối tượng truy tìm","ghiChu":"Tham Lang lần theo hơi thở Tư Đồ Nam trên người Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ vây công","ghiChu":"Nhận ra Sát Lục Tiên Quyết của Vương Lâm là truyền thừa Thiên Vận Tử."},{"ten":"Thần Long","tag":"doi-thu","quanHe":"Đối thủ vây công","ghiChu":"Dùng sơn hồn đè trọng thương Thần Long."},{"ten":"Thần Long (Đại La Kiếm Tông)","tag":"doi-thu","quanHe":"Đối thủ tranh đoạt lệnh bài","ghiChu":"Tham Lang thả đệ nhị nguyên thần và sương mù truy đuổi Thần Long để cướp lệnh bài.","gap":"@c0603"},{"ten":"Vương Tạ","tag":"khac","quanHe":"Người giam giữ","ghiChu":"Bị Vân Tiên đạo lữ giam trong túi trữ vật."},{"ten":"Hồ Quyên","tag":"khac","quanHe":"Người giam giữ","ghiChu":"Đứng sau Hồ Quyên như lão nô."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0487","@c0488","@c0491","@c0594","@c0614","@c0613","@c0571","@c0601","@c0602","@c0603"]},{"id":"nguoi-xich-loa-tho-san-son-coc","name":"Người xích lõa vẽ nhựa cây (thợ săn)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Cư dân sơn cốc Đông Hải yêu linh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (không có linh lực)","trangThai":"song","blurb":"Người nửa thân xích lõa sống trong sơn cốc vùng Đông Hải yêu linh, không có chút linh lực nào nhưng linh tính kinh người, săn dã thú bằng vũ khí u quang.","vaiTro":"Cư dân chủng người lạ trong sơn cốc trận pháp thượng cổ.","tinhCach":[{"text":"Cảnh giác, hoang dã, đề phòng người lạ — giành giữ con thú săn được.","chuong":"@c0492"}],"tabs":{"diem":[{"text":"Không có linh lực nhưng linh tính kinh người, ẩn thân cực giỏi bằng nhựa cây xanh.","chuong":"@c0492"},{"text":"Săn dã thú bằng gậy đen gắn lưỡi dao u quang; máu con thú lộ u quang.","chuong":"@c0492"}],"kinhLich":[{"text":"Nằm ẩn thân trong rừng, bất ngờ bật dậy đâm chết con dã thú lớn không linh lực, nhảy lên lưng thú cắt cổ. Khi Vương Lâm hiện thân, hắn cảnh giác cầm dao thốt giọng khàn “Thú, ta!” để giành con thú; được Vương Lâm nhường, hắn kéo xác thú lui về sơn cốc.","bridge":true,"khoang":"@c0492"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Tu sĩ lạ gặp ở rừng núi, nhường con thú rồi sau giam giữ tra hỏi"}],"tuiDo":{"khac":[{"ten":"Gậy dài màu đen gắn lưỡi dao u quang","loai":"vũ khí","moTa":"Đầu gậy gắn lưỡi dao nhỏ phát u quang; gậy gãy vụn khi đâm thú nhưng lưỡi dao giết được dã thú.","nguon":"@c0492"}]}},"nguon":["@c0492"]},{"id":"au-duong-hoa","name":"Âu Dương Hoa","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Bộ tộc sơn cốc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Lão giả tóc bạc tự xưng trưởng lão sơn cốc, sống ở vùng đất này từ khi có ký ức, thuở nhỏ từng học ở Cổ yêu thành nên có tuổi thọ cao.","vaiTro":"Trưởng lão bộ tộc thân trâu mình người trong sơn cốc, đối đầu Vương Lâm bằng thượng cổ trận pháp.","tinhCach":[{"text":"Vẻ ngoài tang thương, lời lẽ ôn hòa nhưng quyết liệt bảo vệ tộc nhân","chuong":"@c0493"}],"tabs":{"diem":[{"text":"Chỉ hiện thân bằng thế thân hư ảo, bản thể thật ẩn sâu trong cốc","chuong":"@c0493"},{"text":"Thờ yêu linh, định lấy hồn phách người ngoài làm tế phẩm","chuong":"@c0493"}],"kinhLich":[{"text":"Sau ba ngày yên tĩnh, Âu Dương Hoa cầm quải trượng đen cùng mười một sinh vật thân trâu mình người bước ra khỏi cốc, xin thả tộc nhân để đối thoại. Lão tiết lộ về Cổ yêu thành ngoài ba ngàn dặm, khuyên Vương Lâm tới đó tìm vật cần và nói người ngoài cứ bốn trăm năm lại tới một lần.","bridge":true,"khoang":"@c0493"},{"text":"Khi Vương Lâm phá trận, Âu Dương Hoa lộ ra chỉ là thế thân hư ảo; bản thể trong cốc lệnh trận pháp hút kéo vạn vật ngưng thành hư ảnh người màu xanh cao mấy trượng để giết Vương Lâm, lấy hồn phách tế yêu linh.","bridge":true,"khoang":"@c0493"},{"text":"Dựa vào trận pháp thượng cổ trong sơn cốc, Âu Dương Hoa cười lạnh đòi Vương Lâm tự cắt một tay một chân để hắn hấp thu ba phần nguyên thần, dọa biến đối phương thành yêu ảnh thứ hai; khi trận bị tám mươi ba tổ hợp cấm chế đánh tan thì hoảng sợ cầu xin tha mạng.","bridge":true,"khoang":"@c0494"},{"chuong":"@c0495","importance":"normal","tieuDe":"Thần phục Vương Lâm","text":"Dẫn mười tộc nhân ra cốc cung kính xưng Vương Lâm là thượng tiên, xin đừng phá trận pháp kẻo cả tộc thành thức ăn của yêu linh. Cắn ngón tay vẩy giọt máu mở thông đạo mời Vương Lâm vào sơn cốc, kể về Hoàng Long và trận pháp cổ, cảnh báo đêm yêu linh và mời về nhà mình."},{"text":"Kể cho Vương Lâm về nơi yêu linh có chín quận, bộ tộc đang ở thuộc Thiên Yêu quận với yêu đế Tai Hư, bát đại yêu soái, thiên vạn yêu binh, hơn trăm thành trì; nhắc đêm trăng tròn là đêm yêu linh đi săn mồi, và quy luật cứ năm trăm năm có người bên ngoài tiến vào. Sau khi thấy đan dược của Vương Lâm, hạ quyết tâm dẫn hắn tới đáy sơn cốc hình hồ lô xem ngọc yêu linh.","bridge":true,"khoang":"@c0496"},{"text":"Âu Dương Hoa run rẩy nhận hơn mười bình ngọc của Vương Lâm, đem yêu lực kết tinh duy nhất của thung lũng đổi lấy; hé lộ rằng vì trận pháp Hồ Lô Cốc đã suy yếu nặng, không chắc chống được đêm Yêu linh săn mồi, nên cắn răng mời thượng tiên ở lại và tiết lộ bí mật để mong được trợ giúp.","bridge":true,"khoang":"@c0497"},{"bridge":true,"khoang":"@c0497","text":"Đêm xuống, Âu Dương Hoa cùng đàn ông trong cốc cầm vũ khí tập trung ở cửa, niệm chú duy trì trận pháp; khi trận bị sóng yêu khí công phá sắp vỡ, hắn mừng rỡ gọi Vương Lâm là thượng tiên đến cứu mạng."},{"bridge":true,"khoang":"@c0503","text":"Cung kính cung đón Vương Lâm là thượng tiên khi hắn trở về thung lũng, đoán người đi cùng hắn trước đó đã bị giết. Theo lệnh, hắn ra lệnh cấm mọi người vào sâu thung lũng (cấm địa), ai trái lệnh bị đuổi, đồng thời tuyên bố sơn cốc quá nhỏ cần mở rộng địa bàn — tuyên chiến với tộc khác, khiến cư dân phấn khích."},{"chuong":"@c0504","importance":"normal","tieuDe":"Được đả thông kinh mạch, đột phá nhị tinh","text":"Trưởng lão sơn cốc, thuở nhỏ từng học ở thành cổ yêu nhưng bị đuổi vì bị phát hiện có tinh lực. Được Vương Lâm dùng song chỉ điểm từ bụng lên mi tâm cưỡng ép đả thông kinh mạch, đau thấu xương rồi ngất, mấy canh giờ sau tỉnh dậy đạt nhị tinh, tự thấy như được hồi sinh, quỳ tạ thượng tiên."},{"bridge":true,"khoang":"@c0504","text":"Nhận yêu giản, nhìn thấu khẩu quyết luyện hồn, được giao truyền dạy lại cho toàn cốc; ba tháng chuyên tâm tu luyện thuật luyện hồn tiến bộ cực nhanh, cảm kích thề khắc cốt ân điển."},{"text":"Âu Dương Hoa đã tới giai đoạn ba và chế xong hồn phiên trước Thập Tam mấy ngày nhưng cố ý nhường cơ hội cho hắn, nhận ra tương lai sơn cốc thuộc về Thập Tam; lão trình Vương Lâm kế hoạch một tháng sau phát động người trong cốc đánh một bộ tộc vài chục người cách ngàn dặm.","bridge":true,"khoang":"@c0505"},{"chuong":"@c0506","importance":"normal","tieuDe":"Dâng yêu tinh nhận khẩu quyết giai đoạn bốn","text":"Cung kính cầu kiến ‘thượng tiên’, dâng khối đá đen chứa nhị giáp yêu tinh và nhận ngọc giản khẩu quyết Luyện Hồn Thuật giai đoạn thứ tư — hiện là người duy nhất đạt mức này. Vốn phản đối nữ tu, bị Vương Lâm khiển trách liền đổi sang cổ vũ nữ tử tu hành."},{"bridge":true,"khoang":"@c0506–@c0506","text":"Cùng Thập Tam làm chủ công đánh hạ bộ tộc trong động, luyện hóa hồn phách người vừa chết; chỉ huy đồng hóa người ngoại tộc bằng yêu thang và đẩy bộ lạc chuyển sang xâm lược."},{"text":"Dẫn một tổ đi đánh bộ lạc trở về thắng lợi; sau khi Vương Lâm giết lão áo trắng, thu nạp toàn bộ dân Thiên Thủy làm tộc nhân mới và đặt tên bộ lạc là Luyện Hồn.","bridge":true,"khoang":"@c0507"},{"text":"Làm thủ lĩnh dưới quyền Vương Lâm trong bộ lạc Luyện Hồn; bắt Hổ Bào về tộc, mang Thập Tam bị thương đến cầu Vương Lâm cứu rồi thầm chúc hắn may mắn. Sau bốn năm tu vi tăng mạnh, quỳ tiễn Vương Lâm lên đường.","bridge":true,"khoang":"@c0508"},{"bridge":true,"khoang":"@c0529","text":"Dẫn đầu bộ lạc Luyện Hồn hóa hắc vụ ra cung nghênh lão tổ Vương Lâm trở về sau trận chiến với Yêu Tướng."},{"text":"Được Vương Lâm dặn phái mấy trăm tộc nhân tiềm nhập các bộ lạc lớn nhỏ dùng Hồn Phách Thủ Thần chống Linh Thang Loạn Thần để truyền Luyện Hồn Thuật, mục tiêu hơn trăm vạn tộc nhân; nhận ngọc giản phần hai Luyện Hồn Thuật (thần thông rút phách) chỉ truyền chi chính, bóp nát ghi nhớ rồi quỳ tiễn Vương Lâm, xưng lão tổ.","bridge":true,"khoang":"@c0531"},{"text":"Thong dong điều khiển toàn thể tộc nhân Luyện Hồn bộ lạc khoanh chân ngồi, Âu Dương Hoa hô ‘Hồn, tán!’, khiến tộc nhân phóng hồn phách thu được hoá thành đạo hắc khí, trường hồng lao tới chặn Lôi Suất của Lôi Yêu Quận khi hắn xông vào màn sương đen.","bridge":true,"khoang":"@c0583"}],"tuViMoc":[{"chuong":"@c0504","canhGioi":"Nhị tinh","text":"Được Vương Lâm cưỡng ép đả thông kinh mạch, đột phá lên trình độ nhị tinh — đường tắt nâng tu vi nhưng để lại di chứng.","importance":"minor"},{"chuong":"@c0505","canhGioi":"Giai đoạn ba (Luyện Hồn Yêu Thuật)","text":"Được Vương Lâm cho phép, Âu Dương Hoa tu luyện Luyện Hồn Yêu Thuật tới giai đoạn ba. Đây là thành tựu thuộc hệ Luyện Hồn Thuật, không phải tu vi chính.","importance":"minor"}],"tuVi":"Tu vi không rõ; thân thể yếu ớt, có tuổi thọ rất cao nhờ từng học ở Cổ yêu thành.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người ngoài xâm nhập sơn cốc, đối đầu qua trận pháp","ghiChu":"Bị Vương Lâm phá trận và nhận ra chỉ là thế thân hư ảo."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Vây Vương Lâm bằng trận pháp nhưng bị hắn phá trận, áp sát buộc phải cầu tha."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tôn xưng Vương Lâm là thượng tiên, mời vào sơn cốc và tiếp đãi","ghiChu":""},{"ten":"Hoàng Long","tag":"khac","quanHe":"Thượng tiên dẫn tổ tiên tộc Âu Dương Hoa đến định cư, được tôn thờ qua bức tranh","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người bên ngoài mà Âu Dương Hoa dẫn đi đổi đan dược lấy ngọc yêu linh","ghiChu":"Lo sợ tộc nhân chết nhưng vẫn dẫn đi vì đan dược là trọng bảo."},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Thượng tiên được Âu Dương Hoa mời ở lại và đổi yêu lực kết tinh, cầu cứu khi yêu linh tấn công","ghiChu":"@c0497"},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Tôn làm thượng tiên, phụng mệnh thi hành cấm địa và tuyên chiến mở rộng địa bàn","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân / sư tôn","ghiChu":"Đả thông kinh mạch cho đột phá nhị tinh và truyền thụ thuật luyện hồn; Âu Dương Hoa tôn kính xưng vãn bối, hành lễ như đệ tử."},{"ten":"Thập Tam","tag":"khac","quanHe":"Hậu bối được nhường đường","ghiChu":"Âu Dương Hoa nhường cơ hội chế hồn phiên cho Thập Tam và dùng tiểu phiên triệu chim sẻ cứu hắn khi sư tử phản phệ."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Cung kính tôn là ‘thượng tiên’, dâng yêu tinh đổi khẩu quyết","ghiChu":""},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Cùng làm chủ công các trận chinh phạt","ghiChu":""},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"chủ nhân","ghiChu":"Tộc nhân thân tín, luôn nghe lời Vương Lâm."},{"ten":"Hổ Bào","tag":"doi-thu","quanHe":"Người Âu Dương Hoa bắt về tộc","ghiChu":"Bắt Hổ Bào, cho uống Ly Yêu thang để gia nhập bộ lạc."},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Cùng bộ lạc","ghiChu":"Mang Thập Tam bị thương đến cầu Vương Lâm cứu, thầm chúc hắn may mắn."},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Tôn xưng lão tổ, người ban truyền thừa & sứ mệnh bộ lạc","ghiChu":""},{"ten":"Lôi Suất","tag":"doi-thu","quanHe":"Phó soái Lôi Yêu Quận tiến công bộ lạc","ghiChu":"Âu Dương Hoa chỉ huy hồn phách nghênh chiến trước khi Vương Lâm ra tay."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[{"ten":"Quải trượng màu đen","moTa":"Cây gậy đen Âu Dương Hoa cầm khi bước ra khỏi cốc.","nguon":"@c0493"}]}},"nguon":["@c0493","@c0494","@c0495","@c0496","@c0497","@c0503","@c0504","@c0505","@c0506","@c0507","@c0508","@c0529","@c0531","@c0583"]},{"id":"hoang-long-thuong-tien","name":"Hoàng Long","cn":"","aliases":["Hoàng Long thượng tiên"],"gioiTinh":"nam","theLuc":[],"trangThai":"khong-ro","blurb":"Nam tử trung niên trong bức tranh cổ ố vàng nhà Âu Dương Hoa, được tộc nhân tôn là Hoàng Long thượng tiên đã dẫn tổ tiên họ đến định cư sơn cốc.","vaiTro":"Nhân vật được nhắc qua truyền miệng và bức tranh; cái tên khiến Vương Lâm chấn động nguyên thần.","tinhCach":[],"tabs":{"diem":[{"text":"Được tộc Âu Dương Hoa tôn là thượng tiên qua lời kể tổ tiên","chuong":"@c0495"}],"kinhLich":[{"chuong":"@c0495","importance":"normal","tieuDe":"Hoàng Long trong bức tranh cổ","text":"Vô số năm trước dẫn tộc nhân tổ tiên Âu Dương Hoa đến định cư sơn cốc, nơi trận pháp cổ đã tồn tại qua vô số năm. Hình ảnh lưu trong bức tranh ố vàng nứt nẻ: nam tử trung niên mặc trang phục kỳ dị, tay phải tạo ấn ký cổ quái trước ngực, nhìn về một hư ảnh ẩn hiện trong màn sương đen. Cái tên khiến Vương Lâm chấn động nguyên thần."}],"tuViMoc":[],"nhanMach":[{"ten":"Âu Dương Hoa","tag":"khac","quanHe":"Trưởng lão tộc nhân lưu giữ bức tranh và tôn thờ Hoàng Long","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Cái tên Hoàng Long khiến Vương Lâm chấn động nguyên thần","ghiChu":""}],"tuiDo":{}},"nguon":["@c0495"]},{"id":"tai-hu","name":"Tai Hư","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"trangThai":"khong-ro","blurb":"Yêu đế của Thiên Yêu quận nơi yêu linh, thống lĩnh bát đại yêu soái, thiên vạn yêu binh và hơn trăm thành trì.","vaiTro":"Yêu đế","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0496","importance":"normal","tieuDe":"Yêu đế Thiên Yêu quận","text":"Được Âu Dương Hoa nhắc tới là yêu đế của Thiên Yêu quận, nắm giữ một phương với bát đại yêu soái, thiên vạn yêu binh và hơn trăm thành trì."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0496"]},{"id":"hac-y-nam-tu-thien-van-tinh","name":"Hắc y nam tử (Thiên Vận Tinh)","cn":"","aliases":["Hắc y nam tử"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Thành","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Ứng Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Tu sĩ áo đen mặt lạnh cầm kiếm mỏng màu đen, săn yêu linh ở Thiên Vận Tinh để lấy yêu tinh đủ tư cách tiến vào Thiên Yêu Thành; coi Vương Lâm là con mồi.","vaiTro":"Đối thủ của Vương Lâm tại Thiên Vận Tinh","tinhCach":[{"text":"Lạnh lùng, khinh miệt và tự tin, thích dồn con mồi vào thế bất ngờ","chuong":"@c0497"}],"tabs":{"diem":[{"text":"Tu vi Ứng Biến hậu kỳ đại viên mãn, hấp thu yêu lực điên cuồng qua thất khiếu","chuong":"@c0497"},{"text":"Săn yêu linh để lấy yêu tinh đủ tư cách tiến vào Thiên Yêu Thành","chuong":"@c0497"}],"kinhLich":[{"chuong":"@c0497","importance":"normal","tieuDe":"Tuyên bố săn Vương Lâm","text":"Thần thức Vương Lâm phát hiện Hắc y nam tử đang múa kiếm thu hút lượng lớn yêu lực; hắn ngẩng đầu cười lạnh, khen tu vi Vương Lâm không tồi nhưng tuyên bố Vương Lâm là con mồi của mình, dù giao nộp yêu linh cũng vô dụng. Hắn lầm tưởng Vương Lâm chỉ Ứng Biến trung kỳ, cho rằng thu được yêu tinh của đối phương thì đủ tư cách tiến vào Thiên Yêu Thành."},{"bridge":true,"khoang":"@c0497","text":"Hắc y nam tử chém một con vật kỳ dị một sừng làm đôi để hút yêu lực, rồi vung kiếm hóa điện quang phi kiếm lao thẳng tới thung lũng, vang thanh âm lạnh như băng: Săn bắn, bắt đầu!"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Coi Vương Lâm là con mồi để lấy yêu tinh tiến vào Thiên Yêu Thành; lầm tưởng đối phương chỉ Ứng Biến trung kỳ","ghiChu":"@c0497"}],"tuiDo":{"phapBao":[{"ten":"Kiếm mỏng màu đen","trangThai":"dang-co","moTa":"Trường kiếm mỏng màu đen dùng thu hút yêu lực và hóa thành điện quang phi kiếm tấn công từ xa.","nguon":"@c0497"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0497"]},{"id":"la-mo-hac-y-nam-tu","name":"La mỗ (Hắc y nam tử)","cn":"","aliases":["Hắc y nam tử","La mỗ"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Vấn Đỉnh (nguyên thần)","trangThai":"song","blurb":"Tu sĩ hắc y đạp phi kiếm ngông cuồng, chạm trán Vương Lâm giữa sóng yêu linh; sở trường hỏa hệ với Địa diệt chi hỏa và cấm thuật Kiếm toái.","vaiTro":"Đối thủ thoáng qua của Vương Lâm tại Thiên Yêu quận.","tinhCach":[{"text":"Ngông cuồng, lạnh lùng, song thận trọng — sợ giết nhầm người quen nên dò hỏi môn phái trước.","chuong":"@c0498"}],"tabs":{"diem":[{"text":"Nguyên thần cao thâm, sở trường hỏa hệ; tự xưng La mỗ.","chuong":"@c0498"},{"text":"Am hiểu danh tiếng các thế lực, nhận ra ngay thân phận Vương Lâm qua ngọc giản tướng mạo.","chuong":"@c0498"}],"kinhLich":[{"text":"Đạp phi kiếm chặn Vương Lâm, ban đầu tưởng hắn là người Đại La Kiếm Tông. Khi giao đấu, bị loan đao đả thương ngực tuôn huyết quang, phải nuốt đan dược khôi phục. Y tung Kiếm toái cùng Địa diệt chi hỏa hóa sáu rồng lửa nhưng Vương Lâm dùng Sinh Chi Lạc Ấn hóa giải, suýt bị điểm trúng. Cuối cùng y nhận ra đối phương là đệ tử Thiên Vận Tử, Tử hệ lão thất Vương Lâm.","bridge":true,"khoang":"@c0498"},{"text":"Tu sĩ Anh Biến hậu kỳ đại viên mãn tự xưng hành sự thay Tôn sư, giao chiến với Vương Lâm trong Yêu linh khí lãng. Dùng huyết sắc ngũ sát phong ấn Côn Cực Tiên nhưng lần đầu thất bại, bị roi tiên đả thương nguyên thần; sau khi phun độc khí rút lui bất thành, hắn hút khói đen vào ngực chịu đau tột độ, thi triển Ma cấm biến tay trái thành mười Quỷ ảnh thiên quỷ đệ tứ tôn lao vào Vương Lâm.","bridge":true,"khoang":"@c0499"},{"chuong":"@c0501","importance":"normal","tieuDe":"Bị diệt thân, lộ thân phận La Vân","text":"Hồn thú của Vương Lâm thiêu rụi thân thể chỉ còn nguyên thần thoát ra; La Vân dùng Tổn Thần thuật hao tổn tinh hoa nguyên thần để bỏ chạy nhưng bị Côn Cực Tiên quấn bắt. Hắn xưng tên La Vân, người Thiên Quỷ Đạo, có quỷ linh bảo vệ, sư tôn là Quỷ Chân Nhân, dọa sẽ báo thù."},{"chuong":"@c0501","importance":"normal","tieuDe":"Bị Sưu Hồn, giam vào hồn phiên","text":"Vương Lâm lập cấm chế ngăn tự bạo rồi thi triển Sưu Hồn Thuật; La Vân kêu la khoảng một nén nhang rồi bất động, nguyên thần gần như trong suốt. Kết tinh trong đan điền và toàn bộ ký ức bị đoạt, nguyên thần bị giam để luyện thành chủ hồn."}],"tuViMoc":[{"chuong":"@c0501","canhGioi":"Nguyên thần Anh Biến hậu kỳ đại viên mãn","text":"Tu vi sắp bước vào Vấn Đỉnh, nhờ vậy chống được phần nào quỷ phong của hồn thú.","importance":"minor"}],"tuVi":"Nguyên thần cao hơn Vương Lâm nhiều; sở hữu phi kiếm và thủ đoạn hỏa hệ mạnh.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ chạm trán","ghiChu":"Nhận ra Vương Lâm là đệ tử Thiên Vận Tử dùng Tịch Diệt Chỉ; lo khó hạ sát vì hắn có pháp bảo bảo mệnh."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ giao chiến","ghiChu":"Bị Côn Cực Tiên của Vương Lâm đả thương nguyên thần; đáp trả bằng Ma cấm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm diệt thân, bắt sống nguyên thần và Sưu Hồn đoạt ký ức","ghiChu":"@c0501"},{"ten":"Quỷ Chân Nhân","tag":"su-mon","quanHe":"Sư tôn","ghiChu":"La Vân dọa sư tôn sẽ báo thù (@c0501)"}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm (tế kiếm)","trangThai":"hong","moTa":"Phi kiếm y đạp di chuyển, bị kiếm tiên Vương Lâm làm rạn rồi dùng làm Kiếm toái nổ vỡ.","nguon":"@c0498"}],"danDuoc":[{"ten":"Đan dược hồi thương","moTa":"Lấy từ túi trữ vật nuốt nhanh để khôi phục thương thế ngực.","nguon":"@c0498"}],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0498","@c0499","@c0501"]},{"id":"hac-y-nam-tu-mat-seo","name":"Hắc y nhân (mặt sẹo)","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0500","importance":"normal","tieuDe":"Mất Thiên Quỷ, bỏ thân chạy nguyên thần","text":"Trong trận với Vương Lâm, hắn thu Quỷ ảnh (Thiên Quỷ) nhưng bị Vương Lâm áp chế bằng Hóa ma chỉ; Thiên Quỷ tự sinh hắc quang bỏ trốn. Hắn dồn gần 90% quỷ tiên lực vào tiểu cầu hủy diệt, nhưng khi Vương Lâm mở Xạ Thần Xa thả Hồn thú, hắn buộc phải vỗ mi tâm cho nguyên thần rời cơ thể chạy trốn, để lại thân xác không hồn cho tiểu cầu lao tới."}],"tuViMoc":[{"chuong":"@c0500","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tự xưng Anh Biến hậu kỳ đại viên mãn, hơn Vương Lâm một bậc, dựa vào quỷ tiên lực và Thiên Quỷ hấp thu hồn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ sinh tử","ghiChu":"Bị Vương Lâm áp chế, mất Thiên Quỷ, cuối cùng bỏ thân xác cho nguyên thần chạy trốn."}],"tuiDo":{"phapBao":[{"ten":"Thiên Quỷ (Quỷ ảnh)","loai":"khac","trangThai":"mat","moTa":"Quỷ vật chuyên nuốt hồn thể để tăng quỷ lực; bị ép tới mức tự sinh hắc quang bỏ trốn khỏi chủ nhân.","nguon":"@c0500"}],"congPhap":[{"ten":"Thuật khống chế Quỷ ảnh","moTa":"Dùng tơ mảnh màu đen từ ngực và tay để thu hồi và khống chế Thiên Quỷ; phải đặt tay phải trên ngực giữ thuật khỏi bị phá.","nguon":"@c0500"}],"khac":[]}},"nguon":["@c0500"]},{"id":"quy-chan-nhan","name":"Quỷ Chân Nhân","gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Quỷ Đạo","trangThai":"gan-bo"}],"trangThai":"khong-ro","blurb":"Sư tôn của La Vân thuộc Thiên Quỷ Đạo, được nói địa vị ngang hàng Thiên Vận Tử.","vaiTro":"Nhân vật được nhắc tên — mầm xung đột tương lai","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"La Vân dọa Vương Lâm rằng sư tôn Quỷ Chân Nhân sẽ báo thù, người này gặp Thiên Vận Tử cũng phải nói chuyện ngang hàng.","bridge":true,"khoang":"@c0501"}],"tuViMoc":[],"nhanMach":[{"ten":"La Vân","tag":"su-mon","quanHe":"Đệ tử","ghiChu":"@c0501"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0501"]},{"id":"la-van","name":"La Vân","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Quỷ Đạo","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"tu-vong","blurb":"Tu sĩ thân phận tôn quý của Thiên Quỷ Đạo, bị Vương Lâm hấp thu ký ức; bản mạng quỷ linh của hắn phản chủ do tu luyện quá ngắn.","vaiTro":"Phản diện thoáng qua","tinhCach":[{"text":"Toan tính, sẵn sàng giết người ngoài để đoạt yêu lực còn thiếu.","chuong":"@c0502"}],"tabs":{"diem":[{"text":"Thân phận tôn quý ở Thiên Quỷ Đạo, được Sư tôn ban cho một trong chín bản mạng quỷ linh phòng thân.","chuong":"@c0502"}],"kinhLich":[{"text":"La Vân dựa kinh nghiệm tổ tiên Thiên Quỷ Đạo lưu lại, định kế hoạch nhập một quận trong vùng đất yêu linh để đạt chiến công, cần đủ ba giáp yêu lực nên muốn giết Vương Lâm để đoạt nốt một giáp còn thiếu. Kết cục hắn bị Vương Lâm hấp thu trọn ký ức và lấy đi yêu tinh hai giáp; bản mạng Thiên quỷ của hắn cũng phản chủ vì hắn tu luyện quá ngắn.","bridge":true,"khoang":"@c0502"}],"tuViMoc":[],"tuVi":"Yêu tinh trong nguyên thần đan điền tương đương hai giáp yêu lực.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người đoạt ký ức và yêu tinh của hắn","ghiChu":"La Vân định giết Vương Lâm để đoạt giáp yêu lực, ngược lại bị Vương Lâm chế ngự."},{"ten":"Sư tôn của La Vân","tag":"su-mon","quanHe":"Sư tôn ban bản mạng quỷ linh"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0502"]},{"id":"su-ton-cua-la-van","name":"Sư tôn của La Vân","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Quỷ Đạo","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Bậc trên ở Thiên Quỷ Đạo, tự tay đưa cho La Vân một trong chín bản mạng quỷ linh yếu nhất để phòng thân.","vaiTro":"Nhân vật nhắc tên","tinhCach":[],"tabs":{"diem":[{"text":"Nắm giữ chín bản mạng quỷ linh của Thiên Quỷ Đạo, ban cho La Vân một con yếu nhất.","chuong":"@c0502"}],"kinhLich":[{"text":"Được nhắc tới khi Vương Lâm giải thích nguồn gốc bản mạng quỷ linh của La Vân.","bridge":true,"khoang":"@c0502"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"La Vân","tag":"su-mon","quanHe":"Đồ đệ được ban bản mạng quỷ linh"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0502"]},{"id":"thap-tam","name":"Thập Tam","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tập thể tu luyện sơn cốc (Thiên Vận Tinh)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Giai đoạn ba (Luyện Hồn Yêu Thuật)","trangThai":"song","blurb":"Thanh niên ở Thiên Vận Tinh có ngộ tính trời sinh với Luyện Hồn Thuật, được Vương Lâm coi trọng và đích thân cứu khi sư tử cánh dài phản phệ.","vaiTro":"Đệ tử triển vọng nhất của nhóm tu luyện Luyện Hồn Yêu Thuật trong sơn cốc của Vương Lâm.","tinhCach":[{"text":"Kính sợ và sùng kính Vương Lâm tới tận đáy lòng, cuồng nhiệt khao khát đạt tới thập/bách/thiên/vạn hồn phiên.","chuong":"@c0505"}],"tabs":{"diem":[{"text":"Ngộ tính trời sinh với Luyện Hồn Thuật, chỉ ba tháng đã tu tới giai đoạn ba, tốc độ khiến cả tiền nhân Độn Thiên cũng phải động dung.","chuong":"@c0505"}],"kinhLich":[{"text":"Thập Tam chính là người Vương Lâm âm thầm theo dõi từ trước; sau ba tháng tu luyện tới giai đoạn ba, hắn được Vương Lâm gọi tới trao ngọc giản phương pháp chế hồn phiên mới, run rẩy kích động quỳ lạy ba lạy rồi lui ra toàn lực chế tạo.","bridge":true,"khoang":"@c0505"},{"chuong":"@c0505","importance":"normal","tieuDe":"Chế thành hồn phiên, bị sư tử phản phệ","text":"Sau ba lần thất bại, Thập Tam chế thành cây hồn phiên bảy thước đầu tiên và triệu được hồn phách sư tử cánh dài (luyện từ con sư tử trọng thương trong rừng); khi hắn hô “Thu!”, sư tử quay đầu lao thẳng vào hắn đầy sát khí, Thập Tam bị một lực vô hình giam cầm suýt chết, được Vương Lâm ra tay chấn nhiếp cứu mạng."},{"text":"Khí chất trầm ổn kiên nghị hơn trước, Thập Tam cùng Âu Dương Hoa dẫn mười nam nhân đánh hạ bộ tộc trong động dưới lòng đất sau năm ngày. Hắn gọi chủ hồn sư tử nuốt gọn trưởng lão đối phương rồi luyện hóa hồn phách ngay trước mặt ngoại tộc, có được chủ hồn thứ hai.","bridge":true,"khoang":"@c0506"},{"bridge":true,"khoang":"@c0506–@c0506","text":"Được Vương Lâm ban chủ hồn sư tử cho Hồn Phiên kèm lời cảnh cáo về rủi ro phản phệ; đã luyện hóa bảy cây Hồn Phiên với hai chủ hồn."},{"text":"Dẫn tổ đi đánh bộ lạc thì gặp lão áo trắng (Hóa thần trung kỳ), bị đánh nát kinh mạch toàn thân, mất sạch yêu lực tu luyện luyện hồn thuật (đã đạt tam tinh), hồn phiên bị cướp, bị hạ sợi tơ hồng yêu vật vào ngực để làm chiến thư sống.","bridge":true,"khoang":"@c0507"},{"chuong":"@c0507","importance":"normal","tieuDe":"Tuyệt vọng cố tu, phun máu hôn mê","text":"Sau khi được Vương Lâm cứu nhưng thành người tàn phế không thể tu hành, dập đầu ba cái rời đi; về phòng cố thử thổ nạp thuật Luyện hồn chịu đau thấu tim phổi, kêu “Ta không cam lòng!”, phun một ngụm máu lớn, ngã hôn mê."},{"chuong":"@c0508","importance":"normal","tieuDe":"Phế tu vi, tự phát luyện thể","text":"Bị phế tu vi nên chỉ làm thợ săn, gần như câm điếc và mất sức sống. Không cam lòng, mỗi đêm hắn chịu đau thổ nạp tích yêu lực vào máu thịt suốt hơn một năm, vô tình đạt một loại luyện thể tự nhiên; nhiều lần liều mạng săn thú suýt chết."},{"chuong":"@c0508","importance":"normal","tieuDe":"Được Vương Lâm truyền Luyện Thể thuật","text":"Bị dã thú yêu hóa làm trọng thương, được Âu Dương Hoa mang đến; Vương Lâm cứu chữa và truyền Luyện Thể thuật của Cự Ma Tộc qua ngọc giản. Hai năm sau hắn thành tựu, thân thể cứng như sắt, xông trận đầu tiên rồi theo Vương Lâm đi Cổ Yêu thành."},{"text":"Bị thị vệ Cổ Yêu thành giơ trường thương quát lui, Thập Tam tức giận dùng thuật Luyện thể Cự Ma Tộc đấm một quyền làm vỡ vụn trường thương, đẩy lui tên thị vệ thổ huyết. Vương Lâm quở vì quyền đó tuy dùng hết sức nhưng chỉ phát huy bốn phần lực, phần còn lại tiết ra ngoài, chưa khống chế tùy tâm.","bridge":true,"khoang":"@c0509"},{"bridge":true,"khoang":"@c0512","text":"Cùng Hổ Bào tìm tới nhà trọ nhờ thần thức Vương Lâm triệu gọi, rồi theo sát hắn dạo Cổ Yêu thành, cảnh giác quan sát xung quanh. Ở Trúc Thanh lâu, hắn đập vò rượu rót cho Vương Lâm nhưng tự mình không uống."},{"text":"Thấy lão tổ Vương Lâm có biến, Thập Tam lo lắng theo dõi rồi giơ tay bắt vò rượu khiêu khích thứ hai, bị chấn thương ứa máu miệng, ghế vỡ vụn. Khi yêu binh xông tới, hắn tung một quyền đánh trọng thương đối phương văng đi mấy trượng dù Luyện Thể thuật còn chưa đầy đủ, cùng Hổ Bào quyết tử chắn trước lão tổ.","bridge":true,"khoang":"@c0513"},{"bridge":true,"khoang":"@c0514–@c0514","text":"Thở phào khi Vương Lâm tỉnh khỏi nhập ma, lạnh lùng nhìn đám yêu binh và để lại chút Hứa Yêu thạch trả tiền rượu trước khi rời tửu lâu."},{"text":"Với chức trách hộ vệ lão tổ, chủ động bước vào Truyền Tống trận thử trước; sang quân doanh bị sóng âm chấn động phun máu, được Vương Lâm đá nhẹ một luồng tiên lực chữa lành thương thế.","bridge":true,"khoang":"@c0514"},{"bridge":true,"khoang":"@c0515","text":"Theo Vương Lâm vào quân doanh Hắc Giáp quân, Thập Tam điềm tĩnh ngồi thổ nạp ngoài trời, nhắm mắt tu hành thần thông luyện thể tộc Cự Ma; được Vương Lâm giao một ngọc giản để ghi nhớ nội dung quy tắc Cửu quận yêu binh."},{"bridge":true,"khoang":"@c0516–@c0516","text":"Dần bình thản theo Vương Lâm thổ nạp trong quân doanh; thuộc nội dung ngọc giản quân quy, đọc các điều quân quy theo lệnh và đếm ngược nhịp hô hấp khi Vương Lâm ép lui chín thống đội."},{"bridge":true,"khoang":"@c0517","text":"Bám sát Vương Lâm cùng Hổ Bào vào ngôi lầu bùn đất mới dựng trong quân doanh."},{"bridge":true,"khoang":"@c0518","text":"Canh gác ngoài lầu Vương Lâm, Thập Tam quát chặn và xuất một quyền với Diêu Tích Tuyết nhưng bị nàng dùng tia sáng đỏ khống chế đứng im như pho tượng; sau được cơn gió của Vương Lâm giải trừ, nghe thanh âm Vương Lâm liền khoanh chân ngồi xuống, không can dự nữa."},{"chuong":"@c0527","importance":"normal","tieuDe":"Bị phế rồi bị dâng cho Yêu Tướng","text":"Sau khi Vương Lâm rời đi nửa năm, gã kiên quyết ở lại quân doanh chờ chủ. Khi trợ giúp Hổ Bào, gã bị Tư Mã Viêm bóp nát gân cốt ném vào hắc lao. Trước khi chết, gã được Đô thống Tần Lâm mang đi chữa thương rồi dâng cho Yêu Tướng, do thân thể luyện thể kỳ dị với yêu khí gắn kết toàn thân phù hợp yêu cầu của Yêu Tướng."},{"text":"Bị Mạc Lệ Hải bắt giữ định dùng thân thể luyện pháp bảo, nhưng chỉ hôn mê chứ không thương thế. Sau khi Vương Lâm hạ Yêu Tướng, Thập Tam được thả và ba ngày sau được Vương Lâm đánh thức; đã hoàn thành xuất sắc khảo nghiệm một năm qua.","bridge":true,"khoang":"@c0529"},{"chuong":"@c0530","importance":"normal","tieuDe":"Nhận truyền thừa, tôn Vương Lâm làm Lão tổ","text":"Được Vương Lâm trao ngọc giản xanh ghi sáu tầng đầu Cự Linh Cửu Tu, Thập Tam kích động quỳ đập đầu, thề cả đời chỉ tuân mệnh lệnh Vương Lâm và gọi hắn là Lão tổ. Hắn được dặn bảo vệ bộ tộc Luyện Hồn cho tốt rồi bị một luồng gió mát cuốn ra ngoài cốc."}],"tuViMoc":[{"chuong":"@c0505","canhGioi":"Giai đoạn ba (Luyện Hồn Yêu Thuật)","text":"Trời sinh ngộ tính, tu luyện Luyện Hồn Yêu Thuật ba tháng đã đạt giai đoạn ba — vượt xa đại bộ phận hai bảy người trong sơn cốc còn ở giai đoạn một. Đây là thành tựu thuộc hệ Luyện Hồn Thuật.","importance":"minor"},{"chuong":"@c0508","canhGioi":"Luyện thể (Cự Ma Tộc)","text":"Từ luyện thể tự phát gần đạt yêu lực nhị tinh, sau khi được truyền Luyện Thể thuật Cự Ma Tộc thì thành tựu, thân thể cứng như sắt. Thuộc hệ luyện thể, không phải tu vi chính thống.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Thượng tiên hắn sùng kính","ghiChu":"Vương Lâm âm thầm theo dõi, coi trọng, trao phương pháp mới và cứu hắn khỏi sư tử phản phệ."},{"ten":"Âu Dương Hoa","tag":"dong-minh","quanHe":"Tiền bối nhường đường","ghiChu":"Âu Dương Hoa chế xong hồn phiên trước nhưng nhường cơ hội cho Thập Tam và triệu chim sẻ cứu hắn."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"‘Thượng tiên’ dạy Luyện Hồn Thuật và ban chủ hồn","ghiChu":""},{"ten":"Âu Dương Hoa","tag":"dong-minh","quanHe":"Cùng làm chủ công trong các trận chinh phạt","ghiChu":""},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"sư phụ","ghiChu":"Gọi “Sư phụ”, được cứu mạng nhưng không cứu được tu hành."},{"ten":"Lão già áo trắng","tag":"doi-thu","quanHe":"kẻ đánh phế","ghiChu":"Đánh nát kinh mạch, cướp cờ kỳ quái, hạ yêu vật làm chiến thư sống."},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân cứu mạng và truyền công","ghiChu":"Cứu sống, truyền Luyện Thể thuật Cự Ma Tộc, hứa truyền khẩu quyết tầng một Cổ Thần nếu thành tựu."},{"ten":"Hổ Bào","tag":"dong-minh","quanHe":"Cùng theo Vương Lâm","ghiChu":"Cùng làm thị vệ tháp tùng Vương Lâm tới Cổ Yêu thành."},{"ten":"Hổ Bào","tag":"dong-minh","quanHe":"Cùng bảo vệ lão tổ","ghiChu":"Sự kiên quyết của Thập Tam khiến Hổ Bào dần đổi thái độ, thấy hắn không phải kẻ đáng ghét."},{"ten":"Thống lĩnh (Nghiêu Lĩnh, Cổ Yêu thành)","tag":"doi-thu","quanHe":"Đối đầu trong tửu lâu","ghiChu":""},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Thống lĩnh, người Thập Tam phục tùng","ghiChu":"Đọc quân quy và đếm ngược theo lệnh Vương Lâm."},{"ten":"Diêu Tích Tuyết","tag":"doi-thu","quanHe":"Bị nàng khống chế khi nàng xông vào lầu Vương Lâm"},{"ten":"Tần Lâm","tag":"khac","quanHe":"Người mang Thập Tam đi dâng cho Yêu Tướng"},{"ten":"Hổ Bào","tag":"ban-be","quanHe":"Cùng là tùy tùng man rợ của Vương Lâm, trợ giúp lẫn nhau"},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Lão tổ tôn kính","ghiChu":"Người truyền cho Thập Tam công pháp luyện thể Cự Linh Cửu Tu."}],"tuiDo":{"phapBao":[{"ten":"Hồn phiên thay thế (Thiên Vận Tinh)","loai":"phap-bao","trangThai":"dang-co","moTa":"Cây hồn phiên bảy thước Thập Tam tự chế thành sau ba lần thất bại, phong ấn hồn phách sư tử cánh dài.","nguon":"@c0505"}],"congPhap":[{"ten":"Luyện Hồn Thuật","loai":"cong-phap","moTa":"Thần thông Luyện Hồn Tông nhất mạch do Vương Lâm truyền, Thập Tam tu tới giai đoạn ba.","nguon":"@c0505"}]}},"nguon":["@c0505","@c0506","@c0507","@c0508","@c0509","@c0512","@c0513","@c0514","@c0515","@c0516","@c0517","@c0518","@c0527","@c0529","@c0530"]},{"id":"lao-gia-ao-trang-thien-thuy","name":"Lão già áo trắng (Thiên Thủy)","gioiTinh":"nam","theLuc":[{"ten":"Cổ Yêu thành / phủ Tả Dực tướng quân","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa thần trung kỳ","trangThai":"tu-vong","blurb":"Chấp sự dưới trướng Tả Dực tướng quân ở Cổ Yêu thành, đánh phế Thập Tam và hạ chiến thư khiêu chiến Vương Lâm; bị Vương Lâm bóp cổ giết, nguyên thần giam vào cờ Tôn Hồn.","vaiTro":"phản diện chương","tinhCach":[{"text":"Hung tàn, đắc ý, khinh người","chuong":"@c0507"}],"tabs":{"diem":[{"text":"Cố ý không giết Thập Tam, dùng yêu vật và lời nhắn làm chiến thư sống dụ người sau lưng xuất hiện để moi khẩu quyết cờ kỳ quái.","chuong":"@c0507"}],"kinhLich":[{"text":"Về bộ lạc Thiên Thủy thăm thân, chặn tổ Thập Tam, đánh nát kinh mạch hắn, cướp mấy cây cờ kỳ quái, hạ sợi tơ hồng yêu vật vào ngực, thả Thập Tam đi truyền tin.","bridge":true,"khoang":"@c0507"},{"chuong":"@c0507","importance":"major","tieuDe":"Bị Vương Lâm bóp cổ giết","text":"Khi Vương Lâm nhổ trận pháp mảnh đất mang về, ra ngoài trận hạ chiến thư đòi đánh tay đôi; bị Vương Lâm chộp cổ bóp “rắc” chết, nguyên thần bị giam vào cờ Tôn Hồn, xác bị chủ hồn đốt thành tro."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già áo xám (Thiên Thủy)","tag":"dong-hanh","quanHe":"đồng tộc bộ lạc Thiên Thủy","ghiChu":"Được lão áo xám can ngăn nhưng không nghe."},{"ten":"Tả Dực tướng quân","tag":"cap-tren","quanHe":"chủ tướng","ghiChu":"Làm chấp sự/chấp phụ dưới trướng Tả Dực tướng quân tại Cổ Yêu thành."},{"ten":"Thập Tam","tag":"doi-thu","quanHe":"nạn nhân","ghiChu":"Đánh phế và biến thành chiến thư sống."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"kẻ giết mình","ghiChu":"Bị bóp cổ giết, nguyên thần giam vào cờ Tôn Hồn."}],"tuiDo":{"phapBao":[{"ten":"Cây cờ kỳ quái (cướp từ Thập Tam)","trangThai":"da-dung","moTa":"Mấy cây cờ nhỏ cướp từ Thập Tam, muốn moi khẩu quyết sử dụng đầy đủ.","nguon":"@c0507"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0507"]},{"id":"lao-gia-ao-xam-thien-thuy","name":"Lão già áo xám (Thiên Thủy)","gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Thiên Thủy","trangThai":"da-roi"},{"ten":"Bộ lạc Luyện Hồn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ (am hiểu trận pháp viễn cổ)","trangThai":"song","blurb":"Trưởng lão am hiểu trận pháp của bộ lạc Thiên Thủy; can lão áo trắng không được, sau khi lão áo trắng bị giết thì mở trận pháp đầu hàng, theo Vương Lâm sang bộ lạc Luyện Hồn và sinh hứng thú với thuật Luyện hồn.","vaiTro":"phụ","tinhCach":[{"text":"Cẩn trọng, biết thời thế","chuong":"@c0507"}],"tabs":{"diem":[{"text":"Trách lão áo trắng rước họa, buộc phải tự gánh để cứu bộ lạc; định báo cáo lên phủ Tả Dực nhưng sợ hãi từ bỏ sau khi thấy Vương Lâm giết lão áo trắng.","chuong":"@c0507"}],"kinhLich":[{"chuong":"@c0507","importance":"normal","tieuDe":"Mở trận pháp, quy thuận Luyện Hồn","text":"Sau khi lão áo trắng bị giết, sợ hãi mở trận pháp viễn cổ Thiên Thủy; được thu nạp làm tộc nhân bộ lạc Luyện Hồn mới, sinh hứng thú với thuật Luyện hồn."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già áo trắng (Thiên Thủy)","tag":"dong-hanh","quanHe":"đồng tộc, đối nghịch ý kiến","ghiChu":"Can ngăn việc rước họa, sau quy trách nhiệm để cứu bộ lạc."},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"chủ nhân mới","ghiChu":"Quy thuận sau khi chứng kiến uy lực Vương Lâm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0507"]},{"id":"ta-duc-tuong-quan","name":"Tả Dực tướng quân","gioiTinh":"nam","theLuc":[{"ten":"Cổ Yêu thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Tướng quân thống lĩnh ở Cổ Yêu thành; lão già áo trắng làm chấp sự/chấp phụ dưới trướng, lão áo xám định báo cáo việc Vương Lâm lên phủ Tả Dực.","vaiTro":"nhắc tên","tinhCach":[],"tabs":{"diem":[{"text":"Phủ Tướng quân có hàng Trưởng lão tu vi ngang Vương Lâm — gợi thế lực Cổ Yêu thành sẽ chú ý tới Vương Lâm.","chuong":"@c0507"}],"kinhLich":[{"text":"Lão áo trắng làm chấp sự dưới trướng; lão áo xám định báo lên phủ Tả Dực ở Cổ Yêu thành về việc Vương Lâm.","bridge":true,"khoang":"@c0507"},{"text":"Hiện thân trong cung điện khổng lồ có pho tượng đại hán mặc giáp, hỏi tội Vương Lâm đánh yêu binh rồi đánh thử một quyền vô thanh xuyên hư không. Sau khi Vương Lâm hóa giải bằng Tịch Diệt chỉ, hắn đề nghị cho làm Trưởng lão (chức trong) nhưng bị từ chối; bèn ra mười quyền tạo Thập Băng Chiến Ý, hứa nếu tiếp được sẽ ban chức Đô thống có binh quyền.","bridge":true,"khoang":"@c0509"},{"text":"Tả dực Yêu tương trấn giữ Cổ Yêu thành, dùng thần công Thập Băng Quyền Ý sinh ra từ hư vô, vô hình, phát theo tám lần sụp đổ càng về sau càng mạnh. Hắn khen Vương Lâm là một trong số ít người phản công được dưới quyền ý này và thách hắn phá đủ tám lần sụp đổ mới áp sát được.","bridge":true,"khoang":"@c0510"},{"text":"Tả dực Yêu tướng thả các đợt sụp đổ Thập Băng Quyền Ý để thử Vương Lâm, vốn cho rằng đối phương cùng lắm phá đến lần thứ bảy là dừng. Khi Vương Lâm chỉ một lời đã phá tan lần thứ bảy, hắn rốt cục biến sắc, thừa nhận đã xem thường đối phương ngay từ đầu — lần đầu tỏ ra xúc động trong mấy ngàn năm. Quyền ý vốn cực hạn mười lần sụp đổ nhờ hấp thu tâm niệm mà tiến hóa lên lần thứ mười một.","bridge":true,"khoang":"@c0511"},{"chuong":"@c0512","importance":"normal","tieuDe":"Phong Thống lĩnh cho Vương Lâm","text":"Chủ trì khảo nghiệm, thi triển Thập Băng Quyền mười lần ‘sụp đổ’; khi Vương Lâm chủ động lùi trước quyền thứ chín, hắn chộp tay thu lại quyền ý, khen Vương Lâm biết tiến lùi. Hắn xưng danh đầy đủ là Vân Lệ Hải, đánh giá thực lực Vương Lâm đủ làm Thống lĩnh, phong hắn nắm một vạn yêu binh Cổ Yêu thành rồi trao lệnh bài đồng và biến mất."}],"tuViMoc":[{"chuong":"@c0509","canhGioi":"Gần Vấn Đỉnh","text":"Yêu lực nội liễm không dưới mười vạn giáp, kém cảnh giới Vấn Đỉnh không nhi��u.","importance":"major"}],"nhanMach":[{"ten":"Lão già áo trắng (Thiên Thủy)","tag":"cap-tren","quanHe":"thuộc hạ chấp sự","ghiChu":"Chấp sự/chấp phụ dưới trướng."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người ngoài đến xin chức","ghiChu":"Thử thách Vương Lâm bằng đòn quyền và Thập Băng Chiến Ý để xét ban chức."},{"ten":"Diêu Nghiêu lĩnh","tag":"su-mon","quanHe":"Thuộc hạ Cổ Yêu thành","ghiChu":"Diêu Nghiêu lĩnh dẫn Vương Lâm tới gặp hắn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ giao chiến","ghiChu":"Khen Vương Lâm phản công được dưới Thập Băng Quyền Ý, thách phá tám lần sụp đổ."},{"ten":"Diêu Tích Tuyết","tag":"khac","quanHe":"Người từng bại dưới Thập Băng Quyền Ý","ghiChu":"Ba năm trước Diêu Tích Tuyết bại ở lần thứ tám của quyền ý này, sau được ban chức Thống lĩnh."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người hắn thử thách","ghiChu":"Người đầu tiên cảm ngộ được dưới Thập Băng Quyền Ý, khiến hắn lần đầu chấn động."},{"ten":"Yêu đế","tag":"cap-tren","quanHe":"Phụng mệnh","ghiChu":"Phụng mệnh yêu đế đi tìm kiếm một người nhất định."},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Phong Vương Lâm làm Thống lĩnh Cổ Yêu thành","ghiChu":"Đánh giá cao thực lực và sự khôn ngoan biết tiến lùi của Vương Lâm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0507","@c0509","@c0510","@c0511","@c0512"],"aliases":["Tả Dực tướng quân","Tả dực tướng quân","Vân Lệ Hải","Tả Dực Yêu tương"]},{"id":"ho-bao","name":"Hổ Bào","cn":"","aliases":["Hổ Bảo"],"gioiTinh":"nam","theLuc":[{"ten":"Bộ lạc Luyện Hồn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Giai đoạn thứ năm Luyện Hồn (ngang Kết Đan kỳ)","trangThai":"song","blurb":"Thiếu niên thiên tài bộ lạc nhỏ, có yêu lực nhị tinh bẩm sinh, bị bắt nhập bộ lạc Luyện Hồn rồi được Vương Lâm giữ bên người khống chế.","vaiTro":"Đệ tử thiên tài kiêm thị vệ của Vương Lâm","tinhCach":[{"text":"Tư chất thông minh, được đánh giá là thiên tài hiếm có.","chuong":"@c0508"}],"tabs":{"diem":[{"text":"Có yêu lực nhị tinh ngay từ nhỏ, tư chất thông minh xuất chúng.","chuong":"@c0508"},{"text":"Vương Lâm đánh giá nếu trong trăm năm đạt Hóa Thần sẽ gần hoặc vượt Hồng Điệp năm xưa.","chuong":"@c0508"}],"kinhLich":[{"text":"Vốn là cao thủ một bộ lạc nhỏ, Hổ Bào bị Âu Dương Hoa bắt và uống Ly Yêu thang để gia nhập bộ lạc Luyện Hồn. Sau bốn năm hắn tu tới giai đoạn thứ năm với chín mươi ba hồn phiên (ba mươi mốt chủ hồn), thực lực tương đương Kết Đan kỳ.","bridge":true,"khoang":"@c0508"},{"chuong":"@c0508","importance":"normal","tieuDe":"Theo Vương Lâm rời bộ lạc","text":"Được Vương Lâm xem là thiên tài nên giữ bên người để khống chế; cùng Thập Tam theo Vương Lâm rời bộ lạc đi Cổ Yêu thành như thị vệ, cưỡi Văn Thú lên đường."},{"bridge":true,"khoang":"@c0509","text":"Theo Vương Lâm tới Cổ Yêu thành; thoạt thấy thành thì bất giác quỳ lễ, sau xấu hổ đứng dậy nhổ nước bọt về phía thành tỏ vẻ khinh thường, rồi cùng Thập Tam chờ trong thành."},{"bridge":true,"khoang":"@c0512","text":"Đi theo Vương Lâm dạo Cổ Yêu thành, mải mê ngắm hàng quán lầu các náo nhiệt; ở Trúc Thanh lâu, thấy Thập Tam không uống nên hắn cũng không dám uống rượu."},{"text":"Đang len lén uống rượu, Hổ Bào nể lão tổ đang có biến nên nén giận; khi hỗn chiến nổ ra, hắn lấy mười lá cờ nhỏ rồi phất Hồn phiên thả vô số hồn phách rít the thé bay đầy tửu lâu để cản đám yêu binh, cùng Thập Tam quyết tử bảo vệ lão tổ.","bridge":true,"khoang":"@c0513"},{"bridge":true,"khoang":"@c0514–@c0514","text":"Thu hồi hồn phiên đứng cạnh Vương Lâm, cười lạnh với đám yêu binh trong tửu lâu; qua Truyền Tống trận bị sóng âm làm yêu lực tán loạn chạy khắp kinh mạch, được Vương Lâm đặt tay lên vai truyền nguồn lực ôn hòa ổn định lại."},{"bridge":true,"khoang":"@c0515","text":"Theo Vương Lâm vào quân doanh, Hổ Bào tức giận trước sự khinh miệt của yêu binh, gọi Vương Lâm là Lão tổ, nhưng vẫn kìm nén ngồi thổ nạp bên trái hắn suốt ba ngày, càng lúc càng khó giữ bình tĩnh."},{"bridge":true,"khoang":"@c0516–@c0516","text":"Tức giận tích tụ vì thái độ của Vương Lâm nhưng e ngại chưa dám nổi khùng; khi quân doanh bị vây, hắn đứng dậy xuất hồn phiên chuẩn bị chiến đấu."},{"text":"Sống thoải mái trong quân doanh, mâu thuẫn cũ tan dần; đặc biệt rung động với một nữ thống đội tên Từ U, tỏ ra vô cùng ân cần và thường ngồi ngoài lầu như thần giữ cửa.","bridge":true,"khoang":"@c0517"},{"chuong":"@c0527","importance":"normal","tieuDe":"Bị phế tu vi rồi mất tích bí ẩn","text":"Muốn rời quân doanh quay về bộ lạc man rợ thì bị Tư Mã Viêm bắt với cớ vi phạm quân quy, phế tu vi ném vào hắc lao. Ba tháng sau, dù hắc lao canh phòng cực nghiêm, Hổ Bào vẫn mất tích bí ẩn mà ngay cả Tư Mã Viêm cũng không hiểu rõ."},{"text":"Tùy tùng tu Luyện Hồn Thuật do Vương Lâm truyền, quyền khống chế linh hồn nằm ở Vương Lâm. Khi Vương Lâm tìm khắp Cổ Yêu thành và hắc lao, dấu vết linh hồn Hổ Bào hoàn toàn biến mất; Vương Lâm kết luận nếu không chết thì bị giam ở một nơi kỳ dị mà cả thần thức Anh Biến hậu kỳ cũng không quét tới.","bridge":true,"khoang":"@c0529"},{"chuong":"@c0530","importance":"normal","tieuDe":"Tái sinh dưới trướng lão già hắc y, ôm hận Vương Lâm","text":"Sau khi bị Tư Mã Viêm giận cá chém thớt ném vào hắc lao và chờ Vương Lâm tới cứu vô vọng, Hổ Bào được lão già hắc y cứu ra vì sở hữu Luyện Hồn Thuật kỳ dị. Hắn ngồi luyện hóa linh hồn tại chiến trường cổ trong lãnh thổ Yêu Linh, phát thề không bao giờ làm nô bộc cho ai nữa, đang tu Diệt Thế Áp Nguyên Công và quyết báo thù Vương Lâm cùng Tư Mã Viêm khi luyện đủ nghìn vạn hồn phách."},{"chuong":"@c0562","importance":"normal","tieuDe":"Tham vọng yêu đế và cái chết","text":"Hổ Bào thừa nhận hận Vương Lâm tới mức muốn giết, khoe đã có Luyện Hồn thuật cùng trên trăm ngàn hồn phách (phần lớn là anh linh viễn cổ chiến trường, có cả vài hồn cấp yêu suất), mưu gom đủ trăm vạn hồn để lập đệ thập quận và tự xưng yêu đế. Hắn kể trong lúc bị giam ở hắc lao đã thề phải mạnh hơn rồi giết Vương Lâm. Nhưng khi lùa hồn phách công kích, hắn hô “Ức hồn thôn phệ” lẫn “Hồn, tốc quy!” đều vô hiệu vì hồn phách quay sang phục tùng Vương Lâm; cuối cùng bị Thập Ức Tôn Hồn Phiên đánh tứ phân ngũ liệt, toàn bộ hồn phách bị thu đi."}],"tuViMoc":[{"chuong":"@c0508","canhGioi":"Giai đoạn thứ năm Luyện Hồn","text":"Sau bốn năm tu tới giai đoạn thứ năm, sở hữu chín mươi ba hồn phiên trong đó ba mươi mốt chủ hồn, thực lực ngang Kết Đan kỳ. Đây thuộc hệ tu Luyện Hồn của bộ lạc, không phải hệ tu vi chính thống.","importance":"major"}],"nhanMach":[{"ten":"Âu Dương Hoa","tag":"doi-thu","quanHe":"Người bắt Hổ Bào về tộc","ghiChu":"Bắt hắn rồi cho uống Ly Yêu thang gia nhập bộ lạc Luyện Hồn."},{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Lão tổ giữ Hổ Bào bên người","ghiChu":"Đánh giá hắn là thiên tài, giữ bên người để vừa bồi dưỡng vừa khống chế."},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Cùng theo Vương Lâm","ghiChu":"Cùng làm thị vệ tháp tùng Vương Lâm tới Cổ Yêu thành."},{"ten":"Thập Tam","tag":"dong-minh","quanHe":"Cùng bảo vệ lão tổ","ghiChu":"Cảm phục sự kiên quyết của Thập Tam."},{"ten":"Từ U","tag":"khac","quanHe":"Nữ thống đội khiến Hổ Bào rung động","ghiChu":""},{"ten":"Thập Tam","tag":"ban-be","quanHe":"Cùng tùy tùng man rợ của Vương Lâm"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Chủ tử cũ thành kẻ thù","ghiChu":"Người truyền Luyện Hồn Thuật cho Hổ Bào; bị Hổ Bào căm hận vì không tới cứu khỏi hắc lao."},{"ten":"Tư Mã Viêm","tag":"doi-thu","quanHe":"Kẻ đẩy vào hắc lao","ghiChu":"Giận cá chém thớt ném Hổ Bào vào nhà lao, là mục tiêu báo thù."},{"ten":"Lão già hắc bào (ân công của Hổ Bào)","tag":"an-nhan","quanHe":"Ân nhân cứu mạng","ghiChu":"Cứu Hổ Bào ra khỏi hắc lao, truyền Diệt Thế Áp Nguyên Công, dẫn tới chiến trường cổ luyện hồn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Ân nhân cũ từng cứu mạng và truyền Luyện Hồn thuật, sau bị hắn ôm hận muốn giết; rốt cuộc bị Vương Lâm đoạt quyền khống chế hồn rồi giết.","ghiChu":"@c0562"}],"tuiDo":{"phapBao":[{"ten":"Hồn phiên","loai":"phap-bao","trangThai":"dang-co","moTa":"Chín mươi ba hồn phiên cá nhân, trong đó ba mươi mốt là chủ hồn, dùng tu luyện theo thuật Luyện Hồn.","nguon":"@c0508"}],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0508","@c0509","@c0512","@c0513","@c0514","@c0515","@c0516","@c0517","@c0527","@c0529","@c0530","@c0562"]},{"id":"dieu-nghieu-linh","name":"Diêu Nghiêu lĩnh","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Cổ Yêu thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ (chưa viên mãn)","trangThai":"song","blurb":"Nữ tử áo trắng mắt phượng tại Cổ Yêu thành, người quen cũ của Vương Lâm; dẫn hắn đi gặp Tả dực Yêu tương.","vaiTro":"Cao thủ ở Cổ Yêu thành, trung gian dẫn Vương Lâm tới gặp Tả dực Yêu tương.","tinhCach":[{"text":"Lý trí, không thích giao chiến vô nghĩa","chuong":"@c0509"}],"tabs":{"diem":[{"text":"Thân ảnh màu hồng, áo trắng, mắt phượng, lông mày sát nhau, tóc đen xõa vai; tu vi Anh biến hậu kỳ chưa viên mãn","chuong":"@c0509"}],"kinhLich":[{"text":"Khi Vương Lâm thị uy đám yêu binh và tạo quả cầu máu, Diêu Nghiêu lĩnh từ trong cửa thành lao ra điểm tay làm tan cầu máu, nhận ra và gọi tên Vương Lâm. Nàng cho rằng cuộc chiến giữa hai người không ý nghĩa, dẫn Vương Lâm tới quảng trường có Truyền tống trận để đi gặp Tả dực Yêu tương.","bridge":true,"khoang":"@c0509"}],"tuViMoc":[{"chuong":"@c0509","canhGioi":"Anh Biến hậu kỳ","text":"Tu vi Anh biến hậu kỳ chưa viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người quen cũ","ghiChu":"Từng gặp ở ngoài cửa Đông Hải Yêu linh khi nàng độc chiếm một nơi; tại Cổ Yêu thành dẫn Vương Lâm đi gặp Tả dực Yêu tương."},{"ten":"Tả dực Yêu tương","tag":"su-mon","quanHe":"Thuộc phủ Tả dực tướng quân","ghiChu":"Người của Cổ Yêu thành, dẫn Vương Lâm tới gặp chủ thành."}],"tuiDo":{}},"nguon":["@c0509"]},{"id":"thong-linh-nghieu-linh-co-yeu-thanh","name":"Thống lĩnh (Nghiêu Lĩnh, Cổ Yêu thành)","cn":"","aliases":["Người nét mặt âm trầm"],"gioiTinh":"nam","theLuc":[{"ten":"Nghiêu Lĩnh","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Yêu nhân khoảng ba mươi tuổi nét mặt âm trầm, cựu Nghiêu Lĩnh chính ở Cổ Yêu thành bị phế chức nên bất mãn người ngoài đến.","vaiTro":"Phản diện thoáng qua khiêu khích nhóm Vương Lâm","tinhCach":[{"text":"Âm trầm, hiếu thắng, sẵn lòng chịu trách phạt để giành lại chức vị.","chuong":"@c0513"}],"tabs":{"diem":[{"text":"Cựu Nghiêu Lĩnh chính bị một người ngoài đến — được Yêu Tương đại nhân phá lệ ban chức — vượt lên thay thế, sinh bất mãn.","chuong":"@c0513"}],"kinhLich":[{"text":"Dẫn bảy tám yêu binh hắc giáp xông vào tửu lâu, ném hai vò rượu dò xét rồi tấn công bàn Vương Lâm, định dùng Tru Tiên trận giết người ngoài đến. Hắn chú ý Vương Lâm ngay từ đầu, cảm nhận trong cơ thể đối phương có hai luồng lực lượng quỷ dị; khi sáu đạo yêu lực mất khống chế, hắn hô thu hồi không kịp.","bridge":true,"khoang":"@c0513"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khiêu khích","ghiChu":""},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Quyền cao quân yêu","ghiChu":"Phá lệ ban chức thống lĩnh cho người ngoài, khiến hắn bị phế."}],"tuiDo":{}},"nguon":["@c0513"]},{"id":"quan-su-tham-quan","name":"Quản sự tham quân","cn":"","aliases":["Quản sự tham quân mặt gầy"],"gioiTinh":"nam","theLuc":[{"ten":"Quân doanh (dưới trướng Yêu Tương)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Quản sự tham quân dưới trướng Yêu Tương, được phái tới đưa Vương Lâm tới quân doanh.","vaiTro":"Nhân vật phụ — quản sự tham quân yêu tộc.","tinhCach":[{"text":"Lạnh lùng, cung kính khuôn phép","chuong":"@c0514"}],"tabs":{"diem":[{"text":"Vào phòng khiến không khí lạnh hẳn; mặt gầy gò, chừng bốn mươi tuổi","chuong":"@c0514"}],"kinhLich":[{"text":"Tuân lệnh Yêu Tương tới cầu kiến Vương thống lĩnh, xin xem lệnh bài đồng rồi cắn ngón tay vẽ Truyền Tống trận bằng máu cực kỳ phức tạp, dẫn ba người tới quân doanh.","bridge":true,"khoang":"@c0514"},{"bridge":true,"khoang":"@c0515","text":"Dẫn Vương Lâm tới quân doanh Hắc Giáp quân nhậm chức, nhấn mạnh chữ phó đầy châm biếm khi giới thiệu Tư Mã Viêm; sau đó ôm quyền cáo từ về phục mệnh Yêu Tương đại nhân, đi vào trận pháp biến mất."},{"text":"Theo luồng sáng đỏ như máu hiện thân ở quân doanh, cùng lão già áo vải bố tới phân xử việc th��ng lĩnh giết người. Sau khi truyền yêu lực vào ngọc giản xem lại diễn biến, sự khinh thường biến mất, sinh ý kết giao với Vương Lâm, hứa bẩm báo Yêu Tương đại nhân rồi ôm quyền cáo lui.","bridge":true,"khoang":"@c0517"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Được phái tới đưa Vương Lâm (Vương thống lĩnh) tới quân doanh"},{"ten":"Yêu Tương","tag":"cap-tren","quanHe":"Quản sự tham quân dưới trướng Yêu Tương"},{"ten":"Lão già áo vải bố","tag":"dong-hanh","quanHe":"Người đi cùng tới quân doanh","ghiChu":"Đứng phía sau quản sự, thân có bốn phong ấn."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0514","@c0515","@c0517"]},{"id":"nam-tu-am-tram-yeu-binh","name":"Nam tử âm trầm","cn":"","aliases":["Đầu lĩnh sáu yêu binh tửu lâu","Nam tử âm trầm","Tư Mã phó thống lĩnh"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Đầu lĩnh sáu yêu binh trong tửu lâu, vẻ mặt âm trầm, đụng độ thoáng qua với Vương Lâm.","vaiTro":"Nhân vật phụ — yêu binh trong tửu lâu.","tinhCach":[{"text":"Âm trầm, ngạo mạn nhưng dè chừng","chuong":"@c0514"}],"tabs":{"diem":[{"text":"Vẻ mặt âm trầm, là đầu lĩnh của sáu yêu binh bị Vương Lâm nuốt yêu lực","chuong":"@c0514"}],"kinhLich":[{"text":"Đứng lên hỏi danh tính Vương Lâm, vỗ bàn quát đứng lại rồi tán phát yêu lực ngưng thành một thanh trường kiếm bay tới ba người; bị Vương Lâm vung tay tạo gió làm tan, sững lại trầm tư nhìn theo.","bridge":true,"khoang":"@c0514"},{"chuong":"@c0515","importance":"normal","tieuDe":"Ra mắt tân thống lĩnh","text":"Tư Mã Viêm cưỡi một cự thú đen một sừng, mặc hắc giáp phủ kín có đồ họa màu bạc, mũ đen che mặt phóng tới quân doanh. Khi tháo mũ, hắn để lộ khuôn mặt âm trầm chính là người đã gặp Vương Lâm ở tửu lâu, xưng Tư Mã Viêm ra mắt thống lĩnh. Là tâm phúc nắm mười Thống đội của Hắc Giáp quân, hắn lệnh yêu binh tiếp tục thao luyện, ngấm ngầm để vạn yêu binh khinh thường tân thống lĩnh."},{"chuong":"@c0515","importance":"normal","tieuDe":"Khiếp sợ và triệu tập thống đội","text":"Sau ba ngày, Tư Mã Viêm càng lúc càng sợ — không phải sợ Vương Lâm ra tay hay tức giận mà sợ cảm giác nhìn không thấu sự bình thản dị thường của hắn. Tư Mã Viêm triệu bảy tám thống đội về phòng để nghe nhận xét về tân thống lĩnh, được báo hai người Từ U và Chu Khải vắng mặt như thường lệ."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm nuốt yêu lực và hóa giải đòn trường kiếm; được hẹn sẽ gặp lại"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tân thống lĩnh Hắc Giáp quân, cấp trên danh nghĩa","ghiChu":"Tư Mã Viêm bề ngoài quy phục nhưng ngầm chống đối, không thể nhìn thấu."},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Cường giả cấp Yêu Tương cai quản trên Hắc Giáp quân","ghiChu":"Quản sự tham quân về phục mệnh Yêu Tương đại nhân."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0514","@c0515"]},{"id":"tu-u","name":"Từ U","gioiTinh":"nam","theLuc":[{"ten":"Hắc Giáp quân","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một thống đội của Hắc Giáp quân, ít lui tới Tư Mã Viêm và vắng mặt khi được triệu tập.","vaiTro":"Thống đội Hắc Giáp quân, gợi mở khe hở phe phái trong nội bộ.","tabs":{"kinhLich":[{"bridge":true,"khoang":"@c0515","text":"Là thống đội ít lui tới Tư Mã Viêm, Từ U cùng Chu Khải không đến khi Tư Mã Viêm triệu tập bàn về tân thống lĩnh."},{"bridge":true,"khoang":"@c0517","text":"Là nữ thống đội trong Hắc Giáp quân, khiến Hổ Bào rung động và được hắn ân cần đối đãi."}],"nhanMach":[{"ten":"Tư Mã Viêm","tag":"cap-tren","quanHe":"Phó thống lĩnh Hắc Giáp quân","ghiChu":"Từ U ít lui tới và không nghe triệu tập."},{"ten":"Hổ Bào","tag":"khac","quanHe":"Người rung động và ân cần với nàng","ghiChu":""}],"tuViMoc":[]},"nguon":["@c0515","@c0517"]},{"id":"chu-khai","name":"Chu Khải","gioiTinh":"nam","theLuc":[{"ten":"Hắc Giáp quân","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một thống đội của Hắc Giáp quân, ít lui tới Tư Mã Viêm và vắng mặt khi được triệu tập.","vaiTro":"Thống đội Hắc Giáp quân, gợi mở khe hở phe phái trong nội bộ.","tabs":{"kinhLich":[{"bridge":true,"khoang":"@c0515","text":"Là thống đội ít lui tới Tư Mã Viêm, Chu Khải cùng Từ U không đến khi Tư Mã Viêm triệu tập bàn về tân thống lĩnh."}],"nhanMach":[{"ten":"Tư Mã Viêm","tag":"cap-tren","quanHe":"Phó thống lĩnh Hắc Giáp quân","ghiChu":"Chu Khải ít lui tới và không nghe triệu tập."}]},"nguon":["@c0515"]},{"id":"dai-han-dau-troc-bo-cap","name":"Đại hán đầu trọc (ký hiệu bọ cạp)","gioiTinh":"nam","theLuc":[{"ten":"Hắc Giáp quân","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Một thống đội dưới quyền Tư Mã Viêm, đầu trọc mặc giáp đen uy nghiêm, trên đầu có ký hiệu con bọ cạp quỷ dị như vật sống.","vaiTro":"Thống đội tâm phúc của Tư Mã Viêm trong Hắc Giáp quân.","tabs":{"kinhLich":[{"bridge":true,"khoang":"@c0515","text":"Trong buổi Tư Mã Viêm triệu tập, đại hán đầu trọc đứng ra báo cáo việc hai người Từ U và Chu Khải ít lui tới và lần này vẫn không đến."}],"nhanMach":[{"ten":"Tư Mã Viêm","tag":"cap-tren","quanHe":"Phó thống lĩnh Hắc Giáp quân","ghiChu":"Là thống đội tâm phúc, báo cáo cho Tư Mã Viêm."}]},"nguon":["@c0515"]},{"id":"tu-ma-viem","name":"Tư Mã Viêm","cn":"","aliases":["Tư Mã thống lĩnh"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Thống lĩnh quân doanh Thiên Yêu quận, âm trầm nhiều mưu kế, đối đầu tranh giành quyền lực với thống lĩnh mới Vương Lâm.","vaiTro":"Thống lĩnh quân doanh yêu binh, đối thủ chính trị của Vương Lâm trong tranh giành quyền lực Thiên Yêu quận.","tinhCach":[{"text":"Âm trầm, nhiều mưu kế","chuong":"@c0516"},{"text":"Thận trọng, biết chờ thời để đối phương lộ sơ hở","chuong":"@c0516"}],"tabs":{"diem":[{"text":"Chủ trương không trêu chọc Vương Lâm, chờ hắn chủ động xuất thủ để có đối sách","chuong":"@c0516"},{"text":"Nhận tin loạn nhưng cố ý chờ Vương Lâm bị vây mới ra mặt, báo trước cho quản sự tham quân","chuong":"@c0516"}],"kinhLich":[{"text":"Tư Mã Viêm cùng các thống đội định sách chờ Vương Lâm chủ động ra tay rồi mới đối phó. Khi Vương Lâm giết Tôn thống đội và trảm yêu binh, hắn dùng bí thuật báo cho quản sự tham quân, cố ý chờ Vương Lâm bị chín ngàn yêu binh vây mới phóng tới chất vấn. Không ngờ bị Vương Lâm viện dẫn quân quy điều mười ba và điều hai ép vào thế bị động, mới hiểu ra Vương Lâm ngồi im cả tháng chính là để chờ cơ hội này.","bridge":true,"khoang":"@c0516"},{"text":"Hạ lệnh chín ngàn yêu binh tản ra phá thế bao vây, nhưng sau khi quản sự xem ngọc giản thì cục diện đảo ngược; Tư Mã Viêm cung kính nhận “lỗ mãng”, đám thống đội cũng lần lượt nhận lỗi. Sau sự kiện, bốn trong tám thống đội từng thân với hắn dần xa lánh.","bridge":true,"khoang":"@c0517"},{"bridge":true,"khoang":"@c0526","text":"Đứng cung kính bên Đô Thống trong quân doanh Hắc Giáp quân; nhận ra Vương Lâm thì khiếp sợ cực độ, hối hận từng trêu chọc hắn năm xưa, nhớ tới cảnh ngộ của Thập Tam và Hổ Bào, do dự rồi vẫn xông ra."},{"chuong":"@c0527","importance":"normal","tieuDe":"Bị sưu hồn rồi giết","text":"Bị lộ là kẻ đã lấy cớ vi phạm quân quy để phế tu vi Hổ Bào ném vào hắc lao, lại bóp nát gân cốt Thập Tam khi gã trợ giúp Hổ Bào. Bị Vương Lâm chộp tới, dùng Sưu hồn thuật đọc trọn ký ức, rồi bị Sát Lục Tiên quyết khiến thân thể héo rũ tan thành huyết nhục; toàn thân công phu bị luyện hóa thành tia khí xám."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Thống lĩnh mới của quân doanh, đối thủ tranh quyền","ghiChu":"Bị Vương Lâm dùng quân quy phản chế khi ra mặt chất vấn."},{"ten":"Tôn thống đội","tag":"khac","quanHe":"Thống đội dưới quyền","ghiChu":"Bị Vương Lâm giết khi khiêu khích."},{"ten":"Đô Thống Hắc Giáp quân","tag":"cap-tren","quanHe":"Đứng hầu cận bên Đô Thống trong quân doanh.","ghiChu":"@c0526"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm sưu hồn rồi giết để báo thù cho tùy tùng"}],"tuiDo":{}},"nguon":["@c0516","@c0517","@c0526","@c0527"]},{"id":"ton-thong-doi","name":"Tôn thống đội","cn":"","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Kết Đan kỳ","trangThai":"tu-vong","blurb":"Thống đội yêu binh dưới quyền Tư Mã Viêm; khinh miệt sỉ nhục Vương Lâm rồi bị hắn bóp nát cổ, phá tu vi và hút yêu khí.","vaiTro":"Thống đội yêu binh, nạn nhân đầu tiên trong màn ra oai của Vương Lâm.","tinhCach":[{"text":"Ngạo mạn, coi thường thống lĩnh mới","chuong":"@c0516"}],"tabs":{"diem":[],"kinhLich":[{"text":"Tôn thống đội dẫn đội ngàn người thao luyện đi ngang chỗ Vương Lâm, nhổ nước bọt và gọi hắn là phế vật. Vương Lâm mở mắt, giơ tay tạo nguồn lực vô hình trói chặt kéo lại bóp cổ, sai Thập Tam đọc điều thứ tám quân quy rồi bóp nát cổ, phá hủy tu vi và hút yêu khí từ thất khiếu của hắn.","bridge":true,"khoang":"@c0516"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Thống lĩnh mới bị Tôn thống đội sỉ nhục","ghiChu":"Giết Tôn thống đội để ra oai."},{"ten":"Tư Mã Viêm","tag":"khac","quanHe":"Thống lĩnh quân doanh, cấp trên","ghiChu":"Tôn thống đội thuộc quyền Tư Mã Viêm."}],"tuiDo":{}},"nguon":["@c0516"]},{"id":"lao-gia-ao-vai-bo-bon-phong-an","name":"Lão già áo vải bố","aliases":["Lão già tóc bạc bốn phong ấn"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"song","blurb":"Lão già mặc áo vải bố, tóc bạc trắng phất phơ, đi cùng quản sự tham quân; trong thân có bốn phong ấn.","vaiTro":"Người đi theo quản sự tham quân tới quân doanh thị uy.","tinhCach":[{"text":"Khiếp sợ rồi bội phục trước thực lực của Vương Lâm.","chuong":"@c0517"}],"tabs":{"diem":[{"text":"Trong cơ thể có tới bốn cái phong ấn, thân phận và sức mạnh thật bị che giấu.","chuong":"@c0517"}],"kinhLich":[{"chuong":"@c0517","importance":"normal","tieuDe":"Phong ấn suýt vỡ vì ánh mắt Vương Lâm","text":"Đi cùng quản sự tham quân hiện thân thị uy ở quân doanh. Khi ánh mắt chạm mắt Vương Lâm, một trong bốn phong ấn của lão suýt bị phá vỡ khiến lão khiếp sợ; cuối cùng lão ôm quyền bội phục tu vi của Vương Lâm."}],"tuViMoc":[],"nhanMach":[{"ten":"Quản sự tham quân","tag":"dong-hanh","quanHe":"Người mà lão đi theo","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Thống lĩnh khiến phong ấn của lão suýt vỡ","ghiChu":""}],"tuiDo":{}},"nguon":["@c0517"]},{"id":"dong-phu-chi-linh-ton-long","name":"Động Phủ Chi Linh (động phủ tiên cấm)","cn":"","aliases":["Người đàn ông trung niên áo trắng (động phủ)","Động Phủ Chi Linh","Người đàn ông trung niên dưới cửa đá","#dong-phu-chi-linh-tien-cam"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"khong-ro","blurb":"Một tia linh hồn còn sót lại của động phủ tiên nhân nơi cuối đường Tôn Long, hiện thân thành người trung niên áo trắng tiên phong đạo cốt, canh giữ cửa và khảo nghiệm khách tới bằng ba đạo kiếm khí. (+) Linh thể canh giữ động phủ tiên cấm, hiện hình người đàn ông trung niên dưới cửa đá, chỉ trả lời trong khuôn khổ được phép. [CAN-SOAT-GOP]","vaiTro":"Người gác động phủ tiên nhân","tinhCach":[{"text":"Lạnh lùng, ra điều kiện sống chết dứt khoát: không vào được động phủ thì cả hai phải chết.","chuong":"@c0523"},{"text":"Trọng nghĩa cố nhân — vì nhận ra công pháp Huyết Quân mà ba lần tha Diêu Tích Tuyết.","chuong":"@c0523"}],"tabs":{"diem":[{"text":"Chỉ là tia linh hồn sót lại nhưng nắm quyền sinh sát qua cửa động phủ.","chuong":"@c0523"},{"text":"Hiện hình người đàn ông trung niên dưới cửa đá, canh giữ động phủ làm bằng tiên ngọc và tiên cấm","chuong":"@c0524"},{"text":"Khi hỏi chủ nhân là ai chỉ đáp chủ nhân là chủ nhân, chẳng là ai cả","chuong":"@c0524"}],"kinhLich":[{"text":"Hiện ra ở cửa đá hình mặt người nơi đài thứ mười hai, tuyên bố chỉ kẻ có lệnh bài mới được vào động phủ tiên nhân. Vì nhận ra Diêu Tích Tuyết thi triển công pháp của Huyết Quân năm xưa nên đã ba lần tha nàng; lần này phóng ba đạo kiếm khí khảo nghiệm, ai chống được mới đủ tư cách, bằng không phải chết.","bridge":true,"khoang":"@c0523"},{"chuong":"@c0524","importance":"normal","tieuDe":"Vấn Đáp Với Vương Lâm","text":"Xác nhận Vương Lâm và Diêu Tích Tuyết cùng tiếp ba đạo kiếm khí nên có tư cách vào, nhưng mọi thứ bên trong đã bị chủ nhân phong ấn trước khi rời đi. Linh thể giải thích ký hiệu vàng trên mười một đài bên ngoài là Hộ Phủ Thần Thông, rằng mở được một đạo phong ấn sẽ thu quyền hạn nhưng động phủ tự đóng cửa, người vào trước đều đã chết, và muốn rời đi phải mở được một đạo thảo ấn."}],"tuViMoc":[],"nhanMach":[{"ten":"Diêu Tích Tuyết","tag":"an-nhan","quanHe":"Ba lần tha mạng vì nàng mang truyền thừa công pháp Huyết Quân.","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khảo nghiệm bằng ba đạo kiếm khí; Vương Lâm lợi dụng để bày kế.","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người tiến vào động phủ được linh thể giải đáp","ghiChu":"Vương Lâm hỏi về tư cách, chủ nhân và điều kiện mở phong ấn."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0523","@c0524"]},{"id":"do-thong-hac-giap-quan","name":"Đô Thống Hắc Giáp quân","cn":"","aliases":["Người đàn ông áo giáp đen","Đô Thống Hắc Giáp quân","Người đàn ông vạm vỡ","Đại hán áo giáp đen"],"gioiTinh":"nam","theLuc":[{"ten":"Hắc Giáp quân","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ (chưa đại viên mãn)","trangThai":"song","blurb":"Người đàn ông vạm vỡ mặc áo giáp đen, Đô Thống chỉ huy quân doanh Hắc Giáp quân ngoài Cổ Yêu Thành, yêu lực ngang Anh Biến hậu kỳ.","vaiTro":"Chỉ huy mười vạn Yêu binh Hắc giác và bốn thống lĩnh; ra lệnh giết Vương Lâm rồi bị hắn áp chế.","tinhCach":[{"text":"Uy nghiêm, ra lệnh dứt khoát nhưng đổ mồ hôi và mất khí thế khi đối diện áp lực vượt cấp.","chuong":"@c0526"}],"tabs":{"diem":[{"text":"Yêu lực ngang Anh Biến hậu kỳ chưa đại viên mãn, có thể hóa thân Huyền Vũ trăm trượng đầy gai nhọn.","chuong":"@c0526"}],"kinhLich":[{"text":"Khi Vương Lâm về quân doanh, Đô Thống ra lệnh cho bốn thống lĩnh giết hắn, báo rằng Vương Lâm mất tích hơn một năm nên đã bị Yêu Tướng bãi miễn chức thống lĩnh. Bị áp khí thế, hắn lùi một bước liền mất thế, hóa thân Huyền Vũ trăm trượng chống cự trước Tịch Diệt Chỉ của Vương Lâm.","bridge":true,"khoang":"@c0526"},{"text":"Lộ tên là Tần Lâm, Đô thống mặc áo giáp đen. Khi giao chiến hắn dung thân vào bóng Huyền Vũ, hai mắt lộ tia sáng yêu dị, điều khiển Huyền Vũ quật đuôi đánh Vương Lâm, nhưng bị Tịch Diệt Chỉ phá tan, áo giáp vỡ vụn, phun tiên huyết quỳ gối. Hắn khai từng theo lệnh Yêu Tướng tìm người có cường độ thân thể cao nên đã chữa thương cho Thập Tam rồi dâng tặng. Được Vương Lâm tha vì có công cứu lẫn có tội, hắn ôm ngực rút về tẩm cung chữa thương sau khi tiết lộ Yêu Tướng bế quan, mọi truyền tống trận đều bị phong kín từ bên trong.","bridge":true,"khoang":"@c0527"},{"text":"Trấn giữ cửa thứ tư cung Yêu Tướng, lão già đầu bạc hóa con mãng xà yêu lực màu xám bạc đánh lén Vương Lâm, kinh ngạc nhận ra đối phương đã mạnh vượt bậc so với hơn một năm trước. Khi Vương Lâm thi triển Hóa Ma Chỉ tạo huyết long phá cửa thứ ba, con mãng xà va chạm huyết long rồi đổ sụp, lão già bỏ mạng tại chỗ.","bridge":true,"khoang":"@c0528"}],"tuViMoc":[{"chuong":"@c0526","canhGioi":"Anh Biến","text":"Yêu lực ngang Anh Biến hậu kỳ, chưa đạt đại viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Ra lệnh giết Vương Lâm trở về rồi bị hắn áp chế.","ghiChu":"@c0526"},{"ten":"Tư Mã Viêm","tag":"khac","quanHe":"Thuộc hạ cung kính hầu cận bên cạnh.","ghiChu":"@c0526"},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Cấp trên đã bãi miễn chức thống lĩnh của Vương Lâm.","ghiChu":"@c0526"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bại dưới tay Vương Lâm nhưng được tha"},{"ten":"Thập Tam","tag":"khac","quanHe":"Mang Thập Tam đi chữa thương rồi dâng cho Yêu Tướng"},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Tuân lệnh Yêu Tướng tìm người cường độ thân thể cao"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Từng ngang tu vi Vương Lâm và để ý tới hắn ở quân doanh, lần tái ngộ này bị hắn giết."}],"tuiDo":{}},"nguon":["@c0526","@c0527","@c0528"]},{"id":"de-nhat-do-thong","name":"Đệ nhất Đô Thống","cn":"","aliases":["Đô Thống thấp bé"],"gioiTinh":"nam","theLuc":[{"ten":"Thế lực yêu linh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến (suy đoán)","trangThai":"song","blurb":"Đệ nhất Đô Thống dưới trướng Yêu Tướng, dáng thấp bé mắt sáng như điện, trấn giữ cửa thứ hai cung điện.","vaiTro":"Cường giả trấn cửa của cung Yêu Tướng, đối thủ của Vương Lâm trong trận phá cung.","tinhCach":[{"text":"Trầm tĩnh, ra tay dứt khoát, đứng vững vị trí đệ nhất Đô Thống.","chuong":"@c0528"}],"tabs":{"diem":[{"text":"Tự xưng là đệ nhất Đô Thống dưới trướng Yêu Tướng.","chuong":"@c0528"},{"text":"Dáng thấp bé nhưng đôi mắt sáng quắc như điện.","chuong":"@c0528"}],"kinhLich":[{"text":"Khi Vương Lâm tung Hoàng Tuyền Chỉ phá cửa, đệ nhất Đô Thống dùng quả cầu trắng có vô số tia chớp đen ngưng giữa hai tay, chặn được chỉ pháp cách thân ba tấc. Tuy nhiên lực không đủ, hắn bị đẩy lùi xô sập cửa thứ nhất rồi phun tiên huyết bị bắn văng ra xa.","bridge":true,"khoang":"@c0528"}],"tuViMoc":[],"tuVi":"Tu vi cường giả trấn cửa cung Yêu Tướng, đủ sức chặn nhất thời Hoàng Tuyền Chỉ của Vương Lâm.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Chặn rồi bại dưới Hoàng Tuyền Chỉ của Vương Lâm."},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Chủ tướng","ghiChu":"Là đệ nhất Đô Thống dưới trướng Yêu Tướng."}],"tuiDo":{"phapBao":[{"ten":"Quả cầu trắng tia chớp đen","loai":"phap-bao","trangThai":"dang-co","moTa":"Quả cầu nhỏ bằng nắm tay màu trắng, bên trong vô số tia chớp đen ầm ầm, dùng chặn Hoàng Tuyền Chỉ.","nguon":"@c0528"}]}},"nguon":["@c0528"]},{"id":"nguoi-cao-lon-thap-bang-quyen-y","name":"Người cao lớn (Thập Băng Quyền ý)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thế lực yêu linh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Chưa rõ (cao thâm)","trangThai":"song","blurb":"Cao thủ trấn cửa thứ nhất cung Yêu Tướng, một quyền Thập Băng Quyền ý đủ ngang ngửa Hoàng Tuyền Chỉ của Vương Lâm.","vaiTro":"Đối thủ mạnh nhất Vương Lâm chạm trán khi phá cung Yêu Tướng, thân phận chưa lộ.","tinhCach":[{"text":"Trầm mặc, không nói lời thừa, ra tay là dồn toàn bộ chiến ý.","chuong":"@c0528"}],"tabs":{"diem":[{"text":"Bước ra từ cửa thứ nhất, im lặng không nói nửa lời rồi tung quyền.","chuong":"@c0528"},{"text":"Sở trường Thập Băng Quyền ý, sóng quyền lớp sau mạnh hơn lớp trước.","chuong":"@c0528"}],"kinhLich":[{"text":"Từ cửa thứ nhất, người cao lớn lặng lẽ bước ra tung một quyền Thập Băng Quyền ý đầy chiến ý nghênh đón Hoàng Tuyền Chỉ. Vụ va chạm tạo sóng chấn lan mười dặm, hủy hoại lầu các quanh vùng và hóa tro yêu binh, đẩy Vương Lâm lùi hơn ba trượng.","bridge":true,"khoang":"@c0528"}],"tuViMoc":[],"tuVi":"Tu vi cao thâm, một quyền ngang ngửa sát chiêu Hoàng Tuyền Chỉ của Vương Lâm.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Đối đầu Vương Lâm bằng Thập Băng Quyền ý ở cửa thứ nhất."},{"ten":"Yêu Tương đại nhân","tag":"cap-tren","quanHe":"Chủ tướng","ghiChu":"Trấn cửa cuối cùng bảo vệ Yêu Tướng đang bế quan."}],"tuiDo":{"phapBao":[],"congPhap":[]}},"nguon":["@c0528"]},{"id":"lao-gia-hac-bao-an-cong-ho-bao","name":"Lão già hắc bào (ân công của Hổ Bào)","aliases":["Lão già hắc y","Ân công của Hổ Bào"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Lão già toàn thân hắc y lạnh lùng, thuộc hạ phụng sự chủ nhân trong bộ giáp ở hắc tháp; cứu Hổ Bào vì hắn có Luyện Hồn Thuật kỳ dị và định biến hắn thành Yêu Vệ thí nghiệm.","vaiTro":"Thế lực cổ xưa bí ẩn đứng sau, phụng sự chủ nhân trong hắc tháp.","tinhCach":[{"text":"Lạnh lùng, tính toán, coi trọng người quyết đoán và dứt bỏ.","chuong":"@c0530"}],"tabs":{"diem":[{"text":"Cứu Hổ Bào chỉ vì hắn sở hữu Luyện Hồn Thuật mà lão chưa từng gặp.","chuong":"@c0530"}],"kinhLich":[{"text":"Lão già hắc y giám sát Hổ Bào luyện hóa linh hồn tại chiến trường cổ, tiết lộ chủ tử cũ của Hổ Bào đã xuất hiện ở Cổ Yêu thành. Sau đó lão vào hắc tháp mười tầng, quỳ trên tầng cao nhất trước bộ áo giáp cổ của chủ nhân, báo tin Yêu Đế Thiên Yêu quận ngàn năm trước bị ngừng ở bước đột phá cuối và nh���n tin tức truyền vào mắt khiến lão đổ mồ hôi lạnh.","bridge":true,"khoang":"@c0530"}],"tuViMoc":[],"nhanMach":[{"ten":"Hổ Bào","tag":"khac","quanHe":"Đối tượng được cứu và thí nghiệm","ghiChu":"Cứu khỏi hắc lao, truyền Diệt Thế Áp Nguyên Công, định luyện thành Yêu Vệ."},{"ten":"Chủ nhân (bộ áo giáp trong hắc tháp)","tag":"cap-tren","quanHe":"Chủ nhân phụng sự","ghiChu":"Thực thể cổ xưa trong bộ giáp ở hắc tháp, truyền lệnh và khẩu quyết cho lão."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0530"]},{"id":"chu-nhan-bo-giap-hac-thap","name":"Chủ nhân (bộ áo giáp trong hắc tháp)","aliases":["Chủ nhân","Bộ giáp đen mười tầng","#chu-nhan-ao-giap-hac-thap-556"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Thực thể cổ xưa ngụ trong bộ áo giáp đen đặt ở tầng cao nhất hắc tháp mười tầng, mũ giáp lóe u quang như ánh mắt, vừa thức tỉnh chưa lâu và truyền lệnh cho lão già hắc y. (+) Tồn tại bị thương nặng ngụ trong chiếc áo giáp ở tầng cao nhất hắc tháp trên chiến trường viễn cổ Thiên Yêu quận, đợi mười năm để đoạt nguyên khí tu sĩ Vấn Đỉnh. [CAN-SOAT-GOP]","vaiTro":"Tuyến đối kháng cổ xưa tiềm tàng, đang theo dõi Yêu Đế Thiên Yêu quận.","tinhCach":[{"text":"Uy nghiêm, bí ẩn, khiến trời đất rung động khi hiển uy.","chuong":"@c0530"}],"tabs":{"diem":[{"text":"Mũ giáp lóe hai đạo u quang như ánh mắt, trời đất rung lên như có tiên linh hàng lâm.","chuong":"@c0530"},{"text":"Bị thương quá nặng nên không thể rút nguyên khí ở cự ly xa, phải phá bỏ một cánh tay để hành động.","chuong":"@c0556"}],"kinhLich":[{"chuong":"@c0530","importance":"normal","tieuDe":"Thức tỉnh, truyền lệnh từ trong bộ giáp","text":"Ngụ trong bộ áo giáp cổ ở tầng cao nhất hắc tháp, chủ nhân vừa thức tỉnh chưa lâu, dùng u quang trong mũ giáp truyền tin tức và mệnh lệnh cho lão già hắc y. Khẩu quyết do chủ nhân truyền xuống có thể ngưng tụ toàn bộ tuổi thọ và tiềm lực trong một canh giờ rồi bùng nổ biến tu sĩ thành Yêu Vệ."},{"text":"Nhận biết Vương Lâm vừa thành Vấn Đỉnh, nguyên khí chưa hoàn toàn dung hợp, hắn mở một vòng xoáy đen khổng lồ, quét thần thức tàn bạo khắp chiến trường, dung hợp vô số khúc xương đen thành bộ xương cánh tay, kết hợp hộ uyển lửa ma rồi phái đi hút nguyên khí. Hắn ra lệnh “Đi đi! Mang nguyên khí về đây!” và phá bỏ một cánh tay áo giáp; u quang sau đó tắt hẳn.","bridge":true,"khoang":"@c0556"},{"text":"Đạo thần thức trong hắc tháp phóng tiếng hừ lạnh tức giận đánh vào tâm thần Vương Lâm, rồi liên tục phóng sát khí công kích vì lo hắn điên cuồng tìm tới làm hỏng áo giáp. Khi thấy cơ thể vốn đã sớm chết, nguyên thần đáng lẽ phải tan vỡ của Vương Lâm vẫn sống nhờ chất dịch Thăng Tiên Quả kích thích, đạo thần thức sinh lòng lo sợ và hối tiếc rằng sớm biết thế này thì không nên đi hấp thu hắn.","bridge":true,"khoang":"@c0558"},{"text":"Luồng thần thức trong hắc tháp ở chiến trường viễn cổ phẫn nộ rồi bắt đầu hối hận khi nhận ra Vương Lâm nhờ hấp thu nhiều Thăng Tiên Quả nên không sợ chết, dù bị công kích gần chết vẫn không chết mà chiến ý càng mạnh, lại có thần thông hấp thu sinh cơ vạn vật để tự khôi phục. Hắn lo sợ Vương Lâm chắc chắn sẽ có ngày tiến đến chỗ này, sinh ý hối hận chưa từng có.","bridge":true,"khoang":"@c0559"},{"chuong":"@c0562","importance":"normal","tieuDe":"Lão giả dưới hắc tháp","text":"Một lão giả mặc áo giáp màu đen đứng dưới tòa hắc tháp cao, lặng lẽ nhìn về phía Vương Lâm. Từ hắc tháp tỏa ra ma khí chân chính nồng đậm khác hẳn khí của người tu ma; Vương Lâm nhận định người này là tuyệt đại cường giả."},{"text":"Lão giả hắc giáp bước ra từ dưới hắc tháp, khí tức biểu hiện Vấn Đỉnh hậu kỳ nhờ bộ Sáo Tiêu giáp trên người (tu vi chân thật không cao bằng). Đánh giá đạo Hóa Hoàng Tuyền của Vương Lâm chỉ là phỉ hình uy lực không đủ, nhưng kinh hãi đạo kiếm khí của Lăng Thiên Hậu, phán người phát ra ắt đạt toái niết tam cảnh. Vâng lệnh thần niệm trong tháp bắt sống Vương Lâm, lão lần lượt thi triển Phong, Lôi rồi tổ hợp Phong–Vũ–Lôi–Điện do Sáo Tiêu giáp ban xuống đại địa.","bridge":true,"khoang":"@c0563"},{"text":"Hắc giáp lão giả tuyên bố Phong Vũ Lôi Điện chỉ là thần thông yếu nhất, đạo thật trên khải giáp là Ma đạo. Hắn vuốt ngực khải giáp ngưng hóa ma liêm đao tỏa ma diễm, lại nhờ ma hồn phân thể một sừng từ mi tâm chui ra dung nhập khiến đao sống lại bắn về Vương Lâm. Bị kiếm khí Lăng Thiên Hậu đánh tan ma đao, hắn phun máu, định truy kích nhưng phải đổi hướng cứu hắc tháp khi tia kim mang lao tới. Một cỗ ma khí nồng đậm từ hắc tháp nhập vào hắn: thân phồng lên thành người khổng lồ cao ba trượng, bạch giáp biến lớn, một hắc giác mọc từ trán, gầm rít đuổi theo Vương Lâm gọi hắn tiểu tạp chủng.","bridge":true,"khoang":"@c0564"}],"tuViMoc":[],"nhanMach":[{"ten":"Lão già hắc bào (ân công của Hổ Bào)","tag":"khac","quanHe":"Thuộc hạ phụng sự","ghiChu":"Lão già hắc y nhận lệnh và khẩu quyết luyện Yêu Vệ từ chủ nhân."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Mục tiêu đoạt nguyên khí","ghiChu":"Phái cánh tay xương đen qua vòng xoáy đi đoạt nguyên khí của Vương Lâm sau khi hắn vừa tiến Vấn Đỉnh."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Từng hấp thu Vương Lâm, nay bị hắn điên cuồng truy đuổi","ghiChu":"Tiếng hừ lạnh từ hắc tháp khiến Vương Lâm phun máu rồi nổi điên; đạo thần thức hối tiếc đã đi hấp thu hắn. @c0558"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Từng nhiều lần công kích Vương Lâm, nay hối hận khi thấy hắn không chết mà ngày càng mạnh","ghiChu":"@c0559"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Đứng dưới hắc tháp nhìn về phía Vương Lâm sau khi hắn giết Hổ Bào.","ghiChu":"@c0562"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Giao chiến với Vương Lâm theo lệnh thần niệm trong hắc tháp, muốn bắt sống hắn.","ghiChu":"@c0563"},{"ten":"Thực thể trong tháp đen (chiến trường viễn cổ)","tag":"cap-tren","quanHe":"Vâng lệnh thần niệm khổng lồ ẩn trong hắc tháp ra tay bắt sống Vương Lâm.","ghiChu":"@c0563"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ địch hắn truy giết","ghiChu":"Bị kiếm khí Lăng Thiên Hậu trong tay Vương Lâm đánh thua, hắc tháp cũng bị đánh nứt. @c0564"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]},"tuVi":"Tu vi không rõ; là tồn tại bị thương nặng có thể quét thần thức tàn bạo, điều khiển xương đen và mở vòng xoáy không gian."},"nguon":["@c0530","@c0556","@c0558","@c0559","@c0562","@c0563","@c0564"]},{"id":"nhi-cau","name":"Nhị Cẩu","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Yêu binh trẻ cơ trí dưới quyền đội trưởng canh truyền tống trận thứ mười bốn của Thiên Yêu thành.","vaiTro":"Yêu binh tân binh","tinhCach":[{"text":"Cơ trí, biết lấy lòng cấp trên","chuong":"@c0532"}],"tabs":{"diem":[],"kinhLich":[{"text":"Bóp vai cho đội trưởng Yêu binh rồi hỏi vì sao truyền tống trận thứ mười bốn dạo này mở liên tục, mở đầu cho lời kể về bối cảnh cuộc chiến Yêu tướng.","bridge":true,"khoang":"@c0532"}],"tuViMoc":[],"nhanMach":[{"ten":"Đội trưởng Yêu binh","tag":"cap-tren","quanHe":"Thuộc hạ dưới quyền đội trưởng canh truyền tống trận","ghiChu":""}],"tuiDo":{}},"nguon":["@c0532"]},{"id":"doi-truong-yeu-binh","name":"Đội trưởng Yêu binh (truyền tống trận 14)","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Chỉ huy đội Yêu binh trấn thủ truyền tống trận thứ mười bốn, giáp khắc nhiều hoa văn hơn binh sĩ thường.","vaiTro":"Đội trưởng Yêu binh","tinhCach":[{"text":"Am hiểu nội tình, hay khoe hiểu biết với tân binh","chuong":"@c0532"}],"tabs":{"diem":[],"kinhLich":[{"text":"Kể cho đám tân binh nghe lai lịch cuộc chiến Yêu tướng: cứ ba trăm năm một lần do Đế Quân quan sát, lần này chọn hai vị soái mới thay hai phó soái tử trận trong đại chiến với Hỏa Yêu quận hai trăm năm trước. Khi truyền tống tr���n sáng lên, lập tức cảnh giác chỉnh đốn đội ngũ nghênh đón Mạc Lệ Hải và Vương Lâm.","bridge":true,"khoang":"@c0532"}],"tuViMoc":[],"nhanMach":[{"ten":"Nhị Cẩu","tag":"cap-tren","quanHe":"Cấp trên của Nhị Cẩu","ghiChu":""}],"tuiDo":{}},"nguon":["@c0532"]},{"id":"mac-phi-yeu-tuong","name":"Mặc Phi","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Phó soái cánh quân phải của đại quân yêu binh quận Thiên Yêu, mặc áo giáp cưỡi yêu thú giống Lân; mục tiêu danh nghĩa Vương Lâm tuyên bố bắt giết. (+) Yêu tướng đại nhân trấn thủ biên giới giáp Hỏa Yêu quận, được đánh giá đủ sức vào vòng ba cuộc chiến Yêu tướng. [CAN-SOAT-GOP]","vaiTro":"Yêu tướng trấn biên","tinhCach":[],"tabs":{"diem":[{"text":"Phó soái cánh quân phải, cưỡi yêu thú giống Lân","chuong":"@c0571"}],"kinhLich":[{"text":"Được đội trưởng Yêu binh nhắc tới như một trong những Yêu tướng mạnh nhất, trấn thủ biên giới Hỏa Yêu quận, đủ tư cách lọt vào vòng ba cuộc chiến tuyển soái.","bridge":true,"khoang":"@c0532"},{"text":"Tại Vũ Thành, Yêu Tương Mặc Phi của Hỏa Yêu Quận ở trong một biệt viện cùng hai đệ tử đeo đại kiếm; gương mặt anh tuấn ẩn cương nghị, tướng mạo giống y hệt thanh niên tóc đen sống sót trong thế giới huyết sắc của Hồng Lao.","bridge":true,"khoang":"@c0537"},{"chuong":"@c0542","importance":"normal","tieuDe":"Đệ nhất nhân Yêu Tướng","text":"Đánh bại Mạc Lệ Hải bằng Chuyển Luân thuật, làm Yêu Hải Bách Lãng quay ngược trở về. Sau khi thành Yêu Tướng đã đến Long Đàm Cổ Yêu Điện tĩnh tu ba năm; suốt ba năm chưa ai bu��c hắn phải dùng thần thông thứ hai ngoài Chuyển Luân thuật."},{"text":"Mặc Phi được dân chúng dự đoán chắc chắn giành vị trí thứ nhất trong trận chiến Yêu Tướng. Đã thắng Mạc Lệ Hải ở trận trước. Tại trường đấu, hắn lạnh lùng liếc nhìn Vương Lâm khi Ngao Địch ra khiêu chiến.","bridge":true,"khoang":"@c0543"},{"text":"Yêu Tướng đeo mặt nạ dữ tợn, thong dong gõ sáu tiếng liên tục bằng quyền cách không không bị thương, được hoan hô vang dội; rồi ép thêm tiếng bảy (áo giáp nát) và tiếng tám (dùng tinh thể như gương đỡ phản lực, lùi hơn trăm trượng). Mặt nạ vỡ lộ khuôn mặt anh tuấn giống hệt nam tử tóc đen ở chỗ sâu nhất Hồng Lao. Cùng người trợ giúp tổng cộng mười một tiếng, áp đảo các Yêu Tướng.","bridge":true,"khoang":"@c0546"},{"text":"Mặc Phi hỏi thầm có phải Vương Lâm cũng cảm nhận được luồng khí tức trong Yêu Cổ; khi tiếng trống truyền niệm khiến cả trường rơi lệ cộng hưởng, riêng Mặc Phi vẫn bình thản hờ hững, hoàn toàn không bị lay động.","bridge":true,"khoang":"@c0548"},{"text":"Dẫn cánh quân phải tiến công thành Tùng Đào, bị Vương Lâm tuyên bố phụng lệnh Yêu Đế bắt giết. Tịch Diệt chỉ tan vỡ ngay trước hắn nhưng đó chỉ là hư chiêu; Vương Lâm chuyển sang giết Hợi Trư hộ vệ phía sau, hắn sống sót.","bridge":true,"khoang":"@c0571"}],"tuViMoc":[],"nhanMach":[{"ten":"Thanh niên tóc đen (thế giới huyết sắc)","tag":"khac","quanHe":"Tướng mạo giống y hệt nhau, ngụ ý mối liên hệ phân thân/thế thân chưa giải thích","ghiChu":"@c0537"},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Đã đánh bại trong tỉ thí Yêu Tướng","ghiChu":"@c0542"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Lạnh lùng quan sát Vương Lâm tại trường đấu","ghiChu":"@c0543"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Vương Lâm nhận ra Mặc Phi giống nam tử tóc đen ở Hồng Lao","ghiChu":"@c0546"},{"ten":"Tu sĩ mặc thanh sam","tag":"dong-minh","quanHe":"Người trợ giúp gõ thêm ba tiếng cho Mặc Phi","ghiChu":"@c0546"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm tuyên bố bắt giết để đoạt thanh thế"},{"ten":"Hợi Trư","tag":"dong-minh","quanHe":"Người trung niên hộ vệ phía sau"}],"tuiDo":{}},"nguon":["@c0532","@c0537","@c0542","@c0543","@c0546","@c0548","@c0571"],"aliases":["#mac-phi-pho-soai-thien-yeu"]},{"id":"co-gai-mu-thuyen-hoa-thien-yeu","name":"Cô gái mù trên thuyền hoa","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Yêu linh tộc","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Thiếu nữ Yêu linh bị mù, gảy đàn bi thương trên thuyền hoa ở Hồng thành, cô độc giữa đời và cảm nhận được bóng Vương Lâm tan vào đêm.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Cô độc, thanh khiết như đóa sen trong bùn không nhiễm bụi","chuong":"@c0534"}],"tabs":{"diem":[{"text":"Bị mù, trước mắt chỉ là một khoảng đen kịt bất kể ngày đêm","chuong":"@c0534"},{"text":"Có linh tính cảm nhận được hình bóng cô độc của Vương Lâm trong bóng tối","chuong":"@c0534"}],"kinhLich":[{"text":"Gảy đàn bi thương trên thuyền hoa giữa đám thanh niên uống rượu; khi thuyền đi xa, nàng như có linh tính khẽ xoay nhìn về con đường ven sông tối đen, mơ hồ thấy một hình bóng cô độc đang tan biến, rồi gảy thêm một tiếng đàn — lộ ra nàng bị mù, tiếng đàn vang nhưng không ai thật sự lắng nghe.","bridge":true,"khoang":"@c0534"}],"tuViMoc":[],"tuVi":"","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người dưng gặp thoáng qua","ghiChu":"Vương Lâm đi ngang nghe nàng đánh đàn, chạnh nhớ Uyển Nhi; nàng cảm nhận được bóng hắn tan vào đêm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0534"]},{"id":"minh-huyen","name":"Minh Huyên","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Nữ tử đánh đàn trên hoa thuyền ở Hồng thành; tiếng đàn bi thương của nàng khiến Vương Lâm cảm ngộ về đạo, nhưng nàng lại bị một khách nhân giọng bình thản khống chế.","vaiTro":"Nữ tử đánh đàn hoa thuyền","tinhCach":[{"text":"U buồn, gửi nỗi bi thương vào tiếng đàn","chuong":"@c0535"}],"tabs":{"diem":[{"text":"Tiếng đàn bi thương xuyên cả phong ấn trí nhớ, khiến người nghe cảm động","chuong":"@c0535"},{"text":"Bị một thế lực bí ẩn khống chế, không thể chống cự mệnh lệnh của khách nhân","chuong":"@c0535"}],"kinhLich":[{"text":"Ngày ngày đánh đàn trên hoa thuyền qua lại bờ sông Hồng thành, Minh Huyên không hay có người chăm chú nghe suốt ba ngày; tiếng đàn càng lúc càng bi thương. Khi hoa thuyền xa dần, nàng quay đầu nhìn theo bóng nam tử rời đi, rồi bị một khách nhân giọng bình thản gọi đúng tên và lạnh lùng buộc đổi bài khác vì bài vừa rồi quá buồn; nàng ngọc thủ run rẩy, không thể cự tuyệt cái giọng đại biểu cho trời cao đó.","bridge":true,"khoang":"@c0535"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người chăm chú nghe tiếng đàn của nàng ba ngày; nàng quay đầu nhìn theo khi hắn rời đi","ghiChu":"@c0535"},{"ten":"Khách nhân (bên Minh Huyên)","tag":"doi-thu","quanHe":"Kẻ giọng bình thản khống chế nàng, buộc nàng đổi bài đàn; nàng không thể chống cự","ghiChu":"@c0535"}],"tuiDo":{}},"nguon":["@c0535"]},{"id":"khach-nhan-minh-huyen","name":"Khách nhân (bên Minh Huyên)","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"khong-ro","trangThai":"khong-ro","blurb":"Kẻ giọng nói bình thản lạnh lùng bên Minh Huyên, ra lệnh nàng đổi bài đàn mà nàng không thể chống cự; chưa lộ tên lẫn diện mạo.","vaiTro":"Thế lực bí ẩn khống chế Minh Huyên","tinhCach":[{"text":"Lạnh lùng, giọng nói uy áp như đại biểu trời cao","chuong":"@c0535"}],"tabs":{"diem":[{"text":"Giọng nói khiến Minh Huyên không thể cự tuyệt, như đại biểu cho trời cao","chuong":"@c0535"}],"kinhLich":[{"text":"Khi Vương Lâm rời đi, một giọng nói bình thản bên cạnh Minh Huyên gọi đúng tên nàng và lạnh lùng bảo đổi bài khác vì b��i vừa rồi quá buồn, khiến tiếng đàn dừng lại.","bridge":true,"khoang":"@c0535"}],"tuViMoc":[],"nhanMach":[{"ten":"Minh Huyên","tag":"khac","quanHe":"Khống chế Minh Huyên, ra lệnh nàng đổi bài đàn","ghiChu":"@c0535"}],"tuiDo":{}},"nguon":["@c0535"]},{"id":"mac-le-hai","name":"Yêu Tương đại nhân","tabs":{"kinhLich":[{"text":"Đang tu vi Anh Biến hậu kỳ đại viên mãn, dẫn Vương Lâm tới Hồng lao ở Hồng thành, trả giá ba tầng đầu công pháp Thập Băng Quyền Ý cho nam tử họ Hứa để đổi một suất tu luyện, giao Vương Lâm cho Hứa rồi rời đi với lời chúc tu luyện thành công.","bridge":true,"khoang":"@c0536"},{"text":"Mạc Lệ Hải vận yêu lực che giấu khí tức Vương Lâm khỏi Đế Kiếm, đưa hắn xuống động bế quan dưới giả sơn. Tiết lộ quy chế đại hội Yêu Tướng cho phép người thất bại đề cử người ngoài thay thế, hẹn tiến cử Vương Lâm; rồi dẫn hắn viếng phó soái Huyền Thành.","bridge":true,"khoang":"@c0537"},{"text":"Dẫn Vương Lâm vào soái phủ bái kiến phó soái Huyền Thành để tranh chức phó soái. Khai nắm chắc bốn phần, thêm Vương Lâm thì lên chín phần. Sau khi chứng kiến uy lực Vương Lâm trấn áp phó soái, lần đầu xem hắn là người vượt đẳng cấp, chân thành ôm quyền nhờ trợ giúp trong đại hội Yêu Tướng và mời rượu quý đã chôn hơn năm trăm năm.","bridge":true,"khoang":"@c0538"},{"text":"Chờ Vương Lâm xuất quan ba ngày với sắc mặt tái nhợt, lo lắng vì ngày Yêu Tướng tranh đoạt cận kề. Báo tin mình đã bại trận trước Mặc Phi: dùng Thập Băng Quyền Ý bị đỡ hết, Yêu Hải Bách Lãng bị Chuyển Luân thuật làm quay ngược về.","bridge":true,"khoang":"@c0542"},{"text":"Đêm trước trận chiến Yêu Tướng, Mạc Lệ Hải tiết lộ với Vương Lâm rằng ngoài Thập Băng Quyền Ý và Yêu Hải Bách Lãng, hắn còn tuyệt chiêu Yêu Nhiên do Đế Quân đích thân truyền. Vì đã thua Mặc Phi nên theo giao ước hắn không được tham chiến hôm sau, việc đoạt ngôi Phó Soái hoàn toàn trông cậy vào Vương Lâm. Hắn vái sâu từ biệt, bóng dáng hiu quạnh rời đi.","bridge":true,"khoang":"@c0543"},{"text":"Mỗi ngày đến Đế Đô quan sát các trận tranh đoạt Yêu Tướng, dùng thần thông ghi lại những đối thủ có thể uy hiếp Vương Lâm rồi đưa về cho hắn xem, đặt toàn bộ hy vọng lên Vương Lâm.","bridge":true,"khoang":"@c0545"},{"text":"Khi nghe luật gõ Chiến Yêu Cổ, Mạc Lệ Hải rúng động, sắc mặt tái nhợt; sau khuyên Vương Lâm chịu thua vòng này vì cho rằng khó vượt nổi thành tích Mặc Phi.","bridge":true,"khoang":"@c0546"},{"text":"Khi tiếng trống truyền niệm của Vương Lâm lan khắp Thiên Yêu thành, Mạc Lệ Hải lộ hồi ức, chìm vào cộng hưởng tâm linh cùng cả khán đài.","bridge":true,"khoang":"@c0548"},{"chuong":"@c0551","importance":"minor","tieuDe":"Yên tâm về vị trí Yêu soái","text":"Trong đám Yêu tướng, nhìn bóng Vương Lâm mà biết mình không còn phải thấp thỏm chờ trở thành Yêu soái."},{"chuong":"@c0527","importance":"normal","tieuDe":"Bế quan, thu nhận Thập Tam","text":"Chủ nhân cung điện trung tâm Cổ Yêu Thành. Nhiều năm trước hạ lệnh tìm người có cường độ thân thể cao và đã nhận Thập Tam. Nửa năm trước bắt đầu bế quan, mọi truyền tống trận dẫn vào cung đều bị phong kín từ bên trong, trở thành mục tiêu Vương Lâm quyết xông cung."},{"text":"Yêu tướng thống lĩnh tung tuyệt chiêu Yêu Hải Bách Lãng giao đấu Vương Lâm nhưng bị chưởng ấn hư ảo uy hiếp, không dám đánh cuộc nên nhận thua. Hắn lộ tên thật Mạc Lệ Hải, khai luyện pháp bảo cần thân thể mười tám người, phong Vương Lâm làm Tả dực đệ nhất phó tướng và thả Thập Tam.","bridge":true,"khoang":"@c0529"},{"bridge":true,"khoang":"@c0529","text":"Sau khi Vương Lâm rời đi, Mạc Lệ Hải thừa nhận với năm lão giả rằng chưởng ấn kia chín phần mười là hư trương thanh thế, song không dám liều mạng; nhắc lại bí ẩn tu vi Vương Lâm tăng vọt và việc mất tích cùng Diêu thống lĩnh năm trước."}],"nhanMach":[{"ten":"Nam tử họ Hứa","tag":"dong-minh","quanHe":"Người phụ trách Hồng lao mà Mạc Lệ Hải trả ba tầng Thập Băng Quyền Ý để gửi Vương Lâm vào tu luyện.","ghiChu":"@c0536."},{"ten":"Phó soái Huyền Thành","tag":"dong-minh","quanHe":"Đưa Vương Lâm tới phủ phó soái Huyền Thành, được cho mời vào đình viện","ghiChu":"@c0537"},{"ten":"Phó soái Huyền Thành","tag":"doi-thu","quanHe":"Đối thủ tranh chức phó soái","ghiChu":"Mạc Lệ Hải dẫn Vương Lâm tới bái kiến để tranh chức phó soái Thiên Yêu Thành."},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Đối thủ Yêu Tướng đã đánh bại Mạc Lệ Hải bằng Chuyển Luân thuật","ghiChu":"@c0542"},{"ten":"Mặc Phi","tag":"doi-thu","quanHe":"Thua trận trước Mặc Phi nên mất tư cách tham chiến tranh Phó Soái","ghiChu":"@c0543"},{"ten":"Thạch Tiêu","tag":"doi-thu","quanHe":"Ba trăm năm trước từng để lại vết sẹo trên mặt Thạch Tiêu","ghiChu":"@c0543"},{"ten":"Yêu Đế","tag":"khac","quanHe":"Được Đế Quân đích thân truyền thần thông Yêu Nhiên khi thành Yêu Tướng","ghiChu":"@c0543"},{"ten":"Thống lĩnh (Nghiêu Lĩnh, Cổ Yêu thành)","tag":"khac","quanHe":"Cấp dưới bất mãn","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối tượng Vương Lâm xông cung đòi người"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ rồi thu nhận làm phó tướng dưới trướng","ghiChu":"Bị chưởng ấn hư ảo của Vương Lâm uy hiếp, đành mời làm Tả dực đệ nhất phó tướng."},{"ten":"Yêu Đế","tag":"cap-tren","quanHe":"Quân chủ Thiên Yêu quận","ghiChu":"Mạc Lệ Hải định tiến cử Vương Lâm lên Yêu Đế nếu lọt top ba yêu tướng."}],"tuiDo":{},"tuViMoc":[],"diem":[{"text":"Tự kiểm tra rồi phá lệ ban chức Nghiêu Lĩnh chính cho người ngoài đến, làm thống lĩnh cũ bất mãn.","chuong":"@c0513"}]},"nguon":["@c0536","@c0537","@c0538","@c0542","@c0543","@c0545","@c0546","@c0548","@c0551","@c0513","@c0527","@c0529"],"aliases":["Yêu Tướng","Mạc Lệ Hải","Yêu Tương đại nhân"],"blurb":"Nhân vật quyền cao trong quân yêu Cổ Yêu thành, tự kiểm tra rồi phá lệ ban chức thống lĩnh cho một người ngoài đến."},{"id":"nam-tu-ho-hua-hong-lao","name":"Nam tử họ Hứa","aliases":["Nam tử áo xám (Hồng lao)","Hứa (Hồng lao)","Họ Hứa (Hồng Lao)"],"gioiTinh":"nam","theLuc":[{"ten":"Hồng lao","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Một trong mười người phụ trách Hồng lao, dáng to béo sắc mặt âm trầm, tu luyện sát lục yêu đạo dùng tâm hóa yêu.","vaiTro":"Người tiếp nhận và chỉ điểm sát tâm cho Vương Lâm trong Hồng lao","tinhCach":[{"text":"Âm trầm, ẩn nhẫn; sát tâm sâu kín như kiếm chưa rời vỏ — không tỏa sát khí mà khiến đối phương rúng động nguyên thần.","chuong":"@c0536"}],"tabs":{"diem":[{"text":"Sống ở Hồng lao mấy trăm năm, là người duy nhất trong mười người nơi đây tu sát lục yêu đạo dùng tâm hóa yêu.","chuong":"@c0536"},{"text":"Bị hạn chế không rời được Hồng lao, ôm mối thù muốn giết yêu tướng Thạch Tiễn.","chuong":"@c0536"}],"kinhLich":[{"text":"Ra đón Mạc Lệ Hải và Vương Lâm với tu vi Anh Biến hậu kỳ đại viên mãn, nhận ba tầng đầu Thập Băng Quyền Ý làm giá, dẫn Vương Lâm xuống lồng giam dưới lòng đất và cho một tháng tu luyện.","bridge":true,"khoang":"@c0536"},{"chuong":"@c0536","importance":"normal","tieuDe":"Chỉ điểm sát tâm, giao ước Thạch Tiễn","text":"Phô bày sát tâm khiến Vương Lâm lông tóc dựng ngược, ra điều kiện đưa Vương Lâm tới nơi cảm nh���n sát lục chân chính để đổi việc Vương Lâm âm thầm giết yêu tướng Thạch Tiễn; tiết lộ bí mật thế giới máu tầng đáy nuôi yêu kiếm của yêu đế và dặn không được tiết lộ kể cả với Mạc Lệ Hải."},{"text":"Đợi Vương Lâm tại bậc thang cao nhất Hồng Lao, than “lớn chuyện rồi”, dẫn hắn theo đường khác trốn qua một khe nứt tường nhà dân Hồng Thành, dặn đừng quên giao hẹn; hối tiếc đã đưa người dẫn Đế Kiếm tới.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[{"chuong":"@c0536","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tu vi ngang Mạc Lệ Hải khi ra mặt tại Hồng lao.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người hắn tiếp nhận và chỉ điểm sát tâm, ra điều kiện nhờ giết Thạch Tiễn.","ghiChu":"@c0536."},{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Người gửi Vương Lâm vào Hồng lao, trả ba tầng Thập Băng Quyền Ý.","ghiChu":"@c0536."},{"ten":"Thạch Tiễn","tag":"doi-thu","quanHe":"Yêu tướng hắn thù hận, muốn nhờ Vương Lâm âm thầm giết.","ghiChu":"@c0536."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Giúp Vương Lâm trốn khỏi Hồng Lao; có giao hẹn chưa tiết lộ","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0536","@c0537"]},{"id":"thanh-suong","name":"Thanh Sương","gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Danh tính thần bí tự xưng trong thanh âm mà Vương Lâm nghe được khi đắc kim phù ấn tại Yêu Linh chi địa.","vaiTro":"Nhân vật bí ẩn","tinhCach":[],"tabs":{"diem":[{"text":"Thanh âm thần bí vọng ra giữa cảnh huyễn, chỉ tự xưng “Ta là Thanh Sương” mà chưa lộ thân phận.","chuong":"@c0521"}],"kinhLich":[{"text":"Khi Vương Lâm rơi vào trạng thái huyễn hoặc lúc đắc kim phù ấn, hắn nghe được tiếng nam nữ thì thào, trong đó vọng ra câu tự xưng “Ta là Thanh Sương”. Danh tính này gắn với lực lượng thần bí ban kim phù ấn ở Yêu Linh chi địa, có thể liên quan tới động phủ Tiên đế.","bridge":true,"khoang":"@c0521"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người nghe được thanh âm tự xưng của Thanh Sương khi đắc kim phù ấn","ghiChu":""}],"tuiDo":{}},"nguon":["@c0521"]},{"id":"thanh-nien-toc-den-the-gioi-huyet-sac","name":"Thanh niên tóc đen (thế giới huyết sắc)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Tu sĩ duy nhất trong thế giới máu của Hồng Lao chống được sát lục khí của Vương Lâm, thân không tan; tướng mạo giống hệt Yêu Tương Mặc Phi.","vaiTro":"Người sống sót bí ẩn trong thế giới huyết sắc","tinhCach":[{"text":"Kiên cường nhưng cũng có lúc yếu ớt kêu cứu","chuong":"@c0537"}],"tabs":{"diem":[{"text":"Là tu sĩ duy nhất trong thế giới huyết sắc không bị sát lục khí của Vương Lâm xé tan, ngoài thân có một tầng huyết sát vụ","chuong":"@c0537"},{"text":"Tướng mạo giống y hệt Yêu Tương Mặc Phi của Hỏa Yêu Quận — ngụ ý mối liên hệ phân thân chưa rõ","chuong":"@c0537"}],"kinhLich":[{"text":"Khi sát lục khí của Vương Lâm bạo phát xé tan mọi tu sĩ trong các hồ máu, chỉ mình hắn chống được, thân không tan. Khi Đế Kiếm phá hư không đuổi theo Vương Lâm, hắn yếu ớt kêu “Cứu ta với” nhưng bị bỏ mặc.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Mặc Phi","tag":"khac","quanHe":"Tướng mạo giống y hệt nhau, ngụ ý mối liên hệ phân thân/thế thân chưa giải thích","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0537"]},{"id":"thach-tieu-yeu-tuong","name":"Thạch Tiêu","cn":"","aliases":["Người thanh niên tà dị","Áo giáp thanh sắc","#thach-tien","#thach-tieu"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Kỵ sĩ tóc tím mặc áo giáp thanh sắc, mặt anh tuấn yêu dị với vết sẹo má phải khiến vẻ hung ác; thần thông Lục Chỉ Kiếm Quyết uy lực khó lường, là kình địch của Mạc Lệ Hải trong cuộc chiến Yêu tướng. (+) Yêu Tướng ở trong phủ Yêu Soái, kinh hãi khi Đế Kiếm tự bay ra trận nhãn. [CAN-SOAT-GOP]","vaiTro":"Yêu Tướng Thiên Yêu Quận","tinhCach":[],"tabs":{"diem":[{"text":"Kinh hãi khi Đế Kiếm tự rời trận nhãn, gọi việc này có quỷ dị","chuong":"@c0537"},{"text":"Tóc dài màu tím, vết sẹo má phải khiến gương mặt yêu dị trở nên hung ác.","chuong":"@c0533"},{"text":"Sở trường Lục Chỉ Kiếm Quyết: cong tay điểm năm chỉ cực nhanh rồi khép thành chùy điểm tới.","chuong":"@c0533"}],"kinhLich":[{"text":"Ở trong phủ Yêu Soái, kinh hãi khi Đế Kiếm tự bay ra khỏi trận nhãn, cho rằng việc này có quỷ dị.","bridge":true,"khoang":"@c0537"},{"text":"Đến nhịp thở thứ năm sau khi Mộ Vân được chỉ định, Thạch Tiêu ra khiêu chiến. Hắn dùng quang đồ hình thoi cắn nát năm đạo khí xanh lục của Mộ Vân rồi ấn nổ. Khi Thiên Khôi Công Nhân — trợ giúp của Mộ Vân — xông lên, Thạch Tiêu dùng hình nón dung yêu lực đâm vỡ thân y thành máu thịt, năm đường chỉ đen từ máu thịt nhập vào người hắn.","bridge":true,"khoang":"@c0543"},{"text":"Thạch Tiêu thách Mạc Lệ Hải nhưng bị từ chối, liền chuyển sang khiêu chiến Vương Lâm. Vương Lâm cự tuyệt; giáp vàng buộc Thạch Tiêu lui vì đã thắng không được khiêu chiến tiếp. Lúc đi ngang, hắn hạ giọng dọa sẽ giết Vương Lâm cho hả giận.","bridge":true,"khoang":"@c0543"},{"text":"Đứng trong đám Yêu Tướng, hỏi Trần Đào gõ được mấy tiếng; lộ sát khí khi nhìn Mặc Phi.","bridge":true,"khoang":"@c0546"},{"text":"Khi Vương Lâm tẩy tủy bằng tiếng trống, Thạch Tiêu nhìn hắn với sát khí ngày càng đậm, nhiều lần giơ tay nhưng do dự rồi thả xuống; tới tiếng trống truyền niệm thì cũng lộ một tia bi thương.","bridge":true,"khoang":"@c0548"},{"chuong":"@c0613","importance":"normal","tieuDe":"Bị Vương Lâm giết tại phủ","text":"Tu vi đã ngang Vấn Đỉnh trung kỳ, đả tọa cùng Trần Đào ở yêu tướng phủ Thiên Yêu quận, định ngày mai tấu yêu đế tiến cử Trần Đào làm yêu tướng. Hắn mắng Vương Lâm ti tiện, kể chuyện Mạc Lệ Hải cướp vị trí phó soái và dọa giết Vương Lâm. Vương Lâm hiện thân, dùng thần thông bóng Âm dương hư thật đập vỡ vụn cơ thể hắn — báo lời hứa năm xưa."},{"text":"Cùng Trần Đào phóng ngựa lao vào đoàn Mạc Lệ Hải, khóa mục tiêu rồi tung Lục Chỉ Kiếm Quyết đối Thập Băng Quyền Ý. Sau trận, hắn bàn với Trần Đào về Thần Thông Tam Thức của Mạc Lệ Hải, hứa phái người thu thập tài liệu để Trần Đào luyện Thiên Nguyên đan khôi phục tu vi.","bridge":true,"khoang":"@c0533"},{"text":"Đả tọa cùng Trần Đào tại yêu tướng phủ Thiên Yêu quận, tu vi nay ngang Vấn Đỉnh trung kỳ, định tấu yêu đế tiến cử Trần Đào làm yêu tướng. Hắn mắng Vương Lâm ti tiện, dọa giết. Vương Lâm hiện thân dưới ánh trăng, dùng thần thông bóng Âm dương hư thật đập vỡ vụn mọi bộ phận cơ thể hắn, báo lời hứa năm xưa lấy mạng.","bridge":true,"khoang":"@c0613"}],"tuViMoc":[{"chuong":"@c0613","canhGioi":"Vấn Đỉnh trung kỳ","text":"Tu vi đã thăng tới ngang Vấn Đỉnh trung kỳ trước khi bị giết.","importance":"minor"}],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Tôn Đào","tag":"dong-minh","quanHe":"Ở cạnh nhau khi chứng kiến Đế Kiếm rời trận nhãn","ghiChu":"@c0537"},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Bị Mạc Lệ Hải để lại vết sẹo trên mặt ba trăm năm trước","ghiChu":"@c0543"},{"ten":"Mộ Vân","tag":"doi-thu","quanHe":"Hạ gục Mộ Vân ở trận đầu","ghiChu":"@c0543"},{"ten":"Thiên Khôi Công Nhân","tag":"doi-thu","quanHe":"Giết chết, đâm vỡ thân thành máu thịt","ghiChu":"@c0543"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khiêu chiến rồi hăm dọa sẽ giết Vương Lâm","ghiChu":"@c0543"},{"ten":"Trần Đào","tag":"dong-minh","quanHe":"Hỏi Trần Đào ước lượng có thể gõ được mấy tiếng","ghiChu":"@c0546"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ giết hắn","ghiChu":"Khinh miệt, dọa giết Vương Lâm; bị Vương Lâm giết tại yêu tướng phủ."},{"ten":"Trần Đào","tag":"dong-minh","quanHe":"Đả tọa cùng","ghiChu":"Định tiến cử Trần Đào làm yêu tướng; Trần Đào bênh Vương Lâm."},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Kẻ hắn tố cáo","ghiChu":"Tố Mạc Lệ Hải dùng thủ đoạn hèn hạ cướp vị trí phó soái nhờ Vương Lâm."},{"ten":"Trần Đào","tag":"dong-minh","quanHe":"Đồng hành, nâng đỡ","ghiChu":"Thu thập tài liệu giúp Trần Đào luyện Thiên Nguyên đan."},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Kình địch cuộc chiến Yêu tướng","ghiChu":"Đấu một chiêu trên quân đạo."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Sư đệ đồng hệ của Trần Đào","ghiChu":"Ngưng trọng khi nghe Trần Đào hết lời khen Vương Lâm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ thù","ghiChu":"Khinh miệt và dọa giết Vương Lâm, cuối cùng bị Vương Lâm dùng Âm dương hư thật giết chết để báo lời hứa năm xưa."},{"ten":"Trần Đào","tag":"dong-minh","quanHe":"Đồng liêu yêu tướng phủ","ghiChu":"Đả tọa cùng Trần Đào, định tiến cử Trần Đào làm yêu tướng; Trần Đào bênh Vương Lâm trước khi Thạch Tiêu bị giết."}],"tuiDo":{}},"nguon":["@c0537","@c0543","@c0546","@c0548","@c0613","@c0533"]},{"id":"ton-dao-yeu-tuong","name":"Tôn Đào","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Người đứng cạnh Thạch Tiêu, sắc mặt ngưng trọng khi nhìn ngân quang Đế Kiếm.","vaiTro":"Nhân vật phe Thiên Yêu Quận","tinhCach":[],"tabs":{"diem":[{"text":"Sắc mặt ngưng trọng, kinh hãi nhìn ngân quang Đế Kiếm bay ra","chuong":"@c0537"}],"kinhLich":[{"text":"Đứng cạnh Thạch Tiêu, sắc mặt ngưng trọng kinh hãi nhìn ngân quang Đế Kiếm tự rời trận nhãn.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Thạch Tiêu","tag":"dong-minh","quanHe":"Ở cạnh nhau khi chứng kiến Đế Kiếm rời trận nhãn","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0537"]},{"id":"thanh-nien-ao-xanh-hoa-thuyen","name":"Thanh niên áo xanh (trên họa thuyền)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Thanh niên khoảng 27-28 tuổi mang yêu lực mơ hồ, yêu cầu nữ tử đàn “tiếng đàn chân chính” và nâng rượu chào Vương Lâm.","vaiTro":"Nhân vật bí ẩn bên họa thuyền","tinhCach":[{"text":"Tao nhã, thích thưởng nhạc, tinh tế nhận ra người trên bờ","chuong":"@c0537"}],"tabs":{"diem":[{"text":"Mang yêu lực mơ hồ, gọi Vương Lâm là “một tiểu tử rất thú vị”","chuong":"@c0537"}],"kinhLich":[{"text":"Trên họa thuyền, yêu cầu nữ tử mắt đen đàn “tiếng đàn chân chính”; cảm nhận có người trên bờ, nâng rượu đối ẩm từ xa với Vương Lâm, nhận xét hắn là “tiểu tử rất thú vị”.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Mang yêu lực, cảnh giới chưa rõ.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Đối ẩm từ xa bên sông, nâng rượu chào nhau","ghiChu":"@c0537"},{"ten":"Nữ tử đánh đàn (mắt đen)","tag":"khac","quanHe":"Yêu cầu nàng đàn tiếng đàn chân chính trên họa thuyền","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0537"]},{"id":"nguoi-hoang-bao-quy-phi-lau","name":"Người mặc hoàng bào (Quý Phi Lâu)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Người mặc hoàng bào trong Quý Phi Lâu, thái độ thân mật bỡn cợt với Đế Kiếm khi nó nổi giận bay ra.","vaiTro":"Nhân vật bí ẩn trong hoàng cung","tinhCach":[],"tabs":{"diem":[{"text":"Cười hỏi “Đế Kiếm có chuyện gì vui vậy” khi thấy ngân quang bay qua — thái độ thân mật khác thường","chuong":"@c0537"}],"kinhLich":[{"text":"Trong Quý Phi Lâu, nhìn ngân quang Đế Kiếm bay qua, cười hỏi Đế Kiếm có chuyện gì vui; phía sau có nữ tử xinh đẹp đứng hạ giọng nói.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Nữ tử xinh đẹp (Quý Phi Lâu)","tag":"khac","quanHe":"Nữ tử đứng sau lưng, hạ giọng nói chuyện","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0537"]},{"id":"nu-tu-xinh-dep-quy-phi-lau","name":"Nữ tử xinh đẹp (Quý Phi Lâu)","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Nữ tử xinh đẹp đứng sau người mặc hoàng bào trong Quý Phi Lâu, hạ giọng nói khi Đế Kiếm bay qua.","vaiTro":"Nhân vật phụ trong hoàng cung","tinhCach":[],"tabs":{"diem":[{"text":"Đứng sau người hoàng bào, hạ giọng nói khi thấy ngân quang Đế Kiếm","chuong":"@c0537"}],"kinhLich":[{"text":"Đứng sau người mặc hoàng bào trong Quý Phi Lâu, hạ giọng nói khi ngân quang Đế Kiếm bay qua.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Người mặc hoàng bào (Quý Phi Lâu)","tag":"khac","quanHe":"Đứng sau lưng, hạ giọng nói chuyện","ghiChu":"@c0537"}],"tuiDo":{}},"nguon":["@c0537"]},{"id":"trung-nien-ao-bao-trang-phu-yeu-soai","name":"Trung niên áo bào trắng (phủ Yêu Soái)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Trung niên áo bào trắng trong phủ Yêu Soái, kinh ngạc trước việc Đế Kiếm phẫn nộ rời trận nhãn.","vaiTro":"Nhân vật cấp cao phủ Yêu Soái","tinhCach":[],"tabs":{"diem":[{"text":"Chắp tay sau lưng, kinh ngạc tự hỏi ai khiến Đế Kiếm phẫn nộ ra khỏi trận nhãn","chuong":"@c0537"}],"kinhLich":[{"text":"Trong phủ Yêu Soái, chắp tay sau lưng kinh ngạc, tự hỏi là ai khiến Đế Kiếm phẫn nộ ra khỏi trận nhãn.","bridge":true,"khoang":"@c0537"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[],"tuiDo":{}},"nguon":["@c0537"]},{"id":"pho-soai-huyen-thanh","name":"Phó soái Huyền Thành","cn":"","aliases":["Nam tử áo tím"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Chủ Huyền Thành soái phủ, giao tình tốt với Yêu Đế; cho mời Mạc Lệ Hải và Vương Lâm vào đình viện.","vaiTro":"Phó soái Huyền Thành, Thiên Yêu Quận","tinhCach":[],"tabs":{"diem":[{"text":"Giao tình tốt với Yêu Đế, chủ phủ phó soái Huyền Thành","chuong":"@c0537"}],"kinhLich":[{"text":"Cho mời Mạc Lệ Hải và Vương Lâm vào đình viện trong phủ phó soái Huyền Thành.","bridge":true,"khoang":"@c0537"},{"text":"Tiếp Mạc Lệ Hải và Vương Lâm tại soái phủ, coi thường Vương Lâm chỉ là tùy tùng Anh Biến Hậu Kỳ. Thách Vương Lâm thi triển thần thông mạnh nhất, nếu làm hắn động dung thì công nhận tư cách. Bị hai nghìn đạo sát lục chi khí phá vỡ mãnh hổ yêu khí và màn yêu giáp bảy tấc, liên tục lui giẫm nát hoa quý, đành công nhận Vương Lâm có tư cách. Sau khi hai người đi, phun một ngụm máu tươi, hạ lệnh ba tháng không tiếp ai rồi bế quan.","bridge":true,"khoang":"@c0538"}],"tuViMoc":[{"chuong":"@c0538","canhGioi":"Tương đương Vấn Đỉnh Sơ Kỳ đỉnh phong","text":"Bản lãnh đạt đỉnh Sơ Kỳ và sắp đột phá, nhưng còn cách Vấn Đỉnh Trung Kỳ rất xa.","importance":"minor"}],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Mạc Lệ Hải","tag":"dong-minh","quanHe":"Tiếp Mạc Lệ Hải và Vương Lâm vào đình viện phủ phó soái","ghiChu":"@c0537"},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Đối thủ tranh chức phó soái","ghiChu":"Mạc Lệ Hải tới bái kiến để tranh chức phó soái."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm trấn áp","ghiChu":"Coi thường rồi bị một chiêu sát lục chi khí ép lui, công nhận tư cách và phải bế quan."},{"ten":"Yêu đế","tag":"dong-minh","quanHe":"Quan hệ tốt với Yêu Đế","ghiChu":"Quan hệ tốt với Yêu Đế là lý do chịu tiếp Mạc Lệ Hải."}],"tuiDo":{}},"nguon":["@c0537","@c0538"]},{"id":"nguoi-hoang-bao-de-do-kiem-cac","name":"Người mặc hoàng bào (Đế Đô Kiếm Các)","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Yêu tộc Thiên Yêu Thành","trangThai":"gan-bo"}],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Nhân vật bí ẩn chỉ thấy lưng tại Đế Đô Kiếm Các, trấn áp Đế Kiếm trong trận pháp, cấm nó tới Hồng Lao phá hoại.","vaiTro":"Người trấn giữ Đế Kiếm tại Đế Đô Kiếm Các.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0538","importance":"normal","tieuDe":"Trấn áp Đế Kiếm","text":"Tại Đế Đô Kiếm Các ở trung tâm Thiên Yêu Thành, trấn áp Đế Kiếm trong trận pháp, cấm nó tới Hồng Lao phá hoại nữa, dọa đưa tới Long Đàm. Sau khi Đế Kiếm rút, thế giới huyết sắc tầng thấp nhất của Hồng Lao dần khôi phục."}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0538"]},{"id":"nam-tu-toc-den-huyet-dam","name":"Nam tử tóc đen (trong huyết đàm)","gioiTinh":"nam","aliases":[],"theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"khong-ro","blurb":"Kẻ tu sát trong huyết đàm vô tận, quyết thoát ra như người từng thoát trước đó.","vaiTro":"Nhân vật phụ thoáng qua trong huyết đàm","tinhCach":[{"text":"Kiên định, lấy “hắn” (kẻ từng thoát huyết đàm) làm hình mẫu để noi theo","chuong":"@c0539"}],"tabs":{"diem":[{"text":"Để sát niệm từ huyết đàm nhập thân, sát khí ngày càng đậm, mắt đỏ như máu","chuong":"@c0539"}],"kinhLich":[{"text":"Trong huyết đàm vô tận, nam tử tóc đen khoanh chân để sát niệm nhập thân, ra tay cực ác như huyết long; sau một ngày chỉ còn mình hắn đứng vững. Hắn lao về phía lối ra; khi Ngân long Đế Kiếm chụp móng vuốt tới, hắn mỉm cười hô “Bạo!”, toàn thân nổ tung tạo màn sương máu trăm trượng đánh thương tay ngân long. Sau đó hắn sống lại trong huyết đàm và bị ngân long phun kiếm khí giết đi sống lại nhiều lần.","bridge":true,"khoang":"@c0539"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0539"]},{"id":"nguoi-ao-den-sat-thu-tham-thinh","name":"Người áo đen (sát thủ thám thính)","gioiTinh":"nam","aliases":[],"theLuc":[{"ten":"Yêu Linh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần hậu kỳ","trangThai":"tu-vong","blurb":"Người của Yêu Linh, bản lãnh Hóa Thần hậu kỳ, theo lệnh một Yêu Tướng tới thử Vương Lâm rồi bị giết.","vaiTro":"Sát thủ thám thính thoáng qua","tinhCach":[{"text":"Khinh miệt, ngạo mạn — vừa tới đã đòi ra tay","chuong":"@c0539"}],"tabs":{"diem":[],"kinhLich":[{"text":"Đứng cách trăm trượng với phi kiếm mảnh như rắn nước quấn thân, hắn khinh miệt hỏi Vương Lâm có phải phó tướng Mạc Lệ Hải rồi đòi ra tay. Vương Lâm không thèm nhìn, điểm Tịch Diệt Chỉ phóng đạo hắc khí làm phi kiếm vỡ tan như chẻ tre, đâm trúng ngực khiến hắn phun sương máu mà chết, hối hận trong mắt; khí xám từ thất khiếu hắn bị Vương Lâm thu vào tay phải.","bridge":true,"khoang":"@c0539"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tới thám thính thử Vương Lâm rồi bị giết","ghiChu":""}],"tuiDo":{}},"nguon":["@c0539"]},{"id":"nam-tu-lon-tuoi-ao-den-dau-linh-sat-thu","name":"Nam tử lớn tuổi áo đen (đầu lĩnh sát thủ)","gioiTinh":"nam","aliases":[],"theLuc":[{"ten":"Nhóm sát thủ của lão tổ","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Đầu lĩnh nhóm sát thủ trên tửu lầu, điềm tĩnh đánh giá tu vi Vương Lâm và nhận lệnh lão tổ bắt người.","vaiTro":"Chỉ huy nhóm sát thủ truy bắt Vương Lâm; cuối chương kinh hãi nhận ra ánh mắt Sát Lục Đạo.","tinhCach":[{"text":"Điềm tĩnh, lạnh lùng đánh giá đối thủ","chuong":"@c0540"},{"text":"Biến sắc dữ dội khi nhận ra Sát Lục Đạo","chuong":"@c0540"}],"tabs":{"diem":[],"kinhLich":[{"text":"Cùng số hai quan sát Vương Lâm trên tầng hai tửu lầu, đánh giá tu vi đối thủ đạt Anh Biến Kỳ và lần lượt phái sát thủ. Khi thấy ánh mắt Sát Lục Đạo phóng sát khí, hắn đứng bật dậy làm vỡ bàn, kinh hãi kêu lên đây là Sát Lục Đạo.","bridge":true,"khoang":"@c0540"}],"tuViMoc":[],"tuVi":"Tu vi cao, khí tức tiên yêu dung hợp; chưa rõ cảnh giới cụ thể.","nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Mục tiêu truy bắt theo lệnh lão tổ","gap":"@c0540"},{"ten":"Sát thủ số hai (thanh niên áo đen)","tag":"dong-minh","quanHe":"Thuộc hạ cùng nhóm sát thủ","gap":"@c0540"}],"tuiDo":{}},"nguon":["@c0540"]},{"id":"sat-thu-so-hai-thanh-nien-ao-den","name":"Sát thủ số hai (thanh niên áo đen)","gioiTinh":"nam","aliases":["Số hai"],"theLuc":[{"ten":"Nhóm sát thủ của lão tổ","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Sát thủ bản lãnh tương đương Anh Biến Hậu Kỳ gần viên mãn, thân tỏa khí tức tiên yêu dung hợp.","vaiTro":"Đích thân ra trận đối đầu Vương Lâm, giải được Tịch Diệt Nhất Chỉ nhưng bị Sát Lục Đạo áp chế suýt sụp đổ tâm thần.","tinhCach":[{"text":"Tự tin, hiếu chiến, ung dung khi bước vào trận","chuong":"@c0540"}],"tabs":{"diem":[],"kinhLich":[{"text":"Tự xưng là số hai, đích thân ung dung bước nghìn trượng tới đối đầu Vương Lâm. Hắn tạo hơn trăm quang cầu yêu lực liên tiếp chống đỡ, hao tổn lớn mới tiêu tan được Tịch Diệt Nhất Chỉ, còn lại tám quang cầu. Khi Vương Lâm quay đầu phóng Sát Lục Đạo, hắn như bị sét đánh, thân cứng đờ run rẩy, tâm thần suýt sụp đổ như đối mặt cái chết.","bridge":true,"khoang":"@c0540"}],"tuViMoc":[{"chuong":"@c0540","canhGioi":"Anh Biến Hậu Kỳ (tương đương)","text":"Bản lãnh tương đương Anh Biến Hậu Kỳ, gần viên mãn; thân tỏa yêu lực kèm một tia tiên lực dung hợp kỳ dị.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ trực tiếp, bị Sát Lục Đạo áp chế","gap":"@c0540"},{"ten":"Nam tử lớn tuổi áo đen (đầu lĩnh sát thủ)","tag":"dong-minh","quanHe":"Đầu lĩnh cùng nhóm sát thủ","gap":"@c0540"}],"tuiDo":{}},"nguon":["@c0540"]},{"id":"sat-thu-so-bon-trung-nien-ao-den","name":"Sát thủ số bốn (trung niên mắt sáng)","gioiTinh":"nam","aliases":["Số bốn"],"theLuc":[{"ten":"Nhóm sát thủ của lão tổ","trangThai":"gan-bo"}],"trangThai":"tu-vong","blurb":"Sát thủ bản lãnh tương đương Anh Biến Sơ Kỳ, hóa đạo cầu vồng tập kích Vương Lâm.","vaiTro":"Sát thủ đầu tiên ra trận, bị Tịch Diệt Nhất Chỉ giết chết.","tinhCach":[{"text":"Quyết liệt, lao thẳng vào tập kích","chuong":"@c0540"}],"tabs":{"diem":[],"kinhLich":[{"text":"Nhận hiệu lệnh, hóa thành đạo cầu vồng mang sát khí bay tới tập kích Vương Lâm. Bị Tịch Diệt Nhất Chỉ phá vỡ cầu vồng, phun máu, dù dùng yêu lực vẫn bị hắc khí đuổi đâm vào ngực ngã chết, để lại một đạo khí xám bay về phía Vương Lâm.","bridge":true,"khoang":"@c0540"}],"tuViMoc":[{"chuong":"@c0540","canhGioi":"Anh Biến Sơ Kỳ (tương đương)","text":"Bản lãnh tương đương Anh Biến Sơ Kỳ.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm giết bằng Tịch Diệt Nhất Chỉ","gap":"@c0540"}],"tuiDo":{}},"nguon":["@c0540"]},{"id":"mo-van-yeu-tuong","name":"Mộ Vân","gioiTinh":"nam","tabs":{"diem":[{"text":"Yêu Tướng gầy yếu sắc mặt vàng vọt, xếp top 30, tu Cửu Tử Cửu Sinh chi khí","chuong":"@c0543"}],"kinhLich":[{"text":"Mộ Vân được giáp vàng chỉ định ra trước, từng đạt Ngũ Tử Ngũ Sinh ba trăm năm trước, nay đột phá tầng bảy hóa năm đạo sinh tử yêu khí (khí xanh lục như linh xà). Bị Thạch Tiêu dùng quang đồ hình thoi cắn nát năm đạo khí rồi ấn nổ, thua trận.","bridge":true,"khoang":"@c0543"}],"tuViMoc":[],"nhanMach":[{"ten":"Thạch Tiêu","tag":"doi-thu","quanHe":"Bị Thạch Tiêu hạ gục ở trận đầu","ghiChu":"@c0543"},{"ten":"Thiên Khôi Công Nhân","tag":"dong-minh","quanHe":"Người trợ giúp của Mộ Vân trong trận","ghiChu":"@c0543"}],"tuiDo":{}},"nguon":["@c0543"]},{"id":"thien-khoi-cong-nhan","name":"Thiên Khôi Công Nhân","gioiTinh":"nam","theLuc":[{"ten":"Cự Linh Môn","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Người trợ giúp của Mộ Vân, xuất thân Cự Linh Môn trên Thiên Vận Tinh, thân thể to lớn thiên về sức lực","chuong":"@c0543"}],"kinhLich":[{"text":"Khi Mộ Vân thua, Thiên Khôi Công Nhân xông lên trợ chiến, dùng tiên lực từ lỗ chân lông tạo sương bao thân kèm chú ngữ dựng cấm chế phạm vi trăm trượng. Bị Thạch Tiêu dùng hình nón dung yêu lực đâm vỡ thân, hóa thành đám máu thịt.","bridge":true,"khoang":"@c0543"}],"tuViMoc":[],"nhanMach":[{"ten":"Mộ Vân","tag":"dong-minh","quanHe":"Là người trợ giúp của Mộ Vân","ghiChu":"@c0543"},{"ten":"Thạch Tiêu","tag":"doi-thu","quanHe":"Bị Thạch Tiêu giết chết","ghiChu":"@c0543"}],"tuiDo":{}},"nguon":["@c0543"]},{"id":"ngao-dich-yeu-tuong","name":"Ngao Địch","gioiTinh":"nam","tabs":{"diem":[{"text":"Yêu Tướng bản lãnh trung bình, tính xảo trá trơ trẽn","chuong":"@c0543"}],"kinhLich":[{"text":"Ngao Địch chớp cơ hội ra khiêu chiến Vương Lâm vì thắng Vương Lâm tương đương thắng Mạc Lệ Hải. Hắn dọa rằng nếu ngang sức thì còn người trợ giúp. Vương Lâm bình thản đáp rằng hắn không phải là đối thủ.","bridge":true,"khoang":"@c0543"},{"text":"Được nhắc là Yêu Tướng duy nhất bị Vương Lâm đánh trọng thương ở vòng một; ngoài hắn không Yêu Tướng nào bị thương nặng.","bridge":true,"khoang":"@c0546"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Ra khiêu chiến Vương Lâm, bị coi thường","ghiChu":"@c0543"}],"tuiDo":{}},"nguon":["@c0543","@c0546"]},{"id":"huyen-pho-soai","name":"Huyền Phó Soái","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Một trong sáu Phó Soái Thiên Yêu Quận, sắc mặt tái nhợt như có thương; có thù cũ với Vương Lâm","chuong":"@c0543"}],"kinhLich":[{"text":"Huyền Phó Soái căm giận nhìn Vương Lâm vì có thù cũ, song quả quyết với Hoàng Phó Soái rằng người này chắc chắn vào tam giáp, thậm chí đứng đầu. Hai bên cược: Huyền đưa Phó Thiên Triệu Kỳ nếu Vương Lâm không dẫn đầu. Hắn thầm mong Vương Lâm đánh trọng thương Hoàng Phó Soái.","bridge":true,"khoang":"@c0543"},{"text":"Một trong sáu Phó Soái; chăm chú vào Vương Lâm, đánh cược với Hoàng Phó Soái rằng tu sĩ mình chọn (Vương Lâm) không thua. Trong lòng cảm thấy Mặc Phi chỉ mạnh, còn Vương Lâm mới thật sự đáng sợ; giọng nói khi nhắc Vương Lâm có vẻ sợ hãi.","bridge":true,"khoang":"@c0546"},{"text":"Tu vi ngừng lại đã lâu, nay sắp đột phá nhờ cảm ngộ tiếng trống tẩy tủy của Vương Lâm tại cuộc thí luyện Thiên Yêu thành.","bridge":true,"khoang":"@c0551"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Căm ghét vì thù cũ nhưng tin Vương Lâm sẽ dẫn đầu","ghiChu":"@c0543"},{"ten":"Hoàng Phó Soái","tag":"khac","quanHe":"Đánh cược về thành tích Vương Lâm","ghiChu":"@c0543"},{"ten":"Hoàng Phó Soái","tag":"doi-thu","quanHe":"Đối thủ đánh cược về việc Vương Lâm có thua hay không","ghiChu":"@c0546"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Chọn Vương Lâm để đánh cược, âm thầm cho rằng hắn đáng sợ","ghiChu":"@c0546"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Cảm ngộ tiếng trống của Vương Lâm","ghiChu":"Sắp đột phá nhờ tiếng trống tẩy tủy (@c0551)."}],"tuiDo":{}},"nguon":["@c0543","@c0546","@c0551"]},{"id":"hoang-pho-soai","name":"Hoàng Phó Soái","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Phó Soái mặc giáp lam, tướng mạo tầm thường mà uy nghiêm","chuong":"@c0543"}],"kinhLich":[{"text":"Hoàng Phó Soái thấy Vương Lâm chỉ là Anh Biến hậu kỳ viên mãn nên nghi ngờ lời Huyền Phó Soái. Hắn nhận cược, hứa đưa Huyền Huyền Đan nếu Vương Lâm đứng đầu.","bridge":true,"khoang":"@c0543"},{"text":"Phó Soái, đối thủ đánh cược của Huyền Phó Soái; cho rằng tu sĩ phải tự ra tay nên Huyền tất bại, nhưng cảm nhận giọng Huyền có vẻ sợ hãi khi nói về Vương Lâm.","bridge":true,"khoang":"@c0546"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyền Phó Soái","tag":"khac","quanHe":"Đánh cược về thành tích Vương Lâm","ghiChu":"@c0543"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Nghi ngờ thực lực, coi thường vì chỉ Anh Biến hậu kỳ","ghiChu":"@c0543"},{"ten":"Huyền Phó Soái","tag":"doi-thu","quanHe":"Đối thủ đánh cược về Vương Lâm","ghiChu":"@c0546"}],"tuiDo":{}},"nguon":["@c0543","@c0546"]},{"id":"nam-tu-giap-vang-chu-tri-yeu-tuong","name":"Nam tử mặc giáp vàng","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Quan chủ trì trận chiến Yêu Tướng, phụng mệnh Đế Quân; chưa lộ tên","chuong":"@c0543"}],"kinhLich":[{"text":"Nam tử mặc giáp vàng từ cung điện bước ra, hô gọi các Yêu Tướng bước ra khỏi hàng, công bố quy tắc khiêu chiến tàn khốc: một thắng một bại thì cả hai mất tư cách, Yêu Tướng không được chết, chỉ trợ giúp được phép tử vong. Hắn lần lượt chỉ định người tham chiến và buộc Thạch Tiêu lui sau khi thắng.","bridge":true,"khoang":"@c0543"},{"text":"Phụng mệnh Đế Quân chủ trì vòng hai cuộc tranh đoạt Yêu Tướng, tuyên luật gõ Chiến Yêu Cổ. Lạnh lùng, coi tu sĩ tới đây là đám cường đạo nhắm truyền thừa Cổ Yêu, ôm ý giết kẻ đánh trọng thương Yêu Tướng. Cuối chương gọi Vương Lâm, tỏa sát khí và hỏi hắn có dám đánh cược không.","bridge":true,"khoang":"@c0546"},{"text":"Người mặc kim giáp cười lạnh chế giễu việc đánh Yêu Cổ là giả thần giả quỷ; lão từng theo Yêu Đế nhiều năm, nghĩ tu vi Vương Lâm không đủ thì tẩy tủy ắt trọng thương. Nhưng tới tiếng trống thứ mười một lão lần đầu đại biến sắc mặt, vô thức lùi vài bước, trắng xanh mặt ngơ ngẩn không nói nên lời trước cảnh giới trống truyền niệm.","bridge":true,"khoang":"@c0548"}],"tuViMoc":[],"nhanMach":[{"ten":"Yêu Đế","tag":"cap-tren","quanHe":"Phụng mệnh Đế Quân chủ trì trận chiến","ghiChu":"@c0543"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tỏa sát khí với Vương Lâm vì đánh trọng thương Yêu Tướng, thách đánh cược","ghiChu":"@c0546"},{"ten":"Yêu đế","tag":"cap-tren","quanHe":"Đã theo Yêu Đế nhiều năm, nghe Yêu Đế nói về việc dùng tiếng trống tẩy tủy","ghiChu":"@c0548"}],"tuiDo":{}},"nguon":["@c0543","@c0546","@c0548"]},{"id":"vu-sam-yeu-tuong","name":"Vu Sâm","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Yêu Tướng duy nhất không có thành trì, hằng năm lấy sát lục tu luyện tới đỉnh ở Hỏa Yêu Quận","chuong":"@c0543"}],"kinhLich":[{"text":"Vu Sâm được dân chúng nhắc đến như Yêu Tướng duy nhất không có thành trì, chuyên tu sát lục đạo.","bridge":true,"khoang":"@c0543"},{"text":"Yêu Tướng tu Sát Lục đạo, điều tức rồi bùng nổ dùng song chỉ và thần thông Phệ Hồn Sát Lục đệ nhất thức gõ trống. Gõ liên tiếp bốn tiếng, sau đó tay phải mất cảm giác, yêu lực hao tám phần, lùi hơn trăm trượng, nuốt máu dừng lại. Tuyên bố không có người trợ giúp.","bridge":true,"khoang":"@c0546"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0543","@c0546"]},{"id":"ma-van-yeu-tuong","name":"Ma Văn","gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Yêu Tướng công pháp đặc biệt, kế thừa Long Đàm Cổ Yêu Điện, khiêm tốn ẩn giấu thực lực","chuong":"@c0543"}],"kinhLich":[{"text":"Ma Văn được nhắc đến như Yêu Tướng kế thừa Long Đàm Cổ Yêu Điện, công pháp đặc biệt, khiêm tốn giấu thực lực.","bridge":true,"khoang":"@c0543"}],"tuViMoc":[],"nhanMach":[],"tuiDo":{}},"nguon":["@c0543"]},{"id":"ta-lien-yeu-tuong","name":"Tà Liên","gioiTinh":"nu","theLuc":[{"ten":"Thiên Yêu Quận","trangThai":"gan-bo"}],"tabs":{"diem":[{"text":"Nữ Yêu Tướng duy nhất, ba trăm năm trước bị thương vẫn đạt vị trí thứ tư","chuong":"@c0543"}],"kinhLich":[{"text":"Tà Liên được nhắc đến như nữ Yêu Tướng duy nhất, từng bị thương ba trăm năm trước mà vẫn đạt vị trí thứ tư.","bridge":true,"khoang":"@c0543"},{"text":"Tà Liên xuất hiện trong hàng ngũ yêu tướng quan sát Vương Lâm gõ trống Yêu Cổ; mắt đẹp lóe tinh quang dõi theo khi hắn lập thành tích chín tiếng.","bridge":true,"khoang":"@c0547"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Chú ý quan sát Vương Lâm khi hắn gõ Yêu Cổ","ghiChu":""}],"tuiDo":{}},"nguon":["@c0543","@c0547"]},{"id":"thanh-nien-thuyen-tranh","name":"Thanh niên trên thuyền tranh","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Thanh niên tướng mạo tầm thường nhưng cởi mở, quan sát Vương Lâm nhiều ngày rồi mời lên thuyền tranh nghe đàn uống rượu; tự nhận tục nhân, danh tính bất phàm chưa rõ.","vaiTro":"Nhân vật bí ẩn","tinhCach":[{"text":"Cởi mở, ung dung, thích kết giao theo tâm thái khách qua đường","chuong":"@c0545"}],"tabs":{"diem":[{"text":"Nhận Vương Lâm là tục nhân đồng điệu, mời uống rượu nghe đàn tới bình minh","chuong":"@c0545"},{"text":"Hé lộ có gia đình với “vài vị khách thô lỗ tranh cãi ầm ĩ” và bảy đứa cháu gái bướng bỉnh bị một vị khách đáng ghét quấn lấy","chuong":"@c0545"}],"kinhLich":[{"chuong":"@c0545","importance":"normal","tieuDe":"Mời Vương Lâm lên thuyền tranh","text":"Buổi trưa thuyền tranh đến, thanh niên nâng chén mời Vương Lâm lên mũi thuyền cùng nghe đàn của Minh Phí cô nương. Cuối buổi hỏi Vương Lâm nghe đàn có cảm xúc gì, hai người nhận nhau là tục nhân và hẹn uống tới bình minh; qua đối thoại lộ hắn có gia đình bất phàm."}],"tuViMoc":[],"tuVi":"Chưa rõ tu vi.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Mời lên thuyền tranh nghe đàn uống rượu, cùng nhận nhau là tục nhân","ghiChu":"@c0545"},{"ten":"Minh Phí (cô nương)","tag":"khac","quanHe":"Nữ tử đánh đàn trên thuyền của hắn","ghiChu":"@c0545"}],"tuiDo":{}},"nguon":["@c0545"]},{"id":"minh-phi-co-nuong","name":"Minh Phí (cô nương)","cn":"","aliases":["Minh Phí"],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Nữ tử đánh đàn trên thuyền tranh; tiếng đàn vô tình nhưng hàm chứa bi thương, khiến tâm vướng bận của người nghe rung động.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Lặng lẽ, tiếng đàn vô tình mà ẩn chứa bi thương","chuong":"@c0545"}],"tabs":{"diem":[{"text":"Tiếng đàn của nàng khơi gợi cảm ngộ chữ “nghịch” và nỗi nhớ cố nhân nơi Vương Lâm","chuong":"@c0545"}],"kinhLich":[{"text":"Trên thuyền tranh ở Hồng Thành, Minh Phí đánh đàn cho Vương Lâm và thanh niên bí ẩn nghe; tiếng đàn vô tình mà hàm chứa nghịch ý và bi thương khiến người nghe rung động.","bridge":true,"khoang":"@c0545"}],"tuViMoc":[],"tuVi":"Chưa rõ tu vi.","nhanMach":[{"ten":"Thanh niên trên thuyền tranh","tag":"khac","quanHe":"Đánh đàn trên thuyền của thanh niên","ghiChu":"@c0545"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tiếng đàn khơi cảm ngộ của Vương Lâm","ghiChu":"@c0545"}],"tuiDo":{}},"nguon":["@c0545"]},{"id":"thieu-mon-chu-ngoc-kiem-mon","name":"Thiếu môn chủ Ngọc Kiếm Môn (nam tử áo trắng)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Ngọc Kiếm Môn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến kỳ trở lên","trangThai":"song","blurb":"Nam tử áo trắng tướng mạo sáng sủa, thiếu môn chủ Ngọc Kiếm Môn; bị cuốn vào tranh đoạt Yêu Tướng, thức tỉnh dẫn đoàn tu sĩ rời khỏi Thiên Yêu Thành.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Khí khái, không cam làm con hát mua vui cho Yêu Linh","chuong":"@c0545"}],"tabs":{"diem":[{"text":"Cảm phục Vương Lâm; nhắc danh tiếng Vương Lâm vang như sấm ở Thiên Vận Tinh","chuong":"@c0545"}],"kinhLich":[{"text":"Trên đường tới Mạc phủ, thiếu môn chủ Ngọc Kiếm Môn cùng người trợ giúp của Yêu Tướng Ngao Địch bày tỏ thức tỉnh: ở Yêu Linh tu sĩ chỉ là con hát mua vui, sinh mạng thấp hơn kiến. Họ cáo từ Vương Lâm, hóa cầu vồng bay đi.","bridge":true,"khoang":"@c0545"}],"tuViMoc":[],"tuVi":"Anh Biến kỳ trở lên.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Cảm phục Vương Lâm, cáo từ trước khi rời đi","ghiChu":"@c0545"},{"ten":"Người trợ giúp của Yêu Tướng Ngao Địch (đạo bào trung niên)","tag":"dong-hanh","quanHe":"Cùng thức tỉnh rời khỏi Thiên Yêu Thành","ghiChu":"@c0545"}],"tuiDo":{}},"nguon":["@c0545"]},{"id":"nguoi-tro-giup-yeu-tuong-ngao-dich","name":"Người trợ giúp của Yêu Tướng Ngao Địch (đạo bào trung niên)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Trung niên đạo bào từng trợ giúp Yêu Tướng Ngao Địch; sau cái chết của Ngao Địch thì thức tỉnh, theo đoàn rời khỏi Thiên Yêu Thành.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Tỉnh ngộ chiến công vô nghĩa nếu không còn sống để hưởng","chuong":"@c0545"}],"tabs":{"diem":[{"text":"Cái chết của Ngao Địch khiến hắn buông bỏ, theo đoàn Ngọc Kiếm Môn rời đi","chuong":"@c0545"}],"kinhLich":[{"text":"Sau cái chết của Yêu Tướng Ngao Địch, hắn nói chiến công vô nghĩa nếu không còn sống để hưởng, cùng thiếu môn chủ Ngọc Kiếm Môn cáo từ Vương Lâm rồi hóa cầu vồng bay đi.","bridge":true,"khoang":"@c0545"}],"tuViMoc":[],"tuVi":"Chưa rõ tu vi.","nhanMach":[{"ten":"Ngao Địch","tag":"cap-tren","quanHe":"Từng trợ giúp Yêu Tướng Ngao Địch; cái chết của Ngao Địch khiến hắn thức tỉnh","ghiChu":"@c0545"},{"ten":"Thiếu môn chủ Ngọc Kiếm Môn (nam tử áo trắng)","tag":"dong-hanh","quanHe":"Cùng thức tỉnh rời khỏi Thiên Yêu Thành","ghiChu":"@c0545"}],"tuiDo":{}},"nguon":["@c0545"]},{"id":"mat-duong","name":"Mạt Dương","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"},{"ten":"Kiếm Tiếu Thập Nhị Tử","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"tu-vong","blurb":"Một trong Kiếm Tiếu Thập Nhị Tử của Đại La Kiếm Tông, địa vị tương đương Thiên Vận Thất Tử; đưa chiến thư của Mặc Phi rồi khiêu chiến Vương Lâm và bị giết.","vaiTro":"Phản diện thoáng qua — sứ giả đưa chiến thư kiêm kẻ khiêu chiến Vương Lâm.","tinhCach":[{"text":"Kiêu ngạo, hiếu chiến, coi thường đối thủ nhưng nhanh chóng thất vọng khi bị áp chế.","chuong":"@c0541"}],"tabs":{"diem":[{"text":"Nam tử áo xanh đeo đại kiếm, tỏa tiên lực bao phủ, ai tới gần trong mười trượng đều tan thành sương máu.","chuong":"@c0541"},{"text":"Bảo kiếm bản mệnh là cự kiếm tím dung hợp Tà Dương Chi Hồn (hư ảnh con dê tím).","chuong":"@c0541"}],"kinhLich":[{"text":"Mạt Dương đột nhập Mạc phủ giết hai quân sĩ, vượt qua người thấp bé và ba lão già để trao chiến thư “Chiến!” của Mặc Phi cho Mạc Lệ Hải, hẹn ba ngày sau ở sảnh đường Cổ Đạo. Khi quay đi, hắn chặn Vương Lâm khiêu chiến, phóng sáu mươi tư đạo kiếm khí và thi triển Mạt Dương kiếm trảm với cự kiếm tím dung hợp Tà Dương Chi Hồn, nhưng đều bị hóa giải; bị Vương Lâm đoạt kiếm, hộc máu, định dùng kiếm khí bảo mệnh của Lăng Thiên Hậu thì được tha. Rời Mạc phủ nghìn trượng thầm thề báo thù, hắn bị khí xám ẩn trong cự kiếm xâm nhập, cắt nguyên thần khỏi thân thể, hóa thây khô và bị Vương Lâm đoạt xác.","bridge":true,"khoang":"@c0541"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ địch giết mình","ghiChu":"Khiêu chiến tại Mạc phủ, bị hóa giải kiếm khí, đoạt kiếm bản mệnh rồi âm thầm hạ sát."},{"ten":"Mặc Phi","tag":"su-mon","quanHe":"Người sai phái","ghiChu":"Yêu Tướng Mặc Phi sai Mạt Dương đưa chiến thư cho Mạc Lệ Hải."},{"ten":"Mạc Lệ Hải","tag":"doi-thu","quanHe":"Người nhận chiến thư","ghiChu":"Mạt Dương thay mặt Mặc Phi đưa chiến thư khiêu chiến tới Mạc Lệ Hải."},{"ten":"Lăng Thiên Hậu","tag":"su-mon","quanHe":"Sư tôn","ghiChu":"Sư tôn của Kiếm Tiếu Thập Nhị Tử, ban cho Mạt Dương một đạo kiếm khí bảo mệnh."},{"ten":"Tham Lang","tag":"dong-minh","quanHe":"Tiền bối cùng phe","ghiChu":"Cường giả Mạt Dương trông cậy để báo thù; đang ở Hỏa Yêu Quận."}],"tuViMoc":[],"tuVi":"Cường giả Kiếm Tiếu Thập Nhị Tử của Đại La Kiếm Tông, địa vị tương đương Thiên Vận Thất Tử nhưng không phải đối thủ của Vương Lâm.","tuiDo":{"phapBao":[{"ten":"Cự kiếm tím (bảo kiếm bản mệnh)","loai":"phap-bao","trangThai":"mat","moTa":"Cự kiếm màu tím dung hợp Tà Dương Chi Hồn, bị Vương Lâm bắt sống và diệt Dương Hồn rồi trả lại; chủ nhân hóa thây khô sau đó.","nguon":"@c0541"}]}},"nguon":["@c0541"]},{"id":"tu-si-thanh-sam-tro-giup-mac-phi","name":"Tu sĩ mặc thanh sam","gioiTinh":"nam","aliases":["Người trợ giúp Mặc Phi"],"tabs":{"diem":[],"kinhLich":[{"text":"Tu sĩ lưng mang đại kiếm ra trợ giúp Mặc Phi, dùng chỉ/chưởng/kiếm khí gõ ba tiếng rồi cười khổ lui (có thể gõ năm nhưng sẽ trọng thương, không đáng vì Mặc Phi đã tất thắng).","bridge":true,"khoang":"@c0546"}],"tuViMoc":[],"nhanMach":[{"ten":"Mặc Phi","tag":"dong-minh","quanHe":"Trợ giúp Mặc Phi gõ thêm ba tiếng Chiến Yêu Cổ","ghiChu":"@c0546"}],"tuiDo":{}},"nguon":["@c0546"]},{"id":"dia-soai","name":"Địa Soái","gioiTinh":"nam","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0546","importance":"normal","tieuDe":"Ái tài Mặc Phi","text":"Một trong tám Yêu Soái; ái tài Mặc Phi, hứa dù không thành Phó Soái cũng đề cử nếu gõ được sáu tiếng. Bị nam tử trung niên mặc tử bào ngồi cạnh trêu là động lòng ái tài."}],"tuViMoc":[],"nhanMach":[{"ten":"Mặc Phi","tag":"khac","quanHe":"Ái tài, hứa đề cử nếu Mặc Phi gõ sáu tiếng","ghiChu":"@c0546"}],"tuiDo":{}},"nguon":["@c0546"]},{"id":"thien-soai-thien-yeu-quan","name":"Thiên Soái","gioiTinh":"nam","aliases":["Thiên Soái đại nhân"],"tabs":{"diem":[],"kinhLich":[{"text":"Đứng đầu các Yêu Soái; được nhắc là người duy nhất từng gõ Chiến Yêu Cổ đến mười lăm tiếng (kỷ lục). Trong chương ánh mắt luôn bình thản không đổi sắc.","bridge":true,"khoang":"@c0546"},{"text":"Ban đầu nhắm hờ mắt lộ vẻ thất vọng với Vương Lâm rồi thở dài không muốn nhìn nữa, nhưng khi tiếng trống thứ mười một vang lên Thiên soái lần đầu mở to mắt, đứng thẳng người, ánh mắt sáng như điện kinh ngạc nhận ra danh tính “Là Vương Lâm sao?”.","bridge":true,"khoang":"@c0548"},{"chuong":"@c0549","importance":"normal","tieuDe":"Nhận ra tẩy tủy thật","text":"Là một trong tám Yêu soái, Thiên soái lần đầu mở miệng tuyên bố sẽ nhớ kỹ tên Vương Lâm. Hắn nhận ra tiếng trống của Vương Lâm là tẩy tủy thật, tán thưởng; nhìn thấu sự do dự của Vương Lâm, nhớ năm xưa mình cũng phải lựa chọn khi Vấn Đỉnh, lẩm bẩm Vấn Đỉnh là sự cô độc mà người chưa đạt không thể hiểu."},{"text":"Thần thông của Thiên soái đập vào Kim Ô Húc nhưng chưa đánh trúng đã thu hồi vì không muốn giết; hắn kinh ngạc nhận ra Kim Ô Húc đã bị kẻ khác làm trọng thương kép. Sau đó nhìn Vương Lâm với ánh tán thưởng của trưởng bối với hậu bối, như thấy lại hình bóng mình năm xưa.","bridge":true,"khoang":"@c0551"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người khiến Thiên soái động dung và nhận ra danh tính sau tiếng trống truyền niệm","ghiChu":"@c0548"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Yêu soái chứng kiến Vương Lâm gõ trống","ghiChu":"Tuyên bố nhớ kỹ tên Vương Lâm, tán thưởng tẩy tủy thật (@c0549)."},{"ten":"Kim Ô Húc","tag":"doi-thu","quanHe":"Thần thông đập tới nhưng chưa đánh trúng","ghiChu":"Người ngoài lầm tưởng Thiên soái làm Kim Ô Húc trọng thương (@c0551)."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Tán thưởng hậu bối","ghiChu":"Nhìn Vương Lâm với ánh tán thưởng trưởng bối (@c0551)."}],"tuiDo":{}},"nguon":["@c0546","@c0548","@c0549","@c0551"]},{"id":"vu-soai","name":"Vũ soái","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Yêu tộc Thiên Yêu Thành (hệ Yêu Tướng - Yêu Soái)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Nữ Yêu soái duy nhất; đính chính rằng Vương Lâm đang cảm ngộ chứ không phải cảm nhận khí tức trong Yêu Cổ.","vaiTro":"Yêu soái nữ duy nhất trên khán đài Thiên Yêu thành.","tinhCach":[{"text":"Điềm tĩnh, am hiểu cốt lõi của Yêu Cổ.","chuong":"@c0548"}],"tabs":{"diem":[{"text":"Là Yêu soái nữ duy nhất, từng đích thân đánh Yêu Cổ và cảm được khí tức bên trong.","chuong":"@c0548"}],"kinhLich":[{"text":"Khi người mặc kim giáp chế giễu Vương Lâm là giả thần giả quỷ, Vũ soái lên tiếng khẳng định hắn đang “cảm ngộ” chứ không phải “cảm nhận”, kể năm xưa bà đánh Yêu Cổ cũng cảm được một khí tức bên trong, khiến toàn bộ Yêu soái ngưng trọng.","bridge":true,"khoang":"@c0548"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người mà bà đính chính bênh vực về việc cảm ngộ Yêu Cổ","ghiChu":"@c0548"}],"tuiDo":{}},"nguon":["@c0548"]},{"id":"huyen-soai-thien-yeu","name":"Huyền soái","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Yêu tộc Thiên Yêu Thành (hệ Yêu Tướng - Yêu Soái)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Yêu soái ngồi khán đài; thắc mắc liệu tu sĩ đánh Yêu Cổ có cảm nhận được khí tức bên trong.","vaiTro":"Một trong hàng Yêu soái quan sát màn đánh Yêu Cổ.","tinhCach":[{"text":"Thận trọng, hay đặt nghi vấn.","chuong":"@c0548"}],"tabs":{"diem":[{"text":"Thắc mắc liệu tu sĩ đánh Yêu Cổ có thật sự cảm nhận được khí tức trong trống.","chuong":"@c0548"}],"kinhLich":[{"text":"Khi Vương Lâm đánh Yêu Cổ tới mức kỳ lạ, Huyền soái nêu thắc mắc liệu tu sĩ này có cảm nhận được Yêu Cổ, mở đường cho Vũ soái đính chính.","bridge":true,"khoang":"@c0548"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Tu sĩ mà Huyền soái nghi vấn về việc cảm nhận Yêu Cổ","ghiChu":"@c0548"}],"tuiDo":{}},"nguon":["@c0548"]},{"id":"huyen-hon-soai-thien-yeu","name":"Huyền Hôn soái","cn":"","aliases":["Huyền Hôn soái"],"gioiTinh":"nam","theLuc":[{"ten":"Yêu tộc Thiên Yêu Thành (hệ Yêu Tướng - Yêu Soái)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Yêu soái kính phục Vương Lâm sau tiếng trống truyền niệm; ngờ hắn là người Yêu Đế đã chờ đợi nhiều năm.","vaiTro":"Yêu soái trên khán đài Thiên Yêu thành.","tinhCach":[{"text":"Biết kính phục, nhạy bén với cảnh giới tu hành.","chuong":"@c0548"}],"tabs":{"diem":[{"text":"Tu vi đã dừng lại từ lâu nhưng tiếng trống truyền niệm khiến lão lại rung động.","chuong":"@c0548"}],"kinhLich":[{"chuong":"@c0548","importance":"normal","tieuDe":"Ngờ Vương Lâm là người Yêu Đế chờ","text":"Sau tiếng trống truyền niệm, Huyền Hôn soái kính phục thốt rằng đó là một loại cảnh giới và có lẽ Vương Lâm chính là người mà Yêu Đế bệ hạ đã chờ đợi rất nhiều năm; tu vi lão vốn đình trệ từ lâu nay lại bị rung động."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người Huyền Hôn soái kính phục và ngờ là kẻ Yêu Đế chờ đợi","ghiChu":"@c0548"},{"ten":"Yêu đế","tag":"khac","quanHe":"Đế vương Yêu tộc mà Huyền Hôn soái cho là đang chờ đợi Vương Lâm","ghiChu":"@c0548"}],"tuiDo":{}},"nguon":["@c0548"]},{"id":"thuc-the-thap-den-chien-truong-vien-co","name":"Thực thể trong tháp đen (chiến trường viễn cổ)","cn":"","aliases":["Giáp đen trên chiến trường viễn cổ"],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"Không rõ","trangThai":"khong-ro","blurb":"Sinh linh giấu mình trong bộ giáp đen trên tầng cao nhất tòa tháp đen ở chiến trường viễn cổ, hấp thu âm hồn; chú ý và can thiệp giúp Vương Lâm từ xa.","vaiTro":"Thực thể bí ẩn","tinhCach":[{"text":"Tán thưởng con đường nghịch thiên, ra tay quyết đoán từ xa.","chuong":"@c0550"}],"tabs":{"diem":[{"text":"Phát thần niệm “Nghịch tu… Tốt lắm!” khi Vương Lâm chọn con đường nghịch thiên.","chuong":"@c0550"}],"kinhLich":[{"text":"Trên tầng cao nhất tòa tháp đen đang hấp thu âm hồn chiến trường viễn cổ, hốc mắt bộ giáp đen lóe u quang khiến bầu trời quanh tháp dao động. Khi Kim Ô Húc tập kích Vương Lâm, một tiếng hừ lạnh trong thần niệm vang ra cùng cổ âm hàn bao phủ Kim Ô Húc, đánh vỡ vụn kim giáp khiến hắn hộc máu, dập tắt mặt trời trên tay phải.","bridge":true,"khoang":"@c0550"},{"text":"Một đạo thần niệm khổng lồ từ trong hắc tháp lao ra hóa thành bôn lôi, làm đại địa vỡ vụn nhưng dừng trước người Vương Lâm mười trượng. Đây chính là thanh âm từng khiến Vương Lâm dọc đường vô số lần trọng thương. Thần niệm hỏi chưởng ấn học từ đâu, nghe đáp học từ tiên giới liền thì thào rằng năm đó hắn đích xác đi qua tiên giới, rồi ra lệnh bắt lấy Vương Lâm phải còn sống và thu trở vào trong tháp.","bridge":true,"khoang":"@c0563"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới; sức mạnh đủ đánh vỡ kim giáp Kim Ô Húc từ rất xa chỉ bằng một cổ âm hàn.","nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Can thiệp giúp Vương Lâm","ghiChu":"Tán thưởng con đường nghịch tu và đánh hạ kẻ tập kích Vương Lâm."},{"ten":"Kim Ô Húc","tag":"doi-thu","quanHe":"Đánh vỡ kim giáp Kim Ô Húc","ghiChu":"Dùng cổ âm hàn và tiếng hừ lạnh từ xa khiến Kim Ô Húc hộc máu."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tra hỏi nguồn gốc chưởng ấn của Vương Lâm và hạ lệnh bắt sống; từng nhiều lần khiến hắn trọng thương dọc đường.","ghiChu":"@c0563"},{"ten":"Chủ nhân áo giáp trong hắc tháp","tag":"khac","quanHe":"Sai khiến lão giả hắc giáp khoác Sáo Tiêu giáp ra tay bắt sống Vương Lâm.","ghiChu":"@c0563"}],"tuiDo":{}},"nguon":["@c0550","@c0563"]},{"id":"kim-o-huc-kim-tong-quan","name":"Kim Ô Húc","aliases":["Kim tổng quản","Người đàn ông mặc kim giáp"],"gioiTinh":"nam","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Yêu Soái","trangThai":"tu-vong","blurb":"Cường giả thanh danh hiển hách Thiên Yêu quận, Kim tổng quản; bị trọng thương kép bởi kẻ ẩn danh rồi bị Vương Lâm đập lên Yêu Cổ, chết thê thảm dưới tiếng trống thứ mười lăm.","vaiTro":"Đối thủ cường giả bị Vương Lâm hạ tại cuộc thí luyện trống Thiên Yêu thành.","tinhCach":[{"text":"Cao ngạo nhưng tỉnh táo, biết rõ tương quan thực lực — nhận ra “tiếng hừ thứ hai” mạnh hơn Đế Quân nhiều lần thì hắn ắt phải chết.","chuong":"@c0551"}],"tabs":{"diem":[{"text":"Mãnh Long thoái hóa thành loài bò sát khi bị trọng thương kép, yêu lực tan, kinh mạch nứt vỡ.","chuong":"@c0551"}],"kinhLich":[{"chuong":"@c0551","importance":"normal","tieuDe":"Trọng thương kép rồi chết dưới trống","text":"Bị “hai đạo âm thanh” của kẻ ẩn danh mạnh hơn Đế Quân nhiều lần làm trọng thương hai lần, yêu lực tiêu tán, từ Mãnh Long thoái hóa thành bò sát. Bị Vương Lâm chụp đập lên Yêu Cổ; tiếng trống thứ mười lăm đánh nát thân hắn tiêu tán tận chân trời, đến Kỳ Khôi Phách cũng vỡ, mọi dấu vết biến mất."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm giết","ghiChu":"Vương Lâm chụp hắn đang trọng thương đập lên Yêu Cổ (@c0551)."},{"ten":"Thiên Soái","tag":"doi-thu","quanHe":"Thần thông Thiên soái đập tới nhưng chưa đánh trúng","ghiChu":"Người ngoài lầm tưởng Thiên soái đánh trọng thương hắn (@c0551)."}],"tuiDo":{"phapBao":[{"ten":"Kỳ Khôi Phách","loai":"giáp phòng thân","trangThai":"hong","moTa":"Vật phòng thân của Kim Ô Húc, bị lực phản chấn tiếng trống thứ mười lăm đánh vỡ cùng cái chết của hắn.","nguon":"@c0551"}]}},"nguon":["@c0551"]},{"id":"nguoi-dan-ong-toc-do-tinh-cau-mau","name":"Người đàn ông tóc đỏ (tinh cầu máu)","gioiTinh":"nam","aliases":[],"theLuc":[],"canhGioiCaoNhat":"không-rõ","trangThai":"song","blurb":"Lão quái bí ẩn ngồi trong căn lầu máu giữa một tinh cầu máu rất xa Thiên Vận Tinh, tóc và lông mi đỏ, áo bào đỏ, lo lắng cho đứa hài tử Tích Tuyết.","vaiTro":"Nhân vật bí ẩn cảm ứng thiên kiếp.","tinhCach":[{"text":"Trầm tĩnh, có vẻ quan tâm sâu sắc tới Tích Tuyết.","chuong":"@c0552"}],"tabs":{"diem":[{"text":"Tướng mạo anh tuấn, nhìn như ngoài bốn mươi tuổi dù là lão quái.","chuong":"@c0552"}],"kinhLich":[{"text":"Trong căn lầu máu giữa một tinh cầu là khối máu lớn rất xa Thiên Vận Tinh, người đàn ông tóc và lông mi đỏ, áo bào đỏ cảm nhận dư uy thiên kiếp giáng xuống Đông Hải Yêu Linh, thầm hỏi ‘đứa hài tử Tích Tuyết kia bây giờ thế nào’.","bridge":true,"khoang":"@c0552"}],"tuViMoc":[],"nhanMach":[{"ten":"Tích Tuyết","tag":"khac","quanHe":"Đứa hài tử ông lo lắng","ghiChu":"Ông thầm hỏi đứa hài tử Tích Tuyết bây giờ thế nào với vẻ lo lắng."}],"tuiDo":{}},"nguon":["@c0552"]},{"id":"nam-lao-gia-co-yeu-554","name":"Năm lão già Cổ Yêu","aliases":["Con cháu Cổ Yêu"],"cn":"","gioiTinh":"nam","theLuc":[{"ten":"Tộc Cổ","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"khong-ro","blurb":"Năm lão già tóc trắng xóa từ lòng đất Đế Đô Thiên Yêu thành phóng lên, tự xưng con cháu Cổ Yêu đã thoát trói buộc thiên đạo, nhiều lần bị thiên uy quẳng xuống đất.","vaiTro":"Thực thể Cổ Yêu xuất hiện khi thiên kiếp hủy Đế Đô","tinhCach":[{"text":"Cuồng phóng, ngạo nghễ, đứng trong thiên uy vẫn cười cợt mắng chửi","chuong":"@c0554"}],"tabs":{"diem":[{"text":"Tóc trắng xóa, mắt lấp lánh tia sáng yêu dị, thân gầy gò mang khí tức hoang dã","chuong":"@c0554"},{"text":"Tự xưng con cháu Cổ Yêu, đã thoát khỏi trói buộc của thiên đạo","chuong":"@c0554"}],"kinhLich":[{"text":"Khi thiên kiếp Vương Lâm nghiền nát Đế Đô Thiên Yêu thành, năm lão già từ lòng đất phóng lên, phẫn nộ mắng thiên kiếp phá hủy Đế Đô Thiên Yêu quận của họ. Họ cãi cọ loạn về lời lão tổ tông, phóng Yêu lực bao phủ Thiên Yêu thành rồi lao lên hồng vân nhưng nhiều lần bị bàn tay vô hình quẳng xuống đất tạo năm hố sâu.","bridge":true,"khoang":"@c0554"}],"tuVi":"Chưa rõ cảnh giới; vận dụng Yêu lực đặc thù của Cổ Yêu, chống chịu được thiên uy.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Cùng xuất hiện tại Đế Đô khi thiên kiếp giáng xuống Vương Lâm","ghiChu":"@c0554"}],"tuiDo":{}},"nguon":["@c0554"]},{"id":"co-yeu-lao-to-tong","name":"Cổ Yêu","aliases":["Lão tổ tông","Thanh âm bí ẩn","Nghịch tu đệ nhị"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Thiên Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Không rõ (cường giả viễn cổ chống thiên kiếp)","trangThai":"song","blurb":"Tồn tại không hoàn chỉnh trong Yêu Cổ, lão tổ tông của dân Thiên Yêu quận, tự xưng nghịch tu đệ nhị.","vaiTro":"Cường giả viễn cổ ẩn trong Yêu Cổ; lập Long Đàm giáo dục con dân; giao kèo với Vương Lâm.","tabs":{"diem":[{"text":"Thân thể không hoàn chỉnh, không thể rời xa Yêu Cổ vì tấm da Yêu Cổ vốn là của mình năm xưa.","chuong":"@c0555"},{"text":"Hư ảnh hiện hình cao trăm trượng, hai sừng, da đen-tím, khí tức âm u khiến năm lão tổ Thiên Yêu nhận ra ngay.","chuong":"@c0555"},{"text":"Nghịch tu đệ nhị, nhiều lần chống thiên kiếp; nuốt được cả Xích Tiêu Vân Mang.","chuong":"@c0555"}],"kinhLich":[{"chuong":"@c0555","importance":"normal","tieuDe":"Lập giao kèo & chống thiên kiếp giúp Vương Lâm","text":"Lần đầu lộ diện trước Vương Lâm — kể nguồn gốc chín tồn tại không hoàn chỉnh cùng chiến tranh cửu quận Yêu Linh, đề nghị sửa thân thể và ban lực chống thiên kiếp đổi lấy việc Vương Lâm tương lai thu hồi thánh vật tám quận khác. Hiện hư ảnh sau lưng Vương Lâm, cùng thi triển Diệt đạo - Vân toái đập vỡ hồng vân, rồi há miệng nuốt cả Xích Tiêu Vân Mang. Xong việc ợ no, hóa khói xanh biến mất, hẹn ba tháng sau gặp ở Long Đàm."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đối tác giao kèo: sửa thân, chống kiếp, đổi việc thu hồi thánh vật.","ghiChu":"@c0555"},{"ten":"Vân Độn","tag":"khac","quanHe":"Con cháu Thiên Yêu quận, được năm lão tổ giao đưa Vương Lâm về Long Đàm gặp Cổ Yêu.","ghiChu":"@c0555"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0555"]},{"id":"tu-thu","name":"Tử Thử","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"},{"ten":"Hỏa Yêu quận","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Một trong Thập Nhị Kiếm Tiếu của Đại La Kiếm Tông, giành chức Đô Thống ở Hỏa Yêu quận; chứng kiến Vương Lâm điên cuồng thì nảy ý đồ.","vaiTro":"Đô Thống Hỏa Yêu quận, đệ tử Đại La Kiếm Tông","tinhCach":[{"text":"Cẩn trọng, biết tránh né khi gặp đối thủ Vấn Đỉnh điên cuồng nhưng nhanh chóng tính toán cơ hội.","chuong":"@c0558"}],"tabs":{"diem":[{"text":"Một trong nhóm Thập Nhị Kiếm Tiếu của Đại La Kiếm Tông, nay đã phân tán.","chuong":"@c0558"},{"text":"Tu vi Anh Biến hậu kỳ đại viên mãn, làm Đô Thống ở Hỏa Yêu quận.","chuong":"@c0558"}],"kinhLich":[{"chuong":"@c0558","importance":"normal","tieuDe":"Đô Thống Hỏa Yêu quận ra mặt","text":"Tử Thử dẫn ba vạn Yêu binh thủ hạ đi hội họp sư huynh đệ thì thấy đạo lưu tinh gào thét lao tới. Nhận ra đó là tu vi Vấn Đỉnh trong trạng thái điên cuồng, hắn vội lui vào đám Yêu binh tránh né, kinh hãi vì mọi vật trên đường Vương Lâm đi qua đều khô héo. Sau khi thấy Vương Lâm phun máu, hai mắt Tử Thử đột nhiên sáng ngời."},{"chuong":"@c0559","importance":"normal","tieuDe":"Tử vong dưới tay Vương Lâm","text":"Tham lam muốn dùng nguyên thần Vấn Đỉnh trọng thương của Vương Lâm để dưỡng Kiếm Linh, Tử Thử hạ quyết tâm liều mạng, hóa hư ảnh phóng lên trời cùng ba vạn Yêu binh bày trận tập trung sát khí. Nhưng Vương Lâm đảo hướng lao tới với tốc độ kinh người, chụp lấy đại kiếm của hắn ném ra sau rồi điểm nhẹ lên vai khiến thân thể hắn héo rũ, nguyên thần khô héo hóa Sinh Chi Lạc Ấn dung nhập vào Vương Lâm. Đạo kiếm khí kim quang sư tôn tặng còn lưu ở mi tâm chưa kịp sử dụng thì hắn đã chết."}],"tuViMoc":[{"chuong":"@c0558","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Lần đầu ra mặt với tu vi Anh Biến hậu kỳ đại viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Chứng kiến Vương Lâm điên cuồng, nảy ý đồ","ghiChu":"Vội lui tránh khi thấy Vương Lâm Vấn Đỉnh điên cuồng, sau đó thấy hắn phun máu thì hai mắt sáng ngời. @c0558"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Định đoạt nguyên thần Vấn Đỉnh của Vương Lâm nhưng bị giết trong nháy mắt","ghiChu":"@c0559"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0558","@c0559"]},{"id":"mac-to","name":"Mạc Tổ","gioiTinh":"nam","trangThai":"song","blurb":"Cường giả ở tinh cầu Ma Vực trên Thiên Vận Tinh, tu vi Âm Dương Hư Thực nhị ý, có ba đệ tử thân truyền.","vaiTro":"Tông sư Ma Vực, sư phụ của hai đệ tử bị Vương Lâm giết","tabs":{"diem":[{"text":"Tu vi Âm Dương Hư Thực nhị ý, vượt mức tư cách bước vào mảnh đất Yêu Linh","chuong":"@c0559"}],"kinhLich":[{"chuong":"@c0559","importance":"normal","tieuDe":"Mất hai đệ tử thân truyền","text":"Mạc Tổ ở tinh cầu Ma Vực trên Thiên Vận Tinh, có ba đệ tử thân truyền. Hai đệ tử thân truyền tu vi Anh Biến hậu kỳ vào đất Yêu Linh, tham đoạt Yêu Tinh của Vương Lâm và bị giết sạch, để lại mối thù tiềm tàng giữa ông và Vương Lâm."}],"nhanMach":[{"ten":"Hai đệ tử Mạc Tổ","tag":"su-mon","quanHe":"Hai đệ tử thân truyền Anh Biến hậu kỳ, bị Vương Lâm giết trong đất Yêu Linh","ghiChu":"@c0559"}]},"nguon":["@c0559"]},{"id":"hai-de-tu-mac-to","name":"Hai đệ tử Mạc Tổ","gioiTinh":"nam","trangThai":"tu-vong","blurb":"Hai thanh niên áo xám, đệ tử thân truyền của Mạc Tổ, đều tu vi Anh Biến hậu kỳ.","vaiTro":"Hai kẻ tham đoạt Yêu Tinh của Vương Lâm, bị giết","tabs":{"kinhLich":[{"text":"Đang phi hành trong Hỏa Yêu quận, một người cảm nhận sát khí như hung thú viễn cổ và hô sư đệ lui nhanh, nhưng cả hai lại tham đoạt Yêu Tinh của Vương Lâm nên định liên thủ. Vương Lâm quay lại điểm một chỉ vào mi tâm sư đệ khiến người này héo khô, nguyên thần tan vỡ; sư huynh thuấn di vào hư vô vẫn bị Vương Lâm xuyên không gian tạo trảo chộp ra và bóp tan dù van xin là đệ tử Mạc Tổ.","bridge":true,"khoang":"@c0559"}],"nhanMach":[{"ten":"Mạc Tổ","tag":"su-mon","quanHe":"Sư phụ, tông sư Ma Vực","ghiChu":"@c0559"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Định đoạt Yêu Tinh của Vương Lâm nhưng bị giết sạch","ghiChu":"@c0559"}]},"nguon":["@c0559"]},{"id":"duan-dong","name":"Duẫn Đông","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Hỏa Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Yêu tướng (Yêu lực gần ba mươi vạn)","trangThai":"tu-vong","blurb":"Yêu tướng Hỏa Yêu quận mặc giáp thanh sắc, xung phong giao chiến với Vương Lâm để lập công nhưng bị giết ngay đòn đầu.","vaiTro":"Yêu tướng tốc chiến đầu tiên trong trận vây diệt Vương Lâm tại Vạn Yêu sơn.","tinhCach":[{"text":"Háo công, hung hăng, muốn lập công trước mặt Phó soái","chuong":"@c0560"}],"tabs":{"diem":[{"text":"Tự tin Yêu lực gần ba mươi vạn thừa sức giết tu sĩ Vấn Đỉnh đang trọng thương","chuong":"@c0560"}],"kinhLich":[{"text":"Duẫn Đông ôm quyền xin xuất chiến, hóa thành đạo thanh quang lao về phía Vương Lâm với sát khí, hét lớn dồn toàn Yêu lực chấn nhiếp tinh thần đối phương cùng mười vạn Yêu binh trợ uy. Nhưng luồng sát khí nồng đậm đó lại kích bùng chiến ý điên cuồng của Vương Lâm; hắn không kịp né Tịch Diệt Chỉ, cơ thể héo rũ rồi vỡ nát.","bridge":true,"khoang":"@c0560"},{"importance":"normal","chuong":"c0627","text":"Nhị phẩm tộc vệ Huyễn gia trên Thiên Huyễn chủ tinh, tu vi đỉnh Vấn Đỉnh trung kỳ, khoảng ba mươi tuổi; si mê nhan sắc Liễu Mi (tiểu thư Huyễn Mi).","nguonNblm":true},{"importance":"normal","chuong":"c0629","text":"Đạp tinh la bàn lao vào tầng cương phong Nhiễm Vân tinh, tản thần thức và tiên lực, ngạo nghễ điên cuồng quát tu sĩ Vấn Đỉnh ra gặp; tiếng quát như sấm khiến tu sĩ yếu phun máu.","nguonNblm":true},{"importance":"normal","chuong":"c0630","text":"Dung nhập nửa thân vào hư vô định Na Di trốn, nhưng bị Thất Tinh kiếm trận và tà hồn Thất Sanh Tiếu chộp kéo ra, áp sát khống chế nguyên thần trong vài hơi thở.","nguonNblm":true},{"importance":"normal","chuong":"c0633","text":"Được nhắc lại: theo lời Nhiễm Học Phong, người thật sự giết Huyễn Đông là Hứa Mộc.","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0560","canhGioi":"Yêu tướng","text":"Yêu lực gần ba mươi vạn, tự nhận thừa sức diệt tu sĩ Vấn Đỉnh trọng thương.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Xung phong giao chiến rồi bị Vương Lâm giết bằng Tịch Diệt Chỉ","ghiChu":"@c0560"},{"ten":"Phó soái (Hỏa Yêu quận)","tag":"su-mon","quanHe":"Cấp trên tọa trấn, Duẫn Đông muốn lập công trước mặt","ghiChu":"@c0560"}],"tuiDo":{}},"nguon":["@c0560"]},{"id":"pho-soai-hoa-yeu-quan","name":"Phó soái (Hỏa Yêu quận)","cn":"","aliases":["Người đàn ông trung niên (Hỏa Yêu quận)"],"gioiTinh":"nam","theLuc":[{"ten":"Hỏa Yêu quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Phó soái (thân phận tôn quý)","trangThai":"song","blurb":"Phó soái Hỏa Yêu quận thần thái âm trầm, bất đắc dĩ tọa trấn chỉ huy trận vây diệt Vương Lâm theo lệnh Yêu Đế.","vaiTro":"Người chỉ huy tối cao trong trận bao vây Vương Lâm tại Vạn Yêu sơn.","tinhCach":[{"text":"Âm trầm, kiêu ngạo, ban đầu xem nhẹ Vương Lâm và thấy phiền vì phải huy động lực lượng lớn","chuong":"@c0560"},{"text":"Bi��t thận trọng khi thấy đối thủ thực sự nguy hiểm","chuong":"@c0560"}],"tabs":{"diem":[{"text":"Thân phận tôn quý, vốn có chuyện riêng muốn đến Thiên Văn Thành thì bị Yêu Đế giữ lại","chuong":"@c0560"},{"text":"Lần đầu lộ vẻ thận trọng khi chứng kiến Vương Lâm một đòn giết Duẫn Đông","chuong":"@c0560"}],"kinhLich":[{"text":"Vừa đến Vạn Yêu sơn trên đường tới Thiên Văn Thành, Phó soái nhận lệnh Yêu Đế phải ở lại mấy ngày dẫn dắt hơn mười Yêu tướng và mười vạn Yêu binh giết Vương Lâm. Ban đầu hắn thấy phiền vì cho rằng diệt một tu sĩ Vấn Đỉnh trọng thương không cần lực lượng lớn; sau khi Vương Lâm giết Duẫn Đông và triệu ba vạn Thương Long, hắn lần đầu lộ vẻ thận trọng rồi ra lệnh giết.","bridge":true,"khoang":"@c0560"}],"tuViMoc":[],"nhanMach":[{"ten":"Yêu Đế","tag":"su-mon","quanHe":"Phụng lệnh Yêu Đế ở lại tọa trấn diệt Vương Lâm","ghiChu":"@c0560"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Mục tiêu hắn được lệnh vây diệt","ghiChu":"@c0560"},{"ten":"Duẫn Đông","tag":"khac","quanHe":"Yêu tướng dưới trướng xung phong xuất chiến rồi tử trận","ghiChu":"@c0560"}],"tuiDo":{}},"nguon":["@c0560"]},{"id":"ong-gia-ke-chuyen-van-thien-tong","name":"Ông già kể chuyện (Vân Thiên Tông)","gioiTinh":"nam","trangThai":"song","blurb":"Lão già ở Vân Thiên Tông, năm xưa từng tiếp xúc Vương Lâm, kể truyền thuyết về pho tượng cho cháu trai.","tabs":{"diem":[],"kinhLich":[{"text":"Lão già than nhẹ, kể cho cháu trai nghe về người được tạc tượng ở Vân Thiên Tông — chuỗi chiến tích lẫy lừng của Vương Lâm khắp Chu Tước tinh. Khi cháu hỏi tên, ông cho biết người đó là Vương Lâm, không rõ đã đi đâu; ông từng tiếp xúc Vương Lâm năm xưa nhưng e rằng nay hắn đã không còn nhớ ông là ai.","bridge":true,"khoang":"@c0567"}],"nhanMach":[{"ten":"Người trẻ tuổi (cháu trai)","tag":"ho-hang","quanHe":"Cháu trai của ông già, người nghe truyền thuyết.","ghiChu":"@c0567"}],"tuiDo":{}},"nguon":["@c0567"]},{"id":"nguoi-tre-tuoi-chau-trai-van-thien-tong","name":"Người trẻ tuổi (cháu trai)","gioiTinh":"nam","trangThai":"song","blurb":"Cháu trai của ông già, nghe truyền thuyết về Vương Lâm rồi kích động muốn trở thành người như vậy.","tabs":{"diem":[],"kinhLich":[{"text":"Người trẻ tuổi nghe ông già kể về Vương Lâm, kích động hỏi tên người được tạc tượng và bộc lộ khát vọng trở thành người như vậy.","bridge":true,"khoang":"@c0567"}],"nhanMach":[{"ten":"Ông già kể chuyện (Vân Thiên Tông)","tag":"ho-hang","quanHe":"Ông nội kể truyền thuyết cho mình.","ghiChu":"@c0567"}],"tuiDo":{}},"nguon":["@c0567"]},{"id":"co-van-phong-yeu-de","name":"Yêu đế","cn":"","aliases":["Yêu Đế","Đế Quân"],"gioiTinh":"nam","theLuc":[{"ten":"Yêu tộc (Yêu Đế)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Yêu Đế của yêu tộc, chính là thanh niên từng uống rượu suốt đêm với Vương Lâm năm xưa; đan điền ẩn một viên yêu tinh lớn, sở hữu Đế kiếm. (+) Bậc thống lĩnh Yêu linh chi địa từng ban lời cho phép phong chức cho người ngoài đến nếu đủ tu vi. [CAN-SOAT-GOP]","vaiTro":"Người đứng đầu yêu tộc quân; tỏ thiện ý với Vương Lâm.","tinhCach":[{"text":"Trầm ổn, uy nghiêm tự nhiên dù ăn mặc tầm thường","chuong":"@c0570"},{"text":"Trọng tình, không muốn trở mặt, xem Vương Lâm là người cùng đường","chuong":"@c0570"}],"tabs":{"diem":[{"text":"Là Yêu Đế nhưng năm xưa không lộ tí yêu lực, chỉ khiến người ta thấy bất thường","chuong":"@c0570"},{"text":"Đan điền ẩn một viên yêu tinh lớn khoảng nắm tay, không tỏa yêu lực","chuong":"@c0570"}],"kinhLich":[{"chuong":"@c0570","importance":"normal","tieuDe":"Lộ thân phận Yêu Đế","text":"Bước ra từ tòa lầu các di chuyển theo đại quân, tự xưng Cổ Vân Phong, xác nhận với Vương Lâm địa vị hai bên tương đương. Thu phục Đế kiếm sau khi Vương Lâm chấn vỡ kiếm khí, trao Vương Lâm ngọc giản điều động Thiên soái và tuyên bố hắn là sứ giả Tổ Linh, tỏ thiện ý xem hắn là người cùng đường."},{"bridge":true,"khoang":"@c0509","text":"Được Tả dực Yêu tương nhắc tới: Yêu đế từng có lời ban chức cho người ngoài đến nếu đủ tu vi."},{"chuong":"@c0543","importance":"normal","tieuDe":"Vắng mặt bất thường tại trận Yêu Tướng","text":"Đế Quân từng đích thân truyền thần thông Yêu Nhiên cho Mạc Lệ Hải khi hắn thành Yêu Tướng. Tại trận chiến Yêu Tướng, ngai Yêu Đế phía đông để trống suốt ba tiếng trống vì Đế Quân không tới, khiến Mạc Lệ Hải lẩm bẩm thắc mắc nguyên do."}],"tuViMoc":[{"chuong":"@c0570","canhGioi":"Vấn Đỉnh trở lên","text":"Tu vi cực cao, ngang hàng sứ giả Tổ Linh; đan điền ẩn viên yêu tinh lớn không tỏa yêu lực.","importance":"normal"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Người cùng đường, sứ giả Tổ Linh","ghiChu":"Từng uống rượu suốt đêm năm xưa; trao ngọc giản và tin tức Mặc Phi."},{"ten":"Song nhi","tag":"ho-hang","quanHe":"Cháu gái","ghiChu":"Kiếm linh của Đế kiếm; Yêu Đế không muốn để người khác ức hiếp Song nhi trước mặt mình."},{"ten":"Mạc Lệ Hải","tag":"khac","quanHe":"Đích thân truyền thần thông Yêu Nhiên cho Mạc Lệ Hải","ghiChu":"@c0543"}],"tuiDo":{"phapBao":[{"ten":"Đế kiếm","moTa":"Bảo kiếm cất trong hư vô, kiếm linh là cháu gái Song nhi; xé hư không xuất hiện, rít bén nhọn phóng kiếm khí.","nguon":"@c0570"}],"khac":[{"ten":"Ngọc giản trắng","moTa":"Chứa yêu khí độc đáo, dùng điều động Thiên soái; trao cho Vương Lâm.","nguon":"@c0570"}]}},"nguon":["@c0570","@c0509","@c0543"]},{"id":"song-nhi-kiem-linh-de-kiem","name":"Song nhi","cn":"","aliases":["Kiếm linh Đế kiếm"],"gioiTinh":"nu","theLuc":[{"ten":"Yêu tộc (Yêu Đế)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Kiếm linh của Đế kiếm, cháu gái Yêu Đế; hiện hình bóng người con gái, oán hận Hứa Lập Quốc và Vương Lâm suốt mười năm.","vaiTro":"Kiếm linh Đế kiếm, thúc giục kiếm tấn công Vương Lâm.","tinhCach":[{"text":"Oán hận dai dẳng, nóng nảy khi gặp Hứa Lập Quốc","chuong":"@c0570"}],"tabs":{"diem":[{"text":"Là kiếm linh đồng thời là cháu gái Yêu Đế, được Yêu Đế che chở","chuong":"@c0570"}],"kinhLich":[{"text":"Khi Hứa Lập Quốc đòi gặp lại sau mười năm, Song nhi hiện hình bóng người con gái, tức giận trừng mắt nhìn Vương Lâm và Hứa Lập Quốc, thúc giục Đế kiếm phóng kiếm khí công kích, nhưng bị Vương Lâm chấn vỡ toàn bộ.","bridge":true,"khoang":"@c0570"}],"tuViMoc":[],"nhanMach":[{"ten":"Cổ Vân Phong","tag":"ho-hang","quanHe":"Ông/Yêu Đế","ghiChu":"Yêu Đế che chở, không muốn để người khác ức hiếp Song nhi."},{"ten":"Hứa Lập Quốc","tag":"doi-thu","quanHe":"Oán hận","ghiChu":"Bị Hứa Lập Quốc theo đuổi/đòi gặp; oán hận suốt mười năm."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Thúc giục Đế kiếm tấn công Vương Lâm."}],"tuiDo":{}},"nguon":["@c0570"]},{"id":"hoi-tru","name":"Hợi Trư","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ","trangThai":"tu-vong","blurb":"Người trung niên đeo kiếm lớn hộ vệ phía sau phó soái Mặc Phi, người Đại La Kiếm Tông sở hữu kiếm khí Lăng Thiên Hậu, bị Vương Lâm chém đầu rồi Sưu hồn.","vaiTro":"Đối thủ thoáng qua bị Vương Lâm trảm sát","tinhCach":[{"text":"Dáng vẻ tiên phong đạo cốt, khép mắt điềm tĩnh","chuong":"@c0571"}],"tabs":{"diem":[{"text":"Người Đại La Kiếm Tông sở hữu kiếm khí Lăng Thiên Hậu","chuong":"@c0571"}],"kinhLich":[{"text":"Đứng sau lưng phó soái Mặc Phi trên đuôi yêu thú giống Lân, khép mắt đeo kiếm lớn dáng tiên phong đạo cốt. Khi Vương Lâm tới, hắn bắt pháp quyết thả Khuyển kiếm hóa hồn heo ác đen, định thi triển kiếm khí Lăng Thiên Hậu nhưng bị Hoàng Tuyền trấn áp; bị Vương Lâm điểm một chỉ giết chết, cắt đầu, phong ấn nguyên thần rồi Sưu hồn ném vào Hồn phiên làm chủ hồn.","bridge":true,"khoang":"@c0571"}],"tuViMoc":[{"chuong":"@c0571","canhGioi":"Anh Biến hậu kỳ","text":"Tu vi Anh Biến hậu kỳ; bị Vương Lâm (Vấn Đỉnh) phong ấn nguyên thần không tốn sức.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm chém đầu, Sưu hồn ném vào Hồn phiên làm chủ hồn"},{"ten":"Mặc Phi","tag":"dong-minh","quanHe":"Hộ vệ phía sau phó soái Mặc Phi"},{"ten":"Tham Lang","tag":"dong-minh","quanHe":"Cùng Đại La Kiếm Tông ở đất Yêu Linh"}],"tuiDo":{"phapBao":[{"ten":"Khuyển kiếm","moTa":"Thanh kiếm lớn đeo sau lưng, khi bay ra biến ảo thành hồn một con heo ác đen kịt; sau bị Vương Lâm bắt mang đi.","trangThai":"bi-cuop","nguon":"@c0571"}]}},"nguon":["@c0571"]},{"id":"lao-to-thanh-trang-chuong-khi","name":"Lão tổ (lão già dáng cực kỳ thấp bé)","cn":"","aliases":["Lão phu"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Chủ tòa thành núi đá trắng trong vùng chướng khí biên giới quận Hỏa Yêu và Kim Yêu, ra lệnh truy bắt Vương Lâm để luyện thành Tiên vệ.","vaiTro":"Phản diện tiềm tàng — kẻ nhìn trúng Vương Lâm.","tinhCach":[{"text":"Lạnh lùng, tự tin vào thực lực Tiên vệ dưới trướng","chuong":"@c0574"}],"tabs":{"diem":[{"text":"Tự xưng lão phu, dáng người cực kỳ thấp bé, ẩn cư trong thành trắng giữa chướng khí","chuong":"@c0574"}],"kinhLich":[{"chuong":"@c0574","importance":"normal","tieuDe":"Ra lệnh truy bắt Vương Lâm","text":"Nghe thuộc hạ bẩm báo đã tra ra vị trí Vương Lâm — kẻ mất tích ở quận đô thành Cổ Yêu hai mươi năm trước, nay làm sứ giả Cổ Yêu nhưng chưa rõ tu vi. Lão tổ phái ba tiểu đội thêm một Tiên vệ đi bắt Vương Lâm để dạy dỗ rồi luyện thành Tiên vệ mới, tin rằng chỉ cần hắn chưa đạt Vấn Đỉnh thì Tiên vệ đủ sức bắt."},{"text":"Rút Toả Thần bút uy áp cả Kỳ Lân thú, khoe là vật Tiên giới điểm hoá tu sĩ hạ giới và đuổi Vương Lâm đi. Bị Vương Lâm nói toạc bí mật không có nguyên lực, thẹn quá hoá giận phun tiên huyết vẽ phù văn phản công nhưng bị Lôi thú đánh sụp.","bridge":true,"khoang":"@c0579"},{"bridge":true,"khoang":"@c0579","text":"Lộ bản tính nhát gan, bỏ chạy qua hơn mười loại thần thông độn thuật; bị Vương Lâm dùng Na Di thuật chặn đầu, đành ném Tiên bút vào hư vô rồi cùng đường rút Khốn Tiên võng van cầu nó đừng trói mình."}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ Lão tổ nhìn trúng, ra lệnh truy bắt","ghiChu":""},{"ten":"Bóng đen (thuộc hạ Lão tổ)","tag":"cap-tren","quanHe":"Thuộc hạ bẩm báo và nhận lệnh đi bắt người","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm áp đảo, truy đuổi quyết đoạt pháp bảo Tiên giới","ghiChu":"@c0579"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0574","@c0579"]},{"id":"bong-den-thuoc-ha-lao-to","name":"Bóng đen (thuộc hạ Lão tổ)","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Thuộc hạ của Lão tổ thành trắng, quỳ bẩm báo đã tra ra vị trí Vương Lâm và nhận lệnh đi bắt.","vaiTro":"Thuộc hạ trinh sát của Lão tổ.","tinhCach":[],"tabs":{"diem":[{"text":"Tra được vị trí Vương Lâm nhưng chưa rõ tu vi vì tiểu đội bắt người trước bị giết sạch","chuong":"@c0574"}],"kinhLich":[{"text":"Quỳ bẩm báo với Lão tổ rằng đã tra ra vị trí Vương Lâm — kẻ mất tích ở quận đô thành Cổ Yêu hai mươi năm trước, nay được bổ nhiệm làm sứ giả Cổ Yêu; nhưng chưa tra được tu vi vì tiểu đội bắt người trước ở quận Thiên Yêu đã bị giết sạch không truyền tin. Sau đó nhận lệnh đi bắt.","bridge":true,"khoang":"@c0574"}],"nhanMach":[{"ten":"Lão tổ (lão già dáng cực kỳ thấp bé)","tag":"cap-tren","quanHe":"Chủ nhân, ra lệnh truy bắt Vương Lâm","ghiChu":""}],"tuiDo":{}},"nguon":["@c0574"]},{"id":"ton-nhuoc-nam","name":"Tôn Nhược Nam","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Muội muội của Tôn Vân Sơn, một trong ba nữ tử bị Lão Tổ Liên minh hút tinh khí.","vaiTro":"Nữ tử bị Lão Tổ hút tinh khí trong vùng chướng khí.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Là một trong ba nữ tử tướng mạo tuyệt trần ngồi đối diện Lão Tổ Liên minh trong tòa thành giữa chướng khí; khí màu hồng nhạt từ thất khiếu bị lão già nuốt vào, lộ vẻ cực kỳ mệt mỏi và dấu hiệu già đi khi Vương Lâm bước vào.","bridge":true,"khoang":"@c0576"}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn Vân Sơn","tag":"ho-hang","quanHe":"Huynh trưởng","ghiChu":"@c0576"},{"ten":"Lão Tổ Liên minh","tag":"doi-thu","quanHe":"Bị lão già hút tinh khí","ghiChu":"@c0576"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0576"]},{"id":"lao-to-lien-minh","name":"Lão Tổ Liên minh","cn":"","aliases":["Lão già thấp bé","Tiên giới Lão Tổ"],"gioiTinh":"nam","theLuc":[{"ten":"Tu sĩ Liên minh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Lão tổ của Tu sĩ Liên minh, thân mình thấp bé, tự xưng đến từ Tiên giới và nắm Tiên chủng.","vaiTro":"Thủ lĩnh Tu sĩ Liên minh, đối thủ mới của Vương Lâm.","tinhCach":[{"text":"Quỷ dị, hai lần trêu chọc Vương Lâm","chuong":"@c0576"}],"tabs":{"diem":[{"text":"Tự xưng đến từ Tiên giới, nắm Tiên chủng — vật trừ hắn không ai phá được","chuong":"@c0576"}],"kinhLich":[{"text":"Trong tòa thành sâu giữa chướng khí, lão già thân mình thấp bé khoanh chân ngồi đối diện ba nữ tử tuyệt trần (gồm Tôn Nhược Nam), khí hồng từ thất khiếu hóa hư ảnh tiên tử múa quanh rồi bị lão nuốt. Khi Vương Lâm bước vào, lão mở mắt phóng kim mang, thi triển Hồn Phách thuật khiến chướng khí gào rít, nhưng bị Vương Lâm phá bằng Hồn Tuyền.","bridge":true,"khoang":"@c0576"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Hai lần trêu chọc, bị Vương Lâm truy lùng diệt","ghiChu":"@c0576"},{"ten":"Tiên vệ","tag":"cap-tren","quanHe":"Thuộc hạ được lão ban Toái ngọc","ghiChu":"@c0576"},{"ten":"Tôn Nhược Nam","tag":"doi-thu","quanHe":"Hút tinh khí","ghiChu":"@c0576"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0576"]},{"id":"tien-ve-ao-den","name":"Tiên vệ","cn":"","aliases":["Người đàn ông áo đen"],"gioiTinh":"nam","theLuc":[{"ten":"Tu sĩ Liên minh","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến trung kỳ","trangThai":"tu-vong","blurb":"Thuộc hạ của Lão Tổ Liên minh, tu vi Vấn Đỉnh là giả do Toái ngọc ban, thật chỉ Anh Biến trung kỳ.","vaiTro":"Tiên vệ bị Vương Lâm Sưu hồn rồi luyện hóa lấy Toái ngọc.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0576","importance":"normal","tieuDe":"Bị Sưu hồn và luyện hóa","text":"Bị Vương Lâm hư không chộp lên, đặt tay lên Thiên Linh thi triển Sưu hồn: phát hiện không có nguyên khí, tu vi Vấn Đỉnh là do Toái ngọc trong Nguyên thần ban, thật chỉ Anh Biến trung kỳ, trí nhớ trống rỗng trước khi thành Tiên vệ. Bị Vương Lâm chấn Nguyên thần phun lửa luyện hóa, còn lại một mảnh Toái ngọc."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão Tổ Liên minh","tag":"cap-tren","quanHe":"Chủ nhân, ban Toái ngọc","ghiChu":"@c0576"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm Sưu hồn và luyện hóa","ghiChu":"@c0576"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0576"]},{"id":"tieu-hac-tu","name":"Tiểu hắc tử","gioiTinh":"khong-ro","theLuc":[],"trangThai":"song","blurb":"Linh của thanh loan đao màu đen của Vương Lâm; được sai đuổi theo cây Tiên bút vào hư vô.","vaiTro":"Đao linh dưới trướng Vương Lâm","tabs":{"diem":[{"text":"Linh trú trong thanh loan đao đen (hắc đao) của Vương Lâm, chịu Hứa Lập Quốc điều khiển","chuong":"@c0579"}],"kinhLich":[{"canhGioi":"","text":"Khi lão già ném Toả Thần bút vào hư vô, Tiểu hắc tử mang Hứa Lập Quốc biến mất vào hư vô đuổi theo cây bút theo lệnh của chủ.","bridge":true,"khoang":"@c0579"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"su-mon","quanHe":"Chủ nhân — Vương Lâm xuất thanh hắc đao và sai đuổi Tiên bút","ghiChu":"@c0579"},{"ten":"Hứa Lập Quốc","tag":"dong-minh","quanHe":"Hứa Lập Quốc trực tiếp ra lệnh cho Tiểu hắc tử đuổi theo Tiên bút","ghiChu":"@c0579"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0579"]},{"id":"loi-suat-pho-soai-loi-yeu-quan","name":"Lôi Suất","cn":"","aliases":["Phó soái Lôi Yêu Quận"],"gioiTinh":"nam","theLuc":[{"ten":"Lôi Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh sơ kỳ (tương đương)","trangThai":"khong-ro","blurb":"Phó soái Lôi Yêu Quận, tráng hán trung niên lôi hệ; phá được màn sương đen rồi bị Vương Lâm định thân đánh văng phun máu.","vaiTro":"Phó soái Lôi Yêu Quận dẫn mười vạn yêu binh vây phương Bắc Luyện Hồn bộ lạc.","tinhCach":[{"text":"Tham lam, thèm muốn dị bảo để dâng Yêu Đế lập công","chuong":"@c0583"}],"tabs":{"diem":[{"text":"Tráng hán trung niên lôi hệ, người duy nhất trong quân không mặc giáp, thân ẩn lôi quang, bước tới đâu mặt đất cháy đen","chuong":"@c0583"},{"text":"Tốc độ và uy lực tương đương tu sĩ Vấn Đỉnh sơ kỳ","chuong":"@c0583"}],"kinhLich":[{"text":"Dẫn mười vạn yêu binh Lôi Yêu Quận vây phương Bắc Luyện Hồn bộ lạc, Lôi Suất tung một quyền chứa yêu lực hoá Lôi Long phá thủng một lỗ hổng trên màn sương đen Tôn Hồn Phiên rồi tiến vào. Khi định huỷ toà tháp thờ phụng, hắn bị một tiếng ‘Định’ của Vương Lâm khoá cứng, chỉ còn đôi mắt cử động; tiếp đó bị vung tay áo đánh phun máu văng khỏi bộ lạc, thân như sao băng rơi xuống đất bất động.","bridge":true,"khoang":"@c0583"}],"tuViMoc":[{"chuong":"@c0583","canhGioi":"Vấn Đỉnh sơ kỳ (tương đương)","text":"Bay lên với tốc độ tương đương tu sĩ Vấn Đỉnh sơ kỳ, đủ sức phá một lỗ hổng trên màn sương đen có người chủ trì.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm định thân và đánh văng","ghiChu":"Định huỷ toà tháp thì bị một tiếng ‘Định’ khoá cứng, vung tay áo đánh phun máu."},{"ten":"Nữ Phó soái Thuỷ Yêu Quận","tag":"dong-minh","quanHe":"Cùng vây Luyện Hồn bộ lạc, ước định chia phần","ghiChu":"Lôi Suất lấy dị bảo, Thuỷ Yêu Quận bắt tộc nhân về nghiên cứu."},{"ten":"Yêu Đế","tag":"khac","quanHe":"Quân chủ Yêu Linh mà Lôi Suất muốn dâng dị bảo","ghiChu":"Định lấy màn sương đen về dâng để lập công."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0583"]},{"id":"nu-pho-soai-thuy-yeu-quan","name":"Nữ Phó soái Thuỷ Yêu Quận","cn":"","aliases":["Phó soái Thuỷ Yêu Quận","Nữ thi áo trắng"],"gioiTinh":"nu","theLuc":[{"ten":"Thuỷ Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Nữ Phó soái Thuỷ Yêu Quận tướng mạo tầm thường, mắt ẩn hàn mang; mưu chia phần bắt tộc nhân nhưng bị định thân rồi tháo chạy.","vaiTro":"Phó soái Thuỷ Yêu Quận dẫn mười vạn yêu binh vây phương Nam Luyện Hồn bộ lạc.","tinhCach":[{"text":"Thận trọng, mưu trí, biết phân tích uy lực địch trước khi ra tay","chuong":"@c0583"}],"tabs":{"diem":[{"text":"Nữ tử tướng mạo tầm thường, đôi mắt ẩn hàn mang","chuong":"@c0583"},{"text":"Sở hữu thủ đoạn đặc biệt: thoát khỏi Định Thân thuật sau ba tức nhờ toàn thân loé lam quang","chuong":"@c0583"}],"kinhLich":[{"text":"Dẫn mười vạn yêu binh Thuỷ Yêu Quận vây phương Nam Luyện Hồn bộ lạc, ước định để Lôi Suất lấy dị bảo còn mình bắt toàn bộ tộc nhân về nghiên cứu, ai phản kháng giết thẳng tay. Khi Vương Lâm toàn lực thi triển Định Thân thuật, nàng hô lui binh và triển trận pháp đều chậm, bị định trụ; sau ba tức toàn thân loé lam quang thoát ra, kinh sợ cùng cực xoay người bỏ chạy.","bridge":true,"khoang":"@c0583"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Định Thân thuật của Vương Lâm định trụ","ghiChu":"Loé lam quang thoát định sau ba tức rồi bỏ chạy."},{"ten":"Lôi Suất","tag":"dong-minh","quanHe":"Cùng vây bộ lạc, ước định chia phần","ghiChu":"Phân tích màn sương đen, để Lôi Suất phá trận lấy dị bảo."},{"ten":"Yêu Tương (Thuỷ Yêu Quận)","tag":"dong-minh","quanHe":"Yêu Tương bản Quận đi cùng, bàn ước định chia phần","ghiChu":"Đối thoại phân tích màn sương đen do hồn phách tạo thành."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0583"]},{"id":"co-yeu-hoa-yeu-quan","name":"Cổ Yêu của Hoả Yêu Quận","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Hoả Yêu Quận","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Cổ Yêu","trangThai":"song","blurb":"Cổ Yêu trú tại Thánh địa Yêu Cốc Hoả Yêu Quận, kẻ dựng phong ấn yêu mạc bao quanh đế đô.","vaiTro":"Cổ Yêu cai quản Hoả Yêu Quận, phong ấn đế đô và đối đầu Vương Lâm.","tinhCach":[{"text":"Cao ngạo, xem con dân chỉ là vật giáo hoá để khôi phục yêu lực","chuong":"@c0584"}],"tabs":{"diem":[{"text":"Phóng thần thức quát “Cút!” như sấm khi Vương Lâm thử phá phong ấn","chuong":"@c0584"}],"kinhLich":[{"text":"Cổ Yêu Hoả Yêu Quận theo Thiên Yêu Quận dùng thần thông phong ấn đế đô, trú sâu trong Thánh địa Yêu Cốc. Khi Vương Lâm điểm ngón tay hắc mang vào yêu mạc, hắn phóng một đạo thần thức mãnh liệt xông ra quát “Cút!”, nhưng bị Vương Lâm dùng ấn quyết yêu khí hoá giải; hắn gầm phẫn nộ khi nhận ra Vương Lâm do Bối La phái tới.","bridge":true,"khoang":"@c0584"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối đầu","ghiChu":"Quát đuổi và phẫn nộ với Vương Lâm khi hắn thử phá phong ấn đế đô."}],"tuiDo":{}},"nguon":["@c0584"]},{"id":"nu-tu-bi-sat-luyen-hon-584","name":"Nữ tử (bị Vương Lâm hạ sát)","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"không-ro","trangThai":"tu-vong","blurb":"Nữ tử vô danh bị ba kiếm quang và ba hồn thú của Vương Lâm hạ sát, hồn phách bị Tử Thử Tà hồn ngậm giữ.","vaiTro":"Nạn nhân thoáng qua trong đòn thử nghiệm Tiên thuật của Vương Lâm.","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"text":"Bị ba đạo kiếm quang cùng ba hồn thú Tử Thử, Hợi Trư, Mạt Dương của Vương Lâm đuổi kịp, ba thanh kiếm xuyên qua thân khiến nàng bỏ mình trong sương máu; hồn phách bị Tử Thử Tà hồn ngậm giữ.","bridge":true,"khoang":"@c0584"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị hạ sát","ghiChu":"Bị Vương Lâm giết và thu hồn phách."}],"tuiDo":{}},"nguon":["@c0584"]},{"id":"do-kien","name":"Đỗ Kiến","cn":"","aliases":["Hồng bào thanh niên"],"gioiTinh":"nam","theLuc":[{"ten":"Hệ phái Thiên Vận Tử","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Xích hệ đệ tử của Thiên Vận Tử, anh tuấn ngạo khí; phát hiện vết nứt nghi là Triều Tịch thâm uyên và rủ Vương Lâm kết bạn nhưng trong lòng đầy đố kị ác ý.","vaiTro":"Xích hệ đệ tử Thiên Vận Tử, người dẫn nhóm tới Vân Vụ sơn hải.","tinhCach":[{"text":"Ngạo khí như thiên chi kiêu tử, bề ngoài tươi cười ôn hòa như huynh trưởng.","chuong":"@c0589"},{"text":"Trong lòng nham hiểm, đầy ác ý và đố kị với người tài giỏi hơn mình.","chuong":"@c0589"}],"tabs":{"diem":[{"text":"Xích hệ đệ tử Thiên Vận Tử, tu vi đã chạm ngưỡng Vấn Đỉnh nhưng chưa dám vượt cửa sinh tử.","chuong":"@c0589"},{"text":"Người phát hiện vết nứt trong vân hải nghi là Triều Tịch thâm uyên.","chuong":"@c0589"}],"kinhLich":[{"text":"Đỗ Kiến dẫn Mộ Dung Trác cùng hai nữ tử Phù Vân phái là Triệu Y Huyên và Từ Phi tới Vân Vụ sơn hải của Thủy Yêu quận, tiết lộ đã phát hiện một vết nứt trong vân hải nghi chính là Triều Tịch thâm uyên trong lời đồn. Khi Vương Lâm xuất hiện, hắn rủ kết bạn cùng vào thâm uyên nhưng ngấm ngầm ôm đố kị: nhớ trăm năm trước Vương Lâm chỉ là Anh Biến trung kỳ đến từ phế khí tinh, nay đã vọt lên Vấn Đỉnh sơ kỳ, sợ địa vị tử hệ của hắn về sau tăng vọt.","bridge":true,"khoang":"@c0589"},{"text":"Đỗ Kiến phun tiên huyết hóa vô số hạt huyết và ném bướu thịt ô uế chi nhục tự nổ, nhưng đều bị Vương Lâm dùng Hoàng Tuyền cuốn sạch. Hắn bị Vương Lâm phong ấn nguyên thần, chặt đứt liên hệ với thân thể, rồi cấm chế bằng Cấm Phiên và thu vào túi trữ vật.","bridge":true,"khoang":"@c0591"},{"text":"Nguyên thần Đỗ Kiến vốn sẽ bị lửa nguyên khí thiêu chết trong quá trình Vấn Đỉnh, nhưng Vương Lâm hút sạch lửa cứu hắn. Hơn mười ngày sau nguyên thần dung hợp, đạt Vấn Đỉnh Sơ Kỳ — tu sĩ Vấn Đỉnh yếu nhất, không thể chống cự Vương Lâm. Hắn vừa oán hận vừa cảm kích, nhiều nhất là hối hận và sợ hãi.","bridge":true,"khoang":"@c0608"},{"chuong":"@c0608","importance":"major","tieuDe":"Bị luyện chế thành Tiên Vệ Đồng cấp","text":"Biết phản kháng sẽ chết ngay, Đỗ Kiến đành đánh cuộc gật đầu để Vương Lâm luyện chế thành Tiên Vệ. Bị in ấn quyết, qua nhiều tháng tế luyện hắn hóa thành khôi lỗi thân ảnh gầy gò, da tái nhợt không máu, toàn thân phát khí âm hàn, đạt Đồng cấp Tiên Vệ."},{"chuong":"@c0608","importance":"major","tieuDe":"Được cứu, đạt Vấn Đỉnh Sơ Kỳ","text":"Trong lúc nguyên thần sắp bị lửa nguyên khí thiêu hủy, Đỗ Kiến được Vương Lâm hút lửa cứu nguy. Hơn mười ngày sau nguyên thần dung hợp với thiên địa nguyên khí còn lại, đạt cảnh giới Vấn Đỉnh — song do nguyên khí tổn hao nhiều nên chỉ là Vấn Đỉnh Sơ Kỳ, tu sĩ Vấn Đỉnh yếu nhất, không thể chống cự Vương Lâm."},{"chuong":"@c0608","importance":"major","tieuDe":"Bị luyện chế thành Tiên Vệ","text":"Biết số kiếp đã định, nếu phản kháng sẽ tử vong ngay, Đỗ Kiến đành gật đầu chấp nhận làm vật liệu luyện chế Tiên Vệ. Vương Lâm in ấn quyết lên giữa lông mày hắn, qua nhiều tháng tế luyện biến hắn thành khôi lỗi: thân ảnh gầy gò, phát khí âm hàn, da tái nhợt không máu (máu đã dung nhập gân cốt), cuối cùng đạt Tiên Vệ Đồng cấp."},{"chuong":"@c0608","importance":"normal","tieuDe":"Đạt Vấn Đỉnh rồi bị luyện thành Tiên Vệ","text":"Nguyên thần được Vương Lâm cứu khỏi lửa thiêu, dung hợp thiên địa nguyên khí đạt Vấn Đỉnh Sơ Kỳ (yếu nhất do nguyên khí tổn hao). Tâm trạng phức tạp: oán hận, cảm kích, hối hận, sợ hãi. Bị Vương Lâm ép đồng ý làm vật liệu luyện chế Tiên Vệ, in ấn quyết lên lông mày. Sau nhiều tháng bị luyện hóa thành khôi lỗi Đồng cấp: thân ảnh gầy gò, da tái nhợt không máu, khí âm hàn."},{"importance":"normal","chuong":"c0609","text":"Nguyên thần được dùng làm nền khôi lỗi, dung hợp với Thiên Quỷ rồi bị xóa mờ; hoàn thành bước luyện hóa thứ hai sau hơn nửa năm, thành khôi lỗi Tiên Vệ thứ nhất","nguonNblm":true}],"tuViMoc":[{"chuong":"@c0589","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tu vi đã chạm tới ngưỡng Vấn Đỉnh nhưng chưa dám bước qua cửa sinh tử.","importance":"minor"},{"chuong":"@c0608","canhGioi":"Vấn Đỉnh Sơ Kỳ","text":"Nguyên thần dung hợp thiên địa nguyên khí còn lại, đạt Vấn Đỉnh Sơ Kỳ; do nguyên khí tổn hao nhiều nên là Vấn Đỉnh yếu nhất trừ phi có cơ duyên bù lại.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Rủ Vương Lâm kết bạn vào Triều Tịch thâm uyên nhưng trong lòng đầy đố kị ác ý."},{"ten":"Mộ Dung Trác","tag":"dong-hanh","quanHe":"Đồng hành trong nhóm tiến vào thâm uyên."},{"ten":"Triệu Y Huyên","tag":"dong-hanh","quanHe":"Nữ tử Phù Vân phái cùng nhóm."},{"ten":"Từ Phi","tag":"dong-hanh","quanHe":"Nữ tử Phù Vân phái cùng nhóm."},{"ten":"Thiên Vận Tử","tag":"su-mon","quanHe":"Đỗ Kiến là xích hệ đệ tử của Thiên Vận Tử."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối thủ đã đánh bại, phong ấn nguyên thần và bắt giữ Đỗ Kiến.","ghiChu":"@c0591"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người cứu nguyên thần Đỗ Kiến rồi ép hắn làm vật liệu luyện chế Tiên Vệ","ghiChu":"Được hứa trả tự do sau ngàn năm nếu chưa tử"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người cứu mạng kiêm kẻ chế ngự","ghiChu":"Cứu nguyên thần khỏi lửa thiêu giúp đạt Vấn Đỉnh, nhưng ngay sau đó ép làm vật liệu luyện chế Tiên Vệ"}],"tuiDo":{}},"nguon":["@c0589","@c0591","@c0608"]},{"id":"mo-dung-trac","name":"Mộ Dung Trác","cn":"","aliases":["Hắc y nam tử"],"gioiTinh":"nam","theLuc":[{"ten":"Mặc môn","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh sơ kỳ","trangThai":"song","blurb":"Mặc môn tứ đại đệ tử, anh tuấn lạnh lùng cực ít lời, có thần thông phát hiện đối phương ngoài ngàn dặm; bày tỏ tôn kính ngầm với Vương Lâm.","vaiTro":"Mặc môn tứ đại đệ tử, đồng hành trong nhóm Đỗ Kiến.","tinhCach":[{"text":"Trầm mặc cực ít lời, không nói quá năm chữ một lần.","chuong":"@c0589"},{"text":"Anh tuấn lạnh lùng, tâm tư biến hóa khó dò như đầm nước đọng.","chuong":"@c0589"}],"tabs":{"diem":[{"text":"Có thần thông phát hiện đối phương mạnh ở ngoài ngàn dặm.","chuong":"@c0589"},{"text":"Là một trong ba người Triệu Y Huyên không nhìn thấu nội tâm.","chuong":"@c0589"}],"kinhLich":[{"chuong":"@c0589","importance":"normal","tieuDe":"Bày tỏ tôn kính với Vương Lâm","text":"Mộ Dung Trác cảnh báo trước sự xuất hiện của Vương Lâm bằng hai chữ Rất mạnh. Khi giới thiệu danh tính, hắn bất ngờ ôm quyền nói trọn câu Mặc môn tứ đại đệ tử Mộ Dung Trác — vượt xa thói quen không nói quá năm chữ, khiến ba người đồng hành kinh ngạc; đây là cử chỉ tôn kính ngầm dành cho Vương Lâm."},{"chuong":"@c0591","importance":"normal","tieuDe":"Kết giao và lời cảnh báo Thi Âm Tông","text":"Mộ Dung Trác trầm mặc cùng Vương Lâm vượt Triều Tịch thâm uyên, thi triển thần thông bác tạp không lần nào trùng. Khi chia tay, hắn được Vương Lâm kết giao hiếm có và truyền âm cảnh báo đề phòng Triệu, Từ nhị nữ là người Thi Âm Tông; hắn giả như không nghe nhưng âm thầm cảnh giác."},{"text":"Ở dưới vực sâu Triều Tịch vực, Mộ Dung Trác cảm nhận dao động đáng sợ truyền xuống từ bên trên khi Vương Lâm dồn toàn lực công kích thần niệm Lăng Thiên Hậu.","bridge":true,"khoang":"@c0594"}],"tuViMoc":[{"chuong":"@c0589","canhGioi":"Vấn Đỉnh sơ kỳ","text":"Tu vi đạt Vấn Đỉnh sơ kỳ, ngang hàng Vương Lâm trong nhóm.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Bày tỏ tôn kính ngầm với Vương Lâm qua câu giới thiệu khác thường."},{"ten":"Đỗ Kiến","tag":"dong-hanh","quanHe":"Đồng hành dưới sự dẫn dắt của Đỗ Kiến."},{"ten":"Triệu Y Huyên","tag":"dong-hanh","quanHe":"Cùng nhóm; tâm tư hắn khiến nàng không nhìn thấu."},{"ten":"Từ Phi","tag":"dong-hanh","quanHe":"Cùng nhóm Phù Vân phái."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đồng hành vượt thâm uyên, được Vương Lâm kết giao và cảnh báo về Thi Âm Tông.","ghiChu":"@c0591"}],"tuiDo":{}},"nguon":["@c0589","@c0591","@c0594"]},{"id":"trieu-y-huyen","name":"Triệu Y Huyên","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Phù Vân phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Nữ tử Phù Vân phái dung mạo tuyệt đẹp sắc sảo, có khả năng nhìn thấu nội tâm người khác; hơn trăm năm chỉ không dò thấu ba người là Thần Long, Mộ Dung Trác và Vương Lâm.","vaiTro":"Nữ tử Phù Vân phái đồng hành trong nhóm Đỗ Kiến.","tinhCach":[{"text":"Sắc sảo, tò mò, ưa quan sát và đọc thấu nội tâm người đối diện.","chuong":"@c0589"}],"tabs":{"diem":[{"text":"Có thể nhìn thấu nội tâm hầu hết mọi người ở đất Yêu Linh.","chuong":"@c0589"},{"text":"Hơn trăm năm chỉ ba người nàng không nhìn thấu: Thần Long, Mộ Dung Trác và Vương Lâm.","chuong":"@c0589"}],"kinhLich":[{"chuong":"@c0589","importance":"normal","tieuDe":"Không nhìn thấu Vương Lâm","text":"Triệu Y Huyên tự giới thiệu mình cùng sư muội Từ Phi rồi cùng nhóm tiến vào Vân Vụ sơn hải. Nàng thừa nhận Vương Lâm là người thứ ba nàng không dò thấu nội tâm — khác Thần Long có sương mù hóa lợi kiếm và Mộ Dung Trác tâm tư biến ảo, Vương Lâm chỉ bằng định lực đóng kín cửa tâm linh khóa trụ toàn bộ tâm thần. Khi nàng quan sát, Vương Lâm bất chợt quay đầu liếc nàng một cái rồi thu hồi ánh mắt."},{"bridge":true,"khoang":"@c0591–@c0591","text":"Triệu Y Huyên lộ tham niệm khi thấy Vương Lâm phá kim phù bằng “vô thị thần thông”; thần thông kỳ dị của nàng âm thầm phát uy khiến Vương Lâm nhận ra nàng là người Thi Âm Tông."}],"tuViMoc":[{"chuong":"@c0589","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tu vi Anh Biến hậu kỳ đại viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Từ Phi","tag":"su-mon","quanHe":"Sư muội cùng Phù Vân phái."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người thứ ba hơn trăm năm nàng không nhìn thấu nội tâm."},{"ten":"Đỗ Kiến","tag":"dong-hanh","quanHe":"Cùng nhóm do Đỗ Kiến dẫn."},{"ten":"Mộ Dung Trác","tag":"dong-hanh","quanHe":"Đồng hành; một trong ba người nàng không dò thấu."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm nhận diện là người Thi Âm Tông; là đối tượng hắn cảnh báo Mộ Dung Trác đề phòng.","ghiChu":"@c0591"}],"tuiDo":{}},"nguon":["@c0589","@c0591"]},{"id":"tu-phi-phu-van-phai","name":"Từ Phi (Phù Vân phái)","cn":"","aliases":["Từ Phi"],"gioiTinh":"nu","theLuc":[{"ten":"Phù Vân phái","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ đại viên mãn","trangThai":"song","blurb":"Nữ tử Phù Vân phái nhu nhược mảnh khảnh, mặc y phục hồng, vẻ mặt trắng xanh đáng yêu; sư muội của Triệu Y Huyên. Tên trùng một đồng môn hồi nhỏ của Vương Lâm.","vaiTro":"Nữ tử Phù Vân phái, sư muội Triệu Y Huyên, đồng hành trong nhóm Đỗ Kiến.","tinhCach":[{"text":"Nhu nhược, mảnh khảnh, vẻ mặt đáng yêu.","chuong":"@c0589"}],"tabs":{"diem":[{"text":"Tên trùng với một người đồng môn hồi nhỏ của Vương Lâm, gợi hồi ức song không phải người quen.","chuong":"@c0589"}],"kinhLich":[{"chuong":"@c0589","importance":"minor","tieuDe":"Ra mắt cùng nhóm","text":"Theo Triệu Y Huyên ra mắt khi giới thiệu danh tính trong nhóm; tên Từ Phi gợi hồi ức cho Vương Lâm nhưng hắn xác nhận không quen biết."},{"text":"Khi rời đi, Từ Phi dứt một sợi tóc dán lên vách khe để do thám Vương Lâm. Vương Lâm triệu s��i tóc về, đốt lục hỏa và phun nguyên thần chi khí thổi tan đạo thần thức bên trong, khiến nàng đang phi hành dưới thâm uyên run lên, khóe miệng chảy huyết, lộ vẻ kinh hãi.","bridge":true,"khoang":"@c0591"}],"tuViMoc":[{"chuong":"@c0589","canhGioi":"Anh Biến hậu kỳ đại viên mãn","text":"Tu vi Anh Biến hậu kỳ đại viên mãn.","importance":"minor"}],"nhanMach":[{"ten":"Triệu Y Huyên","tag":"su-mon","quanHe":"Sư tỷ cùng Phù Vân phái."},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tên trùng một đồng môn hồi nhỏ của Vương Lâm, gợi hồi ức cho hắn."},{"ten":"Đỗ Kiến","tag":"dong-hanh","quanHe":"Cùng nhóm do Đỗ Kiến dẫn."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm nhận diện là người Thi Âm Tông; cài tóc do thám hắn và bị phá thần thức, chịu thương phản đòn.","ghiChu":"@c0591"}],"tuiDo":{}},"nguon":["@c0589","@c0591"]},{"id":"than-long-dai-la-kiem-tong","name":"Thần Long (Đại La Kiếm Tông)","cn":"","aliases":["Thần Long"],"gioiTinh":"khong-ro","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"canhGioiCaoNhat":"khong-ro","trangThai":"khong-ro","blurb":"Nhân vật của Đại La Kiếm Tông, trên người luôn có đoàn sương mù hóa lợi kiếm ngăn cản sự dò xét; một trong ba người Triệu Y Huyên không nhìn thấu nội tâm.","vaiTro":"Nhân vật được nhắc tên trong số ba người Triệu Y Huyên không nhìn thấu.","tinhCach":[],"tabs":{"diem":[{"text":"Trên người luôn có đoàn sương mù hóa thành lợi kiếm ngăn cản sự dò xét nội tâm.","chuong":"@c0589"}],"kinhLich":[{"text":"Được Triệu Y Huyên nhắc tới như một trong ba người hơn trăm năm nàng không nhìn thấu nội tâm, do luôn có sương mù hóa lợi kiếm bảo vệ.","bridge":true,"khoang":"@c0589"},{"text":"Sau trăm năm do dự, đại sư huynh Đại La kiếm tông cuối cùng quyết đoán: xin lỗi các sư đệ rồi điểm mi tâm bật ra đạo kiếm khí bản mệnh Lăng Thiên Hậu (mạnh hơn của Tử Thử mấy lần), một mình phá Tử khí thoát ra, không mang theo ai vì cho rằng thêm người sẽ giảm tỉ lệ thành công. Ngoài sương mù, hắn cầm kiếm khí chém giết giữa bầy Văn thú và mỉa mai Tham Lang về sư tôn.","bridge":true,"khoang":"@c0601"},{"text":"Hợp công Tham Lang cùng Vương Lâm: bắt quyết hóa đại kiếm thành hắc long mang kiếm khí lao tới, khi Long hồn bị Phệ Tử Nhất Thức đánh tan thì phun nguyên thần tinh huyết niệm chú khiến kiếm lột da, tái hóa hắc long lần hai mạnh hơn. Nhưng bị sơn hồn của Tham Lang đè giữa thắt lưng, hắn tái nhợt phun máu, khiếp sợ kêu lên không rõ đó là thứ thần thông gì.","bridge":true,"khoang":"@c0602"},{"text":"Thần Long ngưng kết kiếm khí bổn mạng của sư t��n Lăng Thiên Hậu ở ngón tay tỏa lực chấn nhiếp, liều mạng phóng kiếm khí đánh tan thần lôi đen rồi chụp lệnh bài bỏ chạy, nhúng một tia ý thức điều khiển kiếm khí ngăn đệ nhị nguyên thần Tham Lang. Sắp tới cửa ra thì bị Vương Lâm thi triển ‘Định’ làm rơi lệnh bài, sau cùng bị sương mù của Tham Lang vây khốn.","bridge":true,"khoang":"@c0603"},{"text":"Được Vương Tạ thả ra, Thần Long thấy Lăng Thiên Hậu thì mừng như điên, quỳ xuống gọi sư tôn, tố Tham Lang hại các sư đệ. Hắn làm chứng từng thấy Vương Lâm giữ lệnh bài rồi bị Tham Lang khống chế.","bridge":true,"khoang":"@c0614"},{"chuong":"@c0614","importance":"normal","tieuDe":"Được thả, tố Tham Lang trước Kiếm Tôn","text":"Bị Vân Tiên đạo lữ thả ra, thấy Lăng Thiên Hậu thì mừng như điên, quỳ xuống kêu sư tôn. Tố Tham Lang hại các sư đệ; làm chứng từng thấy Vương Lâm giữ lệnh bài rồi bị Tham Lang khống chế."}],"nhanMach":[{"ten":"Triệu Y Huyên","tag":"khac","quanHe":"Một trong ba người Triệu Y Huyên không nhìn thấu nội tâm."},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Kẻ đối đầu","ghiChu":"Thần Long mỉa mai Tham Lang về sư tôn khi chém giết bầy Văn thú do hắn điều khiển."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người bị bỏ rơi","ghiChu":"Bỏ lại Vương Lâm cùng các sư đệ trong sương tím để thoát thân một mình."},{"ten":"Tham Lang","tag":"doi-thu","quanHe":"Đối thủ","ghiChu":"Bị sơn hồn đè trọng thương."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Đồng minh tạm thời chống Tham Lang"},{"ten":"Lăng Thiên Hậu","tag":"su-mon","quanHe":"Sư tôn","ghiChu":"Thần Long nắm giữ kiếm khí bổn mạng uy lực cực mạnh của Lăng Thiên Hậu.","gap":"@c0603"},{"ten":"Vương Tạ","tag":"doi-thu","quanHe":"Bị Vương Tạ giam, sau được thả","ghiChu":"@c0614"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0589","@c0601","@c0602","@c0603","@c0614"]},{"id":"thanh-lam","name":"Thanh Lâm","cn":"","aliases":["Tiên đế Thanh Lâm"],"gioiTinh":"nam","theLuc":[{"ten":"Tiên giới","trangThai":"gan-bo"}],"trangThai":"khong-ro","blurb":"Tiên đế, cường giả đệ nhất Tiên giới, phụ thân của Thanh Sương (Đình nhi); tương truyền ẩn náu trong động phủ ở Yêu Linh để chữa thương sau khi Tiên giới vỡ nát.","vaiTro":"Nhân vật được nhắc tên — mục tiêu truy tìm để giúp Đình nhi thức tỉnh.","tabs":{"diem":[],"kinhLich":[{"chuong":"@c0595","importance":"normal","tieuDe":"Lộ thân phận phụ thân Đình nhi","text":"Qua ngọc giản, lộ ra Thanh Lâm là tiên đế, cường giả đệ nhất Tiên giới và là phụ thân của Thanh Sương. Khi Tiên giới vỡ nát, tương truyền hắn chạy tới ẩn giấu trong một động phủ nơi mảnh đất Yêu Linh để chữa thương. Với tu vi của hắn, có thể khiến Đình nhi thức tỉnh, nên Chu Dật nhờ Vương Lâm tìm tới."}],"tuViMoc":[],"tuVi":"Tiên đế, được xưng là cường giả đệ nhất Tiên giới.","nhanMach":[{"ten":"Thanh Sương","tag":"cha-me","quanHe":"Nhi nữ","ghiChu":"Thanh Sương (Đình nhi) là nhi nữ của Thanh Lâm."}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0595"]},{"id":"ngo-ma-dai-la","name":"Ngọ Mã","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"tu-vong","blurb":"Đệ tử Đại La kiếm tông bị nhốt trong sương tím cùng đồng môn, kích động giết Vương Lâm trước khi chết nhưng lại bị hắn lừa giết.","vaiTro":"Đệ tử Đại La kiếm tông","tinhCach":[{"text":"Kích động, hiếu chiến","chuong":"@c0601"}],"tabs":{"diem":[{"text":"Kích động ba sư đệ còn lại quyết giết Vương Lâm trước khi cùng chết trong sương tím.","chuong":"@c0601"}],"kinhLich":[{"text":"Trong làn sương tím cô lập âm thanh, Ngọ Mã hô hào giết Vương Lâm. Vương Lâm giả giọng sư đệ Tuất Cẩu lừa hắn thu hồi kiếm khí, rồi nhân sơ hở điểm vào mi tâm giết chết, đoạt kiếm khí Lăng Thiên Hậu.","bridge":true,"khoang":"@c0601"}],"tuViMoc":[{"chuong":"@c0601","canhGioi":"Anh Biến kỳ","text":"Đệ tử Đại La dùng kiếm khí bản mệnh Lăng Thiên Hậu.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ giết mình"},{"ten":"Tuất Cẩu","tag":"su-mon","quanHe":"Sư đệ đồng môn","ghiChu":"Giọng của Tuất Cẩu bị Vương Lâm giả để lừa Ngọ Mã."}],"tuiDo":{}},"nguon":["@c0601"]},{"id":"ti-xa-dai-la","name":"Tị Xà","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"tu-vong","blurb":"Đệ tử Đại La kiếm tông bị nhốt trong sương tím; bị Vương Lâm rút sức sống hóa thây khô.","vaiTro":"Đệ tử Đại La kiếm tông","tinhCach":[{"text":"Cảnh giác nhưng bất lực trước thủ đoạn của Vương Lâm","chuong":"@c0601"}],"tabs":{"diem":[{"text":"Bị Vương Lâm áp tay rút sức sống hóa thành thây khô trong sương tím.","chuong":"@c0601"}],"kinhLich":[{"text":"Bị Vương Lâm áp tay rút cạn sức sống hóa thành thây khô; đạo kiếm khí Lăng Thiên Hậu của hắn nổ tung khiến thân thể biến mất.","bridge":true,"khoang":"@c0601"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ giết mình"}],"tuiDo":{}},"nguon":["@c0601"]},{"id":"tuat-cau-dai-la","name":"Tuất Cẩu","gioiTinh":"nam","theLuc":[{"ten":"Đại La Kiếm Tông","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Đệ tử Đại La kiếm tông, sư đệ của Ngọ Mã; giọng của hắn bị Vương Lâm giả để lừa giết Ngọ Mã, và là kẻ duy nhất sống sót trong sương tím.","vaiTro":"Đệ tử Đại La kiếm tông","tinhCach":[{"text":"May mắn sống sót","chuong":"@c0601"}],"tabs":{"diem":[{"text":"Là ‘tên còn sót’ duy nhất Vương Lâm chưa kịp giết trước khi bị Chu Dật cưỡng chế đưa đi.","chuong":"@c0601"}],"kinhLich":[{"text":"Vương Lâm giả giọng hắn để lừa Ngọ Mã thu hồi kiếm khí rồi giết Ngọ Mã. Đúng mười lần hô hấp, Chu Dật cưỡng chế đưa Vương Lâm bay ra nên Tuất Cẩu thoát chết, là kẻ duy nhất sống sót.","bridge":true,"khoang":"@c0601"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Kẻ giả giọng mình"},{"ten":"Ngọ Mã","tag":"su-mon","quanHe":"Sư huynh đồng môn"}],"tuiDo":{}},"nguon":["@c0601"]},{"id":"vuong-ta-van-tien-dao-lu","name":"Vương Tạ","cn":"","gioiTinh":"nam","aliases":["Vân Tiên đạo lữ (nam)"],"theLuc":[{"ten":"Vân Tiên đạo lữ","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nam trong Vân Tiên đạo lữ, ngồi trên mây lành hư ảo, giam giữ Tham Lang và Thần Long; điềm tĩnh trêu chọc Lăng Thiên Hậu.","vaiTro":"Tu sĩ cường đại được các lão quái cố kỵ.","tinhCach":[{"text":"Điềm tĩnh, ưa trêu chọc","chuong":"@c0614"}],"tabs":{"diem":[{"text":"Ngồi trên mây lành hư ảo cùng đạo lữ Hồ Quyên, được các lão quái cố kỵ","chuong":"@c0614"}],"kinhLich":[{"text":"Cùng Hồ Quyên xuất hiện trên cụm mây lành hư ảo, va chạm thần thức làm Lăng Thiên Hậu đau loạng choạng. Vương Tạ chào hỏi, vỗ túi trữ vật thả Thần Long và Tham Lang ra, điềm tĩnh trêu chọc Kiếm Tôn tính nóng nảy không giảm. Khi nhìn Thiên Vận Tử bấm độn thì đồng tử co rút.","bridge":true,"khoang":"@c0614"},{"chuong":"@c0614","importance":"normal","tieuDe":"Xuất hiện tại vùng đất Yêu Linh","text":"Cùng Hồ Quyên ngồi trên mây lành hư ảo xuất hiện trước đám lão quái. Trêu chọc Lăng Thiên Hậu về tính nóng nảy; co đồng tử khi nhìn Thiên Vận Tử bấm độn. Vỗ túi trữ vật thả Thần Long và Tham Lang ra cho các lão quái thẩm vấn."}],"nhanMach":[{"ten":"Hồ Quyên","tag":"the-thiep","quanHe":"Đạo lữ","ghiChu":"@c0614"},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Lăng Thiên Hậu cố kỵ, đòi giao Tham Lang","ghiChu":"@c0614"},{"ten":"Tham Lang","tag":"khac","quanHe":"Giam Tham Lang trong túi trữ vật","ghiChu":"@c0614"},{"ten":"Thiên Vận Tử","tag":"doi-thu","quanHe":"Co đồng tử khi nhìn Thiên Vận Tử bấm độn","ghiChu":"@c0614"},{"ten":"Lăng Thiên Hậu","tag":"khac","quanHe":"Lão quái cố kỵ lẫn nhau","ghiChu":"Trêu chọc Kiếm Tôn về tính nóng nảy; Lăng Thiên Hậu cực kỳ cố kỵ đạo lữ này."},{"ten":"Thiên Vận Tử","tag":"khac","quanHe":"Lão quái cùng cấp","ghiChu":"Vương Tạ co đồng tử khi thấy Thiên Vận Tử bấm độn."},{"ten":"Tham Lang","tag":"khac","quanHe":"Người bị giam, thả ra cho các lão quái","ghiChu":"Tham Lang bị Vân Tiên đạo lữ giam trong túi trữ vật, đứng sau Hồ Quyên và Vương Tạ như lão nô."},{"ten":"Thần Long","tag":"khac","quanHe":"Người bị giam, thả ra cho Lăng Thiên Hậu","ghiChu":"Thần Long bị giam cùng Tham Lang, được thả ra."}],"tuViMoc":[],"tuiDo":{"phapBao":[{"ten":"Túi trữ vật","moTa":"Chứa Thần Long và Tham Lang, vỗ một cái thả họ ra","nguon":"@c0614"}]}},"nguon":["@c0614"]},{"id":"ho-quyen-van-tien-dao-lu","name":"Hồ Quyên","cn":"","gioiTinh":"nu","aliases":["Vân Tiên đạo lữ (nữ)"],"theLuc":[{"ten":"Vân Tiên đạo lữ","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Nữ trong Vân Tiên đạo lữ, đạo lữ của Vương Tạ; mỉm cười, bênh vực Kiếm Tôn quan tâm đệ tử.","vaiTro":"Tu sĩ cường đại được các lão quái cố kỵ.","tinhCach":[{"text":"Mềm mỏng, biết điều","chuong":"@c0614"}],"tabs":{"diem":[{"text":"Ngồi trên mây lành hư ảo cùng đạo lữ Vương Tạ","chuong":"@c0614"}],"kinhLich":[{"text":"Cùng Vương Tạ xuất hiện trên mây lành hư ảo. Khi Lăng Thiên Hậu đòi Tham Lang, Hồ Quyên mỉm cười bênh rằng Kiếm Tôn quan tâm đệ tử là có tình có lý.","bridge":true,"khoang":"@c0614"},{"chuong":"@c0614","importance":"normal","tieuDe":"Xuất hiện cùng Vương Tạ tại vùng đất Yêu Linh","text":"Cùng Vương Tạ ngồi trên mây lành hư ảo xuất hiện. Mỉm cười bênh vực Lăng Thiên Hậu, nói Kiếm Tôn quan tâm đệ tử là có tình có lý."}],"nhanMach":[{"ten":"Vương Tạ","tag":"the-thiep","quanHe":"Đạo lữ","ghiChu":"@c0614"},{"ten":"Lăng Thiên Hậu","tag":"doi-thu","quanHe":"Bênh vực Kiếm Tôn quan tâm đệ tử","ghiChu":"@c0614"},{"ten":"Vương Tạ","tag":"the-thiep","quanHe":"Đạo lữ (bạn đời tu luyện)","ghiChu":"Một nam một nữ kết thành Vân Tiên đạo lữ."},{"ten":"Lăng Thiên Hậu","tag":"khac","quanHe":"Lão quái cố kỵ lẫn nhau","ghiChu":"Hồ Quyên bênh vực Kiếm Tôn nhưng Lăng Thiên Hậu vẫn cố kỵ."},{"ten":"Tham Lang","tag":"khac","quanHe":"Người bị giam","ghiChu":"Tham Lang đứng sau Hồ Quyên như lão nô."}],"tuViMoc":[]},"nguon":["@c0614"]},{"id":"nhiem-nguyet","name":"Nhiễm Nguyệt","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Nhiễm gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến trung kì","trangThai":"song","blurb":"Nữ tu Nhiễm gia ở Nhiễm Vân Tinh, người cầm cự chính giúp nhóm sống sót trong sương độc Minh vụ trùng cho tới khi Vương Lâm tới giải vây.","vaiTro":"Nhân vật phụ — đại diện nhóm Nhiễm Vân Tinh, cầu cứu Vương Lâm.","tinhCach":[{"text":"Trầm tĩnh, gánh vác chính trong nhóm dù tiên lực hao nhanh nhất","chuong":"@c0615"},{"text":"Ẩn hàn ý và kiêu ngạo dù tướng mạo chỉ như thiếu nữ chừng hai mươi","chuong":"@c0615"}],"tabs":{"diem":[{"text":"Tu vi Anh Biến trung kì, cao nhất trong bốn người","chuong":"@c0615"},{"text":"Dùng vòng ngọc toả lôi điện che chở cả nhóm, hiểu Minh vụ trùng sợ nhất Lôi hệ","chuong":"@c0615"}],"kinhLich":[{"text":"Cùng ba nam tu sĩ chiếm được Xích diệu thạch khi thí luyện nên bị vô số Minh vụ trùng truy kích mấy ngày, cuối cùng bị bao vây trong sương độc. Nhiễm Nguyệt dùng vòng ngọc nhỏ toả lôi điện che phủ bốn người, chốc chốc khua tay áo kéo tinh quang ngăn cản, cầu cứu gia tộc và hy vọng tiền bối hiểu Lôi hệ tới cứu. Khi Vương Lâm xuất hiện, nàng thất kinh vì chỉ một ánh mắt của hắn đã đẩy lui đám trùng, liền xưng người Nhiễm gia và hứa báo đáp.","bridge":true,"khoang":"@c0615"},{"chuong":"@c0615","importance":"normal","tieuDe":"Bị Minh vụ trùng vây khốn","text":"Cùng Nhiễm Thần, Nhiễm Phong, Tôn Tuyết Sơn chiếm được Xích diệu thạch khi thí luyện nên bị vô số Minh vụ trùng truy kích mấy ngày rồi bao vây trong sương độc. Nàng dùng vòng ngọc toả lôi điện che bốn người, hao tiên lực nhanh nhất, đã cầu cứu gia tộc và mong tiền bối hiểu Lôi hệ thần thông tới cứu."},{"chuong":"@c0615","importance":"normal","tieuDe":"Cầu cứu Vương Lâm","text":"Khi Vương Lâm dùng ánh mắt làm Minh vụ trùng rút lui, nàng thất kinh, tự xưng người Nhiễm gia Nhiễm Vân Tinh và hứa Nhiễm gia sẽ báo đáp ơn cứu mạng."},{"chuong":"@c0615","importance":"normal","tieuDe":"Bị Minh vụ trùng vây ở La Vân Tinh Vực","text":"Cùng ba nam đến thí luyện, chiếm được Xích diệu thạch nên bị vô số Minh vụ trùng truy kích mấy ngày rồi bao vây trong sương độc. Nhiễm Nguyệt dùng vòng ngọc toả lôi điện che phủ bốn người, cầu cứu gia tộc; khi Vương Lâm xuất hiện và giải vây, nàng thất kinh, xưng người Nhiễm gia Nhiễm Vân Tinh và hứa báo đáp."},{"text":"Sau khi được Vương Lâm cứu khỏi tai nạn, Nhiễm Nguyệt cung kính hỏi hắn có phải Lôi Tiên sứ giả. Nàng dẫn đường về Nhiễm Vân Tinh, hỏi tên và xuất thân của hắn; khi hắn xưng họ Hứa nàng chấn động vì nghi hắn người Hứa gia danh giá ở Thiên Huyễn Tinh. Nàng giải thích cho hắn về Đông Lâm Tinh — còn gọi Đông Lâm Sát Tinh, ác mộng đè nặng dân La Thiên Tinh Vực.","bridge":true,"khoang":"@c0616"}],"tuViMoc":[{"chuong":"@c0615","canhGioi":"Anh Biến trung kì","text":"Xuất hiện với tu vi Anh Biến trung kì, cao hơn ba nam tu sĩ đồng hành.","importance":"minor"},{"chuong":"@c0615","canhGioi":"Anh Biến trung kỳ","text":"Xuất hiện với tu vi Anh Biến trung kỳ, cao hơn ba nam đồng hành (Anh Biến sơ kỳ).","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân giải vây khỏi Minh vụ trùng","ghiChu":"Nhiễm Nguyệt hứa Nhiễm gia báo đáp. @c0615"},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Đồng hành cùng nhóm thí luyện","ghiChu":"@c0615"},{"ten":"Nhiễm Thần","tag":"dong-hanh","quanHe":"Người cùng Nhiễm gia","ghiChu":"@c0615"},{"ten":"Nhiễm Phong","tag":"dong-hanh","quanHe":"Người cùng Nhiễm gia","ghiChu":"@c0615"},{"ten":"Vương Lâm","tag":"dong-hanh","quanHe":"Người đã cứu mạng nàng và ba người kia; nàng nghi hắn là Lôi Tiên sứ giả, dẫn đường đưa hắn về Nhiễm Vân Tinh"},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Cùng nhóm bốn người được Vương Lâm cứu"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân giải vây Minh vụ trùng bằng ánh mắt và Thiên Lôi","ghiChu":""},{"ten":"Nhiễm Thần","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia, cùng bị vây","ghiChu":""},{"ten":"Nhiễm Phong","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia, cùng bị vây","ghiChu":""},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Bạn đồng hành, cùng bị vây","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân cứu mạng — chỉ bằng ánh mắt và Thiên Lôi đã xua tan Minh vụ trùng giải vây cho nhóm.","ghiChu":"Gặp @c0615"},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Đi cùng nhóm thí luyện, lâm nguy do Tôn Tuyết Sơn lấy Xích diệu thạch.","ghiChu":"@c0615"},{"ten":"Nhiễm Thần","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"},{"ten":"Nhiễm Phong","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"}],"tuiDo":{"phapBao":[{"ten":"Vòng ngọc toả lôi điện","trangThai":"dang-co","moTa":"Vòng tay nhỏ toả lôi điện yếu ớt phát sáng, che phủ bốn người chống sương độc; hấp thu phần lớn tiên lực của nàng.","nguon":"@c0615"}]}},"nguon":["@c0615","@c0616"]},{"id":"nhiem-than","name":"Nhiễm Thần","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Nhiễm gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến sơ kì","trangThai":"song","blurb":"Nam tu sĩ Nhiễm gia ở Nhiễm Vân Tinh, một trong ba nam bị Minh vụ trùng vây cùng nhóm.","vaiTro":"Nhân vật phụ thoáng qua.","tinhCach":[{"text":"Cung kính cầu cứu khi gặp nguy","chuong":"@c0615"}],"tabs":{"diem":[{"text":"Tu vi Anh Biến sơ kì","chuong":"@c0615"}],"kinhLich":[{"text":"Cùng nhóm Nhiễm Vân Tinh thay nhau thi triển pháp thuật, xuất pháp bảo cố mở lỗ hổng trong sương độc nhưng thất bại; khi Vương Lâm xuất hiện liền cung kính cầu hắn cứu.","bridge":true,"khoang":"@c0615"},{"chuong":"@c0615","importance":"normal","tieuDe":"Bị vây trong sương độc","text":"Cùng nhóm Nhiễm Vân Tinh bị Minh vụ trùng vây sau khi chiếm Xích diệu thạch; thay nhau thi triển pháp thuật thần thông và xuất pháp bảo cố mở lỗ hổng nhưng thất bại. Khi Vương Lâm xuất hiện thì cung kính cầu cứu."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân giải vây","ghiChu":"@c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Người cùng Nhiễm gia","ghiChu":"@c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia","ghiChu":""},{"ten":"Nhiễm Phong","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia","ghiChu":""},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Cung kính cầu Vương Lâm cứu khỏi vòng vây.","ghiChu":"Gặp @c0615"},{"ten":"Nhiễm Nguyệt","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"},{"ten":"Nhiễm Phong","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"}],"tuiDo":{}},"nguon":["@c0615"]},{"id":"nhiem-phong","name":"Nhiễm Phong","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Nhiễm gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến sơ kì","trangThai":"song","blurb":"Nam tu sĩ Nhiễm gia ở Nhiễm Vân Tinh, một trong ba nam bị Minh vụ trùng vây cùng nhóm.","vaiTro":"Nhân vật phụ thoáng qua.","tinhCach":[{"text":"Cung kính cầu cứu khi gặp nguy","chuong":"@c0615"}],"tabs":{"diem":[{"text":"Tu vi Anh Biến sơ kì","chuong":"@c0615"}],"kinhLich":[{"text":"Cùng nhóm Nhiễm Vân Tinh thay nhau thi triển thần thông cố phá vòng vây sương độc nhưng bất lực; khi Vương Lâm xuất hiện thì cung kính cầu cứu, hứa hậu tạ.","bridge":true,"khoang":"@c0615"},{"chuong":"@c0615","importance":"normal","tieuDe":"Bị Minh vụ trùng vây","text":"Cùng nhóm Nhiễm Vân Tinh cố mở lỗ hổng trong sương độc nhưng thất bại; khi Vương Lâm tới thì cung kính cầu cứu, hứa hậu tạ."},{"chuong":"@c0615","importance":"normal","tieuDe":"Bị vây trong sương độc","text":"Cùng nhóm Nhiễm Vân Tinh bị Minh vụ trùng vây sau khi chiếm Xích diệu thạch; thay nhau thi triển pháp thuật thần thông cố mở lỗ hổng nhưng thất bại. Khi Vương Lâm xuất hiện thì cung kính cầu cứu."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân giải vây","ghiChu":"@c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Người cùng Nhiễm gia","ghiChu":"@c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia","ghiChu":""},{"ten":"Nhiễm Thần","tag":"dong-hanh","quanHe":"Đồng tộc Nhiễm gia","ghiChu":""},{"ten":"Tôn Tuyết Sơn","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Cung kính cầu Vương Lâm cứu khỏi vòng vây.","ghiChu":"Gặp @c0615"},{"ten":"Nhiễm Nguyệt","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"},{"ten":"Nhiễm Thần","tag":"ho-hang","quanHe":"Cùng Nhiễm gia, đồng hành trong nhóm bị vây.","ghiChu":"@c0615"}],"tuiDo":{}},"nguon":["@c0615"]},{"id":"ton-tuyet-son","name":"Tôn Tuyết Sơn","cn":"","aliases":["#ton-tuyet-son-q06-615","#ton-tuyet-son-q06-c0615"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Anh Biến sơ kì","trangThai":"song","blurb":"Tu sĩ Anh Biến sơ kì đi cùng nhóm Nhiễm gia; người tự trách đã tham lam lấy Xích diệu thạch gây vây hãm, sau chỉ đường tới Hợp vân thánh cho Vương Lâm. (+) Nam tu sĩ đi cùng nhóm Nhiễm gia thí luyện, Anh Biến sơ kì; tự trách tham lam lấy Xích diệu thạch gây vây hãm rồi được Vương Lâm cứu. [CAN-SOAT-GOP]","vaiTro":"Nhân vật phụ — người dẫn đường ban đầu của Vương Lâm tại La Thiên Tinh Vực.","tinhCach":[{"text":"Biết tự trách, cười khổ nhận lỗi tham lam","chuong":"@c0615"},{"text":"Nhanh nhạy nắm bắt cơ hội, hứa báo đáp để xin dẫn đường","chuong":"@c0615"}],"tabs":{"diem":[{"text":"Tu vi Anh Biến sơ kì","chuong":"@c0615"},{"text":"Chỉ Vương Lâm đường tới Hợp vân thánh — bảy ngày đường về hướng bắc","chuong":"@c0615"},{"text":"Người tự trách đã tham lam lấy Xích diệu thạch khiến cả nhóm lâm nguy.","chuong":"@c0615"}],"kinhLich":[{"text":"Tự trách vì tham lam lấy Xích diệu thạch khiến cả nhóm lâm nguy trước Minh vụ trùng. Khi Vương Lâm thử thu hồi ánh mắt để sương vây lại, Tôn Tuyết Sơn la lớn hứa dùng Xích diệu thạch báo đáp; nghe Vương Lâm hỏi vị trí Hợp vân thánh, hắn đáp cách bảy ngày đường về hướng bắc và xin được dẫn đường đền ơn cứu mạng.","bridge":true,"khoang":"@c0615"},{"text":"Người La Vân Tinh Vực, vốn coi Lôi hệ thần thông là pháp thuật uy lực nhất, khi���p sợ trước tia lôi uy chân chính trong sấm sét Vương Lâm thi triển — điều mà tổ tiên gia tộc hắn cũng chưa làm được. Hắn cực kỳ tôn kính cuồng nhiệt, nguyện dẫn đường đi Nhiễm Vân Tinh, và trong khi nhìn trộm tinh la bàn của Vương Lâm đã cung cấp thông tin về Thiên Huyễn Tinh cùng La Thiên Tinh Vực.","bridge":true,"khoang":"@c0616"},{"text":"Tự trách đã tham lam lấy Xích diệu thạch nên cả nhóm lâm nguy bị Minh vụ trùng truy kích. Khi Vương Lâm tới, hắn la lớn hứa dùng Xích diệu thạch báo đáp; nghe Vương Lâm hỏi vị trí Hợp vân thánh, hắn đáp cách bảy ngày đường về hướng bắc và xin được dẫn đường để đền ơn cứu mạng.","bridge":true,"khoang":"@c0615"},{"text":"Đi cùng nhóm Nhiễm gia thí luyện, lấy được Xích diệu thạch nên cả nhóm bị Minh vụ trùng truy kích bao vây. Tôn Tuyết Sơn cười khổ tự trách, khi Vương Lâm xuất hiện thì la lớn hứa dùng Xích diệu thạch báo đáp, đáp Hợp vân thánh cách bảy ngày đường hướng bắc và xin dẫn đường đền ơn cứu mạng.","bridge":true,"khoang":"@c0615"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân cứu mạng, người hắn xin dẫn đường để đền ơn","ghiChu":"@c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Đồng hành trong nhóm thí luyện","ghiChu":"@c0615"},{"ten":"Vương Lâm","tag":"dong-hanh","quanHe":"Ân nhân cứu mạng mà hắn vô cùng tôn kính, nguyện dẫn đường"},{"ten":"Tôn Vân Sơn","tag":"dong-hanh","quanHe":"Cùng nhóm bốn người được cứu"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Bạn đồng hành nhóm Nhiễm gia","ghiChu":""},{"ten":"Nhiễm Thần","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":""},{"ten":"Nhiễm Phong","tag":"dong-hanh","quanHe":"Bạn đồng hành","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân giải vây, hứa dẫn đường tới Hợp vân thánh","ghiChu":""},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Ân nhân cứu mạng; hứa dùng Xích diệu thạch báo đáp và dẫn đường tới Hợp vân thánh.","ghiChu":"Gặp @c0615"},{"ten":"Nhiễm Nguyệt","tag":"dong-hanh","quanHe":"Đi cùng nhóm Nhiễm gia thí luyện.","ghiChu":"@c0615"}],"tuiDo":{"khac":[{"ten":"Xích diệu thạch","trangThai":"dang-co","moTa":"Khoáng thạch chiếm được khi thí luyện, nguyên cớ bị Minh vụ trùng truy kích; hứa dùng để báo đáp Vương Lâm.","nguon":"@c0615"}]}},"nguon":["@c0615","@c0616"]},{"id":"mi-nhi-huyen-gia","name":"Mi nhi","aliases":["Cô gái Huyễn gia"],"gioiTinh":"nu","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh","trangThai":"song","blurb":"Nữ tử dung nhan tuyệt thế của Huyễn gia, tu luyện Thiên Huyễn Vô Tình Đạo, đệ tử được đại trưởng lão Huyễn gia thu nhận và đưa rời La Thiên Tinh Vực.","vaiTro":"Đệ tử của đại trưởng lão Huyễn gia, mang tiềm năng phát triển tới Vạn Ảo Thiên Ma Đạo.","tabs":{"diem":[{"text":"Dung nhan tuyệt thế, không thua Hồng Điệp năm đó; tóc ba thước tết ba búi, cài trâm bạch ngọc hình hai con bươm bướm, tỏa khí tức nội mị","chuong":"@c0616"},{"text":"Tu luyện Thiên Huyễn Vô Tình Đạo, mơ hồ có thể phát triển tới Vạn Ảo Thiên Ma Đạo — điều cực hiếm","chuong":"@c0616"}],"kinhLich":[{"text":"Mấy trăm năm trước được lão già đại trưởng lão Huyễn gia ngẫu nhiên gặp, nhận ra tu luyện Thiên Huyễn Vô Tình Đạo có tiềm năng tiến tới Vạn Ảo Thiên Ma Đạo nên thu làm đệ tử. Nay nàng được sư phụ đưa rời Liên Minh Tinh Vực, tu vi đã đạt Vấn Đỉnh nhưng bị tiên lực sư phụ lôi kéo bay đi; nàng lưu luyến vì từ nhỏ lớn lên ở đây, được sư phụ gọi Mi nhi và an ủi.","bridge":true,"khoang":"@c0616"},{"chuong":"@c0616","importance":"normal","tieuDe":"Rời La Thiên Tinh Vực theo sư phụ","text":"Mi nhi cùng lão già đại trưởng lão Huyễn gia rời Liên Minh Tinh Vực bằng đạo cầu vồng tối đen. Nàng tiếc nuối vì từ nhỏ lớn lên ở đây; lão già an ủi nàng không cần lưu luyến. Mấy trăm năm trước lão thu nàng làm đệ tử vì nhận ra nàng tu luyện Thiên Huyễn Vô Tình Đạo, mơ hồ có thể phát triển tới Vạn Ảo Thiên Ma Đạo."}],"tuViMoc":[{"chuong":"@c0616","canhGioi":"Vấn Đỉnh","text":"Tu vi đạt Vấn Đỉnh khi rời La Thiên Tinh Vực.","importance":"major"}],"nhanMach":[{"ten":"Lão già (đại trưởng lão Huyễn gia)","tag":"su-mon","quanHe":"Sư phụ, người thu nàng làm đệ tử mấy trăm năm trước và đưa nàng rời La Thiên Tinh Vực"},{"ten":"Lão già (đại trưởng lão Huyễn gia)","tag":"su-mon","quanHe":"Sư phụ, thu nàng làm đệ tử mấy trăm năm trước, vì nàng mà bỏ tìm Thiên Nghịch Châu","ghiChu":""},{"ten":"Lão già (đại trưởng lão Huyễn gia)","tag":"su-mon","quanHe":"Sư phụ; thu nàng làm đệ tử mấy trăm năm trước, vì nàng mà bỏ việc tìm Thiên Nghịch Châu, đưa nàng về La Thiên Tinh Vực.","ghiChu":"@c0616"}]},"nguon":["@c0616"]},{"id":"lao-gia-dai-truong-lao-huyen-gia","name":"Lão già (đại trưởng lão Huyễn gia)","gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Đại trưởng lão Huyễn gia trên Thiên Huyễn Tinh, vẻ kiêu ngạo lẫn hiểm độc; vì yêu quý đệ tử Mi nhi mà bỏ việc tìm Thiên Nghịch Châu, ��ưa nàng rời La Thiên Tinh Vực. (+) Đại trưởng lão Huyễn gia trên Thiên Huyễn Tinh, sư phụ của Mi nhi; bay không cần la bàn hay pháp bảo, chỉ giẫm chân tại chỗ như na di. [CAN-SOAT-GOP]","vaiTro":"Sư phụ của Mi nhi, đại trưởng lão Huyễn gia.","tabs":{"diem":[{"text":"Vẻ kiêu ngạo, mặt buồn đau lẫn hiểm độc; bay không dùng tinh la bàn hay pháp bảo, chỉ giẫm chân tại chỗ như na di","chuong":"@c0616"},{"text":"Bay không dùng tinh la bàn hay pháp bảo, chỉ giẫm chân tại chỗ như na di","chuong":"@c0616"},{"text":"Vì yêu quý đệ tử Mi nhi mà bỏ việc tìm Thiên Nghịch Châu ở Liên Minh Tinh Vực, đưa nàng về La Thiên Tinh Vực","chuong":"@c0616"},{"text":"Đại trưởng lão Huyễn gia trên Thiên Huyễn Tinh, bắc vực chủ tinh La Thiên Tinh Vực; di chuyển không dùng la bàn hay pháp bảo, chỉ giẫm chân như na di.","chuong":"@c0616"}],"kinhLich":[{"text":"Mấy trăm năm trước ngẫu nhiên gặp Mi nhi, nhận ra nàng tu luyện Thiên Huyễn Vô Tình Đạo có tiềm năng tiến tới Vạn Ảo Thiên Ma Đạo nên thu làm đệ tử. Vì yêu quý đệ tử, lão không ở lại Liên Minh Tinh Vực tiếp tục tìm Thiên Nghịch Châu mà đem nàng quay về La Thiên Tinh Vực, an ủi nàng không lưu luyến khi hai người hóa cầu vồng tối đen rời đi.","bridge":true,"khoang":"@c0616"},{"text":"Lão già hóa cầu vồng tối đen gào thét, đưa Mi nhi rời Liên Minh Tinh Vực về La Thiên Tinh Vực. Mấy trăm năm trước lão ngẫu nhiên gặp nàng, nhận ra nàng tu Thiên Huyễn Vô Tình Đạo có thể tiến tới Vạn Ảo Thiên Ma Đạo nên thu làm đệ tử; vì nàng mà từ bỏ việc tìm Thiên Nghịch Châu.","bridge":true,"khoang":"@c0616"},{"text":"Mấy trăm năm trước lão ngẫu nhiên gặp Mi nhi, nhận ra nàng tu luyện Thiên Huyễn Vô Tình Đạo có tiềm năng phát triển tới Vạn Ảo Thiên Ma Đạo nên thu làm đệ tử. Vì yêu quý đệ tử, lão bỏ việc tìm Thiên Nghịch Châu ở Liên Minh Tinh Vực mà đưa nàng quay về La Thiên Tinh Vực, hóa cầu vồng tối đen gào thét bay đi.","bridge":true,"khoang":"@c0616"}],"nhanMach":[{"ten":"Mi nhi","tag":"su-mon","quanHe":"Đệ tử mà lão yêu quý, thu nhận mấy trăm năm trước; vì nàng mà bỏ việc tìm Thiên Nghịch Châu"},{"ten":"Mi nhi","tag":"su-mon","quanHe":"Đệ tử, thu nạp mấy trăm năm trước","ghiChu":""},{"ten":"Mi nhi","tag":"su-mon","quanHe":"Đệ tử; thu nạp mấy trăm năm trước vì tiềm năng Vô Tình Đạo, hết mực yêu quý.","ghiChu":"@c0616"}]},"nguon":["@c0616"],"aliases":["#lao-gia-dai-truong-lao-huyen-gia-616","#lao-gia-dai-truong-lao-huyen-gia-c0616"]},{"id":"thanh-nien-canh-dong-phu-ton-gia","name":"Thanh niên canh giữ động phủ thành bắc","gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh","trangThai":"song","blurb":"Tu sĩ Nguyên Anh kỳ canh giữ động phủ thành bắc Tôn gia, thu linh thạch cấp lệnh bài phòng, thái độ khinh miệt với tu sĩ ngoại lai.","vaiTro":"Người quản động phủ cho thuê ở thành bắc Tôn gia.","tabs":{"kinhLich":[{"text":"Báo còn tám phòng trống, hảo hạng ngàn khối hạ phẩm linh thạch mỗi năm, cấp dưới trăm khối. Vương Lâm trả trăm khối, nhận lệnh bài phòng thứ năm phía tây. Thanh niên khinh miệt lẩm bẩm cho rằng hắn lại là một tu sĩ ngoại lai tới kết nghĩa mượn linh lực Tôn gia, tư chất tầm thường nhờ đan dược mới đạt Kết Đan.","bridge":true,"khoang":"@c0616"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Tu sĩ ngoại lai thuê phòng động phủ cấp dưới, bị thanh niên khinh miệt"}]},"nguon":["@c0616"]},{"id":"ga-thanh-nien-nui-da-nhiem-van-tinh","name":"Gã thanh niên (núi đá Nhiễm Vân Tinh)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Gã thanh niên ngồi nơi núi đá Nhiễm Vân Tinh hấp thụ tinh hoa trời đất, đợi Vương Lâm đi xa mới mở mắt lộ vẻ khinh miệt.","vaiTro":"Nhân vật bí ẩn, danh tính chưa lộ.","tinhCach":[{"text":"Trầm tĩnh, ẩn nhẫn, lộ vẻ khinh miệt khi không ai để ý.","chuong":"@c0617"}],"tabs":{"diem":[{"text":"Ngồi nơi núi đá hấp thụ tinh hoa trời đất, kín đáo che giấu thái độ thật.","chuong":"@c0617"}],"kinhLich":[{"text":"Khi Vương Lâm ra khỏi phòng xá đi qua chỗ núi đá, gã thanh niên vẫn ngồi hấp thụ tinh hoa trời đất như trước. Đến khi bóng Vương Lâm đi thật xa, gã mới mở to mắt, ánh mắt lộ vẻ khinh miệt.","bridge":true,"khoang":"@c0617"},{"chuong":"@c0617","importance":"minor","tieuDe":"Lộ vẻ khinh miệt với Vương Lâm","text":"Ngồi nơi núi đá hấp thụ tinh hoa trời đất y như trước; khi bóng Vương Lâm đi thật xa, gã mới mở to mắt, ánh mắt lộ vẻ khinh miệt."}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Cùng an cư khu vực Nhiễm Vân Tinh; lộ vẻ khinh miệt sau khi Vương Lâm đi xa.","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Người gã âm thầm dõi theo và lộ vẻ khinh miệt sau khi đi xa","ghiChu":""}],"tuiDo":{}},"nguon":["@c0617"]},{"id":"lo-phong-bao-hop-lau","name":"Lô Phong","cn":"","aliases":["Người đàn ông trung niên gác Bảo Hợp Lâu","#lo-phong-bao-hop-lau-618"],"gioiTinh":"nam","theLuc":[{"ten":"Bảo Hợp Lâu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh","trangThai":"song","blurb":"Người đàn ông trung niên gác cửa Bảo Hợp Lâu nhiều năm, ngạo mạn, dùng lệ ‘hai không tiến, một không ra’ chặn Vương Lâm.","vaiTro":"Người gác cửa kiểm tra tiêu chuẩn khách vào Bảo Hợp Lâu","tinhCach":[{"text":"Ngạo mạn, khinh thường tu sĩ tu vi thấp và pháp bảo bề ngoài k��m","chuong":"@c0618"},{"text":"Kính nể Tôn lão, không dám nói hết sự thật trước lão","chuong":"@c0618"}],"tabs":{"diem":[{"text":"Gác cửa Bảo Hợp Lâu nhiều năm, áp lệ ‘hai không tiến, một không ra’","chuong":"@c0618"},{"text":"Liếc mắt là đánh giá pháp bảo, không cần dùng thần thức","chuong":"@c0618"},{"text":"Tu vi Nguyên Anh, chỉ liếc mắt không cần thần thức đã xét được phẩm chất pháp bảo","chuong":"@c0618"}],"kinhLich":[{"text":"Khi Vương Lâm bước vào Bảo Hợp Lâu, Lô Phong ra chặn, nêu nguyên tắc dưới Nguyên Anh không tiến, không có mười vạn linh thạch không tiến, vào rồi không giao dịch được không ra. Gã chỉ liếc đã chê phi kiếm Vương Lâm thấp kém và từ chối. Trước khi Vương Lâm rời đi, gã bị ánh mắt hắn nhìn thẳng khiến Nguyên Anh gần sụp đổ, mặt tái nhợt, lùi vài bước, thoáng ngờ phi kiếm kia có chỗ khác biệt.","bridge":true,"khoang":"@c0618"},{"text":"Gác cửa Bảo Hợp Lâu, nêu nguyên tắc “hai không tiến, một không ra” chặn Vương Lâm vì không đủ mười vạn linh thạch, chê phi kiếm thấp kém và từ chối thu. Bị ánh mắt Vương Lâm dọa cho rúng động như dội nước lạnh, Nguyên Anh gần sụp đổ, mặt tái nhợt lùi vài bước, thoáng ngờ phi kiếm có chỗ khác biệt.","bridge":true,"khoang":"@c0618"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khinh rẻ và từ chối phi kiếm của Vương Lâm; bị ánh mắt hắn dọa cho Nguyên Anh gần sụp","ghiChu":"@c0618"},{"ten":"Tôn lão","tag":"cap-tren","quanHe":"Kính nể, bẩm báo và phục tùng Tôn lão ở Bảo Hợp Lâu","ghiChu":"@c0618"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khách bị gã từ chối, bị ánh mắt khách dọa rúng động","ghiChu":"Gặp @c0618"},{"ten":"Tôn lão","tag":"cap-tren","quanHe":"Lão già có vị trí siêu nhiên ở Bảo Hợp Lâu mà gã cung kính bẩm báo","ghiChu":"Gặp @c0618"}],"tuViMoc":[{"chuong":"@c0618","canhGioi":"Nguyên Anh","text":"Tu vi Nguyên Anh khi gác cửa Bảo Hợp Lâu.","importance":"minor"}],"tuiDo":{},"tuVi":"Tu vi Nguyên Anh."},"nguon":["@c0618"]},{"id":"ton-lao-bao-hop-lau","name":"Tôn lão","cn":"","aliases":["Lão già lưng còng Bảo Hợp Lâu","#ton-lao-bao-hop-lau-618"],"gioiTinh":"nam","theLuc":[{"ten":"Bảo Hợp Lâu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến trung kỳ (từng đạt, đã tụt cảnh)","trangThai":"song","blurb":"Lão già lưng còng chống gậy ở Bảo Hợp Lâu, hiện Hóa Thần sơ kỳ nhưng có vị trí siêu nhiên; từng đạt Anh Biến trung kỳ rồi bị thương nặng nên tụt cảnh. (+) Lão già lưng còng chống gậy ở Bảo Hợp Lâu, từng đạt Anh Biến trung kì nhưng bị thương nặng tụt cảnh; thoáng thấy bóng dáng Vương Lâm quen quen. [CAN-SOAT-GOP]","vaiTro":"Nhân vật siêu nhiên ở Bảo Hợp Lâu","tinhCach":[{"text":"Trầm tĩnh, mệt mỏi, hay trầm ngâm","chuong":"@c0618"}],"tabs":{"diem":[{"text":"Từng đạt Anh Biến trung kỳ song bị thương quá nặng nên tụt xuống Hóa Thần sơ kỳ","chuong":"@c0618"},{"text":"Có vị trí siêu nhiên ở Bảo Hợp Lâu, được Lô Phong kính nể","chuong":"@c0618"},{"text":"Tu vi hiện Hóa Thần sơ kì nhưng có vị trí siêu nhiên ở Bảo Hợp Lâu, từng đạt Anh Biến trung kì rồi bị thương tụt cảnh","chuong":"@c0618"}],"kinhLich":[{"text":"Nghe Lô Phong bị một tu sĩ làm rúng động, Tôn lão chống gậy đi ra hỏi han. Lô Phong cung kính bẩm báo nhưng không dám nói hết sự thật. Tôn lão nhìn theo bóng Vương Lâm khuất dần, thầm thấy bóng dáng này có chút quen quen, lộ tia nghi hoặc, rồi mệt mỏi trở vào lâu, sờ ngực thở dài, trầm ngâm.","bridge":true,"khoang":"@c0618"},{"chuong":"@c0618","importance":"normal","tieuDe":"Thoáng nhận ra bóng dáng Vương Lâm quen quen","text":"Nghe tiếng Lô Phong, Tôn lão lưng còng chống gậy đi ra, nghe Lô Phong bẩm báo có tu sĩ tới bán phi kiếm tầm thường. Lão nhìn theo bóng Vương Lâm khuất dần, lộ tia nghi hoặc, thầm thấy bóng dáng này có chút quen quen, rồi mệt mỏi trở vào lâu, sờ ngực thở dài, trầm ngâm."},{"text":"Nghe Lô Phong bẩm báo có tu sĩ tới bán phi kiếm tầm thường, lão đi ra nhìn theo bóng Vương Lâm khuất dần, lộ tia nghi hoặc, thầm thấy bóng dáng này có chút quen quen, rồi mệt mỏi trở vào lâu, sờ ngực thở dài trầm ngâm.","bridge":true,"khoang":"@c0618"}],"nhanMach":[{"ten":"Lô Phong","tag":"khac","quanHe":"Người gác cửa Bảo Hợp Lâu kính nể và bẩm báo cho Tôn lão","ghiChu":"@c0618"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Thoáng thấy bóng dáng Vương Lâm quen quen, lộ tia nghi hoặc","ghiChu":"@c0618"},{"ten":"Lô Phong","tag":"cap-tren","quanHe":"Thuộc cấp gác cửa của Bảo Hợp Lâu, kính nể Tôn lão","ghiChu":""},{"ten":"Lô Phong","tag":"khac","quanHe":"Người gác cửa cung kính bẩm báo với lão","ghiChu":"Gặp @c0618"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tu sĩ mà lão thoáng thấy bóng dáng quen quen, lộ tia nghi hoặc","ghiChu":"Gặp @c0618"}],"tuViMoc":[{"chuong":"@c0618","canhGioi":"Hóa Thần sơ kỳ","text":"Hiện tại tu vi Hóa Thần sơ kỳ; từng đạt Anh Biến trung kỳ nhưng bị thương nặng nên tụt cảnh.","importance":"major"}],"tuiDo":{},"tuVi":"Tu vi hiện Hóa Thần sơ kì, từng đạt Anh Biến trung kì rồi bị thương tụt cảnh."},"nguon":["@c0618"]},{"id":"van-si-tre-thanh-truc-cac","name":"Văn sĩ trẻ Thanh Trúc Các","cn":"","aliases":["Văn sĩ Thanh Trúc Các","#van-si-tre-thanh-truc-cac-618","#van-si-tre-thanh-truc-cac-c0618"],"gioiTinh":"nam","theLuc":[{"ten":"Thanh Trúc Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Hóa Thần sơ kỳ","trangThai":"song","blurb":"Thanh niên tu vi Hóa Thần sơ kỳ coi cửa Thanh Trúc Các, thái độ hiền hòa nhiệt tình; xem phi kiếm Vương Lâm rồi kinh khiếp. (+) Thanh niên coi Thanh Trúc Các, thái độ hiền hòa nhiệt tình, kinh khiếp khi xem phi kiếm của Vương Lâm. [CAN-SOAT-GOP]","vaiTro":"Người coi cửa hàng Thanh Trúc Các","tinhCach":[{"text":"Hiền hòa, nhiệt tình, ham đọc sách cổ","chuong":"@c0618"}],"tabs":{"diem":[{"text":"Thái độ niềm nở, khác hẳn Lô Phong ở Bảo Hợp Lâu","chuong":"@c0618"},{"text":"Tu vi Hóa Thần sơ kì, thái độ niềm nở khác hẳn Lô Phong ở Bảo Hợp Lâu","chuong":"@c0618"}],"kinhLich":[{"text":"Khi Vương Lâm tới Thanh Trúc Các, văn sĩ trẻ đang đọc sách cổ, niềm nở mời chào. Ban đầu cười khổ tưởng kiếm tầm thường, nhưng khi nhận lấy dùng thần thức xem xét, đột nhiên mở tròn mắt, kinh khiếp nhìn chằm chằm vào thanh phi kiếm.","bridge":true,"khoang":"@c0618"},{"text":"Đang ngồi đọc sách cổ, văn sĩ trẻ tiếp đón Vương Lâm nhiệt tình. Khi nhận thanh phi kiếm dùng thần thức xem xét, ban đầu cười khổ tưởng kiếm tầm thường, nhưng đột nhiên mở tròn mắt, kinh khiếp nhìn chằm chằm vào thanh kiếm.","bridge":true,"khoang":"@c0618"},{"text":"Đang đọc sách cổ ở Thanh Trúc Các, niềm nở mời chào Vương Lâm. Ban đầu cười khổ tưởng phi kiếm tầm thường, nhưng khi nhận lấy dùng thần thức xem xét, đột nhiên mở tròn mắt, kinh khiếp nhìn chằm chằm vào thanh kiếm.","bridge":true,"khoang":"@c0618"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Nhận phi kiếm của Vương Lâm, dùng thần thức xem rồi kinh khiếp","ghiChu":"@c0618"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Tiếp đón Vương Lâm, kinh khiếp khi xem phi kiếm hắn trình","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách trình phi kiếm khiến văn sĩ kinh khiếp","ghiChu":"Gặp @c0618"}],"tuViMoc":[{"chuong":"@c0618","canhGioi":"Hóa Thần sơ kỳ","text":"Tu vi Hóa Thần sơ kỳ khi coi cửa Thanh Trúc Các.","importance":"minor"}],"tuiDo":{},"tuVi":"Tu vi Hóa Thần sơ kì."},"nguon":["@c0618"]},{"id":"ga-thanh-nien-ngoai-thanh-bac","name":"Gã thanh niên ngoài thành bắc","cn":"","aliases":["#ga-thanh-nien-ngoai-thanh-bac-618","#ga-thanh-nien-ngoai-thanh-bac-c0618"],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Kết Đan","trangThai":"song","blurb":"Tu sĩ tu vi thấp ngồi thổ nạp gần núi đá ngoài thành bắc, khinh thường Vương Lâm nhưng vẫn chỉ đường tới Bảo Hợp Lâu.","vaiTro":"Tu sĩ thoáng qua chỉ đường","tinhCach":[{"text":"Khinh người, cho Vương Lâm là tư chất tầm thường","chuong":"@c0618"}],"tabs":{"diem":[{"text":"Khinh miệt Vương Lâm là tu sĩ Kết Đan không đủ tư cách vào Bảo Hợp Lâu","chuong":"@c0618"}],"kinhLich":[{"text":"Ngồi thổ nạp gần núi đá ngoài thành bắc, gã thanh niên thầm khinh thường Vương Lâm tư chất tầm thường, nhưng khi được hỏi nơi nào buôn bán pháp bảo tốt thì đáp lạnh lùng ‘Thành đông Bảo Hợp Lâu’, trong bụng cười nhạo Vương Lâm chẳng đủ tư cách bước vào.","bridge":true,"khoang":"@c0618"},{"text":"Ngồi thổ nạp gần núi đá ngoài thành bắc, thầm khinh thường Vương Lâm (cho rằng tư chất tầm thường cả đời chẳng kết anh). Khi được Vương Lâm ôn tồn ôm quyền hỏi, gã đáp lạnh lùng khinh miệt “Thành đông Bảo Hợp Lâu”, trong bụng cười nhạo hắn chỉ là tu sĩ Kết Đan e không đủ tư cách bước vào.","bridge":true,"khoang":"@c0618"},{"text":"Ngồi thổ nạp gần núi đá ngoài thành bắc, thầm khinh thường Vương Lâm cho rằng cả đời chẳng kết anh. Khi Vương Lâm ôn tồn hỏi nơi nào buôn bán pháp bảo tốt, gã đáp lạnh lùng khinh miệt “Thành đông Bảo Hợp Lâu”, trong bụng cười nhạo Vương Lâm chỉ là tu sĩ Kết Đan.","bridge":true,"khoang":"@c0618"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Khinh thường nhưng vẫn chỉ Vương Lâm tới Bảo Hợp Lâu","ghiChu":"@c0618"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Khinh thường nhưng chỉ đường cho Vương Lâm tới Bảo Hợp Lâu","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Gã khinh thường nhưng vẫn chỉ đường cho Vương Lâm","ghiChu":"Gặp @c0618"}],"tuViMoc":[{"chuong":"@c0618","canhGioi":"Kết Đan","text":"Tu vi Kết Đan, ngồi thổ nạp ngoài thành bắc.","importance":"minor"}],"tuiDo":{},"tuVi":"Tu vi Kết Đan."},"nguon":["@c0618","@c0617"]},{"id":"ton-mac-thanh-truc-cac","name":"Tôn Mặc","cn":"","aliases":["#ton-mac-thanh-truc-cac-619"],"gioiTinh":"nam","theLuc":[{"ten":"Thanh Trúc Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Kết Đan","trangThai":"song","blurb":"Thanh niên tu sĩ Kết Đan của Thanh Trúc Các, người tiếp Vương Lâm và mời trưởng lão Anh Biến tới kiểm định phi kiếm.","vaiTro":"Nhân vật phụ — nhân viên cửa hàng Thanh Trúc Các tại Nhiễm Vân Tinh.","tinhCach":[{"text":"Tinh tế, am hiểu pháp bảo nhưng dễ tự ái khi nghĩ bị xem thường.","chuong":"@c0619"}],"tabs":{"diem":[{"text":"Dùng thần thức quan sát đánh giá phi kiếm rất tỉ mỉ.","chuong":"@c0619"},{"text":"Dùng thần thức và linh lực thử phi kiếm, phát hiện được lạc ấn thuấn di hiếm thấy","chuong":"@c0619"}],"kinhLich":[{"text":"Tôn Mặc dùng thần thức và linh lực thử thanh phi kiếm Vương Lâm bán, kinh ngạc phát hiện kiếm có lạc ấn thuấn di — điều gần như bất khả với phi kiếm thường. Hắn đánh giá tính chất dung hợp đạt linh bảo bậc trung, linh hoạt sắc bén đạt linh bảo bậc cao, trả từ mười vạn lên mười lăm vạn linh thạch thượng phẩm, rồi vỗ túi trữ vật lấy ngọc giản mời tiền bối Anh Biến tới kiểm định.","bridge":true,"khoang":"@c0619"},{"chuong":"@c0619","importance":"normal","tieuDe":"Thử phi kiếm ngụy tiên bảo và mời trưởng lão","text":"Tôn Mặc dùng thần thức quan sát phi kiếm Vương Lâm đem bán, vận linh lực dung nhập vào kiếm, phát hiện tính chất dung hợp đạt linh bảo bậc trung, sắc bén đạt bậc cao, và đặc biệt có lạc ấn thuấn di khiến kiếm biến mất rồi xuất hiện cách hơn mười trượng. Trả giá mười lăm vạn linh thạch thượng phẩm nhưng không đủ tư cách mua; tức giận khi Vương Lâm hỏi có tu sĩ Anh Biến không, rồi dùng ngọc giản mời trưởng lão tới."},{"text":"Tại Thanh Trúc Các, Tôn Mặc dùng thần thức quan sát thanh phi kiếm Vương Lâm đem bán, phát hiện bên trong có thần thông lạ truyền uy áp khiến nguyên thần chấn động. Hắn dung nhập linh lực, điều khiển kiếm bắn xuyên khối nguyên linh thạch thượng phẩm không một tiếng động, đánh giá tính dung hợp đạt linh bảo bậc trung và linh hoạt sắc bén đạt linh bảo bậc cao, rồi kinh ngạc nhận ra phi kiếm có lạc ấn thuấn di — điều gần như bất khả với phi kiếm thường. Hắn trả mười vạn rồi tăng lên mười lăm vạn linh thạch thượng phẩm, sau dùng ngọc giản mời trưởng lão Anh Biến tới kiểm định.","bridge":true,"khoang":"@c0619"}],"tuViMoc":[{"chuong":"@c0619","canhGioi":"Kết Đan","text":"Tu vi Kết Đan, chỉ phát huy được một phần mười uy lực phi kiếm nên Vương Lâm yêu cầu mời tu sĩ Anh Biến.","importance":"minor"},{"chuong":"@c0619","canhGioi":"Kết Đan","text":"Tu vi Kết Đan, được mô tả khi tiếp xúc Vương Lâm","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách bán phi kiếm","ghiChu":"Nghi Vương Lâm ẩn nấp tu vi vì phong thái như tộc trưởng dù chỉ biểu hiện Kết Đan hậu kì.","gap":"@c0619"},{"ten":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","tag":"su-mon","quanHe":"Trưởng lão gia tộc","ghiChu":"Tôn Mặc mời lão tới kiểm định phi kiếm.","gap":"@c0619"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách hàng mang phi kiếm ngụy tiên bảo tới bán","ghiChu":"Tu vi biểu hiện Kết Đan hậu kì nhưng phong thái như tộc trưởng"},{"ten":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","tag":"cap-tren","quanHe":"Trưởng lão gia tộc Thanh Trúc Các, được Tôn Mặc mời tới kiểm định phi kiếm","ghiChu":"Tu sĩ Anh Biến hậu kì"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người tiếp và thẩm định phi kiếm ngụy tiên bảo Vương Lâm đem bán","ghiChu":"Gặp @c0619"},{"ten":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","tag":"su-mon","quanHe":"Trưởng lão gia tộc cùng Thanh Trúc Các mà Tôn Mặc mời tới kiểm định","ghiChu":"@c0619"}],"tuiDo":{"khac":[{"ten":"Ngọc giản","loai":"truyền tin","moTa":"Ngọc giản Tôn Mặc dùng nói lời rồi hóa thanh quang bay đi mời trưởng lão Anh Biến.","nguon":"@c0619"}]}},"nguon":["@c0619"]},{"id":"lao-gia-ao-xanh-thanh-truc-cac","name":"Lão già áo xanh (trưởng lão Thanh Trúc Các)","cn":"","aliases":["#lao-gia-ao-xanh-truong-lao-thanh-truc-cac-619"],"gioiTinh":"nam","theLuc":[{"ten":"Thanh Trúc Các","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Anh Biến hậu kỳ","trangThai":"song","blurb":"Trưởng lão gia tộc tại Thanh Trúc Các, tu sĩ Anh Biến hậu kỳ có kinh nghiệm sinh tử, kiểm định và mua phi kiếm ngụy tiên bảo của Vương Lâm.","vaiTro":"Nhân vật phụ — trưởng lão kiểm định pháp bảo tại Nhiễm Vân Tinh.","tinhCach":[{"text":"Lão luyện, giàu kinh nghiệm sinh tử; khó che giấu lòng tham trước bảo vật quý hiếm.","chuong":"@c0619"}],"tabs":{"diem":[{"text":"Định danh chính xác phi kiếm là ngụy tiên bảo có thuật Đại Na Di và lôi điện kì dị.","chuong":"@c0619"},{"text":"Định danh được phi kiếm là ngụy tiên bảo có thuật Đại Na Di và lôi điện kì dị","chuong":"@c0619"},{"text":"Tích lũy trăm năm dành năm vạn tiên ngọc cho Vấn Đỉnh, nay dao động trước gương đồng","chuong":"@c0619"}],"kinhLich":[{"text":"Lão già áo xanh tiến vào Thanh Trúc Các thử phi kiếm: thấy nó bay ra ngoài ngàn dặm rồi tức khắc trở lại nhờ thuấn di, tuôn tiên khí hóa kiếm khí sắc bén, lại có đạo quang điện kì dị; chạm thử quang điện thì bị chấn lùi mấy bước, mặt tái nhợt nhưng mắt vui mừng khôn xiết. Lão khẳng định đó là ngụy tiên bảo có thuật Đại Na Di, mua giá ba nghìn tiên ngọc, tiên lực tràn ngập cửa hàng.","bridge":true,"khoang":"@c0619"},{"text":"Khi Vương Lâm đưa ra mặt gương đồng, lão già nhìn thoáng qua thì sắc mặt biến đổi mãnh liệt, kinh sợ hơn cả lúc nhìn phi kiếm, thất thanh gọi đó là “kế thừa ngụy tiên bảo” và lộ rõ lòng tham. Năm vạn tiên ngọc Vương Lâm ra giá là khoản tích lũy trăm năm lão dành cho việc Vấn Đỉnh bảy ngày sau, nếu xuất ra sẽ không đủ.","bridge":true,"khoang":"@c0619"},{"chuong":"@c0619","importance":"normal","tieuDe":"Kiểm định và mua phi kiếm ngụy tiên bảo","text":"Được Tôn Mặc mời tới kiểm định phi kiếm: thấy kiếm có thuấn di (bay ngàn dặm rồi tức khắc quay về), tiên khí hóa kiếm khí sắc bén, và đặc biệt một đạo lôi điện kì dị chạm vào thì bị chấn lùi mấy bước. Xác định phi kiếm là ngụy tiên bảo có thuật Đại Na Di, mua với giá ba nghìn tiên ngọc. Khi Vương Lâm đưa ra gương đồng kế thừa ngụy tiên bảo, lão khiếp sợ và tham lam, nhưng giá năm vạn tiên ngọc là toàn bộ tích lũy trăm năm dành cho Vấn Đỉnh 7 ngày sau."},{"text":"Lão già áo xanh tiến vào Thanh Trúc Các, cầm phi kiếm thử: thấy kiếm bay ra ngoài ngàn dặm rồi tức khắc xuất hiện trở lại (thuấn di), tiên khí tràn ra hóa kiếm khí sắc bén, lại có đạo điện quang chạy qua. Lão chạm thử điện quang thì bị chấn lùi mấy bước, sắc mặt tái nhợt nhưng vui mừng khôn xiết. Lão khẳng định đây không phải tiên bảo mà là ngụy tiên bảo có thuật Đại Na Di, lôi điện kì dị mới là điểm quý báu, rồi mua phi kiếm với ba nghìn tiên ngọc, tiên lực tràn ngập Thanh Trúc Các.","bridge":true,"khoang":"@c0619"},{"chuong":"@c0619","importance":"normal","tieuDe":"Dao động trước gương đồng kế thừa","text":"Khi Vương Lâm lấy ra mặt gương đồng, lão già nhìn thoáng qua thì sắc mặt biến đổi mãnh liệt, khiếp sợ hơn cả lúc nhìn phi kiếm, thất thanh gọi đó là kế thừa ngụy tiên bảo, lộ rõ lòng tham. Năm vạn tiên ngọc Vương Lâm ra giá là khoản tích lũy trăm năm lão dành cho Vấn Đỉnh bảy ngày sau, nếu xuất ra sẽ không đủ."}],"tuViMoc":[{"chuong":"@c0619","canhGioi":"Anh Biến hậu kỳ","text":"Tu vi Anh Biến hậu kỳ (chưa hoàn hảo), giàu kinh nghiệm sinh tử; dự định Vấn Đỉnh bảy ngày sau bằng khoản năm vạn tiên ngọc tích lũy trăm năm.","importance":"minor"},{"chuong":"@c0619","canhGioi":"Anh Biến hậu kì","text":"Tu vi Anh Biến hậu kì chưa hoàn hảo, dự định Vấn Đỉnh 7 ngày sau","importance":"minor"},{"chuong":"@c0619","canhGioi":"Anh Biến hậu kỳ","text":"Tu vi Anh Biến hậu kì chưa hoàn hảo, có kinh nghiệm sinh tử","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Khách bán ngụy tiên bảo","ghiChu":"Mua phi kiếm; bị gương đồng kế thừa ngụy tiên bảo lôi cuốn — đối tượng Vương Lâm ngầm tính giết để đoạt bảo nếu lão ra tay cướp.","gap":"@c0619"},{"ten":"Tôn Mặc","tag":"su-mon","quanHe":"Hậu bối trong Thanh Trúc Các","ghiChu":"Tôn Mặc mời lão tới kiểm định phi kiếm.","gap":"@c0619"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách hàng bán phi kiếm và gương đồng ngụy tiên bảo","ghiChu":"Nghi vấn là con cháu gia tộc lớn vì phong thái bất phàm dù tu vi chỉ Kết Đan hậu kì"},{"ten":"Tôn Mặc","tag":"khac","quanHe":"Thành viên Thanh Trúc Các, người mời lão tới kiểm định","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người bán phi kiếm và gương đồng ngụy tiên bảo cho lão","ghiChu":"Gặp @c0619"},{"ten":"Tôn Mặc","tag":"su-mon","quanHe":"Hậu bối cùng Thanh Trúc Các mời lão tới kiểm định phi kiếm","ghiChu":"@c0619"}],"tuiDo":{"phapBao":[{"ten":"Phi kiếm (ngụy tiên bảo)","loai":"ngụy tiên bảo","trangThai":"dang-co","moTa":"Phi kiếm mua của Vương Lâm với giá ba nghìn tiên ngọc; mang lạc ấn thuấn di, thuật Đại Na Di và lôi điện kì dị.","nguon":"@c0619"}]}},"nguon":["@c0619"]},{"id":"nguoi-thanh-nien-nu-gia-nam-621","name":"Người thanh niên nữ giả nam","aliases":[],"gioiTinh":"nu","theLuc":[],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Một phụ nữ giả nam, gầy gò mặc quần áo rộng thùng thình, dùng pháp thuật che phủ tướng mạo, tĩnh tọa thổ nạp gần chỗ ở Vương Lâm tại Nhiễm Vân Tinh.","vaiTro":"Nhân vật phụ bí ẩn xuất hiện gần nơi trú của Vương Lâm.","tinhCach":[{"text":"Cao giọng dạy bảo, tự tin về cách tu chân.","chuong":"@c0621"}],"tabs":{"diem":[{"text":"Một phụ nữ giả nam, dùng pháp thuật che mặt giấu tướng mạo thật.","chuong":"@c0621"},{"text":"Lên giọng giáo huấn Vương Lâm về tu chân: phải chăm chỉ, bế quan vài chục năm mới kết anh.","chuong":"@c0621"}],"kinhLich":[{"text":"Tĩnh tọa thổ nạp dưới ngọn núi gần chỗ ở Vương Lâm, gọi hắn dừng lại lên giọng dạy bảo: tu chân quan trọng nhất là chăm chỉ, tư chất không tốt phải siêng năng nếu không cả đời không kết anh thành công, khuyên bế quan vài chục năm để tâm vững thân vững mới nghịch thiên tu hành. Khi Vương Lâm vào cửa, một làn gió thổi tung búi tóc, người này vô thức đưa tay vuốt mái tóc dịu dàng, để lộ là nữ giả nam.","bridge":true,"khoang":"@c0621"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người được giáo huấn về tu chân, đã phát hiện ra thân phận nữ giả nam","ghiChu":""}],"tuiDo":{}},"nguon":["@c0621"]},{"id":"ton-khai-minh-621","name":"Tôn Khải Minh","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn Gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"khong-ro","trangThai":"song","blurb":"Lão già mặc hắc y của Tôn Gia, người phụ trách tòa thành nơi Vương Lâm trú tại Nhiễm Vân Tinh; cung kính giao tiên ngọc và lệnh bài đấu giá cho Vương Lâm.","vaiTro":"Người phụ trách thành của Tôn Gia, trung gian giao tiên ngọc và dò xét tu vi Hứa Mộc.","tinhCach":[{"text":"Cung kính, dè dặt; sợ áp lực của Vương Lâm.","chuong":"@c0621"}],"tabs":{"diem":[{"text":"Tu vi vốn cao, tự hạ xuống Kết Đan kỳ khi vào gặp Vương Lâm.","chuong":"@c0621"},{"text":"Nhận lệnh tộc thăm dò tu vi Hứa Mộc, buộc phải nhắc chuyện đấu giá.","chuong":"@c0621"}],"kinhLich":[{"text":"Hạ tu vi xuống Kết Đan kỳ rồi cung kính gặp Vương Lâm, giới thiệu bản thân và hỏi tên — được đáp là Hứa Mộc. Giao túi trữ vật chứa hai mươi vạn tiên ngọc. Được người trong tộc giao nhiệm vụ thăm dò tu vi Hứa Mộc nên buộc phải nói ra chuyện đấu giá bảy ngày sau ở Bảo Hợp Lâu của Nhiễm Gia với một viên bát phẩm thứ thần đan. Bị Vương Lâm phóng áp lực vô hình khiến run rẩy nuốt lời, cuối cùng lấy ra một khối lệnh bài đấu giá hồng sắc đưa cho hắn rồi lui ra.","bridge":true,"khoang":"@c0621"},{"chuong":"@c0621","importance":"normal","tieuDe":"Giao tiên ngọc và lệnh bài cho Hứa Mộc","text":"Tôn Khải Minh cung kính xuất hiện, giới thiệu bản thân và hỏi tên Vương Lâm. Lão giao túi trữ vật chứa hai mươi vạn tiên ngọc, rồi theo lệnh tộc dò tu vi nên buộc phải nói ra chuyện đấu giá bát phẩm thứ thần đan bảy ngày sau ở Bảo Hợp Lâu. Bị Vương Lâm phóng áp lực vô hình khiến lão run rẩy nuốt lời, cuối cùng lão đưa lệnh bài đấu giá hồng sắc rồi lui ra."},{"text":"Ngồi cạnh Tôn Tích ở tầng bốn, Tôn Khải Minh đông cứng trước màn Vương Lâm hô giá một khối tiên ngọc, hồi lâu không nói nên lời.","bridge":true,"khoang":"@c0624"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Giao tiên ngọc và lệnh bài đấu giá cho hắn (dưới danh Hứa Mộc); nhận lệnh dò tu vi","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Khách trú (danh Hứa Mộc) trong thành lão phụ trách","ghiChu":"Cung kính giao tiên ngọc và lệnh bài, được lệnh tộc thăm dò tu vi Vương Lâm."},{"ten":"Tôn Tích","tag":"ho-hang","quanHe":"Ngồi cạnh nhau ở phòng tầng bốn","ghiChu":"Cùng chứng kiến màn ra giá (@c0624)"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0621","@c0624"]},{"id":"ton-tich","name":"Tôn Tích","cn":"","aliases":["Người áo bào tím"],"gioiTinh":"nam","theLuc":[{"ten":"Tôn Gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh sơ kỳ","trangThai":"song","blurb":"Lão tổ Vấn Đỉnh sơ kỳ của Tôn Gia trên Nhiễm Vân Tinh, một trong ba tu sĩ Vấn Đỉnh Kỳ; tới thăm dò Vương Lâm thì bị áp đảo nên quay sang cầu giúp.","vaiTro":"Lão tổ Tôn Gia","tinhCach":[{"text":"Sâu hiểm, thận trọng nhưng linh hoạt biết co duỗi","chuong":"@c0622"}],"tabs":{"diem":[{"text":"Một trong ba tu sĩ Vấn Đỉnh Kỳ trên Nhiễm Vân Tinh","chuong":"@c0622"},{"text":"Vẻ ngoài thanh niên trên dưới ba mươi, áo bào tím, khí sắc bén dung nhập không khí","chuong":"@c0622"}],"kinhLich":[{"text":"Vừa kết thúc tu luyện dưới đáy biển, Tôn Tích tới Thiên Vận Thành trước cổng thành Bắc thăm dò Hứa Mộc (Vương Lâm). Hắn tỏa uy bức và chiến ý nhưng bị Vương Lâm dùng tám bước áp đảo, trắng bệch lui bước, phải ôm quyền cầu hòa.","bridge":true,"khoang":"@c0622"},{"text":"Tôn Tích tự xưng lão tổ Vấn Đỉnh sơ kỳ của Tôn Gia, cầu Vương Lâm trợ giúp. Khi đề nghị dốc toàn lực gia tộc bị bác, hắn đổi sang tặng suất đi Lôi tiên giới trăm năm sau ở La Thiên Tinh Vực; lời nói cũng hé lộ nghi ngờ về lai lịch Vương Lâm.","bridge":true,"khoang":"@c0622"},{"chuong":"@c0622","importance":"normal","tieuDe":"Thăm dò rồi bị Vương Lâm áp đảo","text":"Tôn Tích đứng chờ trước cổng thành Bắc tỏa uy bức và chiến ý, liếc mắt khiến Tôn Lăng run như đứng trước viễn cổ hung thú. Khi Vương Lâm bước tám bước uy thế, hắn trắng bệch liên tục lui, phải ôm quyền nói không có ác ý."},{"chuong":"@c0622","importance":"normal","tieuDe":"Lộ thân phận, đề nghị Lôi tiên giới","text":"Trên đường tới Bảo Hợp Lâu thành Đông, Tôn Tích tự xưng lão tổ Tôn Gia, cầu Vương Lâm giúp. Bị bác đề nghị dốc toàn lực gia tộc, hắn chuyển sang tặng suất đi Lôi tiên giới trăm năm sau, đồng thời sinh nghi về lai lịch của Vương Lâm."},{"text":"Tôn Tích kiêng dè ‘Hứa huynh’, kể lại chuyện bốn năm trước cùng lão tổ Nhiễm Gia và Tiêu Diêu Cư Sĩ đồng thời xuất thủ cướp năm viên bát phẩm đan dược từ một tu sĩ ngoại lai bị trọng thương; kẻ này chết trong tay Nhiễm Gia lão tổ. Hắn tiết lộ trong túi trữ vật kẻ bị giết có lệnh bài Chủ Tinh Thiên Huyễn, gián tiếp cảnh báo Vương Lâm về cái bẫy đan dược.","bridge":true,"khoang":"@c0623"},{"text":"Ở phòng tầng bốn cùng Vương Lâm, khi nghe màn hô giá một khối tiên ngọc, Tôn Tích đang định uống trà thì khựng lại, buột miệng gọi “Hứa huynh, bội phục bội phục!”.","bridge":true,"khoang":"@c0624"},{"text":"Tôn Tích ngồi khoanh chân ở vị trí gần Vương Lâm nhất, là một trong ba người trên Nhiễm Vân tinh cảm nhận rõ cơn lốc tiên lực khi Vương Lâm đột phá; hắn mở mắt kinh sợ.","bridge":true,"khoang":"@c0626"},{"text":"Tôn Tích là tu sĩ liên can việc bốn năm trước, bị Vương Lâm ép hiện thân. Hắn chấp nhận nộp bảy phần tiên ngọc gia tộc. Sau khi Vương Lâm rời đi, Tôn Tích là người nhẹ nhõm nhất, mỉm cười cáo lui với cớ “chuyện quan trọng”, trong lòng có ý nghĩ khác chưa lộ.","bridge":true,"khoang":"@c0627"},{"chuong":"@c0627","importance":"normal","tieuDe":"Hiện thân, nộp bảy phần tiên ngọc","text":"Bị Vương Lâm ép hiện thân, chấp nhận nộp bảy phần tiên ngọc gia tộc để được che chở chuyện bốn năm trước. Sau khi Vương Lâm đi, là người nhẹ nhàng nhất, mỉm cười cáo lui với lý do có chuyện quan trọng, trong lòng ngầm có ý nghĩ khác chưa lộ."},{"text":"Đang thổ nạp trong tổ trạch Tôn gia thì nhận truyền âm của Vương Lâm, được lệnh khắc tất cả tinh đồ của La Thiên tinh vực mà hắn biết vào ngọc giản đưa tới.","bridge":true,"khoang":"@c0628"},{"text":"Một trong ba lão tổ liên minh chống Huyễn gia, bình tĩnh và muốn quan hệ tốt với Hứa Mộc vì hắn càng mạnh càng có lợi. Tôn Tích giải thích cho Vương Lâm chuyện Lão tổ Huyễn gia mang Huyễn Mi về làm con gái nuôi, tu vi đã đạt cảnh giới Âm Dương Hư Thực từ mấy ngàn năm trước.","bridge":true,"khoang":"@c0630"},{"chuong":"@c0630","importance":"normal","tieuDe":"Giải thích chuyện Huyễn Mi","text":"Bình tĩnh trước uy thế của Hứa Mộc, vui mừng vì Hứa Mộc càng mạnh thì càng muốn quan hệ tốt. Tôn Tích giải thích cho Vương Lâm rằng Lão tổ Huyễn gia khi trở về mang theo một cô gái từ Liên Minh Tinh Vực, thu làm con gái nuôi và sắp thi triển Hoán huyết đại pháp; Lão tổ tu vi đã bước vào bước thứ hai, mấy ngàn năm trước đã đạt cảnh giới Âm Dương Hư Thực."},{"text":"Đứng cùng Lão tổ Nhiễm gia và Tiêu Dao tán nhân trên Nhiễm Vân tinh nhìn về chân trời, sắc mặt âm trầm. Hắn chua xót nhận ra Huyễn gia đã bố trí Tỏa tinh đại trận sẽ giáng lâm Nhiễm Vân tinh, rồi lạnh lùng kết luận Huyễn gia muốn diệt tộc cả ba nhà, dùng trận đề phòng họ chạy thoát.","bridge":true,"khoang":"@c0632"},{"chuong":"@c0633","importance":"normal","tieuDe":"Bị mê hoặc tự bạo, để lại phân thân","text":"Một trong ba lão tổ, thuộc Tôn gia. Tiết lộ Lão tổ Huyễn gia tu vi tu đạo bước thứ hai đủ quét ngang chúng sinh. Bị Thiên Huyễn Vô tình đạo mê hoặc, si mê quay sang đánh Nhiễm Học Phong rồi tự bạo chết. Hắn ngầm tế luyện một phân thân tu vi Kết Đan ẩn ở cực nam Nhiễm Vân tinh; từng tìm Vương Lâm vì việc liên quan phân thân nhưng bị từ chối."}],"tuViMoc":[{"chuong":"@c0622","canhGioi":"Vấn Đỉnh sơ kỳ","text":"Lão tổ Vấn Đỉnh sơ kỳ của Tôn Gia, tu vi tương đương Vương Lâm nhưng vẫn bị tâm tính và uy thế áp chế.","importance":"major"}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tới thăm dò bị áp đảo, sau cầu trợ giúp đổi suất Lôi tiên giới","ghiChu":""},{"ten":"Tôn Lăng","tag":"su-mon","quanHe":"Người Tôn Gia phụ trách phòng thủ thành, được Tôn Tích khen tận tụy","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Cảm nhận uy lực đột phá","ghiChu":"Kinh sợ khi cơn lốc tiên lực bùng nổ."},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm ép nộp tiên ngọc che chở chuyện cũ","ghiChu":"@c0627"},{"ten":"Vương Lâm","tag":"cap-tren","quanHe":"Người ra lệnh cho Tôn Tích","ghiChu":"Lệnh khắc tinh đồ La Thiên tinh vực vào ngọc giản."},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Muốn quan hệ tốt với Hứa Mộc, giải thích cho hắn chuyện Lão tổ Huyễn gia và Huyễn Mi.","ghiChu":"@c0630"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Tới thăm dò nhưng bị tám bước áp đảo, sau quay sang cầu giúp","ghiChu":"@c0622"},{"ten":"Tôn Lăng","tag":"su-mon","quanHe":"Cùng Tôn Gia; bị Tôn Tích uy hiếp khi giữ thành nhưng được khen tận tụy","ghiChu":"@c0622"},{"ten":"Lão tổ Nhiễm Gia","tag":"dong-minh","quanHe":"Cùng Tôn Tích và Tiêu Diêu Cư Sĩ cướp đan dược bốn năm trước; nay là người giăng bẫy đấu giá.","ghiChu":"@c0623"},{"ten":"Tiêu Diêu Cư Sĩ","tag":"dong-minh","quanHe":"Một trong ba người cùng cướp đan dược bốn năm trước, được chia một viên.","ghiChu":"@c0623"},{"ten":"Tôn Khải Minh","tag":"ho-hang","quanHe":"Tộc nhân đời thứ ba Tôn Gia phụ trách tòa thành, cung kính tham kiến lão tổ.","ghiChu":"@c0623"},{"ten":"Vương Lâm","tag":"dong-minh","quanHe":"Cùng phòng tầng bốn, gọi hắn là “Hứa huynh”","ghiChu":"Được Vương Lâm ôm quyền chào trước khi rời đi (@c0624)"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm (danh Hứa mỗ) ép nộp tiên ngọc","ghiChu":"@c0627"},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Cùng là lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Triệu Truyền Văn","tag":"dong-minh","quanHe":"Cùng là lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Tiêu Dao tán nhân","tag":"dong-minh","quanHe":"Cùng đứng trên Nhiễm Vân tinh đối mặt mối đe dọa Huyễn gia","ghiChu":"Cùng bàn việc Tỏa tinh đại trận"},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Lão tổ Nhiễm gia, cùng đối phó Huyễn gia","ghiChu":""},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Kẻ mê hoặc","ghiChu":"Bị Vô tình đạo mê hoặc dẫn tới tự bạo; Liễu Mi sau dò ra phân thân của hắn. @c0633"},{"ten":"Vương Lâm","tag":"khac","quanHe":"Người từng cầu nhờ","ghiChu":"Từng tìm Vương Lâm vì việc liên quan phân thân nhưng bị từ chối. @c0633"},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Đồng cảnh ngộ ba lão tổ","ghiChu":"Bị mê hoặc quay sang đánh Nhiễm Học Phong. @c0633"}],"tuiDo":{}},"nguon":["@c0622","@c0626","@c0627","@c0628","@c0630","@c0623","@c0624","@c0632","@c0633"]},{"id":"ton-lang","name":"Tôn Lăng","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn Gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh","trangThai":"song","blurb":"Thanh niên tu sĩ Nguyên Anh người Tôn Gia phụ trách phòng thủ thành Bắc Thiên Vận Thành, tư chất kém nhưng cần cù, kiên quyết bảo vệ Hứa Mộc trước Tôn Tích.","vaiTro":"Tu sĩ Tôn Gia phòng thủ thành Bắc","tinhCach":[{"text":"Cần cù, tận tụy với chức trách, kiên cường dù sợ hãi","chuong":"@c0622"}],"tabs":{"diem":[{"text":"Tự nhận tư chất không tốt nhưng cần cù, mục tiêu đạt Nguyên Anh trung kỳ","chuong":"@c0622"},{"text":"Run rẩy trước uy áp Tôn Tích vẫn đứng vững không lui, khiến Vương Lâm cảm động","chuong":"@c0622"}],"kinhLich":[{"text":"Khi Tôn Tích áo tím tới thành Bắc, Tôn Lăng cầm ngọc giản truyền tin đối chất, kiên quyết không lui dù bị uy áp khiến tu sĩ Nguyên Anh run như đứng trước viễn cổ hung thú. Vương Lâm bước ra giải vây, thả sương mù xanh che mắt hắn rồi tự áp đảo Tôn Tích.","bridge":true,"khoang":"@c0622"},{"chuong":"@c0622","importance":"normal","tieuDe":"Liều mình giữ thành trước Tôn Tích","text":"Khi Tôn Tích tới uy hiếp, Tôn Lăng bảo Vương Lâm trở về, đứng chắn trước hỏi đối phương có chuyện gì, viện cớ Vương Lâm chỉ là tu sĩ Kết Đan. Dù bị Tôn Tích liếc mắt làm run như đứng trước viễn cổ hung thú, hắn vẫn không lui, được khen tận tụy. Lòng kiên cường này khiến Vương Lâm trầm mặc rồi ra tay."}],"tuViMoc":[{"chuong":"@c0622","canhGioi":"Nguyên Anh","text":"Tu sĩ Nguyên Anh, tư chất kém nhưng cần cù, mục tiêu Nguyên Anh trung kỳ.","importance":"minor"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Kiên quyết bảo vệ Hứa Mộc (Vương Lâm) trước Tôn Tích, được Vương Lâm cảm động giải vây","ghiChu":""},{"ten":"Tôn Tích","tag":"su-mon","quanHe":"Lão tổ Tôn Gia, khen Tôn Lăng tận tụy nhưng dùng uy áp ép lui","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Phụ trách giữ thành cho Hứa Mộc, liều mình bảo vệ hắn trước Tôn Tích","ghiChu":"@c0622"},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Bị lão tổ Tôn Gia uy hiếp khi giữ thành nhưng kiên quyết không lui","ghiChu":"@c0622"}],"tuiDo":{}},"nguon":["@c0622"]},{"id":"su-phu-cua-lieu-mi","name":"Sư phụ của Liễu Mi","cn":"","aliases":["Lão già Huyễn Gia"],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn Gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Khuy Niết Kỳ","trangThai":"song","blurb":"Tu sĩ Khuy Niết Kỳ người gia tộc Huyễn Gia trên La Thiên Tinh Vực, sư phụ của Liễu Mi; đưa nàng về Thiên Huyễn Tinh, định thi triển Hoán Huyết và bồi dưỡng nàng vượt bước thứ hai.","vaiTro":"Sư phụ của Liễu Mi (Huyễn Gia)","tinhCach":[{"text":"Coi trọng huyết mạch gia tộc, tận tâm bồi dưỡng đệ tử","chuong":"@c0622"}],"tabs":{"diem":[{"text":"Tu sĩ Khuy Niết Kỳ, người Huyễn Gia, vài ngàn năm chưa quay về Thiên Huyễn Tinh","chuong":"@c0622"}],"kinhLich":[{"text":"Dùng La Thiên Thạch do tổ tiên Huyễn Gia lưu lại, lão đưa Liễu Mi tới Thiên Huyễn Tinh — quê hương gia tộc. Lão giải thích gia tộc La Thiên Tinh Vực coi trọng huyết mạch, định thi triển Hoán Huyết đưa máu Huyễn Gia vào nàng, nhận làm nghĩa nữ đổi tên Huyễn Mi và hứa bồi dưỡng nàng vượt qua Khuy Niết Kỳ của lão.","bridge":true,"khoang":"@c0622"},{"chuong":"@c0622","importance":"normal","tieuDe":"Đưa Liễu Mi về Thiên Huyễn Tinh","text":"Lão dùng La Thiên Thạch do tổ tiên Huyễn Gia lưu lại để bay tới Thiên Huyễn Tinh, giảng rằng La Thiên Tinh Vực coi trọng huyết mạch. Lão định thi triển Hoán Huyết đưa máu Huyễn Gia vào Liễu Mi, nhận làm nghĩa nữ, đổi tên nàng thành Huyễn Mi và hứa bồi dưỡng nàng vượt qua Khuy Niết Kỳ của mình."}],"tuViMoc":[{"chuong":"@c0622","canhGioi":"Khuy Niết Kỳ","text":"Tu sĩ Khuy Niết Kỳ của Huyễn Gia.","importance":"major"}],"nhanMach":[{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Nhận Liễu Mi làm nghĩa nữ, thi triển Hoán Huyết đổi tên thành Huyễn Mi","ghiChu":""},{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Đệ tử, nhận làm nghĩa nữ, đổi tên thành Huyễn Mi và truyền huyết mạch Huyễn Gia","ghiChu":"@c0622"}],"tuiDo":{}},"nguon":["@c0622"]},{"id":"tieu-dieu-cu-si","name":"Tiêu Diêu Cư Sĩ","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Một trong ba người cùng cướp năm viên bát phẩm đan dược từ tu sĩ ngoại lai bốn năm trước, được chia một viên.","vaiTro":"Nhân vật phụ được nhắc tên","tinhCach":[],"tabs":{"diem":[{"text":"Cùng Tôn Tích và lão tổ Nhiễm Gia ra tay cướp đan dược bốn năm trước.","chuong":"@c0623"}],"kinhLich":[{"text":"Bốn năm trước, khi một tu sĩ ngoại lai bị trọng thương chạy đến Thiên Vận Tinh, Tiêu Diêu Cư Sĩ cùng Tôn Tích và lão tổ Nhiễm Gia đồng thời xuất thủ cướp năm viên bát phẩm đan dược; được chia một viên.","bridge":true,"khoang":"@c0623"}],"nhanMach":[{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng ra tay cướp đan dược bốn năm trước.","ghiChu":"@c0623"},{"ten":"Lão tổ Nhiễm Gia","tag":"dong-minh","quanHe":"Cùng cướp đan dược; lão tổ Nhiễm Gia là kẻ giết tu sĩ ngoại lai.","ghiChu":"@c0623"}],"tuiDo":{}},"nguon":["@c0623"]},{"id":"lao-to-nhiem-gia","name":"Lão tổ Nhiễm Gia","cn":"","aliases":["Nhiễm Học Phong","Lão tổ Nhiễm gia","#nhiem-hoc-phong-lao-to-nhiem-gia-630"],"gioiTinh":"nam","theLuc":[{"ten":"Nhiễm gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh trung kỳ","trangThai":"song","blurb":"Lão tổ Nhiễm Gia, tu sĩ Vấn Đỉnh trung kỳ; bốn năm trước giết tu sĩ ngoại lai đoạt ba viên đan dược, nay giăng bẫy đấu giá nhằm vào Vương Lâm. (+) Lão tổ Nhiễm gia, kiêng kỵ thần thông Vương Lâm nên quyết không làm kẻ địch của Hứa Mộc; xin nhận Huyễn Đông từ tay Vương Lâm để xử lý. [CAN-SOAT-GOP]","vaiTro":"Nhân vật phụ, kẻ giăng bẫy","tinhCach":[{"text":"Tâm cơ thâm độc, dùng đan dược làm mồi nhử để kéo người khác vào ân oán.","chuong":"@c0623"}],"tabs":{"diem":[{"text":"Tu sĩ Vấn Đỉnh trung kỳ, kẻ trực tiếp giết tu sĩ ngoại lai bốn năm trước.","chuong":"@c0623"},{"text":"Từng suýt mất mạng khi Vương Lâm ra tay, nay quyết đời này không làm kẻ địch của Hứa Mộc","chuong":"@c0630"}],"kinhLich":[{"text":"Bốn năm trước, lão tổ Nhiễm Gia cùng Tôn Tích và Tiêu Diêu Cư Sĩ cướp năm viên bát phẩm đan dược; tu sĩ ngoại lai chết trong tay lão, lão tự đoạt ba viên.","bridge":true,"khoang":"@c0623"},{"text":"Bày bát phẩm đan dược ra bán ở thành của Tôn Gia, dùng làm mồi nhử dụ Vương Lâm động tâm mua đi để kéo hắn vào ân oán diệt tộc với Huyễn Gia; nếu không mua sẽ tìm cách khác lôi vào.","bridge":true,"khoang":"@c0623"},{"text":"Lão tổ Nhiễm gia, người tu vi cao nhất Nhiễm Vân tinh (Vấn Đỉnh trung kỳ), phóng Chưởng Tâm Lôi vào Vương Lâm nhưng bị con rối Tiên vệ đánh tan đòn sét rồi huých trọng thương khiến lão phun máu, phải nuốt một nắm đan dược. Lão kinh hãi đoán tu vi Vương Lâm có thể là Vấn Đỉnh hậu kỳ đại viên mãn, chấp nhận giao chín phần tiên ngọc gia tộc. Sau khi Vương Lâm đi, lão tự nhủ “mất tiền mua bình yên”, nhắc Hứa Mộc đã chết và đề phòng người này âm thầm rời Nhiễm Vân tinh.","bridge":true,"khoang":"@c0627"},{"text":"Cùng Tiêu Dao tán nhân và Tôn Tích bàn về kết cục sắp tới; đã âm thầm đưa dòng chính ba tộc đi giữ hương khói nhưng căn cơ Nhiễm Vân tinh không thể di chuyển. Oán Hứa Mộc đã hứa che chở rồi rời đi lúc nguy cơ, hối hận chuyện bốn năm trước.","bridge":true,"khoang":"@c0633"},{"text":"Khi Liễu Mi giáng lâm, hắn xưng tên thật Nhiễm Học Phong, quyết tử chiến. Bị Vô tình đạo mê hoặc nhưng gắng giữ tâm thần, dùng Chưởng Tâm Lôi đánh Liễu Mi song bị nàng điểm tay hóa giải; hai đồng bạn quay sang đánh hắn. Hắn thiêu nguyên thần đạt Vấn Đỉnh hậu kỳ (chỉ Ngụy hậu kỳ vì ý cảnh không theo), đánh ra ánh sáng vàng như kiếm vạn trượng.","bridge":true,"khoang":"@c0633"},{"chuong":"@c0633","importance":"normal","tieuDe":"Lời nguyền cuối cùng và tự diệt","text":"Máu chảy đầm đìa, hắn mắng Liễu Mi độc ác lan cuộc chiến tới người thường; Liễu Mi đáp nàng chưa ra tay, ba người tự đánh nhau. Hắn nguyền rủa Liễu Mi cùng Huyễn Mi và Hứa Mộc chết không đất chôn, tiết lộ người giết Huyễn Đông là Hứa Mộc chứ không phải ba người. Hắn tự vỗ trán, nguyên thần thiêu hủy hóa bụi, dùng khả năng cuối bảo vệ Nhiễm Vân tinh."},{"chuong":"@c0630","importance":"normal","tieuDe":"Nhận Huyễn Đông để xử lý","text":"Kiêng kỵ thần thông Vương Lâm, Nhiễm Học Phong quyết không làm địch của Hứa Mộc. Khi Huyễn Đông phơi bày việc ba nhà giết người Huyễn gia bốn năm trước và đe dọa, lão lộ tia sáng lạnh lẽo; sau đó xin Vương Lâm giao Huyễn Đông cho mình xử lý."},{"chuong":"@c0632","importance":"normal","tieuDe":"Đoán trận để lập uy Huyễn Mi","text":"Đứng cùng Tiêu Dao tán nhân và Tôn Tích trên Nhiễm Vân tinh, phỏng đoán việc Huyễn gia hạ Tỏa tinh đại trận nhằm lập uy cho Huyễn Mi — con gái nuôi mới thu của Lão tổ Huyễn gia."},{"chuong":"@c0633","importance":"normal","tieuDe":"Tự bạo bảo vệ Nhiễm Vân tinh","text":"Cùng hai lão tổ bàn kết cục, oán Hứa Mộc rời đi lúc nguy cơ. Khi Liễu Mi giáng lâm, ông thiêu nguyên thần đẩy tu vi lên Vấn Đỉnh hậu kỳ (Ngụy hậu kỳ, ý cảnh không theo kịp), dùng Chưởng Tâm Lôi đánh Liễu Mi nhưng bị hóa giải, rồi bị hai lão tổ bị mê hoặc quay sang đánh. Cuối cùng máu chảy đầm đìa, nguyền rủa Liễu Mi và Huyễn Mi chết không đất chôn, tiết lộ người giết Huyễn Đông là Hứa Mộc, tự vỗ trán thiêu hủy nguyên thần hóa bụi để dùng khả năng cuối bảo vệ Nhiễm Vân tinh."}],"nhanMach":[{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng cướp đan dược bốn năm trước.","ghiChu":"@c0623"},{"ten":"Tiêu Diêu Cư Sĩ","tag":"dong-minh","quanHe":"Cùng cướp đan dược bốn năm trước.","ghiChu":"@c0623"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Đối tượng bị giăng bẫy đan dược.","ghiChu":"@c0623"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm (Hứa mỗ) áp chế, buộc nộp tiên ngọc che chở","ghiChu":"@c0627"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng liên can việc bốn năm trước","ghiChu":"@c0627"},{"ten":"Hứa Mộc","tag":"khac","quanHe":"Người lo việc bốn năm trước cho Nhiễm gia, đã chết","ghiChu":"@c0627"},{"ten":"Tiêu Dao tán nhân (Triệu mỗ)","tag":"dong-minh","quanHe":"Cùng bàn kết cục, đồng bạn tử chiến","ghiChu":"Bị Vô tình đạo mê hoặc quay sang đánh Nhiễm Học Phong."},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng là lão tổ ba tộc Nhiễm Vân tinh","ghiChu":""},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Kẻ diệt tộc, bị hắn nguyền rủa","ghiChu":""},{"ten":"Hứa Mộc","tag":"doi-thu","quanHe":"Người hứa che chở rồi rời đi, bị oán và nguyền rủa","ghiChu":"Hắn tố Hứa Mộc giết Huyễn Đông."},{"ten":"Lão tổ Huyễn Gia","tag":"doi-thu","quanHe":"Sư tôn của Liễu Mi, người ra lệnh diệt tộc","ghiChu":""},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Triệu Truyền Văn","tag":"dong-minh","quanHe":"Cùng lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Kiêng dè và quy phục thế Hứa Mộc, được giao Huyễn Đông xử lý","ghiChu":"@c0630"},{"ten":"Huyễn Đông","tag":"doi-thu","quanHe":"Tộc vệ Huyễn gia bị giao cho lão xử lý","ghiChu":"@c0630"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng đối phó Huyễn gia","ghiChu":""},{"ten":"Tiêu Dao tán nhân","tag":"dong-minh","quanHe":"Cùng bàn việc Tỏa tinh đại trận","ghiChu":""},{"ten":"Huyễn Mi","tag":"doi-thu","quanHe":"Con gái nuôi của lão tổ Huyễn gia thù địch","ghiChu":"Trận pháp được cho là để lập uy cho nàng"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Kẻ diệt tộc","ghiChu":"Nguyền rủa Liễu Mi và Huyễn Mi trước khi tự diệt. @c0633"},{"ten":"Tiêu Dao tán nhân","tag":"dong-minh","quanHe":"Đồng cảnh ngộ ba lão tổ","ghiChu":"Bị mê hoặc quay sang đánh chính Nhiễm Học Phong. @c0633"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Đồng cảnh ngộ ba lão tổ","ghiChu":"Cùng bàn kết cục, sau bị mê hoặc tương tàn. @c0633"},{"ten":"Hứa Mộc","tag":"doi-thu","quanHe":"Oán hận","ghiChu":"Oán Hứa Mộc rời đi lúc nguy cơ; tố Hứa Mộc giết Huyễn Đông, nguyền rủa cùng bị hủy diệt. @c0633"}],"tuiDo":{},"tuViMoc":[{"chuong":"@c0633","canhGioi":"Vấn Đỉnh trung kỳ","text":"Cảnh giới gốc của Nhiễm Học Phong trước khi tử chiến.","importance":"major"},{"chuong":"@c0633","canhGioi":"Vấn Đỉnh hậu kỳ (Ngụy)","text":"Thiêu đốt nguyên thần đẩy lên Vấn Đỉnh hậu kỳ nhưng ý cảnh không theo kịp nên chỉ là Ngụy hậu kỳ, sau đó tự bạo.","importance":"minor"}]},"nguon":["@c0623","@c0627","@c0633","@c0630","@c0632"]},{"id":"ton-tuyet-son-ton-gia","name":"Tôn Tuyết Sơn","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Tôn Gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"song","blurb":"Vãn bối Tôn Gia, tu vi khá cao nhưng thiếu kinh nghiệm, từng được “Hứa huynh” cứu mạng.","vaiTro":"Nhân vật phụ được nhắc tên","tinhCach":[],"tabs":{"diem":[{"text":"Vãn bối Tôn Gia, tu vi khá cao nhưng thiếu kinh nghiệm; mắc nợ ơn cứu mạng của “Hứa huynh”.","chuong":"@c0623"}],"kinhLich":[{"text":"Tôn Tích nhắc Tôn Tuyết Sơn là vãn bối Tôn Gia tu vi khá cao nhưng thiếu kinh nghiệm, từng được “Hứa huynh” (Vương Lâm cải trang) cứu mạng; chính mối quan hệ này giúp Vương Lâm hóa giải nghi ngờ thân phận.","bridge":true,"khoang":"@c0623"}],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Được “Hứa huynh” (Vương Lâm cải trang) cứu mạng.","ghiChu":"@c0623"},{"ten":"Tôn Tích","tag":"ho-hang","quanHe":"Lão tổ Tôn Gia, nhắc tới Tôn Tuyết Sơn như vãn bối trong tộc.","ghiChu":"@c0623"}],"tuiDo":{}},"nguon":["@c0623"]},{"id":"tu-si-ngoai-lai-huyen-gia","name":"Tu sĩ ngoại lai (tộc nhân Huyễn Gia)","cn":"","aliases":[],"gioiTinh":"khong-ro","theLuc":[{"ten":"Huyễn Gia","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"không rõ","trangThai":"tu-vong","blurb":"Tu sĩ ngoại lai bị trọng thương sau đấu pháp, chạy đến Thiên Vận Tinh thì bị ba người cướp đan dược và giết; mang lệnh bài Chủ Tinh Thiên Huyễn của Huyễn Gia.","vaiTro":"Nhân vật phụ được nhắc tên","tinhCach":[],"tabs":{"diem":[{"text":"Tộc nhân Huyễn Gia, chết khiến mọi kẻ động vào di vật vướng nguy cơ bị diệt tộc.","chuong":"@c0623"}],"kinhLich":[{"text":"Bốn năm trước, bị trọng thương sau đấu pháp, chạy đến Thiên Vận Tinh thì bị Tôn Tích, lão tổ Nhiễm Gia và Tiêu Diêu Cư Sĩ đồng thời xuất thủ cướp năm viên bát phẩm đan dược; chết trong tay lão tổ Nhiễm Gia. Trong túi trữ vật có lệnh bài Chủ Tinh Thiên Huyễn.","bridge":true,"khoang":"@c0623"}],"nhanMach":[{"ten":"Lão tổ Nhiễm Gia","tag":"doi-thu","quanHe":"Bị lão tổ Nhiễm Gia giết và cướp đan dược.","ghiChu":"@c0623"},{"ten":"Tôn Tích","tag":"doi-thu","quanHe":"Một trong ba người cùng cướp đan dược.","ghiChu":"@c0623"}],"tuiDo":{}},"nguon":["@c0623"]},{"id":"ton-thai","name":"Tôn Thái","gioiTinh":"nam","tabs":{"kinhLich":[{"text":"Ngồi phòng tầng ba Bảo Hợp Lâu, lão già tang thương nghe giọng người hô giá liền chấn động tâm thần dù tự nhủ giọng này “không phải của hắn”; lão tự ngẫm cả đời chỉ có cái tên “Tằng Ngưu” để lại dấu vết trong tâm thần, và ngờ vực vì sao lạc ấn đã giải trừ ở Đông Lâm Tinh mà vẫn còn. Lão đuổi theo người ra giá, ban đầu tưởng nhận lầm mà xin lỗi quay đi, đến khi bị gọi đích danh “Tôn Thái” thì kinh ngạc thất thanh nhận ra cố nhân Vương Lâm.","bridge":true,"khoang":"@c0624"},{"chuong":"@c0624","importance":"normal","tieuDe":"Bị đưa về phòng tra hỏi","text":"Tôn Thái cay đắng kể đã nghi ngờ mấy trăm năm vẫn không hiểu vì sao thần thông Cự Ma Tộc lão tổ lại đưa được lão tới La Thiên Tinh Vực. Vừa nhắc tới Đông Lâm Tinh thì bị Vương Lâm vung tay áo cuốn thuấn di vào cổng thành Bắc, đưa về phòng riêng và bảo lão giờ mới được nói."},{"text":"Tôn Thái — Đại trưởng lão Thi Âm Tông chi Chu Tước tinh năm xưa, nay tu vi tụt xuống Hóa Thần kỳ — nhận ra Vương Lâm đã biến đổi long trời lở đất từ quân cờ bậc thấp thành cao thủ khí tức sâu không lường từng giết tu sĩ Vấn Đỉnh, chấn động tâm thần đến mức sẵn lòng làm người hầu. Hắn kể bị truyền tống vào La Thiên tinh vực gần Đông Lâm tinh, làm tạp dịch cho Lữ gia gần trăm năm; tiết lộ Đông Lâm tinh có ba gia tộc Hứa-Lữ-Lưu cực mạnh, là địa ngục hỗn loạn, và Thi Âm Tông cùng Tứ Thánh tông là hai tông phái lớn nhất Liên minh tinh vực.","bridge":true,"khoang":"@c0625"},{"chuong":"@c0625","importance":"normal","tieuDe":"Tử khí và lời gửi gắm tro cốt","text":"Hoàng hôn lộ ra một tia tử khí trên thân Tôn Thái; tuổi thọ hắn chỉ còn hai mươi năm, đạo tâm đã bị trăm năm ở Đông Lâm tinh bóp nát nên dù khôi phục tu vi cũng vĩnh viễn không thể tăng tiến. Hắn cảnh báo Vương Lâm bát phẩm đan dược là âm mưu của Lão tổ Nhiễm gia, nhờ mang tro cốt về Ám Nguyệt tinh nơi có Thiên Sơn dưới chân là thôn trang quê cũ, rồi tặng túi trữ vật chứa tiên ngọc và tâm đắc luyện đan luyện khí để tạ ơn."},{"text":"Tôn Thái tập tễnh rời đi dưới ánh chiều tà sau khi tặng Vương Lâm túi trữ vật chứa hơn năm vạn tiên ngọc — cử chỉ giải khai khúc mắc. Hắn từ bỏ việc khôi phục tu vi và tâm tính không cam chịu suốt mấy trăm năm ở La Thiên tinh vực, vì gặp Vương Lâm mà rơi vào kết cục này rồi cũng vì Vương Lâm mà vứt bỏ hết thảy, giải thoát thống khổ. Yêu cầu duy nhất là xin Vương Lâm đưa hắn trở về quê nhà — thôn trang nhỏ dưới chân Thiên Sơn.","bridge":true,"khoang":"@c0626"}],"nhanMach":[{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Người hắn gửi gắm","ghiChu":"Tặng túi trữ vật, xin được đưa về quê nhà dưới chân Thiên Sơn."},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Cố nhân từ thời liên quan Cự Ma Tộc, được hắn nhận ra và đưa về tra hỏi","ghiChu":"Nghe giọng liền chấn động tâm thần, được gọi đích danh tại Bảo Hợp Lâu (@c0624)"},{"ten":"Cự Ma Tộc lão tổ","tag":"khac","quanHe":"Người năm xưa thi triển thần thông đưa Tôn Thái tới La Thiên Tinh Vực","ghiChu":"Uy lực vượt mức tưởng tượng, thành nghi vấn mấy trăm năm (@c0624)"},{"ten":"Tằng Ngưu","tag":"khac","quanHe":"Cái tên duy nhất để lại dấu vết trong tâm thần Tôn Thái","ghiChu":"Lão tự nhủ khi cố lý giải vì sao chấn động (@c0624)"},{"ten":"Vương Lâm","tag":"an-nhan","quanHe":"Người sẽ tiễn và đưa tro cốt về quê","ghiChu":"Năm xưa Tôn Thái từng cứu Vương Lâm khỏi lão tổ Cự Ma tộc; nay Vương Lâm hứa hai mươi năm sau tiễn hắn và mang tro cốt về Ám Nguyệt tinh."},{"ten":"Lão tổ Nhiễm gia","tag":"khac","quanHe":"Người thu nhận làm khách khanh","ghiChu":"Thu nhận Tôn Thái làm khách khanh ở Thành bảo hợp lâu vì hắn có kiến thức luyện đan luyện khí; Tôn Thái cho rằng việc đưa bát phẩm đan dược cho Vương Lâm là âm mưu của lão."}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0626","@c0624","@c0625"],"aliases":["Lão già tang thương"]},{"id":"huyen-phong-than","name":"Huyễn Phong Thần","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Gia chủ Huyễn gia; báo cáo lão tổ về việc tộc nhân mất tích, thầm nghi ngờ lão tổ định giao Huyễn gia cho người ngoài là Liễu Mi.","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Đa nghi, lo lắng quyền vị gia tộc","chuong":"@c0627"}],"tabs":{"diem":[{"text":"Gia chủ Huyễn gia, nghi ngờ lão tổ định giao gia tộc cho người ngoài","chuong":"@c0627"}],"kinhLich":[{"text":"Huyễn Phong Thần cung kính trước lão tổ Huyễn gia, giải thích người mất tích bốn năm trước chỉ là tộc nhân chi nhánh tu vi Vấn Đỉnh trung kỳ, người Huyễn gia quá đông không tra xét hết được. Sau khi rời phòng, hắn thầm nghĩ lão tổ già rồi, vì một người ngoài (Liễu Mi) mà không tiếc thi triển Hoán huyết đại pháp, lại để Huyễn Mi lập uy, nghi ngờ lão tổ định giao Huyễn gia cho người đó.","bridge":true,"khoang":"@c0627"},{"chuong":"@c0627","importance":"normal","tieuDe":"Báo cáo lão tổ, nghi ngờ chuyện kế vị","text":"Cung kính trước lão tổ Huyễn gia, giải thích vì sao việc tộc nhân mất tích bốn năm trước nay mới xử lý: người mất tích chỉ là tộc nhân chi nhánh tu vi Vấn Đỉnh trung kỳ, người Huyễn gia quá đông không tra xét hết. Sau khi rời phòng, thầm nghĩ lão tổ già rồi, vì một người ngoài là Liễu Mi mà không tiếc thi triển Hoán huyết đại pháp, lại để Huyễn Mi lập uy, nghi ngờ lão tổ định giao Huyễn gia cho người đó."}],"nhanMach":[{"ten":"Lão tổ Huyễn Gia","tag":"ho-hang","quanHe":"Lão tổ gia tộc, được hắn báo cáo và thầm nghi ngờ","ghiChu":"@c0627"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Người ngoài hắn nghi lão tổ định giao Huyễn gia cho","ghiChu":"@c0627"},{"ten":"Lão tổ Huyễn gia","tag":"su-mon","quanHe":"Lão tổ trong tộc mà hắn báo cáo và cung kính, nhưng ngầm nghi ngờ","ghiChu":"@c0627"},{"ten":"Liễu Mi","tag":"khac","quanHe":"Người ngoài mà hắn nghi lão tổ định giao Huyễn gia cho","ghiChu":"@c0627"}],"tuiDo":{},"tuViMoc":[]},"nguon":["@c0627"]},{"id":"huyen-dong","name":"Huyễn Đông (thuộc hạ Liễu Mi)","cn":"","aliases":["Huyễn Đông","#huyen-dong-thuoc-ha-lieu-mi-627","#huyen-dong-toc-ve-huyen-gia-629"],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Vấn Đỉnh trung kỳ (đỉnh)","trangThai":"song","blurb":"Thuộc hạ của Liễu Mi, khoảng ba mươi tuổi, tu vi đỉnh Vấn Đỉnh trung kỳ; si mê nhan sắc Liễu Mi, được phái đi Nhiễm Vân tinh xử lý việc tộc nhân Huyễn gia mất tích. (+) Nhị phẩm tộc vệ của Huyễn gia trên Thiên Huyễn chủ tinh, được tiểu thư phái đến Nhiễm Vân tinh diệt người tham dự nhưng bị Vương Lâm đánh trọng thương phải bỏ chạy. [CAN-SOAT-GOP]","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Si mê nhan sắc Liễu Mi, tự tin về thực lực","chuong":"@c0627"}],"tabs":{"diem":[{"text":"Si mê Liễu Mi, hứa làm nhanh gọn dứt khoát việc Nhiễm Vân tinh","chuong":"@c0627"},{"text":"Tu vi đỉnh Vấn Đỉnh trung kỳ, khoảng ba mươi tuổi","chuong":"@c0627"},{"text":"Si mê Liễu Mi, được nàng phái đi Nhiễm Vân tinh","chuong":"@c0627"},{"text":"Nhị phẩm tộc vệ Huyễn gia trên Thiên Huyễn chủ tinh.","chuong":"@c0629"},{"text":"Tu Tâm Ý Ngũ Hành quyết (kim bí quyết) vì tư chất không hợp Thiên Đạo Vô tình.","chuong":"@c0629"}],"kinhLich":[{"text":"Huyễn Đông là thuộc hạ của Liễu Mi, khoảng ba mươi tuổi, tu vi đỉnh Vấn Đỉnh trung kỳ. Vì si mê nhan sắc Liễu Mi, hắn nhận đi Nhiễm Vân tinh xử lý việc tộc nhân mất tích, hứa làm nhanh gọn dứt khoát. Hắn cho rằng người tu vi cao nhất Nhiễm Vân tinh chỉ là lão tổ Nhiễm gia (cũng Vấn Đỉnh trung kỳ) nên không lo.","bridge":true,"khoang":"@c0627"},{"text":"Đạp tinh la bàn gào thét lao vào Nhiễm Vân tinh, thần thức điên cuồng tản ra tạo cảnh thần tiên giáng trần, tự xưng nhị phẩm tộc vệ Huyễn gia, gọi tu sĩ Vấn Đỉnh ra gặp; tiếng quát chấn động khiến nhiều tu sĩ yếu phun máu. Khi giao thủ với Vương Lâm bị Tịch Diệt chỉ nhuốm điện quang đánh phun máu, điện quang vờn quanh nguyên thần đau đớn; kinh hãi nhận ra đối phương không phải người bản tinh, vỗ đùi tăng tốc Na Di bỏ chạy về bẩm báo tiểu thư.","bridge":true,"khoang":"@c0629"},{"text":"Tộc vệ Huyễn gia (tu vi Vấn Đỉnh trung kỳ) phụng mệnh gia tộc tới Nhiễm Vân tinh, bị Vương Lâm dùng Thất Tinh kiếm trận bắt sống. Hắn đe dọa và cầu xin ba lão tổ Nhiễm gia, phơi bày việc người Huyễn gia bốn năm trước bị ba nhà giết, tiết lộ Lão tổ Huyễn gia đã trở về và chuyện tiểu thư Huyễn Mi. Cuối cùng bị Vương Lâm dùng Sưu hồn thuật moi trí nhớ rồi bóp chết, nguyên thần thu vào Tôn hồn phiên.","bridge":true,"khoang":"@c0630"},{"text":"Được Liễu Mi phái đi Nhiễm Vân tinh xử lý việc tộc nhân Huyễn gia mất tích bốn năm trước. Vì si mê nhan sắc Liễu Mi, hắn hứa làm nhanh gọn dứt khoát; cho rằng Nhiễm Vân tinh người tu vi cao nhất chỉ là lão tổ Nhiễm gia (cũng Vấn Đỉnh trung kỳ) nên không hề lo lắng.","bridge":true,"khoang":"@c0627"},{"text":"Huyễn Đông đạp tinh la bàn gào thét lao vào Nhiễm Vân tinh, thần thức điên cuồng tản ra tạo cảnh thần tiên giáng trần, tự xưng nhị phẩm tộc vệ Huyễn gia gọi tu sĩ Vấn Đỉnh ra gặp. Tiếng quát như sấm khiến tu sĩ tu vi thấp phun máu; danh Huyễn gia làm ba người Nhiễm gia tái nhợt.","bridge":true,"khoang":"@c0629"},{"chuong":"@c0629","importance":"normal","tieuDe":"Bại trận, bỏ chạy bẩm báo tiểu thư","text":"Đối đầu Vương Lâm, hắn bấm pháp quyết kim bí quyết của Tâm Ý Ngũ Hành quyết rồi vỗ túi trữ vật lấy kim kiếm đỡ Tịch Diệt chỉ. Kim kiếm vỡ vụn, hắn bị đánh phun máu, điện quang vờn quanh nguyên thần đau đớn; kinh hãi nhận ra tu vi đối phương đáng sợ không phải người bản tinh, hắn tăng tốc Na Di rời đi."},{"chuong":"@c0630","importance":"normal","tieuDe":"Bị bắt và tử vong","text":"Bị Thất Tinh kiếm trận của Vương Lâm kéo ra khỏi hư vô và khống chế nguyên thần. Mặt tái xanh, hắn quát ba lão tổ Nhiễm gia, dọa rằng phụng mệnh gia tộc nên giết hắn vô ích, phơi bày việc ba nhà giết người Huyễn gia bốn năm trước, tiết lộ Lão tổ Huyễn gia đã trở về và Huyễn Mi là đệ tử duy nhất sẽ làm gia chủ tương lai. Cuối cùng bị Vương Lâm dùng Sưu hồn thuật moi trí nhớ rồi bóp chết, máu thịt nguyên thần bị thu vào Tôn hồn phiên."}],"nhanMach":[{"ten":"Liễu Mi","tag":"cap-tren","quanHe":"Chủ nhân; Huyễn Đông si mê nàng và nhận việc thay nàng","ghiChu":"@c0627"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm (giả danh Hứa Mộc) dùng Tịch Diệt chỉ đánh trọng thương khi cố diệt người tham dự.","ghiChu":"@c0629"},{"ten":"Tiểu thư","tag":"cap-tren","quanHe":"Chủ nhân ra lệnh cho hắn diệt người tham dự; hắn muốn lập công để được để ý, định chạy về bẩm báo.","ghiChu":"@c0629"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm bắt sống, moi trí nhớ và bóp chết.","ghiChu":"@c0630"},{"ten":"Nhiễm Học Phong","tag":"doi-thu","quanHe":"Bị giao cho ba lão tổ Nhiễm gia xử lý sau khi bị bắt.","ghiChu":"@c0630"},{"ten":"Lão tổ Huyễn Gia","tag":"su-mon","quanHe":"Tộc vệ phụng mệnh Lão tổ Huyễn gia tới Nhiễm Vân tinh.","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"cap-tren","quanHe":"Chủ nhân mà hắn si mê, được nàng phái đi xử việc","ghiChu":"@c0627"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm (danh Hứa Mộc) đánh vỡ kim kiếm, trọng thương phải bỏ chạy.","ghiChu":"@c0629"},{"ten":"Tiểu thư","tag":"cap-tren","quanHe":"Chủ nhân ra lệnh đến diệt người tham dự; Huyễn Đông muốn lập công để được để ý, định chạy về bẩm báo.","ghiChu":"@c0629"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm bắt sống, moi trí nhớ rồi bóp chết","ghiChu":"@c0630"},{"ten":"Lão tổ Huyễn gia","tag":"su-mon","quanHe":"Phụng mệnh Lão tổ Huyễn gia tới Nhiễm Vân tinh","ghiChu":"@c0630"},{"ten":"Nhiễm Học Phong","tag":"doi-thu","quanHe":"Bị giao cho lão xử lý, từng đe dọa ba lão tổ","ghiChu":"@c0630"},{"ten":"Triệu Truyền Văn","tag":"doi-thu","quanHe":"Điểm danh lão giết người Huyễn gia bốn năm trước","ghiChu":"@c0630"}],"tuiDo":{},"tuViMoc":[{"chuong":"@c0627","canhGioi":"Vấn Đỉnh","text":"Tu vi đỉnh Vấn Đỉnh trung kỳ.","importance":"minor"}]},"nguon":["@c0627","@c0629","@c0630"]},{"id":"hua-moc","name":"Hứa Mộc","gioiTinh":"nam","trangThai":"tu-vong","tabs":{"kinhLich":[{"text":"Hứa Mộc là người lo việc bốn năm trước cho Nhiễm gia và nay đã chết. Lão tổ Nhiễm gia nhắc tới hắn khi tự nhủ về nguồn cơn nhân quả của việc tàn sát người Huyễn gia.","bridge":true,"khoang":"@c0627"},{"chuong":"@c0627","importance":"minor","tieuDe":"Được nhắc khi đã chết","text":"Lão tổ Nhiễm gia nhắc tới Hứa Mộc khi tự nhủ — người lo liệu việc bốn năm trước cho Nhiễm gia, nay đã chết."}],"nhanMach":[{"ten":"Lão tổ Nhiễm Gia","tag":"khac","quanHe":"Người lo việc bốn năm trước cho Nhiễm gia","ghiChu":"@c0627"},{"ten":"Lão tổ Nhiễm gia","tag":"khac","quanHe":"Người lo liệu việc bốn năm trước cho Nhiễm gia, được lão tổ nhắc tới sau khi đã chết","ghiChu":"@c0627"}]},"nguon":["@c0627"]},{"id":"tieu-thu-chu-huyen-dong","name":"Tiểu thư (chủ nhân Huyễn Đông)","cn":"","aliases":["Tiểu thư"],"gioiTinh":"nu","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không-ro","trangThai":"song","blurb":"Chủ nhân ra lệnh cho Huyễn Đông diệt người tham dự; danh tính chưa lộ, chỉ được nhắc tên.","vaiTro":"Nhân vật ẩn sau Huyễn Đông, báo trước thế lực Huyễn gia sẽ truy đến.","tinhCach":[],"tabs":{"diem":[{"text":"Ra lệnh diệt toàn bộ người tham dự; Huyễn Đông muốn lập công để được tiểu thư để ý.","chuong":"@c0629"}],"kinhLich":[{"text":"Ra lệnh cho Huyễn Đông giáng lâm Nhiễm Vân tinh diệt người tham dự; Huyễn Đông quyết làm nhanh gọn để được tiểu thư để ý, khi thua định chạy về bẩm báo.","bridge":true,"khoang":"@c0629"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Đông","tag":"khac","quanHe":"Tộc vệ Huyễn gia nhận lệnh của tiểu thư đi diệt người tham dự, lập công để được để ý.","ghiChu":"@c0629"}],"tuiDo":{}},"nguon":["@c0629"]},{"id":"thanh-nien-canh-dong-phu-thanh-bac-ton-gia","name":"Thanh niên canh giữ động phủ thành bắc","aliases":["#thanh-nien-canh-dong-phu-thanh-bac-ton-gia-c0616"],"gioiTinh":"nam","theLuc":[{"ten":"Tôn gia","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"Nguyên Anh kỳ","trangThai":"song","blurb":"Thanh niên tu vi Nguyên Anh kì canh giữ động phủ thành bắc Tôn gia, thu linh thạch cấp lệnh bài, thái độ khinh miệt với tu sĩ ngoại lai.","vaiTro":"Người canh giữ động phủ thành bắc","tinhCach":[{"text":"Khinh miệt, coi thường tu sĩ ngoại lai","chuong":"@c0616"}],"tabs":{"kinhLich":[{"text":"Thanh niên báo còn tám phòng trống, nhận trăm khối linh thạch của Vương Lâm rồi cấp lệnh bài phòng thứ năm phía tây; lẩm bẩm khinh miệt hắn là tu sĩ ngoại lai nhờ đan dược mới đạt Kết Đan.","bridge":true,"khoang":"@c0616"},{"text":"Báo cho Vương Lâm còn tám phòng trống: hảo hạng ngàn khối hạ phẩm linh thạch một năm, cấp dưới trăm khối. Nhận trăm khối của hắn rồi cấp lệnh bài phòng thứ năm phía tây, thầm khinh miệt cho rằng hắn lại là một tu sĩ ngoại lai tư chất tầm thường nhờ đan dược mới đạt Kết Đan.","bridge":true,"khoang":"@c0616"}],"nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Tu sĩ ngoại lai thuê phòng, bị y khinh miệt","ghiChu":""},{"ten":"Vương Lâm","tag":"khac","quanHe":"Vị tu sĩ ngoại lai thuê phòng cấp dưới mà hắn khinh miệt.","ghiChu":"@c0616"}],"tuiDo":{}},"nguon":["@c0616"]},{"id":"lo-phong","name":"Lô Phong","gioiTinh":"nam","theLuc":[{"ten":"Bảo Hợp Lâu","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Nguyên Anh","trangThai":"song","blurb":"Người đàn ông trung niên gác cửa Bảo Hợp Lâu, ngạo mạn, chặn và khinh thường Vương Lâm.","vaiTro":"Người phụ trách kiểm tra tiêu chuẩn người vào Bảo Hợp Lâu nhiều năm.","tinhCach":[{"text":"Ngạo mạn, khinh người, đánh giá tu sĩ qua tu vi và bề ngoài pháp bảo","chuong":"@c0618"}],"tabs":{"diem":[{"text":"Dùng nguyên tắc “hai không tiến, một không ra” chặn người vào Bảo Hợp Lâu","chuong":"@c0618"}],"kinhLich":[{"text":"Lô Phong ra chặn Vương Lâm, nêu quy củ dưới Nguyên Anh không tiến, dưới mười vạn linh thạch không tiến, vào rồi không giao dịch được không ra. Khi Vương Lâm trình phi kiếm, gã chỉ liếc mắt đã chê chất lượng cực thấp, kiếm quang tối tăm, từ chối thu. Bị ánh mắt Vương Lâm dội như nước lạnh, Nguyên Anh gần sụp đổ, mặt tái nhợt lùi vài bước, thoáng ngờ phi kiếm có chỗ khác biệt.","bridge":true,"khoang":"@c0618"}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Chặn và khinh thường Vương Lâm, bị ánh mắt hắn dọa cho Nguyên Anh gần sụp","ghiChu":""},{"ten":"Tôn lão","tag":"cap-tren","quanHe":"Kính nể Tôn lão ở Bảo Hợp Lâu, bẩm báo sự việc","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0618"]},{"id":"nu-tu-trong-buc-tranh","name":"Nữ tử trong bức tranh","cn":"","aliases":["Nữ tử trong tranh"],"gioiTinh":"nu","theLuc":[{"ten":"Hướng gia (Đông Lâm tinh)","trangThai":"gan-bo"}],"canhGioiCaoNhat":"không rõ","trangThai":"mat-tich","blurb":"Hồn/ý thức trong bức tranh, chỉ lộ bóng lưng, thuộc Hướng gia ở Đông Lâm tinh thuộc La Thiên tinh vực; dụ Vương Lâm đưa nàng về quê hương rồi bị phong ấn vĩnh viễn.","vaiTro":"Nhân vật bí ẩn dụ dỗ — đối thủ trí trá của Vương Lâm trong vùng đất yêu linh.","tinhCach":[{"text":"Khôn khéo, biết đánh vào điểm yếu để dụ dỗ; khi thất bại thì lộ vẻ ác độc gào thét đe dọa","chuong":"@c0612"}],"tabs":{"diem":[{"text":"Hồn nữ tử trong bức tranh, chỉ lộ bóng lưng nhưng toát vẻ hấp dẫn, nắm giữ nhiều bí mật về Thiên Nghịch châu và Tứ đại tiên giới","chuong":"@c0612"}],"kinhLich":[{"chuong":"@c0612","importance":"normal","tieuDe":"Dụ dỗ rồi bị phong ấn vĩnh viễn","text":"Sau mười ba năm im lặng, lần đầu mang cảm xúc van xin Vương Lâm mang nàng xuống đáy hố, dụ bằng lời hứa tiết lộ lai lịch Thiên Nghịch châu và cách cứu sống tàn hồn. Nàng kể truyền thuyết Tứ đại tiên giới, xưng thuộc Hướng gia ở Đông Lâm tinh thuộc La Thiên tinh vực (Lôi tiên giới), đề nghị Vương Lâm đưa nàng về quê hương qua dòng xoáy đổi lấy lời hứa tổ tiên cứu tàn hồn. Bị Vương Lâm nhận ra âm mưu, dụ dỗ rồi gào thét ác độc cũng vô ích, cuối cùng bị phong ấn triệt để bằng cấm chế và con rối Tiên Vệ, chôn sâu trong vách đá."}],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Dụ Vương Lâm đưa về La Thiên tinh vực nhưng bị hắn lật kèo phong ấn vĩnh viễn","ghiChu":"@c0612"},{"ten":"Hướng gia (Đông Lâm tinh)","tag":"ho-hang","quanHe":"Là người của Hướng gia ở Đông Lâm tinh","ghiChu":"@c0612"}],"tuViMoc":[],"tuVi":"Chưa rõ cảnh giới — tồn tại dưới dạng hồn/ý thức trong bức tranh.","tuiDo":{}},"nguon":["@c0612"]},{"id":"thanh-nien-ho-ton-c0624","name":"Thanh niên họ Tôn","gioiTinh":"nam","trangThai":"song","blurb":"Tu sĩ trẻ họ Tôn ở đại sảnh tầng hai Bảo Hợp Lâu, nhận ra giọng người ra giá.","vaiTro":"Nhân vật phụ thoáng qua tại phiên đấu giá.","tabs":{"diem":[],"kinhLich":[{"text":"Ở đại sảnh tầng hai, trợn mắt khó tin khi nghe giá một khối tiên ngọc; hắn nhận ra giọng nói chính là người nhiều ngày trước từng bị hắn cản không cho ra ngoài.","bridge":true,"khoang":"@c0624"}],"tuViMoc":[],"nhanMach":[{"ten":"Thanh niên họ Lô","tag":"khac","quanHe":"Cùng ở tầng hai bàn tán về người ra giá","ghiChu":"@c0624"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0624"]},{"id":"thanh-nien-ho-lo-c0624","name":"Thanh niên họ Lô","gioiTinh":"nam","trangThai":"song","blurb":"Tu sĩ trẻ họ Lô ở tầng hai Bảo Hợp Lâu, lẩm bẩm chê người ra giá điên.","vaiTro":"Nhân vật phụ thoáng qua tại phiên đấu giá.","tabs":{"diem":[],"kinhLich":[{"text":"Ở tầng hai, lẩm bẩm “Người này điên rồi” khi nghe ai đó ra giá một khối tiên ngọc cho món vật khởi điểm một vạn.","bridge":true,"khoang":"@c0624"}],"tuViMoc":[],"nhanMach":[{"ten":"Thanh niên họ Tôn","tag":"khac","quanHe":"Cùng ở tầng hai bàn tán về người ra giá","ghiChu":"@c0624"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0624"]},{"id":"su-gia-hong-bao-nhiem-gia-c0624","name":"Người đàn ông mặc hồng bào (sứ giả Nhiễm Gia)","gioiTinh":"nam","trangThai":"song","theLuc":[{"ten":"Nhiễm Gia","trangThai":"gan-bo"}],"blurb":"Sứ giả của Nhiễm Gia phụ trách rao bán “bát phẩm đan dược” tại Bảo Hợp Lâu, rơi vào thế tiến thoái lưỡng nan trước giá hời của Vương Lâm.","vaiTro":"Nhân vật phụ điều hành phiên đấu giá của Nhiễm Gia.","tabs":{"diem":[],"kinhLich":[{"text":"Mặc trường bào hồng sắc, cầm hộp ngọc mở ra viên thuốc to bằng nắm tay trẻ con rao là bát phẩm đan dược cực hiếm. Mục đích bán cho “một người đặc biệt”; lệnh bài đấu giá phát có chủ đích, sẵn sàng giết kẻ nào tùy tiện hét giá đoạt bảo. Hắn liên tục liếc lên tầng bốn.","bridge":true,"khoang":"@c0624"},{"chuong":"@c0624","importance":"normal","tieuDe":"Thế tiến thoái lưỡng nan","text":"Khi Vương Lâm ra giá một khối tiên ngọc, hắn cười khổ: nhận giá thì lộ việc bán có đầu mối lớn và để lộ Nhiễm Gia đang sợ hãi, không bán thì trái lệnh lão tổ. Cuối cùng cắn răng chấp nhận bán một khối tiên ngọc vì chỉ một người ra giá; viên thuốc liền bị Vương Lâm vung trảo đoạt mất."}],"tuViMoc":[],"nhanMach":[{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm hô giá thấp ép bán rồi đoạt bảo","ghiChu":"@c0624"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0624"]},{"id":"nguoi-tuoi-tre-phia-bac-thanh-c0628","name":"Người tuổi trẻ (tu sĩ ở phía bắc thành)","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Phàm/tu sĩ thấp","trangThai":"song","blurb":"Tu sĩ trẻ lòng dạ thiện lương ở phía bắc thành Nhiễm Vân tinh, từng gặp Vương Lâm; được Vương Lâm tiên đoán có thể đạt Hóa Thần.","vaiTro":"Nhân vật phụ thoáng qua.","tinhCach":[{"text":"Lòng dạ thiện lương, chân chất.","chuong":"@c0628"}],"tabs":{"diem":[{"text":"Tu sĩ trẻ thiện lương, từng biết Vương Lâm bị người bắt đi, vui mừng khi thấy hắn quay về.","chuong":"@c0628"}],"kinhLich":[{"text":"Ngồi khoanh chân trên tảng đá ở phía bắc thành Nhiễm Vân tinh, ngạc nhiên vui mừng khi thấy Vương Lâm quay về. Vương Lâm khích lệ y giữ nguyên tâm cảnh hiện giờ thì có thể đạt tới Hóa Thần; y tưởng là lời an ủi, hứa nếu một ngày Hóa Thần sẽ nhớ lời tiên đoán này, rồi lẩm bẩm hoài nghi liệu mình có thật sự Hóa Thần.","bridge":true,"khoang":"@c0628"}],"tuViMoc":[],"tuVi":"Tu sĩ trẻ cảnh giới thấp ở Nhiễm Vân tinh.","nhanMach":[{"ten":"Vương Lâm","tag":"khac","quanHe":"Người được hắn khích lệ giữ tâm cảnh để đạt Hóa Thần.","ghiChu":"Gặp lại @c0628."}],"tuiDo":{}},"nguon":["@c0628"]},{"id":"tieu-thu-huyen-gia-629","name":"Tiểu thư","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"khong-ro","trangThai":"khong-ro","blurb":"Chủ nhân ra lệnh cho Huyễn Đông đến Nhiễm Vân tinh diệt người tham dự; Huyễn Đông khao khát được nàng để ý và định chạy về bẩm báo khi thua.","vaiTro":"Nhân vật được nhắc tên — thế lực phía sau Huyễn Đông, báo trước Huyễn gia truy đến.","tinhCach":[],"tabs":{"diem":[{"text":"Người ra lệnh cho Huyễn Đông diệt toàn bộ người tham dự ở Nhi��m Vân tinh.","chuong":"@c0629"}],"kinhLich":[{"text":"Được nhắc tên qua lời Huyễn Đông: chủ nhân ra lệnh cho hắn đến diệt người tham dự, Huyễn Đông muốn làm nhanh gọn để được nàng để ý và định bẩm báo nếu thua.","bridge":true,"khoang":"@c0629"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Đông","tag":"khac","quanHe":"Thuộc hạ/tộc vệ thừa lệnh của tiểu thư đến Nhiễm Vân tinh.","ghiChu":"@c0629"}]},"nguon":["@c0629"]},{"id":"nguoi-tre-tuoi-nui-da-ton-gia-thanh-629","name":"Người trẻ tuổi dưới núi đá ở Tôn gia thành","cn":"","aliases":[],"gioiTinh":"nam","theLuc":[],"canhGioiCaoNhat":"Phàm/tu vi thấp","trangThai":"song","blurb":"Tu sĩ tu vi thấp đang thổ nạp dưới núi đá ở Tôn gia thành, bị tiếng quát của Huyễn Đông chấn động tâm mạch phun máu.","vaiTro":"Nhân vật phụ thoáng qua minh họa uy lực tiếng quát của Huyễn Đông.","tinhCach":[],"tabs":{"diem":[{"text":"Tu sĩ tu vi thấp ở Tôn gia thành, bị thanh âm Huyễn Đông chấn động phun máu.","chuong":"@c0629"}],"kinhLich":[{"text":"Đang thổ nạp dưới núi đá ở Tôn gia thành thì bị thanh âm như sấm của Huyễn Đông chấn động tâm mạch, phun máu.","bridge":true,"khoang":"@c0629"}],"tuViMoc":[],"nhanMach":[{"ten":"Huyễn Đông","tag":"khac","quanHe":"Bị tiếng quát của Huyễn Đông chấn động chấn thương.","ghiChu":"@c0629"}]},"nguon":["@c0629"]},{"id":"trieu-truyen-van-lao-to-630","name":"Triệu Truyền Văn","cn":"","aliases":["Tiêu Dao tán nhân"],"gioiTinh":"nam","theLuc":[{"ten":"Tu chân Liên minh","trangThai":"danh-nghia"}],"canhGioiCaoNhat":"","trangThai":"song","blurb":"Một trong ba lão tổ liên minh chống Huyễn gia, bị Huyễn Đông điểm danh là kẻ đã tham gia giết người Huyễn gia bốn năm trước.","vaiTro":"Lão tổ liên minh, mục tiêu trả thù của Huyễn gia.","tinhCach":[{"text":"Lạnh lùng, lộ sát khí khi bị đe dọa","chuong":"@c0630"}],"tabs":{"diem":[{"text":"Bị Huyễn Đông điểm danh là kẻ giết người Huyễn gia bốn năm trước","chuong":"@c0630"}],"kinhLich":[{"chuong":"@c0630","importance":"normal","tieuDe":"Bị Huyễn Đông phơi bày cừu hận","text":"Cùng Nhiễm Học Phong, Tôn Tích bị Huyễn Đông quát muốn chết, phơi bày việc ba nhà giết người Huy���n gia bốn năm trước và đe dọa huyết mạch ba nhà chấm dứt; lão lộ tia sáng lạnh lẽo cùng hai lão tổ kia."},{"chuong":"@c0633","importance":"normal","tieuDe":"Bị mê hoặc tự bạo mà chết","text":"Một trong ba lão tổ, thuộc Triệu gia, tên thật Triệu Truyền Văn. Cùng bàn kết cục rồi quyết tử chiến thiêu nguyên thần. Bị Thiên Huyễn Vô tình đạo của Liễu Mi mê hoặc, si mê mất chiến ý, quay sang đánh Nhiễm Học Phong, thiêu cả thân thể lẫn nguyên thần khiến tu vi tăng vọt rồi tự bạo mà chết."}],"tuViMoc":[],"nhanMach":[{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Cùng lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng lão tổ liên minh chống Huyễn gia","ghiChu":"@c0630"},{"ten":"Huyễn Đông","tag":"doi-thu","quanHe":"Tộc vệ Huyễn gia điểm danh lão giết người Huyễn gia bốn năm trước","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"doi-thu","quanHe":"Kẻ mê hoặc","ghiChu":"Bị Vô tình đạo mê hoặc dẫn tới tự bạo. @c0633"},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Đồng cảnh ngộ ba lão tổ","ghiChu":"Bị mê hoặc quay sang đánh Nhiễm Học Phong. @c0633"},{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Đồng cảnh ngộ ba lão tổ","ghiChu":"Cùng chịu chung kết cục tự bạo. @c0633"}],"tuiDo":{}},"nguon":["@c0630","@c0633"]},{"id":"lao-to-huyen-gia-630","name":"Lão tổ Huyễn gia","cn":"","aliases":["#lao-to-nhiem-gia-lao-to-huyen-gia"],"gioiTinh":"nam","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"canhGioiCaoNhat":"Âm Dương Hư Thực","trangThai":"song","blurb":"Lão tổ Huyễn gia vừa trở về, tu vi đã bước vào bước thứ hai (cảnh giới Âm Dương Hư Thực từ mấy ngàn năm trước), trong tay có Tiên Vệ; mang Liễu Mi về làm con gái nuôi và ra lệnh phong tỏa Nhiễm Vân tinh. (+) Lão già khuôn mặt gầy yếu, lão tổ Huyễn gia ở Thiên Huyễn tinh; người mang Liễu Mi từ Liên minh tinh v��c về và thi triển Hoán huyết đại pháp vì nàng. [CAN-SOAT-GOP]","vaiTro":"Lão tổ tối cao Huyễn gia, mối uy hiếp lớn cài cắm cho tuyến xung đột sau này.","tinhCach":[{"text":"Lão luyện, biết kìm nén để ưu tiên đại sự","chuong":"@c0630"}],"tabs":{"diem":[{"text":"Tu vi Âm Dương Hư Thực, đã bước vào bước thứ hai, có Tiên Vệ trong tay","chuong":"@c0630"},{"text":"Mang Liễu Mi từ Liên Minh Tinh Vực về làm con gái nuôi kiêm đệ tử duy nhất","chuong":"@c0630"}],"kinhLich":[{"chuong":"@c0630","importance":"normal","tieuDe":"Trở về, lập Huyễn Mi và phong tỏa Nhiễm Vân tinh","text":"Vừa trở về, Lão tổ Huyễn gia mang một cô gái từ Liên Minh Tinh Vực về thu làm con gái nuôi (Huyễn Mi), sắp thi triển Hoán huyết đại pháp đổi huyết mạch cho nàng. Khi Huyễn Đông chết, lão giận tím mặt nhưng áp chế đề nghị tiêu diệt Nhiễm Vân tinh, ưu tiên hoàn thành Hoán huyết đại pháp; giao việc trả thù cho Huyễn Mi tự xử lý để lập uy, đồng thời bố trí Tỏa tinh đại trận vây Nhiễm Vân tinh."},{"text":"Lão tổ chủ trì Hoán huyết đại pháp: hút cạn nước đầm, gom máu mấy vạn tộc nhân Huyễn gia, tự cắt cổ tay đổ máu nhiều nhất, dung hợp luyện hóa thành ngàn huyết phù. Lão thi triển Vạn Huyễn Vô Tướng đạo đả đạo niệm vào nguyên thần Liễu Mi và trào hết tiên lực nâng tu vi nàng, tự lấy giá giảm hai trăm năm tu vi khiến cánh tay héo rút, người càng già nua.","bridge":true,"khoang":"@c0631"},{"chuong":"@c0631","importance":"normal","tieuDe":"Cảnh báo vật oán khí rồi bế quan","text":"Lão cảnh báo Liễu Mi giết bỏ vật oán khí kẻo hỏng đạo tâm; tiết lộ tổ tiên Huyễn gia từng là tiên nhân Lôi tiên giới (đã hủy) mà huyết mạch còn lưu. Dặn nàng nối nghiệp Huyễn gia, tò mò bước hai của Vạn Huyễn Thiên ma đạo sẽ sinh thần thông gì, rồi biến mất bế quan."},{"text":"Vừa thu Huyễn Mi làm con gái nuôi; chủ trương ra tay với ba nhà trên Nhiễm Vân tinh, bố trí Tỏa tinh đại trận vây tinh cầu để lập uy cho con gái nuôi và đề phòng họ chạy thoát.","bridge":true,"khoang":"@c0632"},{"text":"Trong tổ trạch Huyễn gia tại Thiên Huyễn tinh phía nam, lão tổ Huyễn gia tra hỏi gia chủ Huyễn Phong Thần vì sao việc tộc nhân mất tích bốn năm trước nay mới xử lý. Lão cho thêm ba tháng tìm người đủ tư cách hơn, lệnh phái tộc vệ cho Huyễn Mi (Liễu Mi) đi nhổ tận gốc mọi người liên quan để giữ uy danh Huyễn gia. Lão từng không tiếc thi triển Hoán huyết đại pháp vì Liễu Mi.","bridge":true,"khoang":"@c0627"},{"chuong":"@c0630","importance":"major","tieuDe":"Trở về, mang Liễu Mi làm con gái nuôi","text":"Lão tổ Huyễn gia vừa trở về, tu vi đã bước vào bước thứ hai — cảnh giới Âm Dương Hư Thực từ mấy ngàn năm trước, có Tiên Vệ trong tay. Hắn mang một cô gái từ Liên Minh Tinh Vực (Liễu Mi) về thu làm con gái nuôi kiêm đệ tử duy nhất, sắp thi triển Hoán huyết đại pháp đổi huyết mạch. Khi Huyễn Đông chết, hắn áp chế ý muốn tiêu diệt Nhiễm Vân tinh, ưu tiên hoàn thành Hoán huyết đại pháp, giao việc trả thù cho Huyễn Mi tự xử để lập uy, bố trí Tỏa tinh đại trận vây Nhiễm Vân tinh."},{"chuong":"@c0631","importance":"normal","tieuDe":"Chủ trì Hoán huyết, truyền công Liễu Mi","text":"Lão tổ hút cạn nước đầm, gom máu mấy vạn tộc nhân Huyễn gia luyện thành một ngàn huyết phù, chủ trì Hoán huyết đại pháp dung nhập huyết mạch Huyễn gia vào thân Liễu Mi. Lão thi triển Vạn Huyễn Vô Tướng đạo đả đạo niệm vào nguyên thần nàng, trào hết tiên lực tự tổn hại tu vi để nâng nàng lên Vấn Đỉnh hậu kỳ đại viên mãn, rồi dặn nàng nối nghiệp Huyễn gia và bế quan tu vào Âm Dương Hư Thực."}],"tuViMoc":[{"chuong":"@c0630","canhGioi":"Âm Dương Hư Thực","text":"Mấy ngàn năm trước đã đạt cảnh giới Âm Dương Hư Thực, nay tu vi đã bước vào bước thứ hai.","importance":"major"},{"chuong":"@c0631","canhGioi":"Đại thần thông Khuy Niết sơ kỳ","text":"Là tu sĩ đại thần thông Khuy Niết sơ kỳ (bước thứ hai tu đạo); đạo của lão là Vạn Huyễn Vô Tướng đạo. Sau khi tổn hại tu vi truyền công Liễu Mi thì già nua đi.","importance":"major"},{"chuong":"@c0631","canhGioi":"Đại thần thông Khuy Niết sơ kỳ","text":"Lão tổ là tu sĩ đại thần thông Khuy Niết sơ kỳ (bước thứ hai của tu đạo), tu Vạn Huyễn Vô Tướng đạo; sau khi tổn hại tu vi truyền công, cánh tay héo rút và người càng già nua.","importance":"major"}],"nhanMach":[{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Con gái nuôi kiêm đệ tử duy nhất, định lập làm gia chủ Huyễn gia tương lai","ghiChu":"@c0630"},{"ten":"Huyễn Đông","tag":"su-mon","quanHe":"Tộc vệ phái tới Nhiễm Vân tinh; chết khiến lão phong tỏa Nhiễm Vân tinh","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Nghĩa nữ / đệ tử nối nghiệp","ghiChu":"Truyền công nâng tu vi, trao huyết mạch Huyễn gia; muốn nàng nối nghiệp gia tộc."},{"ten":"Huyễn Mi","tag":"ho-hang","quanHe":"Con gái nuôi mới thu","ghiChu":""},{"ten":"Liễu Mi","tag":"ho-hang","quanHe":"Nghĩa nữ, được lão mang về từ Liên minh tinh vực và thi triển Hoán huyết đại pháp vì nàng","ghiChu":"@c0627"},{"ten":"Huyễn Phong Thần","tag":"ho-hang","quanHe":"Gia chủ Huyễn gia, được lão tra hỏi việc tộc nhân mất tích","ghiChu":"@c0627"},{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Mang về từ Liên Minh Tinh Vực, thu làm con gái nuôi kiêm đệ tử duy nhất, định lập làm gia chủ tương lai.","ghiChu":"@c0630"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Cường giả Âm Dương Hư Thực mà Vương Lâm tự lượng không dám liều chết; mầm đối đầu giữa hai bên.","ghiChu":"@c0630"},{"ten":"Huyễn Đông","tag":"khac","quanHe":"Tộc vệ Huyễn gia, bị giết khi tới Nhiễm Vân tinh phụng mệnh hắn.","ghiChu":"@c0630"},{"ten":"Liễu Mi","tag":"su-mon","quanHe":"Nghĩa nữ / đệ tử nối nghiệp","ghiChu":"Lão tổ truyền huyết mạch và công pháp, nâng tu vi cho nàng để nối nghiệp Huyễn gia."}],"tuiDo":{}},"nguon":["@c0630","@c0631","@c0632","@c0627"]},{"id":"tieu-dao-tan-nhan","name":"Tiêu Dao tán nhân (Triệu mỗ)","cn":"","aliases":["Triệu mỗ","Tiêu Dao tán nhân","#lao-to-nhiem-gia-tieu-dao-tan-nhan"],"gioiTinh":"nam","theLuc":[],"trangThai":"song","blurb":"Người đàn ông trung niên họ Triệu, tu luyện trong sông băng, liên can việc bốn năm trước; bị Vương Lâm ép nộp tiên ngọc và di vật người Huyễn gia. (+) Một trong ba lão tổ trú trên Nhiễm Vân tinh, cảnh báo Huyễn gia ra tay không chỉ dừng ở Tỏa tinh đại trận. [CAN-SOAT-GOP]","vaiTro":"Nhân vật phụ","tinhCach":[{"text":"Cẩn trọng, nhìn xa","chuong":"@c0632"}],"tabs":{"diem":[],"kinhLich":[{"text":"Đứng cùng Lão tổ Nhiễm gia và Tôn Tích trên Nhiễm Vân tinh, trầm giọng cho rằng Huyễn gia ra tay không chỉ dừng ở việc bố trí Tỏa tinh đại trận.","bridge":true,"khoang":"@c0632"},{"text":"Tiêu Dao tán nhân là người đàn ông trung niên họ Triệu, từng tu luyện trong sông băng (huyền băng), thuộc một gia tộc nhỏ. Bị Vương Lâm ép hiện thân, hắn chấp nhận nộp chín phần tiên ngọc cùng đan dược thừa, túi trữ vật và toàn bộ di vật người Huyễn gia chết bốn năm trước; nếu tiên ngọc không đủ phải đi kiếm thêm. Sau đó hắn về gia tộc chuẩn bị tiên ngọc.","bridge":true,"khoang":"@c0627"},{"chuong":"@c0627","importance":"normal","tieuDe":"Hiện thân, nộp tiên ngọc và di vật","text":"Người đàn ông trung niên từng tu luyện trong sông băng huyền băng, họ Triệu, thuộc gia tộc nhỏ tiên ngọc không nhiều. Bị Vương Lâm ép hiện thân, chấp nhận nộp chín phần tiên ngọc cùng đan dược thừa, túi trữ vật và toàn bộ di vật người Huyễn gia chết bốn năm trước; nếu tiên ngọc không đủ phải đi kiếm thêm. Sau đó về gia tộc chuẩn bị tiên ngọc."}],"tuViMoc":[],"nhanMach":[{"ten":"Tôn Tích","tag":"dong-minh","quanHe":"Cùng đối phó Huyễn gia trên Nhiễm Vân tinh","ghiChu":""},{"ten":"Nhiễm Học Phong","tag":"dong-minh","quanHe":"Lão tổ Nhiễm gia, cùng bàn việc Tỏa tinh đại trận","ghiChu":""},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm ép nộp tiên ngọc và di vật Huyễn gia","ghiChu":"@c0627"},{"ten":"Vương Lâm","tag":"doi-thu","quanHe":"Bị Vương Lâm (danh Hứa mỗ) ép nộp tiên ngọc, đan dược và di vật","ghiChu":"@c0627"}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0632","@c0627"]},{"id":"huyen-mi-con-gai-nuoi-huyen-gia-632","name":"Huyễn Mi","cn":"","aliases":[],"gioiTinh":"nu","theLuc":[{"ten":"Huyễn gia","trangThai":"gan-bo"}],"trangThai":"song","blurb":"Con gái nuôi mới thu của lão tổ Huyễn gia; Tỏa tinh đại trận giáng lâm Nhiễm Vân tinh được cho là để lập uy cho nàng.","vaiTro":"Nhân vật phụ (mới nhắc tên)","tinhCach":[],"tabs":{"diem":[],"kinhLich":[{"chuong":"@c0632","importance":"normal","tieuDe":"Được lập uy bằng Tỏa tinh đại trận","text":"Mới được lão tổ Huyễn gia thu làm con gái nuôi; Lão tổ Nhiễm gia phỏng đoán việc Huyễn gia hạ Tỏa tinh đại trận xuống Nhiễm Vân tinh nhằm lập uy cho nàng."}],"tuViMoc":[],"nhanMach":[{"ten":"Lão tổ Huyễn gia","tag":"su-mon","quanHe":"Cha nuôi, gia chủ Huyễn gia","ghiChu":"Mới thu nàng làm con gái nuôi"},{"ten":"Nhiễm Học Phong","tag":"doi-thu","quanHe":"Lão tổ Nhiễm gia thuộc phe bị Huyễn gia nhắm diệt","ghiChu":""}],"tuiDo":{"phapBao":[],"danDuoc":[],"congPhap":[],"linhThu":[],"nguyenLieu":[],"linhThao":[],"khac":[]}},"nguon":["@c0632"]}]};